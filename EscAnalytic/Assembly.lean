    {ι : Type*}
    (cls : ℕ → Finset ι)
    (Mb : ℕ → ι → ℝ)
    (Pz μ εb : ℕ → ℝ)
    (δb Δb errTerm F2R : ℕ → ι → ℝ)
    (weights : ℕ → ι → List ℚ)
    (M Xq : ℕ → ι → ℚ)
    (R : ℕ → ι → ℕ)
    (εK : ℝ) (T : ℕ)
    (hweights_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      ∀ w, w ∈ weights N b → 0 ≤ w)
    (hmass : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      (weights N b).sum ≤ M N b)
    (hMle : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      (M N b : ℝ) ≤ (1 + εK) * μ N)
    (hXq : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 1 ≤ Xq N b)
    (hμ : ∀ N : ℕ, 3 ≤ N → T ≤ N → 0 < μ N)
    (hPz : ∀ N : ℕ, 3 ≤ N → T ≤ N → 1 ≤ Pz N)
    (hδ_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 0 ≤ δb N b)
    (hΔ_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 0 ≤ Δb N b)
    (hsuen_tail : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      Inputs.suenTailConstant * Δb N b * Real.exp (2 * δb N b) ≤ εb N * μ N)
    (hdecomp : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      Mb N b ≤ ((N : ℝ) / Pz N) *
        (Inputs.suenProb (μ N) (δb N b) (Δb N b) + F2R N b) + errTerm N b)
    (herr_raw : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      errTerm N b ≤
        ∑ r ∈ Finset.range (2 * R N b + 1),
          (Xq N b : ℝ) ^ r * (EscLeanChecks.elemSymmList (weights N b) r : ℝ))
    (hεle : εK ≤ 1)
    (hlevel : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      Pz N * ((Xq N b : ℝ) ^ (2 * R N b)) * Real.exp (2 * μ N)
        ≤ (N : ℝ) * Real.exp (-4 * μ N))
    (hF2R_raw : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      F2R N b ≤ (EscLeanChecks.elemSymmList (weights N b) (2 * R N b) : ℝ))
    (hF2R_tail : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      ((M N b : ℝ) ^ (2 * R N b)) / (Nat.factorial (2 * R N b) : ℝ)
        ≤ Real.exp (-3 * μ N)) :
    ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      Mb N b
        ≤ ((N : ℝ) / Pz N) * Real.exp (-(1 - (εb N + Real.log 3 / μ N)) * μ N) := by
  intro N hN hTN b hb
  rcases Inputs.suenProb_bound_with_suenTailConstant
      (μ N) (δb N b) (Δb N b)
      (le_of_lt (hμ N hN hTN)) (hδ_nonneg N hN hTN b hb)
      (hΔ_nonneg N hN hTN b hb) with
    ⟨_htail_pos, _hrange, _hprob_nonneg, _hprob_le_one, _habsolute, htail⟩
  have hbudget := hsuen_tail N hN hTN b hb
  have hεb_nonneg : 0 ≤ εb N := by
    have htail_nonneg :
        0 ≤ Inputs.suenTailConstant * Δb N b * Real.exp (2 * δb N b) := by
      exact mul_nonneg
        (mul_nonneg (le_of_lt Inputs.suenTailConstant_pos)
          (hΔ_nonneg N hN hTN b hb))
        (le_of_lt (Real.exp_pos _))
    have hmul_nonneg : 0 ≤ εb N * μ N := le_trans htail_nonneg hbudget
    exact nonneg_of_mul_nonneg_left (by simpa [mul_comm] using hmul_nonneg)
      (hμ N hN hTN)
  have hnohit :
      Inputs.suenProb (μ N) (δb N b) (Δb N b)
        ≤ Real.exp (-(1 - εb N) * μ N) := by
    have hexp :
        Real.exp (-μ N + Inputs.suenTailConstant * Δb N b * Real.exp (2 * δb N b))
          ≤ Real.exp (-(1 - εb N) * μ N) := by
      apply Real.exp_le_exp.mpr
      nlinarith
    exact le_trans htail hexp
  have hNnonneg : 0 ≤ (N : ℝ) := by exact_mod_cast Nat.zero_le N
  exact finite_transfer_of_elemSymm_brun_error_and_top
    (weights N b) (M N b) (Xq N b) (R N b)
    (hweights_nonneg N hN hTN b hb) (hmass N hN hTN b hb)
    (hMle N hN hTN b hb) (hXq N hN hTN b hb)
    (hμ N hN hTN) (hPz N hN hTN) hNnonneg
    hεb_nonneg (hdecomp N hN hTN b hb)
    (herr_raw N hN hTN b hb) hεle (hlevel N hN hTN b hb)
    (hF2R_raw N hN hTN b hb) (hF2R_tail N hN hTN b hb) hnohit


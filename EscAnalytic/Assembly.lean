/-- Fixed-numerator main bound from finite-range Suen finite-transfer ingredients
with the reduced-sum large range assembled from pointwise majorants and the
finite initial reduced-sum carrier absorbed automatically. -/
theorem fixed_numerator_main_of_large_suen_finite_transfer_and_fixed_reduced_pointwise_sum_large_range_concrete_euler_smooth_range_auto_initial
    {ι : Type*}
    (m : ℕ)
    (cls : ℕ → Finset ι)
    (Mb : ℕ → ι → ℝ)
    (Ered : ℕ → ℕ)
    (Pz μ εb : ℕ → ℝ)
    (δb Δb Xpow errTerm F2R : ℕ → ι → ℝ)
    (εK : ℝ)
    (c : ℝ) (T Tred : ℕ)
    (hc : 0 < c)
    (hEred_sum : ∀ N : ℕ, 3 ≤ N →
      (Ered N : ℝ) ≤ ∑ b ∈ cls N, Mb N b)
    (hμ : ∀ N : ℕ, 3 ≤ N → T ≤ N → 0 < μ N)
    (hPz : ∀ N : ℕ, 3 ≤ N → T ≤ N → 1 ≤ Pz N)
    (hδ_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 0 ≤ δb N b)
    (hΔ_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 0 ≤ Δb N b)
    (hXpow : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 0 ≤ Xpow N b)
    (hsuen_tail : ∀ K : ℝ, 0 < K → ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      K * Δb N b * Real.exp (2 * δb N b) ≤ εb N * μ N)
    (hdecomp : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      Mb N b ≤ ((N : ℝ) / Pz N) *
        (Inputs.suenProb (μ N) (δb N b) (Δb N b) + F2R N b) + errTerm N b)
    (herr : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      errTerm N b ≤ Xpow N b * Real.exp ((1 + εK) * μ N))
    (hεle : εK ≤ 1)

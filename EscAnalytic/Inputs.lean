    rw [abs_of_nonneg hnonneg]
    exact hupper⟩

/-- Two-sided small-divisor average package with the absolute-value carrier
form used by normalization arguments.

The only non-elementary lower input is still the finite-witness Euler/Mertens
statement inside `smallDivisorAverage_two_sided_from_standard_inputs`; this
wrapper adds no analytic content. -/
theorem smallDivisorAverage_two_sided_from_standard_inputs_with_abs_carrier_bounds
    (P : EscAnalytic.Params) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      0 ≤ Real.log (EscAnalytic.SScale P X) ∧

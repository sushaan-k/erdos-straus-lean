/-- The floor-error component package implies the older signed-component
package by finite floor/count bookkeeping. -/
theorem LinearSieveRoughDyadicModulusOneProductLowerSignedComponentPackageOnPositiveRanges_of_floorErrorPackage
    (h : LinearSieveRoughDyadicModulusOneProductLowerFloorErrorComponentPackageOnPositiveRanges) :
    LinearSieveRoughDyadicModulusOneProductLowerSignedComponentPackageOnPositiveRanges :=

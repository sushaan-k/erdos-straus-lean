/-- Rank-budget certificate builder specialized to the canonical Nat roughness
modulus.  The nontrivial-modulus field is discharged from `2 ≤ z`, and the
event certificate field is discharged by the large-prime admissibility route. -/
noncomputable def natPrimeProductRankBudgetCertificateOfAdmissibleForLargePrimeUniform
    (z N R r s : ℕ) (rhoOf : ℕ → ℕ)
    (eventsByBase : ℕ → Finset EscLeanChecks.SatEvent)
    (B : ℕ → ℕ → ℚ)
    (hz : 2 ≤ z) (hr : 0 < r) (hs : 0 < s)
    (hrank : ∀ b ∈ EscLeanChecks.reducedResiduesMod (natPrimeProductBelow z),
      ∀ k ∈ Finset.range (2 * R + 1),
        (((-1 : Int) ^ k) *
          ((∑ t ∈ (eventsByBase b).powersetCard k,
              EscLeanChecks.baseSatEventCommonHitCountUpTo
                N (natPrimeProductBelow z) b t : ℕ) : Int) : ℚ) ≤
            B b k)
    (hadm : ∀ b event, event ∈ eventsByBase b →
      EscLeanChecks.satEventAdmissibleFor (natPrimeProductBelow z) rhoOf event)
    (hrho : ∀ b event, event ∈ eventsByBase b →
      rhoOf event.e = r * s)
    (hevent : ∀ b event, event ∈ eventsByBase b →
      event.e = r * s ^ 2)
    (hlargeBase : ∀ b event, event ∈ eventsByBase b →
      natPrimeProductBelow z < event.p)
    (hbase : ∀ b event, event ∈ eventsByBase b →
      b + 4 * event.e ≡ 0 [MOD event.dMinus])
    (hbudget :
      (∑ b ∈ EscLeanChecks.reducedResiduesMod (natPrimeProductBelow z),
        ∑ k ∈ Finset.range (2 * R + 1), B b k) < 1) :
    EscLeanChecks.SatEventRankBudgetCertificate N (natPrimeProductBelow z) R :=
  satEventRankBudgetCertificateOfAdmissibleForLargePrimeUniform
    N (natPrimeProductBelow z) R r s rhoOf eventsByBase B
    (one_lt_natPrimeProductBelow z hz) hr hs hrank hadm hrho hevent
    hlargeBase hbase hbudget


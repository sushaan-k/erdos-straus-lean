/-!
# Main-theorem assembly and auxiliary routes

This module contains the long-form compositions used by the main theorem and
the conditional fixed-numerator variants.  Readers interested only in the
closed result should start with `EscAnalytic.Paper` and then follow
`EscAnalytic.MainTheorem` into this file.

The abstract final step in `EscAnalytic.AbstractMain` takes a reduced
exceptional-count estimate, a smooth-range estimate, an Euler-product bound,
and the smooth/rough lifting inequality.  This file supplies those components
from the analytic and finite-certificate layers.  In particular:

* `Transfer.Ered_bound_of_finite_transfer` converts the classwise no-hit bound
  into the reduced exceptional-count estimate;
* `rankin_smoothRange_zNatScale_bound` controls the smooth range;
* `main_of_euler_log_four` absorbs the elementary Euler-product factor; and
* `LiftCount.lift_of_range_bounds` performs the final smooth/rough lifting.

The fixed-numerator, growing-numerator, and quartic developments are retained
here because they share the same transfer machinery.  Their public status and
remaining hypotheses are summarized in `FORMALIZATION.md`.
-/

namespace EscAnalytic

open Classical

/-! ## Actual-family analytic reductions -/

/-- Fixed numerator coprime splitting of the Euler totient factor. -/
theorem fixed_m_totient_mul_of_coprime
    (m rho : ℕ) (hcop : Nat.Coprime m rho) :
    Nat.totient (m * rho) = Nat.totient m * Nat.totient rho :=
  Nat.totient_mul hcop

/-- The predecessor residue `M - 1` is reduced modulo `M`. -/
theorem predecessor_residue_coprime_modulus
    (M : ℕ) (hM : 1 ≤ M) :
    Nat.Coprime (M - 1) M := by
  rw [Nat.coprime_self_sub_left hM]
  exact Nat.coprime_one_left M

/-- A coefficient coprime to `M` has a reduced multiplier putting it in the
minus-one progression modulo `M`. -/
theorem exists_reduced_solution_mul_modEq_pred
    (A M : ℕ) (hM : 0 < M) (hcop : Nat.Coprime A M) :
    ∃ p : ℕ, Nat.Coprime p M ∧ A * p ≡ M - 1 [MOD M] := by
  by_cases hM_one : M = 1
  · subst M
    refine ⟨0, ?_, ?_⟩
    · simp [Nat.Coprime]
    · simp [Nat.ModEq]
  · have hM_gt_one : 1 < M :=
      lt_of_le_of_ne (Nat.succ_le_of_lt hM) (Ne.symm hM_one)
    obtain ⟨b, hb_emod⟩ :=
      Nat.exists_mul_emod_eq_one_of_coprime (k := M) (n := A) hcop hM_gt_one
    have hb_mod : A * b ≡ 1 [MOD M] := by
      rw [Nat.ModEq, hb_emod, Nat.mod_eq_of_lt hM_gt_one]
    let p : ℕ := (M - 1) * b
    refine ⟨p, ?_, ?_⟩
    · have hprod_coprime : Nat.Coprime (A * b) M := by
        rw [Nat.coprime_iff_gcd_eq_one]
        rw [hb_mod.gcd_eq]
        simp
      have hb_coprime : Nat.Coprime b M :=
        hprod_coprime.coprime_dvd_left (dvd_mul_left b A)
      change Nat.Coprime ((M - 1) * b) M
      exact (Nat.coprime_mul_iff_left).2
        ⟨predecessor_residue_coprime_modulus M hM_gt_one.le, hb_coprime⟩
    · have hmul := hb_mod.mul_left (M - 1)
      simpa [p, mul_assoc, mul_left_comm, mul_comm] using hmul

/-- Paper-shaped fixed-`m` minus-one progression residue.

If the coefficient `d_- d_+` is coprime to the fixed auxiliary modulus
`m * rho`, then the congruence `d_- d_+ p ≡ -1 (mod m rho)` has a reduced
residue class for `p`.  This is the elementary non-emptiness/reduced-class
calculation used in `prop:fixed-m-transfer` before the prime-distribution input
is applied. -/
theorem exists_reduced_fixed_m_minus_one_progression_residue
    (m rho dMinus dPlus : ℕ)
    (hmod : 0 < m * rho)
    (hcop : Nat.Coprime (dMinus * dPlus) (m * rho)) :
    ∃ p : ℕ, Nat.Coprime p (m * rho) ∧
      dMinus * dPlus * p ≡ m * rho - 1 [MOD m * rho] := by
  simpa [mul_assoc] using
    exists_reduced_solution_mul_modEq_pred
      (dMinus * dPlus) (m * rho) hmod hcop

/-- The fixed-`m` small congruence is a reduced class in the exact-divisor
coordinate.

If the base class `b` is reduced modulo `d` and `m` is coprime to `d`, then
`b + m * e ≡ 0 (mod d)` forces `e` to be reduced modulo `d`.  This is the
elementary coprimality calculation behind the sentence in `prop:fixed-m-transfer`
that the condition `b ≡ -me (mod d_-)` remains one reduced linear class. -/
theorem fixed_m_small_congruence_forces_reduced_exact_divisor_class
    (m e b d : ℕ)
    (hcopm : Nat.Coprime m d)
    (hcopb : Nat.Coprime b d)
    (hsmall : b + m * e ≡ 0 [MOD d]) :
    Nat.Coprime e d := by
  have _paper_hypothesis_seen : Nat.Coprime m d := hcopm
  rw [Nat.coprime_iff_gcd_eq_one]
  let g := Nat.gcd e d
  have hge : g ∣ e := Nat.gcd_dvd_left e d
  have hgd : g ∣ d := Nat.gcd_dvd_right e d
  have hgme : g ∣ m * e := dvd_mul_of_dvd_right hge m
  have hsmalldvd : d ∣ b + m * e := (Nat.modEq_zero_iff_dvd).1 hsmall
  have hgsmall : g ∣ b + m * e := hgd.trans hsmalldvd
  have hgb : g ∣ b := by
    have hsub := Nat.dvd_sub (Nat.le_add_left (m * e) b) hgsmall hgme
    simpa [Nat.add_sub_cancel_right] using hsub
  have hggcd : g ∣ Nat.gcd b d := Nat.dvd_gcd hgb hgd
  rw [Nat.coprime_iff_gcd_eq_one] at hcopb
  rw [hcopb] at hggcd
  exact Nat.dvd_one.mp hggcd

/-- Alias for the fixed-auxiliary rough-factor absorption used by the
fixed-numerator public frontier. -/
noncomputable def roughFactor_asymp_fixed_auxiliary
    (M : ℕ) (_hM : 1 ≤ M) (a b : ℝ)
    (c C Xbase : ℝ) (hc : 0 < c) (hC : 0 < C)
    (hrough :
      ∀ X : ℝ, Xbase ≤ X →
        c * (Real.log X / Real.log (zScale X)) ≤ Inputs.roughRecip X M a b
          ∧ Inputs.roughRecip X M a b
              ≤ C * (Real.log X / Real.log (zScale X))) :
    FactorAsymp (fun X => Inputs.roughRecip X M a b) roughShape :=
  roughFactor_asymp_of_fixed_bound M a b c C Xbase hc hC hrough

/-- Any fixed natural number is eventually below every positive real power. -/
theorem fixedNat_le_rpow_eventually
    (M : ℕ) {α : ℝ} (hα : 0 < α) :
    ∀ᶠ X : ℝ in Filter.atTop, (M : ℝ) ≤ X ^ α := by
  exact (_root_.tendsto_rpow_atTop hα).eventually
    (Filter.eventually_ge_atTop (M : ℝ))

/-- The actual family satisfies the Brun--Titchmarsh modulus range for every
exponent strictly above `theta`.  The conductor bound is internal; only the
fixed-factor absorption `4 <= X^(nu-theta)` uses eventual growth. -/
theorem actualFamily_modulus_range_eventually
    (P : Params) (ν : ℝ) (hθν : P.θ < ν) :
    ∃ X₀ : ℝ, ∀ X : ℝ, X₀ ≤ X → 1 < X →
      ∀ b : ℕ, ∀ i : Family.FamilyIndex,
        Family.FamilyStaticMem P X (Inputs.roughModulus X) b i →
          (4 * i.rho : ℝ) ≤ X ^ ν := by
  have hgap : 0 < ν - P.θ := sub_pos.mpr hθν
  rcases EscAnalytic.fixedNat_le_rpow_eventually_threshold 4 hgap with
    ⟨X₄, hX₄⟩
  refine ⟨max X₄ 1, ?_⟩
  intro X hX₀ hX b i hmem
  have hX₄' : X₄ ≤ X := le_trans (le_max_left _ _) hX₀
  have hXone : 1 ≤ X := le_trans (le_max_right _ _) hX₀
  have hXpos : 0 < X := lt_of_lt_of_le zero_lt_one hXone
  have hfour : (4 : ℝ) ≤ X ^ (ν - P.θ) := hX₄ X hX₄'
  have hrho : (i.rho : ℝ) ≤ HScale P X :=
    Family.FamilyStaticMem.rho_le_HScale hX hmem
  have hfour_nonneg : 0 ≤ X ^ (ν - P.θ) :=
    Real.rpow_nonneg (le_trans zero_le_one hXone) _
  calc
    (4 * i.rho : ℝ) = (4 : ℝ) * (i.rho : ℝ) := by norm_num
    _ ≤ X ^ (ν - P.θ) * (i.rho : ℝ) :=
      mul_le_mul_of_nonneg_right hfour (Nat.cast_nonneg _)
    _ ≤ X ^ (ν - P.θ) * X ^ P.θ := by
      exact mul_le_mul_of_nonneg_left hrho hfour_nonneg
    _ = X ^ ν := by
      rw [← Real.rpow_add hXpos]
      congr 1
      ring

/-- The complete actual-family reciprocal-prime error is dominated by the
same weighted-BV carrier used in the cited analytic input.  All multiplicity
outside that carrier is accounted for by the explicit elementary factor
`floor(U) * H_floor(Y)`. -/
theorem actualPaperFamilyMassErrorCarrier_le_weightedBV_eventually
    (P : Params) (ν : ℝ) (hθν : P.θ < ν) :
    ∃ X₀ : ℝ, ∀ X : ℝ, X₀ ≤ X → 1 < X → ∀ b : ℕ,
      actualPaperFamilyMassErrorCarrier
          P X (Inputs.roughModulus X) b ≤
        ((⌊UScale X⌋₊ : ℝ) * (harmonic ⌊YScale P X⌋₊ : ℝ)) *
          Inputs.weightedBVSum P X 1 ν := by
  rcases actualFamily_modulus_range_eventually P ν hθν with ⟨Xmod, hmod⟩
  refine ⟨Xmod, ?_⟩
  intro X hXmod hX b
  let I := Family.familyIndexFinset P X (Inputs.roughModulus X) b
  let M := actualPaperFamilyMassModuli P X (Inputs.roughModulus X) b
  let A : ℝ := (⌊UScale X⌋₊ : ℝ) * (harmonic ⌊YScale P X⌋₊ : ℝ)
  have hA : 0 ≤ A := mul_nonneg (Nat.cast_nonneg _)
    (Inputs.harmonic_nonneg_real _)
  have hMsubset : M ⊆ Finset.Icc (1 : ℕ) ⌊X ^ ν⌋₊ := by
    intro m hm
    rcases Finset.mem_image.mp hm with ⟨E, hE, rfl⟩
    rcases Finset.mem_image.mp hE with ⟨i, hi, hiE⟩
    have himem : Family.FamilyStaticMem P X (Inputs.roughModulus X) b i :=
      (Family.mem_familyIndexFinset_iff P X (Inputs.roughModulus X) b i
        (lt_trans zero_lt_one hX)).1 hi
    have hrho : 0 < E.rho := by
      subst E
      exact ExactDivisor.rho_pos i.E (himem.r_pos hX)
        (lt_of_lt_of_le Nat.zero_lt_one himem.s_pos)
    have hrange : (4 * E.rho : ℝ) ≤ X ^ ν := by
      subst E
      exact hmod X hXmod hX b i himem
    exact Finset.mem_Icc.mpr
      ⟨by omega, Nat.le_floor (by simpa [Nat.cast_mul] using hrange)⟩
  have hpoint : ∀ m ∈ M,
      actualPaperFamilyMassErrorCoefficient
          P X (Inputs.roughModulus X) b m *
          Inputs.reducedClassPrimeErrorMax P X m ≤
        A * (((Inputs.tau m : ℝ) ^ (1 : ℝ)) *
          Inputs.reducedClassPrimeErrorMax P X m) := by
    intro m hm
    have hcoef :=
      actualPaperFamilyMassErrorCoefficient_le_tau_mul_cutoffs
        P X (Inputs.roughModulus X) b m hX
    have herr : 0 ≤ Inputs.reducedClassPrimeErrorMax P X m :=
      Inputs.reducedClassPrimeErrorMax_nonneg P X m
    calc
      actualPaperFamilyMassErrorCoefficient
            P X (Inputs.roughModulus X) b m *
            Inputs.reducedClassPrimeErrorMax P X m
          ≤ ((Inputs.tau m : ℝ) * A) *
              Inputs.reducedClassPrimeErrorMax P X m :=
            mul_le_mul_of_nonneg_right hcoef herr
      _ = A * (((Inputs.tau m : ℝ) ^ (1 : ℝ)) *
            Inputs.reducedClassPrimeErrorMax P X m) := by
            rw [Real.rpow_one]
            ring
  rw [actualPaperFamilyMassErrorCarrier_eq_modulus_sum]
  calc
    (∑ m ∈ M,
        actualPaperFamilyMassErrorCoefficient
            P X (Inputs.roughModulus X) b m *
          Inputs.reducedClassPrimeErrorMax P X m)
        ≤ ∑ m ∈ M, A * (((Inputs.tau m : ℝ) ^ (1 : ℝ)) *
            Inputs.reducedClassPrimeErrorMax P X m) := by
          exact Finset.sum_le_sum hpoint
    _ = A * (∑ m ∈ M, ((Inputs.tau m : ℝ) ^ (1 : ℝ)) *
          Inputs.reducedClassPrimeErrorMax P X m) := by
          rw [Finset.mul_sum]
    _ ≤ A * Inputs.weightedBVSum P X 1 ν := by
      apply mul_le_mul_of_nonneg_left _ hA
      unfold Inputs.weightedBVSum
      apply Finset.sum_le_sum_of_subset_of_nonneg hMsubset
      intro m _hmBig _hmSmall
      exact mul_nonneg (Real.rpow_nonneg (Nat.cast_nonneg _) 1)
        (Inputs.reducedClassPrimeErrorMax_nonneg P X m)

/-- The elementary coefficient left outside weighted BV is at most a fixed
ninth power of `log X`. -/
theorem actualPaperFamilyMass_cutoffFactor_le_log_pow_nine
    (P : Params) {X : ℝ} (hX : Real.exp 1 ≤ X) :
    (⌊UScale X⌋₊ : ℝ) * (harmonic ⌊YScale P X⌋₊ : ℝ) ≤
      (1 + P.σ) * (Real.log X) ^ 9 := by
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 1) hX
  have hlogX : 1 ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hX
  have hU_nonneg : 0 ≤ UScale X := by
    unfold UScale
    positivity
  have hfloorU : (⌊UScale X⌋₊ : ℝ) ≤ (Real.log X) ^ 8 := by
    simpa [UScale] using Nat.floor_le hU_nonneg
  have hYpos : 0 < YScale P X := by
    unfold YScale
    exact Real.rpow_pos_of_pos hXpos P.σ
  have hXone : 1 ≤ X := by
    have hexp : Real.exp 0 < Real.exp 1 := Real.exp_lt_exp.mpr zero_lt_one
    exact le_trans (by simpa using hexp.le) hX
  have hYone : 1 ≤ YScale P X := by
    unfold YScale
    exact Real.one_le_rpow hXone P.σ_pos.le
  have hharm : (harmonic ⌊YScale P X⌋₊ : ℝ) ≤
      1 + Real.log (YScale P X) :=
    harmonic_floor_le_one_add_log (YScale P X) hYone
  have hlogY : Real.log (YScale P X) = P.σ * Real.log X := by
    unfold YScale
    rw [Real.log_rpow hXpos]
  have hharm' : (harmonic ⌊YScale P X⌋₊ : ℝ) ≤
      (1 + P.σ) * Real.log X := by
    rw [hlogY] at hharm
    calc
      (harmonic ⌊YScale P X⌋₊ : ℝ) ≤ 1 + P.σ * Real.log X := hharm
      _ ≤ (1 + P.σ) * Real.log X := by
        nlinarith [P.σ_pos]
  have hharm_nonneg : 0 ≤ (harmonic ⌊YScale P X⌋₊ : ℝ) :=
    Inputs.harmonic_nonneg_real _
  have hlog_nonneg : 0 ≤ Real.log X := le_trans zero_le_one hlogX
  calc
    (⌊UScale X⌋₊ : ℝ) * (harmonic ⌊YScale P X⌋₊ : ℝ)
        ≤ (Real.log X) ^ 8 * (harmonic ⌊YScale P X⌋₊ : ℝ) :=
          mul_le_mul_of_nonneg_right hfloorU hharm_nonneg
    _ ≤ (Real.log X) ^ 8 * ((1 + P.σ) * Real.log X) :=
          mul_le_mul_of_nonneg_left hharm' (pow_nonneg hlog_nonneg 8)
    _ = (1 + P.σ) * (Real.log X) ^ 9 := by ring

/-- Applying the cited reciprocal-EH theorem to the exact complete-family
carrier leaves only the explicit elementary cutoff factor. -/
theorem actualPaperFamilyMassErrorCarrier_le_standard_reciprocalEH
    (H : Inputs.ReciprocalElliottHalberstamWeightedBVExternalInput)
    (P : Params) (ν A : ℝ) (hθν : P.θ < ν) (hν1 : ν < 1) (hA : 0 < A) :
    ∃ K X₀ : ℝ, 0 < K ∧ ∀ X : ℝ, X₀ ≤ X → 1 < X → ∀ b : ℕ,
      actualPaperFamilyMassErrorCarrier
          P X (Inputs.roughModulus X) b ≤
        ((⌊UScale X⌋₊ : ℝ) * (harmonic ⌊YScale P X⌋₊ : ℝ)) *
          (K * (Real.log X) ^ (-A)) := by
  have hEH := Inputs.reciprocalEH_sameCarrier_of_weightedBVExternalInput
    H
  rcases hEH P ν A 1 hν1 hA (by norm_num) with ⟨K, Xeh, hK, heh⟩
  rcases actualPaperFamilyMassErrorCarrier_le_weightedBV_eventually
    P ν hθν with ⟨Xmod, hmod⟩
  refine ⟨K, max Xeh Xmod, hK, ?_⟩
  intro X hX hXone b
  have hXeh : Xeh ≤ X := le_trans (le_max_left _ _) hX
  have hXmod : Xmod ≤ X := le_trans (le_max_right _ _) hX
  have hcarrier := hmod X hXmod hXone b
  have hweighted : Inputs.weightedBVSum P X 1 ν ≤
      K * (Real.log X) ^ (-A) := by
    exact le_trans (le_abs_self _) (heh X hXeh)
  have hcutoff : 0 ≤
      (⌊UScale X⌋₊ : ℝ) * (harmonic ⌊YScale P X⌋₊ : ℝ) :=
    mul_nonneg (Nat.cast_nonneg _) (Inputs.harmonic_nonneg_real _)
  exact hcarrier.trans
    (mul_le_mul_of_nonneg_left hweighted hcutoff)

/-- The actual fixed-`dminus` residue mass is bounded by the cited
Brun--Titchmarsh and ordinary-squarefree progression inputs.  The finite
family, modulus range, rough-initial cutoff, and tensor carrier conditions are
all discharged here. -/
theorem actualFamily_fixedDminus_residueMass_le_standard
    (P : Params) [Fact (PhiProgressionGammaQuotientUpperYU P)]
    (ν : ℝ) (hνpos : 0 < ν)
    (hθν : P.θ < ν) (hνβ : ν < P.β) :
    ∃ Cbt Crough K cφ X₀ : ℝ,
      0 < Cbt ∧ 0 < Crough ∧ 0 < K ∧ 0 < cφ ∧
      ∀ X : ℝ, X₀ ≤ X → 1 < X →
        ∀ b : ℕ, ∀ indices : Finset Family.FamilyIndex,
          Nat.Coprime b (Inputs.roughModulus X) →
          (∀ i ∈ indices,
            Family.FamilyStaticMem P (X := X)
              (Inputs.roughModulus X) b i) →
          ∀ D c dminus : ℕ,
            1 ≤ D → Squarefree D → Odd D →
            Nat.Coprime D (Inputs.roughModulus X) →
            (D : ℝ) ≤ YScale P X →
            0 < dminus → (dminus : ℝ) ≤ UScale X →
            dminus ∣ Inputs.roughModulus X →
            Squarefree dminus → Odd dminus →
            (∑ E ∈ familyExactValuesAtDminus indices D c dminus,
              familyFixedEDminusDivisorMass
                (indices.filter (fun i => i.e % D = c)) E dminus D) ≤
              Cbt * (Crough * (Real.log X /
                Real.log (EscAnalytic.zScale X))) * (K / cφ) *
                (exactDivisorMPhiMassRaw P X /
                  ((D : ℝ) * (D : ℝ) * (dminus : ℝ))) := by
  rcases familyFixedEDminusDivisorMass_le_bt_standard_mul_roughInitial
      P ν hνpos hνβ with ⟨Cbt, Xbt, hCbt, hbt⟩
  rcases Inputs.roughInitial_upper_of_zScale_power_cutoff
      P.σ ν 4 P.σ_pos (by norm_num) with
    ⟨Crough, Xrough, hCrough, hrough⟩
  rcases actualFamily_modulus_range_eventually P ν hθν with
    ⟨Xmod, hmod⟩
  rcases exactDivisorMPhiTensorFiberCoprime_le_massRaw_over_modulus_of_standard_ordinarySquarefree
      (P := P) with ⟨K, Xtensor, hK, hTensor⟩
  rcases exactDivisorMPhiMassFiber_comparable_to_shape_of_fiberAverageTwoSided
      (ExactDivisorMPhiFiberAverageTwoSided_of_standard_ordinarySquarefree
        (P := P)) with
    ⟨cφ, _Cφ, Xmass, hcφ, _hCφ, hMass⟩
  let X₂ : ℝ := Real.exp 2
  refine ⟨Cbt, Crough, K, cφ,
    max (max (max (max Xbt Xrough) Xmod) X₂)
      (max Xtensor Xmass), hCbt, hCrough, hK, hcφ, ?_⟩
  intro X hX₀ hX b indices hbcop hmem D c dminus
    hDone hDsqf hDodd hDcopPz hDleY hdmpos hdmleU hdmdiv hdmsqf hdmodd
  have hXbt : Xbt ≤ X := by
    calc
      Xbt ≤ max Xbt Xrough := le_max_left _ _
      _ ≤ max (max Xbt Xrough) Xmod := le_max_left _ _
      _ ≤ max (max (max Xbt Xrough) Xmod) X₂ := le_max_left _ _
      _ ≤ max (max (max (max Xbt Xrough) Xmod) X₂)
          (max Xtensor Xmass) := le_max_left _ _
      _ ≤ X := hX₀
  have hXrough : Xrough ≤ X := by
    calc
      Xrough ≤ max Xbt Xrough := le_max_right _ _
      _ ≤ max (max Xbt Xrough) Xmod := le_max_left _ _
      _ ≤ max (max (max Xbt Xrough) Xmod) X₂ := le_max_left _ _
      _ ≤ max (max (max (max Xbt Xrough) Xmod) X₂)
          (max Xtensor Xmass) := le_max_left _ _
      _ ≤ X := hX₀
  have hXmod : Xmod ≤ X := by
    calc
      Xmod ≤ max (max Xbt Xrough) Xmod := le_max_right _ _
      _ ≤ max (max (max Xbt Xrough) Xmod) X₂ := le_max_left _ _
      _ ≤ max (max (max (max Xbt Xrough) Xmod) X₂)
          (max Xtensor Xmass) := le_max_left _ _
      _ ≤ X := hX₀
  have hX₂ : X₂ ≤ X := by
    calc
      X₂ ≤ max (max (max Xbt Xrough) Xmod) X₂ := le_max_right _ _
      _ ≤ max (max (max (max Xbt Xrough) Xmod) X₂)
          (max Xtensor Xmass) := le_max_left _ _
      _ ≤ X := hX₀
  have hXtensor : Xtensor ≤ X := by
    calc
      Xtensor ≤ max Xtensor Xmass := le_max_left _ _
      _ ≤ max (max (max (max Xbt Xrough) Xmod) X₂)
          (max Xtensor Xmass) := le_max_right _ _
      _ ≤ X := hX₀
  have hXmass : Xmass ≤ X := by
    calc
      Xmass ≤ max Xtensor Xmass := le_max_right _ _
      _ ≤ max (max (max (max Xbt Xrough) Xmod) X₂)
          (max Xtensor Xmass) := le_max_right _ _
      _ ≤ X := hX₀
  have hlogZ : 0 < Real.log (EscAnalytic.zScale X) := by
    exact Inputs.log_zScale_pos_of_exp_two_le (by simpa [X₂] using hX₂)
  have hratio_nonneg : 0 ≤ Real.log X /
      Real.log (EscAnalytic.zScale X) := by
    exact div_nonneg (Real.log_pos hX).le hlogZ.le
  let Eset := familyExactValuesAtDminus indices D c dminus
  have hρpos : ∀ E ∈ Eset, 0 < E.rho := by
    intro E hE
    unfold Eset familyExactValuesAtDminus familyExactValues at hE
    rcases Finset.mem_image.mp hE with ⟨i, hi, rfl⟩
    have hiIndices : i ∈ indices := (Finset.mem_filter.mp hi).1
    have himem := hmem i hiIndices
    have hs : 0 < i.E.s := lt_of_lt_of_le Nat.zero_lt_one himem.s_pos
    have hr : 0 < i.E.r := himem.r_pos hX
    simpa [Family.FamilyIndex.rho, ExactDivisor.rho] using
      Nat.mul_pos hr hs
  have hmodE : ∀ E ∈ Eset, (4 * E.rho : ℝ) ≤ X ^ ν := by
    intro E hE
    unfold Eset familyExactValuesAtDminus familyExactValues at hE
    rcases Finset.mem_image.mp hE with ⟨i, hi, rfl⟩
    have hiIndices : i ∈ indices := (Finset.mem_filter.mp hi).1
    simpa [Family.FamilyIndex.rho, ExactDivisor.rho] using
      hmod X hXmod hX b i (hmem i hiIndices)
  have hbtE : ∀ E ∈ Eset,
      familyFixedEDminusDivisorMass
          (indices.filter (fun i => i.e % D = c)) E dminus D ≤
        (Cbt / (Nat.totient (4 * E.rho) : ℝ)) *
          (1 / (D : ℝ)) * Inputs.roughInitial X (4 * E.rho) P.σ := by
    intro E hE
    exact hbt X hXbt hX b indices E dminus D c hDone
      (hρpos E hE) (hmodE E hE) hmem
  have hroughE : ∀ E ∈ Eset,
      Inputs.roughInitial X (4 * E.rho) P.σ ≤
        Crough * (Real.log X / Real.log (EscAnalytic.zScale X)) := by
    intro E hE
    have hM : ((4 * E.rho : ℕ) : ℝ) ≤ X ^ ν := by
      simpa [Nat.cast_mul] using hmodE E hE
    exact hrough X hXrough (4 * E.rho) hM
  have hfixed := familyFixedDminusResidueMass_le_bt
    P X indices D c dminus hDone Cbt
      (Crough * (Real.log X / Real.log (EscAnalytic.zScale X))) hCbt.le
      (mul_nonneg hCrough.le hratio_nonneg) hρpos hbtE hroughE
  have hTensorFiber := familyExactValuesAtDminus_recipTotient_le_of_tensor_bound
    P X (Inputs.roughModulus X) b indices hX hbcop hmem D c dminus
      hDone hDsqf hDodd hDcopPz hDleY hdmpos hdmleU hdmdiv hdmsqf hdmodd
      K cφ Xtensor Xmass hcφ hTensor (fun X hXmass => (hMass X hXmass).1) (by
        exact max_le_iff.mpr ⟨hXtensor, hXmass⟩)
  have hfactor_nonneg : 0 ≤ Cbt *
      (Crough * (Real.log X / Real.log (EscAnalytic.zScale X))) *
        (1 / (D : ℝ)) := by
    have hDreal : 0 < (D : ℝ) := by exact_mod_cast (lt_of_lt_of_le Nat.zero_lt_one hDone)
    positivity
  have hDreal : 0 < (D : ℝ) := by
    exact_mod_cast (lt_of_lt_of_le Nat.zero_lt_one hDone)
  have hdmreal : 0 < (dminus : ℝ) := by exact_mod_cast hdmpos
  calc
    (∑ E ∈ familyExactValuesAtDminus indices D c dminus,
        familyFixedEDminusDivisorMass
          (indices.filter (fun i => i.e % D = c)) E dminus D) ≤
        Cbt * (Crough * (Real.log X /
          Real.log (EscAnalytic.zScale X))) * (1 / (D : ℝ)) *
          (∑ E ∈ familyExactValuesAtDminus indices D c dminus,
            (1 : ℝ) / (Nat.totient E.rho : ℝ)) := hfixed
    _ ≤ Cbt * (Crough * (Real.log X /
          Real.log (EscAnalytic.zScale X))) * (1 / (D : ℝ)) *
          ((K / cφ) *
            (exactDivisorMPhiMassRaw P X /
              ((D * dminus : ℕ) : ℝ))) := by
      exact mul_le_mul_of_nonneg_left hTensorFiber hfactor_nonneg
    _ = Cbt * (Crough * (Real.log X /
          Real.log (EscAnalytic.zScale X))) * (K / cφ) *
          (exactDivisorMPhiMassRaw P X /
            ((D : ℝ) * (D : ℝ) * (dminus : ℝ))) := by
      field_simp [ne_of_gt hDreal, ne_of_gt hdmreal]
      ring

/-- Aggregate the actual fixed-`dminus` estimate over the finite residue
fiber.  The resulting cubic-log-sized numerator is the paper's actual
residue-tensor bound before normalization by the family mass. -/
theorem actualFamily_residueMassRat_real_le_standard_raw
    (P : Params) [Fact (PhiProgressionGammaQuotientUpperYU P)]
    (ν : ℝ) (hνpos : 0 < ν)
    (hθν : P.θ < ν) (hνβ : ν < P.β) :
    ∃ C X₀ : ℝ, 0 < C ∧
      ∀ X : ℝ, X₀ ≤ X → 1 < X →
        ∀ b : ℕ, ∀ indices : Finset Family.FamilyIndex,
          Nat.Coprime b (Inputs.roughModulus X) →
          (∀ i ∈ indices,
            Family.FamilyStaticMem P (X := X)
              (Inputs.roughModulus X) b i) →
          ∀ D c : ℕ,
            1 ≤ D → Squarefree D → Odd D →
            Nat.Coprime D (Inputs.roughModulus X) →
            (D : ℝ) ≤ YScale P X →
            (Family.familyResidueMassRat indices D c : ℝ) ≤
              C * Real.log X *
                (exactDivisorMPhiMassRaw P X /
                  ((D : ℝ) * (D : ℝ))) := by
  rcases actualFamily_fixedDminus_residueMass_le_standard
      P ν hνpos hθν hνβ with
    ⟨Cbt, Crough, K, cφ, Xfixed, hCbt, hCrough, hK, hcφ, hfixed⟩
  rcases Inputs.smallDivisorWeight_upper_logZ with
    ⟨Csmall, Xsmall, hCsmall, hsmall⟩
  have hCtotal : 0 < Cbt * Crough * (K / cφ) * Csmall := by
    positivity
  refine ⟨Cbt * Crough * (K / cφ) * Csmall,
    max (max Xfixed Xsmall) (Real.exp 2), hCtotal, ?_⟩
  intro X hX₀ hX b indices hbcop hmem D c hDone hDsqf hDodd hDcopPz hDleY
  have hXfixed : Xfixed ≤ X := by
    calc
      Xfixed ≤ max Xfixed Xsmall := le_max_left _ _
      _ ≤ max (max Xfixed Xsmall) (Real.exp 2) := le_max_left _ _
      _ ≤ X := hX₀
  have hXsmall : Xsmall ≤ X := by
    calc
      Xsmall ≤ max Xfixed Xsmall := le_max_right _ _
      _ ≤ max (max Xfixed Xsmall) (Real.exp 2) := le_max_left _ _
      _ ≤ X := hX₀
  have hX₂ : Real.exp 2 ≤ X := by
    exact le_trans (le_max_right _ _) hX₀
  have hlogX : 0 < Real.log X := Real.log_pos hX
  have hlogZ : 0 < Real.log (EscAnalytic.zScale X) := by
    exact Inputs.log_zScale_pos_of_exp_two_le hX₂
  have hratio_nonneg : 0 ≤ Real.log X /
      Real.log (EscAnalytic.zScale X) :=
    div_nonneg hlogX.le hlogZ.le
  let U := familyDminusResidueValues indices D c
  have hdmData : ∀ d ∈ U,
      0 < d ∧ (d : ℝ) ≤ UScale X ∧
        d ∣ Inputs.roughModulus X ∧ Squarefree d ∧ Odd d := by
    intro d hd
    unfold U familyDminusResidueValues at hd
    rcases Finset.mem_image.mp hd with ⟨i, hi, rfl⟩
    have hiIndices : i ∈ indices := (Finset.mem_filter.mp hi).1
    have himem := hmem i hiIndices
    exact ⟨himem.dminus_pos, himem.dminus_le_U,
      himem.dminus_dvd_Pz, himem.dminus_squarefree, himem.dminus_odd⟩
  have hsumD :
      (∑ d ∈ U, (1 : ℝ) / (d : ℝ)) ≤
        Inputs.smallDivisorWeight X 1 := by
    classical
    unfold Inputs.smallDivisorWeight
    apply Finset.sum_le_sum_of_subset_of_nonneg
    · intro d hd
      have hdData := hdmData d hd
      have hdFloor : d ≤ ⌊UScale X⌋₊ := Nat.le_floor hdData.2.1
      apply Finset.mem_filter.mpr
      refine ⟨Finset.mem_Icc.mpr
          ⟨Nat.succ_le_iff.mpr hdData.1, hdFloor⟩, ?_⟩
      exact ⟨hdData.2.2.1, hdData.2.2.2.2, by simp⟩
    · intro d _hdBig _hdSmall
      exact div_nonneg zero_le_one (Nat.cast_nonneg _)
  have hweight : Inputs.smallDivisorWeight X 1 ≤
      Csmall * Real.log (EscAnalytic.zScale X) :=
    hsmall X hXsmall 1
  have hraw_nonneg : 0 ≤ exactDivisorMPhiMassRaw P X := by
    unfold exactDivisorMPhiMassRaw
    apply Finset.sum_nonneg
    intro x _hx
    exact div_nonneg zero_le_one (Nat.cast_nonneg _)
  have hDreal : 0 < (D : ℝ) := by
    exact_mod_cast (lt_of_lt_of_le Nat.zero_lt_one hDone)
  have hDsq_nonneg : 0 ≤ (exactDivisorMPhiMassRaw P X /
      ((D : ℝ) * (D : ℝ))) := by
    exact div_nonneg hraw_nonneg (mul_nonneg hDreal.le hDreal.le)
  have hfactor_nonneg : 0 ≤
      Cbt * (Crough * (Real.log X /
        Real.log (EscAnalytic.zScale X))) * (K / cφ) *
        (exactDivisorMPhiMassRaw P X /
          ((D : ℝ) * (D : ℝ))) := by
    positivity
  have hpoint : ∀ d ∈ U,
      (∑ E ∈ familyExactValuesAtDminus indices D c d,
        familyFixedEDminusDivisorMass
          (indices.filter (fun i => i.e % D = c)) E d D) ≤
        (Cbt * (Crough * (Real.log X /
          Real.log (EscAnalytic.zScale X))) * (K / cφ)) *
          (exactDivisorMPhiMassRaw P X /
            ((D : ℝ) * (D : ℝ))) * ((1 : ℝ) / (d : ℝ)) := by
    intro d hd
    have hdData := hdmData d hd
    have hfixedD := hfixed X hXfixed hX b indices hbcop hmem D c d
      hDone hDsqf hDodd hDcopPz hDleY hdData.1 hdData.2.1
      hdData.2.2.1 hdData.2.2.2.1 hdData.2.2.2.2
    calc
      (∑ E ∈ familyExactValuesAtDminus indices D c d,
          familyFixedEDminusDivisorMass
            (indices.filter (fun i => i.e % D = c)) E d D) ≤
          Cbt * (Crough * (Real.log X /
            Real.log (EscAnalytic.zScale X))) * (K / cφ) *
            (exactDivisorMPhiMassRaw P X /
              ((D : ℝ) * (D : ℝ) * (d : ℝ))) := hfixedD
      _ = (Cbt * (Crough * (Real.log X /
          Real.log (EscAnalytic.zScale X))) * (K / cφ)) *
          (exactDivisorMPhiMassRaw P X /
            ((D : ℝ) * (D : ℝ))) * ((1 : ℝ) / (d : ℝ)) := by
        have hdreal : 0 < (d : ℝ) := by exact_mod_cast hdData.1
        field_simp [ne_of_gt hDreal, ne_of_gt hdreal] <;>
          (try ring) <;> simp
  have hpartition := familyResidueMassRat_real_eq_dminus_partition
    P X (Inputs.roughModulus X) b indices hX hmem D c
  rw [hpartition]
  change (∑ d ∈ U,
      ∑ E ∈ familyExactValuesAtDminus indices D c d,
        familyFixedEDminusDivisorMass
          (indices.filter (fun i => i.e % D = c)) E d D) ≤ _
  calc
    (∑ d ∈ U,
        ∑ E ∈ familyExactValuesAtDminus indices D c d,
          familyFixedEDminusDivisorMass
            (indices.filter (fun i => i.e % D = c)) E d D) ≤
        ∑ d ∈ U,
          (Cbt * (Crough * (Real.log X /
            Real.log (EscAnalytic.zScale X))) * (K / cφ)) *
            (exactDivisorMPhiMassRaw P X /
              ((D : ℝ) * (D : ℝ))) * ((1 : ℝ) / (d : ℝ)) := by
      apply Finset.sum_le_sum
      intro d hd
      exact hpoint d hd
    _ = (Cbt * (Crough * (Real.log X /
        Real.log (EscAnalytic.zScale X))) * (K / cφ)) *
        (exactDivisorMPhiMassRaw P X /
          ((D : ℝ) * (D : ℝ))) *
          (∑ d ∈ U, (1 : ℝ) / (d : ℝ)) := by
      rw [Finset.mul_sum]
    _ ≤ (Cbt * (Crough * (Real.log X /
        Real.log (EscAnalytic.zScale X))) * (K / cφ)) *
        (exactDivisorMPhiMassRaw P X /
          ((D : ℝ) * (D : ℝ))) *
        (Csmall * Real.log (EscAnalytic.zScale X)) := by
      exact mul_le_mul_of_nonneg_left
        (hsumD.trans hweight) hfactor_nonneg
    _ = (Cbt * Crough * (K / cφ) * Csmall) * Real.log X *
        (exactDivisorMPhiMassRaw P X /
          ((D : ℝ) * (D : ℝ))) := by
      field_simp [ne_of_gt hlogZ]
      ring

/-- Fixed-`m` finite-Euler-factor deletion preserves the mass and event-tensor
outputs used in `prop:fixed-m-transfer`.

This is the paper-facing form of the sentence that deleting finitely many Euler
factors and inserting a fixed multiplier changes only the constants: once the
modified small and rough factors are eventually comparable to the original
ones, and the modified event carriers are bounded by a fixed multiple of the
original carriers, the fixed-`m` mass remains cubic and the two distribution
estimates remain `μ/D²` and `μ/D`. -/
theorem fixed_m_finite_euler_deletion_mass_event_tensor_outputs
    (P : Params) (b : ℕ)
    (sigmaSmall roughFactor sigmaSmallM roughFactorM : ℝ → ℝ)
    (hSig : FactorAsymp sigmaSmall sigmaShape)
    (hR : FactorAsymp roughFactor roughShape)
    (Xsig Xrough aSig ASig aR AR : ℝ)
    (haSig : 0 < aSig) (hASig : 0 < ASig)
    (haR : 0 < aR) (hAR : 0 < AR)
    (hSigCmp : ∀ X : ℝ, Xsig ≤ X →
      aSig * sigmaSmall X ≤ sigmaSmallM X ∧
        sigmaSmallM X ≤ ASig * sigmaSmall X)
    (hRoughCmp : ∀ X : ℝ, Xrough ≤ X →
      aR * roughFactor X ≤ roughFactorM X ∧
        roughFactorM X ≤ AR * roughFactor X)
    (B Bsingle BM BsingleM : ℝ → ℕ → ℝ)
    (Xevent Aevent : ℝ) (hAevent : 0 ≤ Aevent)
    (hEventCmp : ∀ X : ℝ, Xevent ≤ X → ∀ D : ℕ, 1 ≤ D →
      BM X D ≤ Aevent * B X D ∧ BsingleM X D ≤ Aevent * Bsingle X D)
    (Kassemb XB : ℝ) (hKassemb : 0 ≤ Kassemb)
    (hassemb : ∀ X : ℝ, XB ≤ X → ∀ D : ℕ, 1 ≤ D →
        B X D ≤ Kassemb * (logCube X / (D : ℝ) ^ 2)
          ∧ Bsingle X D ≤ Kassemb * (logCube X / (D : ℝ))) :
    ∃ c₁ : ℝ, 0 < c₁ ∧ ∃ c₂ : ℝ, 0 < c₂ ∧ ∃ Kev : ℝ, 0 ≤ Kev ∧ ∃ X₀ : ℝ,
      (∀ X : ℝ, X₀ ≤ X →
        c₁ * logCube X ≤ muB P b sigmaSmallM roughFactorM X
          ∧ muB P b sigmaSmallM roughFactorM X ≤ c₂ * logCube X)
      ∧ (∀ X : ℝ, X₀ ≤ X → ∀ D : ℕ, 1 ≤ D →
        BM X D ≤ Kev * (muB P b sigmaSmallM roughFactorM X / (D : ℝ) ^ 2)
          ∧ BsingleM X D ≤
            Kev * (muB P b sigmaSmallM roughFactorM X / (D : ℝ))) :=
  mass_law_and_event_tensor_of_factor_event_comparable
    P b sigmaSmall roughFactor sigmaSmallM roughFactorM hSig hR
    Xsig Xrough aSig ASig aR AR haSig hASig haR hAR hSigCmp hRoughCmp
    B Bsingle BM BsingleM Xevent Aevent hAevent hEventCmp
    Kassemb XB hKassemb hassemb

/-- Fixed-`m` finite-Euler-factor deletion with the assembled event constant's
sign absorbed internally.

This is the same paper-facing bridge as
`fixed_m_finite_euler_deletion_mass_event_tensor_outputs`, but it no longer
requires a separate proof `0 ≤ Kassemb`; the downstream constant is allowed to
use `max` after the eventual log-cube range is reached. -/
theorem fixed_m_finite_euler_deletion_mass_event_tensor_outputs_auto_event_constant
    (P : Params) (b : ℕ)
    (sigmaSmall roughFactor sigmaSmallM roughFactorM : ℝ → ℝ)
    (hSig : FactorAsymp sigmaSmall sigmaShape)
    (hR : FactorAsymp roughFactor roughShape)
    (Xsig Xrough aSig ASig aR AR : ℝ)
    (haSig : 0 < aSig) (hASig : 0 < ASig)
    (haR : 0 < aR) (hAR : 0 < AR)
    (hSigCmp : ∀ X : ℝ, Xsig ≤ X →
      aSig * sigmaSmall X ≤ sigmaSmallM X ∧
        sigmaSmallM X ≤ ASig * sigmaSmall X)
    (hRoughCmp : ∀ X : ℝ, Xrough ≤ X →
      aR * roughFactor X ≤ roughFactorM X ∧
        roughFactorM X ≤ AR * roughFactor X)
    (B Bsingle BM BsingleM : ℝ → ℕ → ℝ)
    (Xevent Aevent : ℝ) (hAevent : 0 ≤ Aevent)
    (hEventCmp : ∀ X : ℝ, Xevent ≤ X → ∀ D : ℕ, 1 ≤ D →
      BM X D ≤ Aevent * B X D ∧ BsingleM X D ≤ Aevent * Bsingle X D)
    (Kassemb XB : ℝ)
    (hassemb : ∀ X : ℝ, XB ≤ X → ∀ D : ℕ, 1 ≤ D →
        B X D ≤ Kassemb * (logCube X / (D : ℝ) ^ 2)
          ∧ Bsingle X D ≤ Kassemb * (logCube X / (D : ℝ))) :
    ∃ c₁ : ℝ, 0 < c₁ ∧ ∃ c₂ : ℝ, 0 < c₂ ∧ ∃ Kev : ℝ, 0 ≤ Kev ∧ ∃ X₀ : ℝ,
      (∀ X : ℝ, X₀ ≤ X →
        c₁ * logCube X ≤ muB P b sigmaSmallM roughFactorM X
          ∧ muB P b sigmaSmallM roughFactorM X ≤ c₂ * logCube X)
      ∧ (∀ X : ℝ, X₀ ≤ X → ∀ D : ℕ, 1 ≤ D →
        BM X D ≤ Kev * (muB P b sigmaSmallM roughFactorM X / (D : ℝ) ^ 2)
          ∧ BsingleM X D ≤
            Kev * (muB P b sigmaSmallM roughFactorM X / (D : ℝ))) :=
  mass_law_and_event_tensor_of_factor_event_comparable_arbitrary_event_constant
    P b sigmaSmall roughFactor sigmaSmallM roughFactorM hSig hR
    Xsig Xrough aSig ASig aR AR haSig hASig haR hAR hSigCmp hRoughCmp
    B Bsingle BM BsingleM Xevent Aevent hAevent hEventCmp
    Kassemb XB hassemb

/-! ## Fixed-numerator transfer packages -/

/-- Fixed-numerator analogue of the final assembly inputs used in `thm:fixed-m`.

This structure does not assert the fixed-`m` transfer estimates themselves.  It
records the final data derived from the fixed-`m` event family before the last
smooth-lifting and Euler-product absorption step. -/
structure FixedNumeratorMainInputs (m : ℕ) where
  /-- reduced-class missed count for the fixed-`m` family. -/
  Ered : ℕ → ℕ
  Ered_c₁ : ℝ
  Ered_C₁ : ℝ
  Ered_pos₁ : 0 < Ered_c₁
  Ered_posC₁ : 0 < Ered_C₁
  Ered_bound : ∀ N : ℕ, 3 ≤ N →
    (Ered N : ℝ) ≤ Ered_C₁ * ((N : ℝ) * saving Ered_c₁ N)
  /-- smooth-lifting range contribution. -/
  smooth : ℕ → ℝ
  smoothExp : ℝ
  smoothC : ℝ
  smoothExp_pos : 0 < smoothExp
  smoothExp_lt_one : smoothExp < 1
  smoothC_pos : 0 < smoothC
  smooth_bound : ∀ N : ℕ, 3 ≤ N → smooth N ≤ smoothC * (N : ℝ) ^ smoothExp
  /-- finite Euler-product loss from the fixed-`m` lifting step. -/
  euler : ℕ → ℝ
  eulerC : ℝ
  eulerC_pos : 0 < eulerC
  euler_bound_four : ∀ N : ℕ, 3 ≤ N → euler N ≤ eulerC * (Real.log N) ^ (4 : ℕ)
  /-- final fixed-`m` lifting inequality. -/
  lift : ∀ N : ℕ, 3 ≤ N →
    (fixedNumeratorExceptionalCount m N : ℝ) ≤ smooth N + euler N * (Ered N : ℝ)

/-- Fixed-numerator transfer/lifting package in the shape supplied by
`prop:fixed-m-transfer` after summing the fixed-`m` finite-interval estimates
over reduced base classes and adding the smooth-lifting decomposition.

This is deliberately separate from `FixedNumeratorMainInputs`: it records the
paper's intermediate handoff from the fixed-`m` transfer estimates to the final
main-bound assembly.  Proving this package from the finite-prime-deletion
argument is the remaining hard fixed-`m` work. -/
structure FixedNumeratorTransferPackage (m : ℕ) where
  /-- reduced fixed-`m` missed count after the per-base finite-transfer step. -/
  Ered : ℕ → ℕ
  Ered_c₁ : ℝ
  Ered_C₁ : ℝ
  Ered_pos₁ : 0 < Ered_c₁
  Ered_posC₁ : 0 < Ered_C₁
  /-- Summed reduced-count saving supplied by the fixed-`m` transfer estimates. -/
  Ered_bound : ∀ N : ℕ, 3 ≤ N →
    (Ered N : ℝ) ≤ Ered_C₁ * ((N : ℝ) * saving Ered_c₁ N)
  /-- Smooth-lifting range contribution for the fixed numerator. -/
  smooth : ℕ → ℝ
  smoothExp : ℝ
  smoothC : ℝ
  smoothExp_pos : 0 < smoothExp
  smoothExp_lt_one : smoothExp < 1
  smoothC_pos : 0 < smoothC
  smooth_bound : ∀ N : ℕ, 3 ≤ N → smooth N ≤ smoothC * (N : ℝ) ^ smoothExp
  /-- Fixed-`m` Euler/lifting loss; constants may depend on `m`. -/
  euler : ℕ → ℝ
  eulerC : ℝ
  eulerC_pos : 0 < eulerC
  euler_bound_four : ∀ N : ℕ, 3 ≤ N → euler N ≤ eulerC * (Real.log N) ^ (4 : ℕ)
  /-- Final fixed-`m` lifting inequality combining smooth and rough ranges. -/
  lift : ∀ N : ℕ, 3 ≤ N →
    (fixedNumeratorExceptionalCount m N : ℝ) ≤ smooth N + euler N * (Ered N : ℝ)

/-- Build the fixed-numerator transfer package from the large-range
finite-transfer estimate, a finite initial certificate, and the fixed-`m`
smooth/rough lifting bounds.

This is the formal version of the handoff in `thm:fixed-m`: after
`prop:fixed-m-transfer` gives the no-hit finite-transfer estimate in every
reduced class for all sufficiently large `N`, and the remaining finite range is
checked separately, the data have exactly the package shape consumed by the
final fixed-numerator assembly. -/
noncomputable def fixedNumeratorTransferPackage_of_large_finite_transfer_and_lift
    {ι : Type*}
    (m : ℕ)
    (cls : ℕ → Finset ι)
    (Mb : ℕ → ι → ℝ)
    (Ered : ℕ → ℕ)
    (Pz μ ε : ℕ → ℝ)
    (c Cinit : ℝ) (T0 : ℕ)
    (hc : 0 < c) (hCinit : 0 < Cinit)
    (hEred_sum : ∀ N : ℕ, 3 ≤ N →
      (Ered N : ℝ) ≤ ∑ b ∈ cls N, Mb N b)
    (hPz : ∀ N : ℕ, 3 ≤ N → T0 ≤ N → 1 ≤ Pz N)
    (hcard : ∀ N : ℕ, 3 ≤ N → T0 ≤ N → ((cls N).card : ℝ) ≤ Pz N)
    (htransfer : ∀ N : ℕ, 3 ≤ N → T0 ≤ N → ∀ b ∈ cls N,
      Mb N b ≤ ((N : ℝ) / Pz N) * Real.exp (-(1 - ε N) * μ N))
    (hsaving : ∀ N : ℕ, 3 ≤ N → T0 ≤ N →
      c * (Real.log N) ^ ((3 : ℝ) / 4) ≤ (1 - ε N) * μ N)
    (hinitial : ∀ N : ℕ, 3 ≤ N → N < T0 →
      (Ered N : ℝ) ≤ Cinit * ((N : ℝ) * saving c N))
    (smooth : ℕ → ℝ) (smoothExp smoothC : ℝ)
    (smoothExp_pos : 0 < smoothExp)
    (smoothExp_lt_one : smoothExp < 1)
    (smoothC_pos : 0 < smoothC)
    (smooth_bound : ∀ N : ℕ, 3 ≤ N →
      smooth N ≤ smoothC * (N : ℝ) ^ smoothExp)
    (euler : ℕ → ℝ) (eulerC : ℝ)
    (eulerC_pos : 0 < eulerC)
    (euler_bound_four : ∀ N : ℕ, 3 ≤ N →
      euler N ≤ eulerC * (Real.log N) ^ (4 : ℕ))

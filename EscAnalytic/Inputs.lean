/-- Fully separated version of the rough Euler-product/error target: the lower
finite-product estimate, upper finite-product estimate, and exact finite-error
estimate may have different thresholds. -/
def roughDyadicBadPrimeSeparatedEulerProductErrorBound
    (a₀ b₀ C₀ : ℝ) : Prop :=
  ∃ c C E Xlo Xhi Xerr : ℝ, 0 < c ∧ 0 < C ∧ E < c ∧
    (∀ X : ℝ, Xlo ≤ X →
      c / Real.log (EscAnalytic.zScale X) ≤
        roughDyadicBadPrimeMainEulerProduct X) ∧
    (∀ X : ℝ, Xhi ≤ X →
      roughDyadicBadPrimeMainEulerProduct X ≤
        C / Real.log (EscAnalytic.zScale X)) ∧
    roughDyadicBadPrimeProductErrorBound a₀ b₀ C₀ E Xerr

/-- Split version of the rough Euler-product/error target.  The Mertens-type
two-sided bound for the finite product is independent of `M` and `t`; the exact
finite error is controlled separately, with an error constant strictly smaller
than the product lower constant. -/
def roughDyadicBadPrimeSplitEulerProductErrorBound
    (a₀ b₀ C₀ : ℝ) : Prop :=
  ∃ c C E Xprod Xerr : ℝ, 0 < c ∧ 0 < C ∧ 0 ≤ E ∧ E < c ∧
    (∀ X : ℝ, Xprod ≤ X →
      c / Real.log (EscAnalytic.zScale X) ≤
          roughDyadicBadPrimeMainEulerProduct X ∧
        roughDyadicBadPrimeMainEulerProduct X ≤
          C / Real.log (EscAnalytic.zScale X)) ∧
    (∀ X : ℝ, Xerr ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        |roughDyadicBadPrimeProductErrorSum X M t| ≤
          E * (t / Real.log (EscAnalytic.zScale X)))

/-- The separated finite-product/error formulation implies the split
finite-product/error formulation by taking the maximum of the two product
thresholds and preserving the independent error threshold. -/
theorem roughDyadicBadPrimeSplitEulerProductErrorBound_of_separated
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicBadPrimeSeparatedEulerProductErrorBound a₀ b₀ C₀) :
    roughDyadicBadPrimeSplitEulerProductErrorBound a₀ b₀ C₀ := by
  rcases h with ⟨c, C, E, Xlo, Xhi, Xerr, hc, hC, hE_lt,
    hprod_lo, hprod_hi, herror⟩
  rcases herror with ⟨hE_nonneg, herr⟩
  refine ⟨c, C, E, max Xlo Xhi, Xerr, hc, hC, hE_nonneg, hE_lt, ?_, herr⟩
  intro X hX
  have hXlo : Xlo ≤ X := le_trans (le_max_left _ _) hX
  have hXhi : Xhi ≤ X := le_trans (le_max_right _ _) hX
  exact ⟨hprod_lo X hXlo, hprod_hi X hXhi⟩

/-- Conversely, the split finite-product/error formulation gives the fully
separated formulation by reusing the same product threshold for the lower and
upper finite-product estimates. -/
theorem roughDyadicBadPrimeSeparatedEulerProductErrorBound_of_split
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicBadPrimeSplitEulerProductErrorBound a₀ b₀ C₀) :
    roughDyadicBadPrimeSeparatedEulerProductErrorBound a₀ b₀ C₀ := by
  rcases h with ⟨c, C, E, Xprod, Xerr, hc, hC, hE_nonneg, hE_lt,
    hprod, herr⟩
  refine ⟨c, C, E, Xprod, Xprod, Xerr, hc, hC, hE_lt, ?_, ?_,
    ⟨hE_nonneg, herr⟩⟩
  · intro X hX
    exact (hprod X hX).1
  · intro X hX
    exact (hprod X hX).2

/-- The split and separated finite-product/error formulations have the same
content; only the bookkeeping of product thresholds differs. -/
theorem roughDyadicBadPrimeSplitEulerProductErrorBound_iff_separated
    (a₀ b₀ C₀ : ℝ) :
    roughDyadicBadPrimeSplitEulerProductErrorBound a₀ b₀ C₀ ↔
      roughDyadicBadPrimeSeparatedEulerProductErrorBound a₀ b₀ C₀ := by
  constructor
  · exact roughDyadicBadPrimeSeparatedEulerProductErrorBound_of_split
  · exact roughDyadicBadPrimeSplitEulerProductErrorBound_of_separated

/-- Lower-only split version of the rough Euler-product/error target.  This
is the part of the sieve input that actually produces the lower count bound:
a one-sided Mertens lower bound for the finite product and an exact error bound
with a smaller constant. -/
def roughDyadicBadPrimeLowerEulerProductErrorBound
    (a₀ b₀ C₀ : ℝ) : Prop :=
  ∃ c E Xprod Xerr : ℝ, 0 < c ∧ 0 ≤ E ∧ E < c ∧
    (∀ X : ℝ, Xprod ≤ X →
      c / Real.log (EscAnalytic.zScale X) ≤
          roughDyadicBadPrimeMainEulerProduct X) ∧
    (∀ X : ℝ, Xerr ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        |roughDyadicBadPrimeProductErrorSum X M t| ≤
          E * (t / Real.log (EscAnalytic.zScale X)))

/-- Lower-only split target with the error stated in the one-sided form that
the lower count actually needs. -/
def roughDyadicBadPrimeLowerEulerProductLowerErrorBound
    (a₀ b₀ C₀ : ℝ) : Prop :=
  ∃ c E Xprod Xerr : ℝ, 0 < c ∧ 0 ≤ E ∧ E < c ∧
    (∀ X : ℝ, Xprod ≤ X →
      c / Real.log (EscAnalytic.zScale X) ≤
          roughDyadicBadPrimeMainEulerProduct X) ∧
    roughDyadicBadPrimeProductErrorLowerBound a₀ b₀ C₀ E Xerr

/-- One-sided split version of the rough Euler-product/error target.  The lower
count uses the product lower bound and the lower signed error; the upper count
uses only the upper signed error together with the unconditional product upper
bound. -/
def roughDyadicBadPrimeOneSidedEulerProductErrorBound
    (a₀ b₀ C₀ : ℝ) : Prop :=
  ∃ c Elower Eupper Xprod Xlower Xupper : ℝ,
    0 < c ∧ 0 ≤ Elower ∧ Elower < c ∧ 0 ≤ Eupper ∧
    (∀ X : ℝ, Xprod ≤ X →
      c / Real.log (EscAnalytic.zScale X) ≤
          roughDyadicBadPrimeMainEulerProduct X) ∧
    roughDyadicBadPrimeProductErrorLowerBound a₀ b₀ C₀ Elower Xlower ∧
    roughDyadicBadPrimeProductErrorUpperBound a₀ b₀ C₀ Eupper Xupper

/-- The absolute-error lower Euler-product target implies the sharper
one-sided-error target. -/
theorem roughDyadicBadPrimeLowerEulerProductLowerErrorBound_of_lowerEulerProductError
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicBadPrimeLowerEulerProductErrorBound a₀ b₀ C₀) :
    roughDyadicBadPrimeLowerEulerProductLowerErrorBound a₀ b₀ C₀ := by
  rcases h with ⟨c, E, Xprod, Xerr, hc, hE_nonneg, hE_lt, hprod, herr⟩
  refine ⟨c, E, Xprod, Xerr, hc, hE_nonneg, hE_lt, hprod, ?_⟩
  exact roughDyadicBadPrimeProductErrorLowerBound_of_errorBound
    ⟨hE_nonneg, herr⟩

/-- A separately supplied finite-product lower bound and one-sided lower error
estimate give the exact one-sided lower Euler-product/error target. -/
theorem roughDyadicBadPrimeLowerEulerProductLowerErrorBound_of_productLower_and_errorLower
    {a₀ b₀ C₀ c E Xprod Xerr : ℝ}
    (hc : 0 < c) (hE_lt : E < c)
    (hprod : ∀ X : ℝ, Xprod ≤ X →
      c / Real.log (EscAnalytic.zScale X) ≤
        roughDyadicBadPrimeMainEulerProduct X)
    (herr : roughDyadicBadPrimeProductErrorLowerBound a₀ b₀ C₀ E Xerr) :
    roughDyadicBadPrimeLowerEulerProductLowerErrorBound a₀ b₀ C₀ :=
  ⟨c, E, Xprod, Xerr, hc, herr.1, hE_lt, hprod, herr⟩

/-- Product-lower control plus independent one-sided lower and upper signed
error controls give the one-sided Euler-product/error package. -/
theorem roughDyadicBadPrimeOneSidedEulerProductErrorBound_of_productLower_and_errors
    {a₀ b₀ C₀ c Elower Eupper Xprod Xlower Xupper : ℝ}
    (hc : 0 < c) (hE_lt : Elower < c)
    (hprod : ∀ X : ℝ, Xprod ≤ X →
      c / Real.log (EscAnalytic.zScale X) ≤
        roughDyadicBadPrimeMainEulerProduct X)
    (hlower :
      roughDyadicBadPrimeProductErrorLowerBound a₀ b₀ C₀ Elower Xlower)
    (hupper :
      roughDyadicBadPrimeProductErrorUpperBound a₀ b₀ C₀ Eupper Xupper) :
    roughDyadicBadPrimeOneSidedEulerProductErrorBound a₀ b₀ C₀ :=
  ⟨c, Elower, Eupper, Xprod, Xlower, Xupper, hc, hlower.1, hE_lt,
    hupper.1, hprod, hlower, hupper⟩

/-- A general one-sided Euler-product/error package with auxiliary exponent
`0` specializes theorem-level to the modulus-one package. -/
theorem roughDyadicBadPrimeOneSidedEulerProductErrorBoundModulusOne_of_zero
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicBadPrimeOneSidedEulerProductErrorBound a₀ b₀ 0) :
    roughDyadicBadPrimeOneSidedEulerProductErrorBoundModulusOne a₀ b₀ C₀ := by
  rcases h with
    ⟨c, Elower, Eupper, Xprod, Xlower, Xupper, hc, hElower_nonneg,
      hE_lt, hEupper_nonneg, hprod, hlower, hupper⟩
  exact
    ⟨c, Elower, Eupper, Xprod, Xlower, Xupper, hc, hElower_nonneg,
      hE_lt, hEupper_nonneg, hprod,
      roughDyadicBadPrimeProductErrorLowerBoundModulusOne_of_errorLower_zero
        hlower,
      roughDyadicBadPrimeProductErrorUpperBoundModulusOne_of_errorUpper_zero
        hupper⟩

/-- A separately supplied finite-product lower bound and exact-error estimate
are exactly the remaining lower rough-sieve data.  The error package carries
`0 ≤ E`; the caller only has to ensure the error constant is strictly smaller
than the product lower constant. -/
theorem roughDyadicBadPrimeLowerEulerProductErrorBound_of_productLower_and_error
    {a₀ b₀ C₀ c E Xprod Xerr : ℝ}
    (hc : 0 < c) (hE_lt : E < c)
    (hprod : ∀ X : ℝ, Xprod ≤ X →
      c / Real.log (EscAnalytic.zScale X) ≤
        roughDyadicBadPrimeMainEulerProduct X)
    (herr : roughDyadicBadPrimeProductErrorBound a₀ b₀ C₀ E Xerr) :
    roughDyadicBadPrimeLowerEulerProductErrorBound a₀ b₀ C₀ := by
  rcases herr with ⟨hE_nonneg, herr⟩
  exact ⟨c, E, Xprod, Xerr, hc, hE_nonneg, hE_lt, hprod, herr⟩

/-- Product-lower control plus separated multiples-discrepancy and filter-loss
bounds give the lower finite-product/error target. -/
theorem roughDyadicBadPrimeLowerEulerProductErrorBound_of_productLower_and_multiples_filterLoss
    {a₀ b₀ C₀ c Em Ef Xprod Xm Xf : ℝ}
    (hc : 0 < c) (hE_lt : Em + Ef < c)
    (hprod : ∀ X : ℝ, Xprod ≤ X →
      c / Real.log (EscAnalytic.zScale X) ≤
        roughDyadicBadPrimeMainEulerProduct X)
    (hm :
      roughDyadicBadPrimeProductMultiplesLocalErrorEnvelopeBound
        a₀ b₀ C₀ Em Xm)
    (hf :
      roughDyadicBadPrimeProductFilterLossEnvelopeBound
        a₀ b₀ C₀ Ef Xf) :
    roughDyadicBadPrimeLowerEulerProductErrorBound a₀ b₀ C₀ :=
  roughDyadicBadPrimeLowerEulerProductErrorBound_of_productLower_and_error
    hc hE_lt hprod
    (roughDyadicBadPrimeProductErrorBound_of_multiples_and_filterLoss hm hf)

/-- Product-lower control plus separate multiples-discrepancy, squarefree-loss,
and auxiliary-loss bounds give the lower finite-product/error target. -/
theorem roughDyadicBadPrimeLowerEulerProductErrorBound_of_productLower_and_multiples_squarefree_auxiliary
    {a₀ b₀ C₀ c Em Es Ea Xprod Xm Xs Xa : ℝ}
    (hc : 0 < c) (hE_lt : Em + (Es + Ea) < c)
    (hprod : ∀ X : ℝ, Xprod ≤ X →
      c / Real.log (EscAnalytic.zScale X) ≤
        roughDyadicBadPrimeMainEulerProduct X)
    (hm :
      roughDyadicBadPrimeProductMultiplesLocalErrorEnvelopeBound
        a₀ b₀ C₀ Em Xm)
    (hs :
      roughDyadicBadPrimeProductSquarefreeLossEnvelopeBound
        a₀ b₀ C₀ Es Xs)
    (ha :
      roughDyadicBadPrimeProductAuxiliaryLossEnvelopeBound
        a₀ b₀ C₀ Ea Xa) :
    roughDyadicBadPrimeLowerEulerProductErrorBound a₀ b₀ C₀ :=
  roughDyadicBadPrimeLowerEulerProductErrorBound_of_productLower_and_error
    hc hE_lt hprod
    (roughDyadicBadPrimeProductErrorBound_of_multiples_squarefree_auxiliary
      hm hs ha)

/-- Product-lower control plus separate multiples-discrepancy, squarefree-loss,
and auxiliary-prime-multiples bounds give the lower finite-product/error target. -/
theorem roughDyadicBadPrimeLowerEulerProductErrorBound_of_productLower_and_multiples_squarefree_auxiliaryPrimeMultiples
    {a₀ b₀ C₀ c Em Es Ea Xprod Xm Xs Xa : ℝ}
    (hc : 0 < c) (hE_lt : Em + (Es + Ea) < c)
    (hprod : ∀ X : ℝ, Xprod ≤ X →

/-- The live positive-range signed-multiples package is equivalent to the
positive-range explicit floor-error package. -/
theorem LinearSieveRoughDyadicMultiplesFloorErrorAbsQuarterBoundOnPositiveRanges_iff_signed :
    LinearSieveRoughDyadicMultiplesFloorErrorAbsQuarterBoundOnPositiveRanges ↔
      LinearSieveRoughDyadicMultiplesSignedErrorQuarterBoundOnPositiveRanges := by
  constructor
  · exact LinearSieveRoughDyadicMultiplesSignedErrorQuarterBoundOnPositiveRanges_of_floorErrorAbs
  · exact LinearSieveRoughDyadicMultiplesFloorErrorAbsQuarterBoundOnPositiveRanges_of_signed

/-- The symmetric and two-one-sided signed-multiples quarter-budget packages
are equivalent. -/
theorem LinearSieveRoughDyadicMultiplesSignedErrorQuarterBound_iff_abs :
    LinearSieveRoughDyadicMultiplesSignedErrorQuarterBound ↔

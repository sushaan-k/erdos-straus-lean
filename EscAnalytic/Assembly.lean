        C * (primePi N : ℝ) * ((N : ℝ) / Real.log (N : ℝ)) * saving c N :=
  prime_bound_le_primePi_bertrand_loss (cor_prime_exceptional H)

/-- Relative density-zero consequence of `cor_prime_exceptional` among primes. -/
theorem cor_prime_exceptional_relative_density_zero (H : MainInputs) :
    Filter.Tendsto (fun N : ℕ => (primeExceptionalCount N : ℝ) / (primePi N : ℝ))
      Filter.atTop (nhds 0) :=
  prime_exceptional_relative_density_zero_of_main (erdos_straus_main H)

/-- The finite smooth-part carrier used by `LiftCount` is bounded by the
`smoothPsi` carrier from `Main`.

This is a definitional bridge, not an analytic estimate: both sides count
positive integers up to `B` whose prime factors are at most `z`; the right side
uses the real-valued smoothness predicate used by the smooth-number inputs. -/
/- ## Smooth-number carriers and Rankin bounds -/

theorem smoothPartCount_le_smoothPsi (z B : ℕ) :
    (smoothPartCount z B : ℝ) ≤ smoothPsi (B : ℝ) (z : ℝ) := by
  classical
  unfold smoothPartCount smoothPsi IsSmooth
  norm_num

/-- The real-valued `smoothPsi` carrier at natural arguments embeds into
Mathlib's finite smooth-number carrier.

This is another carrier bridge, not an asymptotic estimate: the project uses the
`≤ z` convention on prime factors, while Mathlib's `smoothNumbers (z+1)` uses
the strict `< z+1` convention. -/
theorem smoothPsi_nat_le_smoothNumbersUpTo (z B : ℕ) :
    smoothPsi (B : ℝ) (z : ℝ) ≤
      ((Nat.smoothNumbersUpTo B (z + 1)).card : ℝ) := by
  classical
  unfold smoothPsi
  have hcard :
      ((Finset.Icc (1 : ℕ) ⌊(B : ℝ)⌋₊).filter
          (fun n : ℕ => ∀ p : ℕ, Nat.Prime p → p ∣ n → (p : ℝ) ≤ (z : ℝ))).card
        ≤ (Nat.smoothNumbersUpTo B (z + 1)).card := by
    apply Finset.card_le_card
    intro s hs
    rw [Finset.mem_filter, Finset.mem_Icc] at hs
    rw [Nat.mem_smoothNumbersUpTo]
    refine ⟨by simpa using hs.1.2, ?_⟩
    exact (isSmooth_iff_mem_smoothNumbers_succ z s).mp (by
      intro p hp hpd
      exact_mod_cast hs.2 p hp hpd)
  exact_mod_cast hcard

/-- Rankin-ready form of the checked smooth-range envelope.

`LiftCount.smoothRangeCount_le_sum_smoothPartCount` performs the finite fibering
by rough part.  This wrapper replaces the auxiliary `smoothPartCount` carrier by
`Main.smoothPsi`, the exact carrier constrained by the cited smooth-number
inputs. -/
theorem smoothRangeCount_le_sum_smoothPsi (z N : ℕ) :
    (smoothRangeCount z N : ℝ) ≤
      ∑ m ∈ Finset.Icc 1 (Nat.sqrt N), smoothPsi ((N / m : ℕ) : ℝ) (z : ℝ) := by
  classical
  have hbase := smoothRangeCount_le_sum_smoothPartCount z N
  calc
    (smoothRangeCount z N : ℝ)
        ≤ ∑ m ∈ Finset.Icc 1 (Nat.sqrt N), (smoothPartCount z (N / m) : ℝ) := by
          exact_mod_cast hbase
    _ ≤ ∑ m ∈ Finset.Icc 1 (Nat.sqrt N), smoothPsi ((N / m : ℕ) : ℝ) (z : ℝ) := by
          apply Finset.sum_le_sum
          intro m _hm
          exact smoothPartCount_le_smoothPsi z (N / m)

/-- Rankin-ready form of the checked fixed-numerator smooth-range envelope.

This is the fixed-`m` analogue of `smoothRangeCount_le_sum_smoothPsi`: the
finite fibering is proved in `FixedNumeratorLift`, and the auxiliary
`smoothPartCount` carrier is replaced by the same `smoothPsi` carrier used by
the smooth-number input. -/
theorem fixedNumeratorSmoothRangeCount_le_sum_smoothPsi (m z N : ℕ) :
    (fixedNumeratorSmoothRangeCount m z N : ℝ) ≤
      ∑ r ∈ Finset.Icc 1 (Nat.sqrt N), smoothPsi ((N / r : ℕ) : ℝ) (z : ℝ) := by
  classical
  have hbase := fixedNumeratorSmoothRangeCount_le_sum_smoothPartCount m z N
  calc
    (fixedNumeratorSmoothRangeCount m z N : ℝ)
        ≤ ∑ r ∈ Finset.Icc 1 (Nat.sqrt N), (smoothPartCount z (N / r) : ℝ) := by
          exact_mod_cast hbase
    _ ≤ ∑ r ∈ Finset.Icc 1 (Nat.sqrt N), smoothPsi ((N / r : ℕ) : ℝ) (z : ℝ) := by
          apply Finset.sum_le_sum
          intro r _hr
          exact smoothPartCount_le_smoothPsi z (N / r)

/-- Integer version of the manuscript cutoff `z_N = (log N)^4`.

The smooth/rough combinatorics in `LiftCount` is naturally indexed by a natural
threshold, while the analytic scale is real-valued.  We regularize the finite
initial range by forcing the threshold to be at least `2`; this does not change
the asymptotic cutoff and makes the canonical product-of-primes modulus
nondegenerate at every level `N ≥ 3`. -/
noncomputable def zNatScale (N : ℕ) : ℕ :=
  max 2 ⌊zScale (N : ℝ)⌋₊

/-- The regularized natural cutoff is always large enough to define the
canonical prime product without a separate small-`N` side condition. -/
theorem two_le_zNatScale (N : ℕ) : 2 ≤ zNatScale N := by
  unfold zNatScale
  exact le_max_left 2 ⌊zScale (N : ℝ)⌋₊

/-- Uniform final assembly from the checked smooth and reduced-class finite
carriers.

This specializes
`UniformNumeratorLargeRangeInputs.of_uniform_final_assembly_reduced_sum_lift` to
the manuscript cutoff `zNatScale`, the Rankin-ready `smoothPsi` smooth carrier,
and the reduced-class uniform-envelope summation.  It removes two more finite
bookkeeping premises from the uniform-saturation surface: the smooth-count
bound is obtained from `fixedNumeratorSmoothRangeCount_le_sum_smoothPsi`, and
the reduced-sum bound is obtained directly from the finite reduced-class
summation lemma. -/
noncomputable def UniformNumeratorLargeRangeInputs.of_uniform_final_assembly_smoothPsi_class_envelope
    {κ : Type*} [DecidableEq κ]
    {A Ered_c₁ Ered_C₁ smoothExp smoothC eulerC B : ℝ} (T : ℕ)
    (hEred_c₁ : 0 < Ered_c₁) (hEred_C₁ : 0 < Ered_C₁)
    (hsmoothExp_pos : 0 < smoothExp) (hsmoothExp_lt_one : smoothExp < 1)
    (hsmoothC_pos : 0 < smoothC) (heulerC_pos : 0 < eulerC)
    (hB : 0 < B)
    (Ered : ℕ → ℕ → ℕ) (smooth : ℕ → ℕ → ℝ)
    (clsRed : ℕ → ℕ → ℕ → Finset κ)
    (classOfRed : ℕ → ℕ → ℕ → ℕ → κ)
    (Ured : ℕ → ℕ → ℕ → ℝ)
    (hEred : ∀ N m : ℕ, 3 ≤ N → T ≤ N → 2 ≤ m →
      (m : ℝ) ≤ (Real.log N) ^ A →
        (Ered m N : ℝ) ≤ Ered_C₁ * ((N : ℝ) * saving Ered_c₁ N))
    (hsmooth : ∀ N m : ℕ, 3 ≤ N → T ≤ N → 2 ≤ m →
      (m : ℝ) ≤ (Real.log N) ^ A →
        smooth m N ≤ smoothC * (N : ℝ) ^ smoothExp)
    (heuler : ∀ N m : ℕ, 3 ≤ N → T ≤ N → 2 ≤ m →
      (m : ℝ) ≤ (Real.log N) ^ A →
        eulerProductFactorAtNat N ≤ eulerC * (Real.log N) ^ (4 : ℕ))
    (hsmoothPsi_sum : ∀ N m : ℕ, 3 ≤ N → T ≤ N → 2 ≤ m →
      (m : ℝ) ≤ (Real.log N) ^ A →
        (∑ r ∈ Finset.Icc 1 (Nat.sqrt N),
            smoothPsi ((N / r : ℕ) : ℝ) (zNatScale N : ℝ)) ≤ smooth m N)
    (hred_class_mem_large : ∀ N m : ℕ, 3 ≤ N → T ≤ N → 2 ≤ m →
      (m : ℝ) ≤ (Real.log N) ^ A → ∀ s ∈ Finset.Icc 1 N,
        ∀ r ∈ ((Finset.Icc 1 (N / s)).filter
          (fun r => IsRough (zNatScale N) r ∧ ¬ fixedNumeratorRepresentable m r)),
            classOfRed m N s r ∈ clsRed m N s)
    (hred_class_bound_large : ∀ N m : ℕ, 3 ≤ N → T ≤ N → 2 ≤ m →
      (m : ℝ) ≤ (Real.log N) ^ A → ∀ s ∈ Finset.Icc 1 N,
        ∀ b ∈ clsRed m N s,
          ((((Finset.Icc 1 (N / s)).filter
            (fun r => (IsRough (zNatScale N) r ∧ ¬ fixedNumeratorRepresentable m r) ∧
              classOfRed m N s r = b)).card : ℕ) : ℝ) ≤ Ured m N s)
    (hred_class_uniform_sum_large : ∀ N m : ℕ, 3 ≤ N → T ≤ N → 2 ≤ m →
      (m : ℝ) ≤ (Real.log N) ^ A →
        (∑ s ∈ Finset.Icc 1 N, ((clsRed m N s).card : ℝ) * Ured m N s) ≤
          eulerProductFactorAtNat N * (Ered m N : ℝ)) :
    UniformNumeratorLargeRangeInputs A :=
  UniformNumeratorLargeRangeInputs.of_uniform_final_assembly_reduced_sum_lift
    T hEred_c₁ hEred_C₁ hsmoothExp_pos hsmoothExp_lt_one hsmoothC_pos
    heulerC_pos hB Ered smooth (fun _m N => eulerProductFactorAtNat N)
    (fun _m N => zNatScale N)
    hEred hsmooth heuler
    (by
      intro N m hN hTN hm hm_log
      exact le_trans (fixedNumeratorSmoothRangeCount_le_sum_smoothPsi m (zNatScale N) N)
        (hsmoothPsi_sum N m hN hTN hm hm_log))
    (by
      intro N m hN hTN hm hm_log
      exact fixedNumeratorReduced_sum_le_of_class_uniform_majorants
        (m := m) (z := zNatScale N) (N := N)
        (euler := eulerProductFactorAtNat N) (Ered := (Ered m N : ℝ))
        (cls := clsRed m N) (classOf := classOfRed m N) (U := Ured m N)
        (hred_class_mem_large N m hN hTN hm hm_log)
        (hred_class_bound_large N m hN hTN hm hm_log)
        (hred_class_uniform_sum_large N m hN hTN hm hm_log))

/-- The real cutoff `zScale N = (log N)^4` is monotone on natural inputs.

The only small-endpoint wrinkle is `N = 0`, where Lean's real logarithm is
defined as `0`; the fourth power is still nonnegative, so monotonicity starts at
the regularized origin. -/
theorem zScale_nat_mono {M N : ℕ} (hMN : M ≤ N) :
    zScale (M : ℝ) ≤ zScale (N : ℝ) := by
  unfold zScale
  by_cases hM0 : M = 0
  · subst M
    simp only [Nat.cast_zero, Real.log_zero]
    nlinarith [sq_nonneg ((Real.log (N : ℝ)) ^ 2)]
  · have hMposNat : 0 < M := Nat.pos_of_ne_zero hM0
    have hMpos : 0 < (M : ℝ) := by exact_mod_cast hMposNat
    have hMone : 1 ≤ (M : ℝ) := by exact_mod_cast hMposNat
    have hlog_nonneg : 0 ≤ Real.log (M : ℝ) := Real.log_nonneg hMone
    have hMNreal : (M : ℝ) ≤ (N : ℝ) := by exact_mod_cast hMN
    have hlog_le : Real.log (M : ℝ) ≤ Real.log (N : ℝ) :=
      Real.log_le_log hMpos hMNreal
    exact pow_le_pow_left₀ hlog_nonneg hlog_le 4

/-- The regularized natural cutoff is monotone. -/
theorem zNatScale_mono {M N : ℕ} (hMN : M ≤ N) :
    zNatScale M ≤ zNatScale N := by
  unfold zNatScale
  exact max_le_max le_rfl (Nat.floor_mono (zScale_nat_mono hMN))

/-- At dyadic cutoffs `K=2^k`, `k≥2`, the regularized natural cutoff is bounded
by a fixed multiple of `(log K)^4`. -/
theorem zNatScale_dyadic_succ_le_four_log_pow_four {k : ℕ} (hk : 2 ≤ k) :
    ((zNatScale (2 ^ k) + 1 : ℕ) : ℝ) ≤
      4 * (Real.log (((2 ^ k : ℕ) : ℝ))) ^ (4 : ℕ) := by
  let K : ℕ := 2 ^ k
  let L : ℝ := Real.log ((K : ℕ) : ℝ)
  have hKpos_nat : 0 < K := by
    dsimp [K]
    exact pow_pos (by norm_num : 0 < (2 : ℕ)) k
  have hK_ge4_nat : 4 ≤ K := by
    dsimp [K]
    calc
      4 = 2 ^ 2 := by norm_num
      _ ≤ 2 ^ k := Nat.pow_le_pow_right (by norm_num : 0 < 2) hk
  have hK_ge_exp : Real.exp 1 ≤ (K : ℝ) := by
    have hK4 : (4 : ℝ) ≤ (K : ℝ) := by exact_mod_cast hK_ge4_nat
    have hexp3 : Real.exp 1 ≤ (3 : ℝ) := by
      exact le_of_lt (Real.exp_one_lt_d9.trans (by norm_num))
    have hexp4 : Real.exp 1 ≤ (4 : ℝ) := le_trans hexp3 (by norm_num)
    exact le_trans hexp4 hK4
  have hKpos : 0 < (K : ℝ) := by exact_mod_cast hKpos_nat
  have hL_ge_one : 1 ≤ L := by
    dsimp [L]
    rw [Real.le_log_iff_exp_le hKpos]
    exact hK_ge_exp
  have hL4_ge_one : 1 ≤ L ^ (4 : ℕ) := by
    calc
      (1 : ℝ) = (1 : ℝ) ^ (4 : ℕ) := by norm_num
      _ ≤ L ^ (4 : ℕ) := pow_le_pow_left₀ (by norm_num) hL_ge_one 4
  have hz_nonneg : 0 ≤ zScale (K : ℝ) := by
    unfold zScale
    positivity
  have hfloor_le : (⌊zScale (K : ℝ)⌋₊ : ℝ) ≤ zScale (K : ℝ) :=
    Nat.floor_le hz_nonneg
  have hzNat_le : (zNatScale K : ℝ) ≤ zScale (K : ℝ) + 2 := by
    unfold zNatScale
    rw [Nat.cast_max]
    apply max_le
    · simpa [add_comm] using add_le_add_right hz_nonneg 2
    · nlinarith [hfloor_le]
  have hY_le : ((zNatScale K + 1 : ℕ) : ℝ) ≤ zScale (K : ℝ) + 3 := by
    norm_num [Nat.cast_add]
    linarith
  have hz_eq : zScale (K : ℝ) = L ^ (4 : ℕ) := by
    rfl
  have hscale : zScale (K : ℝ) + 3 ≤ 4 * zScale (K : ℝ) := by
    rw [hz_eq]
    nlinarith
  calc
    ((zNatScale (2 ^ k) + 1 : ℕ) : ℝ) = ((zNatScale K + 1 : ℕ) : ℝ) := by rfl
    _ ≤ zScale (K : ℝ) + 3 := hY_le
    _ ≤ 4 * zScale (K : ℝ) := hscale
    _ = 4 * (Real.log (((2 ^ k : ℕ) : ℝ))) ^ (4 : ℕ) := by rfl

/-- Paper-facing analytic core for the fixed-`m` Suen transfer.

This is the genuinely analytic half of the fixed-numerator Suen handoff: it
contains the per-class finite-transfer data, the standard-tail budget, and the
class-count saving, but no reduced rough-carrier envelope.  It is combined with
`FixedNumeratorPaperReducedClassEnvelopeInputs` below. -/
/- ## Fixed-numerator Suen and optimization interfaces -/

structure FixedNumeratorPaperSuenAnalyticCoreInputs
    (m : ℕ) (ι : Type*) where
  cls : ℕ → Finset ι
  Mb : ℕ → ι → ℝ
  Ered : ℕ → ℕ
  Pz : ℕ → ℝ
  μ : ℕ → ℝ
  εb : ℕ → ℝ
  δb : ℕ → ι → ℝ
  Δb : ℕ → ι → ℝ
  Xpow : ℕ → ι → ℝ
  errTerm : ℕ → ι → ℝ
  F2R : ℕ → ι → ℝ
  εK : ℝ
  c : ℝ
  T : ℕ
  c_pos : 0 < c
  Ered_sum : ∀ N : ℕ, 3 ≤ N →
    (Ered N : ℝ) ≤ ∑ b ∈ cls N, Mb N b
  mu_pos : ∀ N : ℕ, 3 ≤ N → T ≤ N → 0 < μ N
  Pz_ge_one : ∀ N : ℕ, 3 ≤ N → T ≤ N → 1 ≤ Pz N
  delta_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 0 ≤ δb N b
  Delta_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 0 ≤ Δb N b
  Xpow_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 0 ≤ Xpow N b
  suen_tail : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
    Inputs.suenTailConstant * Δb N b * Real.exp (2 * δb N b) ≤ εb N * μ N
  decomp : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
    Mb N b ≤ ((N : ℝ) / Pz N) *
      (Inputs.suenProb (μ N) (δb N b) (Δb N b) + F2R N b) + errTerm N b
  err_bound : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
    errTerm N b ≤ Xpow N b * Real.exp ((1 + εK) * μ N)
  eps_le_one : εK ≤ 1
  level : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
    Pz N * Xpow N b * Real.exp (2 * μ N) ≤ (N : ℝ) * Real.exp (-4 * μ N)
  F2R_bound : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
    F2R N b ≤ Real.exp (-3 * μ N)
  class_card : ∀ N : ℕ, 3 ≤ N → T ≤ N → ((cls N).card : ℝ) ≤ Pz N
  saving_bound : ∀ N : ℕ, 3 ≤ N → T ≤ N →
    c * (Real.log N) ^ ((3 : ℝ) / 4)
      ≤ (1 - (εb N + Real.log 3 / μ N)) * μ N

/-- Fixed-`m` analytic core before the finite-level inequality is packaged.

This version carries the optimization hypotheses used in the manuscript
(`eq:X-choice`, Mertens for `P(z)`, the level budget, and the smallness of
`α`) instead of taking the final multiplicative finite-level condition as a
field. -/
structure FixedNumeratorPaperSuenAnalyticCoreOptimizationInputs
    (m : ℕ) (ι : Type*) where
  cls : ℕ → Finset ι
  Mb : ℕ → ι → ℝ
  Ered : ℕ → ℕ
  Pz : ℕ → ℝ
  PzCount : ℕ → ℕ
  μ : ℕ → ℝ
  εb : ℕ → ℝ
  δb : ℕ → ι → ℝ
  Δb : ℕ → ι → ℝ
  Xpow : ℕ → ι → ℝ
  errTerm : ℕ → ι → ℝ
  errExp : ℕ → ι → ℝ
  F2R : ℕ → ι → ℝ
  F2RExp : ℕ → ι → ℝ
  Xscale : ℕ → ι → ℝ
  Rlevel : ℕ → ι → ℝ
  α : ℝ
  Cp : ℝ
  cμ : ℝ
  η : ℝ
  εK : ℝ
  c : ℝ
  T : ℕ
  c_pos : 0 < c
  eta_le_one : η ≤ 1
  c_le_saving_const : c ≤ (1 - η) * cμ
  Ered_sum : ∀ N : ℕ, 3 ≤ N →
    (Ered N : ℝ) ≤ ∑ b ∈ cls N, Mb N b
  mu_pos : ∀ N : ℕ, 3 ≤ N → T ≤ N → 0 < μ N
  Pz_ge_one : ∀ N : ℕ, 3 ≤ N → T ≤ N → 1 ≤ Pz N
  PzCount_le_Pz : ∀ N : ℕ, 3 ≤ N → T ≤ N → (PzCount N : ℝ) ≤ Pz N
  class_card_nat : ∀ N : ℕ, 3 ≤ N → T ≤ N → (cls N).card ≤ PzCount N
  Xscale_pos : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 0 < Xscale N b
  Xpow_eq_rpow : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
    Xpow N b = (Xscale N b) ^ (2 * Rlevel N b)
  scale_choice : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
    Real.log (Xscale N b) =
      α * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)
  mertens_Pz : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
    Real.log (Pz N) ≤ 2 * zScale (Xscale N b)
  level_budget : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
    2 * Rlevel N b * Real.log (Xscale N b) + 6 * μ N
      ≤ Cp * (α ^ 4 * Real.log (N : ℝ))
  alpha_small : (2 + Cp) * α ^ 4 ≤ 1
  mu_lower_saving : ∀ N : ℕ, 3 ≤ N → T ≤ N →
    cμ * (Real.log N) ^ ((3 : ℝ) / 4) ≤ μ N
  defect_upper : ∀ N : ℕ, 3 ≤ N → T ≤ N →
    εb N + Real.log 3 / μ N ≤ η
  delta_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 0 ≤ δb N b
  Delta_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 0 ≤ Δb N b
  suen_tail : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
    Inputs.suenTailConstant * Δb N b * Real.exp (2 * δb N b) ≤ εb N * μ N
  decomp : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
    Mb N b ≤ ((N : ℝ) / Pz N) *
      (Inputs.suenProb (μ N) (δb N b) (Δb N b) + F2R N b) + errTerm N b
  errTerm_le_Xpow_exp : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
    errTerm N b ≤ Xpow N b * Real.exp (errExp N b)
  errExp_bound : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
    errExp N b ≤ (1 + εK) * μ N
  eps_le_one : εK ≤ 1
  F2R_le_exp : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
    F2R N b ≤ Real.exp (F2RExp N b)
  F2RExp_bound : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
    F2RExp N b ≤ -3 * μ N

theorem fixedNumeratorPaperSuenAnalyticCoreOptimizationInputs_level
    {ι : Type*} {m : ℕ}
    (A : FixedNumeratorPaperSuenAnalyticCoreOptimizationInputs m ι) :
    ∀ N : ℕ, 3 ≤ N → A.T ≤ N → ∀ b ∈ A.cls N,
      A.Pz N * A.Xpow N b * Real.exp (2 * A.μ N)
        ≤ (N : ℝ) * Real.exp (-4 * A.μ N) := by
  intro N hN hTN b hb
  rw [A.Xpow_eq_rpow N hN hTN b hb]
  exact finite_level_condition_of_optimization_nat_of_one_le
    (hN := hN)
    (hPz := A.Pz_ge_one N hN hTN)
    (hX := A.Xscale_pos N hN hTN b hb)
    (hscale := A.scale_choice N hN hTN b hb)
    (mertens := A.mertens_Pz N hN hTN b hb)
    (hbudget := A.level_budget N hN hTN b hb)
    (hα_small := A.alpha_small)

/-- Nonnegativity of the packaged level power is not an independent paper
hypothesis: it follows from the positive scale and the defining real-power
identity. -/
theorem fixedNumeratorPaperSuenAnalyticCoreOptimizationInputs_Xpow_nonneg
    {ι : Type*} {m : ℕ}
    (A : FixedNumeratorPaperSuenAnalyticCoreOptimizationInputs m ι) :
    ∀ N : ℕ, 3 ≤ N → A.T ≤ N → ∀ b ∈ A.cls N, 0 ≤ A.Xpow N b := by
  intro N hN hTN b hb
  rw [A.Xpow_eq_rpow N hN hTN b hb]
  exact (Real.rpow_pos_of_pos (A.Xscale_pos N hN hTN b hb) _).le

/-- The sign of the mass-lower constant is forced by the saving constant
comparison; it is not an independent optimization-side input. -/
theorem fixedNumeratorPaperSuenAnalyticCoreOptimizationInputs_cμ_nonneg
    {ι : Type*} {m : ℕ}
    (A : FixedNumeratorPaperSuenAnalyticCoreOptimizationInputs m ι) :
    0 ≤ A.cμ := by
  have hprod_pos : 0 < (1 - A.η) * A.cμ :=
    lt_of_lt_of_le A.c_pos A.c_le_saving_const
  have hfactor_nonneg : 0 ≤ 1 - A.η := sub_nonneg.mpr A.eta_le_one
  by_contra hnot
  have hcμ_nonpos : A.cμ ≤ 0 := le_of_not_ge hnot
  have hprod_nonpos : (1 - A.η) * A.cμ ≤ 0 :=
    mul_nonpos_of_nonneg_of_nonpos hfactor_nonneg hcμ_nonpos
  linarith

/-- Convert primitive mass-lower and defect-upper data into the final saving
inequality used by the fixed-`m` transfer package. -/
theorem saving_bound_of_mu_lower_and_defect_upper
    {c cμ η μ defect L : ℝ}
    (hL_nonneg : 0 ≤ L)
    (hcμ_nonneg : 0 ≤ cμ)
    (hη_le_one : η ≤ 1)
    (hc_le : c ≤ (1 - η) * cμ)
    (hμ_lower : cμ * L ^ ((3 : ℝ) / 4) ≤ μ)
    (hdefect : defect ≤ η) :
    c * L ^ ((3 : ℝ) / 4) ≤ (1 - defect) * μ := by
  have hpow_nonneg : 0 ≤ L ^ ((3 : ℝ) / 4) :=
    Real.rpow_nonneg hL_nonneg _
  have hone_minus_eta_nonneg : 0 ≤ 1 - η := sub_nonneg.mpr hη_le_one
  have hμ_nonneg : 0 ≤ μ :=
    le_trans (mul_nonneg hcμ_nonneg hpow_nonneg) hμ_lower
  have hone_eta_le_defect : 1 - η ≤ 1 - defect := by
    linarith
  calc
    c * L ^ ((3 : ℝ) / 4)
        ≤ ((1 - η) * cμ) * L ^ ((3 : ℝ) / 4) :=
          mul_le_mul_of_nonneg_right hc_le hpow_nonneg
    _ = (1 - η) * (cμ * L ^ ((3 : ℝ) / 4)) := by ring
    _ ≤ (1 - η) * μ :=
          mul_le_mul_of_nonneg_left hμ_lower hone_minus_eta_nonneg
    _ ≤ (1 - defect) * μ :=
          mul_le_mul_of_nonneg_right hone_eta_le_defect hμ_nonneg

/-- If a positive saving constant is bounded by `(1 - η)cμ` with `η ≤ 1`,
then the mass-lower constant `cμ` is forced to be nonnegative. -/
theorem mu_lower_constant_nonneg_of_positive_le_saving_product
    {c cμ η : ℝ}
    (hc : 0 < c)
    (hη_le_one : η ≤ 1)
    (hc_le : c ≤ (1 - η) * cμ) :
    0 ≤ cμ := by
  have hprod_pos : 0 < (1 - η) * cμ :=
    lt_of_lt_of_le hc hc_le
  have hfactor_nonneg : 0 ≤ 1 - η := sub_nonneg.mpr hη_le_one
  by_contra hnot
  have hcμ_nonpos : cμ ≤ 0 := le_of_not_ge hnot
  have hprod_nonpos : (1 - η) * cμ ≤ 0 :=
    mul_nonpos_of_nonneg_of_nonpos hfactor_nonneg hcμ_nonpos
  linarith

/-- Version of `saving_bound_of_mu_lower_and_defect_upper` where the
nonnegativity of `cμ` is derived from the positive final saving constant. -/
theorem saving_bound_of_positive_constant_mu_lower_and_defect_upper
    {c cμ η μ defect L : ℝ}
    (hc : 0 < c)
    (hL_nonneg : 0 ≤ L)
    (hη_le_one : η ≤ 1)
    (hc_le : c ≤ (1 - η) * cμ)
    (hμ_lower : cμ * L ^ ((3 : ℝ) / 4) ≤ μ)
    (hdefect : defect ≤ η) :
    c * L ^ ((3 : ℝ) / 4) ≤ (1 - defect) * μ :=
  saving_bound_of_mu_lower_and_defect_upper
    (hL_nonneg := hL_nonneg)
    (hcμ_nonneg :=
      mu_lower_constant_nonneg_of_positive_le_saving_product hc hη_le_one hc_le)
    (hη_le_one := hη_le_one)
    (hc_le := hc_le)
    (hμ_lower := hμ_lower)
    (hdefect := hdefect)

/-- Natural-parameter version of `Transfer.relaxed_defect_tendsto_zero`.

The fixed-`m` endpoints are indexed by the natural cutoff `N`; this converts the
usual `ε_b(N) → 0` and `μ(N) → ∞` data into the relaxed defect tending to zero
on that same filter. -/
theorem relaxed_defect_tendsto_zero_nat
    {εb μ : ℕ → ℝ}
    (hε : Filter.Tendsto εb Filter.atTop (nhds (0 : ℝ)))
    (hμ : Filter.Tendsto μ Filter.atTop Filter.atTop) :
    Filter.Tendsto (fun N : ℕ => εb N + Real.log 3 / μ N)
      Filter.atTop (nhds (0 : ℝ)) := by
  have hlog :
      Filter.Tendsto (fun N : ℕ => Real.log 3 / μ N)
        Filter.atTop (nhds (0 : ℝ)) := by
    have hmul :
        Filter.Tendsto (fun N : ℕ => (Real.log 3) * (μ N)⁻¹)
          Filter.atTop (nhds ((Real.log 3) * 0)) :=
      (hμ.inv_tendsto_atTop).const_mul (Real.log 3)
    simpa [div_eq_mul_inv, mul_zero] using hmul
  simpa using hε.add hlog

/-- A positive fixed defect budget is eventually larger than the relaxed
finite-transfer defect.

This discharges the paper-local hypothesis
`ε_b(N) + log 3 / μ(N) ≤ η` after increasing the large-range cutoff, provided
the actual Suen defect tends to zero and the mass tends to infinity. -/
theorem relaxed_defect_eventually_le_nat
    {εb μ : ℕ → ℝ} {η : ℝ}
    (hη : 0 < η)
    (hε : Filter.Tendsto εb Filter.atTop (nhds (0 : ℝ)))
    (hμ : Filter.Tendsto μ Filter.atTop Filter.atTop) :
    ∃ T : ℕ, ∀ N : ℕ, T ≤ N → εb N + Real.log 3 / μ N ≤ η := by
  have hdef := relaxed_defect_tendsto_zero_nat (εb := εb) (μ := μ) hε hμ
  have hball : Metric.ball (0 : ℝ) η ∈ nhds (0 : ℝ) :=
    Metric.ball_mem_nhds (0 : ℝ) hη
  have hev :
      ∀ᶠ N : ℕ in Filter.atTop,
        εb N + Real.log 3 / μ N ∈ Metric.ball (0 : ℝ) η :=
    hdef.eventually hball
  rcases Filter.eventually_atTop.mp hev with ⟨T, hT⟩
  refine ⟨T, ?_⟩
  intro N hTN
  have hmem := hT N hTN
  rw [Metric.mem_ball, dist_eq_norm, Real.norm_eq_abs] at hmem
  simpa using (abs_lt.mp hmem).2.le

/-- On the manuscript's natural range `N ≥ 3`, the cubic logarithmic mass scale
dominates the final saving scale `(log N)^(3/4)`. -/
theorem log_rpow_three_quarters_le_logCube_nat
    (N : ℕ) (hN : 3 ≤ N) :
    (Real.log (N : ℝ)) ^ ((3 : ℝ) / 4) ≤ logCube (N : ℝ) := by
  have hNpos : (0 : ℝ) < (N : ℝ) := by
    exact_mod_cast (by omega : 0 < N)
  have hexp_three : Real.exp 1 ≤ (3 : ℝ) := by
    exact le_of_lt (lt_of_lt_of_le Real.exp_one_lt_d9 (by norm_num))
  have hthreeN : (3 : ℝ) ≤ (N : ℝ) := by exact_mod_cast hN
  have hlog_ge_one : (1 : ℝ) ≤ Real.log (N : ℝ) :=
    (Real.le_log_iff_exp_le hNpos).mpr (le_trans hexp_three hthreeN)
  have hpow :
      (Real.log (N : ℝ)) ^ ((3 : ℝ) / 4)
        ≤ (Real.log (N : ℝ)) ^ (3 : ℝ) :=
    Real.rpow_le_rpow_of_exponent_le hlog_ge_one (by norm_num)
  calc
    (Real.log (N : ℝ)) ^ ((3 : ℝ) / 4)
        ≤ (Real.log (N : ℝ)) ^ (3 : ℝ) := hpow
    _ = (Real.log (N : ℝ)) ^ (3 : ℕ) := Real.rpow_natCast (Real.log (N : ℝ)) 3
    _ = logCube (N : ℝ) := by rfl

/-- A cubic mass-law lower bound implies the weaker saving-scale lower bound
used in the fixed-`m` finite-transfer package. -/
theorem mu_lower_saving_of_logCube_lower_nat
    {μ : ℕ → ℝ} {cμ : ℝ} {T : ℕ}
    (cμ_pos : 0 < cμ)
    (hmass_logcube_lower : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      cμ * logCube (N : ℝ) ≤ μ N) :
    ∀ N : ℕ, 3 ≤ N → T ≤ N →
      cμ * (Real.log (N : ℝ)) ^ ((3 : ℝ) / 4) ≤ μ N := by
  intro N hN hTN
  exact le_trans
    (mul_le_mul_of_nonneg_left
        (log_rpow_three_quarters_le_logCube_nat N hN) cμ_pos.le)
      (hmass_logcube_lower N hN hTN)

/-- On the manuscript's natural range `N ≥ 3`, the cubic logarithmic mass scale
dominates the quartic saving scale `(log N)^(4/5)`. -/
theorem log_rpow_four_fifths_le_logCube_nat
    (N : ℕ) (hN : 3 ≤ N) :
    (Real.log (N : ℝ)) ^ ((4 : ℝ) / 5) ≤ logCube (N : ℝ) := by
  have hNpos : (0 : ℝ) < (N : ℝ) := by
    exact_mod_cast (by omega : 0 < N)
  have hexp_three : Real.exp 1 ≤ (3 : ℝ) := by
    exact le_of_lt (lt_of_lt_of_le Real.exp_one_lt_d9 (by norm_num))
  have hthreeN : (3 : ℝ) ≤ (N : ℝ) := by exact_mod_cast hN
  have hlog_ge_one : (1 : ℝ) ≤ Real.log (N : ℝ) :=
    (Real.le_log_iff_exp_le hNpos).mpr (le_trans hexp_three hthreeN)
  have hpow :
      (Real.log (N : ℝ)) ^ ((4 : ℝ) / 5)
        ≤ (Real.log (N : ℝ)) ^ (3 : ℝ) :=
    Real.rpow_le_rpow_of_exponent_le hlog_ge_one (by norm_num)
  calc
    (Real.log (N : ℝ)) ^ ((4 : ℝ) / 5)
        ≤ (Real.log (N : ℝ)) ^ (3 : ℝ) := hpow
    _ = (Real.log (N : ℝ)) ^ (3 : ℕ) := Real.rpow_natCast (Real.log (N : ℝ)) 3
    _ = logCube (N : ℝ) := by rfl

/-- A cubic mass-law lower bound implies the quartic saving-scale lower bound
used in the quartic finite-transfer package. -/
theorem mu_lower_quartic_of_logCube_lower_nat
    {μ : ℕ → ℝ} {cμ : ℝ} {T : ℕ}
    (cμ_pos : 0 < cμ)
    (hmass_logcube_lower : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      cμ * logCube (N : ℝ) ≤ μ N) :
    ∀ N : ℕ, 3 ≤ N → T ≤ N →
      cμ * (Real.log (N : ℝ)) ^ ((4 : ℝ) / 5) ≤ μ N := by
  intro N hN hTN
  exact le_trans
    (mul_le_mul_of_nonneg_left
      (log_rpow_four_fifths_le_logCube_nat N hN) cμ_pos.le)
    (hmass_logcube_lower N hN hTN)

/-- The same cubic mass-law lower bound also makes the mass nonnegative on the
paper range `N ≥ 3`; this removes a separate sign hypothesis from scalar-tail
uses. -/
theorem mu_nonneg_of_logCube_lower_nat
    {μ : ℕ → ℝ} {cμ : ℝ} {T : ℕ}
    (cμ_pos : 0 < cμ)
    (hmass_logcube_lower : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      cμ * logCube (N : ℝ) ≤ μ N) :
    ∀ N : ℕ, 3 ≤ N → T ≤ N → 0 ≤ μ N := by
  intro N hN hTN
  have hNpos : (0 : ℝ) < (N : ℝ) := by
    exact_mod_cast (by omega : 0 < N)
  have hexp_three : Real.exp 1 ≤ (3 : ℝ) := by
    exact le_of_lt (lt_of_lt_of_le Real.exp_one_lt_d9 (by norm_num))
  have hthreeN : (3 : ℝ) ≤ (N : ℝ) := by exact_mod_cast hN
  have hcube_nonneg : 0 ≤ logCube (N : ℝ) :=
    logCube_nonneg_of_exp_one_le (le_trans hexp_three hthreeN)
  have hleft_nonneg : 0 ≤ cμ * logCube (N : ℝ) :=
    mul_nonneg cμ_pos.le hcube_nonneg
  exact le_trans hleft_nonneg (hmass_logcube_lower N hN hTN)

/-- The cubic mass-law lower bound is strictly positive on the paper range
`N ≥ 3`. -/
theorem mu_pos_of_logCube_lower_nat
    {μ : ℕ → ℝ} {cμ : ℝ} {T : ℕ}
    (cμ_pos : 0 < cμ)
    (hmass_logcube_lower : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      cμ * logCube (N : ℝ) ≤ μ N) :
    ∀ N : ℕ, 3 ≤ N → T ≤ N → 0 < μ N := by
  intro N hN hTN
  have hN_gt_one_nat : 1 < N := by omega
  have hN_gt_one : (1 : ℝ) < (N : ℝ) := by exact_mod_cast hN_gt_one_nat
  have hlog_pos : 0 < Real.log (N : ℝ) := Real.log_pos hN_gt_one
  have hcube_pos : 0 < logCube (N : ℝ) := by
    unfold logCube
    exact pow_pos hlog_pos 3
  exact lt_of_lt_of_le (mul_pos cμ_pos hcube_pos)
    (hmass_logcube_lower N hN hTN)

/-- The cubic logarithmic scale tends to infinity along natural numbers. -/
theorem logCube_nat_tendsto_atTop :
    Filter.Tendsto (fun N : ℕ => logCube (N : ℝ))
      Filter.atTop Filter.atTop := by
  have hlog :
      Filter.Tendsto (fun N : ℕ => Real.log (N : ℝ))
        Filter.atTop Filter.atTop :=
    Real.tendsto_log_atTop.comp tendsto_natCast_atTop_atTop
  refine ((tendsto_rpow_atTop (by norm_num : (0 : ℝ) < (3 : ℝ))).comp hlog).congr ?_
  intro N
  unfold logCube
  change Real.log (N : ℝ) ^ (3 : ℝ) = Real.log (N : ℝ) ^ (3 : ℕ)
  exact Real.rpow_natCast (Real.log (N : ℝ)) 3

/-- The concrete defect rate `1 / log N` tends to zero. -/
theorem one_div_log_nat_tendsto_zero :
    Filter.Tendsto (fun N : ℕ => (Real.log (N : ℝ))⁻¹)
      Filter.atTop (nhds (0 : ℝ)) := by
  have hlog :
      Filter.Tendsto (fun N : ℕ => Real.log (N : ℝ))
        Filter.atTop Filter.atTop :=
    Real.tendsto_log_atTop.comp tendsto_natCast_atTop_atTop
  simpa using hlog.inv_tendsto_atTop

/-- A positive cubic mass-law lower bound forces the mass itself to tend to
infinity; this removes the separate `μ → ∞` hypothesis from cutoff arguments. -/
theorem mu_tendsto_atTop_of_logCube_lower_nat
    {μ : ℕ → ℝ} {cμ : ℝ} {T : ℕ}
    (cμ_pos : 0 < cμ)
    (hmass_logcube_lower : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      cμ * logCube (N : ℝ) ≤ μ N) :
    Filter.Tendsto μ Filter.atTop Filter.atTop := by
  have hleft_top :
      Filter.Tendsto (fun N : ℕ => cμ * logCube (N : ℝ))
        Filter.atTop Filter.atTop :=
    Filter.Tendsto.const_mul_atTop cμ_pos logCube_nat_tendsto_atTop
  refine Filter.tendsto_atTop_mono' (l := Filter.atTop)
    (f₁ := fun N : ℕ => cμ * logCube (N : ℝ)) (f₂ := μ) ?_ hleft_top
  filter_upwards [Filter.eventually_ge_atTop 3, Filter.eventually_ge_atTop T] with N hN hTN
  exact hmass_logcube_lower N hN hTN

/-- If a defect term tends to zero and the mass tends to infinity, then after
enlarging the cutoff the defect is at most `1/2`. -/
theorem epsilon_le_half_of_tendsto_zero_and_mu_top_nat
    {ε μ : ℕ → ℝ} {T : ℕ}
    (hε_zero : Filter.Tendsto ε Filter.atTop (nhds (0 : ℝ)))
    (hμ_top : Filter.Tendsto μ Filter.atTop Filter.atTop)
    (hμ_pos : ∀ N : ℕ, 3 ≤ N → T ≤ N → 0 < μ N) :
    ∃ T' : ℕ, T ≤ T' ∧
      ∀ N : ℕ, 3 ≤ N → T' ≤ N → ε N ≤ (1 : ℝ) / 2 := by
  rcases relaxed_defect_eventually_le_nat
    (εb := ε) (μ := μ) (η := (1 : ℝ) / 2) (by norm_num)
    hε_zero hμ_top with ⟨Tdef, hdefect⟩
  refine ⟨max T Tdef, Nat.le_max_left T Tdef, ?_⟩
  intro N hN hTN
  have hT : T ≤ N := le_trans (Nat.le_max_left T Tdef) hTN
  have hTdef : Tdef ≤ N := le_trans (Nat.le_max_right T Tdef) hTN
  have hrel := hdefect N hTdef
  have hlog_pos : 0 < Real.log (3 : ℝ) := Real.log_pos (by norm_num)
  have hterm_nonneg : 0 ≤ Real.log 3 / μ N :=
    div_nonneg hlog_pos.le (le_of_lt (hμ_pos N hN hT))
  linarith

/-- A positive log-cube mass lower bound supplies the mass side needed to make
a vanishing defect eventually at most `1/2`. -/
theorem epsilon_le_half_of_logCube_lower_nat
    {ε μ : ℕ → ℝ} {cμ : ℝ} {T : ℕ}
    (cμ_pos : 0 < cμ)
    (hmass_logcube_lower : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      cμ * logCube (N : ℝ) ≤ μ N)
    (hε_zero : Filter.Tendsto ε Filter.atTop (nhds (0 : ℝ))) :
    ∃ T' : ℕ, T ≤ T' ∧
      ∀ N : ℕ, 3 ≤ N → T' ≤ N → ε N ≤ (1 : ℝ) / 2 :=
  epsilon_le_half_of_tendsto_zero_and_mu_top_nat hε_zero
    (mu_tendsto_atTop_of_logCube_lower_nat cμ_pos hmass_logcube_lower)
    (mu_pos_of_logCube_lower_nat cμ_pos hmass_logcube_lower)

/-- The manuscript saving scale `(log N)^(3/4)` tends to infinity along
natural numbers. -/
theorem log_rpow_three_quarters_nat_tendsto_atTop :
    Filter.Tendsto (fun N : ℕ => (Real.log (N : ℝ)) ^ ((3 : ℝ) / 4))
      Filter.atTop Filter.atTop := by
  have hlog :
      Filter.Tendsto (fun N : ℕ => Real.log (N : ℝ))
        Filter.atTop Filter.atTop :=
    Real.tendsto_log_atTop.comp tendsto_natCast_atTop_atTop
  exact (tendsto_rpow_atTop (by norm_num : (0 : ℝ) < ((3 : ℝ) / 4))).comp hlog

/-- A positive lower bound at the manuscript saving scale forces the mass
parameter itself to tend to infinity. -/
theorem mu_tendsto_atTop_of_log_rpow_three_quarters_lower_nat
    {μ : ℕ → ℝ} {cμ : ℝ} {T : ℕ}
    (cμ_pos : 0 < cμ)
    (hmass_saving_lower : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      cμ * (Real.log (N : ℝ)) ^ ((3 : ℝ) / 4) ≤ μ N) :
    Filter.Tendsto μ Filter.atTop Filter.atTop := by
  have hleft_top :
      Filter.Tendsto
        (fun N : ℕ => cμ * (Real.log (N : ℝ)) ^ ((3 : ℝ) / 4))
        Filter.atTop Filter.atTop :=
    Filter.Tendsto.const_mul_atTop cμ_pos
      log_rpow_three_quarters_nat_tendsto_atTop
  refine Filter.tendsto_atTop_mono' (l := Filter.atTop)
    (f₁ := fun N : ℕ => cμ * (Real.log (N : ℝ)) ^ ((3 : ℝ) / 4))
    (f₂ := μ) ?_ hleft_top
  filter_upwards [Filter.eventually_ge_atTop 3, Filter.eventually_ge_atTop T] with N hN hTN
  exact hmass_saving_lower N hN hTN

/-- Scalar algebra behind the paper's level-budget line.

The manuscript uses
`2R log X + 6μ ≤ C μ log X ≤ Cp α^4 log N`.  This lemma isolates the
non-asymptotic algebra: once `log X = a (log N)^(1/4)` is at least `1`, `2R` is
bounded by `KR μ`, the mass has the upper bound `μ ≤ cM (log X)^3`, and the
constants satisfy `(KR+6)cM ≤ Cp`, the displayed level budget follows. -/
theorem level_budget_of_rank_mu_upper_logX_cube_scalar
    {R : ℕ} {μ Cp KR cM a L : ℝ}
    (hL_nonneg : 0 ≤ L)
    (hlogX_ge_one : 1 ≤ a * L ^ ((1 : ℝ) / 4))
    (hμ_nonneg : 0 ≤ μ)
    (hKR_nonneg : 0 ≤ KR)
    (hrank_upper : 2 * (R : ℝ) ≤ KR * μ)
    (hμ_upper : μ ≤ cM * (a * L ^ ((1 : ℝ) / 4)) ^ 3)
    (hconstants : (KR + 6) * cM ≤ Cp) :
    2 * (R : ℝ) * (a * L ^ ((1 : ℝ) / 4)) + 6 * μ
      ≤ Cp * (a ^ 4 * L) := by
  set Xlog : ℝ := a * L ^ ((1 : ℝ) / 4)
  have hXlog_nonneg : 0 ≤ Xlog := by
    exact le_trans zero_le_one hlogX_ge_one
  have hrank_term : 2 * (R : ℝ) * Xlog ≤ (KR * μ) * Xlog := by
    exact mul_le_mul_of_nonneg_right hrank_upper hXlog_nonneg
  have hsixμ_nonneg : 0 ≤ 6 * μ := by
    exact mul_nonneg (by norm_num) hμ_nonneg
  have hsix_term : 6 * μ ≤ (6 * μ) * Xlog := by
    calc
      6 * μ = (6 * μ) * 1 := by ring
      _ ≤ (6 * μ) * Xlog :=
        mul_le_mul_of_nonneg_left hlogX_ge_one hsixμ_nonneg
  have hleft_to_mu :
      2 * (R : ℝ) * Xlog + 6 * μ ≤ ((KR + 6) * μ) * Xlog := by
    nlinarith
  have hKR6_nonneg : 0 ≤ KR + 6 := by nlinarith
  have hKR6X_nonneg : 0 ≤ (KR + 6) * Xlog :=
    mul_nonneg hKR6_nonneg hXlog_nonneg
  have hmu_to_cube :
      ((KR + 6) * μ) * Xlog ≤ ((KR + 6) * cM) * Xlog ^ 4 := by
    calc
      ((KR + 6) * μ) * Xlog = ((KR + 6) * Xlog) * μ := by ring
      _ ≤ ((KR + 6) * Xlog) * (cM * Xlog ^ 3) :=
        mul_le_mul_of_nonneg_left (by simpa [Xlog] using hμ_upper) hKR6X_nonneg
      _ = ((KR + 6) * cM) * Xlog ^ 4 := by ring
  have hconstants_step :
      ((KR + 6) * cM) * Xlog ^ 4 ≤ Cp * Xlog ^ 4 := by
    exact mul_le_mul_of_nonneg_right hconstants (pow_nonneg hXlog_nonneg 4)
  have hXlog_four : Xlog ^ 4 = a ^ 4 * L := by
    change (a * L ^ ((1 : ℝ) / 4)) ^ 4 = a ^ 4 * L
    rw [mul_pow]
    congr 1
    rw [← Real.rpow_natCast (L ^ ((1 : ℝ) / 4)) 4, ← Real.rpow_mul hL_nonneg]
    norm_num
  calc
    2 * (R : ℝ) * (a * L ^ ((1 : ℝ) / 4)) + 6 * μ
        = 2 * (R : ℝ) * Xlog + 6 * μ := by rfl
    _ ≤ ((KR + 6) * μ) * Xlog := hleft_to_mu
    _ ≤ ((KR + 6) * cM) * Xlog ^ 4 := hmu_to_cube
    _ ≤ Cp * Xlog ^ 4 := hconstants_step
    _ = Cp * (a ^ 4 * L) := by rw [hXlog_four]

/-- Variant of `level_budget_of_rank_mu_upper_logX_cube_scalar` where
`0 ≤ KR` is derived from the simultaneous lower and upper rank bounds.

Pointwise, `24μ ≤ 2R ≤ KR μ` and `0 < μ` force `24 ≤ KR`, so the nonnegativity
of `KR` is not an independent caller hypothesis on any class where the rank
constraints are actually used. -/
theorem level_budget_of_rank_mu_upper_logX_cube_scalar_auto_KR_nonneg
    {R : ℕ} {μ Cp KR cM a L : ℝ}
    (hL_nonneg : 0 ≤ L)
    (hlogX_ge_one : 1 ≤ a * L ^ ((1 : ℝ) / 4))
    (hμ_pos : 0 < μ)
    (hrank_tail : 24 * μ ≤ 2 * (R : ℝ))
    (hrank_upper : 2 * (R : ℝ) ≤ KR * μ)
    (hμ_upper : μ ≤ cM * (a * L ^ ((1 : ℝ) / 4)) ^ 3)
    (hconstants : (KR + 6) * cM ≤ Cp) :
    2 * (R : ℝ) * (a * L ^ ((1 : ℝ) / 4)) + 6 * μ
      ≤ Cp * (a ^ 4 * L) := by
  have hKR_nonneg : 0 ≤ KR := by
    have htwentyfour_to_KR : 24 * μ ≤ KR * μ :=
      le_trans hrank_tail hrank_upper
    nlinarith
  exact
    level_budget_of_rank_mu_upper_logX_cube_scalar
      (R := R) (μ := μ) (Cp := Cp) (KR := KR) (cM := cM)
      (a := a) (L := L)
      hL_nonneg hlogX_ge_one hμ_pos.le hKR_nonneg hrank_upper hμ_upper
      hconstants

/-- The canonical Brun truncation rank `floor(12 μ)+1` always satisfies the
lower rank-tail inequality used by the scalar top-tail bound. -/
theorem brun_floor_rank_tail (μ : ℝ) :
    24 * μ ≤ 2 * ((⌊12 * μ⌋₊ + 1 : ℕ) : ℝ) := by
  have hfloor : 12 * μ ≤ ((⌊12 * μ⌋₊ : ℕ) : ℝ) + 1 :=
    (Nat.lt_floor_add_one (12 * μ)).le
  norm_num at hfloor ⊢
  linarith

/-- Once `μ ≥ 1`, the same canonical rank is bounded above by `26 μ`. -/
theorem brun_floor_rank_upper_of_one_le {μ : ℝ} (hμ : 1 ≤ μ) :
    2 * ((⌊12 * μ⌋₊ + 1 : ℕ) : ℝ) ≤ 26 * μ := by
  have hμ_nonneg : 0 ≤ μ := le_trans zero_le_one hμ
  have hfloor : ((⌊12 * μ⌋₊ : ℕ) : ℝ) ≤ 12 * μ :=
    Nat.floor_le (by nlinarith)
  norm_num at hfloor ⊢
  linarith

theorem fixedNumeratorPaperSuenAnalyticCoreOptimizationInputs_saving_bound
    {ι : Type*} {m : ℕ}

theorem LinearSieveRoughDyadicMultiplesSignedErrorQuarterBoundOnPositiveRanges_of_countDiscrepancyNormalizedOnPositiveRanges
    (h : RoughDyadicCountDiscrepancyUniformNormalizedSmallBoundOnPositiveRanges) :

  · exact linear_sieve_rough_dyadic_with_log_carrier_bounds_of_count_bound
  · exact linear_sieve_rough_dyadic_count_bound_of_log_carrier_bounds

/-- Normalized dyadic rough density: count divided by the left endpoint `t`.
The linear-sieve input is exactly that this density is `≍ 1/log z(X)` on the
dyadic range. -/
noncomputable def roughDyadicDensity (X : ℝ) (M : ℕ) (t : ℝ) : ℝ :=
  roughDyadicCount X M t / t

/-- A count-level rough-sieve estimate gives the normalized dyadic-density
form.  Raising the threshold supplies positivity of `X`, `t`, and `log z(X)`;
the remaining proof is only division by the positive endpoint. -/
theorem roughDyadicDensity_bound_of_count_bound
    {a₀ b₀ C₀ : ℝ} (_ha₀ : 0 < a₀)
    (h :
      ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
        ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
          c * (t / Real.log (EscAnalytic.zScale X)) ≤ roughDyadicCount X M t
            ∧ roughDyadicCount X M t
                ≤ C * (t / Real.log (EscAnalytic.zScale X))) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
        0 < Real.log (EscAnalytic.zScale X) ∧
          c / Real.log (EscAnalytic.zScale X) ≤ roughDyadicDensity X M t ∧
          roughDyadicDensity X M t ≤ C / Real.log (EscAnalytic.zScale X) := by
  rcases linear_sieve_rough_dyadic_with_log_carrier_bounds_of_count_bound h with
    ⟨c, C, X₀, hc, hC, hcount⟩
  refine ⟨c, C, X₀, hc, hC, ?_⟩
  intro X hX M hM t htlo hthi htpos
  rcases hcount X hX M hM t htlo hthi with
    ⟨hlogZ_pos, _hcount_nonneg, hlower, hupper, _habs⟩
  constructor
  · exact hlogZ_pos
  constructor
  · unfold roughDyadicDensity
    have hdiv :
        (c * (t / Real.log (EscAnalytic.zScale X))) / t
          ≤ roughDyadicCount X M t / t :=
      div_le_div_of_nonneg_right hlower htpos.le
    calc
      c / Real.log (EscAnalytic.zScale X)
          = (c * (t / Real.log (EscAnalytic.zScale X))) / t := by
            field_simp [ne_of_gt htpos, ne_of_gt hlogZ_pos]
            ring
      _ ≤ roughDyadicCount X M t / t := hdiv
  · unfold roughDyadicDensity
    have hdiv :
        roughDyadicCount X M t / t
          ≤ (C * (t / Real.log (EscAnalytic.zScale X))) / t :=
      div_le_div_of_nonneg_right hupper htpos.le
    calc
      roughDyadicCount X M t / t
          ≤ (C * (t / Real.log (EscAnalytic.zScale X))) / t := hdiv
      _ = C / Real.log (EscAnalytic.zScale X) := by
            field_simp [ne_of_gt htpos, ne_of_gt hlogZ_pos]
            ring

/-- Conversely, a normalized dyadic-density estimate recovers the count-level
rough-sieve estimate by multiplying by the positive endpoint. -/
theorem linear_sieve_rough_dyadic_count_bound_of_density_bound
    {a₀ b₀ C₀ : ℝ}
    (h :
      ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
        ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
          0 < Real.log (EscAnalytic.zScale X) ∧
            c / Real.log (EscAnalytic.zScale X) ≤ roughDyadicDensity X M t ∧
            roughDyadicDensity X M t ≤ C / Real.log (EscAnalytic.zScale X)) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        c * (t / Real.log (EscAnalytic.zScale X)) ≤ roughDyadicCount X M t
          ∧ roughDyadicCount X M t
              ≤ C * (t / Real.log (EscAnalytic.zScale X)) := by
  rcases h with ⟨c, C, Xbase, hc, hC, hdensity⟩
  refine ⟨c, C, max Xbase (Real.exp 1), hc, hC, ?_⟩
  intro X hX M hM t htlo hthi
  have hXbase : Xbase ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 1 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 1) hXexp
  have htpos : 0 < t := lt_of_lt_of_le (Real.rpow_pos_of_pos hXpos a₀) htlo
  rcases hdensity X hXbase M hM t htlo hthi htpos with
    ⟨hlogZ_pos, hlower, hupper⟩
  constructor
  · unfold roughDyadicDensity at hlower
    have hmul :
        (c / Real.log (EscAnalytic.zScale X)) * t
          ≤ (roughDyadicCount X M t / t) * t :=
      mul_le_mul_of_nonneg_right hlower htpos.le
    calc
      c * (t / Real.log (EscAnalytic.zScale X))
          = (c / Real.log (EscAnalytic.zScale X)) * t := by ring
      _ ≤ (roughDyadicCount X M t / t) * t := hmul
      _ = roughDyadicCount X M t := by
            field_simp [ne_of_gt htpos]
  · unfold roughDyadicDensity at hupper
    have hmul :
        (roughDyadicCount X M t / t) * t
          ≤ (C / Real.log (EscAnalytic.zScale X)) * t :=
      mul_le_mul_of_nonneg_right hupper htpos.le
    calc
      roughDyadicCount X M t
          = (roughDyadicCount X M t / t) * t := by
            field_simp [ne_of_gt htpos]
      _ ≤ (C / Real.log (EscAnalytic.zScale X)) * t := hmul
      _ = C * (t / Real.log (EscAnalytic.zScale X)) := by ring

/-- The dyadic rough-sieve count input is equivalent to the normalized density
statement `roughDyadicCount/t ≍ 1/log z`.  This is often the cleanest primitive
analytic form: all conversion between density and counts is checked here. -/
theorem linear_sieve_rough_dyadic_count_bound_iff_density_bound
    (a₀ b₀ C₀ : ℝ) (ha₀ : 0 < a₀) :
    (∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        c * (t / Real.log (EscAnalytic.zScale X)) ≤ roughDyadicCount X M t
          ∧ roughDyadicCount X M t
              ≤ C * (t / Real.log (EscAnalytic.zScale X))) ↔
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
        0 < Real.log (EscAnalytic.zScale X) ∧
          c / Real.log (EscAnalytic.zScale X) ≤ roughDyadicDensity X M t ∧
          roughDyadicDensity X M t ≤ C / Real.log (EscAnalytic.zScale X) := by
  constructor
  · exact roughDyadicDensity_bound_of_count_bound ha₀
  · exact linear_sieve_rough_dyadic_count_bound_of_density_bound

/-- Lower half of the normalized dyadic rough-density primitive. -/
def roughDyadicDensityLowerBound (a₀ b₀ C₀ : ℝ) : Prop :=
  ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
      0 < Real.log (EscAnalytic.zScale X) ∧
        c / Real.log (EscAnalytic.zScale X) ≤ roughDyadicDensity X M t

/-- Upper half of the normalized dyadic rough-density primitive. -/
def roughDyadicDensityUpperBound (a₀ b₀ C₀ : ℝ) : Prop :=
  ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
      0 < Real.log (EscAnalytic.zScale X) ∧
        roughDyadicDensity X M t ≤ C / Real.log (EscAnalytic.zScale X)

/-- A two-sided normalized dyadic-density estimate is exactly its lower and
upper halves. -/
theorem roughDyadicDensity_bound_iff_lower_upper
    (a₀ b₀ C₀ : ℝ) :
    (∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
        0 < Real.log (EscAnalytic.zScale X) ∧
          c / Real.log (EscAnalytic.zScale X) ≤ roughDyadicDensity X M t ∧
          roughDyadicDensity X M t ≤ C / Real.log (EscAnalytic.zScale X)) ↔
      roughDyadicDensityLowerBound a₀ b₀ C₀ ∧
        roughDyadicDensityUpperBound a₀ b₀ C₀ := by
  constructor
  · rintro ⟨c, C, X₀, hc, hC, h⟩
    refine ⟨⟨c, X₀, hc, ?_⟩, ⟨C, X₀, hC, ?_⟩⟩
    · intro X hX M hM t htlo hthi htpos
      exact ⟨(h X hX M hM t htlo hthi htpos).1,
        (h X hX M hM t htlo hthi htpos).2.1⟩
    · intro X hX M hM t htlo hthi htpos
      exact ⟨(h X hX M hM t htlo hthi htpos).1,
        (h X hX M hM t htlo hthi htpos).2.2⟩
  · rintro ⟨⟨c, Xlo, hc, hlo⟩, ⟨C, Xhi, hC, hhi⟩⟩
    refine ⟨c, C, max Xlo Xhi, hc, hC, ?_⟩
    intro X hX M hM t htlo hthi htpos
    have hXlo : Xlo ≤ X := le_trans (le_max_left _ _) hX
    have hXhi : Xhi ≤ X := le_trans (le_max_right _ _) hX
    rcases hlo X hXlo M hM t htlo hthi htpos with ⟨hlog_lo, hlower⟩
    rcases hhi X hXhi M hM t htlo hthi htpos with ⟨_hlog_hi, hupper⟩
    exact ⟨hlog_lo, hlower, hupper⟩

/-- The count-level rough-sieve primitive is equivalent to the pair consisting
of lower and upper normalized dyadic-density estimates.  This isolates the
remaining rough input into two one-sided analytic targets. -/
theorem linear_sieve_rough_dyadic_count_bound_iff_density_lower_upper
    (a₀ b₀ C₀ : ℝ) (ha₀ : 0 < a₀) :
    (∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        c * (t / Real.log (EscAnalytic.zScale X)) ≤ roughDyadicCount X M t
          ∧ roughDyadicCount X M t
              ≤ C * (t / Real.log (EscAnalytic.zScale X))) ↔
      roughDyadicDensityLowerBound a₀ b₀ C₀ ∧
        roughDyadicDensityUpperBound a₀ b₀ C₀ := by
  rw [linear_sieve_rough_dyadic_count_bound_iff_density_bound a₀ b₀ C₀ ha₀,
    roughDyadicDensity_bound_iff_lower_upper a₀ b₀ C₀]

/-- A one-sided count lower bound gives the corresponding normalized-density
lower bound. -/
theorem roughDyadicDensityLowerBound_of_countLowerBound
    {a₀ b₀ C₀ : ℝ} (_ha₀ : 0 < a₀)
    (h : roughDyadicCountLowerBound a₀ b₀ C₀) :
    roughDyadicDensityLowerBound a₀ b₀ C₀ := by
  rcases h with ⟨c, Xbase, hc, hcount⟩
  refine ⟨c, max Xbase (Real.exp 2), hc, ?_⟩
  intro X hX M hM t htlo hthi htpos
  have hXbase : Xbase ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hlogZ_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp
  have hlower := hcount X hXbase M hM t htlo hthi
  refine ⟨hlogZ_pos, ?_⟩
  unfold roughDyadicDensity
  have hdiv :
      (c * (t / Real.log (EscAnalytic.zScale X))) / t
        ≤ roughDyadicCount X M t / t :=
    div_le_div_of_nonneg_right hlower htpos.le
  calc
    c / Real.log (EscAnalytic.zScale X)
        = (c * (t / Real.log (EscAnalytic.zScale X))) / t := by
          field_simp [ne_of_gt htpos, ne_of_gt hlogZ_pos]
          ring
    _ ≤ roughDyadicCount X M t / t := hdiv

/-- A one-sided count upper bound gives the corresponding normalized-density
upper bound. -/
theorem roughDyadicDensityUpperBound_of_countUpperBound
    {a₀ b₀ C₀ : ℝ} (_ha₀ : 0 < a₀)
    (h : roughDyadicCountUpperBound a₀ b₀ C₀) :
    roughDyadicDensityUpperBound a₀ b₀ C₀ := by
  rcases h with ⟨C, Xbase, hC, hcount⟩
  refine ⟨C, max Xbase (Real.exp 2), hC, ?_⟩
  intro X hX M hM t htlo hthi htpos
  have hXbase : Xbase ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hlogZ_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp
  have hupper := hcount X hXbase M hM t htlo hthi
  refine ⟨hlogZ_pos, ?_⟩
  unfold roughDyadicDensity
  have hdiv :
      roughDyadicCount X M t / t
        ≤ (C * (t / Real.log (EscAnalytic.zScale X))) / t :=
    div_le_div_of_nonneg_right hupper htpos.le
  calc
    roughDyadicCount X M t / t
        ≤ (C * (t / Real.log (EscAnalytic.zScale X))) / t := hdiv
    _ = C / Real.log (EscAnalytic.zScale X) := by
          field_simp [ne_of_gt htpos, ne_of_gt hlogZ_pos]
          ring

/-- A one-sided normalized-density lower bound recovers the one-sided count
lower bound. -/
theorem roughDyadicCountLowerBound_of_densityLowerBound
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicDensityLowerBound a₀ b₀ C₀) :
    roughDyadicCountLowerBound a₀ b₀ C₀ := by
  rcases h with ⟨c, Xbase, hc, hdensity⟩
  refine ⟨c, max Xbase (Real.exp 1), hc, ?_⟩
  intro X hX M hM t htlo hthi
  have hXbase : Xbase ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 1 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 1) hXexp
  have htpos : 0 < t := lt_of_lt_of_le (Real.rpow_pos_of_pos hXpos a₀) htlo
  rcases hdensity X hXbase M hM t htlo hthi htpos with
    ⟨hlogZ_pos, hlower⟩
  unfold roughDyadicDensity at hlower
  have hmul :
      (c / Real.log (EscAnalytic.zScale X)) * t
        ≤ (roughDyadicCount X M t / t) * t :=
    mul_le_mul_of_nonneg_right hlower htpos.le
  calc
    c * (t / Real.log (EscAnalytic.zScale X))
        = (c / Real.log (EscAnalytic.zScale X)) * t := by ring
    _ ≤ (roughDyadicCount X M t / t) * t := hmul
    _ = roughDyadicCount X M t := by
          field_simp [ne_of_gt htpos]

/-- A one-sided normalized-density upper bound recovers the one-sided count
upper bound. -/
theorem roughDyadicCountUpperBound_of_densityUpperBound
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicDensityUpperBound a₀ b₀ C₀) :
    roughDyadicCountUpperBound a₀ b₀ C₀ := by
  rcases h with ⟨C, Xbase, hC, hdensity⟩
  refine ⟨C, max Xbase (Real.exp 1), hC, ?_⟩
  intro X hX M hM t htlo hthi
  have hXbase : Xbase ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 1 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 1) hXexp
  have htpos : 0 < t := lt_of_lt_of_le (Real.rpow_pos_of_pos hXpos a₀) htlo
  rcases hdensity X hXbase M hM t htlo hthi htpos with
    ⟨hlogZ_pos, hupper⟩
  unfold roughDyadicDensity at hupper
  have hmul :
      (roughDyadicCount X M t / t) * t
        ≤ (C / Real.log (EscAnalytic.zScale X)) * t :=
    mul_le_mul_of_nonneg_right hupper htpos.le
  calc
    roughDyadicCount X M t
        = (roughDyadicCount X M t / t) * t := by
          field_simp [ne_of_gt htpos]
    _ ≤ (C / Real.log (EscAnalytic.zScale X)) * t := hmul
    _ = C * (t / Real.log (EscAnalytic.zScale X)) := by ring

/-- One-sided count and normalized-density lower bounds are equivalent. -/
theorem roughDyadicCountLowerBound_iff_densityLowerBound
    (a₀ b₀ C₀ : ℝ) (ha₀ : 0 < a₀) :
    roughDyadicCountLowerBound a₀ b₀ C₀ ↔
      roughDyadicDensityLowerBound a₀ b₀ C₀ :=
  ⟨roughDyadicDensityLowerBound_of_countLowerBound ha₀,
    roughDyadicCountLowerBound_of_densityLowerBound⟩

/-- One-sided count and normalized-density upper bounds are equivalent. -/
theorem roughDyadicCountUpperBound_iff_densityUpperBound
    (a₀ b₀ C₀ : ℝ) (ha₀ : 0 < a₀) :
    roughDyadicCountUpperBound a₀ b₀ C₀ ↔
      roughDyadicDensityUpperBound a₀ b₀ C₀ :=
  ⟨roughDyadicDensityUpperBound_of_countUpperBound ha₀,
    roughDyadicCountUpperBound_of_densityUpperBound⟩

/-- Dyadic-block reciprocal version of the count-level rough-sieve input.

This theorem is not an additional analytic input: it converts an arbitrary
count estimate `roughDyadicCount X M t ≍ t/log z` into the corresponding block
reciprocal estimate `roughBlockRecip X M t ≍ 1/log z` using the checked
inequalities `count/(2t) ≤ blockRecip ≤ count/t`. -/
theorem roughBlockRecip_from_linear_sieve_count_bound
    {a₀ b₀ C₀ : ℝ}
    (h :
      ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
        ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
          c * (t / Real.log (EscAnalytic.zScale X)) ≤ roughDyadicCount X M t
            ∧ roughDyadicCount X M t
                ≤ C * (t / Real.log (EscAnalytic.zScale X))) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
        c / Real.log (EscAnalytic.zScale X) ≤ roughBlockRecip X M t
          ∧ roughBlockRecip X M t ≤ C / Real.log (EscAnalytic.zScale X) := by
  rcases linear_sieve_rough_dyadic_with_log_carrier_bounds_of_count_bound h with
    ⟨c₀, C₀', X₀, hc₀, hC₀', hcount⟩
  refine ⟨c₀ / 2, C₀', X₀, by positivity, hC₀', ?_⟩
  intro X hX M hM t htlo hthi htpos
  have hcntPack := hcount X hX M hM t htlo hthi
  have hlogZ_pos : 0 < Real.log (EscAnalytic.zScale X) := hcntPack.1
  have hcnt :
      c₀ * (t / Real.log (EscAnalytic.zScale X)) ≤ roughDyadicCount X M t ∧
        roughDyadicCount X M t ≤ C₀' * (t / Real.log (EscAnalytic.zScale X)) :=
    ⟨hcntPack.2.2.1, hcntPack.2.2.2.1⟩
  constructor
  · have hblock_ge := roughBlockRecip_ge X M htpos
    have hscaled :
        c₀ / (2 * Real.log (EscAnalytic.zScale X))
          ≤ roughDyadicCount X M t / (2 * t) := by
      rw [div_le_div_iff₀ (mul_pos (by norm_num) hlogZ_pos) (mul_pos (by norm_num) htpos)]
      calc
        c₀ * (2 * t)
            = (c₀ * (t / Real.log (EscAnalytic.zScale X))) *
                (2 * Real.log (EscAnalytic.zScale X)) := by
              field_simp [ne_of_gt hlogZ_pos]
              ring
        _ ≤ roughDyadicCount X M t * (2 * Real.log (EscAnalytic.zScale X)) :=
              mul_le_mul_of_nonneg_right hcnt.1
                (mul_nonneg (by norm_num) hlogZ_pos.le)
    calc
      (c₀ / 2) / Real.log (EscAnalytic.zScale X)
          = c₀ / (2 * Real.log (EscAnalytic.zScale X)) := by ring
      _ ≤ roughDyadicCount X M t / (2 * t) := hscaled
      _ ≤ roughBlockRecip X M t := hblock_ge
  · have hblock_le := roughBlockRecip_le X M htpos
    have hscaled :
        roughDyadicCount X M t / t ≤ C₀' / Real.log (EscAnalytic.zScale X) := by
      rw [div_le_div_iff₀ htpos hlogZ_pos]
      calc
        roughDyadicCount X M t * Real.log (EscAnalytic.zScale X)
            ≤ (C₀' * (t / Real.log (EscAnalytic.zScale X))) *
                Real.log (EscAnalytic.zScale X) :=
              mul_le_mul_of_nonneg_right hcnt.2 hlogZ_pos.le
        _ = C₀' * t := by
              field_simp [ne_of_gt hlogZ_pos]
    exact hblock_le.trans hscaled

/-- Dyadic-block reciprocal version of the count-level rough-sieve input,
specialized to the named primitive count statement. -/
theorem roughBlockRecip_from_linear_sieve
    (a₀ b₀ C₀ : ℝ) (ha₀ : 0 < a₀) (hab : a₀ < b₀) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
        c / Real.log (EscAnalytic.zScale X) ≤ roughBlockRecip X M t
          ∧ roughBlockRecip X M t ≤ C / Real.log (EscAnalytic.zScale X) :=
  roughBlockRecip_from_linear_sieve_count_bound
    (linear_sieve_rough_dyadic_count_bound a₀ b₀ C₀ ha₀ hab)

/-- Conversely, a two-sided dyadic block-reciprocal estimate recovers the
count-level rough-sieve estimate.  The proof uses only
`blockRecip ≤ count/t` for the lower count bound and
`count/(2t) ≤ blockRecip` for the upper count bound, plus the checked
large-`X` positivity of `log z(X)`. -/
theorem linear_sieve_rough_dyadic_count_bound_of_roughBlockRecip_bound
    {a₀ b₀ C₀ : ℝ}
    (h :
      ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
        ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
          c / Real.log (EscAnalytic.zScale X) ≤ roughBlockRecip X M t
            ∧ roughBlockRecip X M t ≤ C / Real.log (EscAnalytic.zScale X)) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        c * (t / Real.log (EscAnalytic.zScale X)) ≤ roughDyadicCount X M t
          ∧ roughDyadicCount X M t
              ≤ C * (t / Real.log (EscAnalytic.zScale X)) := by
  rcases h with ⟨c₀, C₀', Xbase, hc₀, hC₀', hblock⟩
  refine ⟨c₀, 2 * C₀', max Xbase (Real.exp 2), hc₀, by positivity, ?_⟩
  intro X hX M hM t htlo hthi
  have hXbase : Xbase ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 2) hXexp
  have htpos : 0 < t := lt_of_lt_of_le (Real.rpow_pos_of_pos hXpos a₀) htlo
  have hlogZ_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp
  rcases hblock X hXbase M hM t htlo hthi htpos with ⟨hblock_lower, hblock_upper⟩
  constructor
  · have hto_count_div :
        c₀ / Real.log (EscAnalytic.zScale X)
          ≤ roughDyadicCount X M t / t :=
      hblock_lower.trans (roughBlockRecip_le X M htpos)
    rw [div_le_div_iff₀ hlogZ_pos htpos] at hto_count_div
    calc
      c₀ * (t / Real.log (EscAnalytic.zScale X))
          = c₀ * t / Real.log (EscAnalytic.zScale X) := by ring
      _ ≤ roughDyadicCount X M t := by
          rw [div_le_iff₀ hlogZ_pos]
          exact hto_count_div
  · have hcount_div_to :
        roughDyadicCount X M t / (2 * t)
          ≤ C₀' / Real.log (EscAnalytic.zScale X) :=
      (roughBlockRecip_ge X M htpos).trans hblock_upper
    have htwo_t_pos : 0 < 2 * t := mul_pos (by norm_num) htpos
    rw [div_le_div_iff₀ htwo_t_pos hlogZ_pos] at hcount_div_to
    calc
      roughDyadicCount X M t
          ≤ ((2 * C₀') * t) / Real.log (EscAnalytic.zScale X) := by
          rw [le_div_iff₀ hlogZ_pos]
          calc
            roughDyadicCount X M t * Real.log (EscAnalytic.zScale X)
                ≤ C₀' * (2 * t) := hcount_div_to
            _ = (2 * C₀') * t := by ring
      _ = (2 * C₀') * (t / Real.log (EscAnalytic.zScale X)) := by ring

/-- The dyadic count and dyadic block-reciprocal formulations of the rough
sieve input have the same analytic content, up to harmless absolute constants.
The equivalence is entirely internal to the finite dyadic carrier. -/
theorem linear_sieve_rough_dyadic_count_bound_iff_roughBlockRecip_bound
    (a₀ b₀ C₀ : ℝ) :
    (∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        c * (t / Real.log (EscAnalytic.zScale X)) ≤ roughDyadicCount X M t
          ∧ roughDyadicCount X M t
              ≤ C * (t / Real.log (EscAnalytic.zScale X))) ↔
    (∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
        c / Real.log (EscAnalytic.zScale X) ≤ roughBlockRecip X M t
          ∧ roughBlockRecip X M t ≤ C / Real.log (EscAnalytic.zScale X)) := by
  constructor
  · exact roughBlockRecip_from_linear_sieve_count_bound
  · exact linear_sieve_rough_dyadic_count_bound_of_roughBlockRecip_bound

/-- A normalized dyadic-density estimate already gives the dyadic
block-reciprocal carrier used downstream.  This removes the intermediate
count formulation from later arguments when the primitive input is supplied as
`roughDyadicCount/t ≍ 1/log z`. -/
theorem roughBlockRecip_from_roughDyadicDensity_bound
    {a₀ b₀ C₀ : ℝ}
    (h :
      ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
        ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
          0 < Real.log (EscAnalytic.zScale X) ∧
            c / Real.log (EscAnalytic.zScale X) ≤ roughDyadicDensity X M t ∧
            roughDyadicDensity X M t ≤ C / Real.log (EscAnalytic.zScale X)) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
        c / Real.log (EscAnalytic.zScale X) ≤ roughBlockRecip X M t
          ∧ roughBlockRecip X M t ≤ C / Real.log (EscAnalytic.zScale X) :=
  roughBlockRecip_from_linear_sieve_count_bound
    (linear_sieve_rough_dyadic_count_bound_of_density_bound h)

/-- The normalized-density and dyadic block-reciprocal forms of the rough
sieve input have the same content, up to absolute constants.  Both conversions
are checked finite-carrier algebra. -/
theorem roughDyadicDensity_bound_iff_roughBlockRecip_bound
    (a₀ b₀ C₀ : ℝ) (ha₀ : 0 < a₀) :
    (∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
        0 < Real.log (EscAnalytic.zScale X) ∧
          c / Real.log (EscAnalytic.zScale X) ≤ roughDyadicDensity X M t ∧
          roughDyadicDensity X M t ≤ C / Real.log (EscAnalytic.zScale X)) ↔
    (∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
        c / Real.log (EscAnalytic.zScale X) ≤ roughBlockRecip X M t
          ∧ roughBlockRecip X M t ≤ C / Real.log (EscAnalytic.zScale X)) := by
  have hCountDensity :=
    linear_sieve_rough_dyadic_count_bound_iff_density_bound a₀ b₀ C₀ ha₀
  have hCountBlock :=
    linear_sieve_rough_dyadic_count_bound_iff_roughBlockRecip_bound a₀ b₀ C₀
  exact hCountDensity.symm.trans hCountBlock

/-- Lower half of the dyadic block-reciprocal rough primitive. -/
def roughBlockRecipLowerBound (a₀ b₀ C₀ : ℝ) : Prop :=
  ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
      c / Real.log (EscAnalytic.zScale X) ≤ roughBlockRecip X M t

/-- Upper half of the dyadic block-reciprocal rough primitive. -/
def roughBlockRecipUpperBound (a₀ b₀ C₀ : ℝ) : Prop :=
  ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
      roughBlockRecip X M t ≤ C / Real.log (EscAnalytic.zScale X)

/-- A two-sided dyadic block-reciprocal estimate is exactly its lower and upper
halves. -/
theorem roughBlockRecip_bound_iff_lower_upper
    (a₀ b₀ C₀ : ℝ) :
    (∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
        c / Real.log (EscAnalytic.zScale X) ≤ roughBlockRecip X M t
          ∧ roughBlockRecip X M t ≤ C / Real.log (EscAnalytic.zScale X)) ↔
      roughBlockRecipLowerBound a₀ b₀ C₀ ∧
        roughBlockRecipUpperBound a₀ b₀ C₀ := by
  constructor
  · rintro ⟨c, C, X₀, hc, hC, h⟩
    refine ⟨⟨c, X₀, hc, ?_⟩, ⟨C, X₀, hC, ?_⟩⟩
    · intro X hX M hM t htlo hthi htpos
      exact (h X hX M hM t htlo hthi htpos).1
    · intro X hX M hM t htlo hthi htpos
      exact (h X hX M hM t htlo hthi htpos).2
  · rintro ⟨⟨c, Xlo, hc, hlo⟩, ⟨C, Xhi, hC, hhi⟩⟩
    refine ⟨c, C, max Xlo Xhi, hc, hC, ?_⟩
    intro X hX M hM t htlo hthi htpos
    have hXlo : Xlo ≤ X := le_trans (le_max_left _ _) hX
    have hXhi : Xhi ≤ X := le_trans (le_max_right _ _) hX
    exact ⟨hlo X hXlo M hM t htlo hthi htpos,
      hhi X hXhi M hM t htlo hthi htpos⟩

/-- A dyadic Selberg reciprocal upper bound also gives the one-sided
block-reciprocal upper primitive directly.  This is the exact finite-carrier
inclusion `roughBlockRecip ≤ selbergSum`, with no count conversion. -/
theorem roughBlockRecipUpperBound_of_selbergBlockUpper
    (hSelberg : roughDyadicSelbergBlockUpperBound a₀ b₀ C₀) :
    roughBlockRecipUpperBound a₀ b₀ C₀ := by
  rcases hSelberg with ⟨C, Xbase, hC, hSelberg⟩
  refine ⟨C, Xbase, hC, ?_⟩
  intro X hX M hM t htlo hthi _htpos
  exact (roughBlockRecip_le_selbergSum_auxiliary X M t).trans
    (hSelberg X hX M hM t htlo hthi)

/-- The normalized-density rough primitive is equivalent to lower and upper
dyadic block-reciprocal estimates. -/
theorem roughDyadicDensity_bound_iff_roughBlockRecip_lower_upper
    (a₀ b₀ C₀ : ℝ) (ha₀ : 0 < a₀) :
    (∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
        0 < Real.log (EscAnalytic.zScale X) ∧
          c / Real.log (EscAnalytic.zScale X) ≤ roughDyadicDensity X M t ∧
          roughDyadicDensity X M t ≤ C / Real.log (EscAnalytic.zScale X)) ↔
      roughBlockRecipLowerBound a₀ b₀ C₀ ∧
        roughBlockRecipUpperBound a₀ b₀ C₀ := by
  exact (roughDyadicDensity_bound_iff_roughBlockRecip_bound a₀ b₀ C₀ ha₀).trans
    (roughBlockRecip_bound_iff_lower_upper a₀ b₀ C₀)

/-- The count-level rough-sieve primitive is equivalent to lower and upper
dyadic block-reciprocal estimates. -/
theorem linear_sieve_rough_dyadic_count_bound_iff_roughBlockRecip_lower_upper
    (a₀ b₀ C₀ : ℝ) :
    (∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        c * (t / Real.log (EscAnalytic.zScale X)) ≤ roughDyadicCount X M t
          ∧ roughDyadicCount X M t
              ≤ C * (t / Real.log (EscAnalytic.zScale X))) ↔
      roughBlockRecipLowerBound a₀ b₀ C₀ ∧
        roughBlockRecipUpperBound a₀ b₀ C₀ := by
  exact (linear_sieve_rough_dyadic_count_bound_iff_roughBlockRecip_bound
    a₀ b₀ C₀).trans (roughBlockRecip_bound_iff_lower_upper a₀ b₀ C₀)

/-- A bare block-reciprocal estimate gives the carrier-bundled version with
logarithm positivity, nonnegativity, and absolute-value side facts.  The extra
fields are finite-carrier bookkeeping, not additional sieve input. -/
theorem roughBlockRecip_with_carrier_bounds_of_bound
    {a₀ b₀ C₀ : ℝ}
    (h :
      ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
        ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
          c / Real.log (EscAnalytic.zScale X) ≤ roughBlockRecip X M t
            ∧ roughBlockRecip X M t ≤ C / Real.log (EscAnalytic.zScale X)) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
        0 < Real.log (EscAnalytic.zScale X) ∧
          0 ≤ roughBlockRecip X M t ∧
          c / Real.log (EscAnalytic.zScale X) ≤ roughBlockRecip X M t ∧
          roughBlockRecip X M t ≤ C / Real.log (EscAnalytic.zScale X) ∧
          |roughBlockRecip X M t| ≤ C / Real.log (EscAnalytic.zScale X) := by
  rcases h with ⟨c, C, Xbase, hc, hC, hblock⟩
  refine ⟨c, C, max Xbase (Real.exp 2), hc, hC, ?_⟩
  intro X hX M hM t htlo hthi htpos
  have hXbase : Xbase ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hlogZ_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp
  have hcarrier_nonneg : 0 ≤ roughBlockRecip X M t :=
    roughBlockRecip_nonneg X M t
  rcases hblock X hXbase M hM t htlo hthi htpos with ⟨hlower, hupper⟩
  exact ⟨hlogZ_pos, hcarrier_nonneg, hlower, hupper, by
    rw [abs_of_nonneg hcarrier_nonneg]
    exact hupper⟩

/-- Forget the checked carrier side conditions from a bundled block-reciprocal
estimate. -/
theorem roughBlockRecip_bound_of_carrier_bounds
    {a₀ b₀ C₀ : ℝ}
    (h :
      ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
        ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
          0 < Real.log (EscAnalytic.zScale X) ∧
            0 ≤ roughBlockRecip X M t ∧
            c / Real.log (EscAnalytic.zScale X) ≤ roughBlockRecip X M t ∧
            roughBlockRecip X M t ≤ C / Real.log (EscAnalytic.zScale X) ∧
            |roughBlockRecip X M t| ≤ C / Real.log (EscAnalytic.zScale X)) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
        c / Real.log (EscAnalytic.zScale X) ≤ roughBlockRecip X M t
          ∧ roughBlockRecip X M t ≤ C / Real.log (EscAnalytic.zScale X) := by
  rcases h with ⟨c, C, X₀, hc, hC, hcarrier⟩
  refine ⟨c, C, X₀, hc, hC, ?_⟩
  intro X hX M hM t htlo hthi htpos
  have hpack := hcarrier X hX M hM t htlo hthi htpos
  exact ⟨hpack.2.2.1, hpack.2.2.2.1⟩

/-- Bare and carrier-bundled dyadic block reciprocal estimates have the same
analytic content; the bundled version only records log and carrier side facts. -/
theorem roughBlockRecip_bound_iff_carrier_bounds
    (a₀ b₀ C₀ : ℝ) :
    (∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
        c / Real.log (EscAnalytic.zScale X) ≤ roughBlockRecip X M t
          ∧ roughBlockRecip X M t ≤ C / Real.log (EscAnalytic.zScale X)) ↔
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
        0 < Real.log (EscAnalytic.zScale X) ∧
          0 ≤ roughBlockRecip X M t ∧
          c / Real.log (EscAnalytic.zScale X) ≤ roughBlockRecip X M t ∧
          roughBlockRecip X M t ≤ C / Real.log (EscAnalytic.zScale X) ∧
          |roughBlockRecip X M t| ≤ C / Real.log (EscAnalytic.zScale X) := by
  constructor
  · exact roughBlockRecip_with_carrier_bounds_of_bound
  · exact roughBlockRecip_bound_of_carrier_bounds

/-- A one-sided dyadic count lower bound gives the corresponding one-sided
dyadic block-reciprocal lower bound.  The only loss is the factor `2` from
`count/(2t) ≤ blockRecip`; the larger threshold supplies `log z(X)>0`. -/
theorem roughBlockRecipLowerBound_of_countLowerBound
    {a₀ b₀ C₀ : ℝ} (_ha₀ : 0 < a₀)
    (h : roughDyadicCountLowerBound a₀ b₀ C₀) :
    roughBlockRecipLowerBound a₀ b₀ C₀ := by
  rcases h with ⟨c, Xbase, hc, hcount⟩
  refine ⟨c / 2, max Xbase (Real.exp 2), half_pos hc, ?_⟩
  intro X hX M hM t htlo hthi htpos
  have hXbase : Xbase ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hlogZ_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp
  have hcnt := hcount X hXbase M hM t htlo hthi
  have hblock := roughBlockRecip_ge X M htpos
  have hscaled :
      (c * (t / Real.log (EscAnalytic.zScale X))) / (2 * t)
        ≤ roughDyadicCount X M t / (2 * t) :=
    div_le_div_of_nonneg_right hcnt (mul_pos (by norm_num) htpos).le
  calc
    (c / 2) / Real.log (EscAnalytic.zScale X)
        = (c * (t / Real.log (EscAnalytic.zScale X))) / (2 * t) := by
          field_simp [ne_of_gt htpos, ne_of_gt hlogZ_pos]
          ring
    _ ≤ roughDyadicCount X M t / (2 * t) := hscaled
    _ ≤ roughBlockRecip X M t := hblock

/-- A one-sided dyadic count upper bound gives the corresponding one-sided
dyadic block-reciprocal upper bound.  This is the checked conversion
`blockRecip ≤ count/t`. -/
theorem roughBlockRecipUpperBound_of_countUpperBound
    {a₀ b₀ C₀ : ℝ} (_ha₀ : 0 < a₀)
    (h : roughDyadicCountUpperBound a₀ b₀ C₀) :
    roughBlockRecipUpperBound a₀ b₀ C₀ := by
  rcases h with ⟨C, Xbase, hC, hcount⟩
  refine ⟨C, max Xbase (Real.exp 2), hC, ?_⟩
  intro X hX M hM t htlo hthi htpos
  have hXbase : Xbase ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hlogZ_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp
  have hcnt := hcount X hXbase M hM t htlo hthi
  have hblock := roughBlockRecip_le X M htpos
  have hscaled :
      roughDyadicCount X M t / t
        ≤ (C * (t / Real.log (EscAnalytic.zScale X))) / t :=
    div_le_div_of_nonneg_right hcnt htpos.le
  calc
    roughBlockRecip X M t
        ≤ roughDyadicCount X M t / t := hblock
    _ ≤ (C * (t / Real.log (EscAnalytic.zScale X))) / t := hscaled
    _ = C / Real.log (EscAnalytic.zScale X) := by
          field_simp [ne_of_gt htpos, ne_of_gt hlogZ_pos]
          ring

/-- A one-sided dyadic block-reciprocal lower bound recovers the corresponding
one-sided count lower bound.  This is the reverse finite-carrier inequality to
`roughBlockRecipLowerBound_of_countLowerBound`, using
`roughBlockRecip ≤ count/t`. -/
theorem roughDyadicCountLowerBound_of_roughBlockRecipLowerBound
    {a₀ b₀ C₀ : ℝ} (_ha₀ : 0 < a₀)
    (h : roughBlockRecipLowerBound a₀ b₀ C₀) :
    roughDyadicCountLowerBound a₀ b₀ C₀ := by
  rcases h with ⟨c, Xbase, hc, hblock⟩
  refine ⟨c, max Xbase (Real.exp 1), hc, ?_⟩
  intro X hX M hM t htlo hthi
  have hXbase : Xbase ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 1 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 1) hXexp
  have htpos : 0 < t := lt_of_lt_of_le (Real.rpow_pos_of_pos hXpos a₀) htlo
  have hblock_lower := hblock X hXbase M hM t htlo hthi htpos
  have hblock_upper := roughBlockRecip_le X M htpos
  have hmul :
      (c / Real.log (EscAnalytic.zScale X)) * t
        ≤ (roughDyadicCount X M t / t) * t :=
    mul_le_mul_of_nonneg_right (hblock_lower.trans hblock_upper) htpos.le
  calc
    c * (t / Real.log (EscAnalytic.zScale X))
        = (c / Real.log (EscAnalytic.zScale X)) * t := by ring
    _ ≤ (roughDyadicCount X M t / t) * t := hmul
    _ = roughDyadicCount X M t := by
          field_simp [ne_of_gt htpos]

/-- A one-sided dyadic block-reciprocal upper bound recovers the corresponding
one-sided count upper bound.  The only loss is the factor `2`, from
`count/(2t) ≤ blockRecip`. -/
theorem roughDyadicCountUpperBound_of_roughBlockRecipUpperBound
    {a₀ b₀ C₀ : ℝ} (_ha₀ : 0 < a₀)
    (h : roughBlockRecipUpperBound a₀ b₀ C₀) :
    roughDyadicCountUpperBound a₀ b₀ C₀ := by
  rcases h with ⟨C, Xbase, hC, hblock⟩
  refine ⟨2 * C, max Xbase (Real.exp 1), by positivity, ?_⟩
  intro X hX M hM t htlo hthi
  have hXbase : Xbase ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 1 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 1) hXexp
  have htpos : 0 < t := lt_of_lt_of_le (Real.rpow_pos_of_pos hXpos a₀) htlo
  have htwo_t_pos : 0 < 2 * t := mul_pos (by norm_num) htpos
  have hblock_lower := roughBlockRecip_ge X M htpos
  have hblock_upper := hblock X hXbase M hM t htlo hthi htpos
  have hmul :
      (roughDyadicCount X M t / (2 * t)) * (2 * t)
        ≤ (C / Real.log (EscAnalytic.zScale X)) * (2 * t) :=
    mul_le_mul_of_nonneg_right (hblock_lower.trans hblock_upper) htwo_t_pos.le
  calc
    roughDyadicCount X M t
        = (roughDyadicCount X M t / (2 * t)) * (2 * t) := by
          field_simp [ne_of_gt htwo_t_pos]
    _ ≤ (C / Real.log (EscAnalytic.zScale X)) * (2 * t) := hmul
    _ = (2 * C) * (t / Real.log (EscAnalytic.zScale X)) := by ring

/-- The lower count primitive is equivalent to the lower dyadic
block-reciprocal primitive. -/
theorem roughDyadicCountLowerBound_iff_roughBlockRecipLowerBound
    (a₀ b₀ C₀ : ℝ) (ha₀ : 0 < a₀) :
    roughDyadicCountLowerBound a₀ b₀ C₀ ↔
      roughBlockRecipLowerBound a₀ b₀ C₀ := by
  constructor
  · exact roughBlockRecipLowerBound_of_countLowerBound ha₀
  · exact roughDyadicCountLowerBound_of_roughBlockRecipLowerBound ha₀

/-- The upper count primitive is equivalent, up to the harmless dyadic factor
`2`, to the upper dyadic block-reciprocal primitive. -/
theorem roughDyadicCountUpperBound_iff_roughBlockRecipUpperBound
    (a₀ b₀ C₀ : ℝ) (ha₀ : 0 < a₀) :
    roughDyadicCountUpperBound a₀ b₀ C₀ ↔
      roughBlockRecipUpperBound a₀ b₀ C₀ := by
  constructor
  · exact roughBlockRecipUpperBound_of_countUpperBound ha₀
  · exact roughDyadicCountUpperBound_of_roughBlockRecipUpperBound ha₀

/-- Direct block-reciprocal replacement for the lower half of the named dyadic
rough-count input.  This is often the cleanest lower primitive after dyadic
normalization: `blockRecip ≳ 1/log z` is equivalent to the count lower bound by
checked finite-carrier inequalities. -/
theorem linear_sieve_rough_dyadic_count_lower_bound_of_roughBlockRecipLowerBound
    {a₀ b₀ C₀ : ℝ} (ha₀ : 0 < a₀)
    (hblock : roughBlockRecipLowerBound a₀ b₀ C₀) :
    roughDyadicCountLowerBound a₀ b₀ C₀ :=
  roughDyadicCountLowerBound_of_roughBlockRecipLowerBound ha₀ hblock

/-- Direct block-reciprocal replacement for the upper half of the named dyadic
rough-count input.  This is the one-sided Selberg-facing primitive:
`blockRecip ≲ 1/log z` gives the count upper bound with only the dyadic factor
`2`. -/
theorem linear_sieve_rough_dyadic_count_upper_bound_of_roughBlockRecipUpperBound
    {a₀ b₀ C₀ : ℝ} (ha₀ : 0 < a₀)
    (hblock : roughBlockRecipUpperBound a₀ b₀ C₀) :
    roughDyadicCountUpperBound a₀ b₀ C₀ :=
  roughDyadicCountUpperBound_of_roughBlockRecipUpperBound ha₀ hblock

/-- Block-reciprocal linear-sieve consequence bundled with the checked carrier,
logarithm, and absolute-value side conditions.  This is still derived from the
count-level sieve input; no reciprocal-sum estimate is assumed here. -/
theorem roughBlockRecip_from_linear_sieve_with_carrier_bounds
    (a₀ b₀ C₀ : ℝ) (ha₀ : 0 < a₀) (hab : a₀ < b₀) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
        0 < Real.log (EscAnalytic.zScale X) ∧
          0 ≤ roughBlockRecip X M t ∧
          c / Real.log (EscAnalytic.zScale X) ≤ roughBlockRecip X M t ∧
          roughBlockRecip X M t ≤ C / Real.log (EscAnalytic.zScale X) ∧
          |roughBlockRecip X M t| ≤ C / Real.log (EscAnalytic.zScale X) :=
  roughBlockRecip_with_carrier_bounds_of_bound
    (roughBlockRecip_from_linear_sieve a₀ b₀ C₀ ha₀ hab)

/-- **Rough squarefree reciprocal sum** (`lem:rough-sqf`, `(eq:rough-recip-uniform)`,
tex 963–971).  This is now a *theorem*: the reciprocal estimate
`roughRecip ≍ (log X)/(log z)` is *derived* from the bare count-level linear-sieve
input `linear_sieve_rough_dyadic_with_carrier_bounds` by dyadic partial summation.

Decompose `(X^a, X^b]` into the `≍ (b-a)·logX/log2` dyadic blocks
`(X^a·2^k, X^a·2^{k+1}]`.  On a block `(t,2t]` with `t = X^a·2^k`, each reciprocal
`1/n` lies in `[1/(2t), 1/t)`, so the block reciprocal sum lies between
`count/(2t)` and `count/t`; the count input makes each block contribute `≍ 1/log z`;
there are `≍ (b-a)·logX/log2` blocks, giving the total `≍ (log X)/(log z)`.

This generic form takes the count estimate as an explicit hypothesis.  The named
`rough_sqf_recip` below is just the specialization to the standard
linear-sieve input. -/
theorem rough_sqf_recip_of_count_bound
    (_P : EscAnalytic.Params) (a₀ b₀ c₁ C₀ : ℝ)
    (ha₀ : 0 < a₀) (hab : a₀ < b₀) (hc₁ : 0 < c₁)
    (hcountInput :
      ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
        ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
          c * (t / Real.log (EscAnalytic.zScale X)) ≤ roughDyadicCount X M t
            ∧ roughDyadicCount X M t
                ≤ C * (t / Real.log (EscAnalytic.zScale X))) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ a b : ℝ, a₀ ≤ a → a < b → b ≤ b₀ → c₁ ≤ b - a →
        c * (Real.log X / Real.log (EscAnalytic.zScale X)) ≤ roughRecip X M a b
          ∧ roughRecip X M a b
              ≤ C * (Real.log X / Real.log (EscAnalytic.zScale X)) := by
  classical
  -- The count-level sieve input, packaged with carrier side facts.
  obtain ⟨cC, CC, XC, hcC, hCC, hcount⟩ :=
    linear_sieve_rough_dyadic_with_carrier_bounds_of_count_bound hcountInput
  -- Output constants from the partial summation.
  refine ⟨cC * c₁ / (4 * Real.log 2), CC * b₀ * (1 / Real.log 2 + 1 / c₁),
    max XC (Real.exp (2 * Real.log 2 / c₁ + 2)), ?_, ?_, ?_⟩
  · -- positivity of the lower constant
    have hlog2 : 0 < Real.log 2 := Real.log_pos (by norm_num)
    positivity
  · -- positivity of the upper constant
    have hlog2 : 0 < Real.log 2 := Real.log_pos (by norm_num)
    have hb₀ : 0 < b₀ := lt_trans ha₀ hab
    have : 0 < 1 / Real.log 2 + 1 / c₁ := by positivity
    positivity
  intro X hXbig M hM a b ha hab' hb hc
  have hlog2 : 0 < Real.log 2 := Real.log_pos (by norm_num)
  have hXC : XC ≤ X := le_trans (le_max_left _ _) hXbig
  have hXbnd : Real.exp (2 * Real.log 2 / c₁ + 2) ≤ X := le_trans (le_max_right _ _) hXbig
  -- Basic positivity facts.
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos _) hXbnd
  have hLge : 2 * Real.log 2 / c₁ + 2 ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]; exact hXbnd
  have hL2 : (2 : ℝ) ≤ Real.log X := by nlinarith [div_nonneg (by positivity : (0:ℝ) ≤ 2 * Real.log 2) hc₁.le]
  have hLpos : 0 < Real.log X := lt_of_lt_of_le (by norm_num) hL2
  have hXgt1 : 1 < X := by
    have : Real.exp 0 < X := lt_of_lt_of_le (by simpa using Real.exp_lt_exp.mpr (by positivity : (0:ℝ) < 2 * Real.log 2 / c₁ + 2)) hXbnd
    simpa using this
  -- `log z = 4 log log X > 0`.
  have hLogLog_pos : 0 < Real.log (Real.log X) := Real.log_pos (lt_of_lt_of_le one_lt_two hL2)
  have hLz_eq : Real.log (EscAnalytic.zScale X) = 4 * Real.log (Real.log X) := by
    unfold EscAnalytic.zScale; rw [Real.log_pow]; push_cast; ring
  have hLzpos : 0 < Real.log (EscAnalytic.zScale X) := by rw [hLz_eq]; positivity
  set Lz := Real.log (EscAnalytic.zScale X) with hLzdef
  set L := Real.log X with hLdef
  have hba_pos : 0 < b - a := by linarith
  have hba_ge : c₁ ≤ b - a := hc
  have hba_le_b₀ : b - a ≤ b₀ := by linarith
  -- Number of blocks.
  set Nup := ⌊(b - a) * L / Real.log 2⌋₊ + 1 with hNupdef
  set Nlo := ⌊(b - a) * L / Real.log 2⌋₊ with hNlodef
  have hNup_pos : 0 < Nup := by omega
  -- key real value: q := (b-a) L / log2
  set q := (b - a) * L / Real.log 2 with hqdef
  have hq_nonneg : 0 ≤ q := by
    rw [hqdef]; positivity
  -- floor bounds
  have hfloor_le : (Nlo : ℝ) ≤ q := Nat.floor_le hq_nonneg
  have hlt_floor : q < (Nlo : ℝ) + 1 := Nat.lt_floor_add_one q
  -- dyAnchor X a k = X^a * 2^k ; relate 2^Nup, 2^Nlo to X^{b-a}.
  -- `2^N = exp(N log2)` and `X^{b-a} = exp((b-a) L)`.
  have hpow2 : ∀ m : ℕ, (2 : ℝ) ^ m = Real.exp ((m : ℝ) * Real.log 2) := by
    intro m
    rw [Real.exp_nat_mul, Real.exp_log (by norm_num : (0:ℝ) < 2)]
  have hXba : X ^ (b - a) = Real.exp ((b - a) * L) := by
    rw [Real.rpow_def_of_pos hXpos]
    congr 1
    rw [hLdef]; ring
  have hXa_pos : 0 < X ^ a := Real.rpow_pos_of_pos hXpos a
  have hXb_split : X ^ b = X ^ a * X ^ (b - a) := by
    rw [← Real.rpow_add hXpos]; congr 1; ring
  -- `X^{b-a} ≤ 2^Nup`  (so `X^b ≤ dyAnchor X a Nup`).
  have hreach_up : X ^ b ≤ dyAnchor X a Nup := by
    unfold dyAnchor
    rw [hXb_split]
    apply mul_le_mul_of_nonneg_left _ hXa_pos.le
    rw [hXba, hpow2 Nup]
    apply Real.exp_le_exp.mpr
    have hqle : q ≤ (Nup : ℝ) := by rw [hNupdef]; push_cast; linarith [hlt_floor]
    have : (b - a) * L = q * Real.log 2 := by rw [hqdef]; field_simp
    rw [this]
    exact mul_le_mul_of_nonneg_right hqle hlog2.le
  -- `2^Nlo ≤ X^{b-a}`  (so `dyAnchor X a Nlo ≤ X^b`).
  have hreach_lo : dyAnchor X a Nlo ≤ X ^ b := by
    unfold dyAnchor
    rw [hXb_split]
    apply mul_le_mul_of_nonneg_left _ hXa_pos.le
    rw [hXba, hpow2 Nlo]
    apply Real.exp_le_exp.mpr
    have : (b - a) * L = q * Real.log 2 := by rw [hqdef]; field_simp
    rw [this]
    exact mul_le_mul_of_nonneg_right hfloor_le hlog2.le
  -- The anchors used all lie in the count range `[X^{a₀}, 2 X^{b₀}]`.
  -- Lower end: `X^{a₀} ≤ X^a = dyAnchor X a 0 ≤ dyAnchor X a k`.
  have hanchor_lo : ∀ k : ℕ, X ^ a₀ ≤ dyAnchor X a k := by
    intro k
    have h1 : X ^ a₀ ≤ X ^ a := Real.rpow_le_rpow_of_exponent_le hXgt1.le ha
    have h2 : X ^ a = dyAnchor X a 0 := by unfold dyAnchor; simp
    exact le_trans h1 (h2 ▸ dyAnchor_mono hXpos (Nat.zero_le k))
  -- Upper end for the UPPER blocks (k < Nup): `dyAnchor X a k ≤ 2 X^{b₀}`.
  -- `dyAnchor X a k = X^a 2^k < X^a 2^Nup ≤ X^a · 2 · X^{b-a} = 2 X^b ≤ 2 X^{b₀}`.
  have h2Nup : (2 : ℝ) ^ Nup ≤ 2 * X ^ (b - a) := by
    rw [hpow2 Nup, hXba]
    have hqle : (Nup : ℝ) ≤ q + 1 := by rw [hNupdef]; push_cast; linarith [hfloor_le]
    calc Real.exp ((Nup : ℝ) * Real.log 2)
        ≤ Real.exp ((q + 1) * Real.log 2) :=
          Real.exp_le_exp.mpr (mul_le_mul_of_nonneg_right hqle hlog2.le)
      _ = Real.exp (q * Real.log 2) * Real.exp (Real.log 2) := by
          rw [← Real.exp_add]; congr 1; ring
      _ = Real.exp ((b - a) * L) * 2 := by
          rw [Real.exp_log (by norm_num : (0:ℝ) < 2)]
          congr 2; rw [hqdef]; field_simp
      _ = 2 * Real.exp ((b - a) * L) := by ring
  have hanchor_up : ∀ k : ℕ, k < Nup → dyAnchor X a k ≤ 2 * X ^ b₀ := by
    intro k hk
    unfold dyAnchor
    have hk2 : (2 : ℝ) ^ k ≤ 2 ^ Nup :=
      pow_le_pow_right₀ (by norm_num) (by omega)
    have hXbb₀ : X ^ b ≤ X ^ b₀ := Real.rpow_le_rpow_of_exponent_le hXgt1.le hb
    calc X ^ a * 2 ^ k
        ≤ X ^ a * 2 ^ Nup := mul_le_mul_of_nonneg_left hk2 hXa_pos.le
      _ ≤ X ^ a * (2 * X ^ (b - a)) := mul_le_mul_of_nonneg_left h2Nup hXa_pos.le
      _ = 2 * X ^ b := by rw [hXb_split]; ring
      _ ≤ 2 * X ^ b₀ := by linarith
  -- Upper end for the LOWER blocks (k < Nlo): `dyAnchor X a k ≤ X^b ≤ 2 X^{b₀}`.
  have hanchor_up_lo : ∀ k : ℕ, k < Nlo → dyAnchor X a k ≤ 2 * X ^ b₀ := by
    intro k hk
    have hmono : dyAnchor X a k ≤ dyAnchor X a Nlo := dyAnchor_mono hXpos (by omega)
    have hXbb₀ : X ^ b ≤ X ^ b₀ := Real.rpow_le_rpow_of_exponent_le hXgt1.le hb
    have hX0 : 0 ≤ X ^ b₀ := (Real.rpow_pos_of_pos hXpos b₀).le
    calc dyAnchor X a k ≤ dyAnchor X a Nlo := hmono
      _ ≤ X ^ b := hreach_lo
      _ ≤ X ^ b₀ := hXbb₀
      _ ≤ 2 * X ^ b₀ := by linarith
  -- ===== UPPER BOUND on roughRecip. =====
  have hupper : roughRecip X M a b ≤ CC * b₀ * (1 / Real.log 2 + 1 / c₁) * (L / Lz) := by
    have hstep := roughRecip_le_blockSum X M a b hXpos Nup hNup_pos hreach_up
    -- each summand ≤ CC / Lz
    have hsum_le : ∑ k ∈ Finset.range Nup,
        roughDyadicCount X M (dyAnchor X a k) / dyAnchor X a k
          ≤ ∑ _k ∈ Finset.range Nup, CC / Lz := by
      apply Finset.sum_le_sum
      intro k hk
      rw [Finset.mem_range] at hk
      have htlo : X ^ a₀ ≤ dyAnchor X a k := hanchor_lo k
      have hthi : dyAnchor X a k ≤ 2 * X ^ b₀ := hanchor_up k hk
      have hcnt := (hcount X hXC M hM (dyAnchor X a k) htlo hthi).2.2.1
      have htk_pos : 0 < dyAnchor X a k := dyAnchor_pos hXpos k
      rw [div_le_div_iff₀ htk_pos hLzpos]
      calc roughDyadicCount X M (dyAnchor X a k) * Lz
          ≤ (CC * (dyAnchor X a k / Lz)) * Lz :=
            mul_le_mul_of_nonneg_right hcnt hLzpos.le
        _ = CC * dyAnchor X a k := by field_simp
    rw [Finset.sum_const, Finset.card_range, nsmul_eq_mul] at hsum_le
    -- (Nup : ℝ) ≤ b₀ (1/log2 + 1/c₁) L
    have hNup_bound : (Nup : ℝ) ≤ b₀ * (1 / Real.log 2 + 1 / c₁) * L := by
      have h1 : (Nup : ℝ) ≤ q + 1 := by rw [hNupdef]; push_cast; linarith [hfloor_le]
      have hq_le : q ≤ b₀ * (1 / Real.log 2) * L := by
        rw [hqdef]
        rw [div_eq_mul_inv]
        have : (b - a) * L * (Real.log 2)⁻¹ ≤ b₀ * L * (Real.log 2)⁻¹ :=
          mul_le_mul_of_nonneg_right
            (mul_le_mul_of_nonneg_right hba_le_b₀ hLpos.le) (by positivity)
        calc (b - a) * L * (Real.log 2)⁻¹ ≤ b₀ * L * (Real.log 2)⁻¹ := this
          _ = b₀ * (1 / Real.log 2) * L := by rw [one_div]; ring
      have h1_le : (1 : ℝ) ≤ b₀ * (1 / c₁) * L := by
        have hb₀c₁ : c₁ ≤ b₀ := le_trans hba_ge hba_le_b₀
        have : (1 : ℝ) ≤ (c₁ * (1 / c₁)) * L := by
          rw [mul_one_div, div_self (ne_of_gt hc₁), one_mul]; exact hL2.trans' (by norm_num)
        calc (1 : ℝ) ≤ c₁ * (1 / c₁) * L := this
          _ ≤ b₀ * (1 / c₁) * L :=
            mul_le_mul_of_nonneg_right
              (mul_le_mul_of_nonneg_right hb₀c₁ (by positivity)) hLpos.le
      calc (Nup : ℝ) ≤ q + 1 := h1
        _ ≤ b₀ * (1 / Real.log 2) * L + b₀ * (1 / c₁) * L :=
            add_le_add hq_le h1_le
        _ = b₀ * (1 / Real.log 2 + 1 / c₁) * L := by ring
    calc roughRecip X M a b
        ≤ ∑ k ∈ Finset.range Nup,
            roughDyadicCount X M (dyAnchor X a k) / dyAnchor X a k := hstep
      _ ≤ (Nup : ℝ) * (CC / Lz) := hsum_le
      _ ≤ (b₀ * (1 / Real.log 2 + 1 / c₁) * L) * (CC / Lz) :=
          mul_le_mul_of_nonneg_right hNup_bound (by positivity)
      _ = CC * b₀ * (1 / Real.log 2 + 1 / c₁) * (L / Lz) := by ring
  -- ===== LOWER BOUND on roughRecip. =====
  have hlower : cC * c₁ / (4 * Real.log 2) * (L / Lz) ≤ roughRecip X M a b := by
    have hstep := blockSum_le_roughRecip X M a b hXpos Nlo hreach_lo
    -- each summand ≥ cC / (2 Lz)
    have hsum_ge : ∑ _k ∈ Finset.range Nlo, cC / (2 * Lz)
        ≤ ∑ k ∈ Finset.range Nlo,
            roughDyadicCount X M (dyAnchor X a k) / (2 * dyAnchor X a k) := by
      apply Finset.sum_le_sum
      intro k hk
      rw [Finset.mem_range] at hk
      have htlo : X ^ a₀ ≤ dyAnchor X a k := hanchor_lo k
      have hthi : dyAnchor X a k ≤ 2 * X ^ b₀ := hanchor_up_lo k hk
      have hcnt := (hcount X hXC M hM (dyAnchor X a k) htlo hthi).2.1
      have htk_pos : 0 < dyAnchor X a k := dyAnchor_pos hXpos k
      have h2tk_pos : 0 < 2 * dyAnchor X a k := by positivity
      have h2Lz_pos : 0 < 2 * Lz := by positivity
      rw [div_le_div_iff₀ h2Lz_pos h2tk_pos]
      calc cC * (2 * dyAnchor X a k)
          = (cC * (dyAnchor X a k / Lz)) * (2 * Lz) := by field_simp; ring
        _ ≤ roughDyadicCount X M (dyAnchor X a k) * (2 * Lz) :=
            mul_le_mul_of_nonneg_right hcnt h2Lz_pos.le
    rw [Finset.sum_const, Finset.card_range, nsmul_eq_mul] at hsum_ge
    -- (Nlo : ℝ) ≥ c₁ L / (2 log2)
    have hNlo_bound : c₁ / (2 * Real.log 2) * L ≤ (Nlo : ℝ) := by
      have hq_ge : q - 1 ≤ (Nlo : ℝ) := by linarith [hlt_floor]
      -- q = (b-a)L/log2 ≥ c₁ L / log2, and q ≥ 2 c₁L/(2log2); use L large to absorb the -1.
      have hq_lb : c₁ / Real.log 2 * L ≤ q := by
        rw [hqdef, div_mul_eq_mul_div, div_le_div_iff₀ hlog2 hlog2]
        apply mul_le_mul_of_nonneg_right _ hlog2.le
        exact mul_le_mul_of_nonneg_right hba_ge hLpos.le
      -- L ≥ 2 log2 / c₁ + 2, so c₁ L /(2 log2) ≥ 1 and q ≥ 2·(c₁ L/(2log2)) → q-1 ≥ c₁L/(2log2)
      have hhalf : c₁ / (2 * Real.log 2) * L ≤ q - 1 := by
        have hLbig : 2 * Real.log 2 / c₁ ≤ L := by rw [hLdef]; linarith [hLge]
        -- c₁/(2log2) * L ≥ 1  ⟺  L ≥ 2log2/c₁
        have hone : (1 : ℝ) ≤ c₁ / (2 * Real.log 2) * L := by
          rw [div_mul_eq_mul_div, le_div_iff₀ (by positivity)]
          have : 2 * Real.log 2 = c₁ * (2 * Real.log 2 / c₁) := by field_simp
          rw [one_mul, this]
          exact mul_le_mul_of_nonneg_left hLbig hc₁.le
        -- q ≥ c₁/log2 * L = 2 * (c₁/(2log2) * L) ≥ c₁/(2log2)*L + 1
        have hq2 : 2 * (c₁ / (2 * Real.log 2) * L) ≤ q := by
          have : 2 * (c₁ / (2 * Real.log 2) * L) = c₁ / Real.log 2 * L := by
            field_simp; ring
          rw [this]; exact hq_lb
        linarith
      linarith
    -- assemble
    have hLz_ne : Lz ≠ 0 := ne_of_gt hLzpos
    have hlog2_ne : Real.log 2 ≠ 0 := ne_of_gt hlog2
    calc cC * c₁ / (4 * Real.log 2) * (L / Lz)
        = (c₁ / (2 * Real.log 2) * L) * (cC / (2 * Lz)) := by
          field_simp; ring
      _ ≤ (Nlo : ℝ) * (cC / (2 * Lz)) :=
          mul_le_mul_of_nonneg_right hNlo_bound (by positivity)
      _ ≤ ∑ k ∈ Finset.range Nlo,
            roughDyadicCount X M (dyAnchor X a k) / (2 * dyAnchor X a k) := hsum_ge
      _ ≤ roughRecip X M a b := hstep
  -- Conclude, rewriting `L / Lz` back into the `(log X)/(log z)` form.
  have hform : L / Lz = Real.log X / Real.log (EscAnalytic.zScale X) := by
    rw [hLdef, hLzdef]
  rw [hform] at hupper hlower
  exact ⟨hlower, hupper⟩

/-- Rough squarefree reciprocal estimate from a normalized dyadic-density
input.  This is the same dyadic partial-summation theorem as
`rough_sqf_recip_of_count_bound`, with the count formulation eliminated by the
checked density/count equivalence. -/
theorem rough_sqf_recip_of_roughDyadicDensity_bound
    (P : EscAnalytic.Params) (a₀ b₀ c₁ C₀ : ℝ)
    (ha₀ : 0 < a₀) (hab : a₀ < b₀) (hc₁ : 0 < c₁)
    (hdensity :
      ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
        ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
          0 < Real.log (EscAnalytic.zScale X) ∧
            c / Real.log (EscAnalytic.zScale X) ≤ roughDyadicDensity X M t ∧
            roughDyadicDensity X M t ≤ C / Real.log (EscAnalytic.zScale X)) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ a b : ℝ, a₀ ≤ a → a < b → b ≤ b₀ → c₁ ≤ b - a →
        c * (Real.log X / Real.log (EscAnalytic.zScale X)) ≤ roughRecip X M a b
          ∧ roughRecip X M a b
              ≤ C * (Real.log X / Real.log (EscAnalytic.zScale X)) :=
  rough_sqf_recip_of_count_bound P a₀ b₀ c₁ C₀ ha₀ hab hc₁
    (linear_sieve_rough_dyadic_count_bound_of_density_bound hdensity)

/-- **Rough squarefree reciprocal sum** (`lem:rough-sqf`, `(eq:rough-recip-uniform)`,
tex 963–971), specialized to the standard count-level linear-sieve input. -/
theorem rough_sqf_recip
    (P : EscAnalytic.Params) (a₀ b₀ c₁ C₀ : ℝ)
    (ha₀ : 0 < a₀) (hab : a₀ < b₀) (hc₁ : 0 < c₁) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ a b : ℝ, a₀ ≤ a → a < b → b ≤ b₀ → c₁ ≤ b - a →
        c * (Real.log X / Real.log (EscAnalytic.zScale X)) ≤ roughRecip X M a b
          ∧ roughRecip X M a b
              ≤ C * (Real.log X / Real.log (EscAnalytic.zScale X)) :=
  rough_sqf_recip_of_count_bound P a₀ b₀ c₁ C₀ ha₀ hab hc₁
    (linear_sieve_rough_dyadic_count_bound a₀ b₀ C₀ ha₀ hab)

/-- Lower half of the final rough reciprocal-window estimate. -/
def roughRecipLowerBound (a₀ b₀ c₁ C₀ : ℝ) : Prop :=
  ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
    ∀ a b : ℝ, a₀ ≤ a → a < b → b ≤ b₀ → c₁ ≤ b - a →
      c * (Real.log X / Real.log (EscAnalytic.zScale X)) ≤ roughRecip X M a b

/-- Upper half of the final rough reciprocal-window estimate. -/
def roughRecipUpperBound (a₀ b₀ c₁ C₀ : ℝ) : Prop :=
  ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
    ∀ a b : ℝ, a₀ ≤ a → a < b → b ≤ b₀ → c₁ ≤ b - a →
      roughRecip X M a b ≤ C * (Real.log X / Real.log (EscAnalytic.zScale X))

/-- A two-sided final rough reciprocal estimate is exactly its lower and upper
halves. -/
theorem rough_sqf_recip_bound_iff_lower_upper
    (a₀ b₀ c₁ C₀ : ℝ) :
    (∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ a b : ℝ, a₀ ≤ a → a < b → b ≤ b₀ → c₁ ≤ b - a →
        c * (Real.log X / Real.log (EscAnalytic.zScale X)) ≤ roughRecip X M a b
          ∧ roughRecip X M a b
              ≤ C * (Real.log X / Real.log (EscAnalytic.zScale X))) ↔
      roughRecipLowerBound a₀ b₀ c₁ C₀ ∧
        roughRecipUpperBound a₀ b₀ c₁ C₀ := by
  constructor
  · rintro ⟨c, C, X₀, hc, hC, h⟩
    refine ⟨⟨c, X₀, hc, ?_⟩, ⟨C, X₀, hC, ?_⟩⟩
    · intro X hX M hM a b ha hab hb hc₁
      exact (h X hX M hM a b ha hab hb hc₁).1
    · intro X hX M hM a b ha hab hb hc₁
      exact (h X hX M hM a b ha hab hb hc₁).2
  · rintro ⟨⟨c, Xlo, hc, hlo⟩, ⟨C, Xhi, hC, hhi⟩⟩
    refine ⟨c, C, max Xlo Xhi, hc, hC, ?_⟩
    intro X hX M hM a b ha hab hb hc₁
    have hXlo : Xlo ≤ X := le_trans (le_max_left _ _) hX
    have hXhi : Xhi ≤ X := le_trans (le_max_right _ _) hX
    exact ⟨hlo X hXlo M hM a b ha hab hb hc₁,
      hhi X hXhi M hM a b ha hab hb hc₁⟩

/-- A one-sided dyadic block-reciprocal lower bound gives the lower half of the
final rough reciprocal-window estimate.  This is the lower half of the dyadic
partial-summation argument with the upper sieve estimate removed. -/
theorem roughRecipLowerBound_of_roughBlockRecipLowerBound
    (_P : EscAnalytic.Params) (a₀ b₀ c₁ C₀ : ℝ)
    (_ha₀ : 0 < a₀) (_hab : a₀ < b₀) (hc₁ : 0 < c₁)
    (hblock : roughBlockRecipLowerBound a₀ b₀ C₀) :
    roughRecipLowerBound a₀ b₀ c₁ C₀ := by
  classical
  rcases hblock with ⟨cB, XB, hcB, hblock⟩
  refine ⟨cB * c₁ / (2 * Real.log 2),
    max XB (Real.exp (2 * Real.log 2 / c₁ + 2)), ?_, ?_⟩
  · have hlog2 : 0 < Real.log 2 := Real.log_pos (by norm_num)
    positivity
  intro X hXbig M hM a b ha hab' hb hc
  have hlog2 : 0 < Real.log 2 := Real.log_pos (by norm_num)
  have hXB : XB ≤ X := le_trans (le_max_left _ _) hXbig
  have hXbnd : Real.exp (2 * Real.log 2 / c₁ + 2) ≤ X :=
    le_trans (le_max_right _ _) hXbig
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos _) hXbnd
  have hLge : 2 * Real.log 2 / c₁ + 2 ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hXbnd
  have hL2 : (2 : ℝ) ≤ Real.log X := by
    nlinarith [div_nonneg (by positivity : (0 : ℝ) ≤ 2 * Real.log 2) hc₁.le]
  have hLpos : 0 < Real.log X := lt_of_lt_of_le (by norm_num) hL2
  have hXgt1 : 1 < X := by
    have : Real.exp 0 < X := lt_of_lt_of_le
      (by
        simpa using Real.exp_lt_exp.mpr
          (by positivity : (0 : ℝ) < 2 * Real.log 2 / c₁ + 2))
      hXbnd
    simpa using this
  have hLogLog_pos : 0 < Real.log (Real.log X) :=
    Real.log_pos (lt_of_lt_of_le one_lt_two hL2)
  have hLz_eq : Real.log (EscAnalytic.zScale X) = 4 * Real.log (Real.log X) := by
    unfold EscAnalytic.zScale
    rw [Real.log_pow]
    push_cast
    ring
  have hLzpos : 0 < Real.log (EscAnalytic.zScale X) := by
    rw [hLz_eq]
    positivity
  set Lz := Real.log (EscAnalytic.zScale X) with hLzdef
  set L := Real.log X with hLdef
  have hba_ge : c₁ ≤ b - a := hc
  have hba_nonneg : 0 ≤ b - a := le_trans hc₁.le hba_ge
  set Nlo := ⌊(b - a) * L / Real.log 2⌋₊ with hNlodef
  set q := (b - a) * L / Real.log 2 with hqdef
  have hq_nonneg : 0 ≤ q := by
    rw [hqdef]
    exact div_nonneg (mul_nonneg hba_nonneg hLpos.le) hlog2.le
  have hfloor_le : (Nlo : ℝ) ≤ q := Nat.floor_le hq_nonneg
  have hlt_floor : q < (Nlo : ℝ) + 1 := Nat.lt_floor_add_one q
  have hpow2 : ∀ m : ℕ, (2 : ℝ) ^ m = Real.exp ((m : ℝ) * Real.log 2) := by
    intro m
    rw [Real.exp_nat_mul, Real.exp_log (by norm_num : (0 : ℝ) < 2)]
  have hXba : X ^ (b - a) = Real.exp ((b - a) * L) := by
    rw [Real.rpow_def_of_pos hXpos]
    congr 1
    rw [hLdef]
    ring
  have hXa_pos : 0 < X ^ a := Real.rpow_pos_of_pos hXpos a
  have hXb_split : X ^ b = X ^ a * X ^ (b - a) := by
    rw [← Real.rpow_add hXpos]
    congr 1
    ring
  have hreach_lo : dyAnchor X a Nlo ≤ X ^ b := by
    unfold dyAnchor
    rw [hXb_split]
    apply mul_le_mul_of_nonneg_left _ hXa_pos.le
    rw [hXba, hpow2 Nlo]
    apply Real.exp_le_exp.mpr
    have : (b - a) * L = q * Real.log 2 := by
      rw [hqdef]
      field_simp
    rw [this]
    exact mul_le_mul_of_nonneg_right hfloor_le hlog2.le
  have hanchor_lo : ∀ k : ℕ, X ^ a₀ ≤ dyAnchor X a k := by
    intro k
    have h1 : X ^ a₀ ≤ X ^ a :=
      Real.rpow_le_rpow_of_exponent_le hXgt1.le ha
    have h2 : X ^ a = dyAnchor X a 0 := by
      unfold dyAnchor
      simp
    exact le_trans h1 (h2 ▸ dyAnchor_mono hXpos (Nat.zero_le k))
  have hanchor_up_lo : ∀ k : ℕ, k < Nlo → dyAnchor X a k ≤ 2 * X ^ b₀ := by
    intro k hk
    have hmono : dyAnchor X a k ≤ dyAnchor X a Nlo :=
      dyAnchor_mono hXpos (by omega)
    have hXbb₀ : X ^ b ≤ X ^ b₀ :=
      Real.rpow_le_rpow_of_exponent_le hXgt1.le hb
    have hX0 : 0 ≤ X ^ b₀ := (Real.rpow_pos_of_pos hXpos b₀).le
    calc
      dyAnchor X a k ≤ dyAnchor X a Nlo := hmono
      _ ≤ X ^ b := hreach_lo
      _ ≤ X ^ b₀ := hXbb₀
      _ ≤ 2 * X ^ b₀ := by linarith
  have hstep := roughBlockRecipSum_le_roughRecip X M a b hXpos Nlo hreach_lo
  have hsum_ge :
      ∑ _k ∈ Finset.range Nlo, cB / Lz
        ≤ ∑ k ∈ Finset.range Nlo, roughBlockRecip X M (dyAnchor X a k) := by
    apply Finset.sum_le_sum
    intro k hk
    rw [Finset.mem_range] at hk
    have htlo : X ^ a₀ ≤ dyAnchor X a k := hanchor_lo k
    have hthi : dyAnchor X a k ≤ 2 * X ^ b₀ := hanchor_up_lo k hk
    have htk_pos : 0 < dyAnchor X a k := dyAnchor_pos hXpos k
    simpa [hLzdef] using hblock X hXB M hM (dyAnchor X a k) htlo hthi htk_pos
  rw [Finset.sum_const, Finset.card_range, nsmul_eq_mul] at hsum_ge
  have hNlo_bound : c₁ / (2 * Real.log 2) * L ≤ (Nlo : ℝ) := by
    have hq_ge : q - 1 ≤ (Nlo : ℝ) := by linarith [hlt_floor]
    have hq_lb : c₁ / Real.log 2 * L ≤ q := by
      rw [hqdef, div_mul_eq_mul_div, div_le_div_iff₀ hlog2 hlog2]
      apply mul_le_mul_of_nonneg_right _ hlog2.le
      exact mul_le_mul_of_nonneg_right hba_ge hLpos.le
    have hhalf : c₁ / (2 * Real.log 2) * L ≤ q - 1 := by
      have hLbig : 2 * Real.log 2 / c₁ ≤ L := by
        rw [hLdef]
        linarith [hLge]
      have hone : (1 : ℝ) ≤ c₁ / (2 * Real.log 2) * L := by
        rw [div_mul_eq_mul_div, le_div_iff₀ (by positivity)]
        have : 2 * Real.log 2 = c₁ * (2 * Real.log 2 / c₁) := by
          field_simp
        rw [one_mul, this]
        exact mul_le_mul_of_nonneg_left hLbig hc₁.le
      have hq2 : 2 * (c₁ / (2 * Real.log 2) * L) ≤ q := by
        have : 2 * (c₁ / (2 * Real.log 2) * L) = c₁ / Real.log 2 * L := by
          field_simp
          ring
        rw [this]
        exact hq_lb
      linarith
    linarith
  have hform : L / Lz = Real.log X / Real.log (EscAnalytic.zScale X) := by
    rw [hLdef, hLzdef]
  calc
    (cB * c₁ / (2 * Real.log 2)) *
        (Real.log X / Real.log (EscAnalytic.zScale X))
        = (c₁ / (2 * Real.log 2) * L) * (cB / Lz) := by
          rw [← hform]
          field_simp
          ring
    _ ≤ (Nlo : ℝ) * (cB / Lz) :=
        mul_le_mul_of_nonneg_right hNlo_bound (by positivity)
    _ ≤ ∑ k ∈ Finset.range Nlo, roughBlockRecip X M (dyAnchor X a k) := hsum_ge
    _ ≤ roughRecip X M a b := hstep


          else 0 := by
          calc
            ∑ u ∈ (roughModulus X).primeFactors.powerset,
                (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
                  roughBadPrimeSubsetProductSquarefreeCount X t u
                = ∑ u ∈ (roughModulus X).primeFactors.powerset,
                    ∑ n ∈ W,
                      if Squarefree n ∧ badPrimeSubsetModulus u ∣ n then
                        (((-1 : ℤ) ^ u.card : ℤ) : ℝ) else 0 := by
                  apply Finset.sum_congr rfl
                  intro u _hu
                  rw [hcount u, Finset.mul_sum]
                  apply Finset.sum_congr rfl
                  intro n _hn
                  by_cases hs : Squarefree n
                  · by_cases hdiv : badPrimeSubsetModulus u ∣ n
                    · simp [hs, hdiv]
                    · simp [hs, hdiv]
                  · simp [hs]
            _ = ∑ n ∈ W,
                  ∑ u ∈ (roughModulus X).primeFactors.powerset,
                    if Squarefree n ∧ badPrimeSubsetModulus u ∣ n then
                      (((-1 : ℤ) ^ u.card : ℤ) : ℝ) else 0 := by
                  rw [Finset.sum_comm]
            _ = ∑ n ∈ W,
                  if Squarefree n then
                    ∑ u ∈ (roughModulus X).primeFactors.powerset,
                      if badPrimeSubsetModulus u ∣ n then
                        (((-1 : ℤ) ^ u.card : ℤ) : ℝ) else 0
                  else 0 := by
                  apply Finset.sum_congr rfl
                  intro n _hn
                  by_cases hs : Squarefree n
                  · simp [hs]
                  · simp [hs]
    _ = ∑ n ∈ W,
          if Squarefree n ∧ Nat.Coprime n (roughModulus X) then
            (1 : ℝ) else 0 := by
          apply Finset.sum_congr rfl
          intro n _hn
          have hinner :
              (∑ u ∈ (roughModulus X).primeFactors.powerset,
                if badPrimeSubsetModulus u ∣ n then
                  (((-1 : ℤ) ^ u.card : ℤ) : ℝ) else 0)
                = if Nat.Coprime n (roughModulus X) then (1 : ℝ) else 0 := by
            have hbase :=
              roughDyadicBadPrimeProductMultiplesCountSum_eq_roughWindowCount X t
            clear hbase
            have hfilter :
                (roughModulus X).primeFactors.powerset.filter
                    (fun u : Finset ℕ => badPrimeSubsetModulus u ∣ n) =
                  (roughModulus X).primeFactors.powerset.filter
                    (fun u : Finset ℕ => ∀ p ∈ u, p ∣ n) := by
              ext u
              by_cases hu : u ∈ (roughModulus X).primeFactors.powerset
              · have hsubset : u ⊆ (roughModulus X).primeFactors :=
                  Finset.mem_powerset.mp hu
                have huprime : ∀ p ∈ u, Nat.Prime p := by
                  intro p hp
                  exact Nat.prime_of_mem_primeFactors (hsubset hp)
                simp [hu, (badPrimeSubsetModulus_dvd_iff huprime)]
              · simp [hu]
            calc
              ∑ u ∈ (roughModulus X).primeFactors.powerset,
                (if badPrimeSubsetModulus u ∣ n then
                  (((-1 : ℤ) ^ u.card : ℤ) : ℝ) else 0)
                  = ∑ u ∈
                      (roughModulus X).primeFactors.powerset.filter
                        (fun u : Finset ℕ => badPrimeSubsetModulus u ∣ n),
                      (((-1 : ℤ) ^ u.card : ℤ) : ℝ) := by
                    rw [Finset.sum_filter]
              _ = ∑ u ∈ (badPrimeFactors (roughModulus X) n).powerset,
                      (((-1 : ℤ) ^ u.card : ℤ) : ℝ) := by
                    rw [hfilter, ← badPrimeFactors_powerset_eq_filter]
              _ = if Nat.Coprime n (roughModulus X) then (1 : ℝ) else 0 := by
                    have h :=
                      congrArg (fun z : ℤ => (z : ℝ))
                        (roughModulus_badPrimeFactors_parity_sum X n)
                    simpa using h
          by_cases hs : Squarefree n
          · simpa [hs] using hinner
          · simp [hs]
    _ = (((W.filter
          (fun n : ℕ => Squarefree n ∧ Nat.Coprime n (roughModulus X))).card : ℕ) : ℝ) := by
          rw [Finset.card_eq_sum_ones, ← Finset.sum_filter]
          simp [and_assoc]

/-- The signed squarefree-loss carrier is the difference between rough counts
before and after imposing squarefreeness. -/
theorem roughDyadicBadPrimeProductSquarefreeSignedLossSum_eq_roughWindowCount_sub_squarefree
    (X : ℝ) (t : ℝ) :
    roughDyadicBadPrimeProductSquarefreeSignedLossSum X t =
      roughDyadicRoughWindowCount X t -
        roughDyadicRoughSquarefreeWindowCount X t := by
  unfold roughDyadicBadPrimeProductSquarefreeSignedLossSum
    roughBadPrimeSubsetProductSquarefreeLoss
  calc
    ∑ u ∈ (roughModulus X).primeFactors.powerset,
        (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
          (roughBadPrimeSubsetProductMultiplesCount X t u -
            roughBadPrimeSubsetProductSquarefreeCount X t u)
        = (∑ u ∈ (roughModulus X).primeFactors.powerset,
            (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
              roughBadPrimeSubsetProductMultiplesCount X t u) -
          ∑ u ∈ (roughModulus X).primeFactors.powerset,
            (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
              roughBadPrimeSubsetProductSquarefreeCount X t u := by
          rw [← Finset.sum_sub_distrib]
          apply Finset.sum_congr rfl
          intro u _hu
          ring
    _ = roughDyadicRoughWindowCount X t -
          roughDyadicRoughSquarefreeWindowCount X t := by
          change roughDyadicBadPrimeProductMultiplesCountSum X t -
              roughDyadicBadPrimeProductSquarefreeCountSum X t =
            roughDyadicRoughWindowCount X t -
              roughDyadicRoughSquarefreeWindowCount X t
          rw [roughDyadicBadPrimeProductMultiplesCountSum_eq_roughWindowCount,
            roughDyadicBadPrimeProductSquarefreeCountSum_eq_roughSquarefreeWindowCount]

/-- The signed squarefree-loss carrier is exactly the count of rough dyadic
integers that fail squarefreeness. -/
theorem roughDyadicBadPrimeProductSquarefreeSignedLossSum_eq_roughNonSquarefreeCount
    (X : ℝ) (t : ℝ) :
    roughDyadicBadPrimeProductSquarefreeSignedLossSum X t =
      roughDyadicRoughNonSquarefreeWindowCount X t := by
  rw [roughDyadicBadPrimeProductSquarefreeSignedLossSum_eq_roughWindowCount_sub_squarefree]
  unfold roughDyadicRoughWindowCount roughDyadicRoughSquarefreeWindowCount
    roughDyadicRoughNonSquarefreeWindowCount
  let W : Finset ℕ := natWindow t (2 * t)
  let R : Finset ℕ := W.filter (fun n : ℕ => Nat.Coprime n (roughModulus X))
  let S : Finset ℕ := R.filter (fun n : ℕ => Squarefree n)
  let NS : Finset ℕ := R.filter (fun n : ℕ => ¬ Squarefree n)
  have hNS_card : NS.card = R.card - S.card := by
    have hNS_eq : NS = R \ S := by
      ext n
      by_cases hnR : n ∈ R
      · by_cases hs : Squarefree n <;> simp [S, NS, hnR, hs]
      · simp [S, NS, hnR]
    have hS_subset : S ⊆ R := by
      intro n hn
      exact (Finset.mem_filter.mp hn).1
    rw [hNS_eq, Finset.card_sdiff hS_subset]
  have hS :
      ((W.filter
        (fun n : ℕ => Squarefree n ∧ Nat.Coprime n (roughModulus X))).card) =
        S.card := by
    apply congrArg Finset.card
    ext n
    simp [R, S, and_assoc, and_left_comm, and_comm]
  have hNS :
      ((W.filter
        (fun n : ℕ => Nat.Coprime n (roughModulus X) ∧ ¬ Squarefree n)).card) =
        NS.card := by
    apply congrArg Finset.card
    ext n
    simp [R, NS, and_assoc, and_left_comm, and_comm]
  have hR :
      ((W.filter (fun n : ℕ => Nat.Coprime n (roughModulus X))).card) =
        R.card := rfl
  have hS_le_R : S.card ≤ R.card :=
    Finset.card_le_card (by
      intro n hn
      exact (Finset.mem_filter.mp hn).1)
  have hreal :
      (R.card : ℝ) - (S.card : ℝ) = (NS.card : ℝ) := by
    have hnat : R.card - S.card = NS.card := by
      exact hNS_card.symm
    rw [← hnat]
    exact (Nat.cast_sub hS_le_R).symm
  simpa [W, R, S, NS, hR, hS, hNS] using hreal

/-- A nonsquarefree natural number has a squared prime divisor. -/
theorem exists_prime_square_dvd_of_not_squarefree {n : ℕ}
    (hn : ¬ Squarefree n) :
    ∃ p : ℕ, Nat.Prime p ∧ p ^ 2 ∣ n := by
  by_cases hnzero : n = 0
  · refine ⟨2, Nat.prime_two, ?_⟩
    rw [hnzero]
    exact dvd_zero _
  · by_contra hnone
    apply hn
    rw [Nat.squarefree_iff_prime_squarefree]
    intro p hp hpdvd
    apply hnone
    exact ⟨p, hp, by simpa [pow_two] using hpdvd⟩

/-- If a rough integer is not squarefree, then it has a square prime divisor
outside the rough-modulus prime-factor set. -/
theorem exists_prime_square_not_rough_of_coprime_not_squarefree
    {X : ℝ} {n : ℕ}
    (hcop : Nat.Coprime n (roughModulus X)) (hnsq : ¬ Squarefree n) :
    ∃ p : ℕ, Nat.Prime p ∧ p ∉ (roughModulus X).primeFactors ∧ p ^ 2 ∣ n := by
  rcases exists_prime_square_dvd_of_not_squarefree hnsq with
    ⟨p, hp, hp2dvd⟩
  refine ⟨p, hp, ?_, hp2dvd⟩
  intro hprough
  have hp_dvd_rough : p ∣ roughModulus X := Nat.dvd_of_mem_primeFactors hprough
  have hp_dvd_n : p ∣ n := by
    exact dvd_trans (dvd_mul_right p p) (by simpa [pow_two] using hp2dvd)
  have hp_dvd_gcd : p ∣ Nat.gcd n (roughModulus X) :=
    Nat.dvd_gcd hp_dvd_n hp_dvd_rough
  rw [hcop.gcd_eq_one] at hp_dvd_gcd
  exact hp.not_dvd_one hp_dvd_gcd

/-- The rough nonsquarefree carrier is contained in the concrete large-square
divisor carrier. -/
theorem roughDyadicRoughNonSquarefreeWindowCount_le_largeSquareDivisorCount
    (X : ℝ) (t : ℝ) :
    roughDyadicRoughNonSquarefreeWindowCount X t ≤
      roughDyadicLargeSquareDivisorCount X t := by
  classical
  unfold roughDyadicRoughNonSquarefreeWindowCount
    roughDyadicLargeSquareDivisorCount
  have hcard :
      ((natWindow t (2 * t)).filter
        (fun n : ℕ => Nat.Coprime n (roughModulus X) ∧ ¬ Squarefree n)).card ≤
      ((natWindow t (2 * t)).filter
        (fun n : ℕ =>
          ∃ p : ℕ, Nat.Prime p ∧ p ∉ (roughModulus X).primeFactors ∧ p ^ 2 ∣ n)).card := by
    apply Finset.card_le_card
    intro n hn
    rw [Finset.mem_filter] at hn
    rw [Finset.mem_filter]
    exact ⟨hn.1,
      exists_prime_square_not_rough_of_coprime_not_squarefree hn.2.1 hn.2.2⟩
  exact_mod_cast hcard

/-- The signed squarefree-loss carrier is bounded by the large-square divisor
tail. -/
theorem roughDyadicBadPrimeProductSquarefreeSignedLossSum_le_largeSquareDivisorCount
    (X : ℝ) (t : ℝ) :
    roughDyadicBadPrimeProductSquarefreeSignedLossSum X t ≤
      roughDyadicLargeSquareDivisorCount X t := by
  rw [roughDyadicBadPrimeProductSquarefreeSignedLossSum_eq_roughNonSquarefreeCount]
  exact roughDyadicRoughNonSquarefreeWindowCount_le_largeSquareDivisorCount X t

/-- The signed squarefree-loss carrier is nonnegative: it counts rough dyadic
integers lost when squarefreeness is imposed. -/
theorem roughDyadicBadPrimeProductSquarefreeSignedLossSum_nonneg
    (X : ℝ) (t : ℝ) :
    0 ≤ roughDyadicBadPrimeProductSquarefreeSignedLossSum X t := by
  rw [roughDyadicBadPrimeProductSquarefreeSignedLossSum_eq_roughWindowCount_sub_squarefree]
  unfold roughDyadicRoughWindowCount roughDyadicRoughSquarefreeWindowCount
  have hsub :
      ((natWindow t (2 * t)).filter
        (fun n : ℕ => Squarefree n ∧ Nat.Coprime n (roughModulus X))).card ≤
      ((natWindow t (2 * t)).filter
        (fun n : ℕ => Nat.Coprime n (roughModulus X))).card := by
    apply Finset.card_le_card
    intro n hn
    rw [Finset.mem_filter] at hn
    rw [Finset.mem_filter]
    exact ⟨hn.1, hn.2.2⟩
  exact sub_nonneg.mpr (by exact_mod_cast hsub)

/-- The summed squarefree-loss envelope inherits the empty-subset obstruction:
it is at least the count of multiples of `4` in the dyadic window. -/
theorem natWindow_four_multiples_card_le_squarefreeLossEnvelopeSum
    (X : ℝ) (t : ℝ) :
    (((natWindow t (2 * t)).filter (fun n : ℕ => 4 ∣ n)).card : ℝ) ≤
      roughDyadicBadPrimeProductSquarefreeLossEnvelopeSum X t := by
  classical
  unfold roughDyadicBadPrimeProductSquarefreeLossEnvelopeSum
  have hempty :
      (∅ : Finset ℕ) ∈ (roughModulus X).primeFactors.powerset := by
    simp
  have hnonneg :
      ∀ u ∈ (roughModulus X).primeFactors.powerset,
        0 ≤ roughBadPrimeSubsetProductSquarefreeLoss X t u := by
    intro u _hu
    exact roughBadPrimeSubsetProductSquarefreeLoss_nonneg X t u
  exact
    (natWindow_four_multiples_card_le_empty_squarefreeLoss X t).trans
      (Finset.single_le_sum hnonneg hempty)

/-- Sum of auxiliary-coprimality losses over all subset terms. -/
noncomputable def roughDyadicBadPrimeProductAuxiliaryLossEnvelopeSum
    (X : ℝ) (M : ℕ) (t : ℝ) : ℝ :=
  ∑ u ∈ (roughModulus X).primeFactors.powerset,
    roughBadPrimeSubsetProductAuxiliaryLoss X M t u

/-- With no auxiliary modulus, the summed auxiliary-loss envelope is zero. -/
theorem roughDyadicBadPrimeProductAuxiliaryLossEnvelopeSum_one
    (X : ℝ) (t : ℝ) :
    roughDyadicBadPrimeProductAuxiliaryLossEnvelopeSum X 1 t = 0 := by
  classical
  unfold roughDyadicBadPrimeProductAuxiliaryLossEnvelopeSum
  simp [roughBadPrimeSubsetProductAuxiliaryLoss_one]

/-- Summed form of the auxiliary-coprimality union bound across all rough
inclusion-exclusion subset terms. -/
theorem roughDyadicBadPrimeProductAuxiliaryLossEnvelopeSum_le_powerset_card_mul_auxiliaryModulusPrimeMultiplesLoss
    (X : ℝ) (M : ℕ) (t : ℝ) :
    roughDyadicBadPrimeProductAuxiliaryLossEnvelopeSum X M t ≤
      (((roughModulus X).primeFactors.powerset.card : ℕ) : ℝ) *
        auxiliaryModulusPrimeMultiplesLoss X M t := by
  classical
  unfold roughDyadicBadPrimeProductAuxiliaryLossEnvelopeSum
  have hterm :
      ∀ u ∈ (roughModulus X).primeFactors.powerset,
        roughBadPrimeSubsetProductAuxiliaryLoss X M t u ≤
          auxiliaryModulusPrimeMultiplesLoss X M t := by
    intro u _hu
    exact roughBadPrimeSubsetProductAuxiliaryLoss_le_auxiliaryModulusPrimeMultiplesLoss
      X M t u
  have hsum :=
    Finset.sum_le_card_nsmul
      ((roughModulus X).primeFactors.powerset)
      (fun u : Finset ℕ => roughBadPrimeSubsetProductAuxiliaryLoss X M t u)
      (auxiliaryModulusPrimeMultiplesLoss X M t) hterm
  simpa [nsmul_eq_mul] using hsum

/-- The filter-loss envelope splits exactly into squarefree and auxiliary
coprimality loss envelopes. -/
theorem roughDyadicBadPrimeProductFilterLossEnvelopeSum_eq_squarefreeLoss_add_auxiliaryLoss
    (X : ℝ) (M : ℕ) (t : ℝ) :
    roughDyadicBadPrimeProductFilterLossEnvelopeSum X M t =
      roughDyadicBadPrimeProductSquarefreeLossEnvelopeSum X t +
        roughDyadicBadPrimeProductAuxiliaryLossEnvelopeSum X M t := by
  classical
  unfold roughDyadicBadPrimeProductFilterLossEnvelopeSum
    roughDyadicBadPrimeProductSquarefreeLossEnvelopeSum
    roughDyadicBadPrimeProductAuxiliaryLossEnvelopeSum
  calc
    ∑ u ∈ (roughModulus X).primeFactors.powerset,
        roughBadPrimeSubsetProductFilterLoss X M t u
        = ∑ u ∈ (roughModulus X).primeFactors.powerset,
            (roughBadPrimeSubsetProductSquarefreeLoss X t u +
              roughBadPrimeSubsetProductAuxiliaryLoss X M t u) := by
          apply Finset.sum_congr rfl
          intro u _hu
          rw [roughBadPrimeSubsetProductFilterLoss_eq_squarefreeLoss_add_auxiliaryLoss]
    _ = (∑ u ∈ (roughModulus X).primeFactors.powerset,
            roughBadPrimeSubsetProductSquarefreeLoss X t u) +
          ∑ u ∈ (roughModulus X).primeFactors.powerset,
            roughBadPrimeSubsetProductAuxiliaryLoss X M t u := by
          rw [Finset.sum_add_distrib]

/-- With no auxiliary modulus, the filter-loss envelope is exactly the
squarefree-loss envelope. -/
theorem roughDyadicBadPrimeProductFilterLossEnvelopeSum_one_eq_squarefreeLoss
    (X : ℝ) (t : ℝ) :
    roughDyadicBadPrimeProductFilterLossEnvelopeSum X 1 t =
      roughDyadicBadPrimeProductSquarefreeLossEnvelopeSum X t := by
  rw [roughDyadicBadPrimeProductFilterLossEnvelopeSum_eq_squarefreeLoss_add_auxiliaryLoss,
    roughDyadicBadPrimeProductAuxiliaryLossEnvelopeSum_one]
  ring

/-- The absolute local-error envelope is bounded by the sum of the
multiples-only lattice discrepancy envelope and the arithmetic filter-loss
envelope. -/
theorem roughDyadicBadPrimeProductLocalErrorEnvelopeSum_le_multiplesError_add_filterLoss
    (X : ℝ) (M : ℕ) (t : ℝ) :
    roughDyadicBadPrimeProductLocalErrorEnvelopeSum X M t ≤
      roughDyadicBadPrimeProductMultiplesLocalErrorEnvelopeSum X t +
        roughDyadicBadPrimeProductFilterLossEnvelopeSum X M t := by
  classical
  unfold roughDyadicBadPrimeProductLocalErrorEnvelopeSum
    roughDyadicBadPrimeProductMultiplesLocalErrorEnvelopeSum
    roughDyadicBadPrimeProductFilterLossEnvelopeSum
  calc
    ∑ u ∈ (roughModulus X).primeFactors.powerset,
        |roughBadPrimeSubsetProductLocalError X M t u|
        ≤ ∑ u ∈ (roughModulus X).primeFactors.powerset,
            (|roughBadPrimeSubsetProductMultiplesLocalError X t u| +
              roughBadPrimeSubsetProductFilterLoss X M t u) := by
          apply Finset.sum_le_sum
          intro u _hu
          exact
            abs_roughBadPrimeSubsetProductLocalError_le_multiplesLocalError_add_filterLoss
              X M t u
    _ = (∑ u ∈ (roughModulus X).primeFactors.powerset,
            |roughBadPrimeSubsetProductMultiplesLocalError X t u|) +
          ∑ u ∈ (roughModulus X).primeFactors.powerset,
            roughBadPrimeSubsetProductFilterLoss X M t u := by
          rw [Finset.sum_add_distrib]

/-- In the modulus-one lane, the local-error envelope is controlled by only
the multiples discrepancy and the squarefree loss. -/
theorem roughDyadicBadPrimeProductLocalErrorEnvelopeSum_one_le_multiplesError_add_squarefreeLoss
    (X : ℝ) (t : ℝ) :
    roughDyadicBadPrimeProductLocalErrorEnvelopeSum X 1 t ≤
      roughDyadicBadPrimeProductMultiplesLocalErrorEnvelopeSum X t +
        roughDyadicBadPrimeProductSquarefreeLossEnvelopeSum X t := by
  calc
    roughDyadicBadPrimeProductLocalErrorEnvelopeSum X 1 t
        ≤ roughDyadicBadPrimeProductMultiplesLocalErrorEnvelopeSum X t +
            roughDyadicBadPrimeProductFilterLossEnvelopeSum X 1 t :=
          roughDyadicBadPrimeProductLocalErrorEnvelopeSum_le_multiplesError_add_filterLoss
            X 1 t
    _ = roughDyadicBadPrimeProductMultiplesLocalErrorEnvelopeSum X t +
          roughDyadicBadPrimeProductSquarefreeLossEnvelopeSum X t := by
          rw [roughDyadicBadPrimeProductFilterLossEnvelopeSum_one_eq_squarefreeLoss]

/-- Exact decomposition of the product-count inclusion-exclusion carrier into
its signed main term and finite error carrier. -/
theorem roughDyadicBadPrimeProductCountSum_eq_mainTerm_add_error
    (X : ℝ) (M : ℕ) (t : ℝ) :
    roughDyadicBadPrimeSubsetProductCountSum X M t =
      roughDyadicBadPrimeProductMainTermSum X t +
        roughDyadicBadPrimeProductErrorSum X M t := by
  unfold roughDyadicBadPrimeProductErrorSum
  ring

/-- The global product-error carrier is the signed sum of the subset-local
errors. -/
theorem roughDyadicBadPrimeProductErrorSum_eq_signed_localError_sum
    (X : ℝ) (M : ℕ) (t : ℝ) :
    roughDyadicBadPrimeProductErrorSum X M t =
      ∑ u ∈ (roughModulus X).primeFactors.powerset,
        (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
          roughBadPrimeSubsetProductLocalError X M t u := by
  unfold roughDyadicBadPrimeProductErrorSum
    roughDyadicBadPrimeSubsetProductCountSum
    roughDyadicBadPrimeProductMainTermSum
    roughBadPrimeSubsetProductLocalError
  rw [← Finset.sum_sub_distrib]
  apply Finset.sum_congr rfl
  intro u _hu
  ring

/-- In the modulus-one lane, the signed product error splits into signed
multiples discrepancy minus signed squarefree loss.  This is the cancellation
aware form needed to avoid the known empty-subset obstruction in the absolute
squarefree-loss envelope. -/
theorem roughDyadicBadPrimeProductErrorSum_one_eq_signedMultiples_sub_signedSquarefree
    (X : ℝ) (t : ℝ) :
    roughDyadicBadPrimeProductErrorSum X 1 t =
      roughDyadicBadPrimeProductMultiplesSignedErrorSum X t -
        roughDyadicBadPrimeProductSquarefreeSignedLossSum X t := by
  classical
  rw [roughDyadicBadPrimeProductErrorSum_eq_signed_localError_sum]
  unfold roughDyadicBadPrimeProductMultiplesSignedErrorSum
    roughDyadicBadPrimeProductSquarefreeSignedLossSum
  rw [← Finset.sum_sub_distrib]
  apply Finset.sum_congr rfl
  intro u _hu
  rw [roughBadPrimeSubsetProductLocalError_eq_multiplesLocalError_sub_filterLoss,
    roughBadPrimeSubsetProductFilterLoss_one_eq_squarefreeLoss]
  ring

/-- The absolute global product error is bounded by the sum of absolute
subset-local errors. -/
theorem abs_roughDyadicBadPrimeProductErrorSum_le_localErrorEnvelope
    (X : ℝ) (M : ℕ) (t : ℝ) :
    |roughDyadicBadPrimeProductErrorSum X M t| ≤
      roughDyadicBadPrimeProductLocalErrorEnvelopeSum X M t := by
  classical
  rw [roughDyadicBadPrimeProductErrorSum_eq_signed_localError_sum]
  calc
    |∑ u ∈ (roughModulus X).primeFactors.powerset,
        (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
          roughBadPrimeSubsetProductLocalError X M t u|
        ≤ ∑ u ∈ (roughModulus X).primeFactors.powerset,
          |(((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
            roughBadPrimeSubsetProductLocalError X M t u| :=
          Finset.abs_sum_le_sum_abs _ _
    _ = roughDyadicBadPrimeProductLocalErrorEnvelopeSum X M t := by
          unfold roughDyadicBadPrimeProductLocalErrorEnvelopeSum
          apply Finset.sum_congr rfl
          intro u _hu
          rw [abs_mul]
          have hsign :
              |(((-1 : ℤ) ^ u.card : ℤ) : ℝ)| = (1 : ℝ) := by
            simp
          rw [hsign, one_mul]

/-- The signed multiples-discrepancy carrier is bounded by its absolute
local-error envelope.  This is purely finite triangle inequality plus the fact
that every inclusion-exclusion sign has absolute value `1`. -/
theorem abs_roughDyadicBadPrimeProductMultiplesSignedErrorSum_le_envelope
    (X : ℝ) (t : ℝ) :
    |roughDyadicBadPrimeProductMultiplesSignedErrorSum X t| ≤
      roughDyadicBadPrimeProductMultiplesLocalErrorEnvelopeSum X t := by
  classical
  unfold roughDyadicBadPrimeProductMultiplesSignedErrorSum
  calc
    |∑ u ∈ (roughModulus X).primeFactors.powerset,
        (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
          roughBadPrimeSubsetProductMultiplesLocalError X t u|
        ≤ ∑ u ∈ (roughModulus X).primeFactors.powerset,
          |(((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
            roughBadPrimeSubsetProductMultiplesLocalError X t u| :=
          Finset.abs_sum_le_sum_abs _ _
    _ = roughDyadicBadPrimeProductMultiplesLocalErrorEnvelopeSum X t := by
          unfold roughDyadicBadPrimeProductMultiplesLocalErrorEnvelopeSum
          apply Finset.sum_congr rfl
          intro u _hu
          rw [abs_mul]
          have hsign :
              |(((-1 : ℤ) ^ u.card : ℤ) : ℝ)| = (1 : ℝ) := by
            simp
          rw [hsign, one_mul]

/-- The signed squarefree-loss carrier is bounded by the absolute squarefree
loss envelope.  This finite implication is valid but often too wasteful for
the lower route; it is still useful for explicit comparison with the older
absolute-envelope reductions. -/
theorem abs_roughDyadicBadPrimeProductSquarefreeSignedLossSum_le_envelope
    (X : ℝ) (t : ℝ) :
    |roughDyadicBadPrimeProductSquarefreeSignedLossSum X t| ≤
      roughDyadicBadPrimeProductSquarefreeLossEnvelopeSum X t := by
  classical
  unfold roughDyadicBadPrimeProductSquarefreeSignedLossSum
  calc
    |∑ u ∈ (roughModulus X).primeFactors.powerset,
        (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
          roughBadPrimeSubsetProductSquarefreeLoss X t u|
        ≤ ∑ u ∈ (roughModulus X).primeFactors.powerset,
          |(((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
            roughBadPrimeSubsetProductSquarefreeLoss X t u| :=
          Finset.abs_sum_le_sum_abs _ _
    _ = roughDyadicBadPrimeProductSquarefreeLossEnvelopeSum X t := by
          unfold roughDyadicBadPrimeProductSquarefreeLossEnvelopeSum
          apply Finset.sum_congr rfl
          intro u _hu
          rw [abs_mul]
          have hsign :
              |(((-1 : ℤ) ^ u.card : ℤ) : ℝ)| = (1 : ℝ) := by
            simp
          rw [hsign, one_mul]
          exact abs_of_nonneg
            (roughBadPrimeSubsetProductSquarefreeLoss_nonneg X t u)

/-- Crude pointwise envelope for one subset-local error: discard cancellation
and bound the filtered count by the explicit floor quotient. -/
theorem abs_roughBadPrimeSubsetProductLocalError_le_floor_div_add_main
    (X : ℝ) (M : ℕ) {t : ℝ} (ht : 0 ≤ t) {u : Finset ℕ}
    (hu : u ∈ (roughModulus X).primeFactors.powerset) :
    |roughBadPrimeSubsetProductLocalError X M t u| ≤
      ((⌊2 * t⌋₊ / badPrimeSubsetModulus u : ℕ) : ℝ) +
        t / (badPrimeSubsetModulus u : ℝ) := by
  have hcount_nonneg :
      0 ≤ roughBadPrimeSubsetProductCount X M t u := by
    unfold roughBadPrimeSubsetProductCount
    exact Nat.cast_nonneg _
  have hq_pos : 0 < badPrimeSubsetModulus u :=
    badPrimeSubsetModulus_pos_of_mem_rough_powerset X hu
  have hmain_nonneg :
      0 ≤ t / (badPrimeSubsetModulus u : ℝ) :=
    div_nonneg ht (by exact_mod_cast hq_pos.le)
  unfold roughBadPrimeSubsetProductLocalError
  calc
    |roughBadPrimeSubsetProductCount X M t u -
        t / (badPrimeSubsetModulus u : ℝ)|
        = |roughBadPrimeSubsetProductCount X M t u +
            -(t / (badPrimeSubsetModulus u : ℝ))| := by
          rw [sub_eq_add_neg]
    _ ≤ |roughBadPrimeSubsetProductCount X M t u| +
            |-(t / (badPrimeSubsetModulus u : ℝ))| :=
          abs_add _ _
    _ = |roughBadPrimeSubsetProductCount X M t u| +
            |t / (badPrimeSubsetModulus u : ℝ)| := by
          rw [abs_neg]
    _ ≤ |roughBadPrimeSubsetProductCount X M t u| +
            |t / (badPrimeSubsetModulus u : ℝ)| := by
          rfl
    _ = roughBadPrimeSubsetProductCount X M t u +
          t / (badPrimeSubsetModulus u : ℝ) := by
          rw [abs_of_nonneg hcount_nonneg, abs_of_nonneg hmain_nonneg]
    _ ≤ ((⌊2 * t⌋₊ / badPrimeSubsetModulus u : ℕ) : ℝ) +
          t / (badPrimeSubsetModulus u : ℝ) :=
          add_le_add_right
            (roughBadPrimeSubsetProductCount_le_floor_div X M t hu) _

/-- Crude absolute local-error envelope obtained by summing the pointwise
floor-quotient plus main-term bounds. -/
noncomputable def roughDyadicBadPrimeProductLocalErrorCrudeEnvelopeSum
    (X : ℝ) (t : ℝ) : ℝ :=
  ∑ u ∈ (roughModulus X).primeFactors.powerset,
    (((⌊2 * t⌋₊ / badPrimeSubsetModulus u : ℕ) : ℝ) +
      t / (badPrimeSubsetModulus u : ℝ))

/-- The exact local-error envelope is bounded by the crude quotient-plus-main
envelope.  This is intentionally a diagnostic bound; it exposes why more
cancellation or a sharper lattice-counting input is needed for the final
`t/log z` saving. -/
theorem roughDyadicBadPrimeProductLocalErrorEnvelopeSum_le_crudeEnvelope
    (X : ℝ) (M : ℕ) {t : ℝ} (ht : 0 ≤ t) :
    roughDyadicBadPrimeProductLocalErrorEnvelopeSum X M t ≤
      roughDyadicBadPrimeProductLocalErrorCrudeEnvelopeSum X t := by
  classical
  unfold roughDyadicBadPrimeProductLocalErrorEnvelopeSum
    roughDyadicBadPrimeProductLocalErrorCrudeEnvelopeSum
  apply Finset.sum_le_sum
  intro u hu
  exact abs_roughBadPrimeSubsetProductLocalError_le_floor_div_add_main
    X M ht hu

/-- Crude pointwise envelope for the multiples-only lattice discrepancy.  This
does not use the squarefree or auxiliary-coprimality filters; it isolates the
endpoint/floor contribution of one product-modulus term. -/
theorem abs_roughBadPrimeSubsetProductMultiplesLocalError_le_floor_div_add_main
    (X : ℝ) {t : ℝ} (ht : 0 ≤ t) {u : Finset ℕ}
    (hu : u ∈ (roughModulus X).primeFactors.powerset) :
    |roughBadPrimeSubsetProductMultiplesLocalError X t u| ≤
      ((⌊2 * t⌋₊ / badPrimeSubsetModulus u : ℕ) : ℝ) +
        t / (badPrimeSubsetModulus u : ℝ) := by
  have hcount_nonneg :
      0 ≤ roughBadPrimeSubsetProductMultiplesCount X t u := by
    unfold roughBadPrimeSubsetProductMultiplesCount
    exact Nat.cast_nonneg _
  have hq_pos : 0 < badPrimeSubsetModulus u :=
    badPrimeSubsetModulus_pos_of_mem_rough_powerset X hu
  have hmain_nonneg :
      0 ≤ t / (badPrimeSubsetModulus u : ℝ) :=
    div_nonneg ht (by exact_mod_cast hq_pos.le)
  unfold roughBadPrimeSubsetProductMultiplesLocalError
  calc
    |roughBadPrimeSubsetProductMultiplesCount X t u -
        t / (badPrimeSubsetModulus u : ℝ)|
        = |roughBadPrimeSubsetProductMultiplesCount X t u +
            -(t / (badPrimeSubsetModulus u : ℝ))| := by
          rw [sub_eq_add_neg]
    _ ≤ |roughBadPrimeSubsetProductMultiplesCount X t u| +
            |-(t / (badPrimeSubsetModulus u : ℝ))| :=
          abs_add _ _
    _ = |roughBadPrimeSubsetProductMultiplesCount X t u| +
            |t / (badPrimeSubsetModulus u : ℝ)| := by
          rw [abs_neg]
    _ = roughBadPrimeSubsetProductMultiplesCount X t u +
          t / (badPrimeSubsetModulus u : ℝ) := by
          rw [abs_of_nonneg hcount_nonneg, abs_of_nonneg hmain_nonneg]
    _ ≤ ((⌊2 * t⌋₊ / badPrimeSubsetModulus u : ℕ) : ℝ) +
          t / (badPrimeSubsetModulus u : ℝ) :=
          add_le_add_right
            (roughBadPrimeSubsetProductMultiplesCount_le_floor_div X t hq_pos) _

/-- The multiples-only lattice-discrepancy envelope is bounded by the same
crude quotient-plus-main envelope as the full local-error envelope. -/
theorem roughDyadicBadPrimeProductMultiplesLocalErrorEnvelopeSum_le_crudeEnvelope
    (X : ℝ) {t : ℝ} (ht : 0 ≤ t) :
    roughDyadicBadPrimeProductMultiplesLocalErrorEnvelopeSum X t ≤
      roughDyadicBadPrimeProductLocalErrorCrudeEnvelopeSum X t := by
  classical
  unfold roughDyadicBadPrimeProductMultiplesLocalErrorEnvelopeSum
    roughDyadicBadPrimeProductLocalErrorCrudeEnvelopeSum
  apply Finset.sum_le_sum
  intro u hu
  exact abs_roughBadPrimeSubsetProductMultiplesLocalError_le_floor_div_add_main
    X ht hu

/-- One subset's arithmetic filter loss is bounded by its multiples-only
carrier. -/
theorem roughBadPrimeSubsetProductFilterLoss_le_multiplesCount
    (X : ℝ) (M : ℕ) (t : ℝ) (u : Finset ℕ) :
    roughBadPrimeSubsetProductFilterLoss X M t u ≤
      roughBadPrimeSubsetProductMultiplesCount X t u := by
  have hcount_nonneg :
      0 ≤ roughBadPrimeSubsetProductCount X M t u := by
    unfold roughBadPrimeSubsetProductCount
    exact Nat.cast_nonneg _
  unfold roughBadPrimeSubsetProductFilterLoss
  linarith

/-- Crude pointwise quotient envelope for one subset's arithmetic filter loss. -/
theorem roughBadPrimeSubsetProductFilterLoss_le_floor_div
    (X : ℝ) (M : ℕ) (t : ℝ) {u : Finset ℕ}
    (hu : u ∈ (roughModulus X).primeFactors.powerset) :
    roughBadPrimeSubsetProductFilterLoss X M t u ≤
      ((⌊2 * t⌋₊ / badPrimeSubsetModulus u : ℕ) : ℝ) := by
  exact (roughBadPrimeSubsetProductFilterLoss_le_multiplesCount X M t u).trans
    (roughBadPrimeSubsetProductMultiplesCount_le_floor_div X t
      (badPrimeSubsetModulus_pos_of_mem_rough_powerset X hu))

/-- Absolute-value quotient envelope for the product-modulus expansion.  This
is the finite Euler-product object left after all squarefree/coprimality
filters and alternating signs have been discarded. -/
noncomputable def roughDyadicBadPrimeProductEnvelopeSum
    (X : ℝ) (t : ℝ) : ℝ :=
  ∑ u ∈ (roughModulus X).primeFactors.powerset,
    ((⌊2 * t⌋₊ / badPrimeSubsetModulus u : ℕ) : ℝ)

/-- The arithmetic filter-loss envelope is bounded by the quotient envelope
obtained by discarding the filters termwise. -/
theorem roughDyadicBadPrimeProductFilterLossEnvelopeSum_le_productEnvelope
    (X : ℝ) (M : ℕ) (t : ℝ) :
    roughDyadicBadPrimeProductFilterLossEnvelopeSum X M t ≤
      roughDyadicBadPrimeProductEnvelopeSum X t := by
  classical
  unfold roughDyadicBadPrimeProductFilterLossEnvelopeSum
    roughDyadicBadPrimeProductEnvelopeSum
  apply Finset.sum_le_sum
  intro u hu
  exact roughBadPrimeSubsetProductFilterLoss_le_floor_div X M t hu

/-- The quotient envelope contains the empty-subset term.  Consequently this
absolute-value envelope is at least the ambient dyadic-window scale and cannot
itself be the source of the rough-sieve `1 / log z` saving. -/
theorem roughDyadicBadPrimeProductEnvelopeSum_ge_floor_two_mul
    (X : ℝ) (t : ℝ) :
    ((⌊2 * t⌋₊ : ℕ) : ℝ) ≤ roughDyadicBadPrimeProductEnvelopeSum X t := by
  classical
  unfold roughDyadicBadPrimeProductEnvelopeSum
  have hempty :
      (∅ : Finset ℕ) ∈ (roughModulus X).primeFactors.powerset := by
    simp
  have hnonneg :
      ∀ u ∈ (roughModulus X).primeFactors.powerset,
        0 ≤ ((⌊2 * t⌋₊ / badPrimeSubsetModulus u : ℕ) : ℝ) := by
    intro u _hu
    exact Nat.cast_nonneg _
  have hsingle :=
    Finset.single_le_sum hnonneg hempty
  simpa [badPrimeSubsetModulus] using hsingle

/-- The normalizing logarithm `log z(X)` tends to infinity. -/
theorem tendsto_log_zScale_atTop :
    Filter.Tendsto (fun X : ℝ => Real.log (EscAnalytic.zScale X))
      Filter.atTop Filter.atTop := by
  have hloglog :
      Filter.Tendsto (fun X : ℝ => Real.log (Real.log X))
        Filter.atTop Filter.atTop := by
    exact Real.tendsto_log_atTop.comp Real.tendsto_log_atTop
  have hmul :
      Filter.Tendsto (fun X : ℝ => (4 : ℝ) * Real.log (Real.log X))
        Filter.atTop Filter.atTop :=
    Filter.Tendsto.const_mul_atTop (by norm_num : (0 : ℝ) < 4) hloglog
  refine hmul.congr' ?_
  filter_upwards [Filter.eventually_gt_atTop (0 : ℝ)] with X _hX
  unfold EscAnalytic.zScale
  rw [Real.log_pow]
  ring

/-- Once `t ≥ 1`, the empty-subset quotient term `⌊2t⌋` is at least `t`. -/
theorem self_le_floor_two_mul {t : ℝ} (ht : 1 ≤ t) :
    t ≤ (⌊2 * t⌋₊ : ℝ) := by
  have hfloor_gt : 2 * t - 1 < (⌊2 * t⌋₊ : ℝ) :=
    Nat.sub_one_lt_floor (2 * t)
  linarith

/-- The bad-prime parity carrier is exactly the alternating sum of explicit
small-prime-subset divisibility counts. -/
theorem roughDyadicBadPrimeParitySum_eq_subsetCountSum (X : ℝ) (M : ℕ) (t : ℝ) :
    roughDyadicBadPrimeParitySum X M t =
      roughDyadicBadPrimeSubsetCountSum X M t := by
  classical
  unfold roughDyadicBadPrimeParitySum roughDyadicBadPrimeSubsetCountSum
    roughBadPrimeSubsetCount
  let base : Finset ℕ :=
    (natWindow t (2 * t)).filter
      (fun n : ℕ => Squarefree n ∧ Nat.Coprime n (auxiliaryModulus M))
  let primes : Finset (Finset ℕ) := (roughModulus X).primeFactors.powerset
  calc
    (∑ n ∈ base,
        ((∑ u ∈ (badPrimeFactors (roughModulus X) n).powerset,
            (-1 : ℤ) ^ u.card : ℤ) : ℝ))
        = ∑ n ∈ base,
            ∑ u ∈ primes.filter (fun u : Finset ℕ => ∀ p ∈ u, p ∣ n),
              (((-1 : ℤ) ^ u.card : ℤ) : ℝ) := by
          apply Finset.sum_congr rfl
          intro n _hn
          rw [Int.cast_sum]
          exact Finset.sum_congr
            (badPrimeFactors_powerset_eq_filter (roughModulus X) n) (by
              intro u _hu
              rfl)
    _ = ∑ n ∈ base,
          ∑ u ∈ primes,
            if (∀ p ∈ u, p ∣ n) then (((-1 : ℤ) ^ u.card : ℤ) : ℝ) else 0 := by
          apply Finset.sum_congr rfl
          intro n _hn
          rw [Finset.sum_filter]
    _ = ∑ u ∈ primes,
          ∑ n ∈ base,
            if (∀ p ∈ u, p ∣ n) then (((-1 : ℤ) ^ u.card : ℤ) : ℝ) else 0 := by
          rw [Finset.sum_comm]
    _ = ∑ u ∈ primes,
          (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
            (((base.filter (fun n : ℕ => ∀ p ∈ u, p ∣ n)).card : ℕ) : ℝ) := by
          apply Finset.sum_congr rfl
          intro u _hu
          rw [← Finset.sum_filter, Finset.sum_const, nsmul_eq_mul]
          ring
    _ = ∑ u ∈ (roughModulus X).primeFactors.powerset,
          (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
            (((natWindow t (2 * t)).filter
              (fun n : ℕ =>
                Squarefree n ∧ Nat.Coprime n (auxiliaryModulus M) ∧
                  ∀ p ∈ u, p ∣ n)).card : ℝ) := by
          dsimp [base, primes]
          apply Finset.sum_congr rfl
          intro u _hu
          simp [Finset.filter_filter, and_assoc, and_left_comm, and_comm]

/-- The subset-divisibility inclusion-exclusion carrier is identical to the
standard product-modulus carrier. -/
theorem roughDyadicBadPrimeSubsetCountSum_eq_productCountSum
    (X : ℝ) (M : ℕ) (t : ℝ) :
    roughDyadicBadPrimeSubsetCountSum X M t =
      roughDyadicBadPrimeSubsetProductCountSum X M t := by
  classical
  unfold roughDyadicBadPrimeSubsetCountSum
    roughDyadicBadPrimeSubsetProductCountSum
  apply Finset.sum_congr rfl
  intro u hu
  rw [roughBadPrimeSubsetCount_eq_productCount X M t hu]

/-- The bad-prime parity carrier, after all finite algebra is expanded, is the
alternating sum of product-modulus dyadic counts. -/
theorem roughDyadicBadPrimeParitySum_eq_productCountSum
    (X : ℝ) (M : ℕ) (t : ℝ) :
    roughDyadicBadPrimeParitySum X M t =
      roughDyadicBadPrimeSubsetProductCountSum X M t := by
  rw [roughDyadicBadPrimeParitySum_eq_subsetCountSum,
    roughDyadicBadPrimeSubsetCountSum_eq_productCountSum]

/-- The full alternating product-modulus expansion is bounded in absolute value
by the explicit quotient envelope.  Thus the upper half of the linear-sieve
input can be attacked by estimating this concrete finite sum. -/
theorem abs_roughDyadicBadPrimeSubsetProductCountSum_le_envelope
    (X : ℝ) (M : ℕ) (t : ℝ) :
    |roughDyadicBadPrimeSubsetProductCountSum X M t| ≤
      roughDyadicBadPrimeProductEnvelopeSum X t := by
  classical
  unfold roughDyadicBadPrimeSubsetProductCountSum
    roughDyadicBadPrimeProductEnvelopeSum
  calc
    |∑ u ∈ (roughModulus X).primeFactors.powerset,
        (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
          roughBadPrimeSubsetProductCount X M t u|
        ≤ ∑ u ∈ (roughModulus X).primeFactors.powerset,
            |(((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
              roughBadPrimeSubsetProductCount X M t u| :=
          Finset.abs_sum_le_sum_abs
            (fun u : Finset ℕ =>
              (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
                roughBadPrimeSubsetProductCount X M t u)
            ((roughModulus X).primeFactors.powerset)
    _ ≤ ∑ u ∈ (roughModulus X).primeFactors.powerset,
          ((⌊2 * t⌋₊ / badPrimeSubsetModulus u : ℕ) : ℝ) := by
          apply Finset.sum_le_sum
          intro u hu
          have hcoeff :
              |(((-1 : ℤ) ^ u.card : ℤ) : ℝ)| = 1 := by
            simp
          have hcount_nonneg :
              0 ≤ roughBadPrimeSubsetProductCount X M t u := by
            unfold roughBadPrimeSubsetProductCount
            exact Nat.cast_nonneg _
          calc
            |(((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
                roughBadPrimeSubsetProductCount X M t u|
                = roughBadPrimeSubsetProductCount X M t u := by
                  rw [abs_mul, hcoeff, abs_of_nonneg hcount_nonneg, one_mul]
            _ ≤ ((⌊2 * t⌋₊ / badPrimeSubsetModulus u : ℕ) : ℝ) :=
                roughBadPrimeSubsetProductCount_le_floor_div X M t hu

/-- Overstrong quotient-envelope upper target.

This is useful only as a diagnostic implication: by
`roughDyadicBadPrimeProductEnvelopeSum_ge_floor_two_mul`, the absolute-value
envelope already contains the empty-subset term, so it cannot be an
unconditional route to the desired `t / log z` rough-sieve saving. -/
def roughDyadicBadPrimeProductEnvelopeUpperBound
    (a₀ b₀ C₀ : ℝ) : Prop :=
  ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
      roughDyadicBadPrimeProductEnvelopeSum X t
        ≤ C * (t / Real.log (EscAnalytic.zScale X))

/-- The absolute-value quotient envelope cannot satisfy the desired
`t / log z(X)` upper bound on any nontrivial dyadic range.

The obstruction is structural, not quantitative: the envelope contains the
empty-subset term `⌊2t⌋`, while `log z(X)` is unbounded.  Thus for large `X` the
claimed right-hand side would be strictly smaller than `t`. -/
theorem not_roughDyadicBadPrimeProductEnvelopeUpperBound
    {a₀ b₀ C₀ : ℝ} (ha₀ : 0 < a₀) (hab : a₀ < b₀) :
    ¬ roughDyadicBadPrimeProductEnvelopeUpperBound a₀ b₀ C₀ := by
  intro h
  rcases h with ⟨C, X₀, hC, hEnv⟩
  have hlog_event :
      ∀ᶠ X : ℝ in Filter.atTop, C < Real.log (EscAnalytic.zScale X) :=
    tendsto_log_zScale_atTop.eventually (Filter.eventually_gt_atTop C)
  have hX₀_event : ∀ᶠ X : ℝ in Filter.atTop, X₀ ≤ X :=
    Filter.eventually_ge_atTop X₀
  have hXone_event : ∀ᶠ X : ℝ in Filter.atTop, (1 : ℝ) ≤ X :=
    Filter.eventually_ge_atTop (1 : ℝ)
  have hAll :
      ∀ᶠ X : ℝ in Filter.atTop,
        C < Real.log (EscAnalytic.zScale X) ∧ X₀ ≤ X ∧ (1 : ℝ) ≤ X :=
    hlog_event.and (hX₀_event.and hXone_event)
  rcases hAll.exists with ⟨X, hlog, hX₀, hXone⟩
  let t : ℝ := X ^ a₀
  have hXpos : 0 < X := lt_of_lt_of_le zero_lt_one hXone
  have htpos : 0 < t := by
    dsimp [t]
    exact Real.rpow_pos_of_pos hXpos a₀
  have ht_ge_one : (1 : ℝ) ≤ t := by
    dsimp [t]
    calc
      (1 : ℝ) = 1 ^ a₀ := by rw [Real.one_rpow]
      _ ≤ X ^ a₀ := Real.rpow_le_rpow (by norm_num) hXone ha₀.le
  have hthi : t ≤ 2 * X ^ b₀ := by
    have hXa_le_Xb : X ^ a₀ ≤ X ^ b₀ :=
      Real.rpow_le_rpow_of_exponent_le hXone hab.le
    have hXb_pos : 0 < X ^ b₀ := Real.rpow_pos_of_pos hXpos b₀
    dsimp [t]
    nlinarith
  have hM : (((0 : ℕ) : ℝ) ≤ X ^ C₀) := by
    simpa using (Real.rpow_pos_of_pos hXpos C₀).le
  have hbound := hEnv X hX₀ 0 hM t le_rfl hthi
  have hfloor_le_env := roughDyadicBadPrimeProductEnvelopeSum_ge_floor_two_mul X t
  have ht_le_floor : t ≤ (⌊2 * t⌋₊ : ℝ) :=
    self_le_floor_two_mul ht_ge_one
  have ht_le_rhs : t ≤ C * (t / Real.log (EscAnalytic.zScale X)) :=
    (ht_le_floor.trans hfloor_le_env).trans hbound
  have hlog_pos : 0 < Real.log (EscAnalytic.zScale X) := lt_trans hC hlog
  have hCdiv_lt : C / Real.log (EscAnalytic.zScale X) < 1 := by
    rw [div_lt_one hlog_pos]
    exact hlog
  have hrhs_lt : C * (t / Real.log (EscAnalytic.zScale X)) < t := by
    calc
      C * (t / Real.log (EscAnalytic.zScale X))
          = (C / Real.log (EscAnalytic.zScale X)) * t := by
            field_simp [ne_of_gt hlog_pos]
      _ < 1 * t := mul_lt_mul_of_pos_right hCdiv_lt htpos
      _ = t := by ring
  exact (not_lt_of_ge ht_le_rhs) hrhs_lt

/-- The overstrong quotient-envelope estimate would imply the upper half of the
product-modulus rough-sieve bound.  This theorem is kept as a diagnostic
implication only; the envelope hypothesis itself is not a viable unconditional
target because of `roughDyadicBadPrimeProductEnvelopeSum_ge_floor_two_mul`. -/
theorem roughDyadicBadPrimeProductCount_upper_of_envelope
    {a₀ b₀ C₀ : ℝ}
    (hEnv : roughDyadicBadPrimeProductEnvelopeUpperBound a₀ b₀ C₀) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        roughDyadicBadPrimeSubsetProductCountSum X M t
          ≤ C * (t / Real.log (EscAnalytic.zScale X)) := by
  rcases hEnv with ⟨C, X₀, hC, hEnv⟩
  refine ⟨C, X₀, hC, ?_⟩
  intro X hX M hM t htlo hthi
  have hsum_le_abs :
      roughDyadicBadPrimeSubsetProductCountSum X M t
        ≤ |roughDyadicBadPrimeSubsetProductCountSum X M t| :=
    le_abs_self _
  exact hsum_le_abs.trans
    ((abs_roughDyadicBadPrimeSubsetProductCountSum_le_envelope X M t).trans
      (hEnv X hX M hM t htlo hthi))

/-- The linear-sieve dyadic count target, rewritten on the explicit
inclusion-exclusion carrier. -/
def roughDyadicBadPrimeParityBound (a₀ b₀ C₀ : ℝ) : Prop :=
  ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
      c * (t / Real.log (EscAnalytic.zScale X)) ≤
          roughDyadicBadPrimeParitySum X M t ∧
        roughDyadicBadPrimeParitySum X M t ≤
          C * (t / Real.log (EscAnalytic.zScale X))

/-- Product-modulus version of the linear-sieve dyadic count target. -/
def roughDyadicBadPrimeProductCountBound (a₀ b₀ C₀ : ℝ) : Prop :=
  ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
      c * (t / Real.log (EscAnalytic.zScale X)) ≤
          roughDyadicBadPrimeSubsetProductCountSum X M t ∧
        roughDyadicBadPrimeSubsetProductCountSum X M t ≤
          C * (t / Real.log (EscAnalytic.zScale X))

/-- Lower half of the product-modulus rough-sieve target. -/
def roughDyadicBadPrimeProductCountLowerBound (a₀ b₀ C₀ : ℝ) : Prop :=
  ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
      c * (t / Real.log (EscAnalytic.zScale X)) ≤
        roughDyadicBadPrimeSubsetProductCountSum X M t

/-- Upper half of the product-modulus rough-sieve target. -/
def roughDyadicBadPrimeProductCountUpperBound (a₀ b₀ C₀ : ℝ) : Prop :=
  ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
      roughDyadicBadPrimeSubsetProductCountSum X M t ≤
        C * (t / Real.log (EscAnalytic.zScale X))

/-- Lower half of the original rough dyadic count target. -/
def roughDyadicCountLowerBound (a₀ b₀ C₀ : ℝ) : Prop :=
  ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
      c * (t / Real.log (EscAnalytic.zScale X)) ≤
        roughDyadicCount X M t

/-- Lower half of the rough dyadic count target in the no-extra-modulus lane.
This isolates the genuine rough/squarefree inclusion-exclusion estimate before
the large-prime auxiliary tail is transferred back in. -/
def roughDyadicCountModulusOneLowerBoundCore (a₀ b₀ : ℝ) : Prop :=
  ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
      c * (t / Real.log (EscAnalytic.zScale X)) ≤
        roughDyadicCount X 1 t

/-- Backward-compatible parameter-shaped wrapper for the no-extra-modulus lower
target.  The auxiliary growth exponent is irrelevant in the `M = 1` lane. -/
def roughDyadicCountModulusOneLowerBound (a₀ b₀ _C₀ : ℝ) : Prop :=
  roughDyadicCountModulusOneLowerBoundCore a₀ b₀

/-- The core no-extra-modulus lower target gives the parameter-shaped wrapper. -/
theorem roughDyadicCountModulusOneLowerBound_of_core
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicCountModulusOneLowerBoundCore a₀ b₀) :
    roughDyadicCountModulusOneLowerBound a₀ b₀ C₀ :=
  h

/-- Forget the irrelevant auxiliary-growth exponent from the parameter-shaped
no-extra-modulus lower target. -/
theorem roughDyadicCountModulusOneLowerBound_core_of_bound
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicCountModulusOneLowerBound a₀ b₀ C₀) :
    roughDyadicCountModulusOneLowerBoundCore a₀ b₀ :=
  h

/-- Parameter-shaped bound for the explicit auxiliary-tail floor envelope.
Unlike the older full auxiliary-prime envelope, this only counts prime factors
of the auxiliary modulus beyond the rough cutoff. -/
def roughDyadicAuxiliaryTailMultiplesFloorEnvelopeBound
    (a₀ b₀ C₀ E X₀ : ℝ) : Prop :=
  0 ≤ E ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
      auxiliaryTailMultiplesFloorEnvelope X M t ≤
        E * (t / Real.log (EscAnalytic.zScale X))

/-- Packaged arbitrary-small auxiliary-tail floor envelope.  The statement
works for arbitrary `C₀` by proving the estimate with exponent
`max C₀ 0`, which dominates every admissible `M ≤ X^C₀` once `X ≥ 1`. -/
theorem roughDyadicAuxiliaryTailMultiplesFloorEnvelopeBound_arbitrary_small
    (a₀ b₀ C₀ eps : ℝ) (heps : 0 < eps) :
    ∃ X₀ : ℝ,
      roughDyadicAuxiliaryTailMultiplesFloorEnvelopeBound
        a₀ b₀ C₀ eps X₀ := by
  let C : ℝ := max C₀ 0
  refine ⟨Real.exp (max 2 (2 * (C + 1) / eps)), ⟨heps.le, ?_⟩⟩
  intro X hX M hM t htlo _hthi
  have hXexp2 : Real.exp 2 ≤ X :=
    le_trans (Real.exp_le_exp.mpr (le_max_left _ _)) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 2) hXexp2
  have hXone : 1 ≤ X := le_trans (by norm_num : (1 : ℝ) ≤ Real.exp 2) hXexp2
  have hC_nonneg : 0 ≤ C := by
    dsimp [C]
    exact le_max_right C₀ 0
  have hC₀_le_C : C₀ ≤ C := by
    dsimp [C]
    exact le_max_left C₀ 0
  have hpow_le : X ^ C₀ ≤ X ^ C :=
    Real.rpow_le_rpow_of_exponent_le hXone hC₀_le_C
  have hM' : (M : ℝ) ≤ X ^ C := hM.trans hpow_le
  have ht_nonneg : 0 ≤ t :=
    le_trans (Real.rpow_pos_of_pos hXpos a₀).le htlo
  exact
    auxiliaryTailMultiplesFloorEnvelope_le_eps_mul_t_div_log_zScale
      X M hX hC_nonneg heps hM' ht_nonneg

/-- A modulus-one lower bound plus a strictly smaller auxiliary-tail floor
envelope gives the full lower rough-dyadic count bound for all admissible
auxiliary moduli. -/
theorem roughDyadicCountLowerBound_of_modulusOne_and_auxiliaryTailFloor
    {a₀ b₀ C₀ c E Xone Xtail : ℝ}
    (_hc : 0 < c) (hE_lt : E < c)
    (hone :
      ∀ X : ℝ, Xone ≤ X →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        c * (t / Real.log (EscAnalytic.zScale X)) ≤
          roughDyadicCount X 1 t)
    (htail :
      roughDyadicAuxiliaryTailMultiplesFloorEnvelopeBound
        a₀ b₀ C₀ E Xtail) :
    roughDyadicCountLowerBound a₀ b₀ C₀ := by
  rcases htail with ⟨_hE_nonneg, htail⟩
  refine ⟨c - E, max Xone Xtail, sub_pos.mpr hE_lt, ?_⟩
  intro X hX M hM t htlo hthi
  have hXone : Xone ≤ X := le_trans (le_max_left _ _) hX
  have hXtail : Xtail ≤ X := le_trans (le_max_right _ _) hX
  have hone_bound := hone X hXone t htlo hthi
  have htail_count :=
    roughDyadicCount_one_le_count_add_multiplesFloorEnvelope X M t
  have htail_bound := htail X hXtail M hM t htlo hthi
  calc
    (c - E) * (t / Real.log (EscAnalytic.zScale X))
        = c * (t / Real.log (EscAnalytic.zScale X)) -
            E * (t / Real.log (EscAnalytic.zScale X)) := by ring
    _ ≤ roughDyadicCount X M t := by
        nlinarith

/-- Upper half of the original rough dyadic count target. -/
def roughDyadicCountUpperBound (a₀ b₀ C₀ : ℝ) : Prop :=
  ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
      roughDyadicCount X M t ≤
        C * (t / Real.log (EscAnalytic.zScale X))

/-- Upper half of the rough dyadic count target in the no-extra-modulus lane.
This is weaker than the Selberg-block reciprocal carrier: it asks only for the
actual squarefree rough count needed downstream. -/
def roughDyadicCountModulusOneUpperBoundCore (a₀ b₀ : ℝ) : Prop :=
  ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
      roughDyadicCount X 1 t ≤
        C * (t / Real.log (EscAnalytic.zScale X))

/-- Backward-compatible parameter-shaped wrapper for the no-extra-modulus upper
count target.  The auxiliary growth exponent is irrelevant in the `M = 1`
lane. -/
def roughDyadicCountModulusOneUpperBound (a₀ b₀ _C₀ : ℝ) : Prop :=
  roughDyadicCountModulusOneUpperBoundCore a₀ b₀

/-- The core no-extra-modulus upper target gives the parameter-shaped wrapper. -/
theorem roughDyadicCountModulusOneUpperBound_of_core
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicCountModulusOneUpperBoundCore a₀ b₀) :
    roughDyadicCountModulusOneUpperBound a₀ b₀ C₀ :=
  h

/-- Forget the irrelevant auxiliary-growth exponent from the parameter-shaped
no-extra-modulus upper target. -/
theorem roughDyadicCountModulusOneUpperBound_core_of_bound
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicCountModulusOneUpperBound a₀ b₀ C₀) :
    roughDyadicCountModulusOneUpperBoundCore a₀ b₀ :=
  h

/-- A general upper rough-dyadic count bound specializes to the no-extra-modulus
upper core.  This is only a carrier specialization: set `M = 1` and `C₀ = 0`,
so the auxiliary-size condition is automatic. -/
theorem roughDyadicCountModulusOneUpperBoundCore_of_countUpperBound
    {a₀ b₀ : ℝ}
    (h : roughDyadicCountUpperBound a₀ b₀ 0) :
    roughDyadicCountModulusOneUpperBoundCore a₀ b₀ := by
  rcases h with ⟨C, X₀, hC, hcount⟩
  refine ⟨C, X₀, hC, ?_⟩
  intro X hX t htlo hthi
  have hM : (((1 : ℕ) : ℝ) ≤ X ^ (0 : ℝ)) := by
    simp
  exact hcount X hX 1 hM t htlo hthi

/-- Main-term/error formulation of the product-modulus rough-sieve target.  It
requires a positive main term of size `t/log z`, a matching upper bound, and an
absolute error strictly smaller than the main lower constant. -/
def roughDyadicBadPrimeProductMainTermDominatesErrorBound
    (a₀ b₀ C₀ : ℝ) : Prop :=
  ∃ c C E X₀ : ℝ, 0 < c ∧ 0 < C ∧ 0 ≤ E ∧ E < c ∧
    ∀ X : ℝ, X₀ ≤ X →
    ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
      c * (t / Real.log (EscAnalytic.zScale X)) ≤
          roughDyadicBadPrimeProductMainTermSum X t ∧
        roughDyadicBadPrimeProductMainTermSum X t ≤
          C * (t / Real.log (EscAnalytic.zScale X)) ∧
        |roughDyadicBadPrimeProductErrorSum X M t| ≤
          E * (t / Real.log (EscAnalytic.zScale X))

/-- Euler-product plus exact-error version of the rough-sieve target.  The main
term has been reduced to the finite product
`∏_{p | P(z)} (1 - 1/p)`; the error is the exact carrier produced by subtracting
that main term from the product-modulus inclusion-exclusion count. -/
def roughDyadicBadPrimeEulerProductErrorBound
    (a₀ b₀ C₀ : ℝ) : Prop :=
  ∃ c C E X₀ : ℝ, 0 < c ∧ 0 < C ∧ 0 ≤ E ∧ E < c ∧
    ∀ X : ℝ, X₀ ≤ X →
    ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
      c / Real.log (EscAnalytic.zScale X) ≤
          roughDyadicBadPrimeMainEulerProduct X ∧
        roughDyadicBadPrimeMainEulerProduct X ≤
          C / Real.log (EscAnalytic.zScale X) ∧
        |roughDyadicBadPrimeProductErrorSum X M t| ≤
          E * (t / Real.log (EscAnalytic.zScale X))

/-- Lower Mertens-type bound for the finite bad-prime Euler product. -/
def roughDyadicBadPrimeMainEulerProductLowerBound : Prop :=
  ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
    c / Real.log (EscAnalytic.zScale X) ≤
      roughDyadicBadPrimeMainEulerProduct X

/-- A weaker axiom-free lower bound for the finite bad-prime Euler product.
The denominator is `z=(log X)^4`, not `log z`; this is the strongest lower
bound currently obtained from the elementary same-cutoff harmonic route alone.
-/
def roughDyadicBadPrimeMainEulerProductZScaleLowerBound : Prop :=
  ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
    c / EscAnalytic.zScale X ≤
      roughDyadicBadPrimeMainEulerProduct X

/-- Upper Mertens-type bound for the finite bad-prime Euler product. -/
def roughDyadicBadPrimeMainEulerProductUpperBound : Prop :=
  ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
    roughDyadicBadPrimeMainEulerProduct X ≤
      C / Real.log (EscAnalytic.zScale X)

/-- Dual product-sum inequality linking the rough Euler product to the
small-divisor Euler carrier.  This is the exact finite inequality needed to
turn the already formalized logarithmic lower bound for
`smallDivisorEulerSum` into the Mertens-type upper bound for the rough product.
-/
def roughDyadicBadPrimeMainEulerProductSmallDivisorDualBound : Prop :=
  ∃ X₀ : ℝ, ∀ X : ℝ, X₀ ≤ X →
    roughDyadicBadPrimeMainEulerProduct X * smallDivisorEulerSum X ≤ 1

/-- The truncated small-divisor Euler carrier is bounded by the full reciprocal
divisor sum of the rough modulus.  This is finite bookkeeping only: the support
is a subset of the divisors of `P(z)`, and `φ(d)/d² ≤ 1/d`. -/
theorem smallDivisorEulerSum_le_roughModulus_divisor_recip_sum (X : ℝ) :
    smallDivisorEulerSum X ≤
      ∑ d ∈ (roughModulus X).divisors, (1 : ℝ) / (d : ℝ) := by
  classical
  unfold smallDivisorEulerSum
  let support : Finset ℕ :=
    (Finset.Icc (1 : ℕ) ⌊EscAnalytic.UScale X⌋₊).filter
      (fun d => d ∣ roughModulus X ∧ Odd d)
  have hterm :
      (∑ d ∈ support, (Nat.totient d : ℝ) / (d : ℝ) ^ 2) ≤
        ∑ d ∈ support, (1 : ℝ) / (d : ℝ) := by
    apply Finset.sum_le_sum
    intro d hd
    dsimp [support] at hd
    rw [Finset.mem_filter] at hd
    have hdIcc : d ∈ Finset.Icc (1 : ℕ) ⌊EscAnalytic.UScale X⌋₊ := hd.1
    have hdpos_nat : 0 < d :=
      lt_of_lt_of_le Nat.zero_lt_one (Finset.mem_Icc.mp hdIcc).1
    have hdpos : (0 : ℝ) < d := by exact_mod_cast hdpos_nat
    have htot_le_nat : (Nat.totient d : ℝ) ≤ (d : ℝ) := by
      exact_mod_cast Nat.totient_le d
    calc
      (Nat.totient d : ℝ) / (d : ℝ) ^ 2
          ≤ (d : ℝ) / (d : ℝ) ^ 2 :=
            div_le_div_of_nonneg_right htot_le_nat (sq_nonneg _)
      _ = (1 : ℝ) / (d : ℝ) := by
            field_simp [ne_of_gt hdpos]
            ring
  have hsubset : support ⊆ (roughModulus X).divisors := by
    intro d hd
    dsimp [support] at hd
    rw [Finset.mem_filter] at hd
    exact Nat.mem_divisors.mpr
      ⟨hd.2.1, Nat.ne_of_gt (roughModulus_pos X)⟩
  have hsubsum :
      (∑ d ∈ support, (1 : ℝ) / (d : ℝ)) ≤
        ∑ d ∈ (roughModulus X).divisors, (1 : ℝ) / (d : ℝ) :=
    Finset.sum_le_sum_of_subset_of_nonneg hsubset (by
      intro d _hdDiv _hdSmall
      exact div_nonneg zero_le_one (Nat.cast_nonneg d))
  exact hterm.trans hsubsum

/-- The rough Euler product is dual to the full reciprocal divisor sum of the
rough modulus.  This is the local-density identity
`(φ(P)/P) * ∑_{d|P} 1/d ≤ 1` for squarefree `P=P(z)`. -/
theorem roughDyadicBadPrimeMainEulerProduct_mul_divisor_recip_sum_le_one
    (X : ℝ) :
    roughDyadicBadPrimeMainEulerProduct X *
        (∑ d ∈ (roughModulus X).divisors, (1 : ℝ) / (d : ℝ)) ≤ 1 := by
  have hPpos_nat : 0 < roughModulus X := roughModulus_pos X
  have hPpos : (0 : ℝ) < (roughModulus X : ℝ) := by exact_mod_cast hPpos_nat
  have hdiv :=
    divisor_recip_sum_mul_totient_le_self hPpos_nat (roughModulus_squarefree X)
  change totientPrimeFactorProduct (roughModulus X) *
      (∑ d ∈ (roughModulus X).divisors, (1 : ℝ) / (d : ℝ)) ≤ 1
  rw [← totient_div_eq_totientPrimeFactorProduct hPpos_nat]
  change ((Nat.totient (roughModulus X) : ℝ) / (roughModulus X : ℝ)) *
      (∑ d ∈ (roughModulus X).divisors, (1 : ℝ) / (d : ℝ)) ≤ 1
  calc
    ((Nat.totient (roughModulus X) : ℝ) / (roughModulus X : ℝ)) *
        (∑ d ∈ (roughModulus X).divisors, (1 : ℝ) / (d : ℝ))
        = ((∑ d ∈ (roughModulus X).divisors, (1 : ℝ) / (d : ℝ)) *
            (Nat.totient (roughModulus X) : ℝ)) / (roughModulus X : ℝ) := by
              field_simp [ne_of_gt hPpos]
              ring
    _ ≤ (roughModulus X : ℝ) / (roughModulus X : ℝ) :=
          div_le_div_of_nonneg_right hdiv hPpos.le
    _ = 1 := by field_simp [ne_of_gt hPpos]

/-- Exact square-Euler identity for the rough modulus. -/
theorem roughDyadicBadPrimeMainEulerProduct_mul_divisor_recip_sum_eq_square_euler
    (X : ℝ) :
    roughDyadicBadPrimeMainEulerProduct X *
        (∑ d ∈ (roughModulus X).divisors, (1 : ℝ) / (d : ℝ)) =
      ∏ p ∈ (roughModulus X).primeFactors, (1 - ((p : ℝ) ^ 2)⁻¹) := by
  unfold roughDyadicBadPrimeMainEulerProduct
  exact primeFactorProduct_one_sub_inv_mul_divisor_recip_sum_eq_square_euler
    (roughModulus_squarefree X)

/-- Mertens-upper formulation for the full reciprocal divisor sum of the rough
modulus. -/
def roughModulusDivisorRecipUpperBound : Prop :=
  ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
    (∑ d ∈ (roughModulus X).divisors, (1 : ℝ) / (d : ℝ)) ≤
      C * Real.log (EscAnalytic.zScale X)

/-- The reciprocal divisor sum of a squarefree integer is bounded by the
exponential of the reciprocal prime-factor sum. -/
theorem divisor_recip_sum_le_exp_primeFactor_recip_sum_of_squarefree
    {d : ℕ} (hsqf : Squarefree d) :
    (∑ m ∈ d.divisors, (1 : ℝ) / (m : ℝ)) ≤
      Real.exp (∑ p ∈ d.primeFactors, (p : ℝ)⁻¹) := by
  classical
  have hprod_le :
      ∏ p ∈ d.primeFactors, (1 + (p : ℝ)⁻¹)
        ≤ ∏ p ∈ d.primeFactors, Real.exp ((p : ℝ)⁻¹) := by
    refine Finset.prod_le_prod ?h_nonneg ?h_point
    · intro p _hp
      exact add_nonneg zero_le_one (inv_nonneg.mpr (Nat.cast_nonneg p))
    · intro p _hp
      have h := Real.add_one_le_exp ((p : ℝ)⁻¹)
      nlinarith
  calc
    (∑ m ∈ d.divisors, (1 : ℝ) / (m : ℝ))
        = ∏ p ∈ d.primeFactors, (1 + (p : ℝ)⁻¹) := by
          rw [divisor_recip_sum_eq_primeFactorProduct_one_add_inv hsqf]
    _ ≤ ∏ p ∈ d.primeFactors, Real.exp ((p : ℝ)⁻¹) := hprod_le
    _ = Real.exp (∑ p ∈ d.primeFactors, (p : ℝ)⁻¹) := by
          rw [Real.exp_sum]

/-- Sharp prime-reciprocal Mertens upper bound over the rough modulus prime
factors.  The coefficient of `log log z` is deliberately fixed at `1`; this is
exactly the strength needed to recover a divisor-reciprocal bound of size
`O(log z)`. -/
def roughModulusPrimeRecipSharpMertensUpperBound : Prop :=
  ∃ K X₀ : ℝ, ∀ X : ℝ, X₀ ≤ X →
    (∑ p ∈ (roughModulus X).primeFactors, (p : ℝ)⁻¹) ≤
      Real.log (Real.log (EscAnalytic.zScale X)) + K

/-- Standard sharp prime-reciprocal Mertens upper bound over primes up to a
real cutoff.  This is the classical analytic input
`∑_{p≤z} 1/p ≤ log log z + O(1)`, isolated before specializing to the rough
modulus `P(z)`. -/
def PrimeRecipSharpMertensUpperBound : Prop :=
  ∃ K Z₀ : ℝ, ∀ z : ℝ, Z₀ ≤ z →
    (∑ p ∈ (Finset.Icc (2 : ℕ) ⌊z⌋₊).filter (fun p => Nat.Prime p),
        (p : ℝ)⁻¹) ≤
      Real.log (Real.log z) + K

/-- Natural-cutoff form of the sharp prime-reciprocal Mertens upper bound.
This is the usual sequence formulation; the theorem below performs the
floor-transfer to the real-cutoff formulation consumed by the rough-modulus
specialization. -/
def PrimeRecipSharpMertensNatUpperBound : Prop :=
  ∃ K N₀ : ℕ, ∀ N : ℕ, N₀ ≤ N →
    (∑ p ∈ (Finset.Icc (2 : ℕ) N).filter (fun p => Nat.Prime p),
        (p : ℝ)⁻¹) ≤
      Real.log (Real.log (N : ℝ)) + K

/-- Natural-cutoff form with the conventional real additive constant.  The
exported axiom below uses a natural-number constant only to make downstream
threshold bookkeeping convenient; the two formulations are equivalent. -/
def PrimeRecipSharpMertensNatRealConstantUpperBound : Prop :=
  ∃ K : ℝ, ∃ N₀ : ℕ, ∀ N : ℕ, N₀ ≤ N →
    (∑ p ∈ (Finset.Icc (2 : ℕ) N).filter (fun p => Nat.Prime p),
        (p : ℝ)⁻¹) ≤
      Real.log (Real.log (N : ℝ)) + K

/-- Defect form of the natural-cutoff prime-reciprocal Mertens sum.  Bounding
this eventually above is exactly the standard `log log N + O(1)` upper
statement. -/
noncomputable def primeRecipSharpMertensNatDefect (N : ℕ) : ℝ :=
  (∑ p ∈ (Finset.Icc (2 : ℕ) N).filter (fun p => Nat.Prime p),
      (p : ℝ)⁻¹) - Real.log (Real.log (N : ℝ))

/-- Eventual bounded-defect formulation of the natural-cutoff
prime-reciprocal Mertens upper bound. -/
def PrimeRecipSharpMertensNatDefectEventuallyUpperBound : Prop :=
  ∃ K : ℝ, ∀ᶠ N : ℕ in Filter.atTop,
    primeRecipSharpMertensNatDefect N ≤ K

/-- Big-O-one formulation of the natural-cutoff prime-reciprocal Mertens
defect.  This is a convenient import target for libraries or external formal
proofs that state Mertens as a bounded error term. -/
def PrimeRecipSharpMertensNatDefectIsBigOOne : Prop :=
  Asymptotics.IsBigO Filter.atTop
    (fun N : ℕ => primeRecipSharpMertensNatDefect N)
    (fun _ : ℕ => (1 : ℝ))

/-- Eventual absolute boundedness of the natural-cutoff prime-reciprocal
Mertens defect.  This is the common two-sided error-term shape
`|sum_{p≤N} 1/p - log log N| ≤ K` for all sufficiently large `N`. -/
def PrimeRecipSharpMertensNatDefectEventuallyAbsBound : Prop :=
  ∃ K : ℝ, ∀ᶠ N : ℕ in Filter.atTop,
    |primeRecipSharpMertensNatDefect N| ≤ K

/-- Eventual two-sided boundedness of the natural-cutoff prime-reciprocal
Mertens defect.  This is equivalent to the absolute-value form and is often the
most convenient target when importing a theorem stated with separate upper and
lower constants. -/
def PrimeRecipSharpMertensNatDefectEventuallyTwoSidedBound : Prop :=
  ∃ K : ℝ, ∀ᶠ N : ℕ in Filter.atTop,
    -K ≤ primeRecipSharpMertensNatDefect N ∧
      primeRecipSharpMertensNatDefect N ≤ K

/-- Convergent-defect formulation of prime-reciprocal Mertens.  This is the
customary sharpened statement that the difference
`sum_{p≤N} 1/p - log log N` tends to a finite Mertens constant. -/
def PrimeRecipSharpMertensNatDefectConverges : Prop :=
  ∃ C : ℝ, Filter.Tendsto
    (fun N : ℕ => primeRecipSharpMertensNatDefect N)
    Filter.atTop (nhds C)

/-- A finite limiting Mertens constant gives eventual absolute boundedness of
the natural-cutoff prime-reciprocal Mertens defect. -/
theorem PrimeRecipSharpMertensNatDefectEventuallyAbsBound_of_converges
    (h : PrimeRecipSharpMertensNatDefectConverges) :
    PrimeRecipSharpMertensNatDefectEventuallyAbsBound := by
  rcases h with ⟨C, hC⟩
  refine ⟨|C| + 1, ?_⟩
  have hclose :
      ∀ᶠ N : ℕ in Filter.atTop,
        dist (primeRecipSharpMertensNatDefect N) C < 1 :=
    (Metric.tendsto_nhds.mp hC) 1 (by norm_num)
  refine hclose.mono ?_
  intro N hN
  rw [Real.dist_eq] at hN
  have htri :
      |primeRecipSharpMertensNatDefect N| ≤
        |primeRecipSharpMertensNatDefect N - C| + |C| := by
    calc
      |primeRecipSharpMertensNatDefect N|
          = |(primeRecipSharpMertensNatDefect N - C) + C| := by ring_nf
      _ ≤ |primeRecipSharpMertensNatDefect N - C| + |C| := abs_add _ _
  linarith [le_of_lt hN]

/-- A standard eventual absolute-error estimate gives the Big-O-one Mertens
defect primitive. -/
theorem PrimeRecipSharpMertensNatDefectIsBigOOne_of_eventuallyAbsBound
    (h : PrimeRecipSharpMertensNatDefectEventuallyAbsBound) :
    PrimeRecipSharpMertensNatDefectIsBigOOne := by
  rcases h with ⟨K, hK⟩
  refine Asymptotics.isBigO_iff.mpr ⟨max K 0, ?_⟩
  refine hK.mono ?_
  intro N hN
  exact (by simpa [Real.norm_eq_abs] using hN.trans (le_max_left K 0))

/-- The Big-O-one Mertens defect primitive gives an eventual absolute-error
estimate. -/
theorem PrimeRecipSharpMertensNatDefectEventuallyAbsBound_of_isBigOOne
    (h : PrimeRecipSharpMertensNatDefectIsBigOOne) :
    PrimeRecipSharpMertensNatDefectEventuallyAbsBound := by
  rcases (Asymptotics.isBigO_iff.mp h) with ⟨C, hC⟩
  exact ⟨C, by simpa [Real.norm_eq_abs] using hC⟩

/-- The local Big-O-one primitive is exactly the usual eventual absolute-error
form of the sharp prime-reciprocal Mertens theorem. -/
theorem PrimeRecipSharpMertensNatDefectIsBigOOne_iff_eventuallyAbsBound :
    PrimeRecipSharpMertensNatDefectIsBigOOne ↔
      PrimeRecipSharpMertensNatDefectEventuallyAbsBound := by
  constructor
  · exact PrimeRecipSharpMertensNatDefectEventuallyAbsBound_of_isBigOOne
  · exact PrimeRecipSharpMertensNatDefectIsBigOOne_of_eventuallyAbsBound

/-- The two-sided bounded-defect form implies the absolute-error form. -/
theorem PrimeRecipSharpMertensNatDefectEventuallyAbsBound_of_twoSided
    (h : PrimeRecipSharpMertensNatDefectEventuallyTwoSidedBound) :
    PrimeRecipSharpMertensNatDefectEventuallyAbsBound := by
  rcases h with ⟨K, hK⟩
  refine ⟨K, ?_⟩
  refine hK.mono ?_
  intro N hN
  exact abs_le.mpr hN

/-- The absolute-error form implies the two-sided bounded-defect form. -/
theorem PrimeRecipSharpMertensNatDefectEventuallyTwoSidedBound_of_absBound
    (h : PrimeRecipSharpMertensNatDefectEventuallyAbsBound) :
    PrimeRecipSharpMertensNatDefectEventuallyTwoSidedBound := by
  rcases h with ⟨K, hK⟩
  refine ⟨K, ?_⟩
  refine hK.mono ?_
  intro N hN
  exact abs_le.mp hN

/-- Absolute-error and two-sided bounded-defect formulations of sharp
prime-reciprocal Mertens are equivalent. -/
theorem PrimeRecipSharpMertensNatDefectEventuallyAbsBound_iff_twoSided :
    PrimeRecipSharpMertensNatDefectEventuallyAbsBound ↔
      PrimeRecipSharpMertensNatDefectEventuallyTwoSidedBound := by
  constructor
  · exact PrimeRecipSharpMertensNatDefectEventuallyTwoSidedBound_of_absBound
  · exact PrimeRecipSharpMertensNatDefectEventuallyAbsBound_of_twoSided

/-- A two-sided bounded-defect Mertens theorem also directly discharges the
Big-O-one primitive. -/
theorem PrimeRecipSharpMertensNatDefectIsBigOOne_of_twoSided
    (h : PrimeRecipSharpMertensNatDefectEventuallyTwoSidedBound) :
    PrimeRecipSharpMertensNatDefectIsBigOOne :=
  PrimeRecipSharpMertensNatDefectIsBigOOne_of_eventuallyAbsBound
    (PrimeRecipSharpMertensNatDefectEventuallyAbsBound_of_twoSided h)

/-- Eventual upper boundedness of the defect gives the conventional
real-constant natural-cutoff Mertens statement. -/
theorem PrimeRecipSharpMertensNatRealConstantUpperBound_of_defectEventuallyUpperBound
    (h : PrimeRecipSharpMertensNatDefectEventuallyUpperBound) :
    PrimeRecipSharpMertensNatRealConstantUpperBound := by
  rcases h with ⟨K, hK⟩
  rw [Filter.eventually_atTop] at hK
  rcases hK with ⟨N₀, hN₀⟩
  refine ⟨K, N₀, ?_⟩
  intro N hN
  have hdef := hN₀ N hN
  dsimp [primeRecipSharpMertensNatDefect] at hdef
  linarith

/-- The conventional real-constant natural-cutoff Mertens statement gives
eventual upper boundedness of the defect. -/
theorem PrimeRecipSharpMertensNatDefectEventuallyUpperBound_of_natRealConstant
    (h : PrimeRecipSharpMertensNatRealConstantUpperBound) :
    PrimeRecipSharpMertensNatDefectEventuallyUpperBound := by
  rcases h with ⟨K, N₀, hN₀⟩
  refine ⟨K, ?_⟩
  rw [Filter.eventually_atTop]
  exact ⟨N₀, fun N hN => by
    have hsum := hN₀ N hN
    dsimp [primeRecipSharpMertensNatDefect]
    linarith⟩

/-- The bounded-defect and conventional real-constant natural-cutoff Mertens
formulations are equivalent. -/
theorem PrimeRecipSharpMertensNatDefectEventuallyUpperBound_iff_realConstant :
    PrimeRecipSharpMertensNatDefectEventuallyUpperBound ↔
      PrimeRecipSharpMertensNatRealConstantUpperBound := by
  constructor
  · exact PrimeRecipSharpMertensNatRealConstantUpperBound_of_defectEventuallyUpperBound
  · exact PrimeRecipSharpMertensNatDefectEventuallyUpperBound_of_natRealConstant

/-- A Big-O-one bound for the defect implies the eventual upper boundedness
form of Mertens. -/
theorem PrimeRecipSharpMertensNatDefectEventuallyUpperBound_of_isBigOOne
    (h : PrimeRecipSharpMertensNatDefectIsBigOOne) :
    PrimeRecipSharpMertensNatDefectEventuallyUpperBound := by
  rcases (Asymptotics.isBigO_iff.mp h) with ⟨C, hC⟩
  refine ⟨C, ?_⟩
  refine hC.mono ?_
  intro N hN
  have hle_abs :
      primeRecipSharpMertensNatDefect N ≤
        ‖primeRecipSharpMertensNatDefect N‖ := le_abs_self _
  simpa using hle_abs.trans hN

/-- A finite limiting Mertens constant gives the Big-O-one defect formulation.
-/
theorem PrimeRecipSharpMertensNatDefectIsBigOOne_of_converges
    (h : PrimeRecipSharpMertensNatDefectConverges) :
    PrimeRecipSharpMertensNatDefectIsBigOOne :=
  PrimeRecipSharpMertensNatDefectIsBigOOne_of_eventuallyAbsBound
    (PrimeRecipSharpMertensNatDefectEventuallyAbsBound_of_converges h)

/-- A finite limiting Mertens constant gives the exact one-sided bounded-defect
form consumed by the rough-prime Euler-product lower bound. -/
theorem PrimeRecipSharpMertensNatDefectEventuallyUpperBound_of_converges
    (h : PrimeRecipSharpMertensNatDefectConverges) :
    PrimeRecipSharpMertensNatDefectEventuallyUpperBound :=
  PrimeRecipSharpMertensNatDefectEventuallyUpperBound_of_isBigOOne
    (PrimeRecipSharpMertensNatDefectIsBigOOne_of_converges h)

/-- Unconditional crude same-carrier envelope: the prime reciprocal sum is a
subsum of the harmonic series at the same cutoff.  This is much weaker than
Mertens' `log log N + O(1)` bound, but it verifies the finite carrier and gives
an axiom-free sanity upper bound. -/
theorem primeRecipSum_le_harmonic (N : ℕ) :
    (∑ p ∈ (Finset.Icc (2 : ℕ) N).filter (fun p => Nat.Prime p),
        (p : ℝ)⁻¹) ≤
      ((harmonic N : ℚ) : ℝ) := by
  classical
  rw [harmonic_eq_sum_Icc]
  simp_rw [Rat.cast_sum, Rat.cast_inv, Rat.cast_natCast]
  apply Finset.sum_le_sum_of_subset_of_nonneg
  · intro p hp
    have hpIcc : p ∈ Finset.Icc (2 : ℕ) N := (Finset.mem_filter.mp hp).1
    exact Finset.mem_Icc.mpr
      ⟨le_trans (by norm_num : (1 : ℕ) ≤ 2) (Finset.mem_Icc.mp hpIcc).1,
        (Finset.mem_Icc.mp hpIcc).2⟩
  · intro p _hp_all _hp_prime
    exact inv_nonneg.mpr (Nat.cast_nonneg p)

/-- Unconditional logarithmic same-carrier envelope for the prime reciprocal
sum.  The sharp Mertens input improves this from `O(log N)` to
`log log N + O(1)`. -/
theorem primeRecipSum_le_one_add_log (N : ℕ) :
    (∑ p ∈ (Finset.Icc (2 : ℕ) N).filter (fun p => Nat.Prime p),
        (p : ℝ)⁻¹) ≤
      1 + Real.log (N : ℝ) :=
  (primeRecipSum_le_harmonic N).trans (harmonic_le_one_add_log N)

/-- Unconditional defect-level harmonic fallback for the prime-reciprocal
Mertens carrier.  This is far weaker than Mertens' bounded defect, but it
checks the same finite prime-reciprocal carrier at the exact defect altitude. -/
theorem primeRecipSharpMertensNatDefect_le_one_add_log_sub_loglog (N : ℕ) :
    primeRecipSharpMertensNatDefect N ≤
      1 + Real.log (N : ℝ) - Real.log (Real.log (N : ℝ)) := by
  have hsum := primeRecipSum_le_one_add_log N
  dsimp [primeRecipSharpMertensNatDefect]
  linarith

/-- Once `log N ≥ 1`, the crude harmonic fallback gives an `O(log N)` bound for
the prime-reciprocal Mertens defect.  The remaining Mertens input is exactly
the improvement from this logarithmic envelope to an eventual constant. -/
theorem primeRecipSharpMertensNatDefect_le_two_mul_log_of_one_le_log
    (N : ℕ) (hlog : 1 ≤ Real.log (N : ℝ)) :
    primeRecipSharpMertensNatDefect N ≤ 2 * Real.log (N : ℝ) := by
  have hdef :=
    primeRecipSharpMertensNatDefect_le_one_add_log_sub_loglog N
  have hloglog_nonneg : 0 ≤ Real.log (Real.log (N : ℝ)) :=
    Real.log_nonneg hlog
  linarith

/-- Chebyshev upper bound for the finite prime-log carrier, proved from
Mathlib's primorial estimate.  This is the elementary input needed for the
dyadic route toward the sharp prime-reciprocal Mertens upper bound. -/
theorem primeLogSum_le_log_four_mul (N : ℕ) :
    (∑ p ∈ (Finset.Icc (1 : ℕ) N).filter (fun p => Nat.Prime p),
        Real.log (p : ℝ)) ≤
      Real.log (4 : ℝ) * (N : ℝ) := by
  classical
  let s := (Finset.range (N + 1)).filter Nat.Prime
  have hs_eq :
      (∑ p ∈ (Finset.Icc (1 : ℕ) N).filter (fun p => Nat.Prime p),
          Real.log (p : ℝ)) =
        ∑ p ∈ s, Real.log (p : ℝ) := by
    apply Finset.sum_congr
    · ext p
      by_cases hp : Nat.Prime p
      · simp [s, hp, hp.one_le, Nat.lt_succ_iff]
      · simp [s, hp]
    · intro p _hp
      rfl
  have hlog_prod :
      Real.log (∏ p ∈ s, (p : ℝ)) = ∑ p ∈ s, Real.log (p : ℝ) := by
    rw [Real.log_prod]
    intro p hp
    have hpPrime : Nat.Prime p := (Finset.mem_filter.mp hp).2
    exact_mod_cast hpPrime.ne_zero
  have hprod_cast :
      (∏ p ∈ s, (p : ℝ)) = ((primorial N : ℕ) : ℝ) := by
    unfold primorial
    simp [s]
  have hprim : ((primorial N : ℕ) : ℝ) ≤ (4 : ℝ) ^ N := by
    exact_mod_cast primorial_le_4_pow N
  have hprod_pos : 0 < (∏ p ∈ s, (p : ℝ)) := by
    rw [hprod_cast]
    exact_mod_cast primorial_pos N
  have hlog_le :
      Real.log (∏ p ∈ s, (p : ℝ)) ≤ Real.log ((4 : ℝ) ^ N) := by
    exact Real.log_le_log hprod_pos (by simpa [hprod_cast] using hprim)
  have hlog_pow : Real.log ((4 : ℝ) ^ N) = (N : ℝ) * Real.log (4 : ℝ) := by
    rw [Real.log_pow]
  rw [hs_eq, ← hlog_prod]
  calc
    Real.log (∏ p ∈ s, (p : ℝ)) ≤ Real.log ((4 : ℝ) ^ N) := hlog_le
    _ = (N : ℝ) * Real.log (4 : ℝ) := hlog_pow
    _ = Real.log (4 : ℝ) * (N : ℝ) := by ring

/-- Dyadic reciprocal-prime shell bound derived from the primorial/Chebyshev
upper estimate.  Summing these `1/k` shell bounds is the remaining elementary
dyadic step toward an unconditional proof of the sharp Mertens input. -/
theorem primeRecipDyadicBlock_le (k : ℕ) (hk : 1 ≤ k) :
    (∑ p ∈ (Finset.Ioc (2 ^ k) (2 ^ (k + 1))).filter (fun p => Nat.Prime p),
        (p : ℝ)⁻¹) ≤
      (2 * Real.log (4 : ℝ)) / ((k : ℝ) * Real.log (2 : ℝ)) := by
  classical
  let shell := (Finset.Ioc (2 ^ k) (2 ^ (k + 1))).filter
    (fun p : ℕ => Nat.Prime p)
  let A : ℝ := (((2 ^ k : ℕ) : ℝ)⁻¹) /
    ((k : ℝ) * Real.log (2 : ℝ))
  have hk_pos_real : 0 < (k : ℝ) := by exact_mod_cast hk
  have hlog2_pos : 0 < Real.log (2 : ℝ) := Real.log_pos (by norm_num)
  have hden_pos : 0 < (k : ℝ) * Real.log (2 : ℝ) :=
    mul_pos hk_pos_real hlog2_pos
  have hpow_pos : 0 < ((2 ^ k : ℕ) : ℝ) := by positivity
  have hA_nonneg : 0 ≤ A := by
    dsimp [A]
    exact div_nonneg (inv_nonneg.mpr hpow_pos.le) hden_pos.le
  have hterm : ∀ p ∈ shell, (p : ℝ)⁻¹ ≤ A * Real.log (p : ℝ) := by
    intro p hp
    have hpIoc : p ∈ Finset.Ioc (2 ^ k) (2 ^ (k + 1)) :=
      (Finset.mem_filter.mp hp).1
    have hpPrime : Nat.Prime p := (Finset.mem_filter.mp hp).2
    have hp_gt : 2 ^ k < p := (Finset.mem_Ioc.mp hpIoc).1
    have hpow_le_p : ((2 ^ k : ℕ) : ℝ) ≤ (p : ℝ) := by
      exact_mod_cast le_of_lt hp_gt
    have hinv_le : (p : ℝ)⁻¹ ≤ (((2 ^ k : ℕ) : ℝ)⁻¹) := by
      exact inv_anti₀ hpow_pos hpow_le_p
    have hlog_lower :
        (k : ℝ) * Real.log (2 : ℝ) ≤ Real.log (p : ℝ) := by
      have hlog_pow :
          Real.log (((2 ^ k : ℕ) : ℝ)) =
            (k : ℝ) * Real.log (2 : ℝ) := by
        rw [Nat.cast_pow, Real.log_pow]
        norm_num
      have hlog_le := Real.log_le_log hpow_pos hpow_le_p
      simpa [hlog_pow] using hlog_le
    have hratio :
        1 ≤ Real.log (p : ℝ) / ((k : ℝ) * Real.log (2 : ℝ)) := by
      rw [le_div_iff₀ hden_pos]
      simpa using hlog_lower
    have hscale : (((2 ^ k : ℕ) : ℝ)⁻¹) ≤ A * Real.log (p : ℝ) := by
      have hmul :=
        mul_le_mul_of_nonneg_left hratio (inv_nonneg.mpr hpow_pos.le)
      rw [mul_one] at hmul
      simpa [A, div_eq_mul_inv, mul_comm, mul_left_comm, mul_assoc] using hmul
    exact hinv_le.trans hscale
  have hsum_term :
      (∑ p ∈ shell, (p : ℝ)⁻¹) ≤
        A * (∑ p ∈ shell, Real.log (p : ℝ)) := by
    calc
      (∑ p ∈ shell, (p : ℝ)⁻¹)
          ≤ ∑ p ∈ shell, A * Real.log (p : ℝ) :=
            Finset.sum_le_sum hterm
      _ = A * (∑ p ∈ shell, Real.log (p : ℝ)) := by
            rw [Finset.mul_sum]
  have hshell_log_le_total :
      (∑ p ∈ shell, Real.log (p : ℝ)) ≤
        (∑ p ∈ (Finset.Icc (1 : ℕ) (2 ^ (k + 1))).filter
            (fun p => Nat.Prime p), Real.log (p : ℝ)) := by
    refine Finset.sum_le_sum_of_subset_of_nonneg ?hsub ?hnonneg
    · intro p hp
      have hpIoc : p ∈ Finset.Ioc (2 ^ k) (2 ^ (k + 1)) :=
        (Finset.mem_filter.mp hp).1
      have hpPrime : Nat.Prime p := (Finset.mem_filter.mp hp).2
      exact Finset.mem_filter.mpr
        ⟨Finset.mem_Icc.mpr
          ⟨by exact_mod_cast hpPrime.one_le, (Finset.mem_Ioc.mp hpIoc).2⟩,
          hpPrime⟩
    · intro p hp _hnot
      have hpPrime : Nat.Prime p := (Finset.mem_filter.mp hp).2
      exact Real.log_nonneg (by exact_mod_cast hpPrime.one_le)
  have htotal := primeLogSum_le_log_four_mul (2 ^ (k + 1))
  have hlog_shell_bound :
      (∑ p ∈ shell, Real.log (p : ℝ)) ≤
        Real.log (4 : ℝ) * ((2 ^ (k + 1) : ℕ) : ℝ) :=
    hshell_log_le_total.trans htotal
  have hmain :=
    hsum_term.trans (mul_le_mul_of_nonneg_left hlog_shell_bound hA_nonneg)
  have hcalc :
      A * (Real.log (4 : ℝ) * ((2 ^ (k + 1) : ℕ) : ℝ)) =
        (2 * Real.log (4 : ℝ)) / ((k : ℝ) * Real.log (2 : ℝ)) := by
    dsimp [A]
    have hpow_ne : ((2 ^ k : ℕ) : ℝ) ≠ 0 := ne_of_gt hpow_pos
    field_simp [hpow_ne, ne_of_gt hden_pos]
    rw [pow_succ]
    ring
  calc
    (∑ p ∈ (Finset.Ioc (2 ^ k) (2 ^ (k + 1))).filter
        (fun p => Nat.Prime p), (p : ℝ)⁻¹)
        = ∑ p ∈ shell, (p : ℝ)⁻¹ := by rfl
    _ ≤ A * (Real.log (4 : ℝ) * ((2 ^ (k + 1) : ℕ) : ℝ)) := hmain
    _ = (2 * Real.log (4 : ℝ)) / ((k : ℝ) * Real.log (2 : ℝ)) := hcalc

/-- Finite dyadic summation of the Chebyshev/primorial prime-reciprocal shell
bound.  This is the verified harmonic-sum layer in the elementary dyadic route;
the remaining sharp-Mertens gap is the coefficient-one analytic strengthening,
not the finite shell bookkeeping. -/
theorem primeRecipDyadicBlocks_sum_le (K : ℕ) :
    (∑ k ∈ Finset.Icc (1 : ℕ) K,
      ∑ p ∈ (Finset.Ioc (2 ^ k) (2 ^ (k + 1))).filter (fun p => Nat.Prime p),
        (p : ℝ)⁻¹) ≤
      ((2 * Real.log (4 : ℝ)) / Real.log (2 : ℝ)) *
        ((harmonic K : ℚ) : ℝ) := by
  classical
  let C : ℝ := (2 * Real.log (4 : ℝ)) / Real.log (2 : ℝ)
  have hlog2_ne : Real.log (2 : ℝ) ≠ 0 :=
    ne_of_gt (Real.log_pos (by norm_num))
  have hterm :
      ∀ k ∈ Finset.Icc (1 : ℕ) K,
        (∑ p ∈ (Finset.Ioc (2 ^ k) (2 ^ (k + 1))).filter
          (fun p => Nat.Prime p), (p : ℝ)⁻¹) ≤ C * (k : ℝ)⁻¹ := by
    intro k hk
    have hk_one : 1 ≤ k := (Finset.mem_Icc.mp hk).1
    have hk_pos : 0 < (k : ℝ) := by exact_mod_cast hk_one
    have hk_ne : (k : ℝ) ≠ 0 := ne_of_gt hk_pos
    have hshell := primeRecipDyadicBlock_le k hk_one
    have hrewrite :
        (2 * Real.log (4 : ℝ)) / ((k : ℝ) * Real.log (2 : ℝ)) =
          C * (k : ℝ)⁻¹ := by
      dsimp [C]
      field_simp [hk_ne, hlog2_ne]
      ring
    simpa [hrewrite] using hshell
  calc
    (∑ k ∈ Finset.Icc (1 : ℕ) K,
      ∑ p ∈ (Finset.Ioc (2 ^ k) (2 ^ (k + 1))).filter (fun p => Nat.Prime p),
        (p : ℝ)⁻¹)
        ≤ ∑ k ∈ Finset.Icc (1 : ℕ) K, C * (k : ℝ)⁻¹ :=
          Finset.sum_le_sum hterm
    _ = C * (∑ k ∈ Finset.Icc (1 : ℕ) K, (k : ℝ)⁻¹) := by
          rw [Finset.mul_sum]
    _ = C * ((harmonic K : ℚ) : ℝ) := by
          rw [harmonic_eq_sum_Icc]
          simp only [Rat.cast_sum, Rat.cast_inv, Rat.cast_natCast]

/-- Logarithmic envelope for the verified dyadic Chebyshev/primorial
prime-reciprocal block sum.  This is still weaker than sharp Mertens because
the coefficient of `log K` is the Chebyshev constant
`2 log 4 / log 2`, but the finite harmonic-to-log step is axiom-free. -/
theorem primeRecipDyadicBlocks_sum_le_one_add_log (K : ℕ) :
    (∑ k ∈ Finset.Icc (1 : ℕ) K,
      ∑ p ∈ (Finset.Ioc (2 ^ k) (2 ^ (k + 1))).filter (fun p => Nat.Prime p),
        (p : ℝ)⁻¹) ≤
      ((2 * Real.log (4 : ℝ)) / Real.log (2 : ℝ)) *
        (1 + Real.log (K : ℝ)) := by
  let C : ℝ := (2 * Real.log (4 : ℝ)) / Real.log (2 : ℝ)
  have hC_nonneg : 0 ≤ C := by
    dsimp [C]
    exact div_nonneg
      (mul_nonneg (by norm_num) (Real.log_nonneg (by norm_num)))
      (Real.log_pos (by norm_num)).le
  exact (primeRecipDyadicBlocks_sum_le K).trans
    (mul_le_mul_of_nonneg_left (harmonic_le_one_add_log K) hC_nonneg)

/-- The dyadic shells from `1` through `K` cover the prime-reciprocal sum up to
`2^(K+1)`, apart from the prime `2`.  This is pure finite interval bookkeeping:
it contains no prime-number-theorem or Mertens content. -/
theorem primeRecipSum_two_pow_succ_le_dyadicBlocks (K : ℕ) :
    (∑ p ∈ (Finset.Icc (2 : ℕ) (2 ^ (K + 1))).filter (fun p => Nat.Prime p),
        (p : ℝ)⁻¹) ≤
      (2 : ℝ)⁻¹ +
        ∑ k ∈ Finset.Icc (1 : ℕ) K,
          ∑ p ∈ (Finset.Ioc (2 ^ k) (2 ^ (k + 1))).filter (fun p => Nat.Prime p),
            (p : ℝ)⁻¹ := by
  classical
  induction K with
  | zero =>
      have hfilter :
          (Finset.Icc (2 : ℕ) (2 ^ (0 + 1))).filter (fun p => Nat.Prime p) =
            ({2} : Finset ℕ) := by
        ext p
        by_cases hp : p = 2
        · simp [hp, Nat.prime_two]
        · simp [hp]
      rw [hfilter]
      norm_num
  | succ K ih =>
      let mid : ℕ := 2 ^ (K + 1)
      let top : ℕ := 2 ^ ((K + 1) + 1)
      let A : Finset ℕ := (Finset.Icc (2 : ℕ) mid).filter (fun p => Nat.Prime p)
      let B : Finset ℕ := (Finset.Ioc mid top).filter (fun p => Nat.Prime p)
      have htwo_le_mid : 2 ≤ mid := by
        dsimp [mid]
        exact Nat.pow_le_pow_right (by norm_num : 1 ≤ 2)
          (by omega : 1 ≤ K + 1)
      have hmid_le_top : mid ≤ top := by
        dsimp [mid, top]
        exact Nat.pow_le_pow_right (by norm_num : 1 ≤ 2)
          (by omega : K + 1 ≤ (K + 1) + 1)
      have hsplit_set :
          (Finset.Icc (2 : ℕ) top).filter (fun p => Nat.Prime p) = A ∪ B := by
        ext p
        by_cases hp : Nat.Prime p
        · simp [A, B, hp, htwo_le_mid, hmid_le_top]
          omega
        · simp [A, B, hp]
      have hdisj : Disjoint A B := by
        rw [Finset.disjoint_left]
        intro p hpA hpB
        have hpA' : p ∈ Finset.Icc (2 : ℕ) mid := (Finset.mem_filter.mp hpA).1
        have hpB' : p ∈ Finset.Ioc mid top := (Finset.mem_filter.mp hpB).1
        exact (not_lt_of_ge (Finset.mem_Icc.mp hpA').2) (Finset.mem_Ioc.mp hpB').1
      have hsplit_sum :
          (∑ p ∈ (Finset.Icc (2 : ℕ) top).filter (fun p => Nat.Prime p),
              (p : ℝ)⁻¹) =
            (∑ p ∈ A, (p : ℝ)⁻¹) + ∑ p ∈ B, (p : ℝ)⁻¹ := by
        rw [hsplit_set, Finset.sum_union hdisj]
      have hA :
          (∑ p ∈ A, (p : ℝ)⁻¹) =
            ∑ p ∈ (Finset.Icc (2 : ℕ) (2 ^ (K + 1))).filter
              (fun p => Nat.Prime p), (p : ℝ)⁻¹ := by
        rfl
      have hB :
          (∑ p ∈ B, (p : ℝ)⁻¹) =
            ∑ p ∈ (Finset.Ioc (2 ^ (K + 1)) (2 ^ ((K + 1) + 1))).filter
              (fun p => Nat.Prime p), (p : ℝ)⁻¹ := by
        rfl
      have hblocks_succ :
          (∑ k ∈ Finset.Icc (1 : ℕ) (K + 1),
            ∑ p ∈ (Finset.Ioc (2 ^ k) (2 ^ (k + 1))).filter
              (fun p => Nat.Prime p), (p : ℝ)⁻¹) =
            (∑ k ∈ Finset.Icc (1 : ℕ) K,
              ∑ p ∈ (Finset.Ioc (2 ^ k) (2 ^ (k + 1))).filter
                (fun p => Nat.Prime p), (p : ℝ)⁻¹) +
              ∑ p ∈ (Finset.Ioc (2 ^ (K + 1)) (2 ^ ((K + 1) + 1))).filter
                (fun p => Nat.Prime p), (p : ℝ)⁻¹ := by
        have hnot : K + 1 ∉ Finset.Icc (1 : ℕ) K := by
          simp
        have hIcc :
            insert (K + 1) (Finset.Icc (1 : ℕ) K) =
              Finset.Icc (1 : ℕ) (K + 1) := by
          ext k
          simp
          omega
        rw [← hIcc, Finset.sum_insert hnot]
        ring
      calc
        (∑ p ∈ (Finset.Icc (2 : ℕ) (2 ^ ((K + 1) + 1))).filter
            (fun p => Nat.Prime p), (p : ℝ)⁻¹)
            = (∑ p ∈ A, (p : ℝ)⁻¹) + ∑ p ∈ B, (p : ℝ)⁻¹ := hsplit_sum
        _ = (∑ p ∈ (Finset.Icc (2 : ℕ) (2 ^ (K + 1))).filter
              (fun p => Nat.Prime p), (p : ℝ)⁻¹) +
              ∑ p ∈ (Finset.Ioc (2 ^ (K + 1)) (2 ^ ((K + 1) + 1))).filter
                (fun p => Nat.Prime p), (p : ℝ)⁻¹ := by
            rw [hA, hB]
        _ ≤ ((2 : ℝ)⁻¹ +
              ∑ k ∈ Finset.Icc (1 : ℕ) K,
                ∑ p ∈ (Finset.Ioc (2 ^ k) (2 ^ (k + 1))).filter
                  (fun p => Nat.Prime p), (p : ℝ)⁻¹) +
              ∑ p ∈ (Finset.Ioc (2 ^ (K + 1)) (2 ^ ((K + 1) + 1))).filter
                (fun p => Nat.Prime p), (p : ℝ)⁻¹ :=
            add_le_add_right ih _
        _ = (2 : ℝ)⁻¹ +
              ∑ k ∈ Finset.Icc (1 : ℕ) (K + 1),
                ∑ p ∈ (Finset.Ioc (2 ^ k) (2 ^ (k + 1))).filter
                  (fun p => Nat.Prime p), (p : ℝ)⁻¹ := by
            rw [hblocks_succ]
            ring

/-- The dyadic shells through `K` are contained in the ordinary
prime-reciprocal sum up to `2^(K+1)`.  This is the reverse finite-covering
inequality to `primeRecipSum_two_pow_succ_le_dyadicBlocks`: together the two
show that the dyadic block formulation of Mertens is not losing hidden finite
content. -/
theorem primeRecipDyadicBlocks_le_primeRecipSum_two_pow_succ (K : ℕ) :
    (∑ k ∈ Finset.Icc (1 : ℕ) K,
      ∑ p ∈ (Finset.Ioc (2 ^ k) (2 ^ (k + 1))).filter (fun p => Nat.Prime p),
        (p : ℝ)⁻¹) ≤
      ∑ p ∈ (Finset.Icc (2 : ℕ) (2 ^ (K + 1))).filter (fun p => Nat.Prime p),
        (p : ℝ)⁻¹ := by
  classical
  induction K with
  | zero =>
      have hnonneg :
          0 ≤ ∑ p ∈ (Finset.Icc (2 : ℕ) (2 ^ (0 + 1))).filter
              (fun p => Nat.Prime p), (p : ℝ)⁻¹ := by
        exact Finset.sum_nonneg (fun p _hp => inv_nonneg.mpr (Nat.cast_nonneg p))
      simpa using hnonneg
  | succ K ih =>
      let mid : ℕ := 2 ^ (K + 1)
      let top : ℕ := 2 ^ ((K + 1) + 1)
      let A : Finset ℕ := (Finset.Icc (2 : ℕ) mid).filter (fun p => Nat.Prime p)
      let B : Finset ℕ := (Finset.Ioc mid top).filter (fun p => Nat.Prime p)
      have htwo_le_mid : 2 ≤ mid := by
        dsimp [mid]
        exact Nat.pow_le_pow_right (by norm_num : 1 ≤ 2)
          (by omega : 1 ≤ K + 1)
      have hmid_le_top : mid ≤ top := by
        dsimp [mid, top]
        exact Nat.pow_le_pow_right (by norm_num : 1 ≤ 2)
          (by omega : K + 1 ≤ (K + 1) + 1)
      have hsplit_set :
          (Finset.Icc (2 : ℕ) top).filter (fun p => Nat.Prime p) = A ∪ B := by
        ext p
        by_cases hp : Nat.Prime p
        · simp [A, B, hp, htwo_le_mid, hmid_le_top]
          omega
        · simp [A, B, hp]
      have hdisj : Disjoint A B := by
        rw [Finset.disjoint_left]
        intro p hpA hpB
        have hpA' : p ∈ Finset.Icc (2 : ℕ) mid := (Finset.mem_filter.mp hpA).1
        have hpB' : p ∈ Finset.Ioc mid top := (Finset.mem_filter.mp hpB).1
        exact (not_lt_of_ge (Finset.mem_Icc.mp hpA').2) (Finset.mem_Ioc.mp hpB').1
      have hsplit_sum :
          (∑ p ∈ (Finset.Icc (2 : ℕ) top).filter (fun p => Nat.Prime p),
              (p : ℝ)⁻¹) =
            (∑ p ∈ A, (p : ℝ)⁻¹) + ∑ p ∈ B, (p : ℝ)⁻¹ := by
        rw [hsplit_set, Finset.sum_union hdisj]
      have hA :
          (∑ p ∈ A, (p : ℝ)⁻¹) =
            ∑ p ∈ (Finset.Icc (2 : ℕ) (2 ^ (K + 1))).filter
              (fun p => Nat.Prime p), (p : ℝ)⁻¹ := by
        rfl
      have hB :
          (∑ p ∈ B, (p : ℝ)⁻¹) =
            ∑ p ∈ (Finset.Ioc (2 ^ (K + 1)) (2 ^ ((K + 1) + 1))).filter
              (fun p => Nat.Prime p), (p : ℝ)⁻¹ := by
        rfl
      have hblocks_succ :
          (∑ k ∈ Finset.Icc (1 : ℕ) (K + 1),
            ∑ p ∈ (Finset.Ioc (2 ^ k) (2 ^ (k + 1))).filter
              (fun p => Nat.Prime p), (p : ℝ)⁻¹) =
            (∑ k ∈ Finset.Icc (1 : ℕ) K,
              ∑ p ∈ (Finset.Ioc (2 ^ k) (2 ^ (k + 1))).filter
                (fun p => Nat.Prime p), (p : ℝ)⁻¹) +
              ∑ p ∈ (Finset.Ioc (2 ^ (K + 1)) (2 ^ ((K + 1) + 1))).filter
                (fun p => Nat.Prime p), (p : ℝ)⁻¹ := by
        have hnot : K + 1 ∉ Finset.Icc (1 : ℕ) K := by
          simp
        have hIcc :
            insert (K + 1) (Finset.Icc (1 : ℕ) K) =
              Finset.Icc (1 : ℕ) (K + 1) := by
          ext k
          simp
          omega
        rw [← hIcc, Finset.sum_insert hnot]
        ring
      calc
        (∑ k ∈ Finset.Icc (1 : ℕ) (K + 1),
          ∑ p ∈ (Finset.Ioc (2 ^ k) (2 ^ (k + 1))).filter
            (fun p => Nat.Prime p), (p : ℝ)⁻¹)
            = (∑ k ∈ Finset.Icc (1 : ℕ) K,
                ∑ p ∈ (Finset.Ioc (2 ^ k) (2 ^ (k + 1))).filter
                  (fun p => Nat.Prime p), (p : ℝ)⁻¹) +
                ∑ p ∈ (Finset.Ioc (2 ^ (K + 1)) (2 ^ ((K + 1) + 1))).filter
                  (fun p => Nat.Prime p), (p : ℝ)⁻¹ := hblocks_succ
        _ ≤ (∑ p ∈ (Finset.Icc (2 : ℕ) (2 ^ (K + 1))).filter
                (fun p => Nat.Prime p), (p : ℝ)⁻¹) +
              ∑ p ∈ (Finset.Ioc (2 ^ (K + 1)) (2 ^ ((K + 1) + 1))).filter
                (fun p => Nat.Prime p), (p : ℝ)⁻¹ :=
            add_le_add_right ih _
        _ = ∑ p ∈ (Finset.Icc (2 : ℕ) (2 ^ ((K + 1) + 1))).filter
              (fun p => Nat.Prime p), (p : ℝ)⁻¹ := by
            rw [hsplit_sum, hA, hB]

/-- Arbitrary-cutoff version of the verified dyadic coverage bound.  Choosing
`K = floor(log_2 N)` covers every prime up to `N` by the dyadic shells through
`K`, plus the prime `2`. -/
theorem primeRecipSum_le_half_add_dyadicBlocks_log (N : ℕ) :
    (∑ p ∈ (Finset.Icc (2 : ℕ) N).filter (fun p => Nat.Prime p),
        (p : ℝ)⁻¹) ≤
      (2 : ℝ)⁻¹ +
        ∑ k ∈ Finset.Icc (1 : ℕ) (Nat.log 2 N),
          ∑ p ∈ (Finset.Ioc (2 ^ k) (2 ^ (k + 1))).filter
            (fun p => Nat.Prime p), (p : ℝ)⁻¹ := by
  classical
  let K : ℕ := Nat.log 2 N
  have hN_le_top : N ≤ 2 ^ (K + 1) := by
    have hlt : N < 2 ^ (K + 1) := by
      simpa [K, Nat.succ_eq_add_one] using
        Nat.lt_pow_succ_log_self (by norm_num : 1 < 2) N
    exact le_of_lt hlt
  have hsubset :
      (Finset.Icc (2 : ℕ) N).filter (fun p => Nat.Prime p) ⊆
        (Finset.Icc (2 : ℕ) (2 ^ (K + 1))).filter (fun p => Nat.Prime p) := by
    intro p hp
    have hpIcc : p ∈ Finset.Icc (2 : ℕ) N := (Finset.mem_filter.mp hp).1
    have hpPrime : Nat.Prime p := (Finset.mem_filter.mp hp).2
    exact Finset.mem_filter.mpr
      ⟨Finset.mem_Icc.mpr
        ⟨(Finset.mem_Icc.mp hpIcc).1, (Finset.mem_Icc.mp hpIcc).2.trans hN_le_top⟩,
        hpPrime⟩
  have hsum_le :
      (∑ p ∈ (Finset.Icc (2 : ℕ) N).filter (fun p => Nat.Prime p),
          (p : ℝ)⁻¹) ≤
        ∑ p ∈ (Finset.Icc (2 : ℕ) (2 ^ (K + 1))).filter
          (fun p => Nat.Prime p), (p : ℝ)⁻¹ := by
    refine Finset.sum_le_sum_of_subset_of_nonneg hsubset ?_
    intro p _hp_big _hp_small
    exact inv_nonneg.mpr (Nat.cast_nonneg p)
  exact hsum_le.trans (by
    simpa [K] using primeRecipSum_two_pow_succ_le_dyadicBlocks K)

/-- Weak Mertens envelope with the natural dyadic logarithm.  This is
unconditional and already has the right `log log` architecture; what remains
external in sharp Mertens is the coefficient-one analytic improvement. -/
theorem primeRecipSum_le_half_add_dyadicLog_envelope (N : ℕ) :
    (∑ p ∈ (Finset.Icc (2 : ℕ) N).filter (fun p => Nat.Prime p),
        (p : ℝ)⁻¹) ≤
      (2 : ℝ)⁻¹ +
        ((2 * Real.log (4 : ℝ)) / Real.log (2 : ℝ)) *
          (1 + Real.log ((Nat.log 2 N : ℕ) : ℝ)) := by
  let K : ℕ := Nat.log 2 N
  have hcover := primeRecipSum_le_half_add_dyadicBlocks_log N
  have hblocks := primeRecipDyadicBlocks_sum_le_one_add_log K
  exact hcover.trans (by
    simpa [K] using add_le_add_left hblocks ((2 : ℝ)⁻¹))

/-- The dyadic logarithm is bounded by the real logarithm, in logarithmic form.
For `N >= 4` this gives the real `log log N` version of the weak Chebyshev
Mertens bound. -/
theorem log_natLog_two_le_loglog_sub_loglog_two
    {N : ℕ} (hN : 4 ≤ N) :
    Real.log ((Nat.log 2 N : ℕ) : ℝ) ≤
      Real.log (Real.log (N : ℝ)) - Real.log (Real.log (2 : ℝ)) := by
  let K : ℕ := Nat.log 2 N
  have hN_ne_zero : N ≠ 0 := by omega
  have hK_ge_two : 2 ≤ K := by
    exact Nat.le_log_of_pow_le (by norm_num : 1 < 2)
      (by simpa [K] using hN)
  have hK_pos : 0 < (K : ℝ) := by exact_mod_cast (lt_of_lt_of_le (by norm_num : 0 < 2) hK_ge_two)
  have hN_pos : 0 < (N : ℝ) := by exact_mod_cast (lt_of_lt_of_le (by norm_num : 0 < 4) hN)
  have hN_gt_one : (1 : ℝ) < (N : ℝ) := by exact_mod_cast (lt_of_lt_of_le (by norm_num : 1 < 4) hN)
  have hlogN_pos : 0 < Real.log (N : ℝ) := Real.log_pos hN_gt_one
  have hlog2_pos : 0 < Real.log (2 : ℝ) := Real.log_pos (by norm_num)
  have hpow_le : 2 ^ K ≤ N := by
    simpa [K] using Nat.pow_log_le_self 2 hN_ne_zero
  have hpow_pos : 0 < ((2 ^ K : ℕ) : ℝ) := by positivity
  have hpow_le_real : ((2 ^ K : ℕ) : ℝ) ≤ (N : ℝ) := by
    exact_mod_cast hpow_le
  have hlog_pow :
      Real.log (((2 ^ K : ℕ) : ℝ)) = (K : ℝ) * Real.log (2 : ℝ) := by
    rw [Nat.cast_pow, Real.log_pow]
    norm_num
  have hK_log_le_logN :
      (K : ℝ) * Real.log (2 : ℝ) ≤ Real.log (N : ℝ) := by
    simpa [hlog_pow] using Real.log_le_log hpow_pos hpow_le_real
  have hK_le_div :
      (K : ℝ) ≤ Real.log (N : ℝ) / Real.log (2 : ℝ) := by
    rw [le_div_iff₀ hlog2_pos]
    simpa [mul_comm] using hK_log_le_logN
  have hdiv_pos : 0 < Real.log (N : ℝ) / Real.log (2 : ℝ) :=
    div_pos hlogN_pos hlog2_pos
  have hlog_le :
      Real.log (K : ℝ) ≤ Real.log (Real.log (N : ℝ) / Real.log (2 : ℝ)) :=
    Real.log_le_log hK_pos hK_le_div
  have hlog_div :
      Real.log (Real.log (N : ℝ) / Real.log (2 : ℝ)) =
        Real.log (Real.log (N : ℝ)) - Real.log (Real.log (2 : ℝ)) := by
    rw [Real.log_div (ne_of_gt hlogN_pos) (ne_of_gt hlog2_pos)]
  simpa [K, hlog_div] using hlog_le

/-- Proved in Lean weak-Mertens bound obtained from Chebyshev/primorial plus finite
dyadic summation.  The coefficient is the Chebyshev constant
`2 log 4 / log 2`, not the sharp Mertens coefficient `1`. -/
theorem primeRecipSum_le_chebyshev_loglog_envelope
    {N : ℕ} (hN : 4 ≤ N) :
    (∑ p ∈ (Finset.Icc (2 : ℕ) N).filter (fun p => Nat.Prime p),
        (p : ℝ)⁻¹) ≤
      (2 : ℝ)⁻¹ +
        ((2 * Real.log (4 : ℝ)) / Real.log (2 : ℝ)) *
          (1 + (Real.log (Real.log (N : ℝ)) -
            Real.log (Real.log (2 : ℝ)))) := by
  let C : ℝ := (2 * Real.log (4 : ℝ)) / Real.log (2 : ℝ)
  have hC_nonneg : 0 ≤ C := by
    dsimp [C]
    exact div_nonneg
      (mul_nonneg (by norm_num) (Real.log_nonneg (by norm_num)))
      (Real.log_pos (by norm_num)).le
  have hbase := primeRecipSum_le_half_add_dyadicLog_envelope N
  have hlog := log_natLog_two_le_loglog_sub_loglog_two hN
  have hinside :
      1 + Real.log ((Nat.log 2 N : ℕ) : ℝ) ≤
        1 + (Real.log (Real.log (N : ℝ)) -
          Real.log (Real.log (2 : ℝ))) := by
    exact add_le_add_left hlog 1
  exact hbase.trans
    (add_le_add_left (mul_le_mul_of_nonneg_left hinside hC_nonneg) ((2 : ℝ)⁻¹))

/-- Exact-defect form of the verified Chebyshev/primorial dyadic route.  This
is stronger than the harmonic `O(log N)` fallback: it reaches the `log log N`
scale on the same finite carrier.  What remains external in sharp Mertens is
the coefficient-one strengthening and bounded residual term. -/
theorem primeRecipSharpMertensNatDefect_le_chebyshev_loglog_envelope
    {N : ℕ} (hN : 4 ≤ N) :
    primeRecipSharpMertensNatDefect N ≤
      (((2 * Real.log (4 : ℝ)) / Real.log (2 : ℝ)) - 1) *
          Real.log (Real.log (N : ℝ)) +
        ((2 : ℝ)⁻¹ +
          ((2 * Real.log (4 : ℝ)) / Real.log (2 : ℝ)) *
            (1 - Real.log (Real.log (2 : ℝ)))) := by
  have hsum := primeRecipSum_le_chebyshev_loglog_envelope hN
  dsimp [primeRecipSharpMertensNatDefect]
  linarith

/-- Coefficient-one dyadic-block formulation of the prime-reciprocal Mertens
upper bound.  It isolates the genuinely analytic strengthening missing from the
verified Chebyshev/primorial route: the finite dyadic shells must sum with
leading coefficient `1` in `log K`, up to an eventual additive constant. -/
def PrimeRecipDyadicBlocksSharpUpperBound : Prop :=
  ∃ B : ℝ, ∃ K₀ : ℕ, ∀ K : ℕ, K₀ ≤ K →
    (∑ k ∈ Finset.Icc (1 : ℕ) K,
      ∑ p ∈ (Finset.Ioc (2 ^ k) (2 ^ (k + 1))).filter (fun p => Nat.Prime p),
        (p : ℝ)⁻¹) ≤ Real.log (K : ℝ) + B

/-- Harmonic-error dyadic-block formulation of prime-reciprocal Mertens.
This is the partial-summation target: the dyadic prime-reciprocal block sum
differs above from the ambient harmonic sum by at most an eventual constant. -/
def PrimeRecipDyadicBlocksHarmonicBoundedError : Prop :=
  ∃ B : ℝ, ∃ K₀ : ℕ, ∀ K : ℕ, K₀ ≤ K →
    (∑ k ∈ Finset.Icc (1 : ℕ) K,
      ∑ p ∈ (Finset.Ioc (2 ^ k) (2 ^ (k + 1))).filter (fun p => Nat.Prime p),
        (p : ℝ)⁻¹) - ((harmonic K : ℚ) : ℝ) ≤ B

/-- The logarithm is bounded by the same-cutoff harmonic number. -/
theorem log_natCast_le_harmonic (K : ℕ) :
    Real.log (K : ℝ) ≤ ((harmonic K : ℚ) : ℝ) := by
  have h :=
    log_le_harmonic_floor ((K : ℕ) : ℝ) (by positivity : (0 : ℝ) ≤ (K : ℝ))
  simpa [Nat.floor_natCast] using h

/-- A dyadic harmonic-error bound gives the coefficient-one dyadic-block
Mertens formulation.  The only extra work is the checked elementary comparison
`H_K ≤ 1 + log K`. -/
theorem PrimeRecipDyadicBlocksSharpUpperBound_of_harmonicBoundedError
    (h : PrimeRecipDyadicBlocksHarmonicBoundedError) :
    PrimeRecipDyadicBlocksSharpUpperBound := by
  rcases h with ⟨B, K₀, hB⟩
  refine ⟨1 + B, K₀, ?_⟩
  intro K hK
  have hdiff := hB K hK
  have hharm : ((harmonic K : ℚ) : ℝ) ≤ 1 + Real.log (K : ℝ) :=
    harmonic_le_one_add_log K
  linarith

/-- The coefficient-one dyadic-block formulation gives the harmonic-error
formulation.  This direction uses only the elementary lower bound
`log K ≤ H_K`. -/
theorem PrimeRecipDyadicBlocksHarmonicBoundedError_of_sharpUpperBound
    (h : PrimeRecipDyadicBlocksSharpUpperBound) :
    PrimeRecipDyadicBlocksHarmonicBoundedError := by
  rcases h with ⟨B, K₀, hB⟩
  refine ⟨B, K₀, ?_⟩
  intro K hK
  have hsum := hB K hK
  have hlog_le_harm := log_natCast_le_harmonic K
  linarith

/-- The harmonic-error and coefficient-one dyadic-block formulations have the
same analytic content.  This records that the remaining Mertens gap can be
attacked as a bounded partial-summation error against the ordinary harmonic
series, with no hidden finite-interval bookkeeping. -/
theorem PrimeRecipDyadicBlocksHarmonicBoundedError_iff_sharpUpperBound :
    PrimeRecipDyadicBlocksHarmonicBoundedError ↔
      PrimeRecipDyadicBlocksSharpUpperBound := by
  constructor
  · exact PrimeRecipDyadicBlocksSharpUpperBound_of_harmonicBoundedError
  · exact PrimeRecipDyadicBlocksHarmonicBoundedError_of_sharpUpperBound

/-- A coefficient-one dyadic-block estimate discharges the exact natural-cutoff
Mertens defect input.  All interval coverage, floor-log transfer, and
`log log` bookkeeping are checked here; only the coefficient-one dyadic block
estimate remains external in this route. -/
theorem PrimeRecipSharpMertensNatDefectEventuallyUpperBound_of_dyadicBlocksSharpUpperBound
    (h : PrimeRecipDyadicBlocksSharpUpperBound) :
    PrimeRecipSharpMertensNatDefectEventuallyUpperBound := by
  rcases h with ⟨B, K₀, hblocks⟩
  refine ⟨(2 : ℝ)⁻¹ + B - Real.log (Real.log (2 : ℝ)), ?_⟩
  rw [Filter.eventually_atTop]
  refine ⟨max 4 (2 ^ K₀), ?_⟩
  intro N hN
  let K : ℕ := Nat.log 2 N
  have hN_four : 4 ≤ N := le_trans (le_max_left _ _) hN
  have hpow_le : 2 ^ K₀ ≤ N := le_trans (le_max_right _ _) hN
  have hK₀ : K₀ ≤ K := by
    exact Nat.le_log_of_pow_le (by norm_num : 1 < 2) (by simpa using hpow_le)
  have hcover := primeRecipSum_le_half_add_dyadicBlocks_log N
  have hblock := hblocks K hK₀
  have hlog := log_natLog_two_le_loglog_sub_loglog_two hN_four
  have hsum :
      (∑ p ∈ (Finset.Icc (2 : ℕ) N).filter (fun p => Nat.Prime p),
          (p : ℝ)⁻¹) ≤
        Real.log (Real.log (N : ℝ)) +
          ((2 : ℝ)⁻¹ + B - Real.log (Real.log (2 : ℝ))) := by
    calc
      (∑ p ∈ (Finset.Icc (2 : ℕ) N).filter (fun p => Nat.Prime p),
          (p : ℝ)⁻¹)
          ≤ (2 : ℝ)⁻¹ +
            ∑ k ∈ Finset.Icc (1 : ℕ) K,
              ∑ p ∈ (Finset.Ioc (2 ^ k) (2 ^ (k + 1))).filter
                (fun p => Nat.Prime p), (p : ℝ)⁻¹ := by
              simpa [K] using hcover
      _ ≤ (2 : ℝ)⁻¹ + (Real.log (K : ℝ) + B) := by
              exact add_le_add_left hblock ((2 : ℝ)⁻¹)
      _ = Real.log (K : ℝ) + ((2 : ℝ)⁻¹ + B) := by ring
      _ ≤ (Real.log (Real.log (N : ℝ)) - Real.log (Real.log (2 : ℝ))) +
            ((2 : ℝ)⁻¹ + B) := by
              exact add_le_add_right (by simpa [K] using hlog) ((2 : ℝ)⁻¹ + B)
      _ = Real.log (Real.log (N : ℝ)) +
            ((2 : ℝ)⁻¹ + B - Real.log (Real.log (2 : ℝ))) := by ring
  dsimp [primeRecipSharpMertensNatDefect]
  linarith

/-- A dyadic harmonic-error estimate discharges the exact natural-cutoff
Mertens defect input.  This is the direct route from the sharper
partial-summation target to the live rough-sieve Mertens API. -/
theorem PrimeRecipSharpMertensNatDefectEventuallyUpperBound_of_dyadicBlocksHarmonicBoundedError
    (h : PrimeRecipDyadicBlocksHarmonicBoundedError) :
    PrimeRecipSharpMertensNatDefectEventuallyUpperBound :=
  PrimeRecipSharpMertensNatDefectEventuallyUpperBound_of_dyadicBlocksSharpUpperBound
    (PrimeRecipDyadicBlocksSharpUpperBound_of_harmonicBoundedError h)

/-- The natural-number-constant natural-cutoff Mertens statement immediately
gives the conventional real-constant statement. -/
theorem PrimeRecipSharpMertensNatRealConstantUpperBound_of_nat
    (h : PrimeRecipSharpMertensNatUpperBound) :
    PrimeRecipSharpMertensNatRealConstantUpperBound := by
  rcases h with ⟨K, N₀, hN⟩
  exact ⟨(K : ℝ), N₀, hN⟩

/-- The conventional real-constant natural-cutoff Mertens statement implies the
natural-number-constant version after rounding the additive constant upward. -/
theorem PrimeRecipSharpMertensNatUpperBound_of_natRealConstant
    (h : PrimeRecipSharpMertensNatRealConstantUpperBound) :
    PrimeRecipSharpMertensNatUpperBound := by
  rcases h with ⟨K, N₀, hN⟩
  let KNat : ℕ := ⌊max K 0⌋₊ + 1
  refine ⟨KNat, N₀, ?_⟩
  intro N hN₀
  have hK_le : K ≤ (KNat : ℝ) := by
    have hK_nonneg_le : K ≤ max K 0 := le_max_left _ _
    have hfloor_lt :
        max K 0 < ((⌊max K 0⌋₊ : ℕ) : ℝ) + 1 := by
      exact Nat.lt_floor_add_one (max K 0)
    have hfloor_lt' : max K 0 < (KNat : ℝ) := by
      dsimp [KNat]
      simpa [Nat.cast_add, Nat.cast_one] using hfloor_lt
    exact le_trans hK_nonneg_le (le_of_lt hfloor_lt')
  exact (hN N hN₀).trans (add_le_add_left hK_le _)

/-- Natural-cutoff Mertens control implies the coefficient-one dyadic block
formulation.  This is the reverse direction to
`PrimeRecipSharpMertensNatDefectEventuallyUpperBound_of_dyadicBlocksSharpUpperBound`
up to the already checked equivalence between defect and natural-cutoff
formulations. -/
theorem PrimeRecipDyadicBlocksSharpUpperBound_of_natUpperBound
    (h : PrimeRecipSharpMertensNatUpperBound) :
    PrimeRecipDyadicBlocksSharpUpperBound := by
  rcases h with ⟨A, N₀, hN⟩
  refine ⟨(A : ℝ) + Real.log (2 * Real.log (2 : ℝ)), max 1 N₀, ?_⟩
  intro K hK
  have hK_one : 1 ≤ K := le_trans (le_max_left _ _) hK
  have hN₀_le_K : N₀ ≤ K := le_trans (le_max_right _ _) hK
  have hK_le_top : K ≤ 2 ^ (K + 1) := by
    exact le_trans (le_of_lt (Nat.lt_two_pow K))
      (Nat.pow_le_pow_right (by norm_num : 1 ≤ 2) (Nat.le_succ K))
  have hN₀_le_top : N₀ ≤ 2 ^ (K + 1) := le_trans hN₀_le_K hK_le_top
  have hblocks := primeRecipDyadicBlocks_le_primeRecipSum_two_pow_succ K
  have hMertens := hN (2 ^ (K + 1)) hN₀_le_top
  have hK_pos : 0 < (K : ℝ) := by exact_mod_cast hK_one
  have hKsucc_pos : 0 < ((K + 1 : ℕ) : ℝ) := by positivity
  have hlog2_pos : 0 < Real.log (2 : ℝ) := Real.log_pos (by norm_num)
  have htwo_log2_pos : 0 < 2 * Real.log (2 : ℝ) := by positivity
  have hlog_top :
      Real.log (((2 ^ (K + 1) : ℕ) : ℝ)) =
        ((K + 1 : ℕ) : ℝ) * Real.log (2 : ℝ) := by
    rw [Nat.cast_pow, Real.log_pow]
    norm_num
  have hKsucc_le_twoK : ((K + 1 : ℕ) : ℝ) ≤ 2 * (K : ℝ) := by
    have hnat : K + 1 ≤ 2 * K := by omega
    exact_mod_cast hnat
  have hlog_top_le :
      Real.log (((2 ^ (K + 1) : ℕ) : ℝ)) ≤
        (K : ℝ) * (2 * Real.log (2 : ℝ)) := by
    rw [hlog_top]
    nlinarith [mul_le_mul_of_nonneg_right hKsucc_le_twoK hlog2_pos.le]
  have hlog_top_pos :
      0 < Real.log (((2 ^ (K + 1) : ℕ) : ℝ)) := by
    rw [hlog_top]
    exact mul_pos hKsucc_pos hlog2_pos
  have hright_pos : 0 < (K : ℝ) * (2 * Real.log (2 : ℝ)) :=
    mul_pos hK_pos htwo_log2_pos
  have hloglog_le :
      Real.log (Real.log (((2 ^ (K + 1) : ℕ) : ℝ))) ≤
        Real.log ((K : ℝ) * (2 * Real.log (2 : ℝ))) :=
    Real.log_le_log hlog_top_pos hlog_top_le
  have hlog_mul :
      Real.log ((K : ℝ) * (2 * Real.log (2 : ℝ))) =
        Real.log (K : ℝ) + Real.log (2 * Real.log (2 : ℝ)) := by
    rw [Real.log_mul (ne_of_gt hK_pos) (ne_of_gt htwo_log2_pos)]
  calc
    (∑ k ∈ Finset.Icc (1 : ℕ) K,
      ∑ p ∈ (Finset.Ioc (2 ^ k) (2 ^ (k + 1))).filter (fun p => Nat.Prime p),
        (p : ℝ)⁻¹)
        ≤ ∑ p ∈ (Finset.Icc (2 : ℕ) (2 ^ (K + 1))).filter
            (fun p => Nat.Prime p), (p : ℝ)⁻¹ := hblocks
    _ ≤ Real.log (Real.log (((2 ^ (K + 1) : ℕ) : ℝ))) + (A : ℝ) :=
          hMertens
    _ ≤ Real.log (K : ℝ) + ((A : ℝ) + Real.log (2 * Real.log (2 : ℝ))) := by
          have hloglog_le' :
              Real.log (Real.log (((2 ^ (K + 1) : ℕ) : ℝ))) ≤
                Real.log (K : ℝ) + Real.log (2 * Real.log (2 : ℝ)) := by
            simpa [hlog_mul] using hloglog_le
          linarith

/-- The one-sided bounded-defect Mertens formulation implies the coefficient-one
dyadic block formulation. -/
theorem PrimeRecipDyadicBlocksSharpUpperBound_of_defectEventuallyUpperBound
    (h : PrimeRecipSharpMertensNatDefectEventuallyUpperBound) :
    PrimeRecipDyadicBlocksSharpUpperBound :=
  PrimeRecipDyadicBlocksSharpUpperBound_of_natUpperBound
    (PrimeRecipSharpMertensNatUpperBound_of_natRealConstant
      (PrimeRecipSharpMertensNatRealConstantUpperBound_of_defectEventuallyUpperBound h))

/-- Coefficient-one dyadic blocks and one-sided bounded-defect Mertens are
equivalent in this formalization.  The remaining product-lower analytic input
can therefore be attacked either as a conventional Mertens theorem or as the
coefficient-one dyadic-shell strengthening; all conversion bookkeeping is
checked. -/
theorem PrimeRecipDyadicBlocksSharpUpperBound_iff_defectEventuallyUpperBound :
    PrimeRecipDyadicBlocksSharpUpperBound ↔
      PrimeRecipSharpMertensNatDefectEventuallyUpperBound := by
  constructor
  · exact PrimeRecipSharpMertensNatDefectEventuallyUpperBound_of_dyadicBlocksSharpUpperBound
  · exact PrimeRecipDyadicBlocksSharpUpperBound_of_defectEventuallyUpperBound

/-- A standard bounded-error asymptotic for the prime-reciprocal Mertens defect
discharges the natural-cutoff sharp Mertens input used by the rough-sieve route. -/
theorem PrimeRecipSharpMertensNatUpperBound_of_defectIsBigOOne
    (h : PrimeRecipSharpMertensNatDefectIsBigOOne) :
    PrimeRecipSharpMertensNatUpperBound :=
  PrimeRecipSharpMertensNatUpperBound_of_natRealConstant
    (PrimeRecipSharpMertensNatRealConstantUpperBound_of_defectEventuallyUpperBound
      (PrimeRecipSharpMertensNatDefectEventuallyUpperBound_of_isBigOOne h))

/-- A conventional eventual absolute-error Mertens theorem discharges the
natural-cutoff upper-bound input used downstream. -/
theorem PrimeRecipSharpMertensNatUpperBound_of_eventuallyAbsBound
    (h : PrimeRecipSharpMertensNatDefectEventuallyAbsBound) :
    PrimeRecipSharpMertensNatUpperBound :=
  PrimeRecipSharpMertensNatUpperBound_of_defectIsBigOOne
    (PrimeRecipSharpMertensNatDefectIsBigOOne_of_eventuallyAbsBound h)

/-- A conventional two-sided bounded-error Mertens theorem discharges the
natural-cutoff upper-bound input used downstream. -/
theorem PrimeRecipSharpMertensNatUpperBound_of_twoSided
    (h : PrimeRecipSharpMertensNatDefectEventuallyTwoSidedBound) :
    PrimeRecipSharpMertensNatUpperBound :=
  PrimeRecipSharpMertensNatUpperBound_of_defectIsBigOOne
    (PrimeRecipSharpMertensNatDefectIsBigOOne_of_twoSided h)

/-- The two natural-cutoff Mertens formulations differ only in whether the
eventual additive constant is encoded as a natural number or a real number. -/
theorem PrimeRecipSharpMertensNatUpperBound_iff_realConstant :
    PrimeRecipSharpMertensNatUpperBound ↔
      PrimeRecipSharpMertensNatRealConstantUpperBound := by
  constructor
  · exact PrimeRecipSharpMertensNatRealConstantUpperBound_of_nat
  · exact PrimeRecipSharpMertensNatUpperBound_of_natRealConstant

/-- The public natural-cutoff Mertens upper bound and the exact one-sided
defect-upper formulation have the same content.  This keeps rounding the
eventual additive constant as theorem-level bookkeeping rather than part of
the trusted frontier. -/
theorem PrimeRecipSharpMertensNatUpperBound_iff_defectEventuallyUpperBound :
    PrimeRecipSharpMertensNatUpperBound ↔
      PrimeRecipSharpMertensNatDefectEventuallyUpperBound := by
  constructor
  · intro h
    exact PrimeRecipSharpMertensNatDefectEventuallyUpperBound_of_natRealConstant
      (PrimeRecipSharpMertensNatRealConstantUpperBound_of_nat h)
  · intro h
    exact PrimeRecipSharpMertensNatUpperBound_of_natRealConstant
      (PrimeRecipSharpMertensNatRealConstantUpperBound_of_defectEventuallyUpperBound h)

/-- The public natural-cutoff Mertens upper bound is equivalent to the
coefficient-one dyadic prime-reciprocal shell estimate.  Thus all finite
interval coverage and `log log` bookkeeping between these two standard
formulations is theorem-level; the analytic content is exactly the sharp
coefficient-one dyadic-shell bound. -/
theorem PrimeRecipSharpMertensNatUpperBound_iff_dyadicBlocksSharpUpperBound :
    PrimeRecipSharpMertensNatUpperBound ↔
      PrimeRecipDyadicBlocksSharpUpperBound := by
  constructor
  · exact PrimeRecipDyadicBlocksSharpUpperBound_of_natUpperBound
  · intro h
    exact PrimeRecipSharpMertensNatUpperBound_of_natRealConstant
      (PrimeRecipSharpMertensNatRealConstantUpperBound_of_defectEventuallyUpperBound
        (PrimeRecipSharpMertensNatDefectEventuallyUpperBound_of_dyadicBlocksSharpUpperBound h))

/-- A natural-cutoff prime-reciprocal Mertens bound implies the real-cutoff
version after the finite floor-transfer. -/
theorem PrimeRecipSharpMertensUpperBound_of_nat
    (h : PrimeRecipSharpMertensNatUpperBound) :
    PrimeRecipSharpMertensUpperBound := by
  rcases h with ⟨K, N₀, hN⟩
  refine ⟨K, max (3 : ℝ) ((N₀ : ℝ) + 1), ?_⟩
  intro z hz
  have hz_three : (3 : ℝ) ≤ z := le_trans (le_max_left _ _) hz
  have hz_N₀ : (N₀ : ℝ) + 1 ≤ z := le_trans (le_max_right _ _) hz
  have hz_pos : 0 < z := lt_of_lt_of_le (by norm_num : (0 : ℝ) < 3) hz_three
  have hN₀_le_floor : N₀ ≤ ⌊z⌋₊ := by
    exact Nat.le_floor (show (N₀ : ℝ) ≤ z by nlinarith)
  have hfloor_ge_three : (3 : ℕ) ≤ ⌊z⌋₊ := by
    exact Nat.le_floor hz_three
  have hfloor_pos : 0 < ((⌊z⌋₊ : ℕ) : ℝ) := by
    exact_mod_cast (lt_of_lt_of_le (by norm_num : (0 : ℕ) < 3) hfloor_ge_three)
  have hfloor_gt_one : (1 : ℝ) < ((⌊z⌋₊ : ℕ) : ℝ) := by
    exact_mod_cast (lt_of_lt_of_le (by norm_num : (1 : ℕ) < 3) hfloor_ge_three)
  have hlog_floor_pos : 0 < Real.log ((⌊z⌋₊ : ℕ) : ℝ) :=
    Real.log_pos hfloor_gt_one
  have hfloor_le_z : ((⌊z⌋₊ : ℕ) : ℝ) ≤ z :=
    Nat.floor_le hz_pos.le
  have hlog_floor_le_log_z :
      Real.log ((⌊z⌋₊ : ℕ) : ℝ) ≤ Real.log z :=
    Real.log_le_log hfloor_pos hfloor_le_z
  have hloglog_floor_le_loglog_z :
      Real.log (Real.log ((⌊z⌋₊ : ℕ) : ℝ)) ≤
        Real.log (Real.log z) :=
    Real.log_le_log hlog_floor_pos hlog_floor_le_log_z
  exact (hN ⌊z⌋₊ hN₀_le_floor).trans
    (add_le_add_right hloglog_floor_le_loglog_z K)

/-- The real-cutoff prime-reciprocal Mertens bound implies the natural-cutoff
form.  This is the reverse floor-transfer to
`PrimeRecipSharpMertensUpperBound_of_nat`, so the remaining Mertens input is
not an artifact of choosing real or natural cutoffs. -/
theorem PrimeRecipSharpMertensNatUpperBound_of_real
    (h : PrimeRecipSharpMertensUpperBound) :
    PrimeRecipSharpMertensNatUpperBound := by
  rcases h with ⟨K, Z₀, hZ⟩
  let KNat : ℕ := ⌊max K 0⌋₊ + 1
  let N₀ : ℕ := max 3 (⌊max Z₀ 0⌋₊ + 1)
  refine ⟨KNat, N₀, ?_⟩
  intro N hN
  have hthree : 3 ≤ N := le_trans (le_max_left _ _) hN
  have hfloor_succ_le : ⌊max Z₀ 0⌋₊ + 1 ≤ N :=
    le_trans (le_max_right _ _) hN
  have hZ₀_nonneg_le : Z₀ ≤ max Z₀ 0 := le_max_left _ _
  have hZ₀_floor_succ :
      Z₀ < ((⌊max Z₀ 0⌋₊ + 1 : ℕ) : ℝ) := by
    have hfloor_lt :
        max Z₀ 0 < ((⌊max Z₀ 0⌋₊ : ℕ) : ℝ) + 1 := by
      exact Nat.lt_floor_add_one (max Z₀ 0)
    have hfloor_lt' :
        max Z₀ 0 < ((⌊max Z₀ 0⌋₊ + 1 : ℕ) : ℝ) := by
      simpa [Nat.cast_add, Nat.cast_one] using hfloor_lt
    exact lt_of_le_of_lt hZ₀_nonneg_le hfloor_lt'
  have hZ₀_le_N : Z₀ ≤ (N : ℝ) := by
    have hs : ((⌊max Z₀ 0⌋₊ + 1 : ℕ) : ℝ) ≤ (N : ℝ) := by
      exact_mod_cast hfloor_succ_le
    exact le_trans (le_of_lt hZ₀_floor_succ) hs
  have hK_le : K ≤ (KNat : ℝ) := by
    have hK_nonneg_le : K ≤ max K 0 := le_max_left _ _
    have hfloor_lt :
        max K 0 < ((⌊max K 0⌋₊ : ℕ) : ℝ) + 1 := by
      exact Nat.lt_floor_add_one (max K 0)
    have hfloor_lt' : max K 0 < (KNat : ℝ) := by
      dsimp [KNat]
      simpa [Nat.cast_add, Nat.cast_one] using hfloor_lt
    exact le_trans hK_nonneg_le (le_of_lt hfloor_lt')
  have hreal := hZ (N : ℝ) hZ₀_le_N
  have hfloor_eq : ⌊(N : ℝ)⌋₊ = N := by
    exact Nat.floor_natCast N
  have hreal_nat :
      (∑ p ∈ (Finset.Icc (2 : ℕ) N).filter (fun p => Nat.Prime p),
          (p : ℝ)⁻¹) ≤
        Real.log (Real.log (N : ℝ)) + K := by
    simpa [hfloor_eq] using hreal
  have hconst :
      Real.log (Real.log (N : ℝ)) + K ≤
        Real.log (Real.log (N : ℝ)) + (KNat : ℝ) :=
    add_le_add_left hK_le _
  exact hreal_nat.trans hconst

/-- Real-cutoff and natural-cutoff forms of the sharp prime-reciprocal Mertens
input are equivalent. -/
theorem PrimeRecipSharpMertensUpperBound_iff_nat :
    PrimeRecipSharpMertensUpperBound ↔ PrimeRecipSharpMertensNatUpperBound := by
  constructor
  · exact PrimeRecipSharpMertensNatUpperBound_of_real
  · exact PrimeRecipSharpMertensUpperBound_of_nat

/-- Real-cutoff Mertens is also equivalent to the conventional natural-cutoff
form with a real additive constant. -/
theorem PrimeRecipSharpMertensUpperBound_iff_natRealConstant :
    PrimeRecipSharpMertensUpperBound ↔
      PrimeRecipSharpMertensNatRealConstantUpperBound := by
  constructor
  · intro h
    exact PrimeRecipSharpMertensNatRealConstantUpperBound_of_nat
      (PrimeRecipSharpMertensNatUpperBound_of_real h)
  · intro h
    exact PrimeRecipSharpMertensUpperBound_of_nat
      (PrimeRecipSharpMertensNatUpperBound_of_natRealConstant h)

/-- The standard prime-reciprocal Mertens bound implies the rough-modulus
version by the identity between the prime factors of `P(z)` and the defining
prime cutoff. -/
theorem roughModulusPrimeRecipSharpMertensUpperBound_of_primeRecipSharpMertens
    (h : PrimeRecipSharpMertensUpperBound) :
    roughModulusPrimeRecipSharpMertensUpperBound := by
  rcases h with ⟨K, Z₀, hprime⟩
  refine ⟨K, max (Real.exp 1) (Real.exp (max 1 Z₀)), ?_⟩
  intro X hX
  have hXexp1 : Real.exp 1 ≤ X := le_trans (le_max_left _ _) hX
  have hXexpZ : Real.exp (max 1 Z₀) ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 1) hXexp1
  have hlog_ge_max : max 1 Z₀ ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hXexpZ
  have hlog_ge_one : 1 ≤ Real.log X := le_trans (le_max_left _ _) hlog_ge_max
  have hlog_ge_Z₀ : Z₀ ≤ Real.log X := le_trans (le_max_right _ _) hlog_ge_max
  have hlog_nonneg : 0 ≤ Real.log X := le_trans zero_le_one hlog_ge_one
  have hlog_le_z : Real.log X ≤ EscAnalytic.zScale X := by
    unfold EscAnalytic.zScale
    have hle_sq : Real.log X ≤ Real.log X * Real.log X := by nlinarith
    have hsq_ge_one : 1 ≤ Real.log X * Real.log X := by nlinarith
    have hsq_nonneg : 0 ≤ Real.log X * Real.log X := by nlinarith
    have hsq_le_four :
        Real.log X * Real.log X ≤
          (Real.log X * Real.log X) * (Real.log X * Real.log X) := by
      have hmul := mul_le_mul_of_nonneg_left hsq_ge_one hsq_nonneg
      simpa [one_mul] using hmul
    calc
      Real.log X ≤ Real.log X * Real.log X := hle_sq
      _ ≤ (Real.log X * Real.log X) * (Real.log X * Real.log X) := hsq_le_four
      _ = (Real.log X) ^ (4 : ℕ) := by ring
  have hz_ge_Z₀ : Z₀ ≤ EscAnalytic.zScale X := hlog_ge_Z₀.trans hlog_le_z
  simpa [roughModulus, primeProductBelow_primeFactors_eq]
    using hprime (EscAnalytic.zScale X) hz_ge_Z₀

/-- Natural-cutoff prime-reciprocal Mertens control implies the rough-modulus
prime-reciprocal Mertens upper bound. -/
theorem roughModulusPrimeRecipSharpMertensUpperBound_of_primeRecipSharpMertensNat
    (h : PrimeRecipSharpMertensNatUpperBound) :
    roughModulusPrimeRecipSharpMertensUpperBound :=
  roughModulusPrimeRecipSharpMertensUpperBound_of_primeRecipSharpMertens
    (PrimeRecipSharpMertensUpperBound_of_nat h)

/-- Unconditional rough-modulus prime-reciprocal fallback.

This is the same finite carrier as the sharp rough-modulus Mertens statement,
but with the elementary same-cutoff bound `O(log z)` in place of the sharp
`log log z + O(1)` estimate. -/
theorem roughModulusPrimeRecip_le_one_add_log_zScale
    {X : ℝ} (hX : Real.exp 1 ≤ X) :
    (∑ p ∈ (roughModulus X).primeFactors, (p : ℝ)⁻¹) ≤
      1 + Real.log (EscAnalytic.zScale X) := by
  have hz_ge_one : 1 ≤ EscAnalytic.zScale X :=
    zScale_ge_one_of_exp_one_le hX
  have hz_ge_one_natcast : ((1 : ℕ) : ℝ) ≤ EscAnalytic.zScale X := by
    simpa using hz_ge_one
  have hz_pos : 0 < EscAnalytic.zScale X :=
    lt_of_lt_of_le zero_lt_one hz_ge_one
  have hfloor_pos_nat : 0 < ⌊EscAnalytic.zScale X⌋₊ := by
    exact lt_of_lt_of_le (by norm_num : 0 < (1 : ℕ))
      (Nat.le_floor hz_ge_one_natcast)
  have hfloor_pos : 0 < ((⌊EscAnalytic.zScale X⌋₊ : ℕ) : ℝ) := by
    exact_mod_cast hfloor_pos_nat
  have hfloor_le_z :
      ((⌊EscAnalytic.zScale X⌋₊ : ℕ) : ℝ) ≤ EscAnalytic.zScale X :=
    Nat.floor_le hz_pos.le
  have hlog_floor_le :
      Real.log ((⌊EscAnalytic.zScale X⌋₊ : ℕ) : ℝ) ≤
        Real.log (EscAnalytic.zScale X) :=
    Real.log_le_log hfloor_pos hfloor_le_z
  have hprime :=
    primeRecipSum_le_one_add_log ⌊EscAnalytic.zScale X⌋₊
  calc
    (∑ p ∈ (roughModulus X).primeFactors, (p : ℝ)⁻¹)
        = ∑ p ∈ (Finset.Icc (2 : ℕ) ⌊EscAnalytic.zScale X⌋₊).filter
            (fun p => Nat.Prime p), (p : ℝ)⁻¹ := by
          simp [roughModulus, primeProductBelow_primeFactors_eq]
    _ ≤ 1 + Real.log ((⌊EscAnalytic.zScale X⌋₊ : ℕ) : ℝ) := hprime
    _ ≤ 1 + Real.log (EscAnalytic.zScale X) :=
          add_le_add_left hlog_floor_le 1

/-- Unconditional linear-in-`z` fallback for the full reciprocal divisor sum
of the rough modulus.  The sharp Mertens route below improves this from
`O(z)` to `O(log z)`, which is exactly the missing analytic strength needed
for the final lower Euler-product half. -/
theorem roughModulus_divisor_recip_upper_linear_zScale
    {X : ℝ} (hX : Real.exp 1 ≤ X) :
    (∑ d ∈ (roughModulus X).divisors, (1 : ℝ) / (d : ℝ)) ≤
      Real.exp 1 * EscAnalytic.zScale X := by
  have hz_ge_one : 1 ≤ EscAnalytic.zScale X :=
    zScale_ge_one_of_exp_one_le hX
  have hz_pos : 0 < EscAnalytic.zScale X :=
    lt_of_lt_of_le zero_lt_one hz_ge_one
  have hdiv_exp :=
    divisor_recip_sum_le_exp_primeFactor_recip_sum_of_squarefree
      (d := roughModulus X) (roughModulus_squarefree X)
  have hprime_sum := roughModulusPrimeRecip_le_one_add_log_zScale hX
  have hexp_le :
      Real.exp (∑ p ∈ (roughModulus X).primeFactors, (p : ℝ)⁻¹) ≤
        Real.exp (1 + Real.log (EscAnalytic.zScale X)) :=
    Real.exp_le_exp.mpr hprime_sum
  calc
    (∑ d ∈ (roughModulus X).divisors, (1 : ℝ) / (d : ℝ))
        ≤ Real.exp (∑ p ∈ (roughModulus X).primeFactors, (p : ℝ)⁻¹) :=
          hdiv_exp
    _ ≤ Real.exp (1 + Real.log (EscAnalytic.zScale X)) := hexp_le
    _ = Real.exp 1 * EscAnalytic.zScale X := by
          rw [Real.exp_add, Real.exp_log hz_pos]

/-- Explicit-constant version of the sharp prime-reciprocal route to the
reciprocal-divisor bound. -/
theorem roughModulus_divisor_recip_upper_of_primeRecipSharpMertens
    {K Xprime : ℝ}
    (hprime : ∀ X : ℝ, Xprime ≤ X →
      (∑ p ∈ (roughModulus X).primeFactors, (p : ℝ)⁻¹) ≤
        Real.log (Real.log (EscAnalytic.zScale X)) + K) :
    ∀ X : ℝ, max Xprime (Real.exp 2) ≤ X →
      (∑ d ∈ (roughModulus X).divisors, (1 : ℝ) / (d : ℝ)) ≤
        Real.exp K * Real.log (EscAnalytic.zScale X) := by
  intro X hX
  have hXprime : Xprime ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hlogZ_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp
  have hdiv_exp :=
    divisor_recip_sum_le_exp_primeFactor_recip_sum_of_squarefree
      (d := roughModulus X) (roughModulus_squarefree X)
  have hprime_sum := hprime X hXprime
  have hexp_le :
      Real.exp (∑ p ∈ (roughModulus X).primeFactors, (p : ℝ)⁻¹)
        ≤ Real.exp (Real.log (Real.log (EscAnalytic.zScale X)) + K) :=
    Real.exp_le_exp.mpr hprime_sum
  calc
    (∑ d ∈ (roughModulus X).divisors, (1 : ℝ) / (d : ℝ))
        ≤ Real.exp (∑ p ∈ (roughModulus X).primeFactors, (p : ℝ)⁻¹) :=
          hdiv_exp
    _ ≤ Real.exp (Real.log (Real.log (EscAnalytic.zScale X)) + K) :=
          hexp_le
    _ = Real.exp K * Real.log (EscAnalytic.zScale X) := by
          rw [Real.exp_add, Real.exp_log hlogZ_pos]
          ring

/-- The sharp prime-reciprocal Mertens upper bound implies the full
reciprocal-divisor Mertens upper bound for the rough modulus. -/
theorem roughModulusDivisorRecipUpperBound_of_primeRecipSharpMertens
    (hprime : roughModulusPrimeRecipSharpMertensUpperBound) :
    roughModulusDivisorRecipUpperBound := by
  rcases hprime with ⟨K, Xprime, hprime⟩
  refine ⟨Real.exp K, max Xprime (Real.exp 2), Real.exp_pos K, ?_⟩
  exact roughModulus_divisor_recip_upper_of_primeRecipSharpMertens hprime

/-- Natural-cutoff prime-reciprocal Mertens control implies the full
reciprocal-divisor Mertens upper bound for the rough modulus. -/
theorem roughModulusDivisorRecipUpperBound_of_primeRecipSharpMertensNat
    (hprime : PrimeRecipSharpMertensNatUpperBound) :
    roughModulusDivisorRecipUpperBound :=
  roughModulusDivisorRecipUpperBound_of_primeRecipSharpMertens
    (roughModulusPrimeRecipSharpMertensUpperBound_of_primeRecipSharpMertensNat
      hprime)

/-- Explicit-constant form of the divisor-reciprocal route to the finite
Euler-product lower bound. -/
theorem roughDyadicBadPrimeMainEulerProduct_lower_of_divisorRecipUpper
    {C Xdiv : ℝ} (hC : 0 < C)
    (hdiv : ∀ X : ℝ, Xdiv ≤ X →
      (∑ d ∈ (roughModulus X).divisors, (1 : ℝ) / (d : ℝ)) ≤
        C * Real.log (EscAnalytic.zScale X)) :
    ∀ X : ℝ, max Xdiv (Real.exp 2) ≤ X →
      (4 * C)⁻¹ / Real.log (EscAnalytic.zScale X) ≤
        roughDyadicBadPrimeMainEulerProduct X := by
  intro X hX
  have hXdiv : Xdiv ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hlog_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp
  have hprod_nonneg : 0 ≤ roughDyadicBadPrimeMainEulerProduct X :=
    roughDyadicBadPrimeMainEulerProduct_nonneg X
  have hsum_upper := hdiv X hXdiv
  have hsquare := roughModulus_square_euler_product_ge_quarter X
  have hidentity :=
    roughDyadicBadPrimeMainEulerProduct_mul_divisor_recip_sum_eq_square_euler X
  have hquarter_le :
      (1 / 4 : ℝ) ≤
        roughDyadicBadPrimeMainEulerProduct X *
          (∑ d ∈ (roughModulus X).divisors, (1 : ℝ) / (d : ℝ)) := by
    rw [hidentity]
    exact hsquare
  have hquarter_le_scaled :
      (1 / 4 : ℝ) ≤
        roughDyadicBadPrimeMainEulerProduct X *
          (C * Real.log (EscAnalytic.zScale X)) :=
    hquarter_le.trans
      (mul_le_mul_of_nonneg_left hsum_upper hprod_nonneg)
  rw [div_le_iff₀ hlog_pos]
  rw [inv_le_iff_one_le_mul₀ (mul_pos (by norm_num : (0 : ℝ) < 4) hC)]
  nlinarith

/-- Explicit-constant axiom-free fallback for the finite Euler-product lower
bound.  Replacing the sharp divisor-reciprocal estimate `O(log z)` by the
elementary estimate `O(z)` gives only `V(z) ≫ 1/z`, which is too weak for the
live rough-sieve lower bound but exactly records the current unconditional
product-side strength. -/
theorem roughDyadicBadPrimeMainEulerProduct_lower_zScale_of_divisorRecipUpperLinear
    {C Xdiv : ℝ} (hC : 0 < C)
    (hdiv : ∀ X : ℝ, Xdiv ≤ X →
      (∑ d ∈ (roughModulus X).divisors, (1 : ℝ) / (d : ℝ)) ≤
        C * EscAnalytic.zScale X) :
    ∀ X : ℝ, max Xdiv (Real.exp 1) ≤ X →
      (4 * C)⁻¹ / EscAnalytic.zScale X ≤
        roughDyadicBadPrimeMainEulerProduct X := by
  intro X hX
  have hXdiv : Xdiv ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 1 ≤ X := le_trans (le_max_right _ _) hX
  have hz_pos : 0 < EscAnalytic.zScale X :=
    lt_of_lt_of_le zero_lt_one (zScale_ge_one_of_exp_one_le hXexp)
  have hprod_nonneg : 0 ≤ roughDyadicBadPrimeMainEulerProduct X :=
    roughDyadicBadPrimeMainEulerProduct_nonneg X
  have hsum_upper := hdiv X hXdiv
  have hsquare := roughModulus_square_euler_product_ge_quarter X
  have hidentity :=
    roughDyadicBadPrimeMainEulerProduct_mul_divisor_recip_sum_eq_square_euler X
  have hquarter_le :
      (1 / 4 : ℝ) ≤
        roughDyadicBadPrimeMainEulerProduct X *
          (∑ d ∈ (roughModulus X).divisors, (1 : ℝ) / (d : ℝ)) := by
    rw [hidentity]
    exact hsquare
  have hquarter_le_scaled :
      (1 / 4 : ℝ) ≤
        roughDyadicBadPrimeMainEulerProduct X *
          (C * EscAnalytic.zScale X) :=
    hquarter_le.trans
      (mul_le_mul_of_nonneg_left hsum_upper hprod_nonneg)
  rw [div_le_iff₀ hz_pos]
  rw [inv_le_iff_one_le_mul₀ (mul_pos (by norm_num : (0 : ℝ) < 4) hC)]
  nlinarith

/-- Unconditional `1/z` lower fallback for the finite rough Euler product.  The
sharp `1/log z` lower bound remains exactly the Mertens-side analytic input. -/
theorem roughDyadicBadPrimeMainEulerProductZScaleLowerBound_unconditional :
    roughDyadicBadPrimeMainEulerProductZScaleLowerBound := by
  refine ⟨(4 * Real.exp 1)⁻¹, Real.exp 1,
    inv_pos.mpr (mul_pos (by norm_num) (Real.exp_pos 1)), ?_⟩
  intro X hX
  exact
    roughDyadicBadPrimeMainEulerProduct_lower_zScale_of_divisorRecipUpperLinear
      (Real.exp_pos 1)
      (fun X hX => roughModulus_divisor_recip_upper_linear_zScale hX)
      X (by simpa using hX)

/-- The lower Mertens half for the rough Euler product follows from the

    h.2.2⟩

/-- Package-level reverse of the absolute-to-one-sided signed-multiples
projection: two one-sided signed estimates with the same budget imply the
symmetric absolute estimate after maxing their thresholds. -/
theorem LinearSieveRoughDyadicMultiplesSignedErrorAbsQuarterBound_of_signed
    (h : LinearSieveRoughDyadicMultiplesSignedErrorQuarterBound) :
    LinearSieveRoughDyadicMultiplesSignedErrorAbsQuarterBound := by
  intro a₀ b₀ C₀ c Xprod hc hprod
  rcases h a₀ b₀ C₀ c Xprod hc hprod with ⟨Xl, Xu, hlower, hupper⟩
  exact
    ⟨max Xl Xu,
      roughDyadicBadPrimeProductMultiplesSignedErrorAbsBoundModulusOne_of_lower_upper
        hlower hupper⟩

/-- Package-level projection from a symmetric absolute signed-multiples
estimate to its two one-sided signed forms. -/
theorem LinearSieveRoughDyadicMultiplesSignedErrorQuarterBound_of_abs
    (h : LinearSieveRoughDyadicMultiplesSignedErrorAbsQuarterBound) :
    LinearSieveRoughDyadicMultiplesSignedErrorQuarterBound := by
  intro a₀ b₀ C₀ c Xprod hc hprod
  rcases h a₀ b₀ C₀ c Xprod hc hprod with ⟨Xm, hXm⟩
  exact
    ⟨Xm, Xm,
      roughDyadicBadPrimeProductMultiplesSignedErrorLowerBoundModulusOne_of_abs
        hXm,
      roughDyadicBadPrimeProductMultiplesSignedErrorUpperBoundModulusOne_of_abs
        hXm⟩

/-- Package-level projection from the explicit alternating floor-error target
to the signed-multiples quarter-budget used downstream. -/
theorem LinearSieveRoughDyadicMultiplesSignedErrorQuarterBound_of_floorErrorAbs
    (h : LinearSieveRoughDyadicMultiplesFloorErrorAbsQuarterBound) :
    LinearSieveRoughDyadicMultiplesSignedErrorQuarterBound := by
  intro a₀ b₀ C₀ c Xprod hc hprod
  rcases h a₀ b₀ C₀ c Xprod hc hprod with ⟨Xm, hXm⟩
  have hSigned :
      roughDyadicBadPrimeProductMultiplesSignedErrorAbsBoundModulusOne
        a₀ b₀ C₀ (c / 4) (max Xm 1) :=
    roughDyadicBadPrimeProductMultiplesSignedErrorAbsBoundModulusOne_of_floorError
      hXm
  exact
    ⟨max Xm 1, max Xm 1,
      roughDyadicBadPrimeProductMultiplesSignedErrorLowerBoundModulusOne_of_abs
        hSigned,
      roughDyadicBadPrimeProductMultiplesSignedErrorUpperBoundModulusOne_of_abs
        hSigned⟩

/-- Positive-range projection from the explicit alternating floor-error target
to the signed-multiples quarter-budget consumed by the live public route. -/
theorem LinearSieveRoughDyadicMultiplesSignedErrorQuarterBoundOnPositiveRanges_of_floorErrorAbs
    (h : LinearSieveRoughDyadicMultiplesFloorErrorAbsQuarterBoundOnPositiveRanges) :
    LinearSieveRoughDyadicMultiplesSignedErrorQuarterBoundOnPositiveRanges := by
  intro a₀ b₀ C₀ c Xprod ha₀ hab hc hprod
  rcases h a₀ b₀ C₀ c Xprod ha₀ hab hc hprod with ⟨Xm, hXm⟩
  have hSigned :
      roughDyadicBadPrimeProductMultiplesSignedErrorAbsBoundModulusOne
        a₀ b₀ C₀ (c / 4) (max Xm 1) :=
    roughDyadicBadPrimeProductMultiplesSignedErrorAbsBoundModulusOne_of_floorError
      hXm
  exact
    ⟨max Xm 1, max Xm 1,
      roughDyadicBadPrimeProductMultiplesSignedErrorLowerBoundModulusOne_of_abs
        hSigned,
      roughDyadicBadPrimeProductMultiplesSignedErrorUpperBoundModulusOne_of_abs
        hSigned⟩

/-- Package-level reverse bridge from symmetric signed-multiples control to
the explicit alternating floor-error target. -/
theorem LinearSieveRoughDyadicMultiplesFloorErrorAbsQuarterBound_of_signedErrorAbs
    (h : LinearSieveRoughDyadicMultiplesSignedErrorAbsQuarterBound) :
    LinearSieveRoughDyadicMultiplesFloorErrorAbsQuarterBound := by
  intro a₀ b₀ C₀ c Xprod hc hprod
  rcases h a₀ b₀ C₀ c Xprod hc hprod with ⟨Xm, hXm⟩
  exact
    ⟨max Xm 1,
      roughDyadicBadPrimeProductMultiplesFloorErrorAbsBoundModulusOne_of_signedError

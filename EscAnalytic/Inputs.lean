/-- Paired one-sided normalized positive-range floor-error estimates imply the
normalized absolute floor-error statement. -/
theorem RoughDyadicFloorErrorUniformNormalizedSmallBoundOnPositiveRanges_of_oneSided
    (h : RoughDyadicFloorErrorUniformNormalizedOneSidedSmallBoundOnPositiveRanges) :
    RoughDyadicFloorErrorUniformNormalizedSmallBoundOnPositiveRanges := by
  intro a₀ b₀ C₀ eps ha₀ hab heps

/-- Quarter-budget interface for the actual modulus-one rough-count
Euler-product discrepancy.  This is equivalent to the signed-multiples
formulation above by the checked finite identity
`roughDyadicBadPrimeProductMultiplesSignedErrorSum_eq_roughWindowCount_sub_main`.
-/
def LinearSieveRoughDyadicCountDiscrepancyAbsQuarterBound : Prop :=
  ∀ (a₀ b₀ C₀ c Xprod : ℝ), 0 < c →
    (∀ X : ℝ, Xprod ≤ X →
      c / Real.log (EscAnalytic.zScale X) ≤
        roughDyadicBadPrimeMainEulerProduct X) →
    ∃ Xm : ℝ,
      roughDyadicRoughWindowEulerProductDiscrepancyAbsBoundModulusOne
        a₀ b₀ C₀ (c / 4) Xm

/-- Standard uniform-small form of the modulus-one rough-count discrepancy:
for every fixed dyadic parameter range and every positive error budget, the
Euler-product main-term discrepancy is eventually bounded by that budget times
`t/log z`.  This is stronger than the quarter-budget interface below because it
does not need to be paired with a separate product lower constant. -/
def RoughDyadicCountDiscrepancyUniformSmallBound : Prop :=
  ∀ (a₀ b₀ C₀ eps : ℝ), 0 < eps →
    ∃ Xm : ℝ,
      roughDyadicRoughWindowEulerProductDiscrepancyAbsBoundModulusOne
        a₀ b₀ C₀ eps Xm

/-- Normalized uniform-small form of the modulus-one rough-count discrepancy:
for every fixed dyadic parameter range and every positive error budget, the
relative discrepancy after scaling by `t/log z` is eventually bounded by that
budget. -/
def RoughDyadicCountDiscrepancyUniformNormalizedSmallBound : Prop :=
  ∀ (a₀ b₀ C₀ eps : ℝ), 0 < eps →
    ∃ Xm : ℝ,
      roughDyadicRoughWindowEulerProductDiscrepancyNormalizedAbsBoundModulusOne
        a₀ b₀ C₀ eps Xm

/-- Positive-range uniform-small form of the modulus-one rough-count
Euler-product discrepancy. -/
def RoughDyadicCountDiscrepancyUniformSmallBoundOnPositiveRanges : Prop :=
  ∀ (a₀ b₀ C₀ eps : ℝ), 0 < a₀ → a₀ < b₀ → 0 < eps →
    ∃ Xm : ℝ,
      roughDyadicRoughWindowEulerProductDiscrepancyAbsBoundModulusOne
        a₀ b₀ C₀ eps Xm

/-- Positive-range normalized uniform-small form of the modulus-one rough-count
Euler-product discrepancy. -/
def RoughDyadicCountDiscrepancyUniformNormalizedSmallBoundOnPositiveRanges : Prop :=
  ∀ (a₀ b₀ C₀ eps : ℝ), 0 < a₀ → a₀ < b₀ → 0 < eps →
    ∃ Xm : ℝ,
      roughDyadicRoughWindowEulerProductDiscrepancyNormalizedAbsBoundModulusOne
        a₀ b₀ C₀ eps Xm

/-- Relative-to-main-term positive-range rough-window discrepancy.  This is the
customary linear-sieve error shape
`|R(t,z) - t V(z)| ≤ eps * t V(z)`.  The theorem below converts it to the
active normalized `t/log z` interface using the already proved unconditional
upper bound `V(z) ≪ 1/log z`. -/
def RoughDyadicCountDiscrepancyRelativeMainUniformSmallBoundOnPositiveRanges :
    Prop :=
  ∀ (a₀ b₀ _C₀ eps : ℝ), 0 < a₀ → a₀ < b₀ → 0 < eps →
    ∃ X₀ : ℝ, ∀ X : ℝ, X₀ ≤ X →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        |roughDyadicRoughWindowCount X t -
          t * roughDyadicBadPrimeMainEulerProduct X| ≤
          eps * (t * roughDyadicBadPrimeMainEulerProduct X)

/-- Optional broader fixed-log-power linear-sieve/fundamental-lemma count
discrepancy: for any fixed positive log-power sieve level `z = (log X)^k`, any
fixed positive polynomial window, and any positive error budget, the `P(z)`
rough dyadic-window count has normalized Euler-product discrepancy eventually
below that budget.  This is a theorem-level sufficient condition for the live
`z = (log X)^4` positive-range input, but it is deliberately **not** part of the
exported axiom frontier. -/
def PrimeProductLogPowerRoughWindowCountDiscrepancyUniformNormalizedSmallBound :
    Prop :=
  ∀ (k : ℕ) (a₀ b₀ eps : ℝ), 0 < k → 0 < a₀ → a₀ < b₀ → 0 < eps →
    ∃ X₀ : ℝ, ∀ X : ℝ, X₀ ≤ X →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        |primeProductBelowRoughWindowCount ((Real.log X) ^ k) t -
          t * primeProductBelowEulerProduct ((Real.log X) ^ k)| /
            (t / Real.log ((Real.log X) ^ k)) ≤ eps

/-- Unnormalized fixed-log-power linear-sieve/fundamental-lemma count
discrepancy.  This is the same generic target as
`PrimeProductLogPowerRoughWindowCountDiscrepancyUniformNormalizedSmallBound`,
but stated in the raw scaled-error form
`|count-main| ≤ eps · t/log((log X)^k)`. -/
def PrimeProductLogPowerRoughWindowCountDiscrepancyUniformSmallBound : Prop :=
  ∀ (k : ℕ) (a₀ b₀ eps : ℝ), 0 < k → 0 < a₀ → a₀ < b₀ → 0 < eps →
    ∃ X₀ : ℝ, ∀ X : ℝ, X₀ ≤ X →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        |primeProductBelowRoughWindowCount ((Real.log X) ^ k) t -
          t * primeProductBelowEulerProduct ((Real.log X) ^ k)| ≤
            eps * (t / Real.log ((Real.log X) ^ k))

/-- Uniform positive-range domination of the finite-periodic rough-modulus
remainder by the normalized sieve scale.  This is stronger than the live
positive-range discrepancy input in the manuscript's polynomial windows, but it
is an exact theorem-level sufficient condition for that input. -/
def RoughDyadicPeriodRemainderUniformNormalizedSmallBoundOnPositiveRanges : Prop :=
  ∀ (a₀ b₀ _C₀ eps : ℝ), 0 < a₀ → a₀ < b₀ → 0 < eps →
    ∃ X₀ : ℝ, ∀ X : ℝ, X₀ ≤ X →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        ((Nat.totient (roughModulus X) : ℝ) + 1) /
            (t / Real.log (EscAnalytic.zScale X)) ≤ eps

/-- The raw uniform-small discrepancy statement implies its normalized
relative-error form. -/
theorem RoughDyadicCountDiscrepancyUniformNormalizedSmallBound_of_uniformSmall
    (h : RoughDyadicCountDiscrepancyUniformSmallBound) :
    RoughDyadicCountDiscrepancyUniformNormalizedSmallBound := by
  intro a₀ b₀ C₀ eps heps

/-- A one-sided modulus-one finite product-error estimate proves the core
upper count primitive directly.  This is the count-level upper route that does
not require any auxiliary-modulus estimate. -/
theorem roughDyadicCountModulusOneUpperBoundCore_of_productErrorUpperModulusOne
    {a₀ b₀ C₀ E Xerr : ℝ}
    (herr :
      roughDyadicBadPrimeProductErrorUpperBoundModulusOne
        a₀ b₀ C₀ E Xerr) :
    roughDyadicCountModulusOneUpperBoundCore a₀ b₀ := by
  rcases herr with ⟨hE_nonneg, herr⟩
  rcases roughDyadicBadPrimeMainEulerProductUpperBound_unconditional with
    ⟨C, Xprod, hC, hprod⟩
  refine ⟨C + E, max (max Xprod Xerr) (Real.exp 2),
    add_pos_of_pos_of_nonneg hC hE_nonneg, ?_⟩
  intro X hX t htlo hthi
  have hXprod : Xprod ≤ X := le_trans (le_max_left _ _)
    (le_trans (le_max_left _ _) hX)
  have hXerr : Xerr ≤ X := le_trans (le_max_right _ _)
    (le_trans (le_max_left _ _) hX)
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 2) hXexp
  have htpos : 0 < t := lt_of_lt_of_le (Real.rpow_pos_of_pos hXpos a₀) htlo
  let T : ℝ := t / Real.log (EscAnalytic.zScale X)
  have hmain :=
    roughDyadicBadPrimeProductMainTermSum_eq_mul_eulerProduct X t
  have hprod_hi := hprod X hXprod
  have hmain_hi :
      roughDyadicBadPrimeProductMainTermSum X t ≤ C * T := by
    calc
      roughDyadicBadPrimeProductMainTermSum X t
          = t * roughDyadicBadPrimeMainEulerProduct X := hmain
      _ ≤ t * (C / Real.log (EscAnalytic.zScale X)) :=
          mul_le_mul_of_nonneg_left hprod_hi htpos.le
      _ = C * T := by
          simp [T]
          ring
  have herr_upper := herr X hXerr t htlo hthi
  have hdecomp :=
    roughDyadicBadPrimeProductCountSum_eq_mainTerm_add_error X 1 t
  calc
    roughDyadicCount X 1 t
        = roughDyadicBadPrimeSubsetProductCountSum X 1 t := by
          rw [← roughDyadicBadPrimeParitySum_eq_roughDyadicCount,
            roughDyadicBadPrimeParitySum_eq_productCountSum]
    _ = roughDyadicBadPrimeProductMainTermSum X t +
          roughDyadicBadPrimeProductErrorSum X 1 t := hdecomp
    _ ≤ C * T + E * T := by
        nlinarith
    _ = (C + E) * (t / Real.log (EscAnalytic.zScale X)) := by
        simp [T]
        ring


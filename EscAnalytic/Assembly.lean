/-! ## Smooth-range and transfer inputs for fixed numerators -/

/-- Paper-facing fixed-`m` Suen transfer inputs.

This names the remaining fixed-numerator handoff in the strongest checked shape:
the paper supplies per-class Suen finite-transfer data, a standard-tail budget
against the cited Suen constant, and a uniform class envelope for the reduced
rough carriers.  The finite initial range is not a separate field; downstream
constructors absorb it by enlarging the final implied constant. -/
structure FixedNumeratorPaperSuenTransferInputs
    (m : ℕ) (ι κ : Type*) [DecidableEq κ] where
  cls : ℕ → Finset ι
  Mb : ℕ → ι → ℝ
  Ered : ℕ → ℕ
  Pz : ℕ → ℝ
  μ : ℕ → ℝ
  εb : ℕ → ℝ
  δb : ℕ → ι → ℝ
  Δb : ℕ → ι → ℝ
  Xpow : ℕ → ι → ℝ
  errTerm : ℕ → ι → ℝ
  F2R : ℕ → ι → ℝ
  εK : ℝ
  c : ℝ
  T : ℕ
  Tred : ℕ
  c_pos : 0 < c
  Ered_sum : ∀ N : ℕ, 3 ≤ N →
    (Ered N : ℝ) ≤ ∑ b ∈ cls N, Mb N b
  mu_pos : ∀ N : ℕ, 3 ≤ N → T ≤ N → 0 < μ N
  Pz_ge_one : ∀ N : ℕ, 3 ≤ N → T ≤ N → 1 ≤ Pz N
  delta_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 0 ≤ δb N b
  Delta_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 0 ≤ Δb N b
  Xpow_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 0 ≤ Xpow N b
  suen_tail : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
    Inputs.suenTailConstant * Δb N b * Real.exp (2 * δb N b) ≤ εb N * μ N
  decomp : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
    Mb N b ≤ ((N : ℝ) / Pz N) *
      (Inputs.suenProb (μ N) (δb N b) (Δb N b) + F2R N b) + errTerm N b
  err_bound : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
    errTerm N b ≤ Xpow N b * Real.exp ((1 + εK) * μ N)
  eps_le_one : εK ≤ 1
  level : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
    Pz N * Xpow N b * Real.exp (2 * μ N) ≤ (N : ℝ) * Real.exp (-4 * μ N)
  F2R_bound : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
    F2R N b ≤ Real.exp (-3 * μ N)
  class_card : ∀ N : ℕ, 3 ≤ N → T ≤ N → ((cls N).card : ℝ) ≤ Pz N
  saving_bound : ∀ N : ℕ, 3 ≤ N → T ≤ N →
    c * (Real.log N) ^ ((3 : ℝ) / 4)
      ≤ (1 - (εb N + Real.log 3 / μ N)) * μ N
  clsRed : ℕ → ℕ → Finset κ
  classOfRed : ℕ → ℕ → ℕ → κ
  Ured : ℕ → ℕ → ℝ
  red_class_mem_large : ∀ N : ℕ, 3 ≤ N → Tred ≤ N → ∀ s ∈ Finset.Icc 1 N,
    ∀ r ∈ ((Finset.Icc 1 (N / s)).filter
      (fun r => IsRough (zNatScale N) r ∧ ¬ fixedNumeratorRepresentable m r)),
        classOfRed N s r ∈ clsRed N s
  red_class_bound_large : ∀ N : ℕ, 3 ≤ N → Tred ≤ N → ∀ s ∈ Finset.Icc 1 N,
    ∀ b ∈ clsRed N s,
      ((((Finset.Icc 1 (N / s)).filter
        (fun r => (IsRough (zNatScale N) r ∧ ¬ fixedNumeratorRepresentable m r) ∧
          classOfRed N s r = b)).card : ℕ) : ℝ) ≤ Ured N s
  red_class_uniform_sum_large : ∀ N : ℕ, 3 ≤ N → Tred ≤ N →
    (∑ s ∈ Finset.Icc 1 N, ((clsRed N s).card : ℝ) * Ured N s) ≤
      eulerProductFactorAtNat N * (Ered N : ℝ)

/-- Mathlib's finite smooth-number carrier is monotone in the smoothness
cutoff. -/
theorem smoothNumbers_mono {k k' n : ℕ} (hkk' : k ≤ k')
    (hn : n ∈ Nat.smoothNumbers k) :
    n ∈ Nat.smoothNumbers k' := by
  rw [Nat.mem_smoothNumbers] at hn ⊢
  exact ⟨hn.1, fun p hp => lt_of_lt_of_le (hn.2 p hp) hkk'⟩

/-- Mathlib's finite smooth-number carrier is monotone in both the size and
smoothness cutoffs. -/
theorem smoothNumbersUpTo_mono {N N' k k' : ℕ} (hNN' : N ≤ N') (hkk' : k ≤ k') :
    Nat.smoothNumbersUpTo N k ⊆ Nat.smoothNumbersUpTo N' k' := by
  intro n hn
  rw [Nat.mem_smoothNumbersUpTo] at hn ⊢
  exact ⟨le_trans hn.1 hNN', smoothNumbers_mono hkk' hn.2⟩

/-- Cardinality form of monotonicity for Mathlib's finite smooth-number
carrier. -/
theorem smoothNumbersUpTo_card_mono {N N' k k' : ℕ} (hNN' : N ≤ N') (hkk' : k ≤ k') :
    (Nat.smoothNumbersUpTo N k).card ≤ (Nat.smoothNumbersUpTo N' k').card :=
  Finset.card_le_card (smoothNumbersUpTo_mono hNN' hkk')

/-- The concrete Rankin-facing smooth-range carrier at the manuscript cutoff.

`LiftCount` proves that the actual smooth range injects into this finite sum,
and also embeds the underlying finite smooth carrier into mathlib's
`Nat.smoothNumbersUpTo`.  The only analytic estimate left for the manuscript
cutoff is the cited sharp smooth-number summation bound
`rankin_smoothRange_zNatScale_bound`. -/
noncomputable def smoothRankinEnvelope (N : ℕ) : ℝ :=
  ∑ m ∈ Finset.Icc 1 (Nat.sqrt N),
    smoothPsi ((N / m : ℕ) : ℝ) (zNatScale N : ℝ)

/-- The Rankin-facing `smoothPsi` envelope embeds termwise into Mathlib's
finite smooth-number carrier.  This records the carrier translation before the
sharp Rankin/de Bruijn asymptotic is invoked. -/
theorem smoothRankinEnvelope_le_sum_smoothNumbersUpTo (N : ℕ) :
    smoothRankinEnvelope N ≤
      ∑ m ∈ Finset.Icc 1 (Nat.sqrt N),
        ((Nat.smoothNumbersUpTo (N / m) (zNatScale N + 1)).card : ℝ) := by
  classical
  unfold smoothRankinEnvelope
  apply Finset.sum_le_sum
  intro m _hm
  exact smoothPsi_nat_le_smoothNumbersUpTo (zNatScale N) (N / m)

/-- Mathlib-backed crude smooth-number envelope for the Rankin-facing sum.

This is not the sharp Rankin/de Bruijn estimate needed in the final assembly;
it simply composes the checked carrier bridge with Mathlib's finite bound
`Nat.smoothNumbersUpTo_card_le`. -/
theorem smoothRankinEnvelope_le_sum_mathlib_smooth_bound (N : ℕ) :
    smoothRankinEnvelope N ≤
      ∑ m ∈ Finset.Icc 1 (Nat.sqrt N),
        ((2 ^ (zNatScale N + 1).primesBelow.card * Nat.sqrt (N / m) : ℕ) : ℝ) := by
  classical
  calc
    smoothRankinEnvelope N
        ≤ ∑ m ∈ Finset.Icc 1 (Nat.sqrt N),
            ((Nat.smoothNumbersUpTo (N / m) (zNatScale N + 1)).card : ℝ) :=
          smoothRankinEnvelope_le_sum_smoothNumbersUpTo N
    _ ≤ ∑ m ∈ Finset.Icc 1 (Nat.sqrt N),
          ((2 ^ (zNatScale N + 1).primesBelow.card * Nat.sqrt (N / m) : ℕ) : ℝ) := by
          apply Finset.sum_le_sum
          intro m _hm
          exact_mod_cast
            Nat.smoothNumbersUpTo_card_le (N / m) (zNatScale N + 1)

/-- Rankin/de Bruijn reduction to two smaller Mathlib-carrier estimates.

Mathlib's finite smooth-number bound gives
`Ψ(N/m,z) ≤ 2^π(z) sqrt(N/m)`.  Therefore the remaining sublinear smooth-range
input follows from:

* a power bound `2^π(z_N) = O(N^η)` with `η < 1/4`, and
* the square-root divisor-sum estimate
  `∑_{m≤√N} sqrt(N/m) = O(N^(3/4))`.

This theorem contains no analytic input.  It records what the direct Mathlib
`2^π(z)` envelope would require; at the manuscript scale `z=(log N)^4` this is
an intentionally over-strong diagnostic criterion, not the intended route for
discharging the Rankin/de Bruijn input. -/
theorem rankin_mathlibSmoothNumbersUpTo_zNatScale_bound_of_prime_power_and_sqrt_sum
    {η A B : ℝ} (hη0 : 0 < η) (hη1 : η < (1 : ℝ) / 4)
    (hA : 0 < A) (hB : 0 < B)
    (hPrimePower : ∀ N : ℕ, 3 ≤ N →
      ((2 ^ (zNatScale N + 1).primesBelow.card : ℕ) : ℝ) ≤ A * (N : ℝ) ^ η)
    (hSqrtSum : ∀ N : ℕ, 3 ≤ N →
      (∑ m ∈ Finset.Icc 1 (Nat.sqrt N), ((Nat.sqrt (N / m) : ℕ) : ℝ))
        ≤ B * (N : ℝ) ^ ((3 : ℝ) / 4)) :
    ∃ θ C : ℝ, 0 < θ ∧ θ < 1 ∧ 0 < C ∧
      ∀ N : ℕ, 3 ≤ N →
        (∑ m ∈ Finset.Icc 1 (Nat.sqrt N),
          ((Nat.smoothNumbersUpTo (N / m) (zNatScale N + 1)).card : ℝ))
            ≤ C * (N : ℝ) ^ θ := by
  refine ⟨η + (3 : ℝ) / 4, A * B, by nlinarith, by nlinarith,
    mul_pos hA hB, ?_⟩
  intro N hN
  have hNpos : 0 < (N : ℝ) := by
    exact_mod_cast (lt_of_lt_of_le (by norm_num : (0 : ℕ) < 3) hN)
  have hNnonneg : 0 ≤ (N : ℝ) := hNpos.le
  have hfactor_nonneg :
      0 ≤ ((2 ^ (zNatScale N + 1).primesBelow.card : ℕ) : ℝ) :=
    Nat.cast_nonneg _
  have hsum_nonneg :
      0 ≤ ∑ m ∈ Finset.Icc 1 (Nat.sqrt N), ((Nat.sqrt (N / m) : ℕ) : ℝ) := by
    apply Finset.sum_nonneg
    intro m _hm
    exact Nat.cast_nonneg _
  have htarget_nonneg : 0 ≤ A * (N : ℝ) ^ η :=
    mul_nonneg hA.le (Real.rpow_nonneg hNnonneg η)
  calc
    (∑ m ∈ Finset.Icc 1 (Nat.sqrt N),
      ((Nat.smoothNumbersUpTo (N / m) (zNatScale N + 1)).card : ℝ))
        ≤ ∑ m ∈ Finset.Icc 1 (Nat.sqrt N),
          ((2 ^ (zNatScale N + 1).primesBelow.card * Nat.sqrt (N / m) : ℕ) : ℝ) := by
          apply Finset.sum_le_sum
          intro m _hm
          exact_mod_cast
            Nat.smoothNumbersUpTo_card_le (N / m) (zNatScale N + 1)
    _ = ((2 ^ (zNatScale N + 1).primesBelow.card : ℕ) : ℝ) *
          ∑ m ∈ Finset.Icc 1 (Nat.sqrt N), ((Nat.sqrt (N / m) : ℕ) : ℝ) := by
          simp_rw [Nat.cast_mul]
          rw [Finset.mul_sum]
    _ ≤ (A * (N : ℝ) ^ η) * (B * (N : ℝ) ^ ((3 : ℝ) / 4)) :=
          mul_le_mul (hPrimePower N hN) (hSqrtSum N hN) hsum_nonneg htarget_nonneg
    _ = A * B * (N : ℝ) ^ (η + (3 : ℝ) / 4) := by
          rw [Real.rpow_add hNpos]
          ring

/-- Rankin/de Bruijn reduction from a uniform pointwise smooth-number saving.

This is the theorem-level shape of the remaining smooth-number input:
if every fiber in the Rankin sum satisfies
`Ψ(N/m,z_N) ≤ A N^η` for some `η < 1/2`, then summing over the at most `√N`
possible rough parts gives a sublinear bound with exponent `η+1/2`.

The proof is fully finite and contains no analytic input; the analytic debt is
only the pointwise de Bruijn-type estimate supplied as `hPointwise`. -/
theorem rankin_mathlibSmoothNumbersUpTo_zNatScale_bound_of_uniform_pointwise_power
    {η A : ℝ} (hη0 : 0 < η) (hηhalf : η < (1 : ℝ) / 2)
    (hA : 0 < A)
    (hPointwise : ∀ N m : ℕ, 3 ≤ N →
      m ∈ Finset.Icc 1 (Nat.sqrt N) →
        ((Nat.smoothNumbersUpTo (N / m) (zNatScale N + 1)).card : ℝ)
          ≤ A * (N : ℝ) ^ η) :
    ∃ θ C : ℝ, 0 < θ ∧ θ < 1 ∧ 0 < C ∧
      ∀ N : ℕ, 3 ≤ N →
        (∑ m ∈ Finset.Icc 1 (Nat.sqrt N),
          ((Nat.smoothNumbersUpTo (N / m) (zNatScale N + 1)).card : ℝ))
            ≤ C * (N : ℝ) ^ θ := by
  refine ⟨η + (1 : ℝ) / 2, A, by nlinarith, by nlinarith, hA, ?_⟩
  intro N hN
  have hNpos : 0 < (N : ℝ) := by
    exact_mod_cast (lt_of_lt_of_le (by norm_num : (0 : ℕ) < 3) hN)
  have hNnonneg : 0 ≤ (N : ℝ) := hNpos.le
  have hfactor_nonneg : 0 ≤ A * (N : ℝ) ^ η :=
    mul_nonneg hA.le (Real.rpow_nonneg hNnonneg η)
  have hcard : (Finset.Icc (1 : ℕ) (Nat.sqrt N)).card = Nat.sqrt N := by
    rw [Nat.card_Icc]
    omega
  have hsqrt_le :
      (Nat.sqrt N : ℝ) ≤ (N : ℝ) ^ ((1 : ℝ) / 2) := by
    simpa [Real.sqrt_eq_rpow] using Real.nat_sqrt_le_real_sqrt (a := N)
  calc
    (∑ m ∈ Finset.Icc 1 (Nat.sqrt N),
      ((Nat.smoothNumbersUpTo (N / m) (zNatScale N + 1)).card : ℝ))
        ≤ ∑ _m ∈ Finset.Icc 1 (Nat.sqrt N), A * (N : ℝ) ^ η := by
          apply Finset.sum_le_sum
          intro m hm
          exact hPointwise N m hN hm
    _ = (Nat.sqrt N : ℝ) * (A * (N : ℝ) ^ η) := by
          rw [Finset.sum_const, hcard, nsmul_eq_mul]
    _ ≤ (N : ℝ) ^ ((1 : ℝ) / 2) * (A * (N : ℝ) ^ η) :=
        mul_le_mul_of_nonneg_right hsqrt_le hfactor_nonneg
    _ = A * (N : ℝ) ^ (η + (1 : ℝ) / 2) := by
          rw [Real.rpow_add hNpos]
          ring

/-- Rankin/de Bruijn reduction with the correct divisor-fiber dependence.

This is the finite carrier shape needed by the standard Rankin method.  A
weighted smooth-number estimate with an `m^{-α}` factor, together with the
matching divisor-power sum, gives the Mathlib smooth-number summation input
with exponent `α + ε + (1 - α)/2 < 1`.

The theorem contains no smooth-number asymptotic input: all analytic content is
isolated in `hFiber` and `hDivisorPowerSum`. -/
theorem rankin_mathlibSmoothNumbersUpTo_zNatScale_bound_of_weighted_fibers
    {α ε A B : ℝ} (hα0 : 0 < α) (hα1 : α < 1) (hε0 : 0 ≤ ε)
    (hgap : ε < (1 - α) / 2) (hA : 0 < A) (hB : 0 < B)
    (hFiber : ∀ N m : ℕ, 3 ≤ N →
      m ∈ Finset.Icc 1 (Nat.sqrt N) →
        ((Nat.smoothNumbersUpTo (N / m) (zNatScale N + 1)).card : ℝ)
          ≤ (A * (N : ℝ) ^ α * (N : ℝ) ^ ε) * (m : ℝ) ^ (-α))
    (hDivisorPowerSum : ∀ N : ℕ, 3 ≤ N →
      (∑ m ∈ Finset.Icc 1 (Nat.sqrt N), (m : ℝ) ^ (-α))
        ≤ B * (N : ℝ) ^ ((1 - α) / 2)) :
    ∃ θ C : ℝ, 0 < θ ∧ θ < 1 ∧ 0 < C ∧
      ∀ N : ℕ, 3 ≤ N →
        (∑ m ∈ Finset.Icc 1 (Nat.sqrt N),
          ((Nat.smoothNumbersUpTo (N / m) (zNatScale N + 1)).card : ℝ))
            ≤ C * (N : ℝ) ^ θ := by
  refine ⟨α + ε + (1 - α) / 2, A * B, by nlinarith,
    by nlinarith, mul_pos hA hB, ?_⟩
  intro N hN
  have hNpos : 0 < (N : ℝ) := by
    exact_mod_cast (lt_of_lt_of_le (by norm_num : (0 : ℕ) < 3) hN)
  have hNnonneg : 0 ≤ (N : ℝ) := hNpos.le
  have hfactor_nonneg :
      0 ≤ A * (N : ℝ) ^ α * (N : ℝ) ^ ε :=
    mul_nonneg (mul_nonneg hA.le (Real.rpow_nonneg hNnonneg α))
      (Real.rpow_nonneg hNnonneg ε)
  have hsum_nonneg :
      0 ≤ ∑ m ∈ Finset.Icc 1 (Nat.sqrt N), (m : ℝ) ^ (-α) := by
    apply Finset.sum_nonneg
    intro m _hm
    exact Real.rpow_nonneg (Nat.cast_nonneg m) (-α)
  calc
    (∑ m ∈ Finset.Icc 1 (Nat.sqrt N),
      ((Nat.smoothNumbersUpTo (N / m) (zNatScale N + 1)).card : ℝ))
        ≤ ∑ m ∈ Finset.Icc 1 (Nat.sqrt N),
          (A * (N : ℝ) ^ α * (N : ℝ) ^ ε) * (m : ℝ) ^ (-α) := by
          apply Finset.sum_le_sum
          intro m hm
          exact hFiber N m hN hm
    _ = (A * (N : ℝ) ^ α * (N : ℝ) ^ ε) *
          ∑ m ∈ Finset.Icc 1 (Nat.sqrt N), (m : ℝ) ^ (-α) := by
          rw [Finset.mul_sum]
    _ ≤ (A * (N : ℝ) ^ α * (N : ℝ) ^ ε) *
          (B * (N : ℝ) ^ ((1 - α) / 2)) :=
          mul_le_mul_of_nonneg_left (hDivisorPowerSum N hN) hfactor_nonneg
    _ = A * B * (((N : ℝ) ^ α * (N : ℝ) ^ ε) *
          (N : ℝ) ^ ((1 - α) / 2)) := by
          ring
    _ = A * B * (N : ℝ) ^ (α + ε + (1 - α) / 2) := by
          rw [← Real.rpow_add hNpos α ε]
          rw [← Real.rpow_add hNpos (α + ε) ((1 - α) / 2)]

/-- Rankin/de Bruijn reduction where the divisor sum is discharged
unconditionally by the elementary bound `∑_{m≤√N} m^{-α} ≤ √N`.

This is weaker than the sharp power-sum form above, but it removes one analytic
hypothesis entirely.  The cost is the stronger exponent condition
`α + ε < 1/2` on the weighted fiber estimate. -/
theorem rankin_mathlibSmoothNumbersUpTo_zNatScale_bound_of_weighted_fibers_small_alpha
    {α ε A : ℝ} (hα0 : 0 < α) (hε0 : 0 ≤ ε)
    (hgap : α + ε < (1 : ℝ) / 2) (hA : 0 < A)
    (hFiber : ∀ N m : ℕ, 3 ≤ N →
      m ∈ Finset.Icc 1 (Nat.sqrt N) →
        ((Nat.smoothNumbersUpTo (N / m) (zNatScale N + 1)).card : ℝ)
          ≤ (A * (N : ℝ) ^ α * (N : ℝ) ^ ε) * (m : ℝ) ^ (-α)) :
    ∃ θ C : ℝ, 0 < θ ∧ θ < 1 ∧ 0 < C ∧
      ∀ N : ℕ, 3 ≤ N →
        (∑ m ∈ Finset.Icc 1 (Nat.sqrt N),
          ((Nat.smoothNumbersUpTo (N / m) (zNatScale N + 1)).card : ℝ))
            ≤ C * (N : ℝ) ^ θ := by
  refine ⟨α + ε + (1 : ℝ) / 2, A, by nlinarith, by nlinarith, hA, ?_⟩
  intro N hN
  have hNpos : 0 < (N : ℝ) := by
    exact_mod_cast (lt_of_lt_of_le (by norm_num : (0 : ℕ) < 3) hN)
  have hNnonneg : 0 ≤ (N : ℝ) := hNpos.le
  have hfactor_nonneg :
      0 ≤ A * (N : ℝ) ^ α * (N : ℝ) ^ ε :=
    mul_nonneg (mul_nonneg hA.le (Real.rpow_nonneg hNnonneg α))
      (Real.rpow_nonneg hNnonneg ε)
  have hcard : (Finset.Icc (1 : ℕ) (Nat.sqrt N)).card = Nat.sqrt N := by
    rw [Nat.card_Icc]
    omega
  have hpow_sum_le_sqrt :
      (∑ m ∈ Finset.Icc 1 (Nat.sqrt N), (m : ℝ) ^ (-α))
        ≤ (Nat.sqrt N : ℝ) := by
    calc
      (∑ m ∈ Finset.Icc 1 (Nat.sqrt N), (m : ℝ) ^ (-α))
          ≤ ∑ _m ∈ Finset.Icc 1 (Nat.sqrt N), (1 : ℝ) := by
            apply Finset.sum_le_sum
            intro m hm
            have hm_ge_one : (1 : ℝ) ≤ (m : ℝ) := by
              exact_mod_cast (Finset.mem_Icc.mp hm).1
            exact Real.rpow_le_one_of_one_le_of_nonpos hm_ge_one (by linarith)
      _ = (Nat.sqrt N : ℝ) := by
            rw [Finset.sum_const, hcard, nsmul_eq_mul]
            simp
  have hsqrt_le :
      (Nat.sqrt N : ℝ) ≤ (N : ℝ) ^ ((1 : ℝ) / 2) := by
    simpa [Real.sqrt_eq_rpow] using Real.nat_sqrt_le_real_sqrt (a := N)
  calc
    (∑ m ∈ Finset.Icc 1 (Nat.sqrt N),
      ((Nat.smoothNumbersUpTo (N / m) (zNatScale N + 1)).card : ℝ))
        ≤ ∑ m ∈ Finset.Icc 1 (Nat.sqrt N),
          (A * (N : ℝ) ^ α * (N : ℝ) ^ ε) * (m : ℝ) ^ (-α) := by
          apply Finset.sum_le_sum
          intro m hm
          exact hFiber N m hN hm
    _ = (A * (N : ℝ) ^ α * (N : ℝ) ^ ε) *
          ∑ m ∈ Finset.Icc 1 (Nat.sqrt N), (m : ℝ) ^ (-α) := by
          rw [Finset.mul_sum]
    _ ≤ (A * (N : ℝ) ^ α * (N : ℝ) ^ ε) * (N : ℝ) ^ ((1 : ℝ) / 2) :=
          mul_le_mul_of_nonneg_left (hpow_sum_le_sqrt.trans hsqrt_le) hfactor_nonneg
    _ = A * (N : ℝ) ^ (α + ε + (1 : ℝ) / 2) := by
          calc
            (A * (N : ℝ) ^ α * (N : ℝ) ^ ε) * (N : ℝ) ^ ((1 : ℝ) / 2)
                = A * (((N : ℝ) ^ α * (N : ℝ) ^ ε) *
                    (N : ℝ) ^ ((1 : ℝ) / 2)) := by ring
            _ = A * ((N : ℝ) ^ (α + ε) * (N : ℝ) ^ ((1 : ℝ) / 2)) := by
                  rw [← Real.rpow_add hNpos α ε]
            _ = A * (N : ℝ) ^ (α + ε + (1 : ℝ) / 2) := by
                  rw [← Real.rpow_add hNpos (α + ε) ((1 : ℝ) / 2)]

/-- Convert a pointwise de Bruijn-style fiber estimate at the natural scale
`N/m` into the weighted Rankin fiber estimate used by the divisor-power
summation.

This peels one more bookkeeping layer off the smooth-number input: the external
content may be stated for the actual fiber size `N/m`, while the `m^{-α}` weight
is recovered here from `((N / m : ℕ) : ℝ) ≤ N / m`. -/
theorem rankin_mathlibSmoothNumbersUpTo_zNatScale_weighted_fiber_bound_of_pointwise_natDiv
    (hPointwise :
      ∃ α ε A : ℝ, 0 < α ∧ α < 1 ∧ 0 ≤ ε ∧ ε < (1 - α) / 2 ∧ 0 < A ∧
        ∀ N m : ℕ, 3 ≤ N →
          m ∈ Finset.Icc 1 (Nat.sqrt N) →
            ((Nat.smoothNumbersUpTo (N / m) (zNatScale N + 1)).card : ℝ)
              ≤ A * (((N / m : ℕ) : ℝ) ^ α) * (N : ℝ) ^ ε) :
    ∃ α ε A : ℝ, 0 < α ∧ α < 1 ∧ 0 ≤ ε ∧ ε < (1 - α) / 2 ∧ 0 < A ∧
      ∀ N m : ℕ, 3 ≤ N →
        m ∈ Finset.Icc 1 (Nat.sqrt N) →
          ((Nat.smoothNumbersUpTo (N / m) (zNatScale N + 1)).card : ℝ)
            ≤ (A * (N : ℝ) ^ α * (N : ℝ) ^ ε) * (m : ℝ) ^ (-α) := by
  rcases hPointwise with ⟨α, ε, A, hα0, hα1, hε0, hgap, hA, hPointwise⟩
  refine ⟨α, ε, A, hα0, hα1, hε0, hgap, hA, ?_⟩
  intro N m hN hm
  have hm_ge_one : 1 ≤ m := (Finset.mem_Icc.mp hm).1
  have hm_pos_nat : 0 < m := lt_of_lt_of_le Nat.zero_lt_one hm_ge_one
  have hNpos : 0 < (N : ℝ) := by
    exact_mod_cast (lt_of_lt_of_le (by norm_num : (0 : ℕ) < 3) hN)
  have hm_pos : 0 < (m : ℝ) := by exact_mod_cast hm_pos_nat
  have hcast_div_le : ((N / m : ℕ) : ℝ) ≤ (N : ℝ) / (m : ℝ) :=
    Nat.cast_div_le
  have hpow_le :
      (((N / m : ℕ) : ℝ) ^ α) ≤ ((N : ℝ) / (m : ℝ)) ^ α :=
    Real.rpow_le_rpow (Nat.cast_nonneg _) hcast_div_le hα0.le
  have hdiv_pow :
      ((N : ℝ) / (m : ℝ)) ^ α = (N : ℝ) ^ α * (m : ℝ) ^ (-α) := by
    rw [div_eq_mul_inv]
    rw [Real.mul_rpow hNpos.le (inv_nonneg.mpr hm_pos.le)]
    rw [Real.inv_rpow hm_pos.le]
    rw [← Real.rpow_neg hm_pos.le]
  calc
    ((Nat.smoothNumbersUpTo (N / m) (zNatScale N + 1)).card : ℝ)
        ≤ A * (((N / m : ℕ) : ℝ) ^ α) * (N : ℝ) ^ ε :=
          hPointwise N m hN hm
    _ ≤ A * (((N : ℝ) / (m : ℝ)) ^ α) * (N : ℝ) ^ ε := by
          exact mul_le_mul_of_nonneg_right
            (mul_le_mul_of_nonneg_left hpow_le hA.le)
            (Real.rpow_nonneg hNpos.le ε)
    _ = (A * (N : ℝ) ^ α * (N : ℝ) ^ ε) * (m : ℝ) ^ (-α) := by
          rw [hdiv_pow]
          ring

/-- Finite Rankin inequality for Mathlib's smooth-number carrier.

For `α > 0`, each positive `n ≤ Y` contributes at least one unit to
`Y^α n^{-α}`.  Summing over the smooth carrier gives
`#Ψ(Y,z) ≤ Y^α ∑_{n∈Ψ(Y,z)} n^{-α}`.  This is the exact elementary step that
turns a weighted Euler-product bound into a pointwise smooth-count bound. -/
theorem smoothNumbersUpTo_card_le_rpow_mul_weighted_sum
    (Y z : ℕ) {α : ℝ} (hα0 : 0 < α) :
    ((Nat.smoothNumbersUpTo Y z).card : ℝ) ≤
      (Y : ℝ) ^ α *
        ∑ n ∈ Nat.smoothNumbersUpTo Y z, (n : ℝ) ^ (-α) := by
  classical
  calc
    ((Nat.smoothNumbersUpTo Y z).card : ℝ)
        = ∑ _n ∈ Nat.smoothNumbersUpTo Y z, (1 : ℝ) := by
          rw [Finset.sum_const, nsmul_eq_mul]
          simp
    _ ≤ ∑ n ∈ Nat.smoothNumbersUpTo Y z,
          (Y : ℝ) ^ α * (n : ℝ) ^ (-α) := by
          apply Finset.sum_le_sum
          intro n hn
          have hnpack := Nat.mem_smoothNumbersUpTo.mp hn
          have hn_ne_zero : n ≠ 0 := Nat.ne_zero_of_mem_smoothNumbers hnpack.2
          have hn_pos_nat : 0 < n := Nat.pos_of_ne_zero hn_ne_zero
          have hn_pos : 0 < (n : ℝ) := by exact_mod_cast hn_pos_nat
          have hn_le_Y : (n : ℝ) ≤ (Y : ℝ) := by exact_mod_cast hnpack.1
          have hpow_le : (n : ℝ) ^ α ≤ (Y : ℝ) ^ α :=
            Real.rpow_le_rpow hn_pos.le hn_le_Y hα0.le
          have hweight_nonneg : 0 ≤ (n : ℝ) ^ (-α) :=
            Real.rpow_nonneg hn_pos.le (-α)
          calc
            (1 : ℝ) = (n : ℝ) ^ α * (n : ℝ) ^ (-α) := by
              rw [← Real.rpow_add hn_pos]
              ring_nf
              simp
            _ ≤ (Y : ℝ) ^ α * (n : ℝ) ^ (-α) :=
              mul_le_mul_of_nonneg_right hpow_le hweight_nonneg
    _ = (Y : ℝ) ^ α *
          ∑ n ∈ Nat.smoothNumbersUpTo Y z, (n : ℝ) ^ (-α) := by
          rw [Finset.mul_sum]

/-- Weighted smooth sums are monotone in the size cutoff. -/
theorem smoothNumbersUpTo_weighted_sum_mono
    {Y K z : ℕ} (hYK : Y ≤ K) (α : ℝ) :
    (∑ n ∈ Nat.smoothNumbersUpTo Y z, (n : ℝ) ^ (-α))
      ≤ ∑ n ∈ Nat.smoothNumbersUpTo K z, (n : ℝ) ^ (-α) := by
  classical
  exact Finset.sum_le_sum_of_subset_of_nonneg
    (smoothNumbersUpTo_mono hYK le_rfl)
    (by
      intro n _hnBig _hnSmall
      exact Real.rpow_nonneg (Nat.cast_nonneg n) (-α))

/-- The exact finite weighted smooth-number carrier for the Rankin step:
`∑_{n≤K, n z-smooth} n^{-α}`.  This is the Euler-product object behind the
remaining smooth-number primitive. -/
noncomputable def rankinWeightedSmoothSum (K z : ℕ) (α : ℝ) : ℝ :=
  ∑ n ∈ Nat.smoothNumbersUpTo K z, (n : ℝ) ^ (-α)

/-- The dyadic weighted smooth-number carrier at the manuscript cutoff
`z_K = zNatScale K + 1`, with `K = 2^k`. -/
noncomputable def dyadicRankinWeightedSmoothSum (k : ℕ) (α : ℝ) : ℝ :=
  rankinWeightedSmoothSum (2 ^ k) (zNatScale (2 ^ k) + 1) α

/-- Finite prime-geometric product for the Rankin weighted smooth sum.

The factor at a prime `p < z` is the finite geometric sum over exponents up to
`log_p K`.  This is the concrete Euler-product target for proving
`rankinWeightedSmoothSum K z α`; the separate comparison theorem should inject
each `z`-smooth `n ≤ K` into its exponent vector. -/
noncomputable def rankinPrimeGeomProduct (K z : ℕ) (α : ℝ) : ℝ :=
  ∏ p ∈ z.primesBelow,
    ∑ e ∈ Finset.range (Nat.log p K + 1), (((p ^ e : ℕ) : ℝ)) ^ (-α)

/-- Dyadic prime-geometric product at the manuscript cutoff. -/
noncomputable def dyadicRankinPrimeGeomProduct (k : ℕ) (α : ℝ) : ℝ :=
  rankinPrimeGeomProduct (2 ^ k) (zNatScale (2 ^ k) + 1) α

/-- One local prime factor in the finite Rankin prime-geometric product. -/
noncomputable def rankinPrimeGeomLocalFactor (K : ℕ) (α : ℝ) (p : ℕ) : ℝ :=
  ∑ e ∈ Finset.range (Nat.log p K + 1), (((p ^ e : ℕ) : ℝ)) ^ (-α)

/-- Additive logarithmic carrier for the finite Rankin prime-geometric product. -/
noncomputable def rankinPrimeGeomLogSum (K z : ℕ) (α : ℝ) : ℝ :=
  ∑ p ∈ z.primesBelow, Real.log (rankinPrimeGeomLocalFactor K α p)

/-- Additive excess carrier obtained from the elementary inequality
`log x ≤ x - 1`.  Bounding this finite prime-local sum is enough to bound the
finite Rankin product. -/
noncomputable def rankinPrimeGeomExcessSum (K z : ℕ) (α : ℝ) : ℝ :=
  ∑ p ∈ z.primesBelow, (rankinPrimeGeomLocalFactor K α p - 1)

/-- Positive-exponent tail of one local Rankin prime-geometric factor, written
with a shifted range: the summation index `e` represents exponent `e+1`. -/
noncomputable def rankinPrimeGeomLocalTail (K : ℕ) (α : ℝ) (p : ℕ) : ℝ :=
  ∑ e ∈ Finset.range (Nat.log p K), (((p ^ (e + 1) : ℕ) : ℝ)) ^ (-α)

/-- Additive positive-exponent prime-power tail for the finite Rankin product. -/
noncomputable def rankinPrimeGeomTailSum (K z : ℕ) (α : ℝ) : ℝ :=
  ∑ p ∈ z.primesBelow, rankinPrimeGeomLocalTail K α p

/-- The same local tail, rewritten as a genuine finite geometric sum with ratio
`p^{-α}`.  This is the natural carrier for the remaining Rankin product
estimate. -/
noncomputable def rankinPrimeGeomLocalRpowTail (K : ℕ) (α : ℝ) (p : ℕ) : ℝ :=
  ∑ e ∈ Finset.range (Nat.log p K), ((p : ℝ) ^ (-α)) ^ (e + 1)

/-- Additive geometric-tail carrier for the finite Rankin product. -/
noncomputable def rankinPrimeGeomRpowTailSum (K z : ℕ) (α : ℝ) : ℝ :=
  ∑ p ∈ z.primesBelow, rankinPrimeGeomLocalRpowTail K α p

/-- Infinite-geometric local majorant for the positive-exponent Rankin tail. -/
noncomputable def rankinPrimeGeomLocalGeomMajorant (α : ℝ) (p : ℕ) : ℝ :=
  (p : ℝ) ^ (-α) / (1 - (p : ℝ) ^ (-α))

/-- Additive infinite-geometric majorant for the finite Rankin product tail. -/
noncomputable def rankinPrimeGeomGeomMajorantSum (z : ℕ) (α : ℝ) : ℝ :=
  ∑ p ∈ z.primesBelow, rankinPrimeGeomLocalGeomMajorant α p

/-- Plain prime-power sum at the Rankin exponent. -/
noncomputable def rankinPrimeRpowSum (z : ℕ) (α : ℝ) : ℝ :=
  ∑ p ∈ z.primesBelow, (p : ℝ) ^ (-α)

/-- All-integers power sum at the Rankin exponent, used as a prime-sum
majorant. -/
noncomputable def rankinNatRpowSum (z : ℕ) (α : ℝ) : ℝ :=
  ∑ n ∈ Finset.Icc 1 z, (n : ℝ) ^ (-α)

/-- A cruder additive tail carrier: bound every positive-exponent local term by
the first term `p^{-α}` and multiply by the number `log_p K` of terms. -/
noncomputable def rankinPrimeGeomLogWeightedTailSum (K z : ℕ) (α : ℝ) : ℝ :=
  ∑ p ∈ z.primesBelow, (Nat.log p K : ℝ) * (p : ℝ) ^ (-α)

/-- Uniform-base version of the cruder Rankin tail carrier: replace every
`log_p K` by the worst-case `log_2 K`. -/
noncomputable def rankinPrimeGeomUniformLogTailSum (K z : ℕ) (α : ℝ) : ℝ :=
  (Nat.log 2 K : ℝ) * ∑ p ∈ z.primesBelow, (p : ℝ) ^ (-α)

/-- Dyadic logarithmic carrier for the finite Rankin prime-geometric product. -/
noncomputable def dyadicRankinPrimeGeomLogSum (k : ℕ) (α : ℝ) : ℝ :=
  rankinPrimeGeomLogSum (2 ^ k) (zNatScale (2 ^ k) + 1) α

/-- Dyadic excess carrier for the finite Rankin prime-geometric product. -/
noncomputable def dyadicRankinPrimeGeomExcessSum (k : ℕ) (α : ℝ) : ℝ :=
  rankinPrimeGeomExcessSum (2 ^ k) (zNatScale (2 ^ k) + 1) α

/-- Dyadic positive-exponent tail carrier for the finite Rankin product. -/
noncomputable def dyadicRankinPrimeGeomTailSum (k : ℕ) (α : ℝ) : ℝ :=
  rankinPrimeGeomTailSum (2 ^ k) (zNatScale (2 ^ k) + 1) α

/-- Dyadic geometric-tail carrier for the finite Rankin product. -/
noncomputable def dyadicRankinPrimeGeomRpowTailSum (k : ℕ) (α : ℝ) : ℝ :=
  rankinPrimeGeomRpowTailSum (2 ^ k) (zNatScale (2 ^ k) + 1) α

/-- Dyadic infinite-geometric majorant for the finite Rankin product tail. -/
noncomputable def dyadicRankinPrimeGeomGeomMajorantSum (k : ℕ) (α : ℝ) : ℝ :=
  rankinPrimeGeomGeomMajorantSum (zNatScale (2 ^ k) + 1) α

/-- Dyadic plain prime-power sum at the Rankin exponent. -/
noncomputable def dyadicRankinPrimeRpowSum (k : ℕ) (α : ℝ) : ℝ :=
  rankinPrimeRpowSum (zNatScale (2 ^ k) + 1) α

/-- Dyadic all-integers power sum at the Rankin exponent. -/
noncomputable def dyadicRankinNatRpowSum (k : ℕ) (α : ℝ) : ℝ :=
  rankinNatRpowSum (zNatScale (2 ^ k) + 1) α

/-- Dyadic log-weighted first-tail carrier for the finite Rankin product. -/
noncomputable def dyadicRankinPrimeGeomLogWeightedTailSum (k : ℕ) (α : ℝ) : ℝ :=
  rankinPrimeGeomLogWeightedTailSum (2 ^ k) (zNatScale (2 ^ k) + 1) α

/-- Dyadic uniform-base log tail carrier for the finite Rankin product. -/
noncomputable def dyadicRankinPrimeGeomUniformLogTailSum (k : ℕ) (α : ℝ) : ℝ :=
  rankinPrimeGeomUniformLogTailSum (2 ^ k) (zNatScale (2 ^ k) + 1) α

/-- The finite exponent box indexed by primes below `z`, with the exponent of
`p` allowed to range from `0` through `log_p K`. -/
noncomputable def rankinPrimeExponentBox (K z : ℕ) :
    Finset (∀ p : ℕ, p ∈ z.primesBelow → ℕ) :=
  z.primesBelow.pi fun p => Finset.range (Nat.log p K + 1)

/-- Weight of an exponent vector in the finite Rankin prime box. -/
noncomputable def rankinPrimeExponentBoxWeight (z : ℕ) (α : ℝ)
    (v : ∀ p : ℕ, p ∈ z.primesBelow → ℕ) : ℝ :=
  ∏ x ∈ z.primesBelow.attach,
    (((x.1 ^ v x.1 x.2 : ℕ) : ℝ)) ^ (-α)

/-- The weighted smooth-number carrier is nonnegative. -/
theorem rankinWeightedSmoothSum_nonneg (K z : ℕ) (α : ℝ) :
    0 ≤ rankinWeightedSmoothSum K z α := by
  classical
  unfold rankinWeightedSmoothSum
  exact Finset.sum_nonneg (by
    intro n _hn
    exact Real.rpow_nonneg (Nat.cast_nonneg n) (-α))

/-- The finite prime-geometric Rankin product is nonnegative. -/
theorem rankinPrimeGeomProduct_nonneg (K z : ℕ) (α : ℝ) :
    0 ≤ rankinPrimeGeomProduct K z α := by
  classical
  unfold rankinPrimeGeomProduct
  apply Finset.prod_nonneg
  intro p _hp
  exact Finset.sum_nonneg (by
    intro e _he
    exact Real.rpow_nonneg (Nat.cast_nonneg (p ^ e)) (-α))

/-- The local finite geometric factor contains the `e=0` term, hence is at
least `1`. -/
theorem one_le_rankinPrimeGeomLocalFactor (K : ℕ) (α : ℝ) (p : ℕ) :
    1 ≤ rankinPrimeGeomLocalFactor K α p := by
  classical
  unfold rankinPrimeGeomLocalFactor
  have h0mem : 0 ∈ Finset.range (Nat.log p K + 1) := by
    rw [Finset.mem_range]
    omega
  have hterm0 :
      ((((p ^ 0 : ℕ) : ℝ)) ^ (-α)) = 1 := by
    simp
  calc
    (1 : ℝ) = (((p ^ 0 : ℕ) : ℝ)) ^ (-α) := hterm0.symm
    _ ≤ ∑ e ∈ Finset.range (Nat.log p K + 1), (((p ^ e : ℕ) : ℝ)) ^ (-α) :=
        Finset.single_le_sum
          (by
            intro e _he
            exact Real.rpow_nonneg (Nat.cast_nonneg (p ^ e)) (-α))
          h0mem

/-- The local finite geometric factor is positive. -/
theorem rankinPrimeGeomLocalFactor_pos (K : ℕ) (α : ℝ) (p : ℕ) :
    0 < rankinPrimeGeomLocalFactor K α p :=
  lt_of_lt_of_le zero_lt_one (one_le_rankinPrimeGeomLocalFactor K α p)

/-- The finite prime-geometric Rankin product is positive. -/
theorem rankinPrimeGeomProduct_pos (K z : ℕ) (α : ℝ) :
    0 < rankinPrimeGeomProduct K z α := by
  classical
  unfold rankinPrimeGeomProduct
  exact Finset.prod_pos (by
    intro p _hp
    exact rankinPrimeGeomLocalFactor_pos K α p)

/-- The logarithm of the finite prime-geometric product is exactly the additive
logarithmic carrier. -/
theorem log_rankinPrimeGeomProduct_eq_logSum (K z : ℕ) (α : ℝ) :
    Real.log (rankinPrimeGeomProduct K z α) =
      rankinPrimeGeomLogSum K z α := by
  classical
  unfold rankinPrimeGeomProduct rankinPrimeGeomLogSum rankinPrimeGeomLocalFactor
  rw [Real.log_prod]
  intro p _hp
  exact ne_of_gt (rankinPrimeGeomLocalFactor_pos K α p)

/-- The logarithmic carrier is bounded by the elementary excess carrier
`∑ (local factor - 1)`. -/
theorem rankinPrimeGeomLogSum_le_excessSum (K z : ℕ) (α : ℝ) :
    rankinPrimeGeomLogSum K z α ≤ rankinPrimeGeomExcessSum K z α := by
  classical
  unfold rankinPrimeGeomLogSum rankinPrimeGeomExcessSum
  apply Finset.sum_le_sum
  intro p _hp
  exact Real.log_le_sub_one_of_pos (rankinPrimeGeomLocalFactor_pos K α p)

/-- Each local finite factor is `1` plus its positive-exponent tail. -/
theorem rankinPrimeGeomLocalFactor_eq_tail_add_one (K : ℕ) (α : ℝ) (p : ℕ) :
    rankinPrimeGeomLocalFactor K α p = rankinPrimeGeomLocalTail K α p + 1 := by
  classical
  unfold rankinPrimeGeomLocalFactor rankinPrimeGeomLocalTail
  rw [Finset.sum_range_succ']
  simp

/-- The excess carrier is exactly the explicit positive-exponent tail carrier. -/
theorem rankinPrimeGeomExcessSum_eq_tailSum (K z : ℕ) (α : ℝ) :
    rankinPrimeGeomExcessSum K z α = rankinPrimeGeomTailSum K z α := by
  classical
  unfold rankinPrimeGeomExcessSum rankinPrimeGeomTailSum
  apply Finset.sum_congr rfl
  intro p _hp
  rw [rankinPrimeGeomLocalFactor_eq_tail_add_one K α p]
  ring

/-- On a prime, the positive-exponent local tail is exactly the finite
geometric tail with ratio `p^{-α}`. -/
theorem rankinPrimeGeomLocalTail_eq_rpowTail
    {K p : ℕ} {α : ℝ} (hp : Nat.Prime p) :
    rankinPrimeGeomLocalTail K α p = rankinPrimeGeomLocalRpowTail K α p := by
  classical
  unfold rankinPrimeGeomLocalTail rankinPrimeGeomLocalRpowTail
  have hp_pos : 0 < (p : ℝ) := by exact_mod_cast hp.pos
  apply Finset.sum_congr rfl
  intro e _he
  have hcast : (((p ^ (e + 1) : ℕ) : ℝ)) = (p : ℝ) ^ (e + 1) := by
    norm_num [Nat.cast_pow]
  calc
    (((p ^ (e + 1) : ℕ) : ℝ)) ^ (-α)
        = ((p : ℝ) ^ (e + 1)) ^ (-α) := by rw [hcast]
    _ = (p : ℝ) ^ ((e + 1 : ℕ) * (-α)) := by
          exact (Real.rpow_natCast_mul hp_pos.le (e + 1) (-α)).symm
    _ = (p : ℝ) ^ ((-α) * (e + 1 : ℕ)) := by
          congr 1
          ring_nf
    _ = ((p : ℝ) ^ (-α)) ^ (e + 1) := by
          exact Real.rpow_mul_natCast hp_pos.le (-α) (e + 1)

/-- The explicit prime-power tail and the geometric-tail carrier agree over
the prime support. -/
theorem rankinPrimeGeomTailSum_eq_rpowTailSum (K z : ℕ) (α : ℝ) :
    rankinPrimeGeomTailSum K z α = rankinPrimeGeomRpowTailSum K z α := by
  classical
  unfold rankinPrimeGeomTailSum rankinPrimeGeomRpowTailSum
  apply Finset.sum_congr rfl
  intro p hpz
  exact rankinPrimeGeomLocalTail_eq_rpowTail (Nat.prime_of_mem_primesBelow hpz)

/-- A finite shifted geometric sum is bounded by its infinite geometric tail. -/
theorem finite_geometric_shifted_sum_le_div_one_sub
    {q : ℝ} (hq0 : 0 ≤ q) (hq1 : q < 1) (N : ℕ) :
    (∑ e ∈ Finset.range N, q ^ (e + 1)) ≤ q / (1 - q) := by
  have hden_pos : 0 < 1 - q := sub_pos.mpr hq1
  have hden_ne : 1 - q ≠ 0 := ne_of_gt hden_pos
  have hq_ne : q ≠ 1 := ne_of_lt hq1
  have hq_sub_ne : q - 1 ≠ 0 := sub_ne_zero.mpr hq_ne
  have hsum_eq :
      (∑ e ∈ Finset.range N, q ^ (e + 1)) =
        q * ∑ e ∈ Finset.range N, q ^ e := by
    rw [Finset.mul_sum]
    apply Finset.sum_congr rfl
    intro e _he
    rw [pow_succ']
  have hgeom :
      (∑ e ∈ Finset.range N, q ^ e) = (1 - q ^ N) / (1 - q) := by
    rw [geom_sum_eq hq_ne N]
    field_simp [hden_ne, hq_sub_ne]
    ring_nf
  have hgeom_le :
      (∑ e ∈ Finset.range N, q ^ e) ≤ 1 / (1 - q) := by
    rw [hgeom]
    exact div_le_div_of_nonneg_right
      (sub_le_self 1 (pow_nonneg hq0 N)) hden_pos.le
  calc
    (∑ e ∈ Finset.range N, q ^ (e + 1))
        = q * ∑ e ∈ Finset.range N, q ^ e := hsum_eq
    _ ≤ q * (1 / (1 - q)) := mul_le_mul_of_nonneg_left hgeom_le hq0
    _ = q / (1 - q) := by ring_nf

/-- The finite geometric local tail is bounded by the infinite-geometric local
majorant. -/
theorem rankinPrimeGeomLocalRpowTail_le_geomMajorant
    {K p : ℕ} {α : ℝ} (hα0 : 0 < α) (hp : Nat.Prime p) :
    rankinPrimeGeomLocalRpowTail K α p ≤
      rankinPrimeGeomLocalGeomMajorant α p := by
  classical
  unfold rankinPrimeGeomLocalRpowTail rankinPrimeGeomLocalGeomMajorant
  have hp_pos : 0 < (p : ℝ) := by exact_mod_cast hp.pos
  have hp_one_lt : (1 : ℝ) < p := by exact_mod_cast hp.one_lt
  have hq0 : 0 ≤ (p : ℝ) ^ (-α) :=
    (Real.rpow_pos_of_pos hp_pos (-α)).le
  have hq1 : (p : ℝ) ^ (-α) < 1 :=
    Real.rpow_lt_one_of_one_lt_of_neg hp_one_lt (by linarith)
  exact finite_geometric_shifted_sum_le_div_one_sub hq0 hq1 (Nat.log p K)

/-- The finite geometric-tail carrier is bounded by the additive
infinite-geometric majorant. -/
theorem rankinPrimeGeomRpowTailSum_le_geomMajorantSum
    (K z : ℕ) {α : ℝ} (hα0 : 0 < α) :
    rankinPrimeGeomRpowTailSum K z α ≤ rankinPrimeGeomGeomMajorantSum z α := by
  classical
  unfold rankinPrimeGeomRpowTailSum rankinPrimeGeomGeomMajorantSum
  apply Finset.sum_le_sum
  intro p hpz
  exact rankinPrimeGeomLocalRpowTail_le_geomMajorant hα0
    (Nat.prime_of_mem_primesBelow hpz)

/-- Uniformly bound the denominator in the infinite-geometric local majorant by
its worst prime value at `p = 2`. -/
theorem rankinPrimeGeomLocalGeomMajorant_le_scaled_rpow
    {p : ℕ} {α : ℝ} (hα0 : 0 < α) (hp : Nat.Prime p) :
    rankinPrimeGeomLocalGeomMajorant α p ≤
      (1 / (1 - (2 : ℝ) ^ (-α))) * (p : ℝ) ^ (-α) := by
  unfold rankinPrimeGeomLocalGeomMajorant
  have htwo_pos : 0 < (2 : ℝ) := by norm_num
  have hp_pos : 0 < (p : ℝ) := by exact_mod_cast hp.pos
  have htwo_le_p : (2 : ℝ) ≤ p := by exact_mod_cast hp.two_le
  have hq0 : 0 ≤ (p : ℝ) ^ (-α) := (Real.rpow_pos_of_pos hp_pos (-α)).le
  have hq2_lt_one : (2 : ℝ) ^ (-α) < 1 :=
    Real.rpow_lt_one_of_one_lt_of_neg (by norm_num : (1 : ℝ) < 2) (by linarith)
  have hden2_pos : 0 < 1 - (2 : ℝ) ^ (-α) := sub_pos.mpr hq2_lt_one
  have hq_le_q2 : (p : ℝ) ^ (-α) ≤ (2 : ℝ) ^ (-α) :=
    Real.rpow_le_rpow_of_nonpos htwo_pos htwo_le_p (by linarith)
  have hden_le : 1 - (2 : ℝ) ^ (-α) ≤ 1 - (p : ℝ) ^ (-α) := by
    linarith
  have hinv_le :
      1 / (1 - (p : ℝ) ^ (-α)) ≤ 1 / (1 - (2 : ℝ) ^ (-α)) :=
    one_div_le_one_div_of_le hden2_pos hden_le
  calc
    (p : ℝ) ^ (-α) / (1 - (p : ℝ) ^ (-α))
        = (p : ℝ) ^ (-α) * (1 / (1 - (p : ℝ) ^ (-α))) := by ring_nf
    _ ≤ (p : ℝ) ^ (-α) * (1 / (1 - (2 : ℝ) ^ (-α))) :=
        mul_le_mul_of_nonneg_left hinv_le hq0
    _ = (1 / (1 - (2 : ℝ) ^ (-α))) * (p : ℝ) ^ (-α) := by ring

/-- The denominator-weighted geometric majorant is controlled by the plain
prime-power sum, up to the constant coming from the prime `2`. -/
theorem rankinPrimeGeomMajorantSum_le_scaled_primeRpowSum
    (z : ℕ) {α : ℝ} (hα0 : 0 < α) :
    rankinPrimeGeomGeomMajorantSum z α ≤
      (1 / (1 - (2 : ℝ) ^ (-α))) * rankinPrimeRpowSum z α := by
  classical
  unfold rankinPrimeGeomGeomMajorantSum rankinPrimeRpowSum
  calc
    (∑ p ∈ z.primesBelow, rankinPrimeGeomLocalGeomMajorant α p)
        ≤ ∑ p ∈ z.primesBelow,
            (1 / (1 - (2 : ℝ) ^ (-α))) * (p : ℝ) ^ (-α) := by
          apply Finset.sum_le_sum
          intro p hpz
          exact rankinPrimeGeomLocalGeomMajorant_le_scaled_rpow hα0
            (Nat.prime_of_mem_primesBelow hpz)
    _ = (1 / (1 - (2 : ℝ) ^ (-α))) *
          ∑ p ∈ z.primesBelow, (p : ℝ) ^ (-α) := by
          rw [Finset.mul_sum]

/-- The prime-power sum is bounded by the corresponding all-integers power
sum. -/
theorem rankinPrimeRpowSum_le_natRpowSum (z : ℕ) (α : ℝ) :
    rankinPrimeRpowSum z α ≤ rankinNatRpowSum z α := by
  classical
  unfold rankinPrimeRpowSum rankinNatRpowSum
  refine Finset.sum_le_sum_of_subset_of_nonneg ?_ ?_
  · intro p hpz
    rw [Finset.mem_Icc]
    exact ⟨(Nat.prime_of_mem_primesBelow hpz).one_le,
      Nat.le_of_lt (Nat.lt_of_mem_primesBelow hpz)⟩
  · intro p _hpz hpnot
    exact Real.rpow_nonneg (Nat.cast_nonneg p) (-α)

/-- The positive-exponent local tail is bounded by the number of exponent slots
times the first positive term. -/
theorem rankinPrimeGeomLocalTail_le_log_mul_first
    {K p : ℕ} {α : ℝ} (hα0 : 0 < α) (hp : Nat.Prime p) :
    rankinPrimeGeomLocalTail K α p ≤ (Nat.log p K : ℝ) * (p : ℝ) ^ (-α) := by
  classical
  unfold rankinPrimeGeomLocalTail
  have hp_pos : 0 < (p : ℝ) := by exact_mod_cast hp.pos
  calc
    (∑ e ∈ Finset.range (Nat.log p K), (((p ^ (e + 1) : ℕ) : ℝ)) ^ (-α))
        ≤ ∑ _e ∈ Finset.range (Nat.log p K), (p : ℝ) ^ (-α) := by
          apply Finset.sum_le_sum
          intro e _he
          have hpow_le_nat : p ≤ p ^ (e + 1) :=
            Nat.le_self_pow (Nat.succ_ne_zero e) p
          have hpow_le : (p : ℝ) ≤ ((p ^ (e + 1) : ℕ) : ℝ) := by
            exact_mod_cast hpow_le_nat
          exact Real.rpow_le_rpow_of_nonpos hp_pos hpow_le (neg_nonpos.mpr hα0.le)
    _ = (Nat.log p K : ℝ) * (p : ℝ) ^ (-α) := by
          rw [Finset.sum_const, Finset.card_range, nsmul_eq_mul]

/-- The explicit positive-exponent tail is bounded by the log-weighted first-tail
carrier. -/
theorem rankinPrimeGeomTailSum_le_logWeightedTailSum
    (K z : ℕ) {α : ℝ} (hα0 : 0 < α) :
    rankinPrimeGeomTailSum K z α ≤ rankinPrimeGeomLogWeightedTailSum K z α := by
  classical
  unfold rankinPrimeGeomTailSum rankinPrimeGeomLogWeightedTailSum
  apply Finset.sum_le_sum
  intro p hpz
  exact rankinPrimeGeomLocalTail_le_log_mul_first hα0
    (Nat.prime_of_mem_primesBelow hpz)

/-- The log-weighted tail is bounded by the uniform-base carrier using
`log_p K ≤ log_2 K` for every prime `p`. -/
theorem rankinPrimeGeomLogWeightedTailSum_le_uniformLogTailSum
    (K z : ℕ) (α : ℝ) :
    rankinPrimeGeomLogWeightedTailSum K z α ≤
      rankinPrimeGeomUniformLogTailSum K z α := by
  classical
  unfold rankinPrimeGeomLogWeightedTailSum rankinPrimeGeomUniformLogTailSum
  calc
    (∑ p ∈ z.primesBelow, (Nat.log p K : ℝ) * (p : ℝ) ^ (-α))
        ≤ ∑ p ∈ z.primesBelow, (Nat.log 2 K : ℝ) * (p : ℝ) ^ (-α) := by
          apply Finset.sum_le_sum
          intro p hpz
          have hlog : Nat.log p K ≤ Nat.log 2 K :=
            Nat.log_anti_left Nat.one_lt_two (Nat.prime_of_mem_primesBelow hpz).two_le
          exact mul_le_mul_of_nonneg_right
            (by exact_mod_cast hlog)
            (Real.rpow_nonneg (Nat.cast_nonneg p) (-α))
    _ = (Nat.log 2 K : ℝ) * ∑ p ∈ z.primesBelow, (p : ℝ) ^ (-α) := by
          rw [Finset.mul_sum]

/-- A logarithmic additive bound implies the finite Rankin prime-product bound. -/
theorem rankinPrimeGeomProduct_le_of_logSum_bound
    {K z : ℕ} {α ε A : ℝ}
    (hK : 0 < K) (hA : 0 < A)
    (hLog : rankinPrimeGeomLogSum K z α ≤ Real.log (A * (K : ℝ) ^ ε)) :
    rankinPrimeGeomProduct K z α ≤ A * (K : ℝ) ^ ε := by
  have hprod_pos : 0 < rankinPrimeGeomProduct K z α :=
    rankinPrimeGeomProduct_pos K z α
  have htarget_pos : 0 < A * (K : ℝ) ^ ε := by
    exact mul_pos hA (Real.rpow_pos_of_pos (by exact_mod_cast hK) ε)
  have hlog_prod :
      Real.log (rankinPrimeGeomProduct K z α) ≤
        Real.log (A * (K : ℝ) ^ ε) := by
    simpa [log_rankinPrimeGeomProduct_eq_logSum K z α] using hLog
  exact (Real.log_le_log_iff hprod_pos htarget_pos).mp hlog_prod

/-- A finite excess-sum bound implies the finite Rankin prime-product bound. -/
theorem rankinPrimeGeomProduct_le_of_excessSum_bound
    {K z : ℕ} {α ε A : ℝ}
    (hK : 0 < K) (hA : 0 < A)
    (hExcess : rankinPrimeGeomExcessSum K z α ≤ Real.log (A * (K : ℝ) ^ ε)) :
    rankinPrimeGeomProduct K z α ≤ A * (K : ℝ) ^ ε :=
  rankinPrimeGeomProduct_le_of_logSum_bound hK hA
    ((rankinPrimeGeomLogSum_le_excessSum K z α).trans hExcess)

/-- A positive-exponent tail bound implies the finite Rankin prime-product
bound. -/
theorem rankinPrimeGeomProduct_le_of_tailSum_bound
    {K z : ℕ} {α ε A : ℝ}
    (hK : 0 < K) (hA : 0 < A)
    (hTail : rankinPrimeGeomTailSum K z α ≤ Real.log (A * (K : ℝ) ^ ε)) :
    rankinPrimeGeomProduct K z α ≤ A * (K : ℝ) ^ ε :=
  rankinPrimeGeomProduct_le_of_excessSum_bound hK hA
    (by simpa [rankinPrimeGeomExcessSum_eq_tailSum K z α] using hTail)

/-- A geometric-tail bound implies the finite Rankin prime-product bound. -/
theorem rankinPrimeGeomProduct_le_of_rpowTailSum_bound
    {K z : ℕ} {α ε A : ℝ}
    (hK : 0 < K) (hA : 0 < A)
    (hTail : rankinPrimeGeomRpowTailSum K z α ≤ Real.log (A * (K : ℝ) ^ ε)) :
    rankinPrimeGeomProduct K z α ≤ A * (K : ℝ) ^ ε :=
  rankinPrimeGeomProduct_le_of_tailSum_bound hK hA
    (by simpa [rankinPrimeGeomTailSum_eq_rpowTailSum K z α] using hTail)

/-- An infinite-geometric-majorant bound implies the finite Rankin prime-product
bound. -/
theorem rankinPrimeGeomProduct_le_of_geomMajorantSum_bound
    {K z : ℕ} {α ε A : ℝ}
    (hK : 0 < K) (hα0 : 0 < α) (hA : 0 < A)
    (hTail : rankinPrimeGeomGeomMajorantSum z α ≤ Real.log (A * (K : ℝ) ^ ε)) :
    rankinPrimeGeomProduct K z α ≤ A * (K : ℝ) ^ ε :=
  rankinPrimeGeomProduct_le_of_rpowTailSum_bound hK hA
    ((rankinPrimeGeomRpowTailSum_le_geomMajorantSum K z hα0).trans hTail)

/-- A plain prime-power-sum bound implies the finite Rankin prime-product bound,
with the geometric denominator absorbed into an explicit constant. -/
theorem rankinPrimeGeomProduct_le_of_primeRpowSum_bound
    {K z : ℕ} {α ε A : ℝ}
    (hK : 0 < K) (hα0 : 0 < α) (hA : 0 < A)
    (hTail :
      (1 / (1 - (2 : ℝ) ^ (-α))) * rankinPrimeRpowSum z α ≤
        Real.log (A * (K : ℝ) ^ ε)) :
    rankinPrimeGeomProduct K z α ≤ A * (K : ℝ) ^ ε :=
  rankinPrimeGeomProduct_le_of_geomMajorantSum_bound hK hα0 hA
    ((rankinPrimeGeomMajorantSum_le_scaled_primeRpowSum z hα0).trans hTail)

/-- An all-integers power-sum bound implies the finite Rankin prime-product
bound. -/
theorem rankinPrimeGeomProduct_le_of_natRpowSum_bound
    {K z : ℕ} {α ε A : ℝ}
    (hK : 0 < K) (hα0 : 0 < α) (hA : 0 < A)
    (hTail :
      (1 / (1 - (2 : ℝ) ^ (-α))) * rankinNatRpowSum z α ≤
        Real.log (A * (K : ℝ) ^ ε)) :
    rankinPrimeGeomProduct K z α ≤ A * (K : ℝ) ^ ε := by
  have hq2_lt_one : (2 : ℝ) ^ (-α) < 1 :=
    Real.rpow_lt_one_of_one_lt_of_neg (by norm_num : (1 : ℝ) < 2) (by linarith)
  have hden2_nonneg : 0 ≤ 1 - (2 : ℝ) ^ (-α) := (sub_pos.mpr hq2_lt_one).le
  have hc_nonneg : 0 ≤ 1 / (1 - (2 : ℝ) ^ (-α)) :=
    div_nonneg zero_le_one hden2_nonneg
  exact
    rankinPrimeGeomProduct_le_of_primeRpowSum_bound hK hα0 hA
      ((mul_le_mul_of_nonneg_left (rankinPrimeRpowSum_le_natRpowSum z α) hc_nonneg).trans
        hTail)

/-- A log-weighted first-tail bound implies the finite Rankin prime-product
bound. -/
theorem rankinPrimeGeomProduct_le_of_logWeightedTailSum_bound
    {K z : ℕ} {α ε A : ℝ}
    (hK : 0 < K) (hα0 : 0 < α) (hA : 0 < A)
    (hTail : rankinPrimeGeomLogWeightedTailSum K z α ≤ Real.log (A * (K : ℝ) ^ ε)) :
    rankinPrimeGeomProduct K z α ≤ A * (K : ℝ) ^ ε :=
  rankinPrimeGeomProduct_le_of_tailSum_bound hK hA
    ((rankinPrimeGeomTailSum_le_logWeightedTailSum K z hα0).trans hTail)

/-- A uniform-base log tail bound implies the finite Rankin prime-product bound. -/
theorem rankinPrimeGeomProduct_le_of_uniformLogTailSum_bound
    {K z : ℕ} {α ε A : ℝ}
    (hK : 0 < K) (hα0 : 0 < α) (hA : 0 < A)
    (hTail : rankinPrimeGeomUniformLogTailSum K z α ≤ Real.log (A * (K : ℝ) ^ ε)) :
    rankinPrimeGeomProduct K z α ≤ A * (K : ℝ) ^ ε :=
  rankinPrimeGeomProduct_le_of_logWeightedTailSum_bound hK hα0 hA
    ((rankinPrimeGeomLogWeightedTailSum_le_uniformLogTailSum K z α).trans hTail)

/-- The finite prime-geometric product expands exactly as a sum over the
prime-exponent box. -/
theorem rankinPrimeGeomProduct_eq_exponentBox_sum (K z : ℕ) (α : ℝ) :
    rankinPrimeGeomProduct K z α =
      ∑ v ∈ rankinPrimeExponentBox K z, rankinPrimeExponentBoxWeight z α v := by
  classical
  unfold rankinPrimeGeomProduct rankinPrimeExponentBox rankinPrimeExponentBoxWeight
  rw [Finset.prod_sum]

/-- Every exponent-box weight is nonnegative. -/
theorem rankinPrimeExponentBoxWeight_nonneg (z : ℕ) (α : ℝ)
    (v : ∀ p : ℕ, p ∈ z.primesBelow → ℕ) :
    0 ≤ rankinPrimeExponentBoxWeight z α v := by
  classical
  unfold rankinPrimeExponentBoxWeight
  exact Finset.prod_nonneg (by
    intro x _hx
    exact Real.rpow_nonneg (Nat.cast_nonneg (x.1 ^ v x.1 x.2)) (-α))

/-- Exponent bound for a smooth number inside the Rankin carrier.

If `n ≤ K` and `n` is `z`-smooth, then the exponent of every prime `p` in `n`
is at most `log_p K`.  This is the box constraint used by the finite
prime-geometric product comparison. -/
theorem smoothNumbersUpTo_factorization_le_log
    {K z n p : ℕ} (hn : n ∈ Nat.smoothNumbersUpTo K z) (hp : Nat.Prime p) :
    n.factorization p ≤ Nat.log p K := by
  have hnpack := Nat.mem_smoothNumbersUpTo.mp hn
  have hn_ne_zero : n ≠ 0 := Nat.ne_zero_of_mem_smoothNumbers hnpack.2
  by_cases hfac : n.factorization p = 0
  · rw [hfac]
    exact Nat.zero_le _
  · have hpow_dvd : p ^ n.factorization p ∣ n :=
      (hp.pow_dvd_iff_le_factorization hn_ne_zero).mpr le_rfl
    have hpow_le_n : p ^ n.factorization p ≤ n :=
      Nat.le_of_dvd (Nat.pos_of_ne_zero hn_ne_zero) hpow_dvd
    exact Nat.le_log_of_pow_le hp.one_lt (le_trans hpow_le_n hnpack.1)

/-- A prime outside the smoothness cutoff has exponent zero in any
`z`-smooth number. -/
theorem smoothNumbersUpTo_factorization_eq_zero_of_not_mem_primesBelow
    {K z n p : ℕ} (hn : n ∈ Nat.smoothNumbersUpTo K z)
    (hp : Nat.Prime p) (hpnot : p ∉ z.primesBelow) :
    n.factorization p = 0 := by
  have hsmooth := (Nat.mem_smoothNumbersUpTo.mp hn).2
  apply Nat.factorization_eq_zero_of_not_dvd
  intro hpdvd
  have hp_lt_z : p < z := (Nat.mem_smoothNumbers'.mp hsmooth) p hp hpdvd
  exact hpnot (Nat.mem_primesBelow.mpr ⟨hp_lt_z, hp⟩)

/-- Raw exponent vector of `n`, restricted to primes below `z`. -/
noncomputable def smoothExponentVector (z n : ℕ) :
    ∀ p : ℕ, p ∈ z.primesBelow → ℕ :=
  fun p _hp => n.factorization p

/-- A smooth number determines an exponent vector lying in the finite Rankin
exponent box. -/
theorem smoothExponentVector_mem_rankinPrimeExponentBox
    {K z n : ℕ} (hn : n ∈ Nat.smoothNumbersUpTo K z) :
    smoothExponentVector z n ∈ rankinPrimeExponentBox K z := by
  classical
  rw [rankinPrimeExponentBox, Finset.mem_pi]
  intro p hpz
  rw [Finset.mem_range]
  exact Nat.lt_succ_of_le
    (smoothNumbersUpTo_factorization_le_log hn (Nat.prime_of_mem_primesBelow hpz))

/-- On the smooth-number carrier, the restricted exponent vector is injective. -/
theorem smoothExponentVector_injective_on_smoothNumbersUpTo
    {K z n m : ℕ}
    (hn : n ∈ Nat.smoothNumbersUpTo K z)
    (hm : m ∈ Nat.smoothNumbersUpTo K z)
    (hvec : smoothExponentVector z n = smoothExponentVector z m) :
    n = m := by
  have hnpack := Nat.mem_smoothNumbersUpTo.mp hn
  have hmpack := Nat.mem_smoothNumbersUpTo.mp hm
  have hn_ne_zero : n ≠ 0 := Nat.ne_zero_of_mem_smoothNumbers hnpack.2
  have hm_ne_zero : m ≠ 0 := Nat.ne_zero_of_mem_smoothNumbers hmpack.2
  refine Nat.eq_of_factorization_eq hn_ne_zero hm_ne_zero ?_
  intro p
  by_cases hp : Nat.Prime p
  · by_cases hpz : p ∈ z.primesBelow
    · have hcongr := congrFun (congrFun hvec p) hpz
      simpa [smoothExponentVector] using hcongr
    · rw [smoothNumbersUpTo_factorization_eq_zero_of_not_mem_primesBelow hn hp hpz,
        smoothNumbersUpTo_factorization_eq_zero_of_not_mem_primesBelow hm hp hpz]
  · rw [Nat.factorization_eq_zero_of_non_prime n hp,
      Nat.factorization_eq_zero_of_non_prime m hp]

/-- The support of the factorization of a smooth number is contained in the
finite set of primes below the smoothness cutoff. -/
theorem factorization_support_subset_primesBelow_of_smoothNumbersUpTo
    {K z n : ℕ} (hn : n ∈ Nat.smoothNumbersUpTo K z) :
    n.factorization.support ⊆ z.primesBelow := by
  intro p hp
  have hsmooth := (Nat.mem_smoothNumbersUpTo.mp hn).2
  have hpPrime : Nat.Prime p := by
    exact Nat.prime_of_mem_primeFactors (by simpa [Nat.support_factorization] using hp)
  have hpdvd : p ∣ n := by
    exact Nat.dvd_of_mem_primeFactors (by simpa [Nat.support_factorization] using hp)
  exact Nat.mem_primesBelow.mpr
    ⟨(Nat.mem_smoothNumbers'.mp hsmooth) p hpPrime hpdvd, hpPrime⟩

/-- A smooth number is reconstructed by multiplying the prime powers indexed by
the finite cutoff prime set. -/
theorem smoothNumbersUpTo_prod_primesBelow_factorization_eq_self
    {K z n : ℕ} (hn : n ∈ Nat.smoothNumbersUpTo K z) :
    (∏ p ∈ z.primesBelow, p ^ n.factorization p) = n := by
  have hnpack := Nat.mem_smoothNumbersUpTo.mp hn
  have hn_ne_zero : n ≠ 0 := Nat.ne_zero_of_mem_smoothNumbers hnpack.2
  have hsupport := factorization_support_subset_primesBelow_of_smoothNumbersUpTo hn
  calc
    (∏ p ∈ z.primesBelow, p ^ n.factorization p)
        = n.factorization.prod (fun p e => p ^ e) := by
          exact (Finsupp.prod_of_support_subset n.factorization hsupport
            (fun p e => p ^ e)
            (by
              intro p _hp
              exact pow_zero p)).symm
    _ = n := Nat.factorization_prod_pow_eq_self hn_ne_zero

/-- The real product over the cutoff prime powers reconstructs the smooth
number. -/
theorem smoothNumbersUpTo_real_prod_primesBelow_factorization_eq_self
    {K z n : ℕ} (hn : n ∈ Nat.smoothNumbersUpTo K z) :
    (∏ p ∈ z.primesBelow, ((p ^ n.factorization p : ℕ) : ℝ)) = (n : ℝ) := by
  exact_mod_cast smoothNumbersUpTo_prod_primesBelow_factorization_eq_self hn

/-- The Rankin product weight of the exponent vector of a smooth number is
exactly the original smooth-number Rankin weight. -/
theorem rankinPrimeExponentBoxWeight_smoothExponentVector
    {K z n : ℕ} (hn : n ∈ Nat.smoothNumbersUpTo K z) (α : ℝ) :
    rankinPrimeExponentBoxWeight z α (smoothExponentVector z n) = (n : ℝ) ^ (-α) := by
  classical
  unfold rankinPrimeExponentBoxWeight smoothExponentVector
  rw [Real.finset_prod_rpow]
  · have hprod :
        (∏ x ∈ z.primesBelow.attach,
          ((x.1 ^ n.factorization x.1 : ℕ) : ℝ)) = (n : ℝ) := by
        calc
          (∏ x ∈ z.primesBelow.attach,
              ((x.1 ^ n.factorization x.1 : ℕ) : ℝ))
              = ∏ p ∈ z.primesBelow, ((p ^ n.factorization p : ℕ) : ℝ) := by
                simpa using
                  (Finset.prod_attach z.primesBelow
                    (fun p : ℕ => ((p ^ n.factorization p : ℕ) : ℝ)))
          _ = (n : ℝ) := smoothNumbersUpTo_real_prod_primesBelow_factorization_eq_self hn
    rw [hprod]
  · intro x _hx
    exact Nat.cast_nonneg (x.1 ^ n.factorization x.1)

/-- The weighted smooth-number Rankin carrier is bounded by the finite
prime-geometric product. -/
theorem rankinWeightedSmoothSum_le_rankinPrimeGeomProduct
    (K z : ℕ) (α : ℝ) :
    rankinWeightedSmoothSum K z α ≤ rankinPrimeGeomProduct K z α := by
  classical
  let S : Finset ℕ := Nat.smoothNumbersUpTo K z
  let f : ℕ → (∀ p : ℕ, p ∈ z.primesBelow → ℕ) := fun n => smoothExponentVector z n
  let w : (∀ p : ℕ, p ∈ z.primesBelow → ℕ) → ℝ :=
    fun v => rankinPrimeExponentBoxWeight z α v
  have hinj : Set.InjOn f ↑S := by
    intro n hn m hm hnm
    exact smoothExponentVector_injective_on_smoothNumbersUpTo hn hm hnm
  have himage_subset : S.image f ⊆ rankinPrimeExponentBox K z := by
    rw [Finset.image_subset_iff]
    intro n hn
    exact smoothExponentVector_mem_rankinPrimeExponentBox hn
  have hsum_image :
      (∑ n ∈ S, w (f n)) = ∑ v ∈ S.image f, w v := by
    exact (Finset.sum_image hinj).symm
  calc
    rankinWeightedSmoothSum K z α
        = ∑ n ∈ S, (n : ℝ) ^ (-α) := by rfl
    _ = ∑ n ∈ S, w (f n) := by
        apply Finset.sum_congr rfl
        intro n hn
        exact (rankinPrimeExponentBoxWeight_smoothExponentVector hn α).symm
    _ = ∑ v ∈ S.image f, w v := hsum_image
    _ ≤ ∑ v ∈ rankinPrimeExponentBox K z, w v :=
        Finset.sum_le_sum_of_subset_of_nonneg himage_subset (by
          intro v _hvBox _hvImage
          exact rankinPrimeExponentBoxWeight_nonneg z α v)
    _ = rankinPrimeGeomProduct K z α := by
        rw [rankinPrimeGeomProduct_eq_exponentBox_sum]

/-- Monotonicity of the weighted smooth-number carrier in the size cutoff. -/
theorem rankinWeightedSmoothSum_mono_size {Y K z : ℕ} (hYK : Y ≤ K) (α : ℝ) :
    rankinWeightedSmoothSum Y z α ≤ rankinWeightedSmoothSum K z α := by
  simpa [rankinWeightedSmoothSum] using
    smoothNumbersUpTo_weighted_sum_mono (Y := Y) (K := K) (z := z) hYK α

/-- Rankin inequality rewritten using the named weighted smooth carrier. -/
theorem smoothNumbersUpTo_card_le_rpow_mul_rankinWeightedSmoothSum
    (Y z : ℕ) {α : ℝ} (hα0 : 0 < α) :
    ((Nat.smoothNumbersUpTo Y z).card : ℝ) ≤
      (Y : ℝ) ^ α * rankinWeightedSmoothSum Y z α := by
  simpa [rankinWeightedSmoothSum] using
    smoothNumbersUpTo_card_le_rpow_mul_weighted_sum Y z hα0

/-- A global dyadic weighted Rankin sum implies the primitive dyadic pointwise
smooth-count estimate.

This isolates the remaining smooth-number work in the standard Euler-product
object `∑_{n∈Ψ(K,z_K)} n^{-α}`.  The passage from that global weighted sum to
every fiber `Ψ(K/m,z_K)` is fully checked: monotonicity gives the fiber
weighted sum, and `smoothNumbersUpTo_card_le_rpow_mul_weighted_sum` supplies the
Rankin factor `(K/m)^α`. -/
theorem rankin_mathlibSmoothNumbersUpTo_zNatScale_dyadic_pointwise_natDiv_bound_of_global_weighted_sum
    (hGlobal :
      ∃ α ε A : ℝ, 0 < α ∧ α < 1 ∧ 0 ≤ ε ∧ ε < (1 - α) / 2 ∧ 0 < A ∧
        ∀ k : ℕ, 2 ≤ k →
          (∑ n ∈ Nat.smoothNumbersUpTo (2 ^ k) (zNatScale (2 ^ k) + 1),
              (n : ℝ) ^ (-α))
            ≤ A * ((2 ^ k : ℕ) : ℝ) ^ ε) :
    ∃ α ε A : ℝ, 0 < α ∧ α < 1 ∧ 0 ≤ ε ∧ ε < (1 - α) / 2 ∧ 0 < A ∧
      ∀ k m : ℕ, 2 ≤ k →
        m ∈ Finset.Icc 1 (Nat.sqrt (2 ^ k)) →
          ((Nat.smoothNumbersUpTo ((2 ^ k) / m) (zNatScale (2 ^ k) + 1)).card : ℝ)
            ≤ A * ((((2 ^ k) / m : ℕ) : ℝ) ^ α) * ((2 ^ k : ℕ) : ℝ) ^ ε := by
  rcases hGlobal with ⟨α, ε, A, hα0, hα1, hε0, hgap, hA, hGlobal⟩
  refine ⟨α, ε, A, hα0, hα1, hε0, hgap, hA, ?_⟩
  intro k m hk _hm
  let K : ℕ := 2 ^ k
  let Y : ℕ := K / m
  have hcard :
      ((Nat.smoothNumbersUpTo Y (zNatScale K + 1)).card : ℝ) ≤
        (Y : ℝ) ^ α *
          ∑ n ∈ Nat.smoothNumbersUpTo Y (zNatScale K + 1), (n : ℝ) ^ (-α) :=
    smoothNumbersUpTo_card_le_rpow_mul_weighted_sum Y (zNatScale K + 1) hα0
  have hsum_mono :
      (∑ n ∈ Nat.smoothNumbersUpTo Y (zNatScale K + 1), (n : ℝ) ^ (-α))
        ≤ ∑ n ∈ Nat.smoothNumbersUpTo K (zNatScale K + 1), (n : ℝ) ^ (-α) :=
    smoothNumbersUpTo_weighted_sum_mono (Nat.div_le_self K m) α
  have hsum_global :
      (∑ n ∈ Nat.smoothNumbersUpTo K (zNatScale K + 1), (n : ℝ) ^ (-α))
        ≤ A * (K : ℝ) ^ ε := by
    simpa [K] using hGlobal k hk
  have hYpow_nonneg : 0 ≤ (Y : ℝ) ^ α :=
    Real.rpow_nonneg (Nat.cast_nonneg Y) α
  calc
    ((Nat.smoothNumbersUpTo ((2 ^ k) / m) (zNatScale (2 ^ k) + 1)).card : ℝ)
        = ((Nat.smoothNumbersUpTo Y (zNatScale K + 1)).card : ℝ) := by rfl
    _ ≤ (Y : ℝ) ^ α *
          ∑ n ∈ Nat.smoothNumbersUpTo Y (zNatScale K + 1), (n : ℝ) ^ (-α) := hcard
    _ ≤ (Y : ℝ) ^ α *
          ∑ n ∈ Nat.smoothNumbersUpTo K (zNatScale K + 1), (n : ℝ) ^ (-α) :=
          mul_le_mul_of_nonneg_left hsum_mono hYpow_nonneg
    _ ≤ (Y : ℝ) ^ α * (A * (K : ℝ) ^ ε) :=
          mul_le_mul_of_nonneg_left hsum_global hYpow_nonneg
    _ = A * (Y : ℝ) ^ α * (K : ℝ) ^ ε := by ring
    _ = A * ((((2 ^ k) / m : ℕ) : ℝ) ^ α) *
          ((2 ^ k : ℕ) : ℝ) ^ ε := by rfl


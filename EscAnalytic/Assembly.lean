/-- Full endpoint for the optimization-shaped fixed-`m` route with the reduced
side stated as the direct reduced-sum estimate.

Compared with the canonical reduced-envelope endpoint, this theorem has no
auxiliary reduced class type, no `classOfRed`, and no class-cardinality envelope.
The non-analytic lift obligation is exactly the direct reduced-sum bound. -/
theorem fixed_m_paper_suen_optimization_direct_reduced_sum_full_outputs_and_final_standard_tail
    {ι : Type*}
    (m : ℕ) (hm : 2 ≤ m)
    (A : FixedNumeratorPaperSuenAnalyticCoreOptimizationInputs m ι)
    (Tred : ℕ)
    (hreduced_sum_large : ∀ N : ℕ, 3 ≤ N → Tred ≤ N →
      (∑ s ∈ Finset.Icc 1 N,
        (fixedNumeratorReducedExceptionalCount m (zNatScale N) (N / s) : ℝ)) ≤
          eulerProductFactorAtNat N * (A.Ered N : ℝ)) :
    (∀ N : ℕ, 3 ≤ N → A.T ≤ N → ((A.cls N).card : ℝ) ≤ A.Pz N) ∧
    (∀ N : ℕ, 3 ≤ N → A.T ≤ N →
      A.c * (Real.log N) ^ ((3 : ℝ) / 4)
        ≤ (1 - (A.εb N + Real.log 3 / A.μ N)) * A.μ N) ∧
    (∀ N : ℕ, 3 ≤ N → A.T ≤ N → ∀ b ∈ A.cls N,
      A.Mb N b ≤ ((N : ℝ) / A.Pz N) *
        (Inputs.suenProb (A.μ N) (A.δb N b) (A.Δb N b) + A.F2R N b) +
          A.errTerm N b) ∧
    (∀ N : ℕ, 3 ≤ N → A.T ≤ N → ∀ b ∈ A.cls N,
      Inputs.suenTailConstant * A.Δb N b * Real.exp (2 * A.δb N b)
        ≤ A.εb N * A.μ N) ∧
    (∀ N : ℕ, 3 ≤ N → A.T ≤ N → ∀ b ∈ A.cls N,
      A.errTerm N b ≤ A.Xpow N b * Real.exp ((1 + A.εK) * A.μ N)) ∧
    (∀ N : ℕ, 3 ≤ N → A.T ≤ N → ∀ b ∈ A.cls N,
      A.Pz N * A.Xpow N b * Real.exp (2 * A.μ N)
        ≤ (N : ℝ) * Real.exp (-4 * A.μ N)) ∧
    (∀ N : ℕ, 3 ≤ N → A.T ≤ N → ∀ b ∈ A.cls N,
      A.F2R N b ≤ Real.exp (-3 * A.μ N)) ∧
    (∀ N : ℕ, 3 ≤ N → A.T ≤ N → ∀ b ∈ A.cls N,
      A.Mb N b ≤ ((N : ℝ) / A.Pz N) *
        Real.exp (-(1 - (A.εb N + Real.log 3 / A.μ N)) * A.μ N)) ∧
    (∀ N : ℕ, 3 ≤ N → Tred ≤ N →

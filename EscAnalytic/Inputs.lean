/-- Reverse bridge from the live positive-range signed-multiples primitive to
the positive-range explicit alternating floor-error package. -/
theorem LinearSieveRoughDyadicMultiplesFloorErrorAbsQuarterBoundOnPositiveRanges_of_signed
    (h : LinearSieveRoughDyadicMultiplesSignedErrorQuarterBoundOnPositiveRanges) :
    LinearSieveRoughDyadicMultiplesFloorErrorAbsQuarterBoundOnPositiveRanges := by
  intro a₀ b₀ C₀ c Xprod ha₀ hab hc hprod
  rcases h a₀ b₀ C₀ c Xprod ha₀ hab hc hprod with ⟨Xl, Xu, hlower, hupper⟩

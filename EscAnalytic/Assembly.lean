/-- Convert a dyadic pointwise de Bruijn-style fiber estimate into the weighted
Rankin fiber estimate used by the divisor-power summation.

For an arbitrary `N`, take the dyadic cutoff `K = 2^(⌊log₂ N⌋+1)`, so
`N ≤ K ≤ 2N`.  The finite smooth-number carrier is monotone in both cutoffs,
and the dyadic loss is absorbed into the existential constant. -/
theorem rankin_mathlibSmoothNumbersUpTo_zNatScale_weighted_fiber_bound_of_dyadic_pointwise_natDiv
    (hDyadic :
      ∃ α ε A : ℝ, 0 < α ∧ α < 1 ∧ 0 ≤ ε ∧ ε < (1 - α) / 2 ∧ 0 < A ∧
        ∀ k m : ℕ, 2 ≤ k →
          m ∈ Finset.Icc 1 (Nat.sqrt (2 ^ k)) →
            ((Nat.smoothNumbersUpTo ((2 ^ k) / m) (zNatScale (2 ^ k) + 1)).card : ℝ)
              ≤ A * ((((2 ^ k) / m : ℕ) : ℝ) ^ α) * ((2 ^ k : ℕ) : ℝ) ^ ε) :
    ∃ α ε A : ℝ, 0 < α ∧ α < 1 ∧ 0 ≤ ε ∧ ε < (1 - α) / 2 ∧ 0 < A ∧
      ∀ N m : ℕ, 3 ≤ N →
        m ∈ Finset.Icc 1 (Nat.sqrt N) →
          ((Nat.smoothNumbersUpTo (N / m) (zNatScale N + 1)).card : ℝ)
            ≤ (A * (N : ℝ) ^ α * (N : ℝ) ^ ε) * (m : ℝ) ^ (-α) := by
  rcases hDyadic with ⟨α, ε, A, hα0, hα1, hε0, hgap, hA, hDyadic⟩
  let A' : ℝ := A * (2 : ℝ) ^ α * (2 : ℝ) ^ ε
  refine ⟨α, ε, A', hα0, hα1, hε0, hgap, ?_, ?_⟩
  · exact mul_pos (mul_pos hA (Real.rpow_pos_of_pos (by norm_num : (0 : ℝ) < 2) α))
      (Real.rpow_pos_of_pos (by norm_num : (0 : ℝ) < 2) ε)
  · intro N m hN hm
    let k : ℕ := Nat.log 2 N + 1
    let K : ℕ := 2 ^ k
    have hN_ne_zero : N ≠ 0 := by omega
    have hNpos : 0 < (N : ℝ) := by
      exact_mod_cast (lt_of_lt_of_le (by norm_num : (0 : ℕ) < 3) hN)
    have hm_ge_one : 1 ≤ m := (Finset.mem_Icc.mp hm).1
    have hm_pos_nat : 0 < m := lt_of_lt_of_le Nat.zero_lt_one hm_ge_one
    have hm_pos : 0 < (m : ℝ) := by exact_mod_cast hm_pos_nat
    have hN_le_K : N ≤ K := by
      have hlt : N < 2 ^ (Nat.log 2 N + 1) :=
        Nat.lt_pow_succ_log_self (by norm_num : 1 < 2) N
      exact Nat.le_of_lt (by simpa [K, k] using hlt)
    have hlogpow_le_N : 2 ^ Nat.log 2 N ≤ N :=
      Nat.pow_log_le_self 2 hN_ne_zero
    have hK_le_twoN : K ≤ 2 * N := by
      have hK_eq : K = 2 * 2 ^ Nat.log 2 N := by
        simp [K, k, pow_succ, mul_comm, mul_left_comm, mul_assoc]
      rw [hK_eq]
      exact Nat.mul_le_mul_left 2 hlogpow_le_N
    have hk_ge_two : 2 ≤ k := by
      have hlog_ge_one : 1 ≤ Nat.log 2 N := by
        exact Nat.le_log_of_pow_le (by norm_num : 1 < 2)
          (by simpa using (by omega : 2 ^ 1 ≤ N))
      omega
    have hmK : m ∈ Finset.Icc 1 (Nat.sqrt K) := by
      exact Finset.mem_Icc.mpr
        ⟨hm_ge_one, le_trans (Finset.mem_Icc.mp hm).2 (Nat.sqrt_le_sqrt hN_le_K)⟩
    have hcard_nat :
        (Nat.smoothNumbersUpTo (N / m) (zNatScale N + 1)).card ≤
          (Nat.smoothNumbersUpTo (K / m) (zNatScale K + 1)).card :=
      smoothNumbersUpTo_card_mono
        (Nat.div_le_div_right hN_le_K)
        (Nat.succ_le_succ (zNatScale_mono hN_le_K))
    have hcard :
        ((Nat.smoothNumbersUpTo (N / m) (zNatScale N + 1)).card : ℝ) ≤
          ((Nat.smoothNumbersUpTo (K / m) (zNatScale K + 1)).card : ℝ) := by
      exact_mod_cast hcard_nat
    have hdyadic :
        ((Nat.smoothNumbersUpTo (K / m) (zNatScale K + 1)).card : ℝ)
          ≤ A * (((K / m : ℕ) : ℝ) ^ α) * (K : ℝ) ^ ε := by
      simpa [K] using hDyadic k m hk_ge_two hmK
    have hKpos_nat : 0 < K := by
      exact pow_pos (by norm_num : (0 : ℕ) < 2) k
    have hKpos : 0 < (K : ℝ) := by exact_mod_cast hKpos_nat
    have hK_le_twoN_real : (K : ℝ) ≤ 2 * (N : ℝ) := by
      exact_mod_cast hK_le_twoN
    have hcast_div_le : ((K / m : ℕ) : ℝ) ≤ (K : ℝ) / (m : ℝ) :=
      Nat.cast_div_le
    have hpow_div_le :
        (((K / m : ℕ) : ℝ) ^ α) ≤ ((K : ℝ) / (m : ℝ)) ^ α :=
      Real.rpow_le_rpow (Nat.cast_nonneg _) hcast_div_le hα0.le
    have hdiv_pow :
        ((K : ℝ) / (m : ℝ)) ^ α = (K : ℝ) ^ α * (m : ℝ) ^ (-α) := by
      rw [div_eq_mul_inv]
      rw [Real.mul_rpow hKpos.le (inv_nonneg.mpr hm_pos.le)]
      rw [Real.inv_rpow hm_pos.le]
      rw [← Real.rpow_neg hm_pos.le]
    have hKpow_alpha :
        (K : ℝ) ^ α ≤ (2 * (N : ℝ)) ^ α :=
      Real.rpow_le_rpow hKpos.le hK_le_twoN_real hα0.le
    have hKpow_eps :
        (K : ℝ) ^ ε ≤ (2 * (N : ℝ)) ^ ε :=
      Real.rpow_le_rpow hKpos.le hK_le_twoN_real hε0
    have hconst_power :
        A * (2 * (N : ℝ)) ^ α * (2 * (N : ℝ)) ^ ε =
          A' * (N : ℝ) ^ α * (N : ℝ) ^ ε := by
      dsimp [A']
      rw [Real.mul_rpow (by norm_num : (0 : ℝ) ≤ 2) hNpos.le]
      rw [Real.mul_rpow (by norm_num : (0 : ℝ) ≤ 2) hNpos.le]
      ring
    have hscale :
        A * (K : ℝ) ^ α * (K : ℝ) ^ ε
          ≤ A * (2 * (N : ℝ)) ^ α * (2 * (N : ℝ)) ^ ε := by
      calc
        A * (K : ℝ) ^ α * (K : ℝ) ^ ε
            ≤ A * (2 * (N : ℝ)) ^ α * (K : ℝ) ^ ε := by
              exact mul_le_mul_of_nonneg_right
                (mul_le_mul_of_nonneg_left hKpow_alpha hA.le)
                (Real.rpow_nonneg hKpos.le ε)
        _ ≤ A * (2 * (N : ℝ)) ^ α * (2 * (N : ℝ)) ^ ε := by
              exact mul_le_mul_of_nonneg_left hKpow_eps
                (mul_nonneg hA.le
                  (Real.rpow_nonneg
                    (mul_nonneg (by norm_num : (0 : ℝ) ≤ 2) hNpos.le) α))
    calc
      ((Nat.smoothNumbersUpTo (N / m) (zNatScale N + 1)).card : ℝ)
          ≤ ((Nat.smoothNumbersUpTo (K / m) (zNatScale K + 1)).card : ℝ) := hcard
      _ ≤ A * (((K / m : ℕ) : ℝ) ^ α) * (K : ℝ) ^ ε := hdyadic
      _ ≤ A * (((K : ℝ) / (m : ℝ)) ^ α) * (K : ℝ) ^ ε := by
            exact mul_le_mul_of_nonneg_right
              (mul_le_mul_of_nonneg_left hpow_div_le hA.le)
              (Real.rpow_nonneg hKpos.le ε)
      _ = (A * (K : ℝ) ^ α * (K : ℝ) ^ ε) * (m : ℝ) ^ (-α) := by
            rw [hdiv_pow]
            ring
      _ ≤ (A * (2 * (N : ℝ)) ^ α * (2 * (N : ℝ)) ^ ε) *
            (m : ℝ) ^ (-α) := by
            exact mul_le_mul_of_nonneg_right hscale
              (Real.rpow_nonneg hm_pos.le (-α))
      _ = (A' * (N : ℝ) ^ α * (N : ℝ) ^ ε) * (m : ℝ) ^ (-α) := by
            rw [hconst_power]

/-- Dyadic pointwise Rankin/de Bruijn fibers imply the matching dyadic weighted
fiber form, before interpolating to arbitrary `N`. -/
theorem rankin_mathlibSmoothNumbersUpTo_zNatScale_dyadic_weighted_fiber_bound_of_dyadic_pointwise_natDiv
    (hDyadic :
      ∃ α ε A : ℝ, 0 < α ∧ α < 1 ∧ 0 ≤ ε ∧ ε < (1 - α) / 2 ∧ 0 < A ∧
        ∀ k m : ℕ, 2 ≤ k →
          m ∈ Finset.Icc 1 (Nat.sqrt (2 ^ k)) →
            ((Nat.smoothNumbersUpTo ((2 ^ k) / m) (zNatScale (2 ^ k) + 1)).card : ℝ)
              ≤ A * ((((2 ^ k) / m : ℕ) : ℝ) ^ α) * ((2 ^ k : ℕ) : ℝ) ^ ε) :
    ∃ α ε A : ℝ, 0 < α ∧ α < 1 ∧ 0 ≤ ε ∧ ε < (1 - α) / 2 ∧ 0 < A ∧
      ∀ k m : ℕ, 2 ≤ k →
        m ∈ Finset.Icc 1 (Nat.sqrt (2 ^ k)) →
          ((Nat.smoothNumbersUpTo ((2 ^ k) / m) (zNatScale (2 ^ k) + 1)).card : ℝ)
            ≤ (A * ((2 ^ k : ℕ) : ℝ) ^ α * ((2 ^ k : ℕ) : ℝ) ^ ε) *
                (m : ℝ) ^ (-α) := by
  rcases rankin_mathlibSmoothNumbersUpTo_zNatScale_weighted_fiber_bound_of_dyadic_pointwise_natDiv
      hDyadic with
    ⟨α, ε, A, hα0, hα1, hε0, hgap, hA, hFiber⟩
  refine ⟨α, ε, A, hα0, hα1, hε0, hgap, hA, ?_⟩
  intro k m hk hm
  have hN : 3 ≤ 2 ^ k := by
    exact le_trans (by norm_num : 3 ≤ 4)
      (by simpa using Nat.pow_le_pow_right (by norm_num : (0 : ℕ) < 2) hk)
  exact hFiber (2 ^ k) m hN hm

/-- Reverse dyadic Rankin fiber conversion.  On the dyadic range
`m ≤ sqrt(2^k)`, the real quotient `(2^k)/m` is at most twice the natural
quotient `((2^k)/m : ℕ)`, so a dyadic weighted-fiber estimate is equivalent,
up to the existential constant, to the pointwise natural-division estimate. -/
theorem rankin_mathlibSmoothNumbersUpTo_zNatScale_dyadic_pointwise_natDiv_bound_of_dyadic_weighted_fibers
    (hWeighted :
      ∃ α ε A : ℝ, 0 < α ∧ α < 1 ∧ 0 ≤ ε ∧ ε < (1 - α) / 2 ∧ 0 < A ∧
        ∀ k m : ℕ, 2 ≤ k →
          m ∈ Finset.Icc 1 (Nat.sqrt (2 ^ k)) →
            ((Nat.smoothNumbersUpTo ((2 ^ k) / m) (zNatScale (2 ^ k) + 1)).card : ℝ)
              ≤ (A * ((2 ^ k : ℕ) : ℝ) ^ α * ((2 ^ k : ℕ) : ℝ) ^ ε) *
                  (m : ℝ) ^ (-α)) :
    ∃ α ε A : ℝ, 0 < α ∧ α < 1 ∧ 0 ≤ ε ∧ ε < (1 - α) / 2 ∧ 0 < A ∧
      ∀ k m : ℕ, 2 ≤ k →
        m ∈ Finset.Icc 1 (Nat.sqrt (2 ^ k)) →
          ((Nat.smoothNumbersUpTo ((2 ^ k) / m) (zNatScale (2 ^ k) + 1)).card : ℝ)
            ≤ A * ((((2 ^ k) / m : ℕ) : ℝ) ^ α) * ((2 ^ k : ℕ) : ℝ) ^ ε := by
  rcases hWeighted with ⟨α, ε, A, hα0, hα1, hε0, hgap, hA, hWeighted⟩
  refine ⟨α, ε, A * 2, hα0, hα1, hε0, hgap, mul_pos hA (by norm_num), ?_⟩
  intro k m hk hm
  let K : ℕ := 2 ^ k
  let D : ℝ := ((K / m : ℕ) : ℝ)
  have hW :
      ((Nat.smoothNumbersUpTo (K / m) (zNatScale K + 1)).card : ℝ)
        ≤ (A * (K : ℝ) ^ α * (K : ℝ) ^ ε) * (m : ℝ) ^ (-α) := by
    simpa [K] using hWeighted k m hk hm
  have hm_ge_one : 1 ≤ m := (Finset.mem_Icc.mp hm).1
  have hm_pos_nat : 0 < m := lt_of_lt_of_le Nat.zero_lt_one hm_ge_one
  have hm_pos : 0 < (m : ℝ) := by exact_mod_cast hm_pos_nat
  have hm_le_K : m ≤ K :=
    le_trans (Finset.mem_Icc.mp hm).2 (Nat.sqrt_le_self K)
  have hKpos_nat : 0 < K := by
    exact pow_pos (by norm_num : (0 : ℕ) < 2) k
  have hKpos : 0 < (K : ℝ) := by exact_mod_cast hKpos_nat
  have hDpos_nat : 0 < K / m := Nat.div_pos hm_le_K hm_pos_nat
  have hD_nonneg : 0 ≤ D := Nat.cast_nonneg _
  have hquot_le_succ :
      (K : ℝ) / (m : ℝ) ≤ (((K / m + 1 : ℕ) : ℝ)) := by
    have hlt : K < m * (K / m + 1) := Nat.lt_mul_div_succ K hm_pos_nat
    have hle : (K : ℝ) ≤ (m : ℝ) * (((K / m + 1 : ℕ) : ℝ)) := by
      exact_mod_cast le_of_lt hlt
    exact (div_le_iff₀ hm_pos).mpr (by
      simpa [mul_comm, Nat.cast_mul] using hle)
  have hsucc_le_two_nat : K / m + 1 ≤ 2 * (K / m) := by omega
  have hsucc_le_two : (((K / m + 1 : ℕ) : ℝ)) ≤ 2 * D := by
    have hcast : (((K / m + 1 : ℕ) : ℝ)) ≤ (((2 * (K / m) : ℕ) : ℝ)) := by
      exact_mod_cast hsucc_le_two_nat
    simpa [D, Nat.cast_mul] using hcast
  have hquot_le_twoD : (K : ℝ) / (m : ℝ) ≤ 2 * D :=
    le_trans hquot_le_succ hsucc_le_two
  have hdiv_pow :
      ((K : ℝ) / (m : ℝ)) ^ α = (K : ℝ) ^ α * (m : ℝ) ^ (-α) := by
    rw [div_eq_mul_inv]
    rw [Real.mul_rpow hKpos.le (inv_nonneg.mpr hm_pos.le)]
    rw [Real.inv_rpow hm_pos.le]
    rw [← Real.rpow_neg hm_pos.le]
  have hquot_nonneg : 0 ≤ (K : ℝ) / (m : ℝ) := div_nonneg hKpos.le hm_pos.le
  have htwoD_nonneg : 0 ≤ 2 * D := mul_nonneg (by norm_num) hD_nonneg
  have hpow_quot_le :
      ((K : ℝ) ^ α * (m : ℝ) ^ (-α)) ≤ 2 * D ^ α := by
    calc
      (K : ℝ) ^ α * (m : ℝ) ^ (-α)
          = ((K : ℝ) / (m : ℝ)) ^ α := hdiv_pow.symm
      _ ≤ (2 * D) ^ α :=
          Real.rpow_le_rpow hquot_nonneg hquot_le_twoD hα0.le
      _ = (2 : ℝ) ^ α * D ^ α := by
          rw [Real.mul_rpow (by norm_num : (0 : ℝ) ≤ 2) hD_nonneg]
      _ ≤ 2 * D ^ α := by
          have htwo_pow_le_two : (2 : ℝ) ^ α ≤ 2 := by
            simpa using
              (Real.rpow_le_rpow_of_exponent_le
                (by norm_num : (1 : ℝ) ≤ 2) hα1.le)
          exact mul_le_mul_of_nonneg_right
            htwo_pow_le_two
            (Real.rpow_nonneg hD_nonneg α)
  have hscale :
      (A * (K : ℝ) ^ α * (K : ℝ) ^ ε) * (m : ℝ) ^ (-α)
        ≤ (A * 2) * D ^ α * (K : ℝ) ^ ε := by
    calc
      (A * (K : ℝ) ^ α * (K : ℝ) ^ ε) * (m : ℝ) ^ (-α)
          = A * ((K : ℝ) ^ α * (m : ℝ) ^ (-α)) * (K : ℝ) ^ ε := by ring
      _ ≤ A * (2 * D ^ α) * (K : ℝ) ^ ε := by
          exact mul_le_mul_of_nonneg_right
            (mul_le_mul_of_nonneg_left hpow_quot_le hA.le)
            (Real.rpow_nonneg hKpos.le ε)
      _ = (A * 2) * D ^ α * (K : ℝ) ^ ε := by ring
  calc
    ((Nat.smoothNumbersUpTo ((2 ^ k) / m) (zNatScale (2 ^ k) + 1)).card : ℝ)
        = ((Nat.smoothNumbersUpTo (K / m) (zNatScale K + 1)).card : ℝ) := by rfl
    _ ≤ (A * (K : ℝ) ^ α * (K : ℝ) ^ ε) * (m : ℝ) ^ (-α) := hW
    _ ≤ (A * 2) * D ^ α * (K : ℝ) ^ ε := hscale
    _ = (A * 2) * ((((2 ^ k) / m : ℕ) : ℝ) ^ α) *
          ((2 ^ k : ℕ) : ℝ) ^ ε := by rfl

/-- The dyadic pointwise Rankin/de Bruijn input is equivalent to the dyadic
weighted-fiber form.  The difference between the two formulations is only the
checked finite floor-division loss on `m ≤ sqrt(2^k)`. -/
theorem rankin_mathlibSmoothNumbersUpTo_zNatScale_dyadic_pointwise_natDiv_bound_iff_dyadic_weighted_fibers :
    (∃ α ε A : ℝ, 0 < α ∧ α < 1 ∧ 0 ≤ ε ∧ ε < (1 - α) / 2 ∧ 0 < A ∧
      ∀ k m : ℕ, 2 ≤ k →
        m ∈ Finset.Icc 1 (Nat.sqrt (2 ^ k)) →
          ((Nat.smoothNumbersUpTo ((2 ^ k) / m) (zNatScale (2 ^ k) + 1)).card : ℝ)
            ≤ A * ((((2 ^ k) / m : ℕ) : ℝ) ^ α) * ((2 ^ k : ℕ) : ℝ) ^ ε) ↔
    (∃ α ε A : ℝ, 0 < α ∧ α < 1 ∧ 0 ≤ ε ∧ ε < (1 - α) / 2 ∧ 0 < A ∧
      ∀ k m : ℕ, 2 ≤ k →
        m ∈ Finset.Icc 1 (Nat.sqrt (2 ^ k)) →
          ((Nat.smoothNumbersUpTo ((2 ^ k) / m) (zNatScale (2 ^ k) + 1)).card : ℝ)
            ≤ (A * ((2 ^ k : ℕ) : ℝ) ^ α * ((2 ^ k : ℕ) : ℝ) ^ ε) *
                (m : ℝ) ^ (-α)) := by
  constructor
  · exact rankin_mathlibSmoothNumbersUpTo_zNatScale_dyadic_weighted_fiber_bound_of_dyadic_pointwise_natDiv
  · exact rankin_mathlibSmoothNumbersUpTo_zNatScale_dyadic_pointwise_natDiv_bound_of_dyadic_weighted_fibers

/-- Exact finite divisor-power envelope used by the Rankin weighted-fiber
argument.

For `0 < α < 1`, the antitone integral comparison gives
`∑_{m≤Y} m^{-α} ≤ (1 + 1/(1-α)) Y^{1-α}`. -/
theorem divisor_rpow_neg_sum_Icc_le
    {α : ℝ} (hα0 : 0 < α) (hα1 : α < 1) (Y : ℕ) (hY : 1 ≤ Y) :
    (∑ m ∈ Finset.Icc (1 : ℕ) Y, (m : ℝ) ^ (-α))
      ≤ (1 + 1 / (1 - α)) * (Y : ℝ) ^ (1 - α) := by
  classical
  let f : ℝ → ℝ := fun x => x ^ (-α)
  have hYreal : (1 : ℝ) ≤ (Y : ℝ) := by exact_mod_cast hY
  have hYpos : 0 < (Y : ℝ) := lt_of_lt_of_le zero_lt_one hYreal
  have hone_sub_pos : 0 < 1 - α := by linarith
  have hanti : AntitoneOn f (Set.Icc (1 : ℝ) (Y : ℝ)) := by
    intro x hx y hy hxy
    exact Real.rpow_le_rpow_of_nonpos (lt_of_lt_of_le zero_lt_one hx.1) hxy (by linarith)
  have htail :
      (∑ i ∈ Finset.Ico (1 : ℕ) Y, f ((i + 1 : ℕ) : ℝ))
        ≤ ∫ x in (1 : ℝ)..(Y : ℝ), f x :=
    by
      simpa [Nat.cast_one] using
        (AntitoneOn.sum_le_integral_Ico hY
          (show AntitoneOn f (Set.Icc (((1 : ℕ) : ℝ)) (Y : ℝ)) from by
            simpa using hanti))
  have htail_eq :
      (∑ m ∈ Finset.Icc (2 : ℕ) Y, (m : ℝ) ^ (-α))
        = ∑ i ∈ Finset.Ico (1 : ℕ) Y, f ((i + 1 : ℕ) : ℝ) := by
    let e : ℕ ↪ ℕ := ⟨Nat.succ, fun _a _b h => Nat.succ.inj h⟩
    have hmap : (Finset.Ico (1 : ℕ) Y).map e = Finset.Icc (2 : ℕ) Y := by
      ext m
      simp [e, Nat.succ_eq_add_one, Finset.mem_Ico, Finset.mem_Icc]
      constructor
      · intro h
        omega
      · intro h
        refine ⟨m - 1, ?_, by omega⟩
        omega
    rw [← hmap]
    simp [e, f]
  have hsplit :
      (∑ m ∈ Finset.Icc (1 : ℕ) Y, (m : ℝ) ^ (-α))
        = 1 + ∑ m ∈ Finset.Icc (2 : ℕ) Y, (m : ℝ) ^ (-α) := by
    have hset : insert (1 : ℕ) (Finset.Icc (2 : ℕ) Y) = Finset.Icc (1 : ℕ) Y := by
      ext m
      simp [Finset.mem_Icc]
      omega
    have hone_not_mem : (1 : ℕ) ∉ Finset.Icc (2 : ℕ) Y := by
      simp [Finset.mem_Icc]
    calc
      (∑ m ∈ Finset.Icc (1 : ℕ) Y, (m : ℝ) ^ (-α))
          = ∑ m ∈ insert (1 : ℕ) (Finset.Icc (2 : ℕ) Y), (m : ℝ) ^ (-α) := by
              rw [hset]
      _ = (((1 : ℕ) : ℝ) ^ (-α)) +
            ∑ m ∈ Finset.Icc (2 : ℕ) Y, (m : ℝ) ^ (-α) := by
              rw [Finset.sum_insert hone_not_mem]
      _ = 1 + ∑ m ∈ Finset.Icc (2 : ℕ) Y, (m : ℝ) ^ (-α) := by
              simp
  have hintegral :
      (∫ x in (1 : ℝ)..(Y : ℝ), f x)
        = ((Y : ℝ) ^ (1 - α) - 1) / (1 - α) := by
    unfold f
    have hpow := integral_rpow
      (a := (1 : ℝ)) (b := (Y : ℝ)) (r := -α)
      (Or.inl (by linarith : -1 < -α))
    simpa [sub_eq_add_neg, add_comm, add_left_comm, add_assoc] using hpow
  have htail_bound :
      (∑ m ∈ Finset.Icc (2 : ℕ) Y, (m : ℝ) ^ (-α))
        ≤ ((Y : ℝ) ^ (1 - α) - 1) / (1 - α) := by
    rw [htail_eq, ← hintegral]
    exact htail
  have hYpow_ge_one : (1 : ℝ) ≤ (Y : ℝ) ^ (1 - α) :=
    Real.one_le_rpow hYreal hone_sub_pos.le
  calc
    (∑ m ∈ Finset.Icc (1 : ℕ) Y, (m : ℝ) ^ (-α))
        = 1 + ∑ m ∈ Finset.Icc (2 : ℕ) Y, (m : ℝ) ^ (-α) := hsplit
    _ ≤ 1 + ((Y : ℝ) ^ (1 - α) - 1) / (1 - α) :=
        add_le_add_left htail_bound 1
    _ ≤ (Y : ℝ) ^ (1 - α) + ((Y : ℝ) ^ (1 - α)) / (1 - α) := by
        have hnum_le :
            (Y : ℝ) ^ (1 - α) - 1 ≤ (Y : ℝ) ^ (1 - α) := by linarith
        have hfrac_le :
            ((Y : ℝ) ^ (1 - α) - 1) / (1 - α) ≤
              ((Y : ℝ) ^ (1 - α)) / (1 - α) :=
          div_le_div_of_nonneg_right hnum_le hone_sub_pos.le
        exact add_le_add hYpow_ge_one hfrac_le
    _ = (1 + 1 / (1 - α)) * (Y : ℝ) ^ (1 - α) := by
        field_simp [hone_sub_pos.ne']
        ring

/-- Quadratic completion: a square-root term is bounded by a linear term plus
an explicit constant. -/
theorem const_mul_sqrt_le_quad_linear {C ε L : ℝ} (hε : 0 < ε) (hL : 0 ≤ L) :
    C * L ^ ((1 : ℝ) / 2) ≤ C ^ 2 / (4 * ε) + ε * L := by
  let y : ℝ := L ^ ((1 : ℝ) / 2)
  have hy2 : y ^ 2 = L := by
    dsimp [y]
    rw [← Real.sqrt_eq_rpow]
    exact Real.sq_sqrt hL
  have hbasic : C * y ≤ C ^ 2 / (4 * ε) + ε * (y ^ 2) := by
    have hden_pos : 0 < 4 * ε := by positivity
    rw [← (mul_le_mul_left hden_pos)]
    field_simp [hε.ne']
    ring_nf
    have hsq : 0 ≤ (C - 2 * ε * y) ^ 2 := sq_nonneg _
    ring_nf at hsq
    nlinarith
  rw [hy2] at hbasic
  exact hbasic

/-- The all-integers Rankin power sum at the manuscript dyadic cutoff is
`O(sqrt(log K))` for the concrete exponent `α = 7/8`. -/
theorem dyadicRankinNatRpowSum_seven_eighth_le_sqrt_log {k : ℕ} (hk : 2 ≤ k) :
    dyadicRankinNatRpowSum k ((7 : ℝ) / 8) ≤
      36 * (Real.log (((2 ^ k : ℕ) : ℝ))) ^ ((1 : ℝ) / 2) := by
  let Y : ℕ := zNatScale (2 ^ k) + 1
  let L : ℝ := Real.log (((2 ^ k : ℕ) : ℝ))
  have hYone : 1 ≤ Y := by
    dsimp [Y]
    omega
  have hsum := divisor_rpow_neg_sum_Icc_le
    (α := ((7 : ℝ) / 8)) (by norm_num) (by norm_num) Y hYone
  have hsum9 : dyadicRankinNatRpowSum k ((7 : ℝ) / 8) ≤
      9 * (Y : ℝ) ^ ((1 : ℝ) / 8) := by
    dsimp [dyadicRankinNatRpowSum, rankinNatRpowSum, Y] at hsum ⊢
    norm_num at hsum ⊢
    exact hsum
  have hKpos_nat : 0 < 2 ^ k := pow_pos (by norm_num : 0 < (2 : ℕ)) k
  have hK_ge4_nat : 4 ≤ 2 ^ k := by
    calc
      4 = 2 ^ 2 := by norm_num
      _ ≤ 2 ^ k := Nat.pow_le_pow_right (by norm_num : 0 < 2) hk
  have hK_ge_exp : Real.exp 1 ≤ (((2 ^ k : ℕ) : ℝ)) := by
    have hK4 : (4 : ℝ) ≤ (((2 ^ k : ℕ) : ℝ)) := by exact_mod_cast hK_ge4_nat
    have hexp3 : Real.exp 1 ≤ (3 : ℝ) := by
      exact le_of_lt (Real.exp_one_lt_d9.trans (by norm_num))
    exact le_trans (le_trans hexp3 (by norm_num : (3 : ℝ) ≤ 4)) hK4
  have hKpos : 0 < (((2 ^ k : ℕ) : ℝ)) := by exact_mod_cast hKpos_nat
  have hL_ge_one : 1 ≤ L := by
    dsimp [L]
    rw [Real.le_log_iff_exp_le hKpos]
    exact hK_ge_exp
  have hL_nonneg : 0 ≤ L := le_trans (by norm_num : (0 : ℝ) ≤ 1) hL_ge_one
  have hY_nonneg : 0 ≤ (Y : ℝ) := by positivity
  have hYle : (Y : ℝ) ≤ 4 * L ^ (4 : ℕ) := by
    dsimp [Y, L]
    exact zNatScale_dyadic_succ_le_four_log_pow_four hk
  have hYpow : (Y : ℝ) ^ ((1 : ℝ) / 8) ≤ 4 * L ^ ((1 : ℝ) / 2) := by
    calc
      (Y : ℝ) ^ ((1 : ℝ) / 8) ≤ (4 * L ^ (4 : ℕ)) ^ ((1 : ℝ) / 8) :=
        Real.rpow_le_rpow hY_nonneg hYle (by norm_num)
      _ ≤ 4 * L ^ ((1 : ℝ) / 2) := by
        have hmul : (4 * L ^ (4 : ℕ)) ^ ((1 : ℝ) / 8) =
            (4 : ℝ) ^ ((1 : ℝ) / 8) * (L ^ (4 : ℕ)) ^ ((1 : ℝ) / 8) := by
          rw [Real.mul_rpow (by norm_num : (0 : ℝ) ≤ 4) (pow_nonneg hL_nonneg 4)]
        rw [hmul]
        have hfour : (4 : ℝ) ^ ((1 : ℝ) / 8) ≤ 4 := by
          calc
            (4 : ℝ) ^ ((1 : ℝ) / 8) ≤ (4 : ℝ) ^ (1 : ℝ) :=
              Real.rpow_le_rpow_of_exponent_le (by norm_num : (1 : ℝ) ≤ 4) (by norm_num)
            _ = 4 := by simp
        have hLpow : (L ^ (4 : ℕ)) ^ ((1 : ℝ) / 8) = L ^ ((1 : ℝ) / 2) := by
          rw [← Real.rpow_natCast (x := L) 4]
          rw [← Real.rpow_mul hL_nonneg]
          norm_num
        rw [hLpow]
        exact mul_le_mul hfour le_rfl (Real.rpow_nonneg hL_nonneg _) (by norm_num)
  calc
    dyadicRankinNatRpowSum k ((7 : ℝ) / 8) ≤ 9 * (Y : ℝ) ^ ((1 : ℝ) / 8) := hsum9
    _ ≤ 9 * (4 * L ^ ((1 : ℝ) / 2)) := mul_le_mul_of_nonneg_left hYpow (by norm_num)
    _ = 36 * L ^ ((1 : ℝ) / 2) := by ring

/-- Concrete dyadic all-integers power-sum bound in the logarithmic form needed
by the Rankin product route. -/
theorem dyadicRankinNatRpowSum_log_bound :
    ∃ α ε A : ℝ, 0 < α ∧ α < 1 ∧ 0 ≤ ε ∧ ε < (1 - α) / 2 ∧ 0 < A ∧
      ∀ k : ℕ, 2 ≤ k →
        (1 / (1 - (2 : ℝ) ^ (-α))) * dyadicRankinNatRpowSum k α
          ≤ Real.log (A * ((2 ^ k : ℕ) : ℝ) ^ ε) := by
  let α : ℝ := (7 : ℝ) / 8
  let ε : ℝ := (1 : ℝ) / 32
  let C : ℝ := (1 / (1 - (2 : ℝ) ^ (-α))) * 36
  let B : ℝ := C ^ 2 / (4 * ε)
  let A : ℝ := Real.exp B
  refine ⟨α, ε, A, by norm_num [α], by norm_num [α], by norm_num [ε], ?_,
    Real.exp_pos B, ?_⟩
  · norm_num [α, ε]
  intro k hk
  let K : ℕ := 2 ^ k
  let L : ℝ := Real.log ((K : ℕ) : ℝ)
  have hKpos_nat : 0 < K := by
    dsimp [K]
    exact pow_pos (by norm_num : 0 < (2 : ℕ)) k
  have hK_ge4_nat : 4 ≤ K := by
    dsimp [K]
    calc
      4 = 2 ^ 2 := by norm_num
      _ ≤ 2 ^ k := Nat.pow_le_pow_right (by norm_num : 0 < 2) hk
  have hK_ge_exp : Real.exp 1 ≤ (K : ℝ) := by
    have hK4 : (4 : ℝ) ≤ (K : ℝ) := by exact_mod_cast hK_ge4_nat
    have hexp3 : Real.exp 1 ≤ (3 : ℝ) := by
      exact le_of_lt (Real.exp_one_lt_d9.trans (by norm_num))
    exact le_trans (le_trans hexp3 (by norm_num : (3 : ℝ) ≤ 4)) hK4
  have hKpos : 0 < (K : ℝ) := by exact_mod_cast hKpos_nat
  have hL_ge_one : 1 ≤ L := by
    dsimp [L]
    rw [Real.le_log_iff_exp_le hKpos]
    exact hK_ge_exp
  have hL_nonneg : 0 ≤ L := le_trans (by norm_num : (0 : ℝ) ≤ 1) hL_ge_one
  have hden_pos : 0 < 1 - (2 : ℝ) ^ (-α) := by
    have hpow_lt : (2 : ℝ) ^ (-α) < 1 :=
      Real.rpow_lt_one_of_one_lt_of_neg (by norm_num : (1 : ℝ) < 2) (by norm_num [α])
    exact sub_pos.mpr hpow_lt
  have hc_nonneg : 0 ≤ 1 / (1 - (2 : ℝ) ^ (-α)) :=
    div_nonneg zero_le_one hden_pos.le
  have hsum := dyadicRankinNatRpowSum_seven_eighth_le_sqrt_log hk
  have hscaled :
      (1 / (1 - (2 : ℝ) ^ (-α))) * dyadicRankinNatRpowSum k α ≤
        C * L ^ ((1 : ℝ) / 2) := by
    dsimp [α, C, L, K] at hsum ⊢
    calc
      (1 / (1 - (2 : ℝ) ^ (-(7 / 8 : ℝ)))) *
          dyadicRankinNatRpowSum k (7 / 8 : ℝ)
          ≤ (1 / (1 - (2 : ℝ) ^ (-(7 / 8 : ℝ)))) *
              (36 * Real.log (((2 ^ k : ℕ) : ℝ)) ^ ((1 : ℝ) / 2)) :=
            mul_le_mul_of_nonneg_left hsum hc_nonneg
      _ = (1 / (1 - (2 : ℝ) ^ (-(7 / 8 : ℝ))) * 36) *
            Real.log (((2 ^ k : ℕ) : ℝ)) ^ ((1 : ℝ) / 2) := by ring
  have habsorb :
      C * L ^ ((1 : ℝ) / 2) ≤ B + ε * L := by
    dsimp [B]
    exact const_mul_sqrt_le_quad_linear (C := C) (ε := ε) (L := L) (by norm_num [ε])
      hL_nonneg
  have hlog :
      Real.log (A * ((K : ℕ) : ℝ) ^ ε) = B + ε * L := by
    have hApos : 0 < A := Real.exp_pos B
    have hpowpos : 0 < ((K : ℕ) : ℝ) ^ ε := Real.rpow_pos_of_pos hKpos ε
    rw [Real.log_mul hApos.ne' hpowpos.ne', Real.log_exp, Real.log_rpow hKpos]
  calc
    (1 / (1 - (2 : ℝ) ^ (-α))) * dyadicRankinNatRpowSum k α
        ≤ C * L ^ ((1 : ℝ) / 2) := hscaled
    _ ≤ B + ε * L := habsorb
    _ = Real.log (A * ((2 ^ k : ℕ) : ℝ) ^ ε) := by
          rw [hlog]

/-- Rankin/de Bruijn reduction with the divisor-power sum discharged by the
elementary integral comparison.

Compared with `rankin_mathlibSmoothNumbersUpTo_zNatScale_bound_of_weighted_fibers`,
this removes the separate divisor-sum hypothesis.  The remaining analytic
content is the weighted fiber estimate for the smooth-number carrier. -/
theorem rankin_mathlibSmoothNumbersUpTo_zNatScale_bound_of_weighted_fibers_exact_divisor_sum
    {α ε A : ℝ} (hα0 : 0 < α) (hα1 : α < 1) (hε0 : 0 ≤ ε)
    (hgap : ε < (1 - α) / 2) (hA : 0 < A)
    (hFiber : ∀ N m : ℕ, 3 ≤ N →
      m ∈ Finset.Icc 1 (Nat.sqrt N) →
        ((Nat.smoothNumbersUpTo (N / m) (zNatScale N + 1)).card : ℝ)
          ≤ (A * (N : ℝ) ^ α * (N : ℝ) ^ ε) * (m : ℝ) ^ (-α)) :
    ∃ θ C : ℝ, 0 < θ ∧ θ < 1 ∧ 0 < C ∧
      ∀ N : ℕ, 3 ≤ N →
        (∑ m ∈ Finset.Icc 1 (Nat.sqrt N),
          ((Nat.smoothNumbersUpTo (N / m) (zNatScale N + 1)).card : ℝ))
            ≤ C * (N : ℝ) ^ θ := by
  refine rankin_mathlibSmoothNumbersUpTo_zNatScale_bound_of_weighted_fibers
    (B := 1 + 1 / (1 - α)) hα0 hα1 hε0 hgap hA ?_ hFiber ?_
  · have hden_pos : 0 < 1 - α := by linarith
    have hinv_pos : 0 < 1 / (1 - α) := one_div_pos.mpr hden_pos
    linarith
  · intro N hN
    have hNpos : 0 < (N : ℝ) := by
      exact_mod_cast (lt_of_lt_of_le (by norm_num : (0 : ℕ) < 3) hN)
    have hNnonneg : 0 ≤ (N : ℝ) := hNpos.le
    have hsqrt_one : 1 ≤ Nat.sqrt N := by
      rw [Nat.le_sqrt]
      omega
    have hsqrt_le_rpow :
        (Nat.sqrt N : ℝ) ≤ (N : ℝ) ^ ((1 : ℝ) / 2) := by
      simpa [Real.sqrt_eq_rpow] using Real.nat_sqrt_le_real_sqrt (a := N)
    have hsqrt_pow_le :
        (Nat.sqrt N : ℝ) ^ (1 - α) ≤
          (N : ℝ) ^ ((1 - α) / 2) := by
      calc
        (Nat.sqrt N : ℝ) ^ (1 - α)
            ≤ ((N : ℝ) ^ ((1 : ℝ) / 2)) ^ (1 - α) :=
              Real.rpow_le_rpow
                (by exact_mod_cast Nat.zero_le (Nat.sqrt N))
                hsqrt_le_rpow
                (by linarith : 0 ≤ 1 - α)
        _ = (N : ℝ) ^ ((1 - α) / 2) := by
              rw [← Real.rpow_mul hNnonneg]
              ring
    have hconst_nonneg : 0 ≤ 1 + 1 / (1 - α) := by
      have hden_pos : 0 < 1 - α := by linarith
      have hinv_pos : 0 < 1 / (1 - α) := one_div_pos.mpr hden_pos
      linarith
    calc
      (∑ m ∈ Finset.Icc 1 (Nat.sqrt N), (m : ℝ) ^ (-α))
          ≤ (1 + 1 / (1 - α)) * (Nat.sqrt N : ℝ) ^ (1 - α) :=
            divisor_rpow_neg_sum_Icc_le hα0 hα1 (Nat.sqrt N) hsqrt_one
      _ ≤ (1 + 1 / (1 - α)) * (N : ℝ) ^ ((1 - α) / 2) :=
            mul_le_mul_of_nonneg_left hsqrt_pow_le hconst_nonneg

/-- Exact elementary divisor-sum envelope for the Rankin-facing smooth carrier.

This is the first theorem-level sharpening beyond the interval-length bound:
instead of replacing every fiber `Ψ(N/m,z)` by the worst endpoint `N`, we keep
the natural `N/m` scale in each fiber. -/
theorem smoothRankinEnvelope_le_sum_natDiv (N : ℕ) :
    smoothRankinEnvelope N ≤
      ∑ m ∈ Finset.Icc 1 (Nat.sqrt N), ((N / m : ℕ) : ℝ) := by
  classical
  unfold smoothRankinEnvelope
  apply Finset.sum_le_sum
  intro m _hm
  exact smoothPsi_nat_le (N / m) (zNatScale N)

/-- Real-division form of `smoothRankinEnvelope_le_sum_natDiv`. -/
theorem smoothRankinEnvelope_le_sum_realDiv (N : ℕ) :
    smoothRankinEnvelope N ≤
      ∑ m ∈ Finset.Icc 1 (Nat.sqrt N), (N : ℝ) / (m : ℝ) := by
  classical
  calc
    smoothRankinEnvelope N
        ≤ ∑ m ∈ Finset.Icc 1 (Nat.sqrt N), ((N / m : ℕ) : ℝ) :=
          smoothRankinEnvelope_le_sum_natDiv N
    _ ≤ ∑ m ∈ Finset.Icc 1 (Nat.sqrt N), (N : ℝ) / (m : ℝ) := by
          apply Finset.sum_le_sum
          intro m _hm
          exact Nat.cast_div_le

/-- Harmonic-sum form of the elementary Rankin-facing envelope.

This is still much weaker than the sharp Rankin/de Bruijn estimate, but it
identifies the exact elementary part of the summation as `N H_{⌊√N⌋}`. -/
theorem smoothRankinEnvelope_le_mul_harmonic_sqrt (N : ℕ) :
    smoothRankinEnvelope N ≤ (N : ℝ) * (harmonic (Nat.sqrt N) : ℝ) := by
  classical
  calc
    smoothRankinEnvelope N
        ≤ ∑ m ∈ Finset.Icc 1 (Nat.sqrt N), (N : ℝ) / (m : ℝ) :=
          smoothRankinEnvelope_le_sum_realDiv N
    _ = (N : ℝ) * (harmonic (Nat.sqrt N) : ℝ) := by
          rw [harmonic_eq_sum_Icc]
          simp only [Rat.cast_sum, Rat.cast_inv, Rat.cast_natCast]
          rw [Finset.mul_sum]
          apply Finset.sum_congr rfl
          intro m _hm
          rw [div_eq_mul_inv]

/-- Logarithmic elementary envelope obtained from the harmonic bound. -/
theorem smoothRankinEnvelope_le_mul_one_add_log_sqrt (N : ℕ) :
    smoothRankinEnvelope N ≤
      (N : ℝ) * (1 + Real.log (Nat.sqrt N : ℝ)) := by
  have henv := smoothRankinEnvelope_le_mul_harmonic_sqrt N
  have hharm :
      (harmonic (Nat.sqrt N) : ℝ) ≤
        1 + Real.log (Nat.sqrt N : ℝ) :=
    harmonic_le_one_add_log (Nat.sqrt N)
  exact henv.trans
    (mul_le_mul_of_nonneg_left hharm (by exact_mod_cast Nat.zero_le N))

/-- The Rankin-facing smooth envelope is nonnegative term by term. -/
theorem smoothRankinEnvelope_nonneg (N : ℕ) :
    0 ≤ smoothRankinEnvelope N := by
  classical
  unfold smoothRankinEnvelope
  apply Finset.sum_nonneg
  intro m _hm
  exact smoothPsi_nonneg ((N / m : ℕ) : ℝ) (zNatScale N : ℝ)

/-- A completely elementary finite-size bound for the Rankin-facing envelope.
This is far too crude for the final saving, but it proves the carrier is an
ordinary finite sum controlled by its interval length and endpoint. -/
theorem smoothRankinEnvelope_le_sqrt_mul_self (N : ℕ) :
    smoothRankinEnvelope N ≤ (Nat.sqrt N : ℝ) * (N : ℝ) := by
  classical
  unfold smoothRankinEnvelope
  calc
    (∑ m ∈ Finset.Icc 1 (Nat.sqrt N),
        smoothPsi ((N / m : ℕ) : ℝ) (zNatScale N : ℝ))
        ≤ ∑ m ∈ Finset.Icc 1 (Nat.sqrt N), (N : ℝ) := by
          apply Finset.sum_le_sum
          intro m _hm
          exact (smoothPsi_nat_le (N / m) (zNatScale N)).trans
            (by exact_mod_cast Nat.div_le_self N m)
    _ = (Nat.sqrt N : ℝ) * (N : ℝ) := by
          have hcard : (Finset.Icc (1 : ℕ) (Nat.sqrt N)).card = Nat.sqrt N := by
            rw [Nat.card_Icc]
            omega
          rw [Finset.sum_const, hcard, nsmul_eq_mul]

/-- Crude unconditional polynomial bound for the Rankin-facing envelope itself.

The final assembly needs the sharper Rankin/de Bruijn power saving `θ < 1`.
This theorem proves, without analytic input, that the exact envelope appearing in
that input is at least an ordinary finite carrier with a `N^(3/2)` bound. -/
theorem smoothRankinEnvelope_crude_polynomial_bound :
    ∃ θ C : ℝ, 0 < θ ∧ 0 < C ∧
      ∀ N : ℕ, 3 ≤ N →
        smoothRankinEnvelope N ≤ C * (N : ℝ) ^ θ := by
  refine ⟨(3 : ℝ) / 2, 1, by norm_num, by norm_num, ?_⟩
  intro N hN
  have hcrude := smoothRankinEnvelope_le_sqrt_mul_self N
  have hNpos : (0 : ℝ) < (N : ℝ) := by
    exact_mod_cast (lt_of_lt_of_le (by norm_num : (0 : ℕ) < 3) hN)
  have hsqrt : (Nat.sqrt N : ℝ) ≤ Real.sqrt (N : ℝ) :=
    Real.nat_sqrt_le_real_sqrt
  calc
    smoothRankinEnvelope N
        ≤ (Nat.sqrt N : ℝ) * (N : ℝ) := hcrude
    _ ≤ Real.sqrt (N : ℝ) * (N : ℝ) :=
        mul_le_mul_of_nonneg_right hsqrt hNpos.le
    _ = 1 * (N : ℝ) ^ ((3 : ℝ) / 2) := by
        calc
          Real.sqrt (N : ℝ) * (N : ℝ)
              = (N : ℝ) ^ ((1 : ℝ) / 2) * (N : ℝ) := by
                rw [Real.sqrt_eq_rpow]
          _ = (N : ℝ) ^ (((1 : ℝ) / 2) + 1) := by
                rw [Real.rpow_add hNpos, Real.rpow_one]
            _ = 1 * (N : ℝ) ^ ((3 : ℝ) / 2) := by
                  norm_num

/-- Sharper elementary polynomial fallback for the Rankin-facing envelope.

The checked harmonic envelope gives `smoothRankinEnvelope N ≤ N H_{⌊√N⌋}`.
Combining this with Mathlib's `log n ≤ n^ε / ε` at `ε = 1/2` yields the
axiom-free bound `O(N^(5/4))`.  The sharp Rankin/de Bruijn input below is
precisely what improves this exponent below `1`. -/
theorem smoothRankinEnvelope_five_four_polynomial_bound :
    ∃ θ C : ℝ, 0 < θ ∧ 0 < C ∧
      ∀ N : ℕ, 3 ≤ N →
        smoothRankinEnvelope N ≤ C * (N : ℝ) ^ θ := by
  refine ⟨(5 : ℝ) / 4, 3, by norm_num, by norm_num, ?_⟩
  intro N hN
  have hNone_nat : 1 ≤ N := le_trans (by norm_num : 1 ≤ 3) hN
  have hNpos : 0 < (N : ℝ) := by
    exact_mod_cast (lt_of_lt_of_le (by norm_num : 0 < 3) hN)
  have hNnonneg : 0 ≤ (N : ℝ) := hNpos.le
  have hNone : (1 : ℝ) ≤ (N : ℝ) := by exact_mod_cast hNone_nat
  have hsqrt_le_rpow :
      (Nat.sqrt N : ℝ) ≤ (N : ℝ) ^ ((1 : ℝ) / 2) := by
    simpa [Real.sqrt_eq_rpow] using Real.nat_sqrt_le_real_sqrt (a := N)
  have hsqrt_rpow_le :
      (Nat.sqrt N : ℝ) ^ ((1 : ℝ) / 2) ≤ (N : ℝ) ^ ((1 : ℝ) / 4) := by
    calc
      (Nat.sqrt N : ℝ) ^ ((1 : ℝ) / 2)
          ≤ ((N : ℝ) ^ ((1 : ℝ) / 2)) ^ ((1 : ℝ) / 2) :=
            Real.rpow_le_rpow
              (by exact_mod_cast Nat.zero_le (Nat.sqrt N))
              hsqrt_le_rpow
              (by norm_num)
      _ = (N : ℝ) ^ ((1 : ℝ) / 4) := by
            rw [← Real.rpow_mul hNnonneg]
            norm_num
  have hlog_le :
      Real.log (Nat.sqrt N : ℝ) ≤
        2 * (Nat.sqrt N : ℝ) ^ ((1 : ℝ) / 2) := by
    have h := Real.log_natCast_le_rpow_div (Nat.sqrt N)
      (by norm_num : (0 : ℝ) < (1 : ℝ) / 2)
    calc
      Real.log (Nat.sqrt N : ℝ)
          ≤ (Nat.sqrt N : ℝ) ^ ((1 : ℝ) / 2) / ((1 : ℝ) / 2) := h
      _ = 2 * (Nat.sqrt N : ℝ) ^ ((1 : ℝ) / 2) := by ring
  have htail :
      1 + Real.log (Nat.sqrt N : ℝ) ≤ 3 * (N : ℝ) ^ ((1 : ℝ) / 4) := by
    have hone_rpow : (1 : ℝ) ≤ (N : ℝ) ^ ((1 : ℝ) / 4) :=
      Real.one_le_rpow hNone (by norm_num)
    have htwosqrt :
        2 * (Nat.sqrt N : ℝ) ^ ((1 : ℝ) / 2) ≤
          2 * (N : ℝ) ^ ((1 : ℝ) / 4) :=
      mul_le_mul_of_nonneg_left hsqrt_rpow_le (by norm_num)
    calc
      1 + Real.log (Nat.sqrt N : ℝ)
          ≤ 1 + 2 * (Nat.sqrt N : ℝ) ^ ((1 : ℝ) / 2) :=
            add_le_add_left hlog_le 1
      _ ≤ (N : ℝ) ^ ((1 : ℝ) / 4) +
            2 * (N : ℝ) ^ ((1 : ℝ) / 4) :=
            add_le_add hone_rpow htwosqrt
      _ = 3 * (N : ℝ) ^ ((1 : ℝ) / 4) := by ring
  calc
    smoothRankinEnvelope N
        ≤ (N : ℝ) * (1 + Real.log (Nat.sqrt N : ℝ)) :=
          smoothRankinEnvelope_le_mul_one_add_log_sqrt N
    _ ≤ (N : ℝ) * (3 * (N : ℝ) ^ ((1 : ℝ) / 4)) :=
        mul_le_mul_of_nonneg_left htail hNnonneg
    _ = 3 * (N : ℝ) ^ ((5 : ℝ) / 4) := by
        calc
          (N : ℝ) * (3 * (N : ℝ) ^ ((1 : ℝ) / 4))
              = 3 * ((N : ℝ) * (N : ℝ) ^ ((1 : ℝ) / 4)) := by ring
          _ = 3 * ((N : ℝ) ^ (1 : ℝ) * (N : ℝ) ^ ((1 : ℝ) / 4)) := by
                rw [Real.rpow_one]
            _ = 3 * (N : ℝ) ^ ((1 : ℝ) + (1 : ℝ) / 4) := by
                  rw [Real.rpow_add hNpos]
            _ = 3 * (N : ℝ) ^ ((5 : ℝ) / 4) := by norm_num

/-- Absolute-value form of the sharper elementary Rankin-envelope fallback. -/
theorem abs_smoothRankinEnvelope_five_four_polynomial_bound :
    ∃ θ C : ℝ, 0 < θ ∧ 0 < C ∧
      ∀ N : ℕ, 3 ≤ N →
        |smoothRankinEnvelope N| ≤ C * (N : ℝ) ^ θ := by
  rcases smoothRankinEnvelope_five_four_polynomial_bound with
    ⟨θ, C, hθ, hC, hbound⟩
  refine ⟨θ, C, hθ, hC, ?_⟩
  intro N hN
  rw [abs_of_nonneg (smoothRankinEnvelope_nonneg N)]
  exact hbound N hN


/-- The symmetric signed-multiples and explicit floor-error quarter-budget
packages are theorem-level equivalent by finite floor-count bookkeeping. -/
theorem LinearSieveRoughDyadicMultiplesFloorErrorAbsQuarterBound_iff_signedErrorAbs :

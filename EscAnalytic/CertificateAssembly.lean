/-- Integer realization of the manuscript cutoff at the chosen family scale
`X`: `max 2 floor((log X)^4)`.  This is deliberately indexed by `X`, not by
the ambient interval endpoint `N`; after optimization those quantities are
different. -/
noncomputable def zNatScaleAt (X : ℝ) : ℕ :=
  max 2 ⌊zScale X⌋₊

/-- The scale-indexed natural cutoff is always nondegenerate. -/
theorem two_le_zNatScaleAt (X : ℝ) : 2 ≤ zNatScaleAt X := by
  unfold zNatScaleAt
  exact le_max_left 2 ⌊zScale X⌋₊

/-- Once the real cutoff is at least two, regularization does not change its
natural floor. -/
theorem zNatScaleAt_eq_floor {X : ℝ} (hfloor : 2 ≤ ⌊zScale X⌋₊) :
    zNatScaleAt X = ⌊zScale X⌋₊ := by
  unfold zNatScaleAt
  exact max_eq_right hfloor

/-- The natural cutoff lies below its real counterpart once that counterpart
is at least two. -/
theorem zNatScaleAt_cast_le_zScale {X : ℝ} (hz : 2 ≤ zScale X) :
    (zNatScaleAt X : ℝ) ≤ zScale X := by
  have hfloor : 2 ≤ ⌊zScale X⌋₊ := Nat.le_floor hz
  rw [zNatScaleAt_eq_floor hfloor]
  exact Nat.floor_le (by
    unfold zScale
    positivity)

/-- Nat-threshold version of the roughness modulus: the product of all primes
`≤ z`. -/
noncomputable def natPrimeProductBelow (z : ℕ) : ℕ :=
  ∏ p in (Finset.Icc (2 : ℕ) z).filter (fun p => Nat.Prime p), p

/-- The canonical Nat roughness modulus is nonzero. -/
theorem natPrimeProductBelow_ne_zero (z : ℕ) :
    natPrimeProductBelow z ≠ 0 := by
  classical
  let s := (Finset.Icc (2 : ℕ) z).filter (fun q => Nat.Prime q)
  have hs_primes : ∀ q ∈ s, Nat.Prime q := by
    intro q hq
    exact (Finset.mem_filter.mp hq).2
  exact Finset.prod_ne_zero_iff.mpr
    (fun q hq => (hs_primes q hq).ne_zero)

/-- Chebyshev's elementary primorial bound gives the exact modulus estimate
needed in the optimized level condition.  It is proved from Mathlib's
`primorial_le_4_pow`, not added as an external input. -/
theorem log_natPrimeProductBelow_le_log_four_mul (z : ℕ) :
    Real.log (natPrimeProductBelow z : ℝ) ≤ Real.log (4 : ℝ) * (z : ℝ) := by
  classical
  let s := (Finset.Icc (2 : ℕ) z).filter (fun p => Nat.Prime p)
  have hs_eq :
      s = (Finset.Icc (1 : ℕ) z).filter (fun p => Nat.Prime p) := by
    ext p
    simp only [s, Finset.mem_filter, Finset.mem_Icc]
    constructor
    · rintro ⟨⟨hp_two, hp_le⟩, hpPrime⟩
      exact ⟨⟨by omega, hp_le⟩, hpPrime⟩
    · rintro ⟨⟨_hp_one, hp_le⟩, hpPrime⟩
      exact ⟨⟨hpPrime.two_le, hp_le⟩, hpPrime⟩
  have hcast : (natPrimeProductBelow z : ℝ) = ∏ p in s, (p : ℝ) := by
    simp [natPrimeProductBelow, s]
  have hlog_prod : Real.log (∏ p in s, (p : ℝ)) =
      ∑ p in s, Real.log (p : ℝ) := by
    rw [Real.log_prod]
    intro p hp
    exact_mod_cast (Finset.mem_filter.mp hp).2.ne_zero
  calc
    Real.log (natPrimeProductBelow z : ℝ)
        = ∑ p in s, Real.log (p : ℝ) := by rw [hcast, hlog_prod]
    _ = ∑ p in (Finset.Icc (1 : ℕ) z).filter (fun p => Nat.Prime p),
          Real.log (p : ℝ) := by rw [hs_eq]
    _ ≤ Real.log (4 : ℝ) * (z : ℝ) := Inputs.primeLogSum_le_log_four_mul z

/-! ## Natural prime-product modulus -/

/-- The elementary constant in the primorial bound is below the manuscript's
convenient constant two. -/
theorem log_natPrimeProductBelow_le_two_mul (z : ℕ) :
    Real.log (natPrimeProductBelow z : ℝ) ≤ 2 * (z : ℝ) := by
  have hlog_two_lt_one : Real.log (2 : ℝ) < 1 := by
    have h := Real.log_lt_sub_one_of_pos (show (0 : ℝ) < 2 by norm_num)
      (show (2 : ℝ) ≠ 1 by norm_num)
    norm_num at h
    exact h
  have hlog_four : Real.log (4 : ℝ) = 2 * Real.log (2 : ℝ) := by
    calc
      Real.log (4 : ℝ) = Real.log ((2 : ℝ) * 2) := by norm_num
      _ = Real.log (2 : ℝ) + Real.log (2 : ℝ) := by
        rw [Real.log_mul (by norm_num) (by norm_num)]
      _ = 2 * Real.log (2 : ℝ) := by ring
  have hlog_four_le_two : Real.log (4 : ℝ) ≤ 2 := by
    rw [hlog_four]
    linarith
  calc
    Real.log (natPrimeProductBelow z : ℝ)
        ≤ Real.log (4 : ℝ) * (z : ℝ) :=
          log_natPrimeProductBelow_le_log_four_mul z
    _ ≤ 2 * (z : ℝ) :=
      mul_le_mul_of_nonneg_right hlog_four_le_two (by positivity)

/-- The canonical primorial at the manuscript's `X`-scale satisfies the
Mertens/Chebyshev estimate used by the finite-level optimization. -/
theorem log_natPrimeProductBelow_zNatScaleAt_le_two_mul_zScale
    {X : ℝ} (hz : 2 ≤ zScale X) :
    Real.log (natPrimeProductBelow (zNatScaleAt X) : ℝ) ≤ 2 * zScale X := by
  calc
    Real.log (natPrimeProductBelow (zNatScaleAt X) : ℝ)
        ≤ 2 * (zNatScaleAt X : ℝ) :=
          log_natPrimeProductBelow_le_two_mul (zNatScaleAt X)
    _ ≤ 2 * zScale X :=
      mul_le_mul_of_nonneg_left (zNatScaleAt_cast_le_zScale hz) (by norm_num)

/-- Every prime at most `z` divides the canonical Nat roughness modulus. -/
theorem prime_dvd_natPrimeProductBelow
    (z p : ℕ)
    (hp : Nat.Prime p)
    (hp_le : p ≤ z) :
    p ∣ natPrimeProductBelow z := by
  classical
  let s := (Finset.Icc (2 : ℕ) z).filter (fun q => Nat.Prime q)
  have hp_mem : p ∈ s := by
    rw [Finset.mem_filter, Finset.mem_Icc]
    exact ⟨⟨hp.two_le, hp_le⟩, hp⟩
  simpa [natPrimeProductBelow, s] using Finset.dvd_prod_of_mem (fun q => q) hp_mem

/-- Once `z ≥ 2`, the canonical Nat roughness modulus is larger than `1`. -/
theorem one_lt_natPrimeProductBelow
    (z : ℕ)
    (hz : 2 ≤ z) :
    1 < natPrimeProductBelow z := by
  have htwo_dvd : 2 ∣ natPrimeProductBelow z :=
    prime_dvd_natPrimeProductBelow z 2 Nat.prime_two hz
  have htwo_le : 2 ≤ natPrimeProductBelow z :=
    Nat.le_of_dvd (Nat.pos_of_ne_zero (natPrimeProductBelow_ne_zero z)) htwo_dvd
  omega

/-- A squarefree integer whose prime factors are all at most `z` divides the
canonical Nat roughness modulus. -/
theorem squarefree_dvd_natPrimeProductBelow
    (z d : ℕ)
    (hd : Squarefree d)
    (hfac : ∀ p : ℕ, Nat.Prime p → p ∣ d → p ≤ z) :
    d ∣ natPrimeProductBelow z := by
  classical
  let s := (Finset.Icc (2 : ℕ) z).filter (fun q => Nat.Prime q)
  have hsubset : d.primeFactors ⊆ s := by
    intro p hp
    rw [Finset.mem_filter, Finset.mem_Icc]
    have hprime : Nat.Prime p := Nat.prime_of_mem_primeFactors hp
    exact ⟨⟨hprime.two_le, hfac p hprime (Nat.dvd_of_mem_primeFactors hp)⟩, hprime⟩
  have hprod_sdiff := Finset.prod_sdiff hsubset (f := fun p : ℕ => p)
  have hprod_dvd : (∏ p ∈ d.primeFactors, p) ∣ (∏ p ∈ s, p) := by
    rw [← hprod_sdiff]
    exact dvd_mul_left _ _
  rw [← Nat.prod_primeFactors_of_squarefree hd]
  simpa [natPrimeProductBelow, s] using hprod_dvd

/-- Exact canonical product-of-primes certificate route at the regularized
Rankin cutoff.

This specializes the budget-decomposition bridge to
`P N = natPrimeProductBelow (zNatScale N)`, fixes `Pz` to the same modulus, and

    ∃ α ε A : ℝ, 0 < α ∧ α < 1 ∧ 0 ≤ ε ∧ ε < (1 - α) / 2 ∧ 0 < A ∧
      ∀ k m : ℕ, 2 ≤ k →
        m ∈ Finset.Icc 1 (Nat.sqrt (2 ^ k)) →
          ((Nat.smoothNumbersUpTo ((2 ^ k) / m) (zNatScale (2 ^ k) + 1)).card : ℝ)
            ≤ A * ((((2 ^ k) / m : ℕ) : ℝ) ^ α) * ((2 ^ k : ℕ) : ℝ) ^ ε := by
  rcases hTail with ⟨α, ε, A, hα0, hα1, hε0, hgap, hA, hTail⟩
  exact
    rankin_mathlibSmoothNumbersUpTo_zNatScale_dyadic_pointwise_natDiv_bound_of_primeGeomProduct
      ⟨α, ε, A, hα0, hα1, hε0, hgap, hA, by
        intro k hk
        have hKpos : 0 < 2 ^ k := pow_pos (by norm_num : (0 : ℕ) < 2) k
        exact
          rankinPrimeGeomProduct_le_of_natRpowSum_bound
            (K := 2 ^ k) (z := zNatScale (2 ^ k) + 1) hKpos hα0 hA

/-- Every prime factor of `natPrimeProductBelow z` is at most `z`. -/
theorem natPrimeProductBelow_prime_factor_le
    (z p : ℕ)
    (hp : Nat.Prime p)
    (hdiv : p ∣ natPrimeProductBelow z) :
    p ≤ z := by
  classical
  let s := (Finset.Icc (2 : ℕ) z).filter (fun q => Nat.Prime q)
  have hs_primes : ∀ q ∈ s, Nat.Prime q := by
    intro q hq
    exact (Finset.mem_filter.mp hq).2
  have hp_mem_factors : p ∈ Nat.primeFactors (∏ q ∈ s, q) :=
    (Nat.mem_primeFactors).mpr ⟨hp, by simpa [natPrimeProductBelow, s] using hdiv,
      by simpa [natPrimeProductBelow, s] using natPrimeProductBelow_ne_zero z⟩
  have hp_mem_s : p ∈ s := by
    simpa [Nat.primeFactors_prod hs_primes] using hp_mem_factors
  exact (Finset.mem_Icc.mp (Finset.mem_filter.mp hp_mem_s).1).2

/-- Prime-factor support for canonical product-of-primes moduli across quotient
scales, under a monotone roughness cutoff. -/
theorem natPrimeProductBelow_prime_factor_le_of_mono
    (z : ℕ → ℕ)
    {M N p : ℕ}
    (hmono : ∀ M N : ℕ, M ≤ N → z M ≤ z N)
    (hMN : M ≤ N)
    (hp : Nat.Prime p)
    (hdiv : p ∣ natPrimeProductBelow (z M)) :
    p ≤ z N :=
  le_trans (natPrimeProductBelow_prime_factor_le (z M) p hp hdiv)
    (hmono M N hMN)

/-- A rough integer is coprime to any modulus whose prime factors all lie below
the roughness threshold. -/
theorem coprime_of_IsRough_of_prime_factors_le
    {z m P : ℕ}
    (hrough : IsRough z m)
    (hPfac : ∀ p : ℕ, Nat.Prime p → p ∣ P → p ≤ z) :
    Nat.Coprime m P := by
  by_contra hnot
  obtain ⟨p, hpprime, hpm, hpP⟩ := Nat.Prime.not_coprime_iff_dvd.mp hnot
  exact hrough p hpprime (hPfac p hpprime hpP) hpm

/-- A rough integer is reduced modulo any modulus whose prime factors all lie
below the roughness threshold. -/
theorem coprime_mod_of_IsRough_of_prime_factors_le
    {z m P : ℕ}
    (hrough : IsRough z m)
    (hPfac : ∀ p : ℕ, Nat.Prime p → p ∣ P → p ≤ z) :
    Nat.Coprime (m % P) P :=
  EscLeanChecks.coprime_mod_right_of_coprime m P
    (coprime_of_IsRough_of_prime_factors_le hrough hPfac)

/-- Bridge from the endpoint-correct rough reduced count to the certified
reduced base count, under the natural condition that the chosen modulus has no
prime factor above the roughness threshold. -/
theorem reducedExceptionalCountGeTwo_le_reducedBaseExceptionalCountGeTwo
    (z M P : ℕ)
    (hPfac : ∀ p : ℕ, Nat.Prime p → p ∣ P → p ≤ z) :
    reducedExceptionalCountGeTwo z M ≤
      EscLeanChecks.reducedBaseExceptionalCountGeTwo M P := by
  classical
  unfold reducedExceptionalCountGeTwo EscLeanChecks.reducedBaseExceptionalCountGeTwo
    EscLeanChecks.reducedBasePointSet
  apply Finset.card_le_card
  intro m hm
  rw [Finset.mem_filter, Finset.mem_Icc] at hm
  obtain ⟨⟨hMlo, hMhi⟩, hrough, hex⟩ := hm
  rw [Finset.mem_filter, Finset.mem_filter]
  exact
    ⟨⟨Finset.mem_range.mpr (Nat.lt_succ_of_le hMhi),
      coprime_mod_of_IsRough_of_prime_factors_le hrough hPfac⟩,
      hMlo, hex⟩

/-- The actual paper family controls the rough reduced exceptional carrier by
its finite no-hit sum.  This composes the roughness-to-reduced-base reduction
with the concrete paper-family certificate, so no separate event-certificate
hypothesis remains at this step. -/
theorem reducedExceptionalCountGeTwo_le_paperFamilyNoHit
    (z N Pz : ℕ) (params : Params) (X : ℝ)
    (indicesByBase : ℕ → Finset Family.FamilyIndex)
    (hPfac : ∀ p : ℕ, Nat.Prime p → p ∣ Pz → p ≤ z)
    (hX : 1 < X)
    (hmem : ∀ b i, i ∈ indicesByBase b →
      Family.FamilyStaticMem params X Pz b i)
    (hdminus_lt_p : ∀ b i, i ∈ indicesByBase b → i.dminus < i.p) :
    (reducedExceptionalCountGeTwo z N : Int) ≤
      EscLeanChecks.reducedBaseSatEventNoHitIndicatorSumUpTo N Pz
        (fun b => Family.familyEvents (indicesByBase b)) := by
  have hrough :
      reducedExceptionalCountGeTwo z N ≤
        EscLeanChecks.reducedBaseExceptionalCountGeTwo N Pz :=
    reducedExceptionalCountGeTwo_le_reducedBaseExceptionalCountGeTwo z N Pz hPfac
  have hcert : ∀ b event,
      event ∈ Family.familyEvents (indicesByBase b) →
        ∃ r s : ℕ,
          0 < r ∧ 0 < s ∧ event.e = r * s ^ 2 ∧
          Nat.Coprime event.dMinus (event.dPlus * event.p) ∧
          event.dMinus ∣ Pz ∧
          b + 4 * event.e ≡ 0 [MOD event.dMinus] ∧
          4 * (r * s) ∣ event.dMinus * (event.dPlus * event.p) + 1 := by
    intro b event hevent
    exact Family.familyEvents_certificate_of_dminus_lt_p params X Pz b (indicesByBase b)
      hX (fun i hi => hdminus_lt_p b i hi)
      (fun i hi => hmem b i hi) event hevent
  calc
    (reducedExceptionalCountGeTwo z N : Int) ≤
        (EscLeanChecks.reducedBaseExceptionalCountGeTwo N Pz : Int) := by
          exact_mod_cast hrough
    _ ≤ EscLeanChecks.reducedBaseSatEventNoHitIndicatorSumUpTo N Pz
        (fun b => Family.familyEvents (indicesByBase b)) :=
      EscLeanChecks.reducedBaseExceptionalCountGeTwo_le_reducedBaseSatEventNoHitIndicatorSum_of_variable_certs
        N Pz (fun b => Family.familyEvents (indicesByBase b)) hcert

/-- The rough reduced exceptional carrier is controlled by the no-hit sum for
the full finite static family from the paper, rather than a caller-selected
subfamily. -/
theorem reducedExceptionalCountGeTwo_le_actualPaperFamilyNoHit
    (z N Pz : ℕ) (params : Params) (X : ℝ)
    (hPfac : ∀ p : ℕ, Nat.Prime p → p ∣ Pz → p ≤ z)
    (hX : 1 < X)
    (hU_lt_primeScale : UScale X < X ^ params.β) :
    (reducedExceptionalCountGeTwo z N : Int) ≤
      EscLeanChecks.reducedBaseSatEventNoHitIndicatorSumUpTo N Pz
        (fun b => Family.familyEvents (Family.familyIndexFinset params X Pz b)) := by
  apply reducedExceptionalCountGeTwo_le_paperFamilyNoHit z N Pz params X
    (fun b => Family.familyIndexFinset params X Pz b) hPfac hX
  · intro b i hi
    exact (Family.mem_familyIndexFinset_iff params X Pz b i
      (lt_trans zero_lt_one hX)).1 hi
  · intro b i hi
    exact Family.familyIndexFinset_dminus_lt_prime params X Pz b hX
      hU_lt_primeScale i hi

/-- The concrete paper family gives an explicit finite compatible-lcm bound
for the reduced exceptional count.  This closes the CRT and Bonferroni
reduction before the remaining analytic estimates are invoked. -/
theorem reducedExceptionalCountGeTwo_le_actualPaperFamilyCompatibleLcm
    (z N Pz R : ℕ) (params : Params) (X : ℝ)
    (hPfac : ∀ p : ℕ, Nat.Prime p → p ∣ Pz → p ≤ z)
    (hPz : 0 < Pz) (hX : 1 < X)
    (hU_lt_primeScale : UScale X < X ^ params.β)
    (hz_lt_primeScale : (z : ℝ) < X ^ params.β) :
    (reducedExceptionalCountGeTwo z N : Int) ≤
      ∑ b ∈ EscLeanChecks.reducedResiduesMod Pz,
        ∑ r ∈ Finset.range (2 * R + 1),
          ((∑ s ∈ EscLeanChecks.baseRowCompatibleSubsetsOfCard Pz b
              (EscLeanChecks.satEventResidualHitRowsFinset
                (Family.familyEvents (Family.familyIndexFinset params X Pz b))) r,
            (N / (Pz * EscLeanChecks.congruenceLcm s.toList) + 1) : Nat) : Int) := by
  calc
    (reducedExceptionalCountGeTwo z N : Int) ≤
        EscLeanChecks.reducedBaseSatEventNoHitIndicatorSumUpTo N Pz
          (fun b => Family.familyEvents (Family.familyIndexFinset params X Pz b)) :=
      reducedExceptionalCountGeTwo_le_actualPaperFamilyNoHit z N Pz params X
        hPfac hX hU_lt_primeScale
    _ = ∑ b ∈ EscLeanChecks.reducedResiduesMod Pz,
        EscLeanChecks.baseSatEventNoHitIndicatorSumUpTo N Pz b
          (Family.familyEvents (Family.familyIndexFinset params X Pz b)) := by
      symm
      exact EscLeanChecks.reducedBaseSatEventNoHitIndicatorSum_eq_sum_base
        N Pz (fun b => Family.familyEvents (Family.familyIndexFinset params X Pz b)) hPz
    _ ≤ ∑ b ∈ EscLeanChecks.reducedResiduesMod Pz,
        ∑ r ∈ Finset.range (2 * R + 1),
          ((∑ s ∈ EscLeanChecks.baseRowCompatibleSubsetsOfCard Pz b
              (EscLeanChecks.satEventResidualHitRowsFinset
                (Family.familyEvents (Family.familyIndexFinset params X Pz b))) r,
            (N / (Pz * EscLeanChecks.congruenceLcm s.toList) + 1) : Nat) : Int) := by
      apply Finset.sum_le_sum
      intro b _hb
      exact Family.actualPaperFamily_baseFiniteIntervalTransfer_le_compatible_lcm
        params X N z Pz b R hPfac hPz hX hz_lt_primeScale

/-- Canonical product-of-primes specialization of the concrete compatible-lcm
bound.  The prime-factor support and positivity of `P(z)` are internal here. -/
theorem reducedExceptionalCountGeTwo_le_actualPaperFamilyCompatibleLcm_natPrimeProduct
    (z N R : ℕ) (params : Params) (X : ℝ)
    (hX : 1 < X)
    (hU_lt_primeScale : UScale X < X ^ params.β)
    (hz_lt_primeScale : (z : ℝ) < X ^ params.β) :
    (reducedExceptionalCountGeTwo z N : Int) ≤
      ∑ b ∈ EscLeanChecks.reducedResiduesMod (natPrimeProductBelow z),
        ∑ r ∈ Finset.range (2 * R + 1),
          ((∑ s ∈ EscLeanChecks.baseRowCompatibleSubsetsOfCard
              (natPrimeProductBelow z) b
              (EscLeanChecks.satEventResidualHitRowsFinset
                (Family.familyEvents
                  (Family.familyIndexFinset params X (natPrimeProductBelow z) b))) r,
            (N / (natPrimeProductBelow z * EscLeanChecks.congruenceLcm s.toList) + 1) : Nat) : Int) := by
  apply reducedExceptionalCountGeTwo_le_actualPaperFamilyCompatibleLcm
    z N (natPrimeProductBelow z) R params X
  · intro p hp hdiv
    exact natPrimeProductBelow_prime_factor_le z p hp hdiv
  · exact Nat.pos_of_ne_zero (natPrimeProductBelow_ne_zero z)
  · exact hX
  · exact hU_lt_primeScale
  · exact hz_lt_primeScale

/-- The polylogarithmic sieve and small-divisor scales are eventually below
the selected-prime scale.  This is an elementary scale separation, independent
of the analytic finite-transfer estimates. -/
theorem Params.eventually_zScale_and_UScale_lt_primeScale (params : Params) :
    ∃ X₀ : ℝ, ∀ X : ℝ, X₀ ≤ X →
      1 < X ∧ zScale X < X ^ params.β ∧ UScale X < X ^ params.β := by
  have hhalf_pos : 0 < params.β / 2 := div_pos params.β_pos (by norm_num)
  rcases Inputs.eventually_UScale_le_rpow hhalf_pos with ⟨XU, hU⟩
  refine ⟨max XU (Real.exp 1), ?_⟩
  intro X hX
  have hXU : XU ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 1 ≤ X := le_trans (le_max_right _ _) hX
  have hXone : 1 < X :=
    lt_of_lt_of_le (Real.one_lt_exp_iff.mpr (by norm_num)) hXexp
  have hXpos : 0 < X := lt_trans zero_lt_one hXone
  have hUhalf : UScale X ≤ X ^ (params.β / 2) := hU X hXU
  have hhalf_lt : params.β / 2 < params.β := by nlinarith [params.β_pos]
  have hpow_lt : X ^ (params.β / 2) < X ^ params.β :=
    Real.rpow_lt_rpow_of_exponent_lt hXone hhalf_lt
  have hU_lt : UScale X < X ^ params.β := lt_of_le_of_lt hUhalf hpow_lt
  have hlog_ge_one : (1 : ℝ) ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hXexp
  have hlog_nonneg : 0 ≤ Real.log X := le_trans zero_le_one hlog_ge_one
  have hlog_four_nonneg : 0 ≤ (Real.log X) ^ (4 : ℕ) :=
    pow_nonneg hlog_nonneg _
  have hlog_four_one : (1 : ℝ) ≤ (Real.log X) ^ (4 : ℕ) := by
    simpa using pow_le_pow_left₀ zero_le_one hlog_ge_one 4
  have hz_le_U : zScale X ≤ UScale X := by
    unfold zScale UScale
    calc
      (Real.log X) ^ (4 : ℕ) = (Real.log X) ^ (4 : ℕ) * 1 := by ring
      _ ≤ (Real.log X) ^ (4 : ℕ) * (Real.log X) ^ (4 : ℕ) :=
        mul_le_mul_of_nonneg_left hlog_four_one hlog_four_nonneg
      _ = (Real.log X) ^ (8 : ℕ) := by ring
  exact ⟨hXone, lt_of_le_of_lt hz_le_U hU_lt, hU_lt⟩

/-- The integer cutoff indexed by the manuscript family scale is eventually
below the selected-prime scale, together with the small-divisor scale. -/
theorem Params.eventually_zNatScaleAt_and_UScale_lt_primeScale (params : Params) :
    ∃ X₀ : ℝ, ∀ X : ℝ, X₀ ≤ X →
      1 < X ∧ (zNatScaleAt X : ℝ) < X ^ params.β ∧ UScale X < X ^ params.β := by
  rcases params.eventually_zScale_and_UScale_lt_primeScale with ⟨Xscale, hscale⟩
  refine ⟨max Xscale (Real.exp 2), ?_⟩
  intro X hX
  have hXscale : Xscale ≤ X := le_trans (le_max_left _ _) hX
  have hXexp2 : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  obtain ⟨hXone, hz, hU⟩ := hscale X hXscale
  have hXpos : 0 < X := lt_trans zero_lt_one hXone
  have hlog_ge_two : (2 : ℝ) ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hXexp2
  have hz_ge_two : (2 : ℝ) ≤ zScale X := by
    unfold zScale
    have hpow : (2 : ℝ) ^ (4 : ℕ) ≤ (Real.log X) ^ (4 : ℕ) :=
      pow_le_pow_left₀ (by norm_num) hlog_ge_two 4
    norm_num at hpow
    linarith
  exact ⟨hXone, lt_of_le_of_lt (zNatScaleAt_cast_le_zScale hz_ge_two) hz, hU⟩

/-- The regularized natural cutoff `z_N` also lies below the selected-prime
scale after a finite threshold. -/
theorem Params.eventually_zNatScale_and_UScale_lt_primeScale (params : Params) :
    ∃ X₀ : ℝ, ∀ N : ℕ, X₀ ≤ (N : ℝ) →
      1 < (N : ℝ) ∧ (zNatScale N : ℝ) < (N : ℝ) ^ params.β ∧
        UScale (N : ℝ) < (N : ℝ) ^ params.β := by
  rcases params.eventually_zScale_and_UScale_lt_primeScale with ⟨Xscale, hscale⟩
  refine ⟨max Xscale (Real.exp 2), ?_⟩
  intro N hN
  have hXscale : Xscale ≤ (N : ℝ) := le_trans (le_max_left _ _) hN
  have hXexp2 : Real.exp 2 ≤ (N : ℝ) := le_trans (le_max_right _ _) hN
  obtain ⟨hNone, hz, hU⟩ := hscale N hXscale
  have hNpos : 0 < (N : ℝ) := lt_trans zero_lt_one hNone
  have hlog_ge_two : (2 : ℝ) ≤ Real.log (N : ℝ) := by
    rw [Real.le_log_iff_exp_le hNpos]
    exact hXexp2
  have hz_ge_two : (2 : ℝ) ≤ zScale (N : ℝ) := by
    unfold zScale
    have hpow : (2 : ℝ) ^ (4 : ℕ) ≤ (Real.log (N : ℝ)) ^ (4 : ℕ) :=
      pow_le_pow_left₀ (by norm_num) hlog_ge_two 4
    norm_num at hpow
    linarith
  have hfloor : 2 ≤ ⌊zScale (N : ℝ)⌋₊ := Nat.le_floor hz_ge_two
  have hz_nonneg : 0 ≤ zScale (N : ℝ) := le_trans zero_le_two hz_ge_two
  have hfloor_le : (⌊zScale (N : ℝ)⌋₊ : ℝ) ≤ zScale (N : ℝ) :=
    Nat.floor_le hz_nonneg
  have hnat : zNatScale N = ⌊zScale (N : ℝ)⌋₊ := by
    unfold zNatScale
    exact max_eq_right hfloor
  refine ⟨hNone, ?_, hU⟩
  rw [hnat]
  exact lt_of_le_of_lt hfloor_le hz

/-- The rough-large range only needs the endpoint-correct reduced count: the
rough part is `> sqrt N`, hence at least `2` for every nonempty rough-large
fiber. -/
theorem roughLargeCount_le_sum_reducedGeTwo (z N : ℕ) :
    roughLargeCount z N ≤
      ∑ s ∈ Finset.Icc 1 N, reducedExceptionalCountGeTwo z (N / s) := by
  classical
  set R : Finset ℕ :=
    (Finset.Icc 2 N).filter
      (fun n => EscLeanChecks.esExceptional n ∧ ¬ roughPart z n ≤ Nat.sqrt N) with hR
  have hmem : ∀ n ∈ R, smoothPart z n ∈ Finset.Icc 1 N := by
    intro n hn
    rw [hR, Finset.mem_filter, Finset.mem_Icc] at hn
    obtain ⟨⟨h2, hN⟩, _⟩ := hn
    have hpos : 0 < n := by omega
    rw [Finset.mem_Icc]
    exact ⟨smooth_pos, le_trans (smooth_le hpos) hN⟩
  have hfib := Finset.card_eq_sum_card_fiberwise (f := fun n => smoothPart z n)
    (s := R) (t := Finset.Icc 1 N) hmem
  rw [show roughLargeCount z N = R.card from rfl, hfib]
  apply Finset.sum_le_sum
  intro s _hs
  rw [reducedExceptionalCountGeTwo]
  apply Finset.card_le_card_of_injOn (fun n => roughPart z n)
  · intro n hn
    rw [Finset.mem_filter] at hn
    obtain ⟨hnR, hfeq⟩ := hn
    rw [hR, Finset.mem_filter, Finset.mem_Icc] at hnR
    obtain ⟨⟨h2, hN⟩, hex, hlarge⟩ := hnR
    have hpos : 0 < n := by omega
    have hsqr : 1 ≤ Nat.sqrt N := by
      rw [Nat.le_sqrt]
      omega
    have hrough_ne_one : roughPart z n ≠ 1 := by
      intro hone
      exact hlarge (by simpa [hone] using hsqr)
    have hrough_two : 2 ≤ roughPart z n := by
      have hrough_pos := rough_pos (z := z) (n := n)
      omega
    rw [Finset.mem_filter, Finset.mem_Icc]
    refine ⟨⟨hrough_two, ?_⟩, roughPart_isRough z n, exceptional_lift hpos hex⟩
    have hsmr : smoothPart z n * roughPart z n = n := smooth_mul_rough z hpos.ne'
    rw [Nat.le_div_iff_mul_le (by rw [← hfeq]; exact smooth_pos), ← hfeq]
    calc roughPart z n * smoothPart z n = smoothPart z n * roughPart z n := by ring
      _ = n := hsmr
      _ ≤ N := hN
  · intro a ha b hb hab
    simp only [Finset.coe_filter, Set.mem_setOf_eq] at ha hb
    obtain ⟨haR, hfa⟩ := ha
    obtain ⟨hbR, hfb⟩ := hb
    rw [hR, Finset.mem_filter, Finset.mem_Icc] at haR hbR
    have hapos : 0 < a := by have := haR.1.1; omega
    have hbpos : 0 < b := by have := hbR.1.1; omega
    have hra : smoothPart z a * roughPart z a = a := smooth_mul_rough z hapos.ne'
    have hrb : smoothPart z b * roughPart z b = b := smooth_mul_rough z hbpos.ne'
    simp only [] at hab
    rw [← hra, ← hrb, hfa, hfb, hab]

/-- The rough-large range is bounded by the sum of certified reduced-base counts
over the quotient scales `N / s`, provided the chosen moduli have no prime
factor above the roughness threshold.

This is the reusable nonzero analogue of the certified-rough-zero bridge: it
turns the `LiftCount` rough-counting notion into the certificate layer's reduced
base-counting notion before any Euler-product comparison is applied. -/
theorem roughLargeCount_le_sum_reducedBaseGeTwo
    (z N : ℕ)
    (P : ℕ → ℕ)
    (hPfac : ∀ M : ℕ, M ≤ N →
      ∀ p : ℕ, Nat.Prime p → p ∣ P M → p ≤ z) :
    roughLargeCount z N ≤
      ∑ s ∈ Finset.Icc 1 N,
        EscLeanChecks.reducedBaseExceptionalCountGeTwo (N / s) (P (N / s)) := by
  classical
  calc roughLargeCount z N
      ≤ ∑ s ∈ Finset.Icc 1 N, reducedExceptionalCountGeTwo z (N / s) :=
        roughLargeCount_le_sum_reducedGeTwo z N
    _ ≤ ∑ s ∈ Finset.Icc 1 N,
          EscLeanChecks.reducedBaseExceptionalCountGeTwo (N / s) (P (N / s)) := by
        apply Finset.sum_le_sum
        intro s _hs
        exact reducedExceptionalCountGeTwo_le_reducedBaseExceptionalCountGeTwo
          z (N / s) (P (N / s)) (hPfac (N / s) (Nat.div_le_self N s))

/-- Real-valued rough-large range bound from an explicit Euler comparison for
the certified reduced-base quotient sum. -/
theorem roughLargeCount_le_euler_mul_reducedBase_of_sum
    (z N : ℕ)
    (P : ℕ → ℕ)
    (euler : ℝ)
    (hPfac : ∀ M : ℕ, M ≤ N →
      ∀ p : ℕ, Nat.Prime p → p ∣ P M → p ≤ z)
    (hsum : ((∑ s ∈ Finset.Icc 1 N,
        EscLeanChecks.reducedBaseExceptionalCountGeTwo (N / s) (P (N / s))) : ℝ)
      ≤ euler * (EscLeanChecks.reducedBaseExceptionalCountGeTwo N (P N) : ℝ)) :
    (roughLargeCount z N : ℝ)
      ≤ euler * (EscLeanChecks.reducedBaseExceptionalCountGeTwo N (P N) : ℝ) := by
  exact le_trans (by
      exact_mod_cast roughLargeCount_le_sum_reducedBaseGeTwo z N P hPfac)
    hsum

/-- Weighted local form of the certified reduced-base quotient-sum comparison.

Instead of assuming the whole quotient sum at once, it is enough to bound each
fiber by a scalar weight times the ambient reduced-base count and then bound the
sum of those weights. -/
theorem reducedBaseQuotientSum_le_mul_of_pointwise_weight
    (N : ℕ)
    (P : ℕ → ℕ)
    (weight : ℕ → ℝ)
    (euler : ℝ)
    (hpoint : ∀ s ∈ Finset.Icc 1 N,
      (EscLeanChecks.reducedBaseExceptionalCountGeTwo (N / s) (P (N / s)) : ℝ)
        ≤ weight s *
          (EscLeanChecks.reducedBaseExceptionalCountGeTwo N (P N) : ℝ))
    (hweight : (∑ s ∈ Finset.Icc 1 N, weight s) ≤ euler) :
    ((∑ s ∈ Finset.Icc 1 N,
        EscLeanChecks.reducedBaseExceptionalCountGeTwo (N / s) (P (N / s))) : ℝ)
      ≤ euler *
        (EscLeanChecks.reducedBaseExceptionalCountGeTwo N (P N) : ℝ) := by
  classical
  have hcast :
      ((∑ s ∈ Finset.Icc 1 N,
          EscLeanChecks.reducedBaseExceptionalCountGeTwo (N / s) (P (N / s))) : ℝ)
        =
      ∑ s ∈ Finset.Icc 1 N,
        (EscLeanChecks.reducedBaseExceptionalCountGeTwo (N / s) (P (N / s)) : ℝ) := by
    norm_num
  rw [hcast]
  calc
    (∑ s ∈ Finset.Icc 1 N,
        (EscLeanChecks.reducedBaseExceptionalCountGeTwo (N / s) (P (N / s)) : ℝ))
        ≤ ∑ s ∈ Finset.Icc 1 N,
            weight s *
              (EscLeanChecks.reducedBaseExceptionalCountGeTwo N (P N) : ℝ) :=
          Finset.sum_le_sum hpoint
    _ = (∑ s ∈ Finset.Icc 1 N, weight s) *
          (EscLeanChecks.reducedBaseExceptionalCountGeTwo N (P N) : ℝ) := by
          rw [Finset.sum_mul]
    _ ≤ euler *
          (EscLeanChecks.reducedBaseExceptionalCountGeTwo N (P N) : ℝ) :=
          mul_le_mul_of_nonneg_right hweight (Nat.cast_nonneg _)

/-- Rough-large bound from the weighted local form of the reduced-base quotient
sum. -/
theorem roughLargeCount_le_euler_mul_reducedBase_of_pointwise_weight
    (z N : ℕ)
    (P : ℕ → ℕ)
    (euler : ℝ)
    (weight : ℕ → ℝ)
    (hPfac : ∀ M : ℕ, M ≤ N →
      ∀ p : ℕ, Nat.Prime p → p ∣ P M → p ≤ z)
    (hpoint : ∀ s ∈ Finset.Icc 1 N,
      (EscLeanChecks.reducedBaseExceptionalCountGeTwo (N / s) (P (N / s)) : ℝ)
        ≤ weight s *
          (EscLeanChecks.reducedBaseExceptionalCountGeTwo N (P N) : ℝ))
    (hweight : (∑ s ∈ Finset.Icc 1 N, weight s) ≤ euler) :
    (roughLargeCount z N : ℝ)
      ≤ euler * (EscLeanChecks.reducedBaseExceptionalCountGeTwo N (P N) : ℝ) :=
  roughLargeCount_le_euler_mul_reducedBase_of_sum z N P euler hPfac
    (reducedBaseQuotientSum_le_mul_of_pointwise_weight N P weight euler hpoint hweight)

/-- Canonical `zNatScale`/prime-product version of the rough-large quotient-sum
bridge.

This exposes the exact bridge used by the strongest certificate capstones: the
rough-large range at `z_N` is bounded by the concrete Euler multiplier times the
canonical reduced-base count once the explicit quotient-sum comparison is known.
The modulus support condition is discharged internally from
`natPrimeProductBelow_prime_factor_le` and monotonicity of `zNatScale`. -/
theorem roughLargeCount_zNatScale_le_eulerProductFactorAtNat_mul_reducedBase_of_sum
    (N : ℕ)
    (hsum : ((∑ s ∈ Finset.Icc 1 N,
        EscLeanChecks.reducedBaseExceptionalCountGeTwo
          (N / s) (natPrimeProductBelow (zNatScale (N / s)))) : ℝ)
      ≤ eulerProductFactorAtNat N *
        (EscLeanChecks.reducedBaseExceptionalCountGeTwo
          N (natPrimeProductBelow (zNatScale N)) : ℝ)) :
    (roughLargeCount (zNatScale N) N : ℝ) ≤
      eulerProductFactorAtNat N *
        (EscLeanChecks.reducedBaseExceptionalCountGeTwo
          N (natPrimeProductBelow (zNatScale N)) : ℝ) :=
  roughLargeCount_le_euler_mul_reducedBase_of_sum (zNatScale N) N
    (fun M => natPrimeProductBelow (zNatScale M)) (eulerProductFactorAtNat N)
    (fun M hMN p hp hdiv =>
      le_trans (natPrimeProductBelow_prime_factor_le (zNatScale M) p hp hdiv)
        (zNatScale_mono hMN))
    hsum

/-- Canonical `zNatScale` rough-large bridge from pointwise weighted quotient
fiber bounds. -/
theorem roughLargeCount_zNatScale_le_eulerProductFactorAtNat_mul_reducedBase_of_pointwise_weight
    (N : ℕ)
    (weight : ℕ → ℝ)
    (hpoint : ∀ s ∈ Finset.Icc 1 N,
      (EscLeanChecks.reducedBaseExceptionalCountGeTwo
        (N / s) (natPrimeProductBelow (zNatScale (N / s))) : ℝ)
        ≤ weight s *
          (EscLeanChecks.reducedBaseExceptionalCountGeTwo
            N (natPrimeProductBelow (zNatScale N)) : ℝ))
    (hweight : (∑ s ∈ Finset.Icc 1 N, weight s) ≤ eulerProductFactorAtNat N) :
    (roughLargeCount (zNatScale N) N : ℝ) ≤
      eulerProductFactorAtNat N *
        (EscLeanChecks.reducedBaseExceptionalCountGeTwo
          N (natPrimeProductBelow (zNatScale N)) : ℝ) :=
  roughLargeCount_le_euler_mul_reducedBase_of_pointwise_weight (zNatScale N) N
    (fun M => natPrimeProductBelow (zNatScale M)) (eulerProductFactorAtNat N)
    weight
    (fun M hMN p hp hdiv =>
      le_trans (natPrimeProductBelow_prime_factor_le (zNatScale M) p hp hdiv)
        (zNatScale_mono hMN))
    hpoint hweight


/-- Certificate-specialized capstone with the rough-large range discharged from
the explicit quotient-sum comparison over certified reduced-base counts.

Compared with `main_modulo_finite_transfer_cert_range_bounds`, this no longer
takes `roughLargeCount ≤ euler · Ered` as a primitive hypothesis.  The rough
count is first mapped into the certified reduced-base counts at scales `N / s`;
the only remaining rough-range analytic input is the displayed Euler comparison
for that concrete finite sum. -/
theorem main_modulo_finite_transfer_cert_range_bounds_of_reducedBase_sum
    (z P R : ℕ → ℕ)
    (cert : ∀ N : ℕ, EscLeanChecks.SatEventRankBudgetCertificate N (P N) (R N))
    (Pz μ εb : ℕ → ℝ)
    (Xpow nohit errTerm F2R : ℕ → ℕ → ℝ)
    (εK : ℝ)
    (Ered_c₁ : ℝ)
    (hc₁ : 0 < Ered_c₁)
    (hμ : ∀ N : ℕ, 3 ≤ N → 0 < μ N)
    (hPz : ∀ N : ℕ, 3 ≤ N → 1 ≤ Pz N)
    (hXpow : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N), 0 ≤ Xpow N b)
    (hεb : ∀ N : ℕ, 3 ≤ N → 0 ≤ εb N)
    (hdecomp : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        (certRankBudget P R cert N b : ℝ) ≤
          ((N : ℝ) / Pz N) * (nohit N b + F2R N b) + errTerm N b)
    (herr : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        errTerm N b ≤ Xpow N b * Real.exp ((1 + εK) * μ N))
    (hεle : εK ≤ 1)
    (hlevel : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        Pz N * Xpow N b * Real.exp (2 * μ N) ≤
          (N : ℝ) * Real.exp (-4 * μ N))
    (hF2R : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        F2R N b ≤ Real.exp (-3 * μ N))
    (hnohit : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        nohit N b ≤ Real.exp (-(1 - εb N) * μ N))
    (hcard : ∀ N : ℕ, 3 ≤ N →
      ((EscLeanChecks.reducedResiduesMod (P N)).card : ℝ) ≤ Pz N)

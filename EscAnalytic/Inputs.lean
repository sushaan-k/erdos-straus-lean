/-- The dyadic endpoint term is theorem-level normalized-small on every
positive dyadic range. -/
theorem RoughDyadicEndpointErrorUniformNormalizedSmallBoundOnPositiveRanges_unconditional :
    RoughDyadicEndpointErrorUniformNormalizedSmallBoundOnPositiveRanges := by
  intro a₀ b₀ C₀ eps ha₀ _hab heps
  rcases eventually_log_zScale_le_eps_mul_rpow ha₀ heps with ⟨Xgrowth, hgrowth⟩
  refine ⟨max Xgrowth (Real.exp 2), ?_⟩
  refine ⟨heps.le, ?_⟩
  intro X hX t htlo _hthi
  have hXgrowth : Xgrowth ≤ X := le_trans (le_max_left _ _) hX
  have hXexp2 : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 2) hXexp2
  have hlog_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp2
  have ht_pos : 0 < t := lt_of_lt_of_le (Real.rpow_pos_of_pos hXpos a₀) htlo
  have ht_nonneg : 0 ≤ t := ht_pos.le
  let T : ℝ := t / Real.log (EscAnalytic.zScale X)
  have hT_pos : 0 < T := div_pos ht_pos hlog_pos
  let D : ℝ :=
    roughDyadicBadPrimeProductMainTermSum X
      (roughBadPrimeProductMultiplesEndpointDelta t)
  have hD_abs : |D| ≤ 1 := by
    simpa [D] using
      abs_roughDyadicBadPrimeProductMultiplesEndpointErrorSum_le_one X ht_nonneg
  have hD_div : |D| / T ≤ 1 / T :=
    div_le_div_of_nonneg_right hD_abs hT_pos.le
  have hlog_le_eps_t :
      Real.log (EscAnalytic.zScale X) ≤ eps * t := by
    calc
      Real.log (EscAnalytic.zScale X)
          ≤ eps * X ^ a₀ := hgrowth X hXgrowth
      _ ≤ eps * t := mul_le_mul_of_nonneg_left htlo heps.le
  have hone_div_T :
      (1 : ℝ) / T = Real.log (EscAnalytic.zScale X) / t := by
    field_simp [T, ne_of_gt ht_pos, ne_of_gt hlog_pos]
  have hone_div_T_le : (1 : ℝ) / T ≤ eps := by
    rw [hone_div_T]
    exact (div_le_iff₀ ht_pos).mpr hlog_le_eps_t
  exact hD_div.trans hone_div_T_le


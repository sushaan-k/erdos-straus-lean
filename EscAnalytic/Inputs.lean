theorem smallDivisorEulerSum_mertensFree_with_carrier_bounds :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      0 ≤ Real.log (EscAnalytic.zScale X) ∧
        0 ≤ smallDivisorEulerSum X ∧
        c ≤ smallDivisorEulerSum X ∧
        smallDivisorEulerSum X ≤ C * Real.log (EscAnalytic.zScale X) ∧
        |smallDivisorEulerSum X| ≤ C * Real.log (EscAnalytic.zScale X) := by
  rcases smallDivisorEulerSum_lower_constant_unconditional with ⟨c, Xlower, hc, hlower⟩
  rcases smallDivisorEulerSum_upper_unconditional with ⟨C, Xupper, hC, hupper⟩
  refine ⟨c, C, max (max Xlower Xupper) (Real.exp 1), hc, hC, ?_⟩
  intro X hX
  have hXlower : Xlower ≤ X := le_trans (le_trans (le_max_left _ _) (le_max_left _ _)) hX
  have hXupper : Xupper ≤ X := le_trans (le_trans (le_max_right _ _) (le_max_left _ _)) hX
  have hXexp : Real.exp 1 ≤ X := le_trans (le_max_right _ _) hX

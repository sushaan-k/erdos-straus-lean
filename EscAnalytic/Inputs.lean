/-- The product-modulus upper bound is exactly an upper bound for the original
rough dyadic count after the finite inclusion-exclusion expansion is closed. -/
theorem roughDyadicCountUpperBound_of_badPrimeProductCountUpperBound
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicBadPrimeProductCountUpperBound a₀ b₀ C₀) :
    roughDyadicCountUpperBound a₀ b₀ C₀ := by
  rcases h with ⟨C, X₀, hC, hhi⟩
  refine ⟨C, X₀, hC, ?_⟩
  intro X hX M hM t htlo hthi
  calc
    roughDyadicCount X M t
        = roughDyadicBadPrimeSubsetProductCountSum X M t := by
          rw [← roughDyadicBadPrimeParitySum_eq_roughDyadicCount,
            roughDyadicBadPrimeParitySum_eq_productCountSum]
    _ ≤ C * (t / Real.log (EscAnalytic.zScale X)) :=
          hhi X hX M hM t htlo hthi

/-- Conversely, the original upper count target is exactly the upper bound for
the product-modulus inclusion-exclusion carrier. -/
theorem roughDyadicBadPrimeProductCountUpperBound_of_countUpperBound
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicCountUpperBound a₀ b₀ C₀) :
    roughDyadicBadPrimeProductCountUpperBound a₀ b₀ C₀ := by
  rcases h with ⟨C, X₀, hC, hhi⟩
  refine ⟨C, X₀, hC, ?_⟩
  intro X hX M hM t htlo hthi
  calc
    roughDyadicBadPrimeSubsetProductCountSum X M t
        = roughDyadicCount X M t := by
          rw [← roughDyadicBadPrimeParitySum_eq_productCountSum,
            roughDyadicBadPrimeParitySum_eq_roughDyadicCount]
    _ ≤ C * (t / Real.log (EscAnalytic.zScale X)) :=
          hhi X hX M hM t htlo hthi

/-- The upper half of the rough dyadic count primitive is equivalent to the
upper half of the explicit product-modulus inclusion-exclusion carrier. -/
theorem roughDyadicCountUpperBound_iff_badPrimeProductCountUpperBound
    (a₀ b₀ C₀ : ℝ) :
    roughDyadicCountUpperBound a₀ b₀ C₀ ↔
      roughDyadicBadPrimeProductCountUpperBound a₀ b₀ C₀ := by
  constructor
  · exact roughDyadicBadPrimeProductCountUpperBound_of_countUpperBound
  · exact roughDyadicCountUpperBound_of_badPrimeProductCountUpperBound

/-- Upper half of the explicit no-extra-modulus inclusion-exclusion carrier. -/
def roughDyadicBadPrimeProductCountModulusOneUpperBoundCore
    (a₀ b₀ : ℝ) : Prop :=
  ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
      roughDyadicBadPrimeSubsetProductCountSum X 1 t ≤
        C * (t / Real.log (EscAnalytic.zScale X))

/-- The modulus-one upper count core implies the corresponding explicit
inclusion-exclusion product-count upper core. -/

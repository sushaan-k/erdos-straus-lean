/-- A bare rough squarefree reciprocal estimate gives the carrier-bundled
version with checked logarithm positivity, nonnegativity, and absolute-value
side facts.  These extra fields are bookkeeping consequences of the finite
carrier, not additional sieve input. -/
theorem rough_sqf_recip_with_carrier_bounds_of_bound
    {a₀ b₀ c₁ C₀ : ℝ}
    (h :
      ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
        ∀ a b : ℝ, a₀ ≤ a → a < b → b ≤ b₀ → c₁ ≤ b - a →
          c * (Real.log X / Real.log (EscAnalytic.zScale X)) ≤ roughRecip X M a b
            ∧ roughRecip X M a b
                ≤ C * (Real.log X / Real.log (EscAnalytic.zScale X))) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ a b : ℝ, a₀ ≤ a → a < b → b ≤ b₀ → c₁ ≤ b - a →
        0 < Real.log X ∧
          0 < Real.log (EscAnalytic.zScale X) ∧
          0 < Real.log X / Real.log (EscAnalytic.zScale X) ∧
          0 ≤ roughRecip X M a b ∧
          c * (Real.log X / Real.log (EscAnalytic.zScale X)) ≤ roughRecip X M a b ∧
          roughRecip X M a b
              ≤ C * (Real.log X / Real.log (EscAnalytic.zScale X)) ∧
          |roughRecip X M a b|
              ≤ C * (Real.log X / Real.log (EscAnalytic.zScale X)) := by
  rcases h with ⟨c, C, Xbase, hc, hC, hrough⟩
  refine ⟨c, C, max Xbase (Real.exp 2), hc, hC, ?_⟩
  intro X hX M hM a b ha hab' hb hc₁
  have hXbase : Xbase ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 2) hXexp
  have hlogX_ge_two : (2 : ℝ) ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hXexp
  have hlogX_pos : 0 < Real.log X := lt_of_lt_of_le (by norm_num) hlogX_ge_two
  have hlogZ_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp
  have hshape_pos : 0 < Real.log X / Real.log (EscAnalytic.zScale X) :=
    div_pos hlogX_pos hlogZ_pos
  have hcarrier_nonneg : 0 ≤ roughRecip X M a b :=
    roughRecip_nonneg X M a b
  rcases hrough X hXbase M hM a b ha hab' hb hc₁ with ⟨hlower, hupper⟩
  exact ⟨hlogX_pos, hlogZ_pos, hshape_pos, hcarrier_nonneg, hlower, hupper, by
    rw [abs_of_nonneg hcarrier_nonneg]
    exact hupper⟩


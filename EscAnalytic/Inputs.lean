two-sided count estimate. -/
theorem linear_sieve_rough_dyadic_count_bound_of_carrier_bounds
    {a₀ b₀ C₀ : ℝ}
    (h :
      ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
        ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
          0 ≤ roughDyadicCount X M t ∧
            c * (t / Real.log (EscAnalytic.zScale X)) ≤ roughDyadicCount X M t ∧
            roughDyadicCount X M t
                ≤ C * (t / Real.log (EscAnalytic.zScale X)) ∧
            |roughDyadicCount X M t|
                ≤ C * (t / Real.log (EscAnalytic.zScale X))) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        c * (t / Real.log (EscAnalytic.zScale X)) ≤ roughDyadicCount X M t
          ∧ roughDyadicCount X M t
              ≤ C * (t / Real.log (EscAnalytic.zScale X)) := by
  rcases h with ⟨c, C, X₀, hc, hC, hcount⟩
  refine ⟨c, C, X₀, hc, hC, ?_⟩
  intro X hX M hM t htlo hthi
  have hpack := hcount X hX M hM t htlo hthi
  exact ⟨hpack.2.1, hpack.2.2.1⟩

/-- Bare and carrier-bundled dyadic linear-sieve count estimates are equivalent;
the side facts in the bundled version are finite-carrier bookkeeping. -/
theorem linear_sieve_rough_dyadic_count_bound_iff_carrier_bounds
    (a₀ b₀ C₀ : ℝ) :
    (∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        c * (t / Real.log (EscAnalytic.zScale X)) ≤ roughDyadicCount X M t
          ∧ roughDyadicCount X M t
              ≤ C * (t / Real.log (EscAnalytic.zScale X))) ↔
    (∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        0 ≤ roughDyadicCount X M t ∧
          c * (t / Real.log (EscAnalytic.zScale X)) ≤ roughDyadicCount X M t ∧
          roughDyadicCount X M t
              ≤ C * (t / Real.log (EscAnalytic.zScale X)) ∧
          |roughDyadicCount X M t|
              ≤ C * (t / Real.log (EscAnalytic.zScale X))) := by
  constructor
  · exact linear_sieve_rough_dyadic_with_carrier_bounds_of_count_bound
  · exact linear_sieve_rough_dyadic_count_bound_of_carrier_bounds

/-- Count-level linear-sieve input bundled with the logarithm positivity needed
by reciprocal conversions.  The analytic content is unchanged from
`linear_sieve_rough_dyadic_with_carrier_bounds`; the larger threshold only
ensures `log z(X) > 0`. -/
theorem linear_sieve_rough_dyadic_with_log_carrier_bounds
    (a₀ b₀ C₀ : ℝ) (ha₀ : 0 < a₀) (hab : a₀ < b₀) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        0 < Real.log (EscAnalytic.zScale X) ∧
          0 ≤ roughDyadicCount X M t ∧
          c * (t / Real.log (EscAnalytic.zScale X)) ≤ roughDyadicCount X M t ∧
          roughDyadicCount X M t
              ≤ C * (t / Real.log (EscAnalytic.zScale X)) ∧
          |roughDyadicCount X M t|
              ≤ C * (t / Real.log (EscAnalytic.zScale X)) := by
  rcases linear_sieve_rough_dyadic_with_carrier_bounds a₀ b₀ C₀ ha₀ hab with
    ⟨c, C, Xbase, hc, hC, hcount⟩
  refine ⟨c, C, max Xbase (Real.exp 2), hc, hC, ?_⟩
  intro X hX M hM t htlo hthi
  have hXbase : Xbase ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 2) hXexp
  have hlogX_ge_two : (2 : ℝ) ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hXexp
  have hloglog_pos : 0 < Real.log (Real.log X) :=
    Real.log_pos (lt_of_lt_of_le one_lt_two hlogX_ge_two)
  have hlogZ_eq :
      Real.log (EscAnalytic.zScale X) = 4 * Real.log (Real.log X) := by
    unfold EscAnalytic.zScale
    rw [Real.log_pow]
    ring
  have hlogZ_pos : 0 < Real.log (EscAnalytic.zScale X) := by
    rw [hlogZ_eq]
    positivity
  exact ⟨hlogZ_pos, hcount X hXbase M hM t htlo hthi⟩

/-- A bare two-sided dyadic count estimate also gives the log-carrier package;
the extra logarithm positivity is supplied by increasing the threshold to
`X ≥ exp 2`. -/
theorem linear_sieve_rough_dyadic_with_log_carrier_bounds_of_count_bound
    {a₀ b₀ C₀ : ℝ}
    (h :
      ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
        ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →

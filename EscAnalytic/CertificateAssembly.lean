/-- Transfer-path capstone with the finite rank-budget certificates constructed
from large-prime admissible event data.

Compared with
`main_modulo_finite_transfer_cert_range_bounds_of_budget_decomp`, this removes
the certificate-object hypothesis.  The finite side now consists of explicit
event families, signed rank-budget bounds, admissibility data, and the total
budget inequality; the analytic side remains the split main/error comparison
used by the transfer theorem. -/
theorem main_modulo_finite_transfer_admissible_largePrime_uniform_cert_range_bounds_of_budget_decomp
    (z P R r s : ℕ → ℕ)
    (rhoOf : ℕ → ℕ → ℕ)
    (eventsByBase : ℕ → ℕ → Finset EscLeanChecks.SatEvent)
    (B : ℕ → ℕ → ℕ → ℚ)
    (hPcert : ∀ N : ℕ, 1 < P N)
    (hr : ∀ N : ℕ, 0 < r N)
    (hs : ∀ N : ℕ, 0 < s N)
    (hrank : ∀ N : ℕ,
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        ∀ k ∈ Finset.range (2 * R N + 1),
          (((-1 : Int) ^ k) *
            ((∑ t ∈ (eventsByBase N b).powersetCard k,
                EscLeanChecks.baseSatEventCommonHitCountUpTo
                  N (P N) b t : ℕ) : Int) : ℚ) ≤
              B N b k)
    (hadm : ∀ N : ℕ,
      ∀ b event, event ∈ eventsByBase N b →
        EscLeanChecks.satEventAdmissibleFor (P N) (rhoOf N) event)
    (hrho : ∀ N : ℕ,
      ∀ b event, event ∈ eventsByBase N b →
        rhoOf N event.e = r N * s N)
    (hevent : ∀ N : ℕ,
      ∀ b event, event ∈ eventsByBase N b →
        event.e = r N * s N ^ 2)
    (hlargeBase : ∀ N : ℕ,
      ∀ b event, event ∈ eventsByBase N b →
        P N < event.p)
    (hbase : ∀ N : ℕ,
      ∀ b event, event ∈ eventsByBase N b →
        b + 4 * event.e ≡ 0 [MOD event.dMinus])
    (hcert_budget : ∀ N : ℕ,
      (∑ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        ∑ k ∈ Finset.range (2 * R N + 1), B N b k) < 1)
    (Pz μ εb : ℕ → ℝ)
    (Xpow nohit errTerm F2R : ℕ → ℕ → ℝ)
    (mainQ errQ : ℕ → ℕ → ℚ)
    (εK : ℝ)
    (Ered_c₁ : ℝ)
    (hc₁ : 0 < Ered_c₁)
    (hμ : ∀ N : ℕ, 3 ≤ N → 0 < μ N)
    (hPz : ∀ N : ℕ, 3 ≤ N → 1 ≤ Pz N)
    (hPz_ge_modulus : ∀ N : ℕ, 3 ≤ N → (P N : ℝ) ≤ Pz N)
    (hXpow : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N), 0 ≤ Xpow N b)
    (hεb : ∀ N : ℕ, 3 ≤ N → 0 ≤ εb N)
    (hbudget_decomp : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        (∑ k ∈ Finset.range (2 * R N + 1), B N b k) ≤ mainQ N b + errQ N b)
    (hmain_real : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        (mainQ N b : ℝ) ≤ ((N : ℝ) / Pz N) * (nohit N b + F2R N b))
    (herr_real : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        (errQ N b : ℝ) ≤ errTerm N b)
    (herr : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        errTerm N b ≤ Xpow N b * Real.exp ((1 + εK) * μ N))
    (hεle : εK ≤ 1)
    (hlevel : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        Pz N * Xpow N b * Real.exp (2 * μ N) ≤
          (N : ℝ) * Real.exp (-4 * μ N))
    (hF2R : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        F2R N b ≤ Real.exp (-3 * μ N))
    (hnohit : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        nohit N b ≤ Real.exp (-(1 - εb N) * μ N))
    (hsaving : ∀ N : ℕ, 3 ≤ N →
      Ered_c₁ * (Real.log N) ^ ((3 : ℝ) / 4) ≤
        (1 - (εb N + Real.log 3 / μ N)) * μ N)
    (smooth : ℕ → ℝ) (smoothExp smoothC : ℝ)
    (hse_pos : 0 < smoothExp) (hse_lt : smoothExp < 1) (hsC : 0 < smoothC)
    (hsmooth : ∀ N : ℕ, 3 ≤ N → smooth N ≤ smoothC * (N : ℝ) ^ smoothExp)
    (hsmooth_nn : ∀ N : ℕ, 0 ≤ smooth N)
    (hsmooth_range : ∀ N : ℕ, 3 ≤ N →

/-- Exact-density conditional form of the odd-divisor Euler lower bound.

If the totient-weighted odd-squarefree carrier captures a fixed positive
proportion of the exact odd-squarefree reciprocal carrier on dyadic cutoffs,
then the downstream Euler carrier has the required logarithmic lower bound.
All dyadic interpolation and finite-support transport is checked here. -/
theorem smallDivisorEulerSum_lower_bound_of_oddSquarefreeTotientNat_recip_density
    (hdensity : ∃ δ > (0 : ℝ), ∀ k : ℕ, 2 ≤ k →
      δ * oddSquarefreeRecipNat (2 ^ k)
        ≤ oddSquarefreeTotientNat (2 ^ k)) :
    ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.zScale X) ≤ smallDivisorEulerSum X := by
  have hdy :
      ∃ c > (0 : ℝ), ∀ k : ℕ, 2 ≤ k →
        c * Real.log ((2 ^ k : ℕ) : ℝ)
          ≤ ∑ d ∈ oddSquarefreeEulerWitnessNat (2 ^ k),
              (Nat.totient d : ℝ) / (d : ℝ) ^ 2 := by
    simpa [oddSquarefreeTotientNat] using
      smallDivisorEulerSum_oddSquarefreeWitnessNat_dyadic_lower_bound_of_oddSquarefreeRecipNat_comparison
        hdensity
  rcases smallDivisorEulerSum_oddSquarefreeWitness_lower_bound_of_dyadic hdy with
    ⟨c, X₀, hc, hwitness⟩
  refine ⟨c, max X₀ (Real.exp 1), hc, ?_⟩
  intro X hX
  have hX₀ : X₀ ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 1 ≤ X := le_trans (le_max_right _ _) hX
  exact (hwitness X hX₀).trans
    (smallDivisorEulerSum_ge_oddSquarefreeWitness X
      (zScale_ge_one_of_exp_one_le hXexp))

/-- Carrier-bundled version of
`smallDivisorEulerSum_lower_bound_of_oddSquarefreeTotientNat_recip_density`.
The upper bound and side conditions are unconditional finite-carrier facts. -/
theorem smallDivisorEulerSum_two_sided_from_oddSquarefreeTotientNat_recip_density
    (hdensity : ∃ δ > (0 : ℝ), ∀ k : ℕ, 2 ≤ k →
      δ * oddSquarefreeRecipNat (2 ^ k)
        ≤ oddSquarefreeTotientNat (2 ^ k)) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      0 ≤ Real.log (EscAnalytic.zScale X) ∧
        0 ≤ smallDivisorEulerSum X ∧
        c * Real.log (EscAnalytic.zScale X) ≤ smallDivisorEulerSum X ∧
        smallDivisorEulerSum X ≤ C * Real.log (EscAnalytic.zScale X) ∧
        |smallDivisorEulerSum X| ≤ C * Real.log (EscAnalytic.zScale X) :=
  smallDivisorEulerSum_lower_bound_with_carrier_bounds_of_lower_bound
    (smallDivisorEulerSum_lower_bound_of_oddSquarefreeTotientNat_recip_density hdensity)

/-- Lower half of the logarithmic small-divisor Euler-sum estimate. -/
def smallDivisorEulerSumLogLowerBound : Prop :=
  ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
    c * Real.log (EscAnalytic.zScale X) ≤ smallDivisorEulerSum X

/-- Upper half of the logarithmic small-divisor Euler-sum estimate. -/
def smallDivisorEulerSumLogUpperBound : Prop :=
  ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
    smallDivisorEulerSum X ≤ C * Real.log (EscAnalytic.zScale X)

/-- The two-sided logarithmic small-divisor Euler estimate is exactly its lower
and upper halves. -/
theorem smallDivisorEulerSum_log_bounds_iff_lower_upper :
    (∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.zScale X) ≤ smallDivisorEulerSum X ∧
        smallDivisorEulerSum X ≤ C * Real.log (EscAnalytic.zScale X)) ↔
      smallDivisorEulerSumLogLowerBound ∧
        smallDivisorEulerSumLogUpperBound := by
  constructor
  · rintro ⟨c, C, X₀, hc, hC, h⟩
    refine ⟨⟨c, X₀, hc, ?_⟩, ⟨C, X₀, hC, ?_⟩⟩
    · intro X hX
      exact (h X hX).1
    · intro X hX
      exact (h X hX).2
  · rintro ⟨⟨c, Xlo, hc, hlo⟩, ⟨C, Xhi, hC, hhi⟩⟩
    refine ⟨c, C, max Xlo Xhi, hc, hC, ?_⟩
    intro X hX
    have hXlo : Xlo ≤ X := le_trans (le_max_left _ _) hX
    have hXhi : Xhi ≤ X := le_trans (le_max_right _ _) hX
    exact ⟨hlo X hXlo, hhi X hXhi⟩

/-- The exact odd-squarefree totient-density input supplies the split
lower/upper logarithmic Euler-sum target.  The upper half is unconditional
finite-carrier algebra; only the lower half uses the density hypothesis. -/
theorem smallDivisorEulerSum_log_lower_upper_of_oddSquarefreeTotientNat_recip_density
    (hdensity : ∃ δ > (0 : ℝ), ∀ k : ℕ, 2 ≤ k →
      δ * oddSquarefreeRecipNat (2 ^ k)
        ≤ oddSquarefreeTotientNat (2 ^ k)) :
    smallDivisorEulerSumLogLowerBound ∧
      smallDivisorEulerSumLogUpperBound := by
  rcases smallDivisorEulerSum_two_sided_from_oddSquarefreeTotientNat_recip_density
    hdensity with ⟨c, C, X₀, hc, hC, h⟩
  exact smallDivisorEulerSum_log_bounds_iff_lower_upper.mp
    ⟨c, C, X₀, hc, hC, fun X hX =>
      ⟨(h X hX).2.2.1, (h X hX).2.2.2.1⟩⟩

/-- Conditional lower half of the small-divisor average from the exact
odd-squarefree totient-density input.  This theorem keeps the genuine
Mertens/density content explicit; the coprime reciprocal estimate and all
summation algebra are supplied by checked theorem-level code. -/
theorem smallDivisorAverage_lower_from_oddSquarefreeTotientNat_recip_density
    (P : EscAnalytic.Params)
    (hdensity : ∃ δ > (0 : ℝ), ∀ k : ℕ, 2 ≤ k →
      δ * oddSquarefreeRecipNat (2 ^ k)
        ≤ oddSquarefreeTotientNat (2 ^ k)) :
    ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X)
        ≤ smallDivisorAverage P X := by
  rcases sAvgRecipCoprime_two_sided_from_standard_input_with_carrier_bounds P with
    ⟨cS, _CS, XS, hcS, _hCS, hcopPack⟩
  exact smallDivisorAverage_lower_from_coprime_and_euler_bound P cS XS hcS
    (fun X hX d hd => ((hcopPack X hX).2 d hd).2.2.1)
    (smallDivisorEulerSum_lower_bound_of_oddSquarefreeTotientNat_recip_density hdensity)

/-- Conditional two-sided small-divisor average from exact odd-squarefree
totient density.  The upper bound is unconditional; only the lower density input
is explicit. -/
theorem smallDivisorAverage_two_sided_from_oddSquarefreeTotientNat_recip_density
    (P : EscAnalytic.Params)
    (hdensity : ∃ δ > (0 : ℝ), ∀ k : ℕ, 2 ≤ k →
      δ * oddSquarefreeRecipNat (2 ^ k)
        ≤ oddSquarefreeTotientNat (2 ^ k)) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X)
        ≤ smallDivisorAverage P X ∧
      smallDivisorAverage P X
        ≤ C * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X) := by
  rcases smallDivisorAverage_lower_from_oddSquarefreeTotientNat_recip_density
      P hdensity with
    ⟨c, Xlow, hc, hlow⟩
  rcases smallDivisorAverage_upper_unconditional P with ⟨C, Xup, hC, hup⟩
  refine ⟨c, C, max Xlow Xup, hc, hC, ?_⟩
  intro X hX
  have hXlow : Xlow ≤ X := le_trans (le_max_left _ _) hX
  have hXup : Xup ≤ X := le_trans (le_max_right _ _) hX
  exact ⟨hlow X hXlow, hup X hXup⟩

/-- Carrier-bundled absolute-value form of the conditional two-sided
small-divisor average from exact odd-squarefree totient density. -/
theorem smallDivisorAverage_two_sided_from_oddSquarefreeTotientNat_recip_density_with_abs_carrier_bounds
    (P : EscAnalytic.Params)
    (hdensity : ∃ δ > (0 : ℝ), ∀ k : ℕ, 2 ≤ k →
      δ * oddSquarefreeRecipNat (2 ^ k)
        ≤ oddSquarefreeTotientNat (2 ^ k)) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      0 ≤ Real.log (EscAnalytic.SScale P X) ∧
        0 ≤ Real.log (EscAnalytic.zScale X) ∧
        0 ≤ smallDivisorAverage P X ∧
        c * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X)

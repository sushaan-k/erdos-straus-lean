    (εK : ℝ)
    (Ered : ℕ → ℕ) (Ered_c₁ : ℝ) (T : ℕ)
    (hc₁ : 0 < Ered_c₁)
    (hEred_sum : ∀ N : ℕ, 3 ≤ N →
      (Ered N : ℝ) ≤ ∑ b ∈ cls N, Mb N b)

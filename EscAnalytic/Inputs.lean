/-- Quarter-budget interface for the signed squarefree-loss component of the
no-extra-modulus rough dyadic product-error term.  This is the live
cancellation-aware replacement for the obstructed absolute squarefree-loss
envelope. -/
def LinearSieveRoughDyadicSquarefreeSignedLossQuarterBound : Prop :=
  ∀ (a₀ b₀ C₀ c Xprod : ℝ), 0 < c →
    (∀ X : ℝ, Xprod ≤ X →
      c / Real.log (EscAnalytic.zScale X) ≤
        roughDyadicBadPrimeMainEulerProduct X) →
    ∃ Xl Xu : ℝ,
      roughDyadicBadPrimeProductSquarefreeSignedLossLowerBoundModulusOne
        a₀ b₀ C₀ (c / 4) Xl ∧
      roughDyadicBadPrimeProductSquarefreeSignedLossUpperBoundModulusOne
        a₀ b₀ C₀ (c / 4) Xu

/-- Upper half of the signed squarefree quarter-budget interface.  The lower
half is theorem-level from finite inclusion-exclusion nonnegativity, so this is
the only remaining squarefree analytic input needed by the live route. -/
def LinearSieveRoughDyadicSquarefreeSignedLossUpperQuarterBound : Prop :=
  ∀ (a₀ b₀ C₀ c Xprod : ℝ), 0 < c →
    (∀ X : ℝ, Xprod ≤ X →
      c / Real.log (EscAnalytic.zScale X) ≤
        roughDyadicBadPrimeMainEulerProduct X) →
    ∃ Xu : ℝ,
      roughDyadicBadPrimeProductSquarefreeSignedLossUpperBoundModulusOne
        a₀ b₀ C₀ (c / 4) Xu

/-- Upper quarter-budget interface for the concrete large-square divisor tail.
The finite carrier bridge proves that this is sufficient for the signed
squarefree-loss upper input. -/
def LinearSieveRoughDyadicLargeSquareTailUpperQuarterBound : Prop :=
  ∀ (a₀ b₀ C₀ c Xprod : ℝ), 0 < c →
    (∀ X : ℝ, Xprod ≤ X →
      c / Real.log (EscAnalytic.zScale X) ≤
        roughDyadicBadPrimeMainEulerProduct X) →
    ∃ Xu : ℝ,
      roughDyadicLargeSquareDivisorUpperBoundModulusOne
        a₀ b₀ C₀ (c / 4) Xu

/-- Upper quarter-budget interface for the explicit finite large-square
prime-tail envelope.  This is sharper than bounding the existential count
directly and is now the exported squarefree-tail analytic primitive. -/
def LinearSieveRoughDyadicLargeSquareTailEnvelopeUpperQuarterBound : Prop :=
  ∀ (a₀ b₀ C₀ c Xprod : ℝ), 0 < c →
    (∀ X : ℝ, Xprod ≤ X →
      c / Real.log (EscAnalytic.zScale X) ≤
        roughDyadicBadPrimeMainEulerProduct X) →
    ∃ Xu : ℝ,
      roughDyadicLargeSquareDivisorEnvelopeUpperBoundModulusOne
        a₀ b₀ C₀ (c / 4) Xu

/-- Upper quarter-budget interface for the explicit floor-division large-square
prime-tail envelope. -/
def LinearSieveRoughDyadicLargeSquareTailFloorEnvelopeUpperQuarterBound : Prop :=
  ∀ (a₀ b₀ C₀ c Xprod : ℝ), 0 < c →
    (∀ X : ℝ, Xprod ≤ X →
      c / Real.log (EscAnalytic.zScale X) ≤
        roughDyadicBadPrimeMainEulerProduct X) →
    ∃ Xu : ℝ,
      roughDyadicLargeSquareDivisorFloorEnvelopeUpperBoundModulusOne
        a₀ b₀ C₀ (c / 4) Xu

/-- Upper quarter-budget interface for the reciprocal-prime-square large-square
prime-tail envelope. -/
def LinearSieveRoughDyadicLargeSquareTailReciprocalEnvelopeUpperQuarterBound : Prop :=
  ∀ (a₀ b₀ C₀ c Xprod : ℝ), 0 < c →
    (∀ X : ℝ, Xprod ≤ X →
      c / Real.log (EscAnalytic.zScale X) ≤
        roughDyadicBadPrimeMainEulerProduct X) →
    ∃ Xu : ℝ,
      roughDyadicLargeSquareDivisorReciprocalEnvelopeUpperBoundModulusOne

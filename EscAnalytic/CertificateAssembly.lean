  main_modulo_reducedBase_certified_rough_zero_range_bounds z P R
    (fun N M =>
      satEventRankBudgetCertificateOfAdmissibleForLargePrimeUniform
        M (P N M) (R N M) (r N M) (s N M) (rhoOf N M)
        (eventsByBase N M) (B N M)
        (hP N M) (hr N M) (hs N M)
        (hrank N M) (hadm N M) (hrho N M) (hevent N M)

/-- Conditional dominated component-envelope package for the rough dyadic
product-error term.  The unconditional lower count route no longer uses this
full auxiliary-prime floor envelope; it is retained as a reduction for callers
that explicitly provide that stronger auxiliary package. -/
theorem linear_sieve_rough_dyadic_product_error_components_dominated_bound
    (hmult : LinearSieveRoughDyadicMultiplesErrorQuarterBound)
    (hsqf : LinearSieveRoughDyadicSquarefreeLossQuarterBound)
    (a₀ b₀ C₀ c Xprod : ℝ) (hc : 0 < c)
    (hprod : ∀ X : ℝ, Xprod ≤ X →
      c / Real.log (EscAnalytic.zScale X) ≤
        roughDyadicBadPrimeMainEulerProduct X)
    (haux :
      ∃ Xa : ℝ,
        roughDyadicBadPrimeProductAuxiliaryPrimeMultiplesFloorEnvelopeBound
          a₀ b₀ C₀ (c / 4) Xa) :
    ∃ Em Es Ea Xm Xs Xa : ℝ, Em + (Es + Ea) < c ∧
      roughDyadicBadPrimeProductMultiplesLocalErrorEnvelopeBound
        a₀ b₀ C₀ Em Xm ∧
      roughDyadicBadPrimeProductSquarefreeLossEnvelopeBound
        a₀ b₀ C₀ Es Xs ∧
      roughDyadicBadPrimeProductAuxiliaryPrimeMultiplesFloorEnvelopeBound
        a₀ b₀ C₀ Ea Xa := by
  rcases
    hmult a₀ b₀ C₀ c Xprod hc hprod with
    ⟨Xm, hm⟩
  rcases
    hsqf a₀ b₀ C₀ c Xprod hc hprod with
    ⟨Xs, hs⟩
  rcases haux with ⟨Xa, ha⟩
  refine ⟨c / 4, c / 4, c / 4, Xm, Xs, Xa, ?_, hm, hs, ha⟩
  linarith

/-- Conditional one-sided dominated lower product-error input, derived from the
component-envelope reduction and the checked finite-error decomposition. -/
theorem linear_sieve_rough_dyadic_product_error_lower_dominated_bound
    (hmult : LinearSieveRoughDyadicMultiplesErrorQuarterBound)
    (hsqf : LinearSieveRoughDyadicSquarefreeLossQuarterBound)
    (a₀ b₀ C₀ c Xprod : ℝ) (hc : 0 < c)
    (hprod : ∀ X : ℝ, Xprod ≤ X →
      c / Real.log (EscAnalytic.zScale X) ≤
        roughDyadicBadPrimeMainEulerProduct X)
    (haux :
      ∃ Xa : ℝ,
        roughDyadicBadPrimeProductAuxiliaryPrimeMultiplesFloorEnvelopeBound
          a₀ b₀ C₀ (c / 4) Xa) :
    ∃ E Xerr : ℝ, E < c ∧
      roughDyadicBadPrimeProductErrorLowerBound a₀ b₀ C₀ E Xerr := by
  rcases
    linear_sieve_rough_dyadic_product_error_components_dominated_bound
      hmult hsqf a₀ b₀ C₀ c Xprod hc hprod haux with
    ⟨Em, Es, Ea, Xm, Xs, Xa, hE_lt, hm, hs, ha⟩
  refine ⟨Em + (Es + Ea), max Xm (max Xs Xa), hE_lt, ?_⟩
  exact
    roughDyadicBadPrimeProductErrorLowerBound_of_errorBound
      (roughDyadicBadPrimeProductErrorBound_of_multiples_squarefree_auxiliaryPrimeMultiplesFloorEnvelope
        hm hs ha)

/-- Conditional lower-side linear-sieve input at Euler-product/error altitude.
The unconditional lower count theorem below uses the tail-transfer route
instead; this theorem records the older Euler/error reduction for callers that
explicitly provide the full auxiliary-prime floor envelope. -/

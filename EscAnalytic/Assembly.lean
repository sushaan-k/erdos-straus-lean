    (∀ N : ℕ, 3 ≤ N → H.T ≤ N → ∀ b ∈ H.cls N,
      H.F2R N b ≤ Real.exp (-3 * H.μ N)) ∧
    (∀ N : ℕ, 3 ≤ N → H.T ≤ N → ∀ b ∈ H.cls N,
      H.Mb N b ≤ ((N : ℝ) / H.Pz N) *
        Real.exp (-(1 - (H.εb N + Real.log 3 / H.μ N)) * H.μ N)) ∧
    (∀ N : ℕ, 3 ≤ N → H.Tred ≤ N →

              ≤ C * (t / Real.log (EscAnalytic.zScale X)) ∧
          |roughDyadicCount X M t|
              ≤ C * (t / Real.log (EscAnalytic.zScale X)) := by
  rcases linear_sieve_rough_dyadic_with_carrier_bounds_of_count_bound h with
    ⟨c, C, Xbase, hc, hC, hcount⟩
  refine ⟨c, C, max Xbase (Real.exp 2), hc, hC, ?_⟩
  intro X hX M hM t htlo hthi
  have hXbase : Xbase ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  exact ⟨log_zScale_pos_of_exp_two_le hXexp, hcount X hXbase M hM t htlo hthi⟩

/-- Forgetting the logarithm-positivity and carrier side facts in the log-carrier
package recovers the bare dyadic count estimate. -/
theorem linear_sieve_rough_dyadic_count_bound_of_log_carrier_bounds
    {a₀ b₀ C₀ : ℝ}

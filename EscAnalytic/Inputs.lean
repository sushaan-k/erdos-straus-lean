/-- The small-divisor dual bound holds unconditionally. -/
theorem roughDyadicBadPrimeMainEulerProductSmallDivisorDualBound_unconditional :
    roughDyadicBadPrimeMainEulerProductSmallDivisorDualBound := by
  refine ⟨0, ?_⟩
  intro X _hX
  have hprod_nonneg := roughDyadicBadPrimeMainEulerProduct_nonneg X
  calc
    roughDyadicBadPrimeMainEulerProduct X * smallDivisorEulerSum X
        ≤ roughDyadicBadPrimeMainEulerProduct X *
            (∑ d ∈ (roughModulus X).divisors, (1 : ℝ) / (d : ℝ)) :=
          mul_le_mul_of_nonneg_left
            (smallDivisorEulerSum_le_roughModulus_divisor_recip_sum X)
            hprod_nonneg
    _ ≤ 1 := roughDyadicBadPrimeMainEulerProduct_mul_divisor_recip_sum_le_one X

/-- The small-divisor dual inequality proves the upper Mertens half of the
finite rough Euler product.  The logarithmic lower growth of
`smallDivisorEulerSum` is already unconditional, so this theorem isolates the
remaining finite product-sum comparison exactly. -/
theorem roughDyadicBadPrimeMainEulerProductUpperBound_of_smallDivisorDual
    (hdual : roughDyadicBadPrimeMainEulerProductSmallDivisorDualBound) :
    roughDyadicBadPrimeMainEulerProductUpperBound := by
  rcases hdual with ⟨Xdual, hdual⟩
  rcases smallDivisorEulerSum_lower_bound with ⟨c, Xlow, hc, hlow⟩
  refine ⟨c⁻¹, max (max Xdual Xlow) (Real.exp 2), inv_pos.mpr hc, ?_⟩
  intro X hX
  have hXdual : Xdual ≤ X := le_trans (le_max_left _ _)
    (le_trans (le_max_left _ _) hX)
  have hXlow : Xlow ≤ X := le_trans (le_max_right _ _)
    (le_trans (le_max_left _ _) hX)
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hlog_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp
  have hprod_nonneg : 0 ≤ roughDyadicBadPrimeMainEulerProduct X :=
    roughDyadicBadPrimeMainEulerProduct_nonneg X
  have hsmall_lower :
      c * Real.log (EscAnalytic.zScale X) ≤ smallDivisorEulerSum X :=
    hlow X hXlow
  have hmul_lower :
      roughDyadicBadPrimeMainEulerProduct X *
          (c * Real.log (EscAnalytic.zScale X)) ≤
        roughDyadicBadPrimeMainEulerProduct X * smallDivisorEulerSum X :=
    mul_le_mul_of_nonneg_left hsmall_lower hprod_nonneg
  have hmul_one :
      roughDyadicBadPrimeMainEulerProduct X *
          (c * Real.log (EscAnalytic.zScale X)) ≤ 1 :=
    hmul_lower.trans (hdual X hXdual)
  have hden_pos : 0 < c * Real.log (EscAnalytic.zScale X) :=
    mul_pos hc hlog_pos
  calc
    roughDyadicBadPrimeMainEulerProduct X
        = (roughDyadicBadPrimeMainEulerProduct X *
            (c * Real.log (EscAnalytic.zScale X))) /
            (c * Real.log (EscAnalytic.zScale X)) := by
              field_simp [ne_of_gt hden_pos]
    _ ≤ 1 / (c * Real.log (EscAnalytic.zScale X)) :=
          div_le_div_of_nonneg_right hmul_one hden_pos.le
    _ = c⁻¹ / Real.log (EscAnalytic.zScale X) := by
          field_simp [ne_of_gt hc, ne_of_gt hlog_pos]

/-- Unconditional upper Mertens half for the finite rough Euler product. -/
theorem roughDyadicBadPrimeMainEulerProductUpperBound_unconditional :
    roughDyadicBadPrimeMainEulerProductUpperBound :=
  roughDyadicBadPrimeMainEulerProductUpperBound_of_smallDivisorDual
    roughDyadicBadPrimeMainEulerProductSmallDivisorDualBound_unconditional

/-- Exact finite-error bound for the signed product-modulus expansion.  The
constant is left visible so it can be compared with the product lower constant
in the separated target below. -/
def roughDyadicBadPrimeProductErrorBound
    (a₀ b₀ C₀ E X₀ : ℝ) : Prop :=
  0 ≤ E ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
      |roughDyadicBadPrimeProductErrorSum X M t| ≤
        E * (t / Real.log (EscAnalytic.zScale X))

/-- One-sided lower control for the signed product-modulus error.  This is the
exact error information needed for the lower rough-count half; it is weaker
than an absolute-value error bound. -/
def roughDyadicBadPrimeProductErrorLowerBound
    (a₀ b₀ C₀ E X₀ : ℝ) : Prop :=
  0 ≤ E ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
      - (E * (t / Real.log (EscAnalytic.zScale X))) ≤
        roughDyadicBadPrimeProductErrorSum X M t

/-- An absolute exact-error estimate implies the one-sided lower error
estimate needed for the lower half. -/
theorem roughDyadicBadPrimeProductErrorLowerBound_of_errorBound
    {a₀ b₀ C₀ E X₀ : ℝ}
    (h : roughDyadicBadPrimeProductErrorBound a₀ b₀ C₀ E X₀) :
    roughDyadicBadPrimeProductErrorLowerBound a₀ b₀ C₀ E X₀ := by
  rcases h with ⟨hE_nonneg, h⟩
  refine ⟨hE_nonneg, ?_⟩
  intro X hX M hM t htlo hthi
  have habs := h X hX M hM t htlo hthi
  exact (neg_le_neg habs).trans (neg_abs_le _)


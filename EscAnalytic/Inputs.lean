  have hc_quarter : 0 < c / 4 := by positivity
  have hprod_quarter :
      ∀ X : ℝ, Xprod' ≤ X →
        (c / 4) / Real.log (EscAnalytic.zScale X) ≤
          roughDyadicBadPrimeMainEulerProduct X := by
    intro X hX
    have hXprod : Xprod ≤ X := le_trans (le_max_left _ _) hX

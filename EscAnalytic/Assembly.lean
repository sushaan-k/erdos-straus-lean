/-- Concrete small optimization parameter determined by the level-budget
constant.

The definition is deliberately total in `Cp`: when `2 + Cp < 1`, taking
`α = 1` already makes `(2 + Cp) α^4 ≤ 1`; otherwise the reciprocal choice is
small enough. -/
noncomputable def optimizationSmallAlpha (Cp : ℝ) : ℝ :=
  if 1 ≤ 2 + Cp then (2 + Cp)⁻¹ else 1

/-- The concrete optimization parameter always satisfies the smallness
condition consumed by `finite_level_condition_of_optimization`. -/
theorem optimizationSmallAlpha_small (Cp : ℝ) :
    (2 + Cp) * (optimizationSmallAlpha Cp) ^ 4 ≤ 1 := by
  unfold optimizationSmallAlpha
  by_cases hA : 1 ≤ 2 + Cp
  · simp [hA]
    have hApos : 0 < 2 + Cp := lt_of_lt_of_le zero_lt_one hA
    have hA3 : 1 ≤ (2 + Cp) ^ 3 := one_le_pow₀ hA
    calc
      (2 + Cp) * ((2 + Cp) ^ 4)⁻¹ = ((2 + Cp) ^ 3)⁻¹ := by
        field_simp [hApos.ne']
        ring
      _ ≤ 1 := inv_le_one_of_one_le₀ hA3
  · simp [hA]
    have hAle : 2 + Cp ≤ 1 := le_of_not_ge hA
    nlinarith

/-- The canonical optimization parameter is nonnegative for every `Cp`. -/
theorem optimizationSmallAlpha_nonneg (Cp : ℝ) :
    0 ≤ optimizationSmallAlpha Cp := by
  unfold optimizationSmallAlpha
  by_cases hA : 1 ≤ 2 + Cp
  · simp [hA]
    exact le_trans (by norm_num : (0 : ℝ) ≤ 1) hA
  · simp [hA]

/-- The canonical optimization parameter is strictly positive for every `Cp`. -/
theorem optimizationSmallAlpha_pos (Cp : ℝ) :
    0 < optimizationSmallAlpha Cp := by
  unfold optimizationSmallAlpha
  by_cases hA : 1 ≤ 2 + Cp
  · simp [hA]
    exact lt_of_lt_of_le zero_lt_one hA
  · simp [hA]

/-- Eventually the canonical logarithmic level has logarithm at least one. -/
theorem eventually_one_le_optimizationSmallAlpha_log_quarter (Cp : ℝ) :
    ∀ᶠ N : ℕ in Filter.atTop,
      1 ≤ optimizationSmallAlpha Cp * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4) := by
  have hlog :
      Filter.Tendsto (fun N : ℕ => Real.log (N : ℝ)) Filter.atTop Filter.atTop :=
    Real.tendsto_log_atTop.comp tendsto_natCast_atTop_atTop
  have hpow :
      Filter.Tendsto (fun N : ℕ => (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4))
        Filter.atTop Filter.atTop :=
    (tendsto_rpow_atTop (by norm_num : (0 : ℝ) < (1 : ℝ) / 4)).comp hlog
  have hmul :
      Filter.Tendsto
        (fun N : ℕ =>
          optimizationSmallAlpha Cp * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4))
        Filter.atTop Filter.atTop :=
    Filter.Tendsto.const_mul_atTop (optimizationSmallAlpha_pos Cp) hpow
  exact hmul.eventually (Filter.eventually_ge_atTop (1 : ℝ))


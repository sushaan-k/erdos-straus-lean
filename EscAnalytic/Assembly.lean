      hc₁ hC₁ hEred smooth smoothExp smoothC hse_pos hse_lt hsC hsmooth
      _hsmooth_nn hsmooth_range hrough_range)

/-- Mertens-free concrete-Euler version of `main_modulo_range_bounds`.

This is identical in conclusion to `main_modulo_range_bounds_concrete_euler`,
but it uses the elementary fourth-log Euler product estimate and absorbs the
extra logarithms in `Main.main_of_euler_log_four`. -/
theorem main_modulo_range_bounds_concrete_euler_fourth
    (z : ℕ → ℕ)
    (Ered : ℕ → ℕ) (Ered_c₁ Ered_C₁ : ℝ)
    (hc₁ : 0 < Ered_c₁) (hC₁ : 0 < Ered_C₁)
    (hEred : ∀ N : ℕ, 3 ≤ N → (Ered N : ℝ) ≤ Ered_C₁ * ((N : ℝ) * saving Ered_c₁ N))
    (smooth : ℕ → ℝ) (smoothExp smoothC : ℝ)
    (hse_pos : 0 < smoothExp) (hse_lt : smoothExp < 1) (hsC : 0 < smoothC)
    (hsmooth : ∀ N : ℕ, 3 ≤ N → smooth N ≤ smoothC * (N : ℝ) ^ smoothExp)

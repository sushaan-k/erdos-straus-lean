/-- Signed multiples discrepancy plus signed squarefree-loss control imply the
modulus-one lower product-error estimate.  This is strictly more precise than
the absolute-envelope route: the squarefree term is bounded after keeping the
alternating signs. -/
theorem roughDyadicBadPrimeProductErrorLowerBoundModulusOne_of_signedComponents
    {a₀ b₀ C₀ Em Es Xm Xs : ℝ}
    (hm :
      roughDyadicBadPrimeProductMultiplesSignedErrorLowerBoundModulusOne
        a₀ b₀ C₀ Em Xm)
    (hs :
      roughDyadicBadPrimeProductSquarefreeSignedLossUpperBoundModulusOne
        a₀ b₀ C₀ Es Xs) :
    roughDyadicBadPrimeProductErrorLowerBoundModulusOne
      a₀ b₀ C₀ (Em + Es) (max Xm Xs) := by
  rcases hm with ⟨hEm_nonneg, hm⟩
  rcases hs with ⟨hEs_nonneg, hs⟩
  refine ⟨add_nonneg hEm_nonneg hEs_nonneg, ?_⟩
  intro X hX t htlo hthi
  have hXm : Xm ≤ X := le_trans (le_max_left _ _) hX
  have hXs : Xs ≤ X := le_trans (le_max_right _ _) hX
  let T : ℝ := t / Real.log (EscAnalytic.zScale X)
  have hm_lower :
      - (Em * T) ≤ roughDyadicBadPrimeProductMultiplesSignedErrorSum X t := by
    simpa [T] using hm X hXm t htlo hthi
  have hs_upper :
      roughDyadicBadPrimeProductSquarefreeSignedLossSum X t ≤ Es * T := by
    simpa [T] using hs X hXs t htlo hthi
  have hsplit :=
    roughDyadicBadPrimeProductErrorSum_one_eq_signedMultiples_sub_signedSquarefree
      X t
  calc
    - ((Em + Es) * T)
        = - (Em * T) - Es * T := by ring
    _ ≤ roughDyadicBadPrimeProductMultiplesSignedErrorSum X t -
          roughDyadicBadPrimeProductSquarefreeSignedLossSum X t := by
        linarith
    _ = roughDyadicBadPrimeProductErrorSum X 1 t := by
        rw [hsplit]

/-- Signed multiples discrepancy plus signed squarefree-loss control imply the
modulus-one upper product-error estimate.  This is the upper-side companion to
`roughDyadicBadPrimeProductErrorLowerBoundModulusOne_of_signedComponents` and
keeps the same cancellation-sensitive finite carrier. -/
theorem roughDyadicBadPrimeProductErrorUpperBoundModulusOne_of_signedComponents
    {a₀ b₀ C₀ Em Es Xm Xs : ℝ}
    (hm :
      roughDyadicBadPrimeProductMultiplesSignedErrorUpperBoundModulusOne
        a₀ b₀ C₀ Em Xm)
    (hs :
      roughDyadicBadPrimeProductSquarefreeSignedLossLowerBoundModulusOne
        a₀ b₀ C₀ Es Xs) :
    roughDyadicBadPrimeProductErrorUpperBoundModulusOne
      a₀ b₀ C₀ (Em + Es) (max Xm Xs) := by
  rcases hm with ⟨hEm_nonneg, hm⟩
  rcases hs with ⟨hEs_nonneg, hs⟩
  refine ⟨add_nonneg hEm_nonneg hEs_nonneg, ?_⟩
  intro X hX t htlo hthi
  have hXm : Xm ≤ X := le_trans (le_max_left _ _) hX
  have hXs : Xs ≤ X := le_trans (le_max_right _ _) hX
  let T : ℝ := t / Real.log (EscAnalytic.zScale X)
  have hm_upper :
      roughDyadicBadPrimeProductMultiplesSignedErrorSum X t ≤ Em * T := by
    simpa [T] using hm X hXm t htlo hthi
  have hs_lower :
      - (Es * T) ≤ roughDyadicBadPrimeProductSquarefreeSignedLossSum X t := by
    simpa [T] using hs X hXs t htlo hthi
  have hsplit :=
    roughDyadicBadPrimeProductErrorSum_one_eq_signedMultiples_sub_signedSquarefree
      X t
  calc
    roughDyadicBadPrimeProductErrorSum X 1 t
        = roughDyadicBadPrimeProductMultiplesSignedErrorSum X t -
          roughDyadicBadPrimeProductSquarefreeSignedLossSum X t := by
        rw [hsplit]
    _ ≤ Em * T + Es * T := by
        linarith
    _ = (Em + Es) * T := by ring

/-- One-sided modulus-one Euler-product/error package.  The lower count uses
the finite-product lower bound and the one-sided lower signed error; the upper
count uses only the one-sided upper signed error together with the checked
finite-product upper bound. -/
def roughDyadicBadPrimeOneSidedEulerProductErrorBoundModulusOne
    (a₀ b₀ C₀ : ℝ) : Prop :=
  ∃ c Elower Eupper Xprod Xlower Xupper : ℝ,
    0 < c ∧ 0 ≤ Elower ∧ Elower < c ∧ 0 ≤ Eupper ∧
    (∀ X : ℝ, Xprod ≤ X →
      c / Real.log (EscAnalytic.zScale X) ≤
          roughDyadicBadPrimeMainEulerProduct X) ∧
    roughDyadicBadPrimeProductErrorLowerBoundModulusOne
      a₀ b₀ C₀ Elower Xlower ∧
    roughDyadicBadPrimeProductErrorUpperBoundModulusOne
      a₀ b₀ C₀ Eupper Xupper

/-- One-sided lower modulus-one Euler-product/error package.

This is the exact lower-half target for removing the lower modulus-one
rough-sieve primitive: prove a finite Euler-product lower bound and a signed
lower error whose constant is strictly smaller than the product constant. -/
def roughDyadicBadPrimeLowerEulerProductErrorBoundModulusOne
    (a₀ b₀ C₀ : ℝ) : Prop :=
  ∃ c E Xprod Xerr : ℝ,
    0 < c ∧ 0 ≤ E ∧ E < c ∧
    (∀ X : ℝ, Xprod ≤ X →
      c / Real.log (EscAnalytic.zScale X) ≤
        roughDyadicBadPrimeMainEulerProduct X) ∧
    roughDyadicBadPrimeProductErrorLowerBoundModulusOne
      a₀ b₀ C₀ E Xerr

/-- The one-sided modulus-one Euler-product/error package is exactly its
expanded product-lower plus lower/upper signed-error data. -/
theorem roughDyadicBadPrimeOneSidedEulerProductErrorBoundModulusOne_iff_productLower_and_errors
    (a₀ b₀ C₀ : ℝ) :
    roughDyadicBadPrimeOneSidedEulerProductErrorBoundModulusOne a₀ b₀ C₀ ↔
      ∃ c Elower Eupper Xprod Xlower Xupper : ℝ,
        0 < c ∧ 0 ≤ Elower ∧ Elower < c ∧ 0 ≤ Eupper ∧
        (∀ X : ℝ, Xprod ≤ X →
          c / Real.log (EscAnalytic.zScale X) ≤
              roughDyadicBadPrimeMainEulerProduct X) ∧
        roughDyadicBadPrimeProductErrorLowerBoundModulusOne
          a₀ b₀ C₀ Elower Xlower ∧
        roughDyadicBadPrimeProductErrorUpperBoundModulusOne
          a₀ b₀ C₀ Eupper Xupper := by
  rfl

/-- The lower modulus-one Euler-product/error package is exactly product-lower
control plus a dominated one-sided lower product-error estimate. -/
theorem roughDyadicBadPrimeLowerEulerProductErrorBoundModulusOne_iff_productLower_and_errorLower
    (a₀ b₀ C₀ : ℝ) :
    roughDyadicBadPrimeLowerEulerProductErrorBoundModulusOne a₀ b₀ C₀ ↔
      ∃ c E Xprod Xerr : ℝ,
        0 < c ∧ 0 ≤ E ∧ E < c ∧
        (∀ X : ℝ, Xprod ≤ X →
          c / Real.log (EscAnalytic.zScale X) ≤
            roughDyadicBadPrimeMainEulerProduct X) ∧
        roughDyadicBadPrimeProductErrorLowerBoundModulusOne
          a₀ b₀ C₀ E Xerr := by
  rfl

/-- A two-sided modulus-one Euler-product/error package projects to the lower
Euler-product/error package. -/
theorem roughDyadicBadPrimeLowerEulerProductErrorBoundModulusOne_of_oneSidedModulusOne
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicBadPrimeOneSidedEulerProductErrorBoundModulusOne
      a₀ b₀ C₀) :
    roughDyadicBadPrimeLowerEulerProductErrorBoundModulusOne a₀ b₀ C₀ := by
  rcases h with
    ⟨c, Elower, _Eupper, Xprod, Xlower, _Xupper, hc, hElower_nonneg,
      hElower_lt, _hEupper_nonneg, hprod, hlower, _hupper⟩
  exact ⟨c, Elower, Xprod, Xlower, hc, hElower_nonneg, hElower_lt,
    hprod, hlower⟩

/-- A two-sided modulus-one Euler-product/error package also exposes the
one-sided upper product-error component. -/
theorem roughDyadicBadPrimeProductErrorUpperBoundModulusOne_of_oneSidedModulusOne
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicBadPrimeOneSidedEulerProductErrorBoundModulusOne
      a₀ b₀ C₀) :
    ∃ E Xerr : ℝ,
      roughDyadicBadPrimeProductErrorUpperBoundModulusOne
        a₀ b₀ C₀ E Xerr := by
  rcases h with
    ⟨_c, _Elower, Eupper, _Xprod, _Xlower, Xupper, _hc, _hElower_nonneg,
      _hElower_lt, _hEupper_nonneg, _hprod, _hlower, hupper⟩
  exact ⟨Eupper, Xupper, hupper⟩


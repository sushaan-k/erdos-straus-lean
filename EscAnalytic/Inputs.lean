    (haux :
      ∀ c Xprod : ℝ, 0 < c →
        (∀ X : ℝ, Xprod ≤ X →
          c / Real.log (EscAnalytic.zScale X) ≤
            roughDyadicBadPrimeMainEulerProduct X) →
        ∃ Xa : ℝ,
          roughDyadicBadPrimeProductAuxiliaryPrimeMultiplesFloorEnvelopeBound
            a₀ b₀ C₀ (c / 4) Xa) :
    roughDyadicBadPrimeLowerEulerProductLowerErrorBound a₀ b₀ C₀ := by
  rcases
    roughDyadicBadPrimeMainEulerProductLowerBound_of_primeRecipSharpMertens
      (rough_modulus_prime_recip_sharp_mertens_upper_bound hmertens) with
    ⟨c, Xprod, hc, hprod⟩
  rcases

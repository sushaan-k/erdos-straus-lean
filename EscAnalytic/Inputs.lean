    (a₀ b₀ C₀ : ℝ) (ha₀ : 0 < a₀) (hab : a₀ < b₀) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        c * (t / Real.log (EscAnalytic.zScale X)) ≤ roughDyadicCount X M t
          ∧ roughDyadicCount X M t
              ≤ C * (t / Real.log (EscAnalytic.zScale X)) :=
  linear_sieve_rough_dyadic_count_bound a₀ b₀ C₀ ha₀ hab

/-- Count-level linear-sieve input bundled with the checked range facts for the
actual finite carrier.  This is a theorem-level packaging of the primitive
two-sided sieve input together with nonnegativity and the absolute-value upper
form. -/
theorem linear_sieve_rough_dyadic_with_carrier_bounds
    (a₀ b₀ C₀ : ℝ) (ha₀ : 0 < a₀) (hab : a₀ < b₀) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        0 ≤ roughDyadicCount X M t ∧
          c * (t / Real.log (EscAnalytic.zScale X)) ≤ roughDyadicCount X M t ∧
          roughDyadicCount X M t
              ≤ C * (t / Real.log (EscAnalytic.zScale X)) ∧
          |roughDyadicCount X M t|
              ≤ C * (t / Real.log (EscAnalytic.zScale X)) := by
  rcases linear_sieve_rough_dyadic a₀ b₀ C₀ ha₀ hab with
    ⟨c, C, X₀, hc, hC, hcount⟩
  refine ⟨c, C, X₀, hc, hC, ?_⟩
  intro X hX M hM t htlo hthi
  have hcarrier_nonneg : 0 ≤ roughDyadicCount X M t :=
    roughDyadicCount_nonneg X M t
  have hbounds := hcount X hX M hM t htlo hthi
  exact ⟨hcarrier_nonneg, hbounds.1, hbounds.2, by
    rw [abs_of_nonneg hcarrier_nonneg]
    exact hbounds.2⟩


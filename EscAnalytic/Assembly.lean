/-- The direct reduced-sum hypothesis follows from the named finite reduced
carrier once `A.Ered` is known to dominate that carrier.

This removes a free-form real-valued sum inequality from the fixed-`m`
interface.  The remaining obligation is the concrete finite statement that the
analytic reduced carrier `A.Ered` majorizes `fixedNumeratorReducedSumCount`. -/
theorem fixedNumeratorPaperSuenOptimization_direct_reduced_sum_large_of_reduced_sum_count_le
    {ι : Type*} {m : ℕ}
    (A : FixedNumeratorPaperSuenAnalyticCoreOptimizationInputs m ι)
    (Tred : ℕ)
    (hEred_count_le : ∀ N : ℕ, 3 ≤ N → Tred ≤ N →
      fixedNumeratorReducedSumCount m (zNatScale N) N ≤ A.Ered N) :
    ∀ N : ℕ, 3 ≤ N → Tred ≤ N →
      (∑ s ∈ Finset.Icc 1 N,
        (fixedNumeratorReducedExceptionalCount m (zNatScale N) (N / s) : ℝ)) ≤
          eulerProductFactorAtNat N * (A.Ered N : ℝ) := by
  intro N hN hTN
  have hsum :
      (∑ s ∈ Finset.Icc 1 N,
        (fixedNumeratorReducedExceptionalCount m (zNatScale N) (N / s) : ℝ)) ≤
          eulerProductFactorAtNat N *
            (fixedNumeratorReducedSumCount m (zNatScale N) N : ℝ) := by
    simpa using
      (fixedNumeratorReduced_sum_le_euler_mul_self
        (m := m) (z := zNatScale N) (N := N)
        (euler := eulerProductFactorAtNat N)
        (eulerProductFactorAtNat_one_le N))
  have hcount_real :
      (fixedNumeratorReducedSumCount m (zNatScale N) N : ℝ) ≤
        (A.Ered N : ℝ) := by
    exact_mod_cast hEred_count_le N hN hTN
  exact
    le_trans hsum
      (mul_le_mul_of_nonneg_left hcount_real
        (eulerProductFactorAtNat_nonneg N))


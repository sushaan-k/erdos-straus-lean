    (smallDivisorAverage_two_sided_from_standard_inputs P)

/-- Add the absolute-value clause to a carrier-bundled two-sided small-divisor
average estimate. -/
theorem smallDivisorAverage_two_sided_with_abs_carrier_bounds_of_carrier_bounds
    (P : EscAnalytic.Params)
    (h :
      ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        0 ≤ Real.log (EscAnalytic.SScale P X) ∧
          0 ≤ Real.log (EscAnalytic.zScale X) ∧
          0 ≤ smallDivisorAverage P X ∧
          c * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X)
            ≤ smallDivisorAverage P X ∧

    (Ered : ℕ → ℕ) (Ered_c₁ Ered_C₁ : ℝ)
    (hc₁ : 0 < Ered_c₁) (hC₁ : 0 < Ered_C₁)
    (hEred : ∀ N : ℕ, 3 ≤ N → (Ered N : ℝ) ≤ Ered_C₁ * ((N : ℝ) * saving Ered_c₁ N))
    (smooth : ℕ → ℝ) (smoothExp smoothC : ℝ)
    (hse_pos : 0 < smoothExp) (hse_lt : smoothExp < 1) (hsC : 0 < smoothC)
    (hsmooth : ∀ N : ℕ, 3 ≤ N → smooth N ≤ smoothC * (N : ℝ) ^ smoothExp)
    (hsmooth_nn : ∀ N : ℕ, 0 ≤ smooth N)
    (euler : ℕ → ℝ) (eulerC : ℝ) (heC : 0 < eulerC)
    (heuler_nn : ∀ N : ℕ, 0 ≤ euler N)
    (heuler : ∀ N : ℕ, 3 ≤ N → euler N ≤ eulerC * Real.log N)
    (hlift : ∀ N : ℕ, 3 ≤ N →
      (exceptionalCount N : ℝ) ≤ smooth N + euler N * (Ered N : ℝ)) :
    ∃ c > (0 : ℝ), ∃ C > (0 : ℝ), ∀ N Y : ℕ, 3 ≤ Y → Y ≤ N →
      (exceptionalGtYCount N Y : ℝ)
        ≤ C * (N : ℝ) * (1 + Real.log N) * saving c Y :=
  exceptionalGtY_quantitative_of_main
    (main_modulo_remaining Ered Ered_c₁ Ered_C₁ hc₁ hC₁ hEred
      smooth smoothExp smoothC hse_pos hse_lt hsC hsmooth hsmooth_nn
      euler eulerC heC heuler_nn heuler hlift)

/-- **Capstone with the lifting field discharged by `LiftCount`.**

Compared with `main_modulo_remaining`, this theorem no longer takes the bundled
`MainInputs.lift` inequality as an assumption.  Instead it takes the two
quantitative range estimates that the manuscript uses after the exact
smooth/rough split:

* the smooth range is bounded by the chosen `smooth N`;
* the rough-large range is bounded by `euler N * Ered N`.

The master lifting inequality is then proved by
`LiftCount.lift_of_range_bounds`, which is the real `s·m` counting bridge. -/
theorem main_modulo_range_bounds
    (z : ℕ → ℕ)
    (Ered : ℕ → ℕ) (Ered_c₁ Ered_C₁ : ℝ)
    (hc₁ : 0 < Ered_c₁) (hC₁ : 0 < Ered_C₁)
    (hEred : ∀ N : ℕ, 3 ≤ N → (Ered N : ℝ) ≤ Ered_C₁ * ((N : ℝ) * saving Ered_c₁ N))
    (smooth : ℕ → ℝ) (smoothExp smoothC : ℝ)
    (hse_pos : 0 < smoothExp) (hse_lt : smoothExp < 1) (hsC : 0 < smoothC)
    (hsmooth : ∀ N : ℕ, 3 ≤ N → smooth N ≤ smoothC * (N : ℝ) ^ smoothExp)
    (hsmooth_nn : ∀ N : ℕ, 0 ≤ smooth N)
    (hsmooth_range : ∀ N : ℕ, 3 ≤ N →
      (smoothRangeCount (z N) N : ℝ) ≤ smooth N)
    (euler : ℕ → ℝ) (eulerC : ℝ) (heC : 0 < eulerC)
    (heuler_nn : ∀ N : ℕ, 0 ≤ euler N)
    (heuler : ∀ N : ℕ, 3 ≤ N → euler N ≤ eulerC * Real.log N)
    (hrough_range : ∀ N : ℕ, 3 ≤ N →
      (roughLargeCount (z N) N : ℝ) ≤ euler N * (Ered N : ℝ)) :
    IsMainBound exceptionalCount :=
  main_modulo_remaining Ered Ered_c₁ Ered_C₁ hc₁ hC₁ hEred
    smooth smoothExp smoothC hse_pos hse_lt hsC hsmooth hsmooth_nn
    euler eulerC heC heuler_nn heuler
    (fun N hN => lift_of_range_bounds (hsmooth_range N hN) (hrough_range N hN))

/-- Constructor for the bundled `MainInputs` from the range-bound interface.

This records explicitly that `LiftCount.lift_of_range_bounds` discharges the
`MainInputs.lift` field once the smooth range and rough-large range estimates are
available.  Applying `Main.main` to this bundle gives `main_modulo_range_bounds`.
-/
def mainInputs_of_range_bounds
    (z : ℕ → ℕ)
    (Ered : ℕ → ℕ) (Ered_c₁ Ered_C₁ : ℝ)
    (hc₁ : 0 < Ered_c₁) (hC₁ : 0 < Ered_C₁)
    (hEred : ∀ N : ℕ, 3 ≤ N → (Ered N : ℝ) ≤ Ered_C₁ * ((N : ℝ) * saving Ered_c₁ N))
    (smooth : ℕ → ℝ) (smoothExp smoothC : ℝ)
    (hse_pos : 0 < smoothExp) (hse_lt : smoothExp < 1) (hsC : 0 < smoothC)
    (hsmooth : ∀ N : ℕ, 3 ≤ N → smooth N ≤ smoothC * (N : ℝ) ^ smoothExp)
    (hsmooth_nn : ∀ N : ℕ, 0 ≤ smooth N)
    (hsmooth_range : ∀ N : ℕ, 3 ≤ N →
      (smoothRangeCount (z N) N : ℝ) ≤ smooth N)
    (euler : ℕ → ℝ) (eulerC : ℝ) (heC : 0 < eulerC)
    (heuler_nn : ∀ N : ℕ, 0 ≤ euler N)
    (heuler : ∀ N : ℕ, 3 ≤ N → euler N ≤ eulerC * Real.log N)
    (hrough_range : ∀ N : ℕ, 3 ≤ N →
      (roughLargeCount (z N) N : ℝ) ≤ euler N * (Ered N : ℝ)) :
    MainInputs :=
  { Ered := Ered, Ered_c₁ := Ered_c₁, Ered_C₁ := Ered_C₁,
    Ered_pos₁ := hc₁, Ered_posC₁ := hC₁, Ered_bound := hEred,
    smooth := smooth, smoothExp := smoothExp, smoothExp_pos := hse_pos,
    smoothExp_lt_one := hse_lt, smoothC := smoothC, smoothC_pos := hsC,
    smooth_bound := hsmooth, smooth_nonneg := hsmooth_nn,
    euler := euler, eulerC := eulerC, eulerC_pos := heC,
    euler_nonneg := heuler_nn,
    euler_bound := fun N hN =>
      (heuler N hN).trans
        (mul_le_mul_of_nonneg_left (log_le_log_pow_four_of_three_le hN) heC.le),
    lift := fun N hN => lift_of_range_bounds (hsmooth_range N hN) (hrough_range N hN) }

/-- Constructor for `MainInputs` with the concrete manuscript Euler product
supplied internally.

Compared with `mainInputs_of_range_bounds`, this constructor no longer asks for
an abstract Euler carrier or for a one-log Euler bound.  The `MainInputs.euler`
field is the concrete finite product `eulerProductFactorAtNat`, and
`MainInputs.euler_bound` is discharged by the elementary fourth-log bound in
`AbstractMain.lean`. -/
noncomputable def mainInputs_of_range_bounds_concrete_euler
    (z : ℕ → ℕ)
    (Ered : ℕ → ℕ) (Ered_c₁ Ered_C₁ : ℝ)
    (hc₁ : 0 < Ered_c₁) (hC₁ : 0 < Ered_C₁)
    (hEred : ∀ N : ℕ, 3 ≤ N → (Ered N : ℝ) ≤ Ered_C₁ * ((N : ℝ) * saving Ered_c₁ N))
    (smooth : ℕ → ℝ) (smoothExp smoothC : ℝ)
    (hse_pos : 0 < smoothExp) (hse_lt : smoothExp < 1) (hsC : 0 < smoothC)
    (hsmooth : ∀ N : ℕ, 3 ≤ N → smooth N ≤ smoothC * (N : ℝ) ^ smoothExp)
    (hsmooth_nn : ∀ N : ℕ, 0 ≤ smooth N)
    (hsmooth_range : ∀ N : ℕ, 3 ≤ N →
      (smoothRangeCount (z N) N : ℝ) ≤ smooth N)
    (hrough_range : ∀ N : ℕ, 3 ≤ N →
      (roughLargeCount (z N) N : ℝ) ≤ eulerProductFactorAtNat N * (Ered N : ℝ)) :
    MainInputs := by
  classical
  let eulerC : ℝ := Classical.choose eulerProductFactorAtNat_log_fourth_bound
  have heulerSpec :
      0 < eulerC ∧ ∀ N : ℕ, 3 ≤ N →
        eulerProductFactorAtNat N ≤ eulerC * (Real.log N) ^ (4 : ℕ) :=
    Classical.choose_spec eulerProductFactorAtNat_log_fourth_bound
  exact
    { Ered := Ered, Ered_c₁ := Ered_c₁, Ered_C₁ := Ered_C₁,
      Ered_pos₁ := hc₁, Ered_posC₁ := hC₁, Ered_bound := hEred,
      smooth := smooth, smoothExp := smoothExp, smoothExp_pos := hse_pos,
      smoothExp_lt_one := hse_lt, smoothC := smoothC, smoothC_pos := hsC,
      smooth_bound := hsmooth, smooth_nonneg := hsmooth_nn,
      euler := eulerProductFactorAtNat, eulerC := eulerC, eulerC_pos := heulerSpec.1,
      euler_nonneg := eulerProductFactorAtNat_nonneg, euler_bound := heulerSpec.2,
      lift := fun N hN => lift_of_range_bounds (hsmooth_range N hN) (hrough_range N hN) }

/-- Constructor for `MainInputs` with the canonical Rankin smooth range and
concrete Euler product supplied internally.

This narrows the range-bound interface to the two quantities still outside this
constructor: the reduced-count saving and the rough-large comparison at the
manuscript cutoff `zNatScale`. -/
noncomputable def mainInputs_of_range_bounds_concrete_euler_rankin_smooth
    (Ered : ℕ → ℕ) (Ered_c₁ Ered_C₁ : ℝ)
    (hc₁ : 0 < Ered_c₁) (hC₁ : 0 < Ered_C₁)
    (hEred : ∀ N : ℕ, 3 ≤ N → (Ered N : ℝ) ≤ Ered_C₁ * ((N : ℝ) * saving Ered_c₁ N))
    (hrough_range : ∀ N : ℕ, 3 ≤ N →
      (roughLargeCount (zNatScale N) N : ℝ) ≤ eulerProductFactorAtNat N * (Ered N : ℝ)) :
    MainInputs := by
  classical
  let smoothExp : ℝ :=
    Classical.choose smoothRangeCount_zNatScale_polynomial_bound_with_carrier_bounds
  let smoothC : ℝ :=
    Classical.choose
      (Classical.choose_spec smoothRangeCount_zNatScale_polynomial_bound_with_carrier_bounds)
  have hsmoothSpec :
      0 < smoothExp ∧ smoothExp < 1 ∧ 0 < smoothC ∧
        ∀ N : ℕ, 3 ≤ N →
          0 ≤ (smoothRangeCount (zNatScale N) N : ℝ) ∧
            (smoothRangeCount (zNatScale N) N : ℝ) ≤ smoothC * (N : ℝ) ^ smoothExp ∧
            |(smoothRangeCount (zNatScale N) N : ℝ)| ≤
              smoothC * (N : ℝ) ^ smoothExp :=
    Classical.choose_spec
      (Classical.choose_spec smoothRangeCount_zNatScale_polynomial_bound_with_carrier_bounds)
  exact mainInputs_of_range_bounds_concrete_euler zNatScale Ered Ered_c₁ Ered_C₁
    hc₁ hC₁ hEred
    (fun N => (smoothRangeCount (zNatScale N) N : ℝ)) smoothExp smoothC
    hsmoothSpec.1 hsmoothSpec.2.1 hsmoothSpec.2.2.1
    (fun N hN => (hsmoothSpec.2.2.2 N hN).2.1)
    (fun N => smoothRangeCount_zNatScale_nonneg N)
    (fun _N _hN => le_rfl)
    hrough_range

/-- The range-bound interface implies the main theorem by first constructing the
canonical `MainInputs` bundle. -/
theorem main_modulo_range_bounds_via_inputs
    (z : ℕ → ℕ)
    (Ered : ℕ → ℕ) (Ered_c₁ Ered_C₁ : ℝ)
    (hc₁ : 0 < Ered_c₁) (hC₁ : 0 < Ered_C₁)
    (hEred : ∀ N : ℕ, 3 ≤ N → (Ered N : ℝ) ≤ Ered_C₁ * ((N : ℝ) * saving Ered_c₁ N))
    (smooth : ℕ → ℝ) (smoothExp smoothC : ℝ)
    (hse_pos : 0 < smoothExp) (hse_lt : smoothExp < 1) (hsC : 0 < smoothC)
    (hsmooth : ∀ N : ℕ, 3 ≤ N → smooth N ≤ smoothC * (N : ℝ) ^ smoothExp)
    (hsmooth_nn : ∀ N : ℕ, 0 ≤ smooth N)
    (hsmooth_range : ∀ N : ℕ, 3 ≤ N →
      (smoothRangeCount (z N) N : ℝ) ≤ smooth N)
    (euler : ℕ → ℝ) (eulerC : ℝ) (heC : 0 < eulerC)
    (heuler_nn : ∀ N : ℕ, 0 ≤ euler N)
    (heuler : ∀ N : ℕ, 3 ≤ N → euler N ≤ eulerC * Real.log N)
    (hrough_range : ∀ N : ℕ, 3 ≤ N →
      (roughLargeCount (z N) N : ℝ) ≤ euler N * (Ered N : ℝ)) :
    IsMainBound exceptionalCount :=
  erdos_straus_main
    (mainInputs_of_range_bounds z Ered Ered_c₁ Ered_C₁ hc₁ hC₁ hEred
      smooth smoothExp smoothC hse_pos hse_lt hsC hsmooth hsmooth_nn
      hsmooth_range euler eulerC heC heuler_nn heuler hrough_range)

/-- Concrete-Euler version of `main_modulo_range_bounds`.

This is the range-estimate capstone with the intended finite Euler product
`Main.eulerProductFactorAtNat` supplied internally.  The remaining range
hypotheses are therefore exactly the smooth range estimate and the rough-large
estimate against that concrete product times the reduced exceptional count. -/
theorem main_modulo_range_bounds_concrete_euler
    (z : ℕ → ℕ)
    (Ered : ℕ → ℕ) (Ered_c₁ Ered_C₁ : ℝ)
    (hc₁ : 0 < Ered_c₁) (hC₁ : 0 < Ered_C₁)
    (hEred : ∀ N : ℕ, 3 ≤ N → (Ered N : ℝ) ≤ Ered_C₁ * ((N : ℝ) * saving Ered_c₁ N))
    (smooth : ℕ → ℝ) (smoothExp smoothC : ℝ)
    (hse_pos : 0 < smoothExp) (hse_lt : smoothExp < 1) (hsC : 0 < smoothC)
    (hsmooth : ∀ N : ℕ, 3 ≤ N → smooth N ≤ smoothC * (N : ℝ) ^ smoothExp)
    (_hsmooth_nn : ∀ N : ℕ, 0 ≤ smooth N)
    (hsmooth_range : ∀ N : ℕ, 3 ≤ N →
      (smoothRangeCount (z N) N : ℝ) ≤ smooth N)
    (hrough_range : ∀ N : ℕ, 3 ≤ N →
      (roughLargeCount (z N) N : ℝ) ≤ eulerProductFactorAtNat N * (Ered N : ℝ)) :
    IsMainBound exceptionalCount :=
  erdos_straus_main

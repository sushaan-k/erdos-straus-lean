/-- Arbitrarily close elementary polynomial fallback for the Rankin-facing
envelope.

For every `η > 0`, the checked harmonic envelope gives
`smoothRankinEnvelope N = O(N^(1+η))`.  This is still not the Rankin/de Bruijn
input needed by the final assembly, since that input must cross the critical
line to an exponent `< 1`; it does show that all purely elementary carrier work
up to the critical line has been formalized. -/
theorem smoothRankinEnvelope_one_plus_eta_polynomial_bound
    (η : ℝ) (hη : 0 < η) :
    ∃ C : ℝ, 0 < C ∧
      ∀ N : ℕ, 3 ≤ N →
        smoothRankinEnvelope N ≤ C * (N : ℝ) ^ (1 + η) := by
  refine ⟨1 + (2 * η)⁻¹, ?_, ?_⟩
  · positivity
  intro N hN
  have hNone_nat : 1 ≤ N := le_trans (by norm_num : 1 ≤ 3) hN
  have hNpos : 0 < (N : ℝ) := by
    exact_mod_cast (lt_of_lt_of_le (by norm_num : 0 < 3) hN)
  have hNnonneg : 0 ≤ (N : ℝ) := hNpos.le
  have hNone : (1 : ℝ) ≤ (N : ℝ) := by exact_mod_cast hNone_nat
  have htwoη_pos : 0 < 2 * η := by positivity
  have hη_nonneg : 0 ≤ η := hη.le
  have htwoη_nonneg : 0 ≤ 2 * η := htwoη_pos.le
  have hsqrt_le_rpow :
      (Nat.sqrt N : ℝ) ≤ (N : ℝ) ^ ((1 : ℝ) / 2) := by
    simpa [Real.sqrt_eq_rpow] using Real.nat_sqrt_le_real_sqrt (a := N)
  have hsqrt_rpow_le :
      (Nat.sqrt N : ℝ) ^ (2 * η) ≤ (N : ℝ) ^ η := by
    calc
      (Nat.sqrt N : ℝ) ^ (2 * η)
          ≤ ((N : ℝ) ^ ((1 : ℝ) / 2)) ^ (2 * η) :=
            Real.rpow_le_rpow
              (by exact_mod_cast Nat.zero_le (Nat.sqrt N))
              hsqrt_le_rpow
              htwoη_nonneg
      _ = (N : ℝ) ^ η := by
            rw [← Real.rpow_mul hNnonneg]
            ring_nf
  have hlog_le :
      Real.log (Nat.sqrt N : ℝ) ≤
        (2 * η)⁻¹ * (Nat.sqrt N : ℝ) ^ (2 * η) := by
    have h := Real.log_natCast_le_rpow_div (Nat.sqrt N) htwoη_pos
    calc
      Real.log (Nat.sqrt N : ℝ)
          ≤ (Nat.sqrt N : ℝ) ^ (2 * η) / (2 * η) := h
      _ = (2 * η)⁻¹ * (Nat.sqrt N : ℝ) ^ (2 * η) := by ring
  have hone_rpow : (1 : ℝ) ≤ (N : ℝ) ^ η :=
    Real.one_le_rpow hNone hη_nonneg
  have hinv_nonneg : 0 ≤ (2 * η)⁻¹ := inv_nonneg.mpr htwoη_nonneg
  have hlog_tail :
      (2 * η)⁻¹ * (Nat.sqrt N : ℝ) ^ (2 * η) ≤
        (2 * η)⁻¹ * (N : ℝ) ^ η :=
    mul_le_mul_of_nonneg_left hsqrt_rpow_le hinv_nonneg
  have htail :
      1 + Real.log (Nat.sqrt N : ℝ) ≤
        (1 + (2 * η)⁻¹) * (N : ℝ) ^ η := by
    calc
      1 + Real.log (Nat.sqrt N : ℝ)
          ≤ 1 + (2 * η)⁻¹ * (Nat.sqrt N : ℝ) ^ (2 * η) :=
            add_le_add_left hlog_le 1
      _ ≤ (N : ℝ) ^ η + (2 * η)⁻¹ * (N : ℝ) ^ η :=
            add_le_add hone_rpow hlog_tail
      _ = (1 + (2 * η)⁻¹) * (N : ℝ) ^ η := by ring
  calc
    smoothRankinEnvelope N
        ≤ (N : ℝ) * (1 + Real.log (Nat.sqrt N : ℝ)) :=
          smoothRankinEnvelope_le_mul_one_add_log_sqrt N
    _ ≤ (N : ℝ) * ((1 + (2 * η)⁻¹) * (N : ℝ) ^ η) :=
        mul_le_mul_of_nonneg_left htail hNnonneg
    _ = (1 + (2 * η)⁻¹) * (N : ℝ) ^ (1 + η) := by
        calc
          (N : ℝ) * ((1 + (2 * η)⁻¹) * (N : ℝ) ^ η)
              = (1 + (2 * η)⁻¹) * ((N : ℝ) * (N : ℝ) ^ η) := by ring
          _ = (1 + (2 * η)⁻¹) * ((N : ℝ) ^ (1 : ℝ) * (N : ℝ) ^ η) := by
                rw [Real.rpow_one]
          _ = (1 + (2 * η)⁻¹) * (N : ℝ) ^ (1 + η) := by
                rw [Real.rpow_add hNpos]


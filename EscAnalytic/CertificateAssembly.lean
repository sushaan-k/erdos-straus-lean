    (hmain_sum_real : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        (∑ k ∈ Finset.range (2 * R N + 1), mainEnv N b k) ≤
          ((N : ℝ) / Pz N) * (nohit N b + F2R N b))
    (herr_rank_real : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        ∀ k ∈ Finset.range (2 * R N + 1),
          (errRank N b k : ℝ) ≤ errEnv N b k)
    (herr_sum_real : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        (∑ k ∈ Finset.range (2 * R N + 1), errEnv N b k) ≤ errTerm N b)
    (herr : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        errTerm N b ≤ Xpow N b * Real.exp ((1 + εK) * μ N))
    (hεle : εK ≤ 1)
    (hlevel : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        Pz N * Xpow N b * Real.exp (2 * μ N) ≤
          (N : ℝ) * Real.exp (-4 * μ N))

      (roughLargeCount (zNatScale N) N : ℝ) ≤ eulerProductFactorAtNat N * (Ered N : ℝ)) :
    Filter.Tendsto (fun N : ℕ =>
      (primeExceptionalCount N : ℝ) / (primePi N : ℝ)) Filter.atTop (nhds 0) :=
  prime_exceptional_relative_density_zero_of_primePi_saving
    (cor_prime_exceptional_pi_saving_modulo_range_bounds_concrete_euler_rankin_smooth
      Ered Ered_c₁ Ered_C₁ hc₁ hC₁ hEred hrough_range)

/-- Capstone form where the reduced-count bound is produced by the finite-transfer
summation theorem and the lifting field is produced by `LiftCount`.

The hypotheses `htransfer` and `hsaving` are the remaining per-class transfer and
mass-to-saving data; `Transfer.Ered_bound_of_finite_transfer` performs the real
summation over reduced classes and converts the exponential transfer saving into
the `MainInputs.Ered_bound` shape. -/
theorem main_modulo_transfer_range_bounds
    {ι : Type*}
    (z : ℕ → ℕ)
    (cls : ℕ → Finset ι)
    (Mb : ℕ → ι → ℝ)
    (Pz μ ε : ℕ → ℝ)
    (Ered : ℕ → ℕ) (Ered_c₁ : ℝ)
    (hc₁ : 0 < Ered_c₁)
    (hEred_sum : ∀ N : ℕ, 3 ≤ N →
      (Ered N : ℝ) ≤ ∑ b ∈ cls N, Mb N b)
    (hPz : ∀ N : ℕ, 3 ≤ N → 1 ≤ Pz N)
    (hcard : ∀ N : ℕ, 3 ≤ N → ((cls N).card : ℝ) ≤ Pz N)
    (htransfer : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      Mb N b ≤ ((N : ℝ) / Pz N) * Real.exp (-(1 - ε N) * μ N))
    (hsaving : ∀ N : ℕ, 3 ≤ N →
      Ered_c₁ * (Real.log N) ^ ((3 : ℝ) / 4) ≤ (1 - ε N) * μ N)
    (smooth : ℕ → ℝ) (smoothExp smoothC : ℝ)
    (hse_pos : 0 < smoothExp) (hse_lt : smoothExp < 1) (hsC : 0 < smoothC)
    (hsmooth : ∀ N : ℕ, 3 ≤ N → smooth N ≤ smoothC * (N : ℝ) ^ smoothExp)
    (hsmooth_nn : ∀ N : ℕ, 0 ≤ smooth N)
    (hsmooth_range : ∀ N : ℕ, 3 ≤ N →
      (smoothRangeCount (z N) N : ℝ) ≤ smooth N)
    (euler : ℕ → ℝ) (eulerC : ℝ) (heC : 0 < eulerC)
    (heuler_nn : ∀ N : ℕ, 0 ≤ euler N)
    (heuler : ∀ N : ℕ, 3 ≤ N → euler N ≤ eulerC * Real.log N)
    (hrough_range : ∀ N : ℕ, 3 ≤ N →
      (roughLargeCount (z N) N : ℝ) ≤ euler N * (Ered N : ℝ)) :
    IsMainBound exceptionalCount :=
  main_modulo_range_bounds z Ered Ered_c₁ 1 hc₁ zero_lt_one
    (fun N hN => by
      have hsum :
          (∑ b ∈ cls N, Mb N b) ≤ (N : ℝ) * saving Ered_c₁ N :=
        Ered_bound_of_finite_transfer_of_one_le (cls N)
          (hPz N hN) (by positivity) (hcard N hN)
          (htransfer N hN) (hsaving N hN)
      calc (Ered N : ℝ)
          ≤ ∑ b ∈ cls N, Mb N b := hEred_sum N hN
        _ ≤ (N : ℝ) * saving Ered_c₁ N := hsum
        _ = 1 * ((N : ℝ) * saving Ered_c₁ N) := by ring)
    smooth smoothExp smoothC hse_pos hse_lt hsC hsmooth hsmooth_nn
    hsmooth_range euler eulerC heC heuler_nn heuler hrough_range

/-- Concrete-Euler version of `main_modulo_transfer_range_bounds`.

This keeps the per-class transfer and mass-to-saving hypotheses explicit, but no
longer asks callers to provide an abstract Euler factor or its logarithmic
bound. -/
theorem main_modulo_transfer_range_bounds_concrete_euler
    {ι : Type*}
    (z : ℕ → ℕ)
    (cls : ℕ → Finset ι)
    (Mb : ℕ → ι → ℝ)
    (Pz μ ε : ℕ → ℝ)
    (Ered : ℕ → ℕ) (Ered_c₁ : ℝ)
    (hc₁ : 0 < Ered_c₁)
    (hEred_sum : ∀ N : ℕ, 3 ≤ N →
      (Ered N : ℝ) ≤ ∑ b ∈ cls N, Mb N b)
    (hPz : ∀ N : ℕ, 3 ≤ N → 1 ≤ Pz N)
    (hcard : ∀ N : ℕ, 3 ≤ N → ((cls N).card : ℝ) ≤ Pz N)
    (htransfer : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      Mb N b ≤ ((N : ℝ) / Pz N) * Real.exp (-(1 - ε N) * μ N))
    (hsaving : ∀ N : ℕ, 3 ≤ N →
      Ered_c₁ * (Real.log N) ^ ((3 : ℝ) / 4) ≤ (1 - ε N) * μ N)
    (smooth : ℕ → ℝ) (smoothExp smoothC : ℝ)
    (hse_pos : 0 < smoothExp) (hse_lt : smoothExp < 1) (hsC : 0 < smoothC)
    (hsmooth : ∀ N : ℕ, 3 ≤ N → smooth N ≤ smoothC * (N : ℝ) ^ smoothExp)
    (_hsmooth_nn : ∀ N : ℕ, 0 ≤ smooth N)
    (hsmooth_range : ∀ N : ℕ, 3 ≤ N →
      (smoothRangeCount (z N) N : ℝ) ≤ smooth N)
    (hrough_range : ∀ N : ℕ, 3 ≤ N →
      (roughLargeCount (z N) N : ℝ) ≤ eulerProductFactorAtNat N * (Ered N : ℝ)) :
    IsMainBound exceptionalCount :=
  main_modulo_range_bounds_concrete_euler_fourth z Ered Ered_c₁ 1 hc₁ zero_lt_one
    (fun N hN => by
      have hsum :
          (∑ b ∈ cls N, Mb N b) ≤ (N : ℝ) * saving Ered_c₁ N :=
        Ered_bound_of_finite_transfer_of_one_le (cls N)
          (hPz N hN) (by positivity) (hcard N hN)
          (htransfer N hN) (hsaving N hN)
      calc (Ered N : ℝ)
          ≤ ∑ b ∈ cls N, Mb N b := hEred_sum N hN
        _ ≤ (N : ℝ) * saving Ered_c₁ N := hsum
        _ = 1 * ((N : ℝ) * saving Ered_c₁ N) := by ring)
    smooth smoothExp smoothC hse_pos hse_lt hsC hsmooth
    hsmooth_range hrough_range

/-- Concrete-Euler transfer capstone with the smooth range discharged by the
named Rankin summatory input at the manuscript cutoff `z_N = ⌊(log N)^4⌋`.

Compared with `main_modulo_transfer_range_bounds_concrete_euler`, this removes
the abstract smooth-function parameters.  The remaining nonstandard inputs are
the reduced-count transfer data and the rough-large Euler comparison; the smooth
side is now the checked `LiftCount` carrier bridge plus the external
`rankin_smoothRange_zNatScale_bound`. -/
theorem main_modulo_transfer_range_bounds_concrete_euler_rankin_smooth
    {ι : Type*}
    (cls : ℕ → Finset ι)
    (Mb : ℕ → ι → ℝ)
    (Pz μ ε : ℕ → ℝ)
    (Ered : ℕ → ℕ) (Ered_c₁ : ℝ)
    (hc₁ : 0 < Ered_c₁)
    (hEred_sum : ∀ N : ℕ, 3 ≤ N →
      (Ered N : ℝ) ≤ ∑ b ∈ cls N, Mb N b)
    (hPz : ∀ N : ℕ, 3 ≤ N → 1 ≤ Pz N)
    (hcard : ∀ N : ℕ, 3 ≤ N → ((cls N).card : ℝ) ≤ Pz N)
    (htransfer : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      Mb N b ≤ ((N : ℝ) / Pz N) * Real.exp (-(1 - ε N) * μ N))
    (hsaving : ∀ N : ℕ, 3 ≤ N →
      Ered_c₁ * (Real.log N) ^ ((3 : ℝ) / 4) ≤ (1 - ε N) * μ N)
    (hrough_range : ∀ N : ℕ, 3 ≤ N →
      (roughLargeCount (zNatScale N) N : ℝ) ≤ eulerProductFactorAtNat N * (Ered N : ℝ)) :
    IsMainBound exceptionalCount := by
  rcases smoothRangeCount_zNatScale_polynomial_bound_with_carrier_bounds with
    ⟨smoothExp, smoothC, hse_pos, hse_lt, hsC, hsmooth_range⟩
  exact main_modulo_transfer_range_bounds_concrete_euler zNatScale cls Mb Pz μ ε
    Ered Ered_c₁ hc₁ hEred_sum hPz hcard htransfer hsaving
    (fun N => smoothC * (N : ℝ) ^ smoothExp) smoothExp smoothC
    hse_pos hse_lt hsC
    (fun _N _hN => le_rfl)
    (fun N => mul_nonneg hsC.le (Real.rpow_nonneg (by positivity : 0 ≤ (N : ℝ)) _))
    (fun N hN => (hsmooth_range N hN).2.1) hrough_range

/-- Uniform per-class transfer bound obtained by applying `Transfer.finite_transfer`
class-by-class.  This helper keeps the strongest capstone theorem readable and
prevents the per-class transfer conclusion from being treated as a primitive
hypothesis. -/
theorem per_class_transfer_of_finite_transfer
    {ι : Type*}
    (cls : ℕ → Finset ι)
    (Mb : ℕ → ι → ℝ)
    (Pz μ εb : ℕ → ℝ)
    (Xpow nohit errTerm F2R : ℕ → ι → ℝ)
    (εK : ℝ)
    (hμ : ∀ N : ℕ, 3 ≤ N → 0 < μ N)
    (hPz : ∀ N : ℕ, 3 ≤ N → 1 ≤ Pz N)
    (hXpow : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N, 0 ≤ Xpow N b)
    (hεb : ∀ N : ℕ, 3 ≤ N → 0 ≤ εb N)
    (hdecomp : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      Mb N b ≤ ((N : ℝ) / Pz N) * (nohit N b + F2R N b) + errTerm N b)
    (herr : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      errTerm N b ≤ Xpow N b * Real.exp ((1 + εK) * μ N))
    (hεle : εK ≤ 1)
    (hlevel : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      Pz N * Xpow N b * Real.exp (2 * μ N) ≤ (N : ℝ) * Real.exp (-4 * μ N))
    (hF2R : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      F2R N b ≤ Real.exp (-3 * μ N))
    (hnohit : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      nohit N b ≤ Real.exp (-(1 - εb N) * μ N)) :
    ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      Mb N b
        ≤ ((N : ℝ) / Pz N) * Real.exp (-(1 - (εb N + Real.log 3 / μ N)) * μ N) := by
  intro N hN b hb
  have hNnonneg : 0 ≤ (N : ℝ) := by exact_mod_cast Nat.zero_le N
  exact @finite_transfer (Mb N b) (N : ℝ) (Pz N) (μ N) (Xpow N b)
    (nohit N b) (errTerm N b) (F2R N b) (εb N) εK
    (hμ N hN) (hPz N hN) (hXpow N hN b hb) hNnonneg
    (hεb N hN) (hdecomp N hN b hb) (herr N hN b hb) hεle
    (hlevel N hN b hb) (hF2R N hN b hb) (hnohit N hN b hb)

/-- Large-range version of `per_class_transfer_of_finite_transfer`.

This is the bridge used when the analytic finite-transfer ingredients are only
proved after an explicit threshold `T`; the finite initial range is handled by a
separate certificate/bound. -/
theorem per_class_transfer_of_finite_transfer_on_range
    {ι : Type*}
    (cls : ℕ → Finset ι)
    (Mb : ℕ → ι → ℝ)
    (Pz μ εb : ℕ → ℝ)
    (Xpow nohit errTerm F2R : ℕ → ι → ℝ)
    (εK : ℝ) (T : ℕ)
    (hμ : ∀ N : ℕ, 3 ≤ N → T ≤ N → 0 < μ N)
    (hPz : ∀ N : ℕ, 3 ≤ N → T ≤ N → 1 ≤ Pz N)
    (hXpow : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 0 ≤ Xpow N b)
    (hεb : ∀ N : ℕ, 3 ≤ N → T ≤ N → 0 ≤ εb N)
    (hdecomp : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      Mb N b ≤ ((N : ℝ) / Pz N) * (nohit N b + F2R N b) + errTerm N b)
    (herr : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      errTerm N b ≤ Xpow N b * Real.exp ((1 + εK) * μ N))
    (hεle : εK ≤ 1)
    (hlevel : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      Pz N * Xpow N b * Real.exp (2 * μ N) ≤ (N : ℝ) * Real.exp (-4 * μ N))
    (hF2R : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      F2R N b ≤ Real.exp (-3 * μ N))
    (hnohit : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      nohit N b ≤ Real.exp (-(1 - εb N) * μ N)) :
    ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      Mb N b
        ≤ ((N : ℝ) / Pz N) * Real.exp (-(1 - (εb N + Real.log 3 / μ N)) * μ N) := by
  intro N hN hTN b hb
  have hNnonneg : 0 ≤ (N : ℝ) := by exact_mod_cast Nat.zero_le N
  exact @finite_transfer (Mb N b) (N : ℝ) (Pz N) (μ N) (Xpow N b)
    (nohit N b) (errTerm N b) (F2R N b) (εb N) εK
    (hμ N hN hTN) (hPz N hN hTN) (hXpow N hN hTN b hb) hNnonneg
    (hεb N hN hTN) (hdecomp N hN hTN b hb) (herr N hN hTN b hb) hεle
    (hlevel N hN hTN b hb) (hF2R N hN hTN b hb) (hnohit N hN hTN b hb)

/-- Variable-class finite-transfer bridge with the no-hit term discharged by
the cited Suen carrier.

The only external analytic input used here is
the theorem-level legacy Suen envelope, through
`Inputs.suenProb_bound_with_carrier_bounds`.  The caller supplies the
paper-specific tail budget `K * Δ * exp(2δ) ≤ ε μ` for the Suen constant `K`;
the theorem then derives the no-hit hypothesis and applies
`per_class_transfer_of_finite_transfer_on_range`. -/
theorem per_class_transfer_of_suen_finite_transfer_on_range
    {ι : Type*}
    (cls : ℕ → Finset ι)
    (Mb : ℕ → ι → ℝ)
    (Pz μ εb : ℕ → ℝ)
    (δb Δb Xpow errTerm F2R : ℕ → ι → ℝ)
    (εK : ℝ) (T : ℕ)
    (hμ : ∀ N : ℕ, 3 ≤ N → T ≤ N → 0 < μ N)
    (hPz : ∀ N : ℕ, 3 ≤ N → T ≤ N → 1 ≤ Pz N)
    (hδ_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 0 ≤ δb N b)
    (hΔ_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 0 ≤ Δb N b)
    (hXpow : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 0 ≤ Xpow N b)
    (hsuen_tail : ∀ K : ℝ, 0 < K → ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      K * Δb N b * Real.exp (2 * δb N b) ≤ εb N * μ N)
    (hdecomp : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      Mb N b ≤ ((N : ℝ) / Pz N) *
        (Inputs.suenProb (μ N) (δb N b) (Δb N b) + F2R N b) + errTerm N b)
    (herr : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      errTerm N b ≤ Xpow N b * Real.exp ((1 + εK) * μ N))
    (hεle : εK ≤ 1)
    (hlevel : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      Pz N * Xpow N b * Real.exp (2 * μ N) ≤ (N : ℝ) * Real.exp (-4 * μ N))
    (hF2R : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      F2R N b ≤ Real.exp (-3 * μ N)) :
    ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      Mb N b
        ≤ ((N : ℝ) / Pz N) * Real.exp (-(1 - (εb N + Real.log 3 / μ N)) * μ N) := by
  rcases Inputs.suenProb_bound_with_carrier_bounds with ⟨K, hK, hbound⟩
  intro N hN hTN b hb
  rcases hbound (μ N) (δb N b) (Δb N b)
      (le_of_lt (hμ N hN hTN)) (hδ_nonneg N hN hTN b hb)
      (hΔ_nonneg N hN hTN b hb) with
    ⟨_htail_pos, _hrange, _hprob_nonneg, _hprob_le_one, _habsolute, htail⟩
  have hbudget := hsuen_tail K hK N hN hTN b hb
  have hεb_nonneg : 0 ≤ εb N := by
    have htail_nonneg :
        0 ≤ K * Δb N b * Real.exp (2 * δb N b) := by
      exact mul_nonneg
        (mul_nonneg (le_of_lt hK) (hΔ_nonneg N hN hTN b hb))
        (le_of_lt (Real.exp_pos _))
    have hmul_nonneg : 0 ≤ εb N * μ N := le_trans htail_nonneg hbudget
    exact nonneg_of_mul_nonneg_left (by simpa [mul_comm] using hmul_nonneg)
      (hμ N hN hTN)
  have hnohit :
      Inputs.suenProb (μ N) (δb N b) (Δb N b)
        ≤ Real.exp (-(1 - εb N) * μ N) := by
    have hexp :
        Real.exp (-μ N + K * Δb N b * Real.exp (2 * δb N b))
          ≤ Real.exp (-(1 - εb N) * μ N) := by
      apply Real.exp_le_exp.mpr
      nlinarith
    exact le_trans htail hexp
  have hNnonneg : 0 ≤ (N : ℝ) := by exact_mod_cast Nat.zero_le N
  exact @finite_transfer (Mb N b) (N : ℝ) (Pz N) (μ N) (Xpow N b)
    (Inputs.suenProb (μ N) (δb N b) (Δb N b)) (errTerm N b) (F2R N b)
    (εb N) εK
    (hμ N hN hTN) (hPz N hN hTN) (hXpow N hN hTN b hb) hNnonneg
    hεb_nonneg (hdecomp N hN hTN b hb) (herr N hN hTN b hb) hεle
    (hlevel N hN hTN b hb) (hF2R N hN hTN b hb) hnohit

/-- Variable-class Suen finite-transfer bridge using the single extracted
standard Suen tail constant.

This is weaker as an interface than
`per_class_transfer_of_suen_finite_transfer_on_range`: the caller only budgets
against `Inputs.suenTailConstant`, the constant actually supplied by the cited
Suen/Janson input, rather than against every positive constant. -/
theorem per_class_transfer_of_suen_finite_transfer_on_range_standard_tail
    {ι : Type*}
    (cls : ℕ → Finset ι)
    (Mb : ℕ → ι → ℝ)
    (Pz μ εb : ℕ → ℝ)
    (δb Δb Xpow errTerm F2R : ℕ → ι → ℝ)
    (εK : ℝ) (T : ℕ)
    (hμ : ∀ N : ℕ, 3 ≤ N → T ≤ N → 0 < μ N)
    (hPz : ∀ N : ℕ, 3 ≤ N → T ≤ N → 1 ≤ Pz N)
    (hδ_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 0 ≤ δb N b)
    (hΔ_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 0 ≤ Δb N b)
    (hXpow : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 0 ≤ Xpow N b)
    (hsuen_tail : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      Inputs.suenTailConstant * Δb N b * Real.exp (2 * δb N b) ≤ εb N * μ N)
    (hdecomp : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      Mb N b ≤ ((N : ℝ) / Pz N) *
        (Inputs.suenProb (μ N) (δb N b) (Δb N b) + F2R N b) + errTerm N b)
    (herr : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      errTerm N b ≤ Xpow N b * Real.exp ((1 + εK) * μ N))
    (hεle : εK ≤ 1)
    (hlevel : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      Pz N * Xpow N b * Real.exp (2 * μ N) ≤ (N : ℝ) * Real.exp (-4 * μ N))
    (hF2R : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      F2R N b ≤ Real.exp (-3 * μ N)) :
    ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      Mb N b
        ≤ ((N : ℝ) / Pz N) * Real.exp (-(1 - (εb N + Real.log 3 / μ N)) * μ N) := by
  intro N hN hTN b hb
  rcases Inputs.suenProb_bound_with_suenTailConstant
      (μ N) (δb N b) (Δb N b)
      (le_of_lt (hμ N hN hTN)) (hδ_nonneg N hN hTN b hb)
      (hΔ_nonneg N hN hTN b hb) with
    ⟨_htail_pos, _hrange, _hprob_nonneg, _hprob_le_one, _habsolute, htail⟩
  have hbudget := hsuen_tail N hN hTN b hb
  have hεb_nonneg : 0 ≤ εb N := by
    have htail_nonneg :
        0 ≤ Inputs.suenTailConstant * Δb N b * Real.exp (2 * δb N b) := by
      exact mul_nonneg
        (mul_nonneg (le_of_lt Inputs.suenTailConstant_pos)
          (hΔ_nonneg N hN hTN b hb))
        (le_of_lt (Real.exp_pos _))
    have hmul_nonneg : 0 ≤ εb N * μ N := le_trans htail_nonneg hbudget
    exact nonneg_of_mul_nonneg_left (by simpa [mul_comm] using hmul_nonneg)
      (hμ N hN hTN)
  have hnohit :
      Inputs.suenProb (μ N) (δb N b) (Δb N b)
        ≤ Real.exp (-(1 - εb N) * μ N) := by
    have hexp :
        Real.exp (-μ N + Inputs.suenTailConstant * Δb N b * Real.exp (2 * δb N b))
          ≤ Real.exp (-(1 - εb N) * μ N) := by
      apply Real.exp_le_exp.mpr
      nlinarith
    exact le_trans htail hexp
  have hNnonneg : 0 ≤ (N : ℝ) := by exact_mod_cast Nat.zero_le N
  exact @finite_transfer (Mb N b) (N : ℝ) (Pz N) (μ N) (Xpow N b)
    (Inputs.suenProb (μ N) (δb N b) (Δb N b)) (errTerm N b) (F2R N b)
    (εb N) εK
    (hμ N hN hTN) (hPz N hN hTN) (hXpow N hN hTN b hb) hNnonneg
    hεb_nonneg (hdecomp N hN hTN b hb) (herr N hN hTN b hb) hεle
    (hlevel N hN hTN b hb) (hF2R N hN hTN b hb) hnohit

/-- Variable-class Suen finite-transfer bridge with the Brun-side coefficient
hypotheses discharged by the concrete finite elementary-symmetric model.

This strengthens `per_class_transfer_of_suen_finite_transfer_on_range_standard_tail`
at the paper-facing natural-number layer: instead of supplying an abstract
`Xpow` envelope for the Brun error and an abstract `F2R ≤ exp(-3 μ)` top-tail
bound, the caller supplies the actual finite coefficient sum
`∑_{r≤2R} X^r e_r(weights)` and the explicit factorial/Stirling top-coefficient
tail.  The no-hit term is still discharged only from the cited Suen/Janson
input through `Inputs.suenTailConstant`. -/

  main_modulo_rough_zero_range_bounds z smooth smoothExp smoothC
    hse_pos hse_lt hsC hsmooth hsmooth_nn hsmooth_range
    (fun N hN =>
      roughLargeCount_eq_zero_of_reducedBase_certificates
        (z N) N (P N) (R N) (cert N)

/-! ## Conditional growing-numerator package

The manuscript's conditional appendix assumes a numerator-uniform saturation
package before proving `thm:uniform-m`.  The declarations below give that
conditional package and its paper-shaped conclusion an explicit Lean surface.
They do not assert the uniform saturation package unconditionally.
-/

/-- Denominator loss in the conditional growing-numerator exponent:
`phi(m) * (m / phi(m))^B`. -/
noncomputable def uniformNumeratorDenominator (B : ℝ) (m : ℕ) : ℝ :=
  (Nat.totient m : ℝ) * ((m : ℝ) / (Nat.totient m : ℝ)) ^ B

/-- The uniform-numerator denominator is positive for every positive numerator.

This discharges the elementary `phi(m)>0` and positive-base `rpow` bookkeeping
behind the denominator loss used in `thm:uniform-m` and `thm:EH-uniform-m`. -/
theorem uniformNumeratorDenominator_pos {B : ℝ} {m : ℕ} (hm : 0 < m) :
    0 < uniformNumeratorDenominator B m := by
  have hphi_pos_nat : 0 < Nat.totient m := Nat.totient_pos.mpr hm
  have hphi_pos : 0 < (Nat.totient m : ℝ) := by
    exact_mod_cast hphi_pos_nat
  have hm_pos : 0 < (m : ℝ) := by
    exact_mod_cast hm
  have hbase_pos : 0 < (m : ℝ) / (Nat.totient m : ℝ) :=
    div_pos hm_pos hphi_pos
  unfold uniformNumeratorDenominator
  exact mul_pos hphi_pos (Real.rpow_pos_of_pos hbase_pos B)

/-- Nonnegative form of `uniformNumeratorDenominator_pos`. -/
theorem uniformNumeratorDenominator_nonneg {B : ℝ} {m : ℕ} (hm : 0 < m) :
    0 ≤ uniformNumeratorDenominator B m :=
  (uniformNumeratorDenominator_pos (B := B) hm).le

/-- Conditional saving appearing in `thm:uniform-m`. -/
noncomputable def uniformNumeratorSaving (c B : ℝ) (m N : ℕ) : ℝ :=
  Real.exp
    (-(c * (Real.log N) ^ ((3 : ℝ) / 4) / uniformNumeratorDenominator B m))

/-- The conditional growing-numerator saving is always positive. -/
theorem uniformNumeratorSaving_pos (c B : ℝ) (m N : ℕ) :
    0 < uniformNumeratorSaving c B m N := by
  unfold uniformNumeratorSaving
  exact Real.exp_pos _

/-- For nonnegative `B`, the denominator loss is at least one.  Thus increasing
the numerator does not make the conditional saving smaller than the base
one-variable saving. -/
theorem one_le_uniformNumeratorDenominator {B : ℝ} (hB : 0 ≤ B)
    {m : ℕ} (hm : 0 < m) :
    1 ≤ uniformNumeratorDenominator B m := by
  have hphi_pos_nat : 0 < Nat.totient m := Nat.totient_pos.mpr hm
  have hphi_one_nat : 1 ≤ Nat.totient m := Nat.succ_le_of_lt hphi_pos_nat
  have hphi_one : (1 : ℝ) ≤ (Nat.totient m : ℝ) := by
    exact_mod_cast hphi_one_nat
  have hphi_pos : 0 < (Nat.totient m : ℝ) := by
    exact_mod_cast hphi_pos_nat
  have hphi_le_nat : (Nat.totient m : ℝ) ≤ (m : ℝ) := by
    exact_mod_cast Nat.totient_le m
  have hbase_one : (1 : ℝ) ≤ (m : ℝ) / (Nat.totient m : ℝ) := by
    rw [le_div_iff₀ hphi_pos]
    simpa using hphi_le_nat
  have hpow_one : (1 : ℝ) ≤ ((m : ℝ) / (Nat.totient m : ℝ)) ^ B :=
    Real.one_le_rpow hbase_one hB
  unfold uniformNumeratorDenominator
  calc
    (1 : ℝ) = (1 : ℝ) * 1 := by ring
    _ ≤ (Nat.totient m : ℝ) * (((m : ℝ) / (Nat.totient m : ℝ)) ^ B) :=
      mul_le_mul hphi_one hpow_one zero_le_one (le_trans zero_le_one hphi_one)

/-- The uniform-numerator saving dominates the base one-variable saving whenever
`B` is positive and `m >= 1`. -/
theorem saving_le_uniformNumeratorSaving
    {c B : ℝ} {m N : ℕ}
    (hc : 0 < c) (hB : 0 < B) (hN : 3 ≤ N) (hm : 0 < m) :
    saving c N ≤ uniformNumeratorSaving c B m N := by
  set L : ℝ := Real.log N with hLdef
  set D : ℝ := uniformNumeratorDenominator B m with hDdef
  set a : ℝ := c * L ^ ((3 : ℝ) / 4) with hadef
  have hLpos : 0 < L := by
    rw [hLdef]
    exact log_pos_of_three_le hN
  have ha_nonneg : 0 ≤ a := by
    rw [hadef]
    exact mul_nonneg hc.le (Real.rpow_pos_of_pos hLpos _).le
  have hDone : 1 ≤ D := by
    rw [hDdef]
    exact one_le_uniformNumeratorDenominator hB.le hm
  have hDpos : 0 < D := lt_of_lt_of_le zero_lt_one hDone
  have hdiv : a / D ≤ a := by
    rw [div_le_iff₀ hDpos]
    exact le_mul_of_one_le_right ha_nonneg hDone
  have hexp : Real.exp (-a) ≤ Real.exp (-(a / D)) :=
    Real.exp_le_exp.mpr (neg_le_neg hdiv)
  simpa [saving, uniformNumeratorSaving, hLdef, hDdef, hadef, L, D, a,
    neg_mul] using hexp

/-- The finite initial range for the uniform-numerator estimate is absorbed by
the same one-variable constant-enlargement argument as the main reduced-count
bound.  The denominator lower bound makes the estimate uniform in `m`. -/
theorem finite_initial_uniformNumerator_bound
    {c B : ℝ} (hc : 0 < c) (hB : 0 < B) (T : ℕ) :
    ∃ Cinit : ℝ, 0 < Cinit ∧
      ∀ N m : ℕ, 3 ≤ N → N < T → 2 ≤ m →
        (fixedNumeratorExceptionalCount m N : ℝ) ≤
          Cinit * (N : ℝ) * uniformNumeratorSaving c B m N := by
  rcases finite_initial_saving_bound (fun N : ℕ => N) hc T with
    ⟨Cinit, hCinit, hinit⟩
  refine ⟨Cinit, hCinit, ?_⟩
  intro N m hN hNT hm
  have hcount : (fixedNumeratorExceptionalCount m N : ℝ) ≤ (N : ℝ) := by
    exact_mod_cast fixedNumeratorExceptionalCount_le_self m N
  have hbase : (N : ℝ) ≤ Cinit * ((N : ℝ) * saving c N) := by
    simpa using hinit N hN hNT
  have hsaving : saving c N ≤ uniformNumeratorSaving c B m N :=
    saving_le_uniformNumeratorSaving hc hB hN (lt_of_lt_of_le (by decide : 0 < 2) hm)
  have hfactor_nonneg : 0 ≤ Cinit * (N : ℝ) :=
    mul_nonneg hCinit.le (Nat.cast_nonneg N)
  calc
    (fixedNumeratorExceptionalCount m N : ℝ)
        ≤ (N : ℝ) := hcount
    _ ≤ Cinit * ((N : ℝ) * saving c N) := hbase
    _ = (Cinit * (N : ℝ)) * saving c N := by ring
    _ ≤ (Cinit * (N : ℝ)) * uniformNumeratorSaving c B m N :=
        mul_le_mul_of_nonneg_left hsaving hfactor_nonneg
    _ = Cinit * (N : ℝ) * uniformNumeratorSaving c B m N := by ring

/-- Paper-shaped Lean carrier for `hyp:uniform-m-saturation` after the
finite-transfer and smooth-lifting assembly steps.  For each fixed logarithmic
range `A`, it provides constants uniform for `2 <= m <= (log N)^A`. -/
structure UniformNumeratorSaturationInputs (A : ℝ) where
  c : ℝ
  C : ℝ
  B : ℝ
  c_pos : 0 < c
  C_pos : 0 < C
  B_pos : 0 < B
  bound : ∀ N m : ℕ, 3 ≤ N → 2 ≤ m → (m : ℝ) ≤ (Real.log N) ^ A →
    (fixedNumeratorExceptionalCount m N : ℝ) ≤
      C * (N : ℝ) * uniformNumeratorSaving c B m N

/-- Build the fixed-log uniform-saturation package from a large-range estimate.

This removes the finite-initial range from the hard part of
`hyp:uniform-m-saturation`: once a uniform numerator estimate is known for
`N >= T`, the finitely many smaller `N` are absorbed by
`finite_initial_uniformNumerator_bound`, uniformly in `m`. -/
noncomputable def uniformNumeratorSaturationInputs_of_eventual_bound
    {A c C B : ℝ} (hc : 0 < c) (hC : 0 < C) (hB : 0 < B) (T : ℕ)
    (hlarge : ∀ N m : ℕ, 3 ≤ N → T ≤ N → 2 ≤ m →
      (m : ℝ) ≤ (Real.log N) ^ A →
        (fixedNumeratorExceptionalCount m N : ℝ) ≤
          C * (N : ℝ) * uniformNumeratorSaving c B m N) :
    UniformNumeratorSaturationInputs A := by
  let hinit_exists := finite_initial_uniformNumerator_bound hc hB T
  let Cinit := Classical.choose hinit_exists
  have hCinit_spec :
      0 < Cinit ∧
        ∀ N m : ℕ, 3 ≤ N → N < T → 2 ≤ m →
          (fixedNumeratorExceptionalCount m N : ℝ) ≤
            Cinit * (N : ℝ) * uniformNumeratorSaving c B m N :=
    Classical.choose_spec hinit_exists
  exact
    { c := c
      C := max C Cinit
      B := B
      c_pos := hc
      C_pos := lt_of_lt_of_le hC (le_max_left C Cinit)
      B_pos := hB
      bound := by
        intro N m hN hm hm_log
        have hN_nonneg : 0 ≤ (N : ℝ) := Nat.cast_nonneg N
        have hsaving_nonneg : 0 ≤ uniformNumeratorSaving c B m N :=
          (uniformNumeratorSaving_pos c B m N).le
        by_cases hTN : T ≤ N
        · have hC_N :
            C * (N : ℝ) ≤ max C Cinit * (N : ℝ) :=
            mul_le_mul_of_nonneg_right (le_max_left C Cinit) hN_nonneg
          exact le_trans (hlarge N m hN hTN hm hm_log)
            (mul_le_mul_of_nonneg_right hC_N hsaving_nonneg)
        · have hNT : N < T := Nat.lt_of_not_ge hTN
          have hC_N :
            Cinit * (N : ℝ) ≤ max C Cinit * (N : ℝ) :=
            mul_le_mul_of_nonneg_right (le_max_right C Cinit) hN_nonneg
          exact le_trans (hCinit_spec.2 N m hN hNT hm)
            (mul_le_mul_of_nonneg_right hC_N hsaving_nonneg) }

/-- Exact large-range hard core of `hyp:uniform-m-saturation` for one fixed
logarithmic range.  The finite initial segment is deliberately not part of this
record: it is discharged by `uniformNumeratorSaturationInputs_of_eventual_bound`.
-/
structure UniformNumeratorLargeRangeInputs (A : ℝ) where
  c : ℝ
  C : ℝ
  B : ℝ
  T : ℕ
  c_pos : 0 < c
  C_pos : 0 < C
  B_pos : 0 < B
  large_bound : ∀ N m : ℕ, 3 ≤ N → T ≤ N → 2 ≤ m →
    (m : ℝ) ≤ (Real.log N) ^ A →
      (fixedNumeratorExceptionalCount m N : ℝ) ≤
        C * (N : ℝ) * uniformNumeratorSaving c B m N

/-- The denominator-loss comparison needed for the uniform-numerator range.

If a fixed-numerator exceptional count has a base `saving c N` bound with
constants independent of `m`, then the same bound holds with the weaker
uniform-numerator saving factor. -/
theorem uniform_base_saving_bound_le_uniformNumeratorSaving
    {c C B : ℝ} {N m : ℕ}
    (hc : 0 < c) (hC : 0 < C) (hB : 0 < B) (hN : 3 ≤ N) (hm : 2 ≤ m)
    (hbound :
      (fixedNumeratorExceptionalCount m N : ℝ) ≤ C * (N : ℝ) * saving c N) :
    (fixedNumeratorExceptionalCount m N : ℝ) ≤
      C * (N : ℝ) * uniformNumeratorSaving c B m N := by
  have hsaving :
      saving c N ≤ uniformNumeratorSaving c B m N :=
    saving_le_uniformNumeratorSaving hc hB hN
      (lt_of_lt_of_le (by decide : 0 < 2) hm)
  have hfactor_nonneg : 0 ≤ C * (N : ℝ) :=
    mul_nonneg hC.le (Nat.cast_nonneg N)
  exact le_trans hbound (mul_le_mul_of_nonneg_left hsaving hfactor_nonneg)

/-- A uniform family of base fixed-numerator saving bounds supplies the exact
large-range uniform-numerator hard core.

This is the algebraic bridge from fixed-`m` saving estimates to the denominator
loss used in `thm:uniform-m`: once the constants are uniform in
`2 <= m <= (log N)^A`, the base saving `saving c N` is dominated by
`uniformNumeratorSaving c B m N`.  Thus the remaining hard content is the
uniform-in-`m` production of the base fixed-numerator estimate, not this
denominator bookkeeping. -/
noncomputable def UniformNumeratorLargeRangeInputs.of_uniform_base_saving_bound
    {A c C B : ℝ} (T : ℕ)
    (hc : 0 < c) (hC : 0 < C) (hB : 0 < B)
    (hlarge : ∀ N m : ℕ, 3 ≤ N → T ≤ N → 2 ≤ m →
      (m : ℝ) ≤ (Real.log N) ^ A →
        (fixedNumeratorExceptionalCount m N : ℝ) ≤
          C * (N : ℝ) * saving c N) :
    UniformNumeratorLargeRangeInputs A :=
  { c := c
    C := C
    B := B
    T := T
    c_pos := hc
    C_pos := hC
    B_pos := hB
    large_bound := by
      intro N m hN hTN hm hm_log
      exact uniform_base_saving_bound_le_uniformNumeratorSaving
        hc hC hB hN hm (hlarge N m hN hTN hm hm_log) }

/-- Uniform final-assembly bridge for `hyp:uniform-m-saturation`.

This is the growing-numerator analogue of the last fixed-`m` absorption step:
if the reduced count, smooth range, Euler loss, and lift inequalities are all
available with one common set of constants throughout the admissible numerator
range, then the exact large-range uniform-numerator hard core follows.  Thus the
remaining mathematical work is the production of those common upstream estimates,
not the final smoothing/Euler/denominator-loss assembly. -/
noncomputable def UniformNumeratorLargeRangeInputs.of_uniform_final_assembly
    {A Ered_c₁ Ered_C₁ smoothExp smoothC eulerC B : ℝ} (T : ℕ)
    (hEred_c₁ : 0 < Ered_c₁) (hEred_C₁ : 0 < Ered_C₁)
    (hsmoothExp_pos : 0 < smoothExp) (hsmoothExp_lt_one : smoothExp < 1)
    (hsmoothC_pos : 0 < smoothC) (heulerC_pos : 0 < eulerC)
    (hB : 0 < B)
    (Ered : ℕ → ℕ → ℕ) (smooth euler : ℕ → ℕ → ℝ)
    (hEred : ∀ N m : ℕ, 3 ≤ N → T ≤ N → 2 ≤ m →
      (m : ℝ) ≤ (Real.log N) ^ A →
        (Ered m N : ℝ) ≤ Ered_C₁ * ((N : ℝ) * saving Ered_c₁ N))
    (hsmooth : ∀ N m : ℕ, 3 ≤ N → T ≤ N → 2 ≤ m →
      (m : ℝ) ≤ (Real.log N) ^ A →
        smooth m N ≤ smoothC * (N : ℝ) ^ smoothExp)
    (heuler : ∀ N m : ℕ, 3 ≤ N → T ≤ N → 2 ≤ m →
      (m : ℝ) ≤ (Real.log N) ^ A →
        euler m N ≤ eulerC * (Real.log N) ^ (4 : ℕ))
    (hlift : ∀ N m : ℕ, 3 ≤ N → T ≤ N → 2 ≤ m →
      (m : ℝ) ≤ (Real.log N) ^ A →
        (fixedNumeratorExceptionalCount m N : ℝ) ≤
          smooth m N + euler m N * (Ered m N : ℝ)) :
    UniformNumeratorLargeRangeInputs A := by
  let cs : ℝ :=
    Classical.choose (poly_absorb hsmoothExp_pos hsmoothExp_lt_one hsmoothC_pos)
  have hpoly_cs :
      cs > (0 : ℝ) ∧ ∃ C > (0 : ℝ),
        ∀ N : ℕ, 3 ≤ N →
          smoothC * (N : ℝ) ^ smoothExp ≤ C * ((N : ℝ) * saving cs N) :=
    Classical.choose_spec (poly_absorb hsmoothExp_pos hsmoothExp_lt_one hsmoothC_pos)
  let Cs : ℝ := Classical.choose hpoly_cs.2
  have hpoly_Cs :
      Cs > (0 : ℝ) ∧
        ∀ N : ℕ, 3 ≤ N →
          smoothC * (N : ℝ) ^ smoothExp ≤ Cs * ((N : ℝ) * saving cs N) :=
    Classical.choose_spec hpoly_cs.2
  let ce : ℝ :=
    Classical.choose (log_pow_four_absorb hEred_c₁ heulerC_pos hEred_C₁)
  have hlog_ce :
      ce > (0 : ℝ) ∧ ∃ C > (0 : ℝ),
        ∀ N : ℕ, 3 ≤ N →
          eulerC * (Real.log N) ^ (4 : ℕ) *
              (Ered_C₁ * ((N : ℝ) * saving Ered_c₁ N))
            ≤ C * ((N : ℝ) * saving ce N) :=
    Classical.choose_spec (log_pow_four_absorb hEred_c₁ heulerC_pos hEred_C₁)
  let Ce : ℝ := Classical.choose hlog_ce.2
  have hlog_Ce :
      Ce > (0 : ℝ) ∧
        ∀ N : ℕ, 3 ≤ N →
          eulerC * (Real.log N) ^ (4 : ℕ) *
              (Ered_C₁ * ((N : ℝ) * saving Ered_c₁ N))
            ≤ Ce * ((N : ℝ) * saving ce N) :=
    Classical.choose_spec hlog_ce.2
  have hcs : 0 < cs := hpoly_cs.1
  have hCs : 0 < Cs := hpoly_Cs.1
  have hce : 0 < ce := hlog_ce.1
  have hCe : 0 < Ce := hlog_Ce.1
  have hpoly := hpoly_Cs.2
  have hlog := hlog_Ce.2
  set c : ℝ := min cs ce with hcdef
  have hc : 0 < c := lt_min hcs hce
  have hC : 0 < Cs + Ce := add_pos hCs hCe
  have sav_mono : ∀ (c' : ℝ), c ≤ c' → ∀ N : ℕ, 3 ≤ N →
      (N : ℝ) * saving c' N ≤ (N : ℝ) * saving c N := by
    intro c' hcc' N hN
    have hLpos : 0 < Real.log N := log_pos_of_three_le hN
    have hL34 : 0 ≤ (Real.log N) ^ ((3 : ℝ) / 4) :=
      (Real.rpow_pos_of_pos hLpos _).le
    have hNpos : (0 : ℝ) ≤ N := by positivity
    apply mul_le_mul_of_nonneg_left _ hNpos
    unfold saving
    apply Real.exp_le_exp.mpr
    exact mul_le_mul_of_nonneg_right (by linarith : -c' ≤ -c) hL34
  refine
    { c := c
      C := Cs + Ce
      B := B
      T := T
      c_pos := hc
      C_pos := hC
      B_pos := hB
      large_bound := ?_ }
  intro N m hN hTN hm hm_log
  have hbase :
      (fixedNumeratorExceptionalCount m N : ℝ) ≤
        (Cs + Ce) * (N : ℝ) * saving c N := by
    have hliftN := hlift N m hN hTN hm hm_log
    have hsmooth_le :
        smooth m N ≤ Cs * ((N : ℝ) * saving c N) := by
      have h1 := hsmooth N m hN hTN hm hm_log
      have h2 := hpoly N hN
      have h3 : (N : ℝ) * saving cs N ≤ (N : ℝ) * saving c N :=
        sav_mono cs (by rw [hcdef]; exact min_le_left _ _) N hN
      calc
        smooth m N ≤ smoothC * (N : ℝ) ^ smoothExp := h1
        _ ≤ Cs * ((N : ℝ) * saving cs N) := h2
        _ ≤ Cs * ((N : ℝ) * saving c N) :=
          mul_le_mul_of_nonneg_left h3 hCs.le
    have hreduced_le :
        euler m N * (Ered m N : ℝ) ≤
          Ce * ((N : ℝ) * saving c N) := by
      have heu := heuler N m hN hTN hm hm_log
      have hEr := hEred N m hN hTN hm hm_log
      have hEr0 : (0 : ℝ) ≤ (Ered m N : ℝ) := by positivity
      have hlog_nonneg : 0 ≤ Real.log N := (log_pos_of_three_le hN).le
      have step1 :
          euler m N * (Ered m N : ℝ)
            ≤ (eulerC * (Real.log N) ^ (4 : ℕ)) *
                (Ered_C₁ * ((N : ℝ) * saving Ered_c₁ N)) := by
        apply mul_le_mul heu hEr hEr0
        exact mul_nonneg heulerC_pos.le (pow_nonneg hlog_nonneg 4)
      have step2 :
          (eulerC * (Real.log N) ^ (4 : ℕ)) *
              (Ered_C₁ * ((N : ℝ) * saving Ered_c₁ N))
            ≤ Ce * ((N : ℝ) * saving ce N) := by
        simpa [mul_assoc] using hlog N hN
      have step3 : (N : ℝ) * saving ce N ≤ (N : ℝ) * saving c N :=
        sav_mono ce (by rw [hcdef]; exact min_le_right _ _) N hN
      calc
        euler m N * (Ered m N : ℝ)
            ≤ (eulerC * (Real.log N) ^ (4 : ℕ)) *
                (Ered_C₁ * ((N : ℝ) * saving Ered_c₁ N)) := step1
        _ ≤ Ce * ((N : ℝ) * saving ce N) := step2
        _ ≤ Ce * ((N : ℝ) * saving c N) :=
          mul_le_mul_of_nonneg_left step3 hCe.le
    calc
      (fixedNumeratorExceptionalCount m N : ℝ)
          ≤ smooth m N + euler m N * (Ered m N : ℝ) := hliftN
      _ ≤ Cs * ((N : ℝ) * saving c N) +
            Ce * ((N : ℝ) * saving c N) :=
          add_le_add hsmooth_le hreduced_le
      _ = (Cs + Ce) * ((N : ℝ) * saving c N) := by ring
      _ = (Cs + Ce) * (N : ℝ) * saving c N := by ring
  exact uniform_base_saving_bound_le_uniformNumeratorSaving
    hc hC hB hN hm hbase

/-- Uniform final assembly with the finite fixed-numerator lift discharged.

This variant exposes the actual smooth-range and reduced-sum estimates used by
the fixed-numerator lift, and proves the old `hlift` premise internally via
`fixedNumerator_lift_of_smooth_and_reduced_sum_bounds`.  Thus the
uniform-saturation surface no longer needs to carry the already-formalized
finite lifting inequality as an independent hypothesis. -/
noncomputable def UniformNumeratorLargeRangeInputs.of_uniform_final_assembly_reduced_sum_lift
    {A Ered_c₁ Ered_C₁ smoothExp smoothC eulerC B : ℝ} (T : ℕ)
    (hEred_c₁ : 0 < Ered_c₁) (hEred_C₁ : 0 < Ered_C₁)
    (hsmoothExp_pos : 0 < smoothExp) (hsmoothExp_lt_one : smoothExp < 1)
    (hsmoothC_pos : 0 < smoothC) (heulerC_pos : 0 < eulerC)
    (hB : 0 < B)
    (Ered : ℕ → ℕ → ℕ) (smooth euler : ℕ → ℕ → ℝ)
    (z : ℕ → ℕ → ℕ)
    (hEred : ∀ N m : ℕ, 3 ≤ N → T ≤ N → 2 ≤ m →
      (m : ℝ) ≤ (Real.log N) ^ A →
        (Ered m N : ℝ) ≤ Ered_C₁ * ((N : ℝ) * saving Ered_c₁ N))
    (hsmooth : ∀ N m : ℕ, 3 ≤ N → T ≤ N → 2 ≤ m →
      (m : ℝ) ≤ (Real.log N) ^ A →
        smooth m N ≤ smoothC * (N : ℝ) ^ smoothExp)
    (heuler : ∀ N m : ℕ, 3 ≤ N → T ≤ N → 2 ≤ m →
      (m : ℝ) ≤ (Real.log N) ^ A →
        euler m N ≤ eulerC * (Real.log N) ^ (4 : ℕ))
    (hsmooth_count : ∀ N m : ℕ, 3 ≤ N → T ≤ N → 2 ≤ m →
      (m : ℝ) ≤ (Real.log N) ^ A →
        (fixedNumeratorSmoothRangeCount m (z m N) N : ℝ) ≤ smooth m N)
    (hreduced_sum : ∀ N m : ℕ, 3 ≤ N → T ≤ N → 2 ≤ m →
      (m : ℝ) ≤ (Real.log N) ^ A →
        ((∑ s ∈ Finset.Icc 1 N,
          fixedNumeratorReducedExceptionalCount m (z m N) (N / s)) : ℝ)
            ≤ euler m N * (Ered m N : ℝ)) :
    UniformNumeratorLargeRangeInputs A :=
  UniformNumeratorLargeRangeInputs.of_uniform_final_assembly
    T hEred_c₁ hEred_C₁ hsmoothExp_pos hsmoothExp_lt_one hsmoothC_pos
    heulerC_pos hB Ered smooth euler hEred hsmooth heuler
    (by
      intro N m hN hTN hm hm_log
      exact fixedNumerator_lift_of_smooth_and_reduced_sum_bounds
        (m := m) (z := z m N) (N := N) (smooth := smooth m N)
        (euler := euler m N) (Ered := (Ered m N : ℝ))
        (hsmooth_count N m hN hTN hm hm_log)
        (hreduced_sum N m hN hTN hm hm_log))

/-- Convert the exact large-range uniform-numerator hard core into the global
fixed-log saturation package by absorbing only the finite initial range. -/
noncomputable def UniformNumeratorLargeRangeInputs.toSaturationInputs
    {A : ℝ} (H : UniformNumeratorLargeRangeInputs A) :
    UniformNumeratorSaturationInputs A :=
  uniformNumeratorSaturationInputs_of_eventual_bound
    H.c_pos H.C_pos H.B_pos H.T H.large_bound

/-- **`thm:uniform-m` (conditional Lean form).** Given the numerator-uniform
saturation package for every fixed logarithmic range, the paper's
growing-numerator exceptional-set estimate follows with explicit constants. -/
theorem thm_uniform_m
    (H : ∀ A : ℝ, 0 < A → UniformNumeratorSaturationInputs A) :
    ∀ A : ℝ, 0 < A →
      ∃ c > (0 : ℝ), ∃ C > (0 : ℝ), ∃ B > (0 : ℝ),
        ∀ N m : ℕ, 3 ≤ N → 2 ≤ m → (m : ℝ) ≤ (Real.log N) ^ A →
          (fixedNumeratorExceptionalCount m N : ℝ) ≤
            C * (N : ℝ) * uniformNumeratorSaving c B m N := by
  intro A hA
  let U := H A hA
  exact ⟨U.c, U.c_pos, U.C, U.C_pos, U.B, U.B_pos, U.bound⟩

/-- Fixed-log uniform theorem from the exact large-range hard core.  This is a
paper-facing way to state what remains after all finite-initial bookkeeping has
been removed. -/
theorem thm_uniform_m_of_largeRangeInputs
    (H : ∀ A : ℝ, 0 < A → UniformNumeratorLargeRangeInputs A) :
    ∀ A : ℝ, 0 < A →
      ∃ c > (0 : ℝ), ∃ C > (0 : ℝ), ∃ B > (0 : ℝ),
        ∀ N m : ℕ, 3 ≤ N → 2 ≤ m → (m : ℝ) ≤ (Real.log N) ^ A →
          (fixedNumeratorExceptionalCount m N : ℝ) ≤
            C * (N : ℝ) * uniformNumeratorSaving c B m N :=
  thm_uniform_m (fun A hA => (H A hA).toSaturationInputs)

/-- Exponential saving with a general logarithmic power, used for the
`in particular` clause of the Elliott-Halberstam conditional variant. -/
noncomputable def logPowerSaving (c η : ℝ) (N : ℕ) : ℝ :=
  Real.exp (-c * (Real.log N) ^ η)

/-- If the denominator loss in the uniform-numerator saving is at most
`(log N)^(3/4 - η)`, then the saving implies the displayed `η`-power
exponential saving. -/
theorem uniformNumeratorSaving_le_logPowerSaving_of_denominator_le
    {c B η : ℝ} {m N : ℕ}
    (hc : 0 < c) (hN : 3 ≤ N) (hm : 2 ≤ m)
    (hden : uniformNumeratorDenominator B m ≤
      (Real.log N) ^ ((3 : ℝ) / 4 - η)) :
    uniformNumeratorSaving c B m N ≤ logPowerSaving c η N := by
  set L : ℝ := Real.log N with hLdef
  have hLpos : 0 < L := by
    rw [hLdef]
    exact log_pos_of_three_le hN
  have hDpos : 0 < uniformNumeratorDenominator B m :=
    uniformNumeratorDenominator_pos (B := B) (by omega : 0 < m)
  have hPpos : 0 < L ^ ((3 : ℝ) / 4 - η) :=
    Real.rpow_pos_of_pos hLpos _
  have hL34_nonneg : 0 ≤ L ^ ((3 : ℝ) / 4) :=
    (Real.rpow_pos_of_pos hLpos _).le
  have hdenL : uniformNumeratorDenominator B m ≤ L ^ ((3 : ℝ) / 4 - η) := by
    simpa [hLdef] using hden
  have hmul :
      L ^ η * L ^ ((3 : ℝ) / 4 - η) = L ^ ((3 : ℝ) / 4) := by
    rw [← Real.rpow_add hLpos]
    ring_nf
  have hLeta_eq :
      L ^ η = L ^ ((3 : ℝ) / 4) / L ^ ((3 : ℝ) / 4 - η) := by
    calc
      L ^ η = (L ^ η * L ^ ((3 : ℝ) / 4 - η)) /
          L ^ ((3 : ℝ) / 4 - η) := by
            field_simp [ne_of_gt hPpos]
      _ = L ^ ((3 : ℝ) / 4) / L ^ ((3 : ℝ) / 4 - η) := by
            rw [hmul]
  have hpow_div :
      L ^ η ≤ L ^ ((3 : ℝ) / 4) / uniformNumeratorDenominator B m := by
    rw [hLeta_eq]
    exact div_le_div_of_nonneg_left hL34_nonneg hDpos hdenL
  have hscaled :
      c * L ^ η ≤ c * L ^ ((3 : ℝ) / 4) /
        uniformNumeratorDenominator B m := by
    calc
      c * L ^ η
          ≤ c * (L ^ ((3 : ℝ) / 4) / uniformNumeratorDenominator B m) :=
            mul_le_mul_of_nonneg_left hpow_div hc.le
      _ = c * L ^ ((3 : ℝ) / 4) / uniformNumeratorDenominator B m := by
            ring
  have hexp :
      -(c * L ^ ((3 : ℝ) / 4) / uniformNumeratorDenominator B m)
        ≤ -c * L ^ η := by
    linarith
  simpa [uniformNumeratorSaving, logPowerSaving, hLdef, L] using
    Real.exp_le_exp.mpr hexp

/-! ## Conditional reciprocal Elliott--Halberstam route -/

/-- Paper-facing carrier for `hyp:reciprocal-EH`.

This is the reciprocal-prime, divisor-weighted Elliott--Halberstam input in the
same `weightedBVSum` carrier used for `lem:weightedBV`, but with every level
`θ < 1` instead of the Bombieri--Vinogradov `1/2 - ε` range.  It is deliberately
kept separate from the assembled exceptional-set package below, so the
conditional theorem exposes the actual paper hypothesis rather than a nameless
final estimate. -/
def ReciprocalElliottHalberstamInput : Prop :=
  ∀ P : EscAnalytic.Params, ∀ θ A Cw : ℝ,
    θ < 1 → 0 < A → 0 ≤ Cw →
      ∃ K X₀ : ℝ, 0 < K ∧ ∀ X : ℝ, X₀ ≤ X →
        |Inputs.weightedBVSum P X Cw θ| ≤ K * (Real.log X) ^ (-A)

/-- The paper-facing reciprocal-EH carrier is exactly the same divisor-weighted
reciprocal-prime BV carrier named in `EscAnalytic.Inputs`.  This bridge removes
any duplicate local hypothesis shape: proving the cited same-carrier input is
precisely enough to supply `hyp:reciprocal-EH`. -/
theorem reciprocalElliottHalberstamInput_of_weightedBVSameCarrier
    (H : Inputs.ReciprocalElliottHalberstamWeightedBVSameCarrier) :
    ReciprocalElliottHalberstamInput := by
  intro P θ A Cw hθ hA hCw
  exact H P θ A Cw hθ hA hCw

/-- Conversely, the local paper carrier supplies the named same-carrier
reciprocal-EH input from `EscAnalytic.Inputs`. -/
theorem weightedBVSameCarrier_of_reciprocalElliottHalberstamInput
    (H : ReciprocalElliottHalberstamInput) :
    Inputs.ReciprocalElliottHalberstamWeightedBVSameCarrier := by
  intro P θ A Cw hθ hA hCw
  exact H P θ A Cw hθ hA hCw

/-- Paper-shaped Lean carrier for the combined reciprocal-Elliott-Halberstam
and uniform-saturation hypotheses in `thm:EH-uniform-m`. -/
structure EHUniformNumeratorInputs where
  κ : ℝ
  c : ℝ
  C : ℝ
  B : ℝ
  κ_pos : 0 < κ
  c_pos : 0 < c
  C_pos : 0 < C
  B_pos : 0 < B
  bound : ∀ N m : ℕ, 3 ≤ N → 2 ≤ m →
    (m : ℝ) ≤ Real.exp (κ * (Real.log N) ^ ((1 : ℝ) / 4)) →
      (fixedNumeratorExceptionalCount m N : ℝ) ≤
        C * (N : ℝ) * uniformNumeratorSaving c B m N

/-- Build the EH numerator package from its exact large-range hard core.

The finite initial range is absorbed into the implied constant, just as in the
fixed-logarithmic uniform-numerator package.  Thus callers can expose only the
eventual exponential-range estimate as hard analytic content. -/
noncomputable def EHUniformNumeratorInputs.of_eventual_bound
    {κ c C B : ℝ} (T : ℕ)
    (hκ : 0 < κ) (hc : 0 < c) (hC : 0 < C) (hB : 0 < B)
    (hlarge : ∀ N m : ℕ, 3 ≤ N → T ≤ N → 2 ≤ m →
      (m : ℝ) ≤ Real.exp (κ * (Real.log N) ^ ((1 : ℝ) / 4)) →
        (fixedNumeratorExceptionalCount m N : ℝ) ≤
          C * (N : ℝ) * uniformNumeratorSaving c B m N) :
    EHUniformNumeratorInputs := by
  let hinit_exists := finite_initial_uniformNumerator_bound hc hB T
  let Cinit := Classical.choose hinit_exists
  have hCinit_spec :
      0 < Cinit ∧
        ∀ N m : ℕ, 3 ≤ N → N < T → 2 ≤ m →
          (fixedNumeratorExceptionalCount m N : ℝ) ≤
            Cinit * (N : ℝ) * uniformNumeratorSaving c B m N :=
    Classical.choose_spec hinit_exists
  exact
    { κ := κ
      c := c
      C := max C Cinit
      B := B
      κ_pos := hκ
      c_pos := hc
      C_pos := lt_of_lt_of_le hC (le_max_left C Cinit)
      B_pos := hB
      bound := by
        intro N m hN hm hm_range
        have hN_nonneg : 0 ≤ (N : ℝ) := Nat.cast_nonneg N
        have hsaving_nonneg : 0 ≤ uniformNumeratorSaving c B m N :=
          (uniformNumeratorSaving_pos c B m N).le
        by_cases hTN : T ≤ N
        · have hC_N :
            C * (N : ℝ) ≤ max C Cinit * (N : ℝ) :=
            mul_le_mul_of_nonneg_right (le_max_left C Cinit) hN_nonneg
          exact le_trans (hlarge N m hN hTN hm hm_range)
            (mul_le_mul_of_nonneg_right hC_N hsaving_nonneg)
        · have hNT : N < T := Nat.lt_of_not_ge hTN
          have hC_N :
            Cinit * (N : ℝ) ≤ max C Cinit * (N : ℝ) :=
            mul_le_mul_of_nonneg_right (le_max_right C Cinit) hN_nonneg
          exact le_trans (hCinit_spec.2 N m hN hNT hm)
            (mul_le_mul_of_nonneg_right hC_N hsaving_nonneg) }

/-- Build the EH numerator package from an exponential-range base-saving bound.

This discharges the denominator-loss conversion theorem-level: a uniform
`saving c N` estimate over the EH numerator range implies the weaker
`uniformNumeratorSaving c B m N` estimate. -/
noncomputable def EHUniformNumeratorInputs.of_uniform_base_saving_bound
    {κ c C B : ℝ} (T : ℕ)
    (hκ : 0 < κ) (hc : 0 < c) (hC : 0 < C) (hB : 0 < B)
    (hlarge : ∀ N m : ℕ, 3 ≤ N → T ≤ N → 2 ≤ m →
      (m : ℝ) ≤ Real.exp (κ * (Real.log N) ^ ((1 : ℝ) / 4)) →
        (fixedNumeratorExceptionalCount m N : ℝ) ≤
          C * (N : ℝ) * saving c N) :
    EHUniformNumeratorInputs :=
  EHUniformNumeratorInputs.of_eventual_bound T hκ hc hC hB
    (by
      intro N m hN hTN hm hm_range
      exact uniform_base_saving_bound_le_uniformNumeratorSaving
        hc hC hB hN hm (hlarge N m hN hTN hm hm_range))

/-- The `almost all` clause of the EH uniform-numerator theorem is an algebraic
consequence of the main EH uniform bound plus the displayed denominator
condition. -/
theorem EHUniformNumeratorInputs.almost_all_of_bound
    (H : EHUniformNumeratorInputs) :
    ∀ η : ℝ, 0 < η →
      ∃ cη > (0 : ℝ), ∃ Cη > (0 : ℝ), ∀ N m : ℕ, 3 ≤ N → 2 ≤ m →
        (m : ℝ) ≤ Real.exp (H.κ * (Real.log N) ^ ((1 : ℝ) / 4)) →
        uniformNumeratorDenominator H.B m ≤ (Real.log N) ^ ((3 : ℝ) / 4 - η) →
          (fixedNumeratorExceptionalCount m N : ℝ) ≤
            Cη * (N : ℝ) * logPowerSaving cη η N := by
  intro η _hη
  refine ⟨H.c, H.c_pos, H.C, H.C_pos, ?_⟩
  intro N m hN hm hm_range hden
  have hbound := H.bound N m hN hm hm_range
  have hsaving :=
    uniformNumeratorSaving_le_logPowerSaving_of_denominator_le
      (c := H.c) (B := H.B) (η := η) H.c_pos hN hm hden
  have hfactor_nonneg : 0 ≤ H.C * (N : ℝ) :=
    mul_nonneg H.C_pos.le (Nat.cast_nonneg N)
  calc
    (fixedNumeratorExceptionalCount m N : ℝ)
        ≤ H.C * (N : ℝ) * uniformNumeratorSaving H.c H.B m N := hbound
    _ ≤ H.C * (N : ℝ) * logPowerSaving H.c η N :=
        mul_le_mul_of_nonneg_left hsaving hfactor_nonneg

/-- Pointwise bridge from the EH numerator range to any smaller logarithmic
range.  The only extra input is the displayed comparison between the
logarithmic range and the EH exponential range at the same value of `N`. -/
theorem EHUniformNumeratorInputs.bound_of_log_range_le_eh_range
    (H : EHUniformNumeratorInputs) {A : ℝ} {N m : ℕ}
    (hN : 3 ≤ N) (hm : 2 ≤ m)
    (hm_log : (m : ℝ) ≤ (Real.log N) ^ A)
    (hlog_le_eh :
      (Real.log N) ^ A ≤
        Real.exp (H.κ * (Real.log N) ^ ((1 : ℝ) / 4))) :
    (fixedNumeratorExceptionalCount m N : ℝ) ≤
      H.C * (N : ℝ) * uniformNumeratorSaving H.c H.B m N :=
  H.bound N m hN hm (hm_log.trans hlog_le_eh)

/-- Every fixed logarithmic numerator range is eventually contained in the
EH exponential numerator range. -/
theorem eventually_log_range_le_eh_range
    {A κ : ℝ} (hA : 0 < A) (hκ : 0 < κ) :
    ∀ᶠ N : ℕ in Filter.atTop,
      (Real.log (N : ℝ)) ^ A ≤
        Real.exp (κ * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) := by
  have heps : 0 < κ / A := div_pos hκ hA
  have hsmall_raw :
      ∀ᶠ X : ℝ in Filter.atTop,
        ‖Real.log X‖ ≤ (κ / A) * ‖X ^ ((1 : ℝ) / 4)‖ :=
    (isLittleO_log_rpow_atTop (by norm_num : (0 : ℝ) < (1 : ℝ) / 4)).def heps
  have hsmall :
      ∀ᶠ X : ℝ in Filter.atTop,
        1 ≤ X → Real.log X ≤ (κ / A) * X ^ ((1 : ℝ) / 4) := by
    filter_upwards [hsmall_raw] with X hXsmall hXone
    have hXpos : 0 < X := lt_of_lt_of_le zero_lt_one hXone
    have hlog_nonneg : 0 ≤ Real.log X := by
      rw [Real.log_nonneg_iff hXpos]
      exact hXone
    have hpow_nonneg : 0 ≤ X ^ ((1 : ℝ) / 4) :=
      (Real.rpow_pos_of_pos hXpos _).le
    have hnorm_log : ‖Real.log X‖ = Real.log X := by
      rw [Real.norm_eq_abs, abs_of_nonneg hlog_nonneg]
    have hnorm_pow : ‖X ^ ((1 : ℝ) / 4)‖ = X ^ ((1 : ℝ) / 4) := by
      rw [Real.norm_eq_abs, abs_of_nonneg hpow_nonneg]
    rw [hnorm_log, hnorm_pow] at hXsmall
    exact hXsmall
  have hlogN_atTop :
      Filter.Tendsto (fun N : ℕ => Real.log (N : ℝ))
        Filter.atTop Filter.atTop :=
    Real.tendsto_log_atTop.comp tendsto_natCast_atTop_atTop
  have hsmallN :
      ∀ᶠ N : ℕ in Filter.atTop,
        1 ≤ Real.log (N : ℝ) →
          Real.log (Real.log (N : ℝ)) ≤
            (κ / A) * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4) :=
    hlogN_atTop.eventually hsmall
  have hlogN_ge_one :
      ∀ᶠ N : ℕ in Filter.atTop, 1 ≤ Real.log (N : ℝ) :=
    hlogN_atTop.eventually (Filter.eventually_ge_atTop (1 : ℝ))
  filter_upwards [hsmallN, hlogN_ge_one] with N hsmallN hLone
  set L : ℝ := Real.log (N : ℝ)
  have hLpos : 0 < L := lt_of_lt_of_le zero_lt_one (by simpa [L] using hLone)
  have hlogL_le : Real.log L ≤ (κ / A) * L ^ ((1 : ℝ) / 4) := by
    simpa [L] using hsmallN hLone
  have hscaled :
      A * Real.log L ≤ κ * L ^ ((1 : ℝ) / 4) := by
    calc
      A * Real.log L ≤ A * ((κ / A) * L ^ ((1 : ℝ) / 4)) :=
        mul_le_mul_of_nonneg_left hlogL_le hA.le
      _ = κ * L ^ ((1 : ℝ) / 4) := by field_simp [ne_of_gt hA]
  have hrpow : L ^ A = Real.exp (A * Real.log L) := by
    simpa [mul_comm] using Real.rpow_def_of_pos hLpos A
  rw [show (Real.log (N : ℝ)) ^ A = L ^ A by rfl, hrpow]
  exact Real.exp_le_exp.mpr hscaled

/-- Eventual version of the logarithmic-range bridge.  This isolates the
analytic growth comparison from the exceptional-set estimate itself. -/
theorem EHUniformNumeratorInputs.eventually_bound_on_log_range
    (H : EHUniformNumeratorInputs) {A : ℝ}
    (hdom : ∀ᶠ N : ℕ in Filter.atTop,
      (Real.log (N : ℝ)) ^ A ≤
        Real.exp (H.κ * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4))) :
    ∀ᶠ N : ℕ in Filter.atTop,
      ∀ m : ℕ, 3 ≤ N → 2 ≤ m →
        (m : ℝ) ≤ (Real.log (N : ℝ)) ^ A →
          (fixedNumeratorExceptionalCount m N : ℝ) ≤
            H.C * (N : ℝ) * uniformNumeratorSaving H.c H.B m N := by
  filter_upwards [hdom] with N hNdom
  intro m hN hm hm_log
  exact H.bound_of_log_range_le_eh_range hN hm hm_log hNdom

/-- The EH numerator package gives the fixed logarithmic numerator range
eventually, without any extra range hypothesis. -/
theorem EHUniformNumeratorInputs.eventually_bound_on_fixed_log_range
    (H : EHUniformNumeratorInputs) {A : ℝ} (hA : 0 < A) :
    ∀ᶠ N : ℕ in Filter.atTop,
      ∀ m : ℕ, 3 ≤ N → 2 ≤ m →
        (m : ℝ) ≤ (Real.log (N : ℝ)) ^ A →
          (fixedNumeratorExceptionalCount m N : ℝ) ≤
            H.C * (N : ℝ) * uniformNumeratorSaving H.c H.B m N :=
  H.eventually_bound_on_log_range
    (eventually_log_range_le_eh_range hA H.κ_pos)

/-- The EH numerator package supplies the exact large-range hard core for every
fixed logarithmic numerator range.  This keeps the finite-initial absorption
separate from the analytic estimate. -/
noncomputable def UniformNumeratorLargeRangeInputs.of_EHUniformNumeratorInputs
    (H : EHUniformNumeratorInputs) (A : ℝ) (hA : 0 < A) :
    UniformNumeratorLargeRangeInputs A := by
  let heventual := Filter.eventually_atTop.mp
      (H.eventually_bound_on_fixed_log_range hA)
  let T := Classical.choose heventual
  have hlarge :
      ∀ b ≥ T,
        ∀ m : ℕ, 3 ≤ b → 2 ≤ m →
          (m : ℝ) ≤ Real.log (b : ℝ) ^ A →
            (fixedNumeratorExceptionalCount m b : ℝ) ≤
              H.C * (b : ℝ) * uniformNumeratorSaving H.c H.B m b :=
    Classical.choose_spec heventual
  exact
    { c := H.c
      C := H.C
      B := H.B
      T := T
      c_pos := H.c_pos
      C_pos := H.C_pos
      B_pos := H.B_pos
      large_bound := by
        intro N m hN hTN hm hm_log
        exact hlarge N hTN m hN hm hm_log }

/-- The EH numerator package supplies the fixed-logarithmic theorem after
absorbing the finite initial range into the constant. -/
theorem thm_uniform_m_of_EHUniformNumeratorInputs
    (H : EHUniformNumeratorInputs) :
    ∀ A : ℝ, 0 < A →
      ∃ c > (0 : ℝ), ∃ C > (0 : ℝ), ∃ B > (0 : ℝ),
        ∀ N m : ℕ, 3 ≤ N → 2 ≤ m → (m : ℝ) ≤ (Real.log N) ^ A →
          (fixedNumeratorExceptionalCount m N : ℝ) ≤
            C * (N : ℝ) * uniformNumeratorSaving c B m N := by
  intro A hA
  rcases Filter.eventually_atTop.mp
      (H.eventually_bound_on_fixed_log_range hA) with ⟨T, hlarge⟩
  rcases finite_initial_uniformNumerator_bound H.c_pos H.B_pos T with
    ⟨Cinit, hCinit, hinitial⟩
  refine ⟨H.c, H.c_pos, max H.C Cinit,
    lt_of_lt_of_le H.C_pos (le_max_left H.C Cinit),
    H.B, H.B_pos, ?_⟩
  intro N m hN hm hm_log
  have hN_nonneg : 0 ≤ (N : ℝ) := Nat.cast_nonneg N
  have hsaving_nonneg : 0 ≤ uniformNumeratorSaving H.c H.B m N :=
    (uniformNumeratorSaving_pos H.c H.B m N).le
  by_cases hTN : T ≤ N
  · have hC_N :
        H.C * (N : ℝ) ≤ max H.C Cinit * (N : ℝ) :=
      mul_le_mul_of_nonneg_right (le_max_left H.C Cinit) hN_nonneg
    exact le_trans (hlarge N hTN m hN hm hm_log)
      (mul_le_mul_of_nonneg_right hC_N hsaving_nonneg)
  · have hNT : N < T := Nat.lt_of_not_ge hTN
    have hC_N :
        Cinit * (N : ℝ) ≤ max H.C Cinit * (N : ℝ) :=
      mul_le_mul_of_nonneg_right (le_max_right H.C Cinit) hN_nonneg
    exact le_trans (hinitial N m hN hNT hm)
      (mul_le_mul_of_nonneg_right hC_N hsaving_nonneg)

/-- The EH numerator package constructs the older fixed-logarithmic
uniform-saturation record for every fixed range.

This is the structure-level bridge behind
`thm_uniform_m_of_EHUniformNumeratorInputs`: any downstream theorem that still
expects `UniformNumeratorSaturationInputs` can receive it directly from the EH
carrier, with the finite initial range already absorbed. -/
noncomputable def uniformNumeratorSaturationInputs_of_EHUniformNumeratorInputs
    (H : EHUniformNumeratorInputs) (A : ℝ) (hA : 0 < A) :
    UniformNumeratorSaturationInputs A :=
  let h0 := thm_uniform_m_of_EHUniformNumeratorInputs H A hA
  let c := Classical.choose h0
  let h1 := Classical.choose_spec h0
  let hCexists := h1.2
  let C := Classical.choose hCexists
  let h2 := Classical.choose_spec hCexists
  let hBexists := h2.2
  let B := Classical.choose hBexists
  let h3 := Classical.choose_spec hBexists
  { c := c
    C := C
    B := B
    c_pos := h1.1
    C_pos := h2.1
    B_pos := h3.1
    bound := h3.2 }

/-- **`thm:EH-uniform-m` (conditional Lean form).** Given the assembled
exponential-range numerator carrier, the paper's exponential numerator-range
bound and its nontrivial almost-all subfamily consequence follow with explicit
constants.  The separate paper-shaped package including reciprocal EH is
`EHUniformNumeratorHypotheses`. -/
theorem thm_EH_uniform_m (H : EHUniformNumeratorInputs) :
    (∃ κ > (0 : ℝ), ∃ c > (0 : ℝ), ∃ C > (0 : ℝ), ∃ B > (0 : ℝ),
      (∀ N m : ℕ, 3 ≤ N → 2 ≤ m →
        (m : ℝ) ≤ Real.exp (κ * (Real.log N) ^ ((1 : ℝ) / 4)) →
          (fixedNumeratorExceptionalCount m N : ℝ) ≤
            C * (N : ℝ) * uniformNumeratorSaving c B m N) ∧
      (∀ η : ℝ, 0 < η →
        ∃ cη > (0 : ℝ), ∃ Cη > (0 : ℝ), ∀ N m : ℕ, 3 ≤ N → 2 ≤ m →
          (m : ℝ) ≤ Real.exp (κ * (Real.log N) ^ ((1 : ℝ) / 4)) →
          uniformNumeratorDenominator B m ≤ (Real.log N) ^ ((3 : ℝ) / 4 - η) →
            (fixedNumeratorExceptionalCount m N : ℝ) ≤
              Cη * (N : ℝ) * logPowerSaving cη η N)) := by
  exact ⟨H.κ, H.κ_pos, H.c, H.c_pos, H.C, H.C_pos, H.B, H.B_pos,
    H.bound, H.almost_all_of_bound⟩

/-- Paper-shaped combined hypotheses for `thm:EH-uniform-m`.

The first field is exactly the reciprocal-prime EH distribution hypothesis.  The
second field is the assembled exponential-range numerator-saturation estimate
produced after the uniform saturation, dependency, finite-transfer, and lifting
steps have been run in that EH range. -/
structure EHUniformNumeratorHypotheses where
  reciprocal_EH : ReciprocalElliottHalberstamInput
  assembled_bound : EHUniformNumeratorInputs

/-- The explicit paper-hypothesis package feeds the older assembled carrier. -/
def EHUniformNumeratorHypotheses.toInputs
    (H : EHUniformNumeratorHypotheses) : EHUniformNumeratorInputs :=
  H.assembled_bound

/-- Build the paper EH hypothesis package from reciprocal EH and the exact
large-range exponential numerator estimate.

This keeps `hyp:reciprocal-EH` as the cited distribution input, while discharging
the assembled-bound record from the displayed eventual estimate and finite
initial absorption. -/
noncomputable def EHUniformNumeratorHypotheses.of_reciprocalEH_eventual_bound
    (hEH : ReciprocalElliottHalberstamInput)
    {κ c C B : ℝ} (T : ℕ)
    (hκ : 0 < κ) (hc : 0 < c) (hC : 0 < C) (hB : 0 < B)
    (hlarge : ∀ N m : ℕ, 3 ≤ N → T ≤ N → 2 ≤ m →
      (m : ℝ) ≤ Real.exp (κ * (Real.log N) ^ ((1 : ℝ) / 4)) →
        (fixedNumeratorExceptionalCount m N : ℝ) ≤
          C * (N : ℝ) * uniformNumeratorSaving c B m N) :
    EHUniformNumeratorHypotheses :=
  { reciprocal_EH := hEH
    assembled_bound :=
      EHUniformNumeratorInputs.of_eventual_bound T hκ hc hC hB hlarge }

/-- Build the paper EH hypothesis package from reciprocal EH and an
exponential-range base-saving estimate.

The denominator-loss conversion and finite initial range are both discharged
internally, so the remaining non-cited content is the base fixed-numerator saving
estimate, uniform over the displayed exponential range. -/
noncomputable def EHUniformNumeratorHypotheses.of_reciprocalEH_uniform_base_saving_bound
    (hEH : ReciprocalElliottHalberstamInput)
    {κ c C B : ℝ} (T : ℕ)
    (hκ : 0 < κ) (hc : 0 < c) (hC : 0 < C) (hB : 0 < B)
    (hlarge : ∀ N m : ℕ, 3 ≤ N → T ≤ N → 2 ≤ m →
      (m : ℝ) ≤ Real.exp (κ * (Real.log N) ^ ((1 : ℝ) / 4)) →
        (fixedNumeratorExceptionalCount m N : ℝ) ≤
          C * (N : ℝ) * saving c N) :
    EHUniformNumeratorHypotheses :=
  { reciprocal_EH := hEH
    assembled_bound :=
      EHUniformNumeratorInputs.of_uniform_base_saving_bound T hκ hc hC hB
        hlarge }

/-- `hyp:reciprocal-EH` plus the assembled uniform-saturation package gives the
EH growing-numerator theorem in the exact theorem shape consumed downstream. -/
theorem thm_EH_uniform_m_of_reciprocalEH_and_uniformSaturation
    (H : EHUniformNumeratorHypotheses) :
    (∃ κ > (0 : ℝ), ∃ c > (0 : ℝ), ∃ C > (0 : ℝ), ∃ B > (0 : ℝ),
      (∀ N m : ℕ, 3 ≤ N → 2 ≤ m →

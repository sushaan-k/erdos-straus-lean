/-- For `X ≥ exp 2`, the normalizing logarithm `log z(X)` is positive. -/
theorem log_zScale_pos_of_exp_two_le {X : ℝ} (hX : Real.exp 2 ≤ X) :
    0 < Real.log (EscAnalytic.zScale X) := by
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 2) hX
  have hlogX_ge_two : (2 : ℝ) ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hX
  have hloglog_pos : 0 < Real.log (Real.log X) :=
    Real.log_pos (lt_of_lt_of_le one_lt_two hlogX_ge_two)
  have hlogZ_eq :
      Real.log (EscAnalytic.zScale X) = 4 * Real.log (Real.log X) := by
    unfold EscAnalytic.zScale
    rw [Real.log_pow]
    ring
  rw [hlogZ_eq]
  positivity

/-- The rough normalizing logarithm grows more slowly than any fixed positive
power of `X`. -/
theorem eventually_log_zScale_le_eps_mul_rpow
    {a₀ eps : ℝ} (ha₀ : 0 < a₀) (heps : 0 < eps) :
    ∃ X₀ : ℝ, ∀ X : ℝ, X₀ ≤ X →
      Real.log (EscAnalytic.zScale X) ≤ eps * X ^ a₀ := by
  have hsmall_eventually :
      ∀ᶠ X : ℝ in Filter.atTop,
        ‖Real.log X‖ ≤ (eps / 4) * ‖X ^ a₀‖ :=
    (isLittleO_log_rpow_atTop ha₀).def (by positivity : 0 < eps / 4)
  rcases Filter.eventually_atTop.mp hsmall_eventually with ⟨Xsmall, hsmall⟩
  refine ⟨max Xsmall (Real.exp 1), ?_⟩
  intro X hX
  have hXsmall : Xsmall ≤ X := le_trans (le_max_left _ _) hX
  have hXexp1 : Real.exp 1 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 1) hXexp1
  have hlogX_nonneg : 0 ≤ Real.log X := by
    rw [Real.log_nonneg_iff hXpos]
    exact le_trans (by norm_num : (1 : ℝ) ≤ Real.exp 1) hXexp1
  have hpow_nonneg : 0 ≤ X ^ a₀ := (Real.rpow_pos_of_pos hXpos a₀).le
  have hlogX_le :
      Real.log X ≤ (eps / 4) * X ^ a₀ := by
    simpa [Real.norm_eq_abs, abs_of_nonneg hlogX_nonneg,
      abs_of_nonneg hpow_nonneg] using hsmall X hXsmall
  have hlogZ_le : Real.log (EscAnalytic.zScale X) ≤ 4 * Real.log X :=
    EscAnalytic.log_zScale_le_four_log hXexp1
  calc
    Real.log (EscAnalytic.zScale X)
        ≤ 4 * Real.log X := hlogZ_le
    _ ≤ 4 * ((eps / 4) * X ^ a₀) :=
          mul_le_mul_of_nonneg_left hlogX_le (by norm_num)
    _ = eps * X ^ a₀ := by ring

/-- The logarithmic small-prime cap `U=(log X)^8` is eventually below every
positive power of `X`. -/
theorem eventually_UScale_le_rpow {δ : ℝ} (hδ : 0 < δ) :
    ∃ X₀ : ℝ, ∀ X : ℝ, X₀ ≤ X →
      EscAnalytic.UScale X ≤ X ^ δ := by
  have hδ8 : 0 < δ / 8 := by positivity
  have hsmall_eventually :
      ∀ᶠ X : ℝ in Filter.atTop,
        ‖Real.log X‖ ≤ (1 : ℝ) * ‖X ^ (δ / 8)‖ :=
    (isLittleO_log_rpow_atTop hδ8).def (by norm_num : (0 : ℝ) < 1)
  rcases Filter.eventually_atTop.mp hsmall_eventually with ⟨Xsmall, hsmall⟩
  refine ⟨max Xsmall (Real.exp 1), ?_⟩
  intro X hX
  have hXsmall : Xsmall ≤ X := le_trans (le_max_left _ _) hX
  have hXexp1 : Real.exp 1 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 1) hXexp1
  have hXnonneg : 0 ≤ X := hXpos.le
  have hlogX_nonneg : 0 ≤ Real.log X := by
    rw [Real.log_nonneg_iff hXpos]
    exact le_trans (by norm_num : (1 : ℝ) ≤ Real.exp 1) hXexp1
  have hpow_nonneg : 0 ≤ X ^ (δ / 8) :=
    (Real.rpow_pos_of_pos hXpos (δ / 8)).le
  have hlog_le :
      Real.log X ≤ X ^ (δ / 8) := by
    simpa [Real.norm_eq_abs, abs_of_nonneg hlogX_nonneg,
      abs_of_nonneg hpow_nonneg] using hsmall X hXsmall
  unfold EscAnalytic.UScale
  calc
    (Real.log X) ^ (8 : ℕ)
        ≤ (X ^ (δ / 8)) ^ (8 : ℕ) :=
          pow_le_pow_left₀ hlogX_nonneg hlog_le 8
    _ = X ^ δ := by
          rw [← Real.rpow_natCast (X ^ (δ / 8)) 8]
          rw [← Real.rpow_mul hXnonneg]
          congr 1
          ring

/-- The elementary comparison `log log X = o(log X)`, in explicit eventual
form.  This is used to discharge fixed polylogarithmic cutoff conditions in the
rough-initial Selberg split. -/
theorem eventually_loglog_le_eps_mul_log
    {eps : ℝ} (heps : 0 < eps) :
    ∃ X₀ : ℝ, ∀ X : ℝ, X₀ ≤ X →
      Real.log (Real.log X) ≤ eps * Real.log X := by
  have hsmall_eventually :
      ∀ᶠ Y : ℝ in Filter.atTop,
        ‖Real.log Y‖ ≤ eps * ‖Y ^ (1 : ℝ)‖ :=
    (isLittleO_log_rpow_atTop (by norm_num : (0 : ℝ) < (1 : ℝ))).def heps
  have hcomp :
      ∀ᶠ X : ℝ in Filter.atTop,
        ‖Real.log (Real.log X)‖ ≤ eps * ‖(Real.log X) ^ (1 : ℝ)‖ :=
    Real.tendsto_log_atTop.eventually hsmall_eventually
  rcases Filter.eventually_atTop.mp hcomp with ⟨Xsmall, hsmall⟩
  refine ⟨max Xsmall (Real.exp 1), ?_⟩
  intro X hX
  have hXsmall : Xsmall ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 1 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 1) hXexp
  have hlogX_ge_one : (1 : ℝ) ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hXexp
  have hlogX_nonneg : 0 ≤ Real.log X := le_trans zero_le_one hlogX_ge_one
  have hloglog_nonneg : 0 ≤ Real.log (Real.log X) := by
    rw [Real.log_nonneg_iff (lt_of_lt_of_le zero_lt_one hlogX_ge_one)]
    exact hlogX_ge_one
  have hpow_eq : (Real.log X) ^ (1 : ℝ) = Real.log X := by
    rw [Real.rpow_one]
  simpa [Real.norm_eq_abs, abs_of_nonneg hloglog_nonneg,
    hpow_eq, abs_of_nonneg hlogX_nonneg] using hsmall X hXsmall

/-- The rough normalizing logarithm is eventually smaller than any fixed
positive multiple of `log X`. -/
theorem eventually_log_zScale_le_eps_mul_log
    {eps : ℝ} (heps : 0 < eps) :
    ∃ X₀ : ℝ, ∀ X : ℝ, X₀ ≤ X →
      Real.log (EscAnalytic.zScale X) ≤ eps * Real.log X := by
  rcases eventually_loglog_le_eps_mul_log (by positivity : 0 < eps / 4) with
    ⟨X₀, hX₀⟩
  refine ⟨max X₀ (Real.exp 1), ?_⟩
  intro X hX
  have hX₀' : X₀ ≤ X := le_trans (le_max_left _ _) hX
  have hlogZ_eq :
      Real.log (EscAnalytic.zScale X) = 4 * Real.log (Real.log X) := by
    unfold EscAnalytic.zScale
    rw [Real.log_pow]
    ring
  rw [hlogZ_eq]
  calc
    4 * Real.log (Real.log X) ≤ 4 * ((eps / 4) * Real.log X) := by
      exact mul_le_mul_of_nonneg_left (hX₀ X hX₀') (by norm_num)
    _ = eps * Real.log X := by ring

/-- Squared form of `log z(X) ≪ sqrt(log X)`, specialized to the constant needed
for the normalized harmonic contribution in `lem:rough-initial`. -/
theorem eventually_log_zScale_sq_le_sixteen_mul_log :
    ∃ X₀ : ℝ, ∀ X : ℝ, X₀ ≤ X →
      (Real.log (EscAnalytic.zScale X)) ^ 2 ≤ 16 * Real.log X := by
  have hsmall_eventually :
      ∀ᶠ Y : ℝ in Filter.atTop,
        ‖Real.log Y‖ ≤ (1 : ℝ) * ‖Y ^ ((1 : ℝ) / 2)‖ :=
    (isLittleO_log_rpow_atTop (by norm_num : (0 : ℝ) < (1 : ℝ) / 2)).def
      (by norm_num : (0 : ℝ) < (1 : ℝ))
  have hcomp :
      ∀ᶠ X : ℝ in Filter.atTop,
        ‖Real.log (Real.log X)‖ ≤
          (1 : ℝ) * ‖(Real.log X) ^ ((1 : ℝ) / 2)‖ :=
    Real.tendsto_log_atTop.eventually hsmall_eventually
  rcases Filter.eventually_atTop.mp hcomp with ⟨Xsmall, hsmall⟩
  refine ⟨max Xsmall (Real.exp 1), ?_⟩
  intro X hX
  have hXsmall : Xsmall ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 1 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 1) hXexp
  have hlogX_ge_one : (1 : ℝ) ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hXexp
  have hlogX_nonneg : 0 ≤ Real.log X := le_trans zero_le_one hlogX_ge_one
  have hloglog_nonneg : 0 ≤ Real.log (Real.log X) := by
    rw [Real.log_nonneg_iff (lt_of_lt_of_le zero_lt_one hlogX_ge_one)]
    exact hlogX_ge_one
  have hsqrt_nonneg : 0 ≤ (Real.log X) ^ ((1 : ℝ) / 2) :=
    (Real.rpow_pos_of_pos (lt_of_lt_of_le zero_lt_one hlogX_ge_one) _).le
  have hloglog_abs : ‖Real.log (Real.log X)‖ = Real.log (Real.log X) := by
    simp [Real.norm_eq_abs, abs_of_nonneg hloglog_nonneg]
  have hsqrt_abs : ‖(Real.log X) ^ ((1 : ℝ) / 2)‖ =
      (Real.log X) ^ ((1 : ℝ) / 2) := by
    rw [Real.norm_eq_abs, abs_of_nonneg (by simpa using hsqrt_nonneg)]
  have hraw := hsmall X hXsmall
  rw [hloglog_abs, hsqrt_abs, one_mul] at hraw
  have hloglog_le :
      Real.log (Real.log X) ≤ (Real.log X) ^ ((1 : ℝ) / 2) := hraw
  have hlogZ_eq :
      Real.log (EscAnalytic.zScale X) = 4 * Real.log (Real.log X) := by
    unfold EscAnalytic.zScale
    rw [Real.log_pow]
    ring
  have hlogZ_nonneg : 0 ≤ Real.log (EscAnalytic.zScale X) := by
    rw [hlogZ_eq]
    positivity
  have hlogZ_le :
      Real.log (EscAnalytic.zScale X) ≤ 4 * (Real.log X) ^ ((1 : ℝ) / 2) := by
    rw [hlogZ_eq]
    nlinarith
  have hsquare_le :
      (Real.log (EscAnalytic.zScale X)) ^ 2 ≤
        (4 * (Real.log X) ^ ((1 : ℝ) / 2)) ^ 2 := by
    exact pow_le_pow_left₀ hlogZ_nonneg hlogZ_le 2
  have hsqrt_sq : ((Real.log X) ^ ((1 : ℝ) / 2)) ^ 2 = Real.log X := by
    rw [← Real.rpow_natCast]
    rw [← Real.rpow_mul hlogX_nonneg]
    norm_num
  calc
    (Real.log (EscAnalytic.zScale X)) ^ 2
        ≤ (4 * (Real.log X) ^ ((1 : ℝ) / 2)) ^ 2 := hsquare_le
    _ = 16 * Real.log X := by
      rw [mul_pow, hsqrt_sq]
      norm_num

/-- Every odd-prime witness is an admissible odd divisor in
`smallDivisorEulerSum`, once `z ≥ 1` so that `p ≤ z` implies `p ≤ U=z²`. -/
theorem oddPrimeEulerWitness_subset_smallDivisorSupport (X : ℝ)
    (hz_ge_one : 1 ≤ EscAnalytic.zScale X) :
    oddPrimeEulerWitness X ⊆
      (Finset.Icc (1 : ℕ) ⌊EscAnalytic.UScale X⌋₊).filter
        (fun d => d ∣ roughModulus X ∧ Odd d) := by
  classical
  intro p hp
  have hpIcc : p ∈ Finset.Icc (3 : ℕ) ⌊EscAnalytic.zScale X⌋₊ :=
    (Finset.mem_filter.mp hp).1
  have hpPrime : Nat.Prime p := (Finset.mem_filter.mp hp).2
  have hp_ge_three : 3 ≤ p := (Finset.mem_Icc.mp hpIcc).1
  have hp_le_floor_z : p ≤ ⌊EscAnalytic.zScale X⌋₊ := (Finset.mem_Icc.mp hpIcc).2
  have hp_ge_one : 1 ≤ p := by omega
  have hp_odd : Odd p := hpPrime.odd_of_ne_two (by omega)
  have hdiv : p ∣ roughModulus X := by
    unfold roughModulus
    exact prime_dvd_primeProductBelow_of_le_floor (EscAnalytic.zScale X) p
      hpPrime hp_le_floor_z
  have hz_nonneg : 0 ≤ EscAnalytic.zScale X := le_trans zero_le_one hz_ge_one
  have hp_le_z : (p : ℝ) ≤ EscAnalytic.zScale X := by
    exact le_trans (by exact_mod_cast hp_le_floor_z) (Nat.floor_le hz_nonneg)
  have hz_le_U : EscAnalytic.zScale X ≤ EscAnalytic.UScale X := by
    rw [UScale_eq_zScale_sq X]
    nlinarith
  have hp_le_floor_U : p ≤ ⌊EscAnalytic.UScale X⌋₊ :=
    Nat.le_floor (le_trans hp_le_z hz_le_U)
  exact Finset.mem_filter.mpr
    ⟨Finset.mem_Icc.mpr ⟨hp_ge_one, hp_le_floor_U⟩, ⟨hdiv, hp_odd⟩⟩

/-- The odd-prime witness gives an explicit finite lower bound for the
odd-divisor Euler-sum carrier. -/
theorem smallDivisorEulerSum_ge_oddPrimeWitness (X : ℝ)
    (hz_ge_one : 1 ≤ EscAnalytic.zScale X) :
    ∑ p ∈ oddPrimeEulerWitness X, (Nat.totient p : ℝ) / (p : ℝ) ^ 2
      ≤ smallDivisorEulerSum X :=
  smallDivisorEulerSum_ge_sum_of_subset X (oddPrimeEulerWitness X)
    (oddPrimeEulerWitness_subset_smallDivisorSupport X hz_ge_one)

/-- A concrete odd-squarefree totient witness lower bound implies the primitive
finite-witness Euler input shape.

This theorem does not assume the finite-witness axiom.  It isolates the
remaining Mertens/Euler-product content in the single explicit carrier
`oddSquarefreeEulerWitness`. -/
theorem smallDivisorEulerSum_finite_witness_lower_bound_of_oddSquarefreeWitness
    (hW :
      ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
        c * Real.log (EscAnalytic.zScale X)
          ≤ ∑ d ∈ oddSquarefreeEulerWitness X,
              (Nat.totient d : ℝ) / (d : ℝ) ^ 2) :
    ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      ∃ T : Finset ℕ,
        T ⊆ (Finset.Icc (1 : ℕ) ⌊EscAnalytic.UScale X⌋₊).filter
          (fun d => d ∣ roughModulus X ∧ Odd d) ∧
        c * Real.log (EscAnalytic.zScale X)
          ≤ ∑ d ∈ T, (Nat.totient d : ℝ) / (d : ℝ) ^ 2 := by
  rcases hW with ⟨c, X₀, hc, hW⟩
  refine ⟨c, max X₀ (Real.exp 1), hc, ?_⟩
  intro X hX
  have hXbase : X₀ ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 1 ≤ X := le_trans (le_max_right _ _) hX
  refine ⟨oddSquarefreeEulerWitness X, ?_, hW X hXbase⟩
  exact oddSquarefreeEulerWitness_subset_smallDivisorSupport X
    (zScale_ge_one_of_exp_one_le hXexp)

/-- Direct lower-bound bridge from the explicit odd-squarefree witness to the
small-divisor Euler carrier. -/
theorem smallDivisorEulerSum_lower_from_oddSquarefreeWitness
    (hW :
      ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
        c * Real.log (EscAnalytic.zScale X)
          ≤ ∑ d ∈ oddSquarefreeEulerWitness X,
              (Nat.totient d : ℝ) / (d : ℝ) ^ 2) :
    ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.zScale X) ≤ smallDivisorEulerSum X := by
  rcases hW with ⟨c, X₀, hc, hW⟩
  refine ⟨c, max X₀ (Real.exp 1), hc, ?_⟩
  intro X hX
  have hXbase : X₀ ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 1 ≤ X := le_trans (le_max_right _ _) hX
  exact (hW X hXbase).trans
    (smallDivisorEulerSum_ge_oddSquarefreeWitness X
      (zScale_ge_one_of_exp_one_le hXexp))

/-- On the odd-prime witness support, `φ(p)/p² = (p-1)/p² ≥ 1/(2p)`. -/
theorem oddPrimeWitness_half_recip_le_totient_sum (X : ℝ) :
    (1 / 2 : ℝ) * (∑ p ∈ oddPrimeEulerWitness X, (1 : ℝ) / (p : ℝ))
      ≤ ∑ p ∈ oddPrimeEulerWitness X, (Nat.totient p : ℝ) / (p : ℝ) ^ 2 := by
  classical
  rw [Finset.mul_sum]
  apply Finset.sum_le_sum
  intro p hp
  have hpIcc : p ∈ Finset.Icc (3 : ℕ) ⌊EscAnalytic.zScale X⌋₊ :=
    (Finset.mem_filter.mp hp).1
  have hpPrime : Nat.Prime p := (Finset.mem_filter.mp hp).2
  have hp_ge_three : 3 ≤ p := (Finset.mem_Icc.mp hpIcc).1
  have hp_ge_one : 1 ≤ p := by omega
  have hp_pos_nat : 0 < p := by omega
  have hp_pos : (0 : ℝ) < (p : ℝ) := by exact_mod_cast hp_pos_nat
  have hp_ne : (p : ℝ) ≠ 0 := ne_of_gt hp_pos
  have hp_two : (2 : ℝ) ≤ (p : ℝ) := by exact_mod_cast (by omega : 2 ≤ p)
  have hnum : (p : ℝ) / 2 ≤ (p : ℝ) - 1 := by nlinarith
  have hcast_sub : ((p - 1 : ℕ) : ℝ) = (p : ℝ) - 1 := by
    rw [Nat.cast_sub hp_ge_one]
    norm_num
  calc
    (1 / 2 : ℝ) * ((1 : ℝ) / (p : ℝ))
        = ((p : ℝ) / 2) / (p : ℝ) ^ 2 := by
          field_simp [hp_ne]
          ring
    _ ≤ ((p : ℝ) - 1) / (p : ℝ) ^ 2 :=
          div_le_div_of_nonneg_right hnum (sq_nonneg (p : ℝ))
    _ = (Nat.totient p : ℝ) / (p : ℝ) ^ 2 := by
          rw [Nat.totient_prime hpPrime, hcast_sub]

/-- The explicit odd-prime reciprocal witness directly lower-bounds the
odd-divisor Euler carrier, with the elementary factor `1/2`.

This packages the support bookkeeping and the pointwise inequality
`φ(p)/p² ≥ 1/(2p)` into the exact form needed by prime-reciprocal witness
arguments.  The logarithmic-rate lower bound for this prime reciprocal sum is
still a separate analytic input. -/
theorem smallDivisorEulerSum_ge_half_oddPrimeRecip (X : ℝ)
    (hz_ge_one : 1 ≤ EscAnalytic.zScale X) :
    (1 / 2 : ℝ) * (∑ p ∈ oddPrimeEulerWitness X, (1 : ℝ) / (p : ℝ))
      ≤ smallDivisorEulerSum X :=
  (oddPrimeWitness_half_recip_le_totient_sum X).trans
    (smallDivisorEulerSum_ge_oddPrimeWitness X hz_ge_one)

/-- The explicit odd-prime reciprocal witness is a nonnegative finite carrier. -/
theorem oddPrimeEulerWitness_recip_sum_nonneg (X : ℝ) :
    0 ≤ ∑ p ∈ oddPrimeEulerWitness X, (1 : ℝ) / (p : ℝ) := by
  classical
  apply Finset.sum_nonneg
  intro p _hp
  exact div_nonneg zero_le_one (Nat.cast_nonneg p)

/-- Eventual version of the odd-prime reciprocal witness comparison. -/
theorem smallDivisorEulerSum_ge_half_oddPrimeRecip_eventual :
    ∀ X : ℝ, Real.exp 1 ≤ X →
      (1 / 2 : ℝ) * (∑ p ∈ oddPrimeEulerWitness X, (1 : ℝ) / (p : ℝ))
        ≤ smallDivisorEulerSum X := by
  intro X hX
  exact smallDivisorEulerSum_ge_half_oddPrimeRecip X
    (zScale_ge_one_of_exp_one_le hX)

/-- Eventual odd-prime reciprocal witness comparison bundled with the finite
carrier nonnegativity facts used by downstream lower-bound bridges. -/
theorem smallDivisorEulerSum_ge_half_oddPrimeRecip_eventual_with_carrier_bounds :
    ∀ X : ℝ, Real.exp 1 ≤ X →
      0 ≤ (∑ p ∈ oddPrimeEulerWitness X, (1 : ℝ) / (p : ℝ)) ∧
        0 ≤ smallDivisorEulerSum X ∧
        (1 / 2 : ℝ) * (∑ p ∈ oddPrimeEulerWitness X, (1 : ℝ) / (p : ℝ))
          ≤ smallDivisorEulerSum X := by
  intro X hX
  exact ⟨oddPrimeEulerWitness_recip_sum_nonneg X,
    smallDivisorEulerSum_nonneg X,
    smallDivisorEulerSum_ge_half_oddPrimeRecip_eventual X hX⟩

/-- The bare eventual odd-prime reciprocal comparison implies the same
comparison bundled with the finite-carrier nonnegativity checks. -/
theorem smallDivisorEulerSum_ge_half_oddPrimeRecip_eventual_with_carrier_bounds_of_bound
    (h :
      ∀ X : ℝ, Real.exp 1 ≤ X →
        (1 / 2 : ℝ) * (∑ p ∈ oddPrimeEulerWitness X, (1 : ℝ) / (p : ℝ))
          ≤ smallDivisorEulerSum X) :
    ∀ X : ℝ, Real.exp 1 ≤ X →
      0 ≤ (∑ p ∈ oddPrimeEulerWitness X, (1 : ℝ) / (p : ℝ)) ∧
        0 ≤ smallDivisorEulerSum X ∧
        (1 / 2 : ℝ) * (∑ p ∈ oddPrimeEulerWitness X, (1 : ℝ) / (p : ℝ))
          ≤ smallDivisorEulerSum X := by
  intro X hX
  exact ⟨oddPrimeEulerWitness_recip_sum_nonneg X, smallDivisorEulerSum_nonneg X, h X hX⟩

/-- Forget the checked nonnegativity side conditions from the eventual
odd-prime reciprocal comparison package. -/
theorem smallDivisorEulerSum_ge_half_oddPrimeRecip_eventual_bound_of_carrier_bounds
    (h :
      ∀ X : ℝ, Real.exp 1 ≤ X →
        0 ≤ (∑ p ∈ oddPrimeEulerWitness X, (1 : ℝ) / (p : ℝ)) ∧
          0 ≤ smallDivisorEulerSum X ∧
          (1 / 2 : ℝ) * (∑ p ∈ oddPrimeEulerWitness X, (1 : ℝ) / (p : ℝ))
            ≤ smallDivisorEulerSum X) :
    ∀ X : ℝ, Real.exp 1 ≤ X →
      (1 / 2 : ℝ) * (∑ p ∈ oddPrimeEulerWitness X, (1 : ℝ) / (p : ℝ))
        ≤ smallDivisorEulerSum X := by
  intro X hX
  exact (h X hX).2.2

/-- The carrier-bundled and bare eventual odd-prime reciprocal comparison are
equivalent. -/
theorem smallDivisorEulerSum_ge_half_oddPrimeRecip_eventual_bound_iff_carrier_bounds :
    (∀ X : ℝ, Real.exp 1 ≤ X →
      (1 / 2 : ℝ) * (∑ p ∈ oddPrimeEulerWitness X, (1 : ℝ) / (p : ℝ))
        ≤ smallDivisorEulerSum X) ↔
    ∀ X : ℝ, Real.exp 1 ≤ X →
      0 ≤ (∑ p ∈ oddPrimeEulerWitness X, (1 : ℝ) / (p : ℝ)) ∧
        0 ≤ smallDivisorEulerSum X ∧
        (1 / 2 : ℝ) * (∑ p ∈ oddPrimeEulerWitness X, (1 : ℝ) / (p : ℝ))
          ≤ smallDivisorEulerSum X := by
  constructor
  · exact smallDivisorEulerSum_ge_half_oddPrimeRecip_eventual_with_carrier_bounds_of_bound
  · exact smallDivisorEulerSum_ge_half_oddPrimeRecip_eventual_bound_of_carrier_bounds

/-- Conditional bridge from an explicit odd-prime reciprocal lower estimate to
the Euler carrier.  This is intentionally only a bridge: the odd-prime lower
estimate itself is not asserted here. -/
theorem smallDivisorEulerSum_lower_from_oddPrimeRecip_witness
    (hrecip :
      ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
        c * Real.log (EscAnalytic.zScale X)
          ≤ (1 / 2 : ℝ) *
            (∑ p ∈ oddPrimeEulerWitness X, (1 : ℝ) / (p : ℝ))) :
    ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.zScale X) ≤ smallDivisorEulerSum X := by
  rcases hrecip with ⟨c, X₀, hc, hlower⟩
  refine ⟨c, max X₀ (Real.exp 1), hc, ?_⟩
  intro X hX
  have hXbase : X₀ ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 1 ≤ X := le_trans (le_max_right _ _) hX
  exact (hlower X hXbase).trans
    (smallDivisorEulerSum_ge_half_oddPrimeRecip_eventual X hXexp)

/-- Standard-input lower bound for the manuscript odd-divisor Euler carrier,
derived from the finite-witness input above. -/
theorem smallDivisorEulerSum_lower_from_standard_input :
    ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.zScale X) ≤ smallDivisorEulerSum X :=
  smallDivisorEulerSum_lower_bound

/-- Compatibility alias for older downstream routes.  Despite the historical
name, the source is now the full truncated Euler-sum lower input, not the
prime-only reciprocal witness. -/
theorem smallDivisorEulerSum_lower_from_prime_recip :
    ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.zScale X) ≤ smallDivisorEulerSum X :=
  smallDivisorEulerSum_lower_from_standard_input

/-- Interchange the two finite sums in `lem:small-divisor-average`.

This is the exact algebraic reduction of
`∑_{s≤S, sqf} A_s/s` to
`∑_{d≤U, d∣P(z), d odd} d⁻¹ ∑_{s≤S, sqf, (s,d)=1} s⁻¹`.  The remaining lower
bound is therefore precisely the coprime squarefree conductor average together
with the truncated odd-prime Euler product. -/
theorem smallDivisorAverage_eq_sum_coprime (P : EscAnalytic.Params) (X : ℝ) :
    smallDivisorAverage P X =
      ∑ d ∈ (Finset.Icc (1 : ℕ) ⌊EscAnalytic.UScale X⌋₊).filter
          (fun d => d ∣ roughModulus X ∧ Odd d),
        (1 : ℝ) / (d : ℝ) * sAvgRecipCoprime P X d := by
  classical
  let Sset : Finset ℕ :=
    (Finset.Icc (1 : ℕ) ⌊EscAnalytic.SScale P X⌋₊).filter (fun s => Squarefree s)
  let Dset : Finset ℕ :=
    (Finset.Icc (1 : ℕ) ⌊EscAnalytic.UScale X⌋₊).filter
      (fun d => d ∣ roughModulus X ∧ Odd d)
  have hleft :
      smallDivisorAverage P X =
        ∑ s ∈ Sset, ∑ d ∈ Dset,
          if Nat.Coprime d s then ((1 : ℝ) / (d : ℝ)) * ((1 : ℝ) / (s : ℝ))
          else 0 := by
    unfold smallDivisorAverage smallDivisorWeight
    simp only [Sset, Dset]
    apply Finset.sum_congr rfl
    intro s hs
    calc
      (∑ d ∈ (Finset.Icc (1 : ℕ) ⌊EscAnalytic.UScale X⌋₊).filter
          (fun d => d ∣ roughModulus X ∧ Odd d ∧ Nat.Coprime d s),
          (1 : ℝ) / (d : ℝ)) / (s : ℝ)
          = (∑ d ∈ Dset, if Nat.Coprime d s then (1 : ℝ) / (d : ℝ) else 0) *
              ((1 : ℝ) / (s : ℝ)) := by
            have hsum :
                (∑ d ∈ (Finset.Icc (1 : ℕ) ⌊EscAnalytic.UScale X⌋₊).filter
                    (fun d => d ∣ roughModulus X ∧ Odd d ∧ Nat.Coprime d s),
                    (1 : ℝ) / (d : ℝ))
                  =
                ∑ d ∈ Dset, if Nat.Coprime d s then (1 : ℝ) / (d : ℝ) else 0 := by
              simp only [Dset]
              rw [Finset.sum_filter]
              rw [Finset.sum_filter]
              apply Finset.sum_congr rfl
              intro d hd
              by_cases hdiv : d ∣ roughModulus X
              · by_cases hodd : Odd d
                · by_cases hcop : Nat.Coprime d s
                  · simp [hdiv, hodd, hcop]
                  · simp [hdiv, hodd, hcop]
                · by_cases hcop : Nat.Coprime d s
                  · simp [hdiv, hodd, hcop]
                  · simp [hdiv, hodd, hcop]
              · by_cases hodd : Odd d
                · by_cases hcop : Nat.Coprime d s
                  · simp [hdiv, hodd, hcop]
                  · simp [hdiv, hodd, hcop]
                · by_cases hcop : Nat.Coprime d s
                  · simp [hdiv, hodd, hcop]
                  · simp [hdiv, hodd, hcop]
            rw [hsum]
            ring
      _ = ∑ d ∈ Dset,
          if Nat.Coprime d s then ((1 : ℝ) / (d : ℝ)) * ((1 : ℝ) / (s : ℝ))
          else 0 := by
          rw [Finset.sum_mul]
          apply Finset.sum_congr rfl
          intro d hd
          by_cases hcop : Nat.Coprime d s
          · simp [hcop]
          · simp [hcop]
  have hcomm :
      (∑ s ∈ Sset, ∑ d ∈ Dset,
          if Nat.Coprime d s then ((1 : ℝ) / (d : ℝ)) * ((1 : ℝ) / (s : ℝ))
          else 0)
        =
      ∑ d ∈ Dset, ∑ s ∈ Sset,
          if Nat.Coprime d s then ((1 : ℝ) / (d : ℝ)) * ((1 : ℝ) / (s : ℝ))
          else 0 := by
    rw [Finset.sum_comm]
  have hright :
      (∑ d ∈ Dset, ∑ s ∈ Sset,
          if Nat.Coprime d s then ((1 : ℝ) / (d : ℝ)) * ((1 : ℝ) / (s : ℝ))
          else 0)
        =
      ∑ d ∈ Dset, (1 : ℝ) / (d : ℝ) * sAvgRecipCoprime P X d := by
    apply Finset.sum_congr rfl
    intro d hd
    unfold sAvgRecipCoprime
    calc
        (∑ s ∈ Sset,
            if Nat.Coprime d s then ((1 : ℝ) / (d : ℝ)) * ((1 : ℝ) / (s : ℝ))
            else 0)
            = ∑ s ∈ Sset.filter (fun s => Nat.Coprime d s),
                ((1 : ℝ) / (d : ℝ)) * ((1 : ℝ) / (s : ℝ)) := by
            exact (Finset.sum_filter
              (s := Sset)
              (p := fun s => Nat.Coprime d s)
              (f := fun s => ((1 : ℝ) / (d : ℝ)) * ((1 : ℝ) / (s : ℝ)))).symm
      _ = (1 : ℝ) / (d : ℝ) *
            ∑ s ∈ Sset.filter (fun s => Nat.Coprime d s), (1 : ℝ) / (s : ℝ) := by
            rw [Finset.mul_sum]
      _ = (1 : ℝ) / (d : ℝ) *
            ∑ s ∈ (Finset.Icc (1 : ℕ) ⌊EscAnalytic.SScale P X⌋₊).filter
              (fun s => Squarefree s ∧ Nat.Coprime s d), (1 : ℝ) / (s : ℝ) := by
            congr 1
            apply Finset.sum_congr ?_ ?_
            · simp only [Sset]
              apply Finset.ext
              intro s
              simp only [Finset.mem_filter]
              constructor
              · intro hs
                exact ⟨hs.1.1, ⟨hs.1.2, hs.2.symm⟩⟩
              · intro hs
                exact ⟨⟨hs.1, hs.2.1⟩, hs.2.2.symm⟩
            · intro s hs
              rfl
  calc
    smallDivisorAverage P X
        = ∑ s ∈ Sset, ∑ d ∈ Dset,
          if Nat.Coprime d s then ((1 : ℝ) / (d : ℝ)) * ((1 : ℝ) / (s : ℝ))
          else 0 := hleft
    _ = ∑ d ∈ Dset, ∑ s ∈ Sset,
          if Nat.Coprime d s then ((1 : ℝ) / (d : ℝ)) * ((1 : ℝ) / (s : ℝ))
          else 0 := hcomm
    _ = ∑ d ∈ Dset, (1 : ℝ) / (d : ℝ) * sAvgRecipCoprime P X d := hright

/-- Lower-bound reduction for `lem:small-divisor-average`.

If every coprime squarefree reciprocal inner sum has the expected
`(φ(d)/d) log S` lower bound, then the whole small-divisor average is bounded
below by `log S` times the odd-divisor Euler sum.  The remaining mathematical
content is therefore the coprime reciprocal estimate and the Euler-product lower
bound, not the finite summation algebra. -/
theorem smallDivisorAverage_lower_from_coprime_average
    (P : EscAnalytic.Params) (X c : ℝ)
    (hcop : ∀ d ∈ (Finset.Icc (1 : ℕ) ⌊EscAnalytic.UScale X⌋₊).filter
          (fun d => d ∣ roughModulus X ∧ Odd d),
        c * Real.log (EscAnalytic.SScale P X) *
            ((Nat.totient d : ℝ) / (d : ℝ)) ≤ sAvgRecipCoprime P X d) :
    c * Real.log (EscAnalytic.SScale P X) * smallDivisorEulerSum X
      ≤ smallDivisorAverage P X := by
  classical
  rw [smallDivisorAverage_eq_sum_coprime]
  unfold smallDivisorEulerSum
  rw [Finset.mul_sum]
  apply Finset.sum_le_sum
  intro d hd
  have hdIcc : d ∈ Finset.Icc (1 : ℕ) ⌊EscAnalytic.UScale X⌋₊ :=
    (Finset.mem_filter.mp hd).1
  have hdpos_nat : 0 < d :=
    lt_of_lt_of_le Nat.zero_lt_one (Finset.mem_Icc.mp hdIcc).1
  have hdpos : (0 : ℝ) < (d : ℝ) := by exact_mod_cast hdpos_nat
  have hinv_nonneg : 0 ≤ (1 : ℝ) / (d : ℝ) :=
    div_nonneg zero_le_one hdpos.le
  have hterm :=
    mul_le_mul_of_nonneg_left (hcop d hd) hinv_nonneg
  calc
    c * Real.log (EscAnalytic.SScale P X) *
        ((Nat.totient d : ℝ) / (d : ℝ) ^ 2)
        = (1 : ℝ) / (d : ℝ) *
            (c * Real.log (EscAnalytic.SScale P X) *
              ((Nat.totient d : ℝ) / (d : ℝ))) := by
          ring_nf
    _ ≤ (1 : ℝ) / (d : ℝ) * sAvgRecipCoprime P X d := hterm

/-- Constant-strength version of `smallDivisorAverage_lower_from_coprime_average`.
If the coprime reciprocal carriers have the local-density factor with no
logarithmic gain, then the small-divisor average already dominates the Euler
carrier itself.  This isolates the missing logarithmic Mertens growth from the
finite summation algebra. -/
theorem smallDivisorAverage_lower_from_coprime_average_constant
    (P : EscAnalytic.Params) (X c : ℝ)
    (hcop : ∀ d ∈ (Finset.Icc (1 : ℕ) ⌊EscAnalytic.UScale X⌋₊).filter
          (fun d => d ∣ roughModulus X ∧ Odd d),
        c * ((Nat.totient d : ℝ) / (d : ℝ)) ≤
          sAvgRecipCoprime P X d) :
    c * smallDivisorEulerSum X ≤ smallDivisorAverage P X := by
  classical
  rw [smallDivisorAverage_eq_sum_coprime]
  unfold smallDivisorEulerSum
  rw [Finset.mul_sum]
  apply Finset.sum_le_sum
  intro d hd
  have hdIcc : d ∈ Finset.Icc (1 : ℕ) ⌊EscAnalytic.UScale X⌋₊ :=
    (Finset.mem_filter.mp hd).1
  have hdpos_nat : 0 < d :=
    lt_of_lt_of_le Nat.zero_lt_one (Finset.mem_Icc.mp hdIcc).1
  have hdpos : (0 : ℝ) < (d : ℝ) := by exact_mod_cast hdpos_nat
  have hinv_nonneg : 0 ≤ (1 : ℝ) / (d : ℝ) :=
    div_nonneg zero_le_one hdpos.le
  have hterm :=
    mul_le_mul_of_nonneg_left (hcop d hd) hinv_nonneg
  calc
    c * ((Nat.totient d : ℝ) / (d : ℝ) ^ 2)
        = (1 : ℝ) / (d : ℝ) *
            (c * ((Nat.totient d : ℝ) / (d : ℝ))) := by
          ring_nf
    _ ≤ (1 : ℝ) / (d : ℝ) * sAvgRecipCoprime P X d := hterm

/-- Fully checked constant-times-Euler lower fallback for the small-divisor
average.  The logarithmic factors in the manuscript theorem remain the two
Mertens-type inputs; this statement proves that the carrier comparison itself
is already unconditional. -/
theorem smallDivisorAverage_lower_Euler_constant_unconditional
    (P : EscAnalytic.Params) :
    ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      c * smallDivisorEulerSum X ≤ smallDivisorAverage P X := by
  rcases sAvgRecipCoprime_lower_local_density_constant_unconditional P with
    ⟨c, X₀, hc, hcop⟩
  exact ⟨c, X₀, hc, fun X hX =>
    smallDivisorAverage_lower_from_coprime_average_constant P X c (hcop X hX)⟩

/-- Combined lower-bound reduction for the small-divisor average.

This packages the exact remaining target: a uniform coprime reciprocal lower
bound and a truncated odd-prime Euler lower bound imply
`∑_{s≤S,sqf} A_s/s ≳ log S log z`. -/
theorem smallDivisorAverage_lower_from_coprime_and_euler
    (P : EscAnalytic.Params) (X cS cE : ℝ)
    (hcS_nonneg : 0 ≤ cS)
    (hlogS_nonneg : 0 ≤ Real.log (EscAnalytic.SScale P X))
    (hcop : ∀ d ∈ (Finset.Icc (1 : ℕ) ⌊EscAnalytic.UScale X⌋₊).filter
          (fun d => d ∣ roughModulus X ∧ Odd d),
        cS * Real.log (EscAnalytic.SScale P X) *
            ((Nat.totient d : ℝ) / (d : ℝ)) ≤ sAvgRecipCoprime P X d)
    (hE : cE * Real.log (EscAnalytic.zScale X) ≤ smallDivisorEulerSum X) :
    cS * cE * Real.log (EscAnalytic.SScale P X) *
        Real.log (EscAnalytic.zScale X)
      ≤ smallDivisorAverage P X := by
  have hmain := smallDivisorAverage_lower_from_coprime_average P X cS hcop
  have hscale_nonneg : 0 ≤ cS * Real.log (EscAnalytic.SScale P X) := by
    exact mul_nonneg hcS_nonneg hlogS_nonneg
  have hEuler_scaled :
      (cS * Real.log (EscAnalytic.SScale P X)) *
          (cE * Real.log (EscAnalytic.zScale X))
        ≤ (cS * Real.log (EscAnalytic.SScale P X)) *
          smallDivisorEulerSum X :=
    mul_le_mul_of_nonneg_left hE hscale_nonneg
  calc
    cS * cE * Real.log (EscAnalytic.SScale P X) *
        Real.log (EscAnalytic.zScale X)
        = (cS * Real.log (EscAnalytic.SScale P X)) *
            (cE * Real.log (EscAnalytic.zScale X)) := by ring
    _ ≤ (cS * Real.log (EscAnalytic.SScale P X)) *
          smallDivisorEulerSum X := hEuler_scaled
    _ ≤ smallDivisorAverage P X := hmain

/-- Eventual small-divisor lower bound from a coprime reciprocal estimate and
an explicitly supplied logarithmic lower bound for the Euler carrier.

This theorem is the generic transport lemma: the finite summation interchange,
scale algebra, and positivity checks are all discharged here, while the source
of the Euler lower bound is left as an explicit hypothesis. -/
theorem smallDivisorAverage_lower_from_coprime_and_euler_bound
    (P : EscAnalytic.Params) (cS XS : ℝ) (hcS : 0 < cS)
    (hcop : ∀ X : ℝ, XS ≤ X →
      ∀ d ∈ (Finset.Icc (1 : ℕ) ⌊EscAnalytic.UScale X⌋₊).filter
          (fun d => d ∣ roughModulus X ∧ Odd d),
        cS * Real.log (EscAnalytic.SScale P X) *
            ((Nat.totient d : ℝ) / (d : ℝ)) ≤ sAvgRecipCoprime P X d)
    (hEuler :
      ∃ cE XE : ℝ, 0 < cE ∧ ∀ X : ℝ, XE ≤ X →
        cE * Real.log (EscAnalytic.zScale X) ≤ smallDivisorEulerSum X) :
    ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X)
        ≤ smallDivisorAverage P X := by
  rcases hEuler with ⟨cE, XE, hcE, hE⟩
  refine ⟨cS * cE, max XS (max XE 1), mul_pos hcS hcE, ?_⟩
  intro X hX
  have hXS : XS ≤ X := le_trans (le_max_left _ _) hX
  have htail : max XE (1 : ℝ) ≤ X := le_trans (le_max_right _ _) hX
  have hXE : XE ≤ X := le_trans (le_max_left _ _) htail
  have hXone : (1 : ℝ) ≤ X := le_trans (le_max_right _ _) htail
  have hXpos : 0 < X := lt_of_lt_of_le zero_lt_one hXone
  have hlogS_nonneg : 0 ≤ Real.log (EscAnalytic.SScale P X) := by
    unfold EscAnalytic.SScale
    rw [Real.log_rpow hXpos]
    exact mul_nonneg P.η_pos.le (Real.log_nonneg hXone)
  exact smallDivisorAverage_lower_from_coprime_and_euler P X cS cE hcS.le
    hlogS_nonneg (hcop X hXS) (hE X hXE)

/-- Eventual small-divisor lower bound from the coprime reciprocal estimate and
the standard truncated Euler-sum/Mertens input.

This packages away the former caller-supplied Euler lower-bound parameter in
`smallDivisorAverage_lower_from_coprime_and_euler`: the Euler-carrier lower
growth is now supplied by `smallDivisorEulerSum_lower_from_standard_input`, which
itself is derived from the finite-witness standard input.  The remaining
hypothesis is exactly the uniform coprime squarefree reciprocal lower estimate. -/
theorem smallDivisorAverage_lower_from_coprime_and_euler_input
    (P : EscAnalytic.Params) (cS XS : ℝ) (hcS : 0 < cS)
    (hcop : ∀ X : ℝ, XS ≤ X →
      ∀ d ∈ (Finset.Icc (1 : ℕ) ⌊EscAnalytic.UScale X⌋₊).filter
          (fun d => d ∣ roughModulus X ∧ Odd d),
        cS * Real.log (EscAnalytic.SScale P X) *
            ((Nat.totient d : ℝ) / (d : ℝ)) ≤ sAvgRecipCoprime P X d) :
    ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X)
        ≤ smallDivisorAverage P X :=
  smallDivisorAverage_lower_from_coprime_and_euler_bound P cS XS hcS hcop
    smallDivisorEulerSum_lower_from_standard_input

/-- Compatibility alias for the former prime-reciprocal route name. -/
theorem smallDivisorAverage_lower_from_coprime_and_prime_recip
    (P : EscAnalytic.Params) (cS XS : ℝ) (hcS : 0 < cS)
    (hcop : ∀ X : ℝ, XS ≤ X →
      ∀ d ∈ (Finset.Icc (1 : ℕ) ⌊EscAnalytic.UScale X⌋₊).filter
          (fun d => d ∣ roughModulus X ∧ Odd d),
        cS * Real.log (EscAnalytic.SScale P X) *
            ((Nat.totient d : ℝ) / (d : ℝ)) ≤ sAvgRecipCoprime P X d) :
    ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X)
        ≤ smallDivisorAverage P X :=
  smallDivisorAverage_lower_from_coprime_and_euler_input P cS XS hcS hcop

/-- Fully packaged lower half of `lem:small-divisor-average`, reduced to the
remaining finite-witness Euler input plus theorem-level coprime reciprocal
machinery.

The coprime squarefree reciprocal lower estimate is supplied by
`coprimeSquarefreeRecip_lower_bound`; the Euler side is supplied by
`smallDivisorEulerSum_lower_from_standard_input`, derived from the finite
truncated Euler-product witness input.  The summation interchange and all scale
algebra remain checked Lean proofs. -/
theorem smallDivisorAverage_lower_from_standard_inputs (P : EscAnalytic.Params) :
    ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X)
        ≤ smallDivisorAverage P X := by
  rcases sAvgRecipCoprime_two_sided_from_standard_input_with_carrier_bounds P with
    ⟨cS, _CS, XS, hcS, _hCS, hcopPack⟩
  exact smallDivisorAverage_lower_from_coprime_and_euler_input P cS XS hcS
    (fun X hX d hd => ((hcopPack X hX).2 d hd).2.2.1)

/-- Finite-witness version of the small-divisor lower-bound reduction.

Instead of assuming the full Euler-sum lower bound directly, it is enough to
exhibit any finite admissible subset `T` of odd divisors whose totient-weighted
sum is already `≳ log z`. -/
theorem smallDivisorAverage_lower_from_coprime_and_euler_witness
    (P : EscAnalytic.Params) (X cS cE : ℝ) (T : Finset ℕ)
    (hcS_nonneg : 0 ≤ cS)
    (hlogS_nonneg : 0 ≤ Real.log (EscAnalytic.SScale P X))
    (hT : T ⊆ (Finset.Icc (1 : ℕ) ⌊EscAnalytic.UScale X⌋₊).filter
      (fun d => d ∣ roughModulus X ∧ Odd d))
    (hcop : ∀ d ∈ (Finset.Icc (1 : ℕ) ⌊EscAnalytic.UScale X⌋₊).filter
          (fun d => d ∣ roughModulus X ∧ Odd d),
        cS * Real.log (EscAnalytic.SScale P X) *
            ((Nat.totient d : ℝ) / (d : ℝ)) ≤ sAvgRecipCoprime P X d)
    (hW : cE * Real.log (EscAnalytic.zScale X)
        ≤ ∑ d ∈ T, (Nat.totient d : ℝ) / (d : ℝ) ^ 2) :
    cS * cE * Real.log (EscAnalytic.SScale P X) *
        Real.log (EscAnalytic.zScale X)
      ≤ smallDivisorAverage P X := by
  exact smallDivisorAverage_lower_from_coprime_and_euler P X cS cE hcS_nonneg
    hlogS_nonneg hcop
    (le_trans hW (smallDivisorEulerSum_ge_sum_of_subset X T hT))

/-- Odd-prime-witness version of the small-divisor lower-bound reduction.

It remains to prove the coprime reciprocal lower estimate and a lower bound for
the explicit odd-prime witness sum.  The support/divisibility/range bookkeeping is
checked here. -/
theorem smallDivisorAverage_lower_from_coprime_and_oddPrimeWitness
    (P : EscAnalytic.Params) (X cS cE : ℝ)
    (hcS_nonneg : 0 ≤ cS)
    (hlogS_nonneg : 0 ≤ Real.log (EscAnalytic.SScale P X))
    (hz_ge_one : 1 ≤ EscAnalytic.zScale X)
    (hcop : ∀ d ∈ (Finset.Icc (1 : ℕ) ⌊EscAnalytic.UScale X⌋₊).filter
          (fun d => d ∣ roughModulus X ∧ Odd d),
        cS * Real.log (EscAnalytic.SScale P X) *
            ((Nat.totient d : ℝ) / (d : ℝ)) ≤ sAvgRecipCoprime P X d)
    (hW : cE * Real.log (EscAnalytic.zScale X)
        ≤ ∑ p ∈ oddPrimeEulerWitness X, (Nat.totient p : ℝ) / (p : ℝ) ^ 2) :
    cS * cE * Real.log (EscAnalytic.SScale P X) *
        Real.log (EscAnalytic.zScale X)
      ≤ smallDivisorAverage P X :=
  smallDivisorAverage_lower_from_coprime_and_euler_witness P X cS cE
    (oddPrimeEulerWitness X) hcS_nonneg hlogS_nonneg
    (oddPrimeEulerWitness_subset_smallDivisorSupport X hz_ge_one) hcop hW

/-- Prime-reciprocal-witness version of the small-divisor lower-bound reduction.

It is enough to prove the uniform coprime reciprocal lower estimate and a lower
bound for the explicit odd-prime reciprocal sum.  The conversion from prime
reciprocals to the Euler carrier is fully checked in
`smallDivisorEulerSum_ge_half_oddPrimeRecip`. -/
theorem smallDivisorAverage_lower_from_coprime_and_oddPrimeRecip
    (P : EscAnalytic.Params) (X cS cE : ℝ)
    (hcS_nonneg : 0 ≤ cS)
    (hlogS_nonneg : 0 ≤ Real.log (EscAnalytic.SScale P X))
    (hz_ge_one : 1 ≤ EscAnalytic.zScale X)
    (hcop : ∀ d ∈ (Finset.Icc (1 : ℕ) ⌊EscAnalytic.UScale X⌋₊).filter
          (fun d => d ∣ roughModulus X ∧ Odd d),
        cS * Real.log (EscAnalytic.SScale P X) *
            ((Nat.totient d : ℝ) / (d : ℝ)) ≤ sAvgRecipCoprime P X d)
    (hW : cE * Real.log (EscAnalytic.zScale X)
        ≤ (1 / 2 : ℝ) * (∑ p ∈ oddPrimeEulerWitness X, (1 : ℝ) / (p : ℝ))) :
    cS * cE * Real.log (EscAnalytic.SScale P X) *
        Real.log (EscAnalytic.zScale X)
      ≤ smallDivisorAverage P X :=
  smallDivisorAverage_lower_from_coprime_and_euler P X cS cE hcS_nonneg
    hlogS_nonneg hcop
    (hW.trans (smallDivisorEulerSum_ge_half_oddPrimeRecip X hz_ge_one))

/-- Eventual small-divisor-average lower bound from a coprime reciprocal lower
estimate and an explicit odd-prime reciprocal witness lower estimate.  The
support and conversion from prime reciprocals to the Euler carrier are fully
checked here. -/
theorem smallDivisorAverage_lower_from_coprime_and_oddPrimeRecip_input
    (P : EscAnalytic.Params) (cS XS : ℝ) (hcS : 0 < cS)
    (hcop : ∀ X : ℝ, XS ≤ X →
      ∀ d ∈ (Finset.Icc (1 : ℕ) ⌊EscAnalytic.UScale X⌋₊).filter
          (fun d => d ∣ roughModulus X ∧ Odd d),
        cS * Real.log (EscAnalytic.SScale P X) *
            ((Nat.totient d : ℝ) / (d : ℝ)) ≤ sAvgRecipCoprime P X d)
    (hrecip :
      ∃ cE XE : ℝ, 0 < cE ∧ ∀ X : ℝ, XE ≤ X →
        cE * Real.log (EscAnalytic.zScale X)
          ≤ (1 / 2 : ℝ) *
            (∑ p ∈ oddPrimeEulerWitness X, (1 : ℝ) / (p : ℝ))) :
    ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X)
        ≤ smallDivisorAverage P X := by
  rcases hrecip with ⟨cE, XE, hcE, hE⟩
  refine ⟨cS * cE, max (max XS XE) (max 1 (Real.exp 1)), mul_pos hcS hcE, ?_⟩
  intro X hX
  have hXS : XS ≤ X := le_trans (le_trans (le_max_left _ _) (le_max_left _ _)) hX
  have hXE : XE ≤ X := le_trans (le_trans (le_max_right _ _) (le_max_left _ _)) hX
  have htail : max (1 : ℝ) (Real.exp 1) ≤ X := le_trans (le_max_right _ _) hX
  have hXone : (1 : ℝ) ≤ X := le_trans (le_max_left _ _) htail
  have hXexp : Real.exp 1 ≤ X := le_trans (le_max_right _ _) htail
  have hXpos : 0 < X := lt_of_lt_of_le zero_lt_one hXone
  have hlogS_nonneg : 0 ≤ Real.log (EscAnalytic.SScale P X) := by
    unfold EscAnalytic.SScale
    rw [Real.log_rpow hXpos]
    exact mul_nonneg P.η_pos.le (Real.log_nonneg hXone)
  exact smallDivisorAverage_lower_from_coprime_and_oddPrimeRecip P X cS cE
    hcS.le hlogS_nonneg (zScale_ge_one_of_exp_one_le hXexp) (hcop X hXS) (hE X hXE)


/-- The pointwise `A_s` carrier is bounded by the full harmonic sum up to `U`. -/
theorem smallDivisorWeight_le_harmonic_floor (X : ℝ) (s : ℕ) :
    smallDivisorWeight X s ≤ (harmonic ⌊EscAnalytic.UScale X⌋₊ : ℝ) := by
  classical
  unfold smallDivisorWeight
  rw [harmonic_eq_sum_Icc]
  simp only [Rat.cast_sum, Rat.cast_inv, Rat.cast_natCast]
  simp_rw [one_div]
  apply Finset.sum_le_sum_of_subset_of_nonneg
  · intro d hd
    exact (Finset.mem_filter.mp hd).1
  · intro d _hdBig _hdSmall
    exact inv_nonneg.mpr (Nat.cast_nonneg d)

/-- `log U = 2 log z` for `U=(log X)^8` and `z=(log X)^4`. -/
theorem log_UScale_eq_two_log_zScale (X : ℝ) :
    Real.log (EscAnalytic.UScale X) = 2 * Real.log (EscAnalytic.zScale X) := by
  unfold EscAnalytic.UScale EscAnalytic.zScale
  rw [Real.log_pow, Real.log_pow]
  ring

/-- Elementary pointwise upper bound for `A_s`: since `U=z²`, the full harmonic
envelope up to `U` is `O(log z)`. -/
theorem smallDivisorWeight_upper_logZ :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ s : ℕ, smallDivisorWeight X s ≤ C * Real.log (EscAnalytic.zScale X) := by
  refine ⟨4, Real.exp (Real.exp 1), by norm_num, ?_⟩
  intro X hX s
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos _) hX
  have hlogX_ge_exp : Real.exp 1 ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hX
  have hlogX_pos : 0 < Real.log X := lt_of_lt_of_le (Real.exp_pos 1) hlogX_ge_exp
  have hlogX_ge_one : (1 : ℝ) ≤ Real.log X :=
    le_trans (by norm_num : (1 : ℝ) ≤ Real.exp 1) hlogX_ge_exp
  have hU_ge_one : (1 : ℝ) ≤ EscAnalytic.UScale X := by
    unfold EscAnalytic.UScale
    calc
      (1 : ℝ) = (1 : ℝ) ^ (8 : ℕ) := by norm_num
      _ ≤ (Real.log X) ^ (8 : ℕ) :=
          pow_le_pow_left₀ zero_le_one hlogX_ge_one 8
  have hharm :
      (harmonic ⌊EscAnalytic.UScale X⌋₊ : ℝ) ≤
        1 + Real.log (EscAnalytic.UScale X) :=
    harmonic_floor_le_one_add_log (EscAnalytic.UScale X) hU_ge_one
  have hloglog_ge_one : (1 : ℝ) ≤ Real.log (Real.log X) := by
    rw [Real.le_log_iff_exp_le hlogX_pos]
    exact hlogX_ge_exp
  have hlogZ_eq :
      Real.log (EscAnalytic.zScale X) = 4 * Real.log (Real.log X) := by
    unfold EscAnalytic.zScale
    rw [Real.log_pow]
    ring
  have hlogZ_ge_one : (1 : ℝ) ≤ Real.log (EscAnalytic.zScale X) := by
    rw [hlogZ_eq]
    nlinarith
  have htail :
      1 + Real.log (EscAnalytic.UScale X) ≤
        4 * Real.log (EscAnalytic.zScale X) := by
    rw [log_UScale_eq_two_log_zScale X]
    nlinarith
  calc
    smallDivisorWeight X s
        ≤ (harmonic ⌊EscAnalytic.UScale X⌋₊ : ℝ) :=
          smallDivisorWeight_le_harmonic_floor X s
    _ ≤ 1 + Real.log (EscAnalytic.UScale X) := hharm
    _ ≤ 4 * Real.log (EscAnalytic.zScale X) := htail

/-- Upper half of `lem:small-divisor-average`, reduced to the already checked
squarefree reciprocal conductor average. -/
theorem smallDivisorAverage_le_logZ_mul_sAvgRecip :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ P : EscAnalytic.Params,
        smallDivisorAverage P X
          ≤ C * Real.log (EscAnalytic.zScale X) * sAvgRecip P X := by
  rcases smallDivisorWeight_upper_logZ with ⟨C, X₀, hC, hweight⟩
  refine ⟨C, X₀, hC, ?_⟩
  intro X hX P
  classical
  unfold smallDivisorAverage sAvgRecip
  calc
    (∑ s ∈ (Finset.Icc (1 : ℕ) ⌊EscAnalytic.SScale P X⌋₊).filter
          (fun s => Squarefree s), smallDivisorWeight X s / (s : ℝ))
        ≤ ∑ s ∈ (Finset.Icc (1 : ℕ) ⌊EscAnalytic.SScale P X⌋₊).filter
          (fun s => Squarefree s),
            (C * Real.log (EscAnalytic.zScale X)) * ((1 : ℝ) / (s : ℝ)) := by
          apply Finset.sum_le_sum
          intro s hs
          have hsIcc : s ∈ Finset.Icc (1 : ℕ) ⌊EscAnalytic.SScale P X⌋₊ :=
            (Finset.mem_filter.mp hs).1
          have hspos_nat : 0 < s :=
            lt_of_lt_of_le Nat.zero_lt_one (Finset.mem_Icc.mp hsIcc).1
          have hs_nonneg : (0 : ℝ) ≤ (s : ℝ) := Nat.cast_nonneg s
          calc
            smallDivisorWeight X s / (s : ℝ)
                ≤ (C * Real.log (EscAnalytic.zScale X)) / (s : ℝ) :=
                  div_le_div_of_nonneg_right (hweight X hX s) hs_nonneg
            _ = (C * Real.log (EscAnalytic.zScale X)) * ((1 : ℝ) / (s : ℝ)) := by
                  ring
    _ = (C * Real.log (EscAnalytic.zScale X)) *
          (∑ s ∈ (Finset.Icc (1 : ℕ) ⌊EscAnalytic.SScale P X⌋₊).filter
            (fun s => Squarefree s), (1 : ℝ) / (s : ℝ)) := by
          rw [Finset.mul_sum]
    _ = C * Real.log (EscAnalytic.zScale X) *
          (∑ s ∈ (Finset.Icc (1 : ℕ) ⌊EscAnalytic.SScale P X⌋₊).filter
            (fun s => Squarefree s), (1 : ℝ) / (s : ℝ)) := by
          ring

/-- Fully elementary upper bound for the averaged small-prime divisor sum:
`∑_s A_s/s ≪ log S log z`.  The lower half, which needs the truncated Euler
product over odd primes, remains separate analytic debt. -/
theorem smallDivisorAverage_upper_unconditional (P : EscAnalytic.Params) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      smallDivisorAverage P X
        ≤ C * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X) := by
  rcases smallDivisorAverage_le_logZ_mul_sAvgRecip with ⟨Cz, Xz, hCz, hz⟩
  rcases sAvgRecip_upper_unconditional P with ⟨Cs, Xs, hCs, hs⟩
  refine ⟨Cz * Cs, max (max Xz Xs) (Real.exp (Real.exp 1)), mul_pos hCz hCs, ?_⟩
  intro X hX
  have hXz : Xz ≤ X := le_trans (le_trans (le_max_left _ _) (le_max_left _ _)) hX
  have hXs : Xs ≤ X := le_trans (le_trans (le_max_right _ _) (le_max_left _ _)) hX
  have hXexp : Real.exp (Real.exp 1) ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos _) hXexp
  have hlogZ_nonneg : 0 ≤ Real.log (EscAnalytic.zScale X) := by
    have hlogX_ge_exp : Real.exp 1 ≤ Real.log X := by
      rw [Real.le_log_iff_exp_le hXpos]
      exact hXexp
    have hlogX_ge_one : (1 : ℝ) ≤ Real.log X :=
      le_trans (by norm_num : (1 : ℝ) ≤ Real.exp 1) hlogX_ge_exp
    have hz_ge_one : (1 : ℝ) ≤ EscAnalytic.zScale X := by
      unfold EscAnalytic.zScale
      calc
        (1 : ℝ) = (1 : ℝ) ^ (4 : ℕ) := by norm_num
        _ ≤ (Real.log X) ^ (4 : ℕ) :=
            pow_le_pow_left₀ zero_le_one hlogX_ge_one 4
    exact Real.log_nonneg hz_ge_one
  have h1 := hz X hXz P
  have h2 := hs X hXs
  calc
    smallDivisorAverage P X
        ≤ Cz * Real.log (EscAnalytic.zScale X) * sAvgRecip P X := h1
    _ ≤ Cz * Real.log (EscAnalytic.zScale X) *
          (Cs * Real.log (EscAnalytic.SScale P X)) := by
          exact mul_le_mul_of_nonneg_left h2
            (mul_nonneg hCz.le hlogZ_nonneg)
    _ = (Cz * Cs) * Real.log (EscAnalytic.SScale P X) *
          Real.log (EscAnalytic.zScale X) := by ring

/-- Absolute-value form of the elementary small-divisor average upper bound. -/
theorem abs_smallDivisorAverage_upper_unconditional (P : EscAnalytic.Params) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      |smallDivisorAverage P X| ≤
        C * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X) := by
  rcases smallDivisorAverage_upper_unconditional P with ⟨C, X₀, hC, hupper⟩
  refine ⟨C, X₀, hC, ?_⟩
  intro X hX
  rw [abs_of_nonneg (smallDivisorAverage_nonneg P X)]
  exact hupper X hX

/-- Two-sided form of the small-divisor average lemma.

The lower bound uses the checked coprime reciprocal bridge and the remaining
finite-witness Euler input packaged in
`smallDivisorAverage_lower_from_standard_inputs`; the upper bound is the fully
checked harmonic/squarefree reciprocal estimate
`smallDivisorAverage_upper_unconditional`. -/
theorem smallDivisorAverage_two_sided_from_standard_inputs
    (P : EscAnalytic.Params) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X)
        ≤ smallDivisorAverage P X ∧
      smallDivisorAverage P X
        ≤ C * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X) := by
  rcases smallDivisorAverage_lower_from_standard_inputs P with ⟨c, Xlow, hc, hlow⟩
  rcases smallDivisorAverage_upper_unconditional P with ⟨C, Xup, hC, hup⟩
  refine ⟨c, C, max Xlow Xup, hc, hC, ?_⟩
  intro X hX
  have hXlow : Xlow ≤ X := le_trans (le_max_left _ _) hX
  have hXup : Xup ≤ X := le_trans (le_max_right _ _) hX
  exact ⟨hlow X hXlow, hup X hXup⟩

/-- A bare two-sided small-divisor average estimate gives the carrier-bundled
version with logarithm and nonnegativity side conditions.  These extra clauses
are finite-carrier bookkeeping rather than new analytic input. -/
theorem smallDivisorAverage_two_sided_with_carrier_bounds_of_bounds
    (P : EscAnalytic.Params)
    (h :
      ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        c * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X)
          ≤ smallDivisorAverage P X ∧
        smallDivisorAverage P X
          ≤ C * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X)) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      0 ≤ Real.log (EscAnalytic.SScale P X) ∧
        0 ≤ Real.log (EscAnalytic.zScale X) ∧
        0 ≤ smallDivisorAverage P X ∧
        c * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X)
          ≤ smallDivisorAverage P X ∧
        smallDivisorAverage P X
          ≤ C * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X) := by
  rcases h with ⟨c, C, Xmain, hc, hC, hbounds⟩
  refine ⟨c, C, max Xmain (Real.exp 1), hc, hC, ?_⟩
  intro X hX
  have hXmain : Xmain ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 1 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 1) hXexp
  have hXone : (1 : ℝ) ≤ X :=
    le_trans (by norm_num : (1 : ℝ) ≤ Real.exp 1) hXexp
  have hlogS_nonneg : 0 ≤ Real.log (EscAnalytic.SScale P X) := by
    unfold EscAnalytic.SScale
    rw [Real.log_rpow hXpos]
    exact mul_nonneg P.η_pos.le (Real.log_nonneg hXone)
  have hlogX_ge_one : (1 : ℝ) ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hXexp
  have hlogZ_nonneg : 0 ≤ Real.log (EscAnalytic.zScale X) := by
    have hloglog_nonneg : 0 ≤ Real.log (Real.log X) :=
      Real.log_nonneg hlogX_ge_one
    unfold EscAnalytic.zScale
    rw [Real.log_pow]
    nlinarith
  rcases hbounds X hXmain with ⟨hlower, hupper⟩
  exact ⟨hlogS_nonneg, hlogZ_nonneg, smallDivisorAverage_nonneg P X, hlower, hupper⟩

/-- Forget the checked carrier side conditions from a bundled two-sided
small-divisor average estimate. -/
theorem smallDivisorAverage_two_sided_bounds_of_carrier_bounds
    (P : EscAnalytic.Params)
    (h :
      ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        0 ≤ Real.log (EscAnalytic.SScale P X) ∧
          0 ≤ Real.log (EscAnalytic.zScale X) ∧
          0 ≤ smallDivisorAverage P X ∧
          c * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X)
            ≤ smallDivisorAverage P X ∧
          smallDivisorAverage P X
            ≤ C * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X)) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X)
        ≤ smallDivisorAverage P X ∧
      smallDivisorAverage P X
        ≤ C * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X) := by
  rcases h with ⟨c, C, X₀, hc, hC, hcarrier⟩
  refine ⟨c, C, X₀, hc, hC, ?_⟩
  intro X hX
  have hpack := hcarrier X hX
  exact ⟨hpack.2.2.2.1, hpack.2.2.2.2⟩

/-- Bare and carrier-bundled two-sided small-divisor average estimates have the
same analytic content. -/
theorem smallDivisorAverage_two_sided_bounds_iff_carrier_bounds
    (P : EscAnalytic.Params) :
    (∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X)
        ≤ smallDivisorAverage P X ∧
      smallDivisorAverage P X
        ≤ C * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X)) ↔
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      0 ≤ Real.log (EscAnalytic.SScale P X) ∧
        0 ≤ Real.log (EscAnalytic.zScale X) ∧
        0 ≤ smallDivisorAverage P X ∧
        c * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X)
          ≤ smallDivisorAverage P X ∧
        smallDivisorAverage P X
          ≤ C * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X) := by
  constructor
  · exact smallDivisorAverage_two_sided_with_carrier_bounds_of_bounds P
  · exact smallDivisorAverage_two_sided_bounds_of_carrier_bounds P

/-- Two-sided small-divisor average bound bundled with the checked carrier and
logarithm side conditions used in downstream normalization. -/
theorem smallDivisorAverage_two_sided_from_standard_inputs_with_carrier_bounds
    (P : EscAnalytic.Params) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      0 ≤ Real.log (EscAnalytic.SScale P X) ∧

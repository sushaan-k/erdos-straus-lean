          eulerProductFactorAtNat N * (A.Ered N : ℝ)) ∧
    (∀ N : ℕ, 3 ≤ N → Tred ≤ N →
      (fixedNumeratorExceptionalCount m N : ℝ) ≤
        (fixedNumeratorSmoothRangeCount m (zNatScale N) N : ℝ) +
          eulerProductFactorAtNat N * (A.Ered N : ℝ)) ∧
    IsMainBound (fixedNumeratorExceptionalCount m) ∧
    ∃ c > (0 : ℝ), ∃ C > (0 : ℝ), ∀ N : ℕ, 3 ≤ N →
      (fixedNumeratorExceptionalCount m N : ℝ) ≤ C * (N : ℝ) * saving c N := by
  refine ⟨
    fixedNumeratorPaperSuenAnalyticCoreOptimizationInputs_class_card A,
    fixedNumeratorPaperSuenAnalyticCoreOptimizationInputs_saving_bound A,
    fixedNumeratorPaperSuenAnalyticCoreOptimizationInputs_decomp A,
    fixedNumeratorPaperSuenAnalyticCoreOptimizationInputs_suen_tail A,

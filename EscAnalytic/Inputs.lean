    LinearSieveRoughDyadicMultiplesSignedErrorQuarterBoundOnPositiveRanges_of_floorErrorNormalized
      h.2.1,
    h.2.2⟩

/-- Standard prime-reciprocal Mertens theorem in one-sided upper-bound form:
`sum_{p ≤ N} 1/p ≤ log log N + O(1)`.  This is the one-sided bounded-defect API
actually consumed by the finite rough-prime Euler-product lower bound; stronger
convergent-defect or two-sided Mertens formulations remain available as
conditional bridge targets above, but are not exported as active assumptions. -/
axiom standard_prime_recip_sharp_mertens_nat_defect_eventually_upper_bound :
    PrimeRecipSharpMertensNatDefectEventuallyUpperBound

/-- Natural-cutoff one-sided bounded-defect prime-reciprocal Mertens API,
theorem-level alias for the exported standard Mertens input.  The exact finite
rough-prime Euler-product lower bound consumed by the live no-extra-modulus
route is then theorem-level from this statement by the checked
dyadic/floor/product bridges above. -/
theorem rough_dyadic_prime_recip_sharp_mertens_nat_defect_eventually_upper_bound :
    PrimeRecipSharpMertensNatDefectEventuallyUpperBound :=
  standard_prime_recip_sharp_mertens_nat_defect_eventually_upper_bound

/-- Finite rough-prime Euler-product lower-bound API, theorem-level from the
exported natural-cutoff prime-reciprocal Mertens input. -/
theorem rough_dyadic_bad_prime_main_euler_product_lower_bound :
    roughDyadicBadPrimeMainEulerProductLowerBound :=
  roughDyadicBadPrimeMainEulerProductLowerBound_of_defectEventuallyUpperBound
    rough_dyadic_prime_recip_sharp_mertens_nat_defect_eventually_upper_bound

/-- Mertens lower control of the rough-prime density gives the paper's inverse
Euler-product upper bound at the same scale:
`V(z) ≫ 1 / log z` implies `V(z)^{-1} ≪ log z`.

This is the algebraic bridge used when the lifting step writes the large-`m`
range with the factor `∏_{p≤z_N}(1-1/p)^{-1}`. -/
theorem roughDyadicBadPrimeMainEulerProduct_inv_log_z_bound_of_lower
    (hprod : roughDyadicBadPrimeMainEulerProductLowerBound) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      (roughDyadicBadPrimeMainEulerProduct X)⁻¹ ≤
        C * Real.log (EscAnalytic.zScale X) := by
  rcases hprod with ⟨c, Xprod, hc, hprodX⟩
  refine ⟨c⁻¹, max Xprod (Real.exp 2), inv_pos.mpr hc, ?_⟩
  intro X hX
  have hXprod : Xprod ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hlog_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp
  have hlower :
      c / Real.log (EscAnalytic.zScale X) ≤ roughDyadicBadPrimeMainEulerProduct X :=
    hprodX X hXprod
  have hlower_pos : 0 < c / Real.log (EscAnalytic.zScale X) :=
    div_pos hc hlog_pos
  have hprod_pos : 0 < roughDyadicBadPrimeMainEulerProduct X :=
    lt_of_lt_of_le hlower_pos hlower
  have hrhs_pos : 0 < c⁻¹ * Real.log (EscAnalytic.zScale X) :=
    mul_pos (inv_pos.mpr hc) hlog_pos
  rw [inv_le_comm₀ hprod_pos hrhs_pos]
  have hrewrite :
      (c⁻¹ * Real.log (EscAnalytic.zScale X))⁻¹ =
        c / Real.log (EscAnalytic.zScale X) := by
    field_simp [ne_of_gt hc, ne_of_gt hlog_pos]
  rw [hrewrite]
  exact hlower


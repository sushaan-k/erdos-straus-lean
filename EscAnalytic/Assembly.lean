    ∀ N : ℕ, 3 ≤ N → T ≤ N →
      (reducedSumCountFor zNatScale N : ℝ) ≤
        (N : ℝ) * quarticSaving (cμ / 2) N :=
  reducedSumCountFor_quartic_saving_of_finite_transfer_sigma_class_majorants

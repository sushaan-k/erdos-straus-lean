    unfold EscAnalytic.zScale
    rw [Real.log_pow]
    positivity
  have hcarrier_nonneg : 0 ≤ smallDivisorEulerSum X := smallDivisorEulerSum_nonneg X
  have hlow := hlower X hXlower
  have hup := hupper X hXupper
  exact ⟨hlogZ_nonneg, hcarrier_nonneg, hlow, hup, by
    rw [abs_of_nonneg hcarrier_nonneg]
    exact hup⟩


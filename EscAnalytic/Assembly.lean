/-- Carrier-identity check for the separated fixed-`m` analytic-core route.

This records, before specializing to optimization-shaped hypotheses, that the
paper-facing package keeps the analytic reduced-count carrier on the large
range and uses the concrete fixed-numerator smooth range and Euler-product
loss from the manuscript's lifting step. -/
theorem fixedNumeratorTransferPackage_of_paper_suen_analytic_core_and_reduced_envelope_standard_tail_fields
    {ι κ : Type*} [DecidableEq κ]
    (m : ℕ) (A : FixedNumeratorPaperSuenAnalyticCoreInputs m ι)
    (R : FixedNumeratorPaperReducedClassEnvelopeInputs m ι κ)
    (hEred : R.Ered = A.Ered) :
    let P :=
      fixedNumeratorTransferPackage_of_paper_suen_analytic_core_and_reduced_envelope_standard_tail
        m A R hEred
    (∀ N : ℕ, R.Tred ≤ N → P.Ered N = A.Ered N) ∧
      P.smooth = (fun N => (fixedNumeratorSmoothRangeCount m (zNatScale N) N : ℝ)) ∧
      P.euler = eulerProductFactorAtNat := by
  simp [fixedNumeratorTransferPackage_of_paper_suen_analytic_core_and_reduced_envelope_standard_tail,
    fixedNumeratorPaperSuenTransferInputs_of_analytic_core_and_reduced_envelope,
    fixedNumeratorTransferPackage_of_paper_suen_transfer_inputs_standard_tail,
    fixedNumeratorTransferPackage_of_large_suen_finite_transfer_and_fixed_reduced_class_uniform_sum_large_range_concrete_euler_smooth_range_auto_initial_standard_tail,
    fixedNumeratorTransferPackage_of_large_suen_finite_transfer_and_fixed_reduced_class_uniform_sum_large_range_concrete_euler_smooth_range_auto_initial,
    fixedNumeratorTransferPackage_of_large_suen_finite_transfer_and_fixed_reduced_class_sum_large_range_concrete_euler_smooth_range_auto_initial_standard_tail,
    fixedNumeratorTransferPackage_of_large_suen_finite_transfer_and_fixed_reduced_class_sum_large_range_concrete_euler_smooth_range_auto_initial,
    fixedNumeratorTransferPackage_of_large_suen_finite_transfer_and_fixed_reduced_pointwise_sum_large_range_concrete_euler_smooth_range_auto_initial_standard_tail,
    fixedNumeratorTransferPackage_of_large_suen_finite_transfer_and_fixed_reduced_pointwise_sum_large_range_concrete_euler_smooth_range_auto_initial,
    fixedNumeratorTransferPackage_of_large_suen_finite_transfer_and_concrete_lift_on_range_and_initial,
    fixedNumeratorTransferPackage_of_large_suen_finite_transfer_and_lift_on_range_and_initial]
  intro N hTN hlt
  omega

/-- Large-range reduced-count saving for the separated fixed-`m`
analytic-core route.

The auto-initial package may alter the finite-initial carrier below `R.Tred`;
above that cutoff this theorem recovers the saving bound for the manuscript's
analytic carrier `A.Ered`. -/
theorem fixedNumeratorTransferPackage_of_paper_suen_analytic_core_and_reduced_envelope_standard_tail_Ered_large
    {ι κ : Type*} [DecidableEq κ]
    (m : ℕ) (A : FixedNumeratorPaperSuenAnalyticCoreInputs m ι)
    (R : FixedNumeratorPaperReducedClassEnvelopeInputs m ι κ)
    (hEred : R.Ered = A.Ered) :
    let P :=
      fixedNumeratorTransferPackage_of_paper_suen_analytic_core_and_reduced_envelope_standard_tail
        m A R hEred
    ∀ N : ℕ, 3 ≤ N → R.Tred ≤ N →
      (A.Ered N : ℝ) ≤ P.Ered_C₁ * ((N : ℝ) * saving P.Ered_c₁ N) := by
  intro P N hN hTN
  have hfields :=
    fixedNumeratorTransferPackage_of_paper_suen_analytic_core_and_reduced_envelope_standard_tail_fields
      m A R hEred
  rcases hfields with ⟨hEredLarge, _hsmooth, _heuler⟩
  have hE : P.Ered N = A.Ered N := hEredLarge N hTN
  simpa [hE] using P.Ered_bound N hN

/-- Large-range concrete lifting inequality for the separated fixed-`m`
analytic-core route.

This exposes the final fixed-numerator lift directly in the manuscript's
concrete carriers, without first passing through the optimization-shaped
specialization. -/
theorem fixedNumeratorTransferPackage_of_paper_suen_analytic_core_and_reduced_envelope_standard_tail_lift_large
    {ι κ : Type*} [DecidableEq κ]
    (m : ℕ) (A : FixedNumeratorPaperSuenAnalyticCoreInputs m ι)
    (R : FixedNumeratorPaperReducedClassEnvelopeInputs m ι κ)
    (hEred : R.Ered = A.Ered) :
    ∀ N : ℕ, 3 ≤ N → R.Tred ≤ N →
      (fixedNumeratorExceptionalCount m N : ℝ) ≤
        (fixedNumeratorSmoothRangeCount m (zNatScale N) N : ℝ) +
          eulerProductFactorAtNat N * (A.Ered N : ℝ) := by
  intro N hN hTN
  let P :=
    fixedNumeratorTransferPackage_of_paper_suen_analytic_core_and_reduced_envelope_standard_tail
      m A R hEred
  have hfields :=
    fixedNumeratorTransferPackage_of_paper_suen_analytic_core_and_reduced_envelope_standard_tail_fields
      m A R hEred
  rcases hfields with ⟨hEredLarge, hsmooth, heuler⟩
  have hE : P.Ered N = A.Ered N := hEredLarge N hTN
  have hEfull :
      ((fixedNumeratorTransferPackage_of_paper_suen_analytic_core_and_reduced_envelope_standard_tail
        m A R hEred).Ered N) = A.Ered N := by
    simpa [P] using hE
  have hlift := P.lift N hN
  simpa [P, hsmooth, heuler, hEfull] using hlift

/-- Full endpoint for the genuinely separated analytic-core/reduced-envelope
fixed-`m` route.

This is the non-optimization version of the paper-facing fixed-`m` handoff:
the analytic core supplies the Suen finite-transfer fields, the reduced
envelope supplies the rough reduced summation, and the shared carrier identity
links both halves before the final transfer package and exceptional-set theorem
are invoked. -/
theorem fixed_m_paper_suen_analytic_core_reduced_envelope_full_outputs_and_final_standard_tail
    {ι κ : Type*} [DecidableEq κ] {m : ℕ}
    (hm : 2 ≤ m)
    (A : FixedNumeratorPaperSuenAnalyticCoreInputs m ι)
    (R : FixedNumeratorPaperReducedClassEnvelopeInputs m ι κ)
    (hEred : R.Ered = A.Ered) :
    (∀ N : ℕ, 3 ≤ N → A.T ≤ N → ((A.cls N).card : ℝ) ≤ A.Pz N) ∧
    (∀ N : ℕ, 3 ≤ N → A.T ≤ N →
      A.c * (Real.log N) ^ ((3 : ℝ) / 4)
        ≤ (1 - (A.εb N + Real.log 3 / A.μ N)) * A.μ N) ∧
    (∀ N : ℕ, 3 ≤ N → A.T ≤ N → ∀ b ∈ A.cls N,
      A.Mb N b ≤ ((N : ℝ) / A.Pz N) *
        (Inputs.suenProb (A.μ N) (A.δb N b) (A.Δb N b) + A.F2R N b) +
          A.errTerm N b) ∧
    (∀ N : ℕ, 3 ≤ N → A.T ≤ N → ∀ b ∈ A.cls N,
      Inputs.suenTailConstant * A.Δb N b * Real.exp (2 * A.δb N b)
        ≤ A.εb N * A.μ N) ∧
    (∀ N : ℕ, 3 ≤ N → A.T ≤ N → ∀ b ∈ A.cls N,
      A.errTerm N b ≤ A.Xpow N b * Real.exp ((1 + A.εK) * A.μ N)) ∧
    (∀ N : ℕ, 3 ≤ N → A.T ≤ N → ∀ b ∈ A.cls N,
      A.Pz N * A.Xpow N b * Real.exp (2 * A.μ N)
        ≤ (N : ℝ) * Real.exp (-4 * A.μ N)) ∧
    (∀ N : ℕ, 3 ≤ N → A.T ≤ N → ∀ b ∈ A.cls N,
      A.F2R N b ≤ Real.exp (-3 * A.μ N)) ∧
    (∀ N : ℕ, 3 ≤ N → A.T ≤ N → ∀ b ∈ A.cls N,
      A.Mb N b ≤ ((N : ℝ) / A.Pz N) *
        Real.exp (-(1 - (A.εb N + Real.log 3 / A.μ N)) * A.μ N)) ∧
    (∀ N : ℕ, 3 ≤ N → R.Tred ≤ N →
      (∑ s ∈ Finset.Icc 1 N, ((R.clsRed N s).card : ℝ) * R.Ured N s) ≤
        eulerProductFactorAtNat N * (A.Ered N : ℝ)) ∧
    (∀ N : ℕ, 3 ≤ N → R.Tred ≤ N →
      (∑ s ∈ Finset.Icc 1 N,
        (fixedNumeratorReducedExceptionalCount m (zNatScale N) (N / s) : ℝ)) ≤
          eulerProductFactorAtNat N * (A.Ered N : ℝ)) ∧
    (∀ N : ℕ, 3 ≤ N → R.Tred ≤ N →
      (fixedNumeratorExceptionalCount m N : ℝ) ≤
        (fixedNumeratorSmoothRangeCount m (zNatScale N) N : ℝ) +
          eulerProductFactorAtNat N * (A.Ered N : ℝ)) ∧
    IsMainBound (fixedNumeratorExceptionalCount m) ∧
    ∃ c > (0 : ℝ), ∃ C > (0 : ℝ), ∀ N : ℕ, 3 ≤ N →
      (fixedNumeratorExceptionalCount m N : ℝ) ≤ C * (N : ℝ) * saving c N := by
  refine ⟨
    A.class_card,
    A.saving_bound,
    A.decomp,
    A.suen_tail,
    A.err_bound,
    A.level,
    A.F2R_bound,
    fixedNumeratorPaperSuenAnalyticCoreInputs_transfer_large A,
    ?_,
    ?_,
    fixedNumeratorTransferPackage_of_paper_suen_analytic_core_and_reduced_envelope_standard_tail_lift_large
      m A R hEred,
    fixed_numerator_main_of_paper_suen_analytic_core_and_reduced_envelope_standard_tail
      m A R hEred,
    thm_fixed_m_of_paper_suen_analytic_core_and_reduced_envelope_standard_tail
      m hm A R hEred⟩
  · intro N hN hTN
    simpa [hEred] using
      fixedNumeratorPaperReducedClassEnvelopeInputs_red_class_uniform_sum_large
        R N hN hTN
  · intro N hN hTN
    calc
      (∑ s ∈ Finset.Icc 1 N,
          (fixedNumeratorReducedExceptionalCount m (zNatScale N) (N / s) : ℝ))
          ≤ ∑ s ∈ Finset.Icc 1 N, ((R.clsRed N s).card : ℝ) * R.Ured N s := by
            apply Finset.sum_le_sum
            intro s hs
            calc
              (fixedNumeratorReducedExceptionalCount m (zNatScale N) (N / s) : ℝ)
                  ≤ ∑ b ∈ R.clsRed N s, R.Ured N s := by
                    exact fixedNumeratorReducedExceptionalCount_le_sum_class_majorants
                      (m := m) (z := zNatScale N) (N := N / s)
                      (R.clsRed N s) (R.classOfRed N s) (fun _b => R.Ured N s)
                      (R.red_class_mem_large N hN hTN s hs)
                      (R.red_class_bound_large N hN hTN s hs)
              _ = ((R.clsRed N s).card : ℝ) * R.Ured N s := by
                    simp [Finset.sum_const, nsmul_eq_mul]
      _ ≤ eulerProductFactorAtNat N * (A.Ered N : ℝ) := by
            simpa [hEred] using
              fixedNumeratorPaperReducedClassEnvelopeInputs_red_class_uniform_sum_large
                R N hN hTN


/-- Lower no-extra-modulus count core from the finite Euler-product lower bound
and only the lower half of the live signed-multiples input.  The squarefree
upper half is theorem-level from the large-square tail estimate. -/
theorem linear_sieve_rough_dyadic_modulus_one_lower_bound_core_of_productLower_and_signedMultiplesLower
    (hprodPack : roughDyadicBadPrimeMainEulerProductLowerBound)
    (hmultLower :
      LinearSieveRoughDyadicMultiplesSignedErrorLowerQuarterBoundOnPositiveRanges)
    (a₀ b₀ : ℝ) (ha₀ : 0 < a₀) (hab : a₀ < b₀) :
    roughDyadicCountModulusOneLowerBoundCore a₀ b₀ := by
  rcases hprodPack with ⟨c, Xprod, hc, hprod⟩
  rcases hmultLower a₀ b₀ 0 c Xprod ha₀ hab hc hprod with
    ⟨_, hm_lower⟩
  rcases
    linear_sieve_rough_dyadic_squarefree_signed_loss_quarter_bound
      a₀ b₀ 0 c Xprod hc hprod with
    ⟨_, _, _, hs_upper⟩
  have hE_lt : c / 4 + c / 4 < c := by
    linarith
  exact
    roughDyadicCountModulusOneLowerBoundCore_of_lowerEulerProductErrorModulusOne
      (roughDyadicBadPrimeLowerEulerProductErrorBoundModulusOne_of_productLower_and_signedComponents
        hc hE_lt hprod hm_lower hs_upper)


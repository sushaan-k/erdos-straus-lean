    intro N _hN hT'N
    exact (Classical.choose_spec hcut) N (le_trans hTdef_le hT'N)
  QuarticLargeRangeInputs.of_canonical_sigma_classes_logcube_mu_lower_eps_half_auto_card_budget_concrete_lift

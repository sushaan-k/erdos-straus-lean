    (heuler : ∀ N : ℕ, 3 ≤ N → euler N ≤ eulerC * Real.log N)
    (hrough_range : ∀ N : ℕ, 3 ≤ N →
      (roughLargeCount (z N) N : ℝ) ≤
        euler N * (EscLeanChecks.reducedBaseExceptionalCountGeTwo N (P N) : ℝ)) :
    IsMainBound exceptionalCount :=
  let cert : ∀ N : ℕ,
      EscLeanChecks.SatEventRankBudgetCertificate N (P N) (R N) :=
    fun N =>
      satEventRankBudgetCertificateOfAdmissibleForLargePrimeUniform
        N (P N) (R N) (r N) (s N) (rhoOf N)
        (eventsByBase N) (B N) (hPcert N) (hr N) (hs N)
        (hrank N) (hadm N) (hrho N) (hevent N) (hlargeBase N)
        (hbase N) (hcert_budget N)
  main_modulo_finite_transfer_cert_range_bounds_of_budget_decomp
    z P R cert Pz μ εb Xpow nohit errTerm F2R mainQ errQ εK Ered_c₁ hc₁
    hμ hPz hPz_ge_modulus hXpow hεb
    (fun N hN b hb => by
      simpa [certRankBudget, cert] using hbudget_decomp N hN b hb)
    hmain_real herr_real herr hεle hlevel hF2R hnohit hsaving
    smooth smoothExp smoothC hse_pos hse_lt hsC hsmooth hsmooth_nn
    hsmooth_range euler eulerC heC heuler_nn heuler hrough_range


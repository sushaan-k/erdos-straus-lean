    (F2R_bound : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ Finset.Icc 1 N,
      F2R N b ≤ Real.exp (-3 * μ N)) :
    ∃ c' > (0 : ℝ), ∃ C > (0 : ℝ), ∀ N : ℕ, 3 ≤ N →
      (fixedNumeratorExceptionalCount m N : ℝ) ≤ C * (N : ℝ) * saving c' N :=
  fixed_m_exceptional_sets_of_suen_optimization_exact_direct_concrete_self_mass_simplified_direct_error_bounds_standard_tail_any_m
    m μ εb δb Δb Rlevel errTerm F2R (optimizationSmallAlpha Cp)
    Cp cμ η T Tred cμ_pos eta_lt_one mertens_Pz level_budget
    (optimizationSmallAlpha_small Cp) mu_lower_saving defect_upper
    delta_nonneg Delta_nonneg suen_tail decomp errTerm_bound F2R_bound

/-- Analytic-core exact-carrier mass domination from finite reduced-class
majorants into the paper's `Mb` mass. -/
theorem fixedNumeratorPaperSuenAnalyticCoreInputs_exact_reduced_carrier_mass_of_reduced_class_majorants
    {ι κ : Type*} [DecidableEq κ] {m : ℕ}
    (H : FixedNumeratorPaperSuenAnalyticCoreInputs m ι)

      _ ≤ roughDyadicBadPrimeMainEulerProduct X := hprod X hXprod
  rcases hmult a₀ b₀ C (c / 4) Xprod' hc_quarter hprod_quarter with
    ⟨Xm, hm⟩
  rcases hsqf a₀ b₀ C (c / 4) Xprod' hc_quarter hprod_quarter with

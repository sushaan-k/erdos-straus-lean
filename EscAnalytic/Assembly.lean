rational per-class budgets.  This bridge casts those rational budgets to the
real finite-transfer estimates before packaging the fixed-`m` final data. -/
noncomputable def fixedNumeratorTransferPackage_of_large_finite_transfer_rat_and_lift
    {ι : Type*}
    (m : ℕ)
    (cls : ℕ → Finset ι)
    (MbQ : ℕ → ι → ℚ)
    (Ered : ℕ → ℕ)
    (Pz μ ε : ℕ → ℝ)
    (c Cinit : ℝ) (T0 : ℕ)
    (hc : 0 < c) (hCinit : 0 < Cinit)
    (hEred_rat : ∀ N : ℕ, 3 ≤ N → T0 ≤ N →
      (Ered N : ℚ) ≤ ∑ b ∈ cls N, MbQ N b)
    (hPz : ∀ N : ℕ, 3 ≤ N → T0 ≤ N → 1 ≤ Pz N)
    (hcard : ∀ N : ℕ, 3 ≤ N → T0 ≤ N → ((cls N).card : ℝ) ≤ Pz N)
    (htransfer : ∀ N : ℕ, 3 ≤ N → T0 ≤ N → ∀ b ∈ cls N,
      (MbQ N b : ℝ) ≤ ((N : ℝ) / Pz N) * Real.exp (-(1 - ε N) * μ N))
    (hsaving : ∀ N : ℕ, 3 ≤ N → T0 ≤ N →
      c * (Real.log N) ^ ((3 : ℝ) / 4) ≤ (1 - ε N) * μ N)
    (hinitial : ∀ N : ℕ, 3 ≤ N → N < T0 →
      (Ered N : ℝ) ≤ Cinit * ((N : ℝ) * saving c N))
    (smooth : ℕ → ℝ) (smoothExp smoothC : ℝ)
    (smoothExp_pos : 0 < smoothExp)
    (smoothExp_lt_one : smoothExp < 1)
    (smoothC_pos : 0 < smoothC)
    (smooth_bound : ∀ N : ℕ, 3 ≤ N →
      smooth N ≤ smoothC * (N : ℝ) ^ smoothExp)
    (euler : ℕ → ℝ) (eulerC : ℝ)
    (eulerC_pos : 0 < eulerC)
    (euler_bound_four : ∀ N : ℕ, 3 ≤ N →
      euler N ≤ eulerC * (Real.log N) ^ (4 : ℕ))
    (lift : ∀ N : ℕ, 3 ≤ N →
      (fixedNumeratorExceptionalCount m N : ℝ) ≤ smooth N + euler N * (Ered N : ℝ)) :
    FixedNumeratorTransferPackage m := by
  let hEredGlobal :=
    Ered_bound_global_of_large_finite_transfer_rat_on_range_and_initial_of_one_le
      cls MbQ Ered Pz μ ε c Cinit T0 hc hCinit hEred_rat

  have heta_le_one : η ≤ 1 := le_of_lt eta_lt_one
  have hc_le : ((1 - η) * cμ) / 2 ≤ (1 - η) * cμ := by
    nlinarith [mul_pos hone_minus_eta_pos cμ_pos]
  exact
    fixed_m_exceptional_sets_of_suen_optimization_exact_direct_concrete_self_mass_simplified_eps_auto_standard_tail_any_m
      m μ εb δb Δb Rlevel errTerm errExp F2R F2RExp
      α Cp cμ η (1 : ℝ) (((1 - η) * cμ) / 2) T Tred
      hc_pos heta_le_one hc_le
      mu_pos mertens_Pz level_budget alpha_small mu_lower_saving defect_upper
      delta_nonneg Delta_nonneg suen_tail decomp errTerm_le_power_exp
      (by
        intro N hN hTN b hb
        have h := errExp_bound N hN hTN b hb
        norm_num at h ⊢
        exact h)
      (by norm_num)
      F2R_le_exp F2RExp_bound

/-- Fixed-`m` concrete self-mass endpoint with `μ`-positivity derived from the
mass lower bound.

Once `0 < cμ`, the lower bound
`cμ (log N)^(3/4) ≤ μ N` already forces `0 < μ N` for every `N ≥ 3`.  Thus the
separate `mu_pos` premise in the previous auto-constant endpoint is finite real
bookkeeping rather than an analytic input. -/
theorem fixed_m_exceptional_sets_of_suen_optimization_exact_direct_concrete_self_mass_simplified_auto_constants_auto_mu_standard_tail_any_m
    (m : ℕ)
    (μ εb : ℕ → ℝ)
    (δb Δb Rlevel errTerm errExp F2R F2RExp : ℕ → ℕ → ℝ)
    (α Cp cμ η : ℝ)
    (T Tred : ℕ)
    (cμ_pos : 0 < cμ)
    (eta_lt_one : η < 1)
    (mertens_Pz : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ Finset.Icc 1 N,
      Real.log (N : ℝ) ≤
        2 * zScale (Real.exp (α * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4))))
    (level_budget : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ Finset.Icc 1 N,
      2 * Rlevel N b *
          (α * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) +
          6 * μ N
        ≤ Cp * (α ^ 4 * Real.log (N : ℝ)))
    (alpha_small : (2 + Cp) * α ^ 4 ≤ 1)
    (mu_lower_saving : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      cμ * (Real.log N) ^ ((3 : ℝ) / 4) ≤ μ N)
    (defect_upper : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      εb N + Real.log 3 / μ N ≤ η)
    (delta_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ Finset.Icc 1 N,
      0 ≤ δb N b)
    (Delta_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ Finset.Icc 1 N,
      0 ≤ Δb N b)
    (suen_tail : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ Finset.Icc 1 N,
      Inputs.suenTailConstant * Δb N b * Real.exp (2 * δb N b) ≤ εb N * μ N)
    (decomp : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ Finset.Icc 1 N,
      (fixedNumeratorReducedExceptionalCount m (zNatScale N) (N / b) : ℝ) ≤
        Inputs.suenProb (μ N) (δb N b) (Δb N b) + F2R N b + errTerm N b)
    (errTerm_le_power_exp : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ Finset.Icc 1 N,
      errTerm N b ≤
        (Real.exp (α * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4))) ^ (2 * Rlevel N b) *
          Real.exp (errExp N b))
    (errExp_bound : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ Finset.Icc 1 N,
      errExp N b ≤ 2 * μ N)
    (F2R_le_exp : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ Finset.Icc 1 N,
      F2R N b ≤ Real.exp (F2RExp N b))
    (F2RExp_bound : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ Finset.Icc 1 N,
      F2RExp N b ≤ -3 * μ N) :
    ∃ c' > (0 : ℝ), ∃ C > (0 : ℝ), ∀ N : ℕ, 3 ≤ N →
      (fixedNumeratorExceptionalCount m N : ℝ) ≤ C * (N : ℝ) * saving c' N := by
  have mu_pos : ∀ N : ℕ, 3 ≤ N → T ≤ N → 0 < μ N := by
    intro N hN hTN
    have hN_gt_one_nat : 1 < N := by omega
    have hN_gt_one : (1 : ℝ) < (N : ℝ) := by exact_mod_cast hN_gt_one_nat
    have hlog_pos : 0 < Real.log (N : ℝ) := Real.log_pos hN_gt_one
    have hpow_pos : 0 < (Real.log N) ^ ((3 : ℝ) / 4) :=
      Real.rpow_pos_of_pos hlog_pos _
    exact lt_of_lt_of_le (mul_pos cμ_pos hpow_pos)
      (mu_lower_saving N hN hTN)
  exact
    fixed_m_exceptional_sets_of_suen_optimization_exact_direct_concrete_self_mass_simplified_auto_constants_standard_tail_any_m
      m μ εb δb Δb Rlevel errTerm errExp F2R F2RExp
      α Cp cμ η T Tred cμ_pos eta_lt_one mu_pos
      mertens_Pz level_budget alpha_small mu_lower_saving defect_upper
      delta_nonneg Delta_nonneg suen_tail decomp errTerm_le_power_exp
      errExp_bound F2R_le_exp F2RExp_bound

/-- Fixed-`m` concrete self-mass endpoint with the artificial exponent carriers
removed.

The preceding endpoint still carried auxiliary functions `errExp` and
`F2RExp`.  They are not mathematical inputs from the paper; they only witness
the two direct estimates eventually consumed by the transfer argument.  This
wrapper states those estimates directly:
`errTerm ≤ X^{2R} exp(2 μ)` and `F₂ ≤ exp(-3 μ)`. -/
theorem fixed_m_exceptional_sets_of_suen_optimization_exact_direct_concrete_self_mass_simplified_direct_error_bounds_standard_tail_any_m
    (m : ℕ)
    (μ εb : ℕ → ℝ)
    (δb Δb Rlevel errTerm F2R : ℕ → ℕ → ℝ)
    (α Cp cμ η : ℝ)
    (T Tred : ℕ)
    (cμ_pos : 0 < cμ)
    (eta_lt_one : η < 1)
    (mertens_Pz : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ Finset.Icc 1 N,
      Real.log (N : ℝ) ≤
        2 * zScale (Real.exp (α * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4))))
    (level_budget : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ Finset.Icc 1 N,
      2 * Rlevel N b *
          (α * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) +
          6 * μ N
        ≤ Cp * (α ^ 4 * Real.log (N : ℝ)))
    (alpha_small : (2 + Cp) * α ^ 4 ≤ 1)
    (mu_lower_saving : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      cμ * (Real.log N) ^ ((3 : ℝ) / 4) ≤ μ N)
    (defect_upper : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      εb N + Real.log 3 / μ N ≤ η)
    (delta_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ Finset.Icc 1 N,
      0 ≤ δb N b)
    (Delta_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ Finset.Icc 1 N,
      0 ≤ Δb N b)
    (suen_tail : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ Finset.Icc 1 N,
      Inputs.suenTailConstant * Δb N b * Real.exp (2 * δb N b) ≤ εb N * μ N)
    (decomp : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ Finset.Icc 1 N,
      (fixedNumeratorReducedExceptionalCount m (zNatScale N) (N / b) : ℝ) ≤
        Inputs.suenProb (μ N) (δb N b) (Δb N b) + F2R N b + errTerm N b)
    (errTerm_bound : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ Finset.Icc 1 N,
      errTerm N b ≤
        (Real.exp (α * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4))) ^ (2 * Rlevel N b) *
          Real.exp (2 * μ N))
    (F2R_bound : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ Finset.Icc 1 N,
      F2R N b ≤ Real.exp (-3 * μ N)) :
    ∃ c' > (0 : ℝ), ∃ C > (0 : ℝ), ∀ N : ℕ, 3 ≤ N →
      (fixedNumeratorExceptionalCount m N : ℝ) ≤ C * (N : ℝ) * saving c' N := by
  exact
    fixed_m_exceptional_sets_of_suen_optimization_exact_direct_concrete_self_mass_simplified_auto_constants_auto_mu_standard_tail_any_m
      m μ εb δb Δb Rlevel errTerm
      (fun N _b => 2 * μ N) F2R (fun N _b => -3 * μ N)
      α Cp cμ η T Tred cμ_pos eta_lt_one
      mertens_Pz level_budget alpha_small mu_lower_saving defect_upper
      delta_nonneg Delta_nonneg suen_tail decomp
      (by
        intro N hN hTN b hb
        exact errTerm_bound N hN hTN b hb)
      (by
        intro N _hN _hTN _b _hb
        rfl)
      (by
        intro N hN hTN b hb
        exact F2R_bound N hN hTN b hb)
      (by
        intro N _hN _hTN _b _hb
        rfl)

/-- The concrete self-mass scale assumption forces a large optimizer.

For `zScale X = (log X)^4`, the hypothesis
`log N <= 2*zScale(exp(α(log N)^(1/4)))` is exactly strong enough to force
`1 <= 2*α^4` on every range `N >= 3`.  This is plain scale algebra, and it marks
when the self-mass shortcut is compatible with the small-alpha optimization
regime. -/
theorem concrete_self_mass_mertens_scale_forces_half_alpha
    (α : ℝ) {N : ℕ} (hN : 3 ≤ N)
    (hscale : Real.log (N : ℝ) ≤
      2 * zScale (Real.exp (α * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)))) :
    1 ≤ 2 * α ^ (4 : ℕ) := by
  have hN_gt_one_nat : 1 < N := by omega
  have hN_gt_one : (1 : ℝ) < (N : ℝ) := by exact_mod_cast hN_gt_one_nat
  have hlog_pos : 0 < Real.log (N : ℝ) := Real.log_pos hN_gt_one
  have hpow :
      ((Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) ^ (4 : ℕ) =
        Real.log (N : ℝ) := by
    rw [← Real.rpow_natCast]
    have hmul : ((1 : ℝ) / 4) * ((4 : ℕ) : ℝ) = 1 := by norm_num
    rw [← Real.rpow_mul (le_of_lt hlog_pos)]
    rw [hmul, Real.rpow_one]
  have hscale_eval :
      zScale (Real.exp (α * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4))) =
        α ^ (4 : ℕ) * Real.log (N : ℝ) := by
    unfold zScale
    rw [Real.log_exp]
    rw [mul_pow]
    rw [hpow]
  rw [hscale_eval] at hscale
  nlinarith [hlog_pos, hscale]

/-- Positive `Cp` makes the concrete self-mass Mertens scale incompatible with
the optimized small-alpha condition.

This prevents an unsound unconditional upgrade of the self-mass wrapper: if the
paper uses the optimized small alpha with `0 < Cp`, the direct `Pz = N` scale
premise cannot hold on any `N >= 3`.  The fixed-m proof must therefore use a
nontrivial class/product scale estimate, not this over-specialized shortcut. -/
theorem concrete_self_mass_mertens_scale_incompatible_with_positive_Cp_small_alpha
    (α Cp : ℝ) {N : ℕ} (hN : 3 ≤ N) (hCp : 0 < Cp)
    (hscale : Real.log (N : ℝ) ≤
      2 * zScale (Real.exp (α * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4))))
    (hsmall : (2 + Cp) * α ^ (4 : ℕ) ≤ 1) :
    False := by
  have hforce : 1 ≤ 2 * α ^ (4 : ℕ) :=
    concrete_self_mass_mertens_scale_forces_half_alpha α hN hscale
  have ha4_nonneg : 0 ≤ α ^ (4 : ℕ) := by positivity
  nlinarith

/-- Specialization of the self-mass obstruction to the concrete optimized
fixed-`m` interface.

The self-mass endpoint with `Pz = N` and
`α = optimizationSmallAlpha Cp` cannot supply its own Mertens-scale premise
when `0 < Cp`.  This is the exact obstruction faced by the over-specialized
concrete-alpha self-mass route. -/
theorem concrete_self_mass_mertens_scale_incompatible_with_optimizationSmallAlpha
    (Cp : ℝ) {N : ℕ} (hN : 3 ≤ N) (hCp : 0 < Cp)
    (hscale : Real.log (N : ℝ) ≤
      2 * zScale (Real.exp (optimizationSmallAlpha Cp *
        (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)))) :
    False :=
  concrete_self_mass_mertens_scale_incompatible_with_positive_Cp_small_alpha
    (optimizationSmallAlpha Cp) Cp hN hCp hscale
    (optimizationSmallAlpha_small Cp)

/-- Class-indexed form of the concrete optimized self-mass obstruction.

If the `Pz = N` Mertens-scale premise is asserted uniformly over the concrete
class set `Finset.Icc 1 N`, then any occupied class already contradicts
positive `Cp`. -/
theorem concrete_self_mass_mertens_PzN_uniform_incompatible_with_optimizationSmallAlpha
    (Cp : ℝ) {N b : ℕ} (hN : 3 ≤ N) (hCp : 0 < Cp)
    (hb : b ∈ Finset.Icc 1 N)
    (hmertens_Pz : ∀ b ∈ Finset.Icc 1 N,
      Real.log (N : ℝ) ≤
        2 * zScale (Real.exp (optimizationSmallAlpha Cp *
          (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)))) :
    False :=
  concrete_self_mass_mertens_scale_incompatible_with_optimizationSmallAlpha
    Cp hN hCp (hmertens_Pz b hb)

/-- The simultaneous lower and upper mass hypotheses force the corresponding
pointwise logarithmic scale inequality.

This isolates a hidden burden in the optimized direct route: once the lower
bound is stated as `cμ * logCube N ≤ μ N`, any upper bound of the form
`μ N ≤ cM * (α (log N)^(1/4))^3` must itself dominate the cubic logarithmic
scale. -/
theorem mass_logCube_lower_and_quarter_upper_force_scale_bound
    {μ : ℕ → ℝ} {cμ cM a : ℝ} {N : ℕ}
    (hmass_upper :
      μ N ≤ cM * (a * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) ^ 3)
    (hmass_lower : cμ * logCube (N : ℝ) ≤ μ N) :
    cμ * logCube (N : ℝ) ≤
      cM * (a * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) ^ 3 :=
  le_trans hmass_lower hmass_upper

/-- Pointwise obstruction for the optimized mass hypotheses.

If the optimized quarter-log upper scale is smaller than the asserted cubic
mass lower scale at a given `N`, then the mass hypotheses are inconsistent.
This is an audit lemma for avoiding vacuous unconditional wrappers. -/
theorem mass_logCube_lower_and_quarter_upper_incompatible_at
    {μ : ℕ → ℝ} {cμ cM a : ℝ} {N : ℕ}
    (hmass_upper :
      μ N ≤ cM * (a * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) ^ 3)
    (hmass_lower : cμ * logCube (N : ℝ) ≤ μ N)
    (hscale :
      cM * (a * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) ^ 3
        < cμ * logCube (N : ℝ)) :
    False := by
  have hforced :=
    mass_logCube_lower_and_quarter_upper_force_scale_bound
      (μ := μ) (cμ := cμ) (cM := cM) (a := a) (N := N)
      hmass_upper hmass_lower
  linarith

/-- Rank-floor route specialization of the pointwise mass-scale obstruction. -/
theorem rank_floor_mass_logCube_lower_and_quarter_upper_incompatible_at
    {μ : ℕ → ℝ} {cμ cM : ℝ} {N : ℕ}
    (hmass_upper :
      μ N ≤ cM *
        (optimizationSmallAlpha (((26 : ℝ) + 6) * cM) *
          (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) ^ 3)
    (hmass_lower : cμ * logCube (N : ℝ) ≤ μ N)
    (hscale :
      cM *
        (optimizationSmallAlpha (((26 : ℝ) + 6) * cM) *
          (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) ^ 3
        < cμ * logCube (N : ℝ)) :
    False :=
  mass_logCube_lower_and_quarter_upper_incompatible_at
    (μ := μ) (cμ := cμ) (cM := cM)
    (a := optimizationSmallAlpha (((26 : ℝ) + 6) * cM)) (N := N)
    hmass_upper hmass_lower hscale

/-- A fixed multiple of `(log N)^(3/4)` is eventually smaller than any positive
multiple of the cubic log scale. -/
theorem eventually_const_mul_log_three_quarters_lt_logCube_nat
    {K cμ : ℝ} (hcμ : 0 < cμ) :
    ∀ᶠ N : ℕ in Filter.atTop,
      K * (Real.log (N : ℝ)) ^ ((3 : ℝ) / 4)
        < cμ * logCube (N : ℝ) := by
  have hlog :
      Filter.Tendsto (fun N : ℕ => Real.log (N : ℝ))
        Filter.atTop Filter.atTop :=
    Real.tendsto_log_atTop.comp tendsto_natCast_atTop_atTop
  have hpow :
      Filter.Tendsto
        (fun N : ℕ => (Real.log (N : ℝ)) ^ ((9 : ℝ) / 4))
        Filter.atTop Filter.atTop :=
    (tendsto_rpow_atTop (by norm_num : (0 : ℝ) < (9 : ℝ) / 4)).comp hlog
  filter_upwards
    [Filter.eventually_ge_atTop 3,
      hpow.eventually (Filter.eventually_gt_atTop (K / cμ))]
    with N hN hbig
  have hN_gt_one_nat : 1 < N := by omega
  have hN_gt_one : (1 : ℝ) < (N : ℝ) := by exact_mod_cast hN_gt_one_nat
  have hLpos : 0 < Real.log (N : ℝ) := Real.log_pos hN_gt_one
  have hL34pos :
      0 < (Real.log (N : ℝ)) ^ ((3 : ℝ) / 4) :=
    Real.rpow_pos_of_pos hLpos ((3 : ℝ) / 4)
  have hK_lt :
      K < cμ * (Real.log (N : ℝ)) ^ ((9 : ℝ) / 4) := by
    have hmul := mul_lt_mul_of_pos_left hbig hcμ
    have hcancel : cμ * (K / cμ) = K := by
      field_simp [ne_of_gt hcμ]
    linarith
  have hmul :=
    mul_lt_mul_of_pos_right hK_lt hL34pos
  have hpow_mul :
      (Real.log (N : ℝ)) ^ ((9 : ℝ) / 4) *
          (Real.log (N : ℝ)) ^ ((3 : ℝ) / 4) =
        (Real.log (N : ℝ)) ^ (3 : ℝ) := by
    rw [← Real.rpow_add hLpos]
    norm_num
  calc
    K * (Real.log (N : ℝ)) ^ ((3 : ℝ) / 4)
        <
          (cμ * (Real.log (N : ℝ)) ^ ((9 : ℝ) / 4)) *
            (Real.log (N : ℝ)) ^ ((3 : ℝ) / 4) := hmul
    _ = cμ * ((Real.log (N : ℝ)) ^ ((9 : ℝ) / 4) *
          (Real.log (N : ℝ)) ^ ((3 : ℝ) / 4)) := by ring
    _ = cμ * (Real.log (N : ℝ)) ^ (3 : ℝ) := by rw [hpow_mul]
    _ = cμ * logCube (N : ℝ) := by
      unfold logCube
      congr 1
      change (Real.log (N : ℝ)) ^ (3 : ℝ) =
        (Real.log (N : ℝ)) ^ (3 : ℕ)
      exact Real.rpow_natCast (Real.log (N : ℝ)) 3

/-- The optimized quarter-log upper scale is eventually smaller than a positive
cubic log lower scale, for any fixed constants. -/
theorem eventually_quarter_log_cube_scale_lt_logCube_nat
    {cμ cM a : ℝ} (hcμ : 0 < cμ) :
    ∀ᶠ N : ℕ in Filter.atTop,
      cM * (a * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) ^ 3
        < cμ * logCube (N : ℝ) := by
  filter_upwards
    [Filter.eventually_ge_atTop 3,
      eventually_const_mul_log_three_quarters_lt_logCube_nat
        (K := cM * a ^ (3 : ℕ)) hcμ]
    with N hN hscale
  have hN_gt_one_nat : 1 < N := by omega
  have hN_gt_one : (1 : ℝ) < (N : ℝ) := by exact_mod_cast hN_gt_one_nat
  have hLpos : 0 < Real.log (N : ℝ) := Real.log_pos hN_gt_one
  have hLnonneg : 0 ≤ Real.log (N : ℝ) := hLpos.le
  have hpow_eq :
      ((Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) ^ (3 : ℕ) =
        (Real.log (N : ℝ)) ^ ((3 : ℝ) / 4) := by
    rw [← Real.rpow_natCast]
    rw [← Real.rpow_mul hLnonneg]
    norm_num
  have hscale_eq :
      cM * (a * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) ^ 3 =
        (cM * a ^ (3 : ℕ)) *
          (Real.log (N : ℝ)) ^ ((3 : ℝ) / 4) := by
    rw [mul_pow, hpow_eq]
    ring
  calc
    cM * (a * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) ^ 3
        = (cM * a ^ (3 : ℕ)) *
          (Real.log (N : ℝ)) ^ ((3 : ℝ) / 4) := hscale_eq
    _ < cμ * logCube (N : ℝ) := by
      simpa [mul_assoc] using hscale

/-- The simultaneous quarter-log upper mass law and cubic lower mass law cannot
hold eventually.  This is the uniform version of the pointwise obstruction
above. -/
theorem mass_logCube_lower_and_quarter_upper_eventually_incompatible
    {μ : ℕ → ℝ} {cμ cM a : ℝ} {T : ℕ}
    (hcμ : 0 < cμ)
    (hmass_upper : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      μ N ≤ cM * (a * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) ^ 3)
    (hmass_lower : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      cμ * logCube (N : ℝ) ≤ μ N) :
    False := by
  rcases Filter.eventually_atTop.mp
      (eventually_quarter_log_cube_scale_lt_logCube_nat
        (cμ := cμ) (cM := cM) (a := a) hcμ) with
    ⟨Tscale, hscale⟩
  let N : ℕ := max 3 (max T Tscale)
  have hN3 : 3 ≤ N := by
    dsimp [N]
    exact Nat.le_max_left 3 (max T Tscale)
  have hTN : T ≤ N := by
    dsimp [N]
    exact le_trans (Nat.le_max_left T Tscale) (Nat.le_max_right 3 (max T Tscale))
  have hTscale : Tscale ≤ N := by
    dsimp [N]
    exact le_trans (Nat.le_max_right T Tscale) (Nat.le_max_right 3 (max T Tscale))
  exact
    mass_logCube_lower_and_quarter_upper_incompatible_at
      (μ := μ) (cμ := cμ) (cM := cM) (a := a) (N := N)
      (hmass_upper N hN3 hTN) (hmass_lower N hN3 hTN)
      (hscale N hTscale)

/-- The optimized rank-floor mass hypotheses are themselves eventually
inconsistent. -/
theorem rank_floor_mass_logCube_lower_and_quarter_upper_eventually_incompatible
    {μ : ℕ → ℝ} {cμ cM : ℝ} {T : ℕ}
    (hcμ : 0 < cμ)
    (hmass_upper : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      μ N ≤ cM *
        (optimizationSmallAlpha (((26 : ℝ) + 6) * cM) *
          (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) ^ 3)
    (hmass_lower : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      cμ * logCube (N : ℝ) ≤ μ N) :
    False :=
  mass_logCube_lower_and_quarter_upper_eventually_incompatible
    (μ := μ) (cμ := cμ) (cM := cM)
    (a := optimizationSmallAlpha (((26 : ℝ) + 6) * cM)) (T := T)
    hcμ hmass_upper hmass_lower

/-- A fixed multiple of `log N` is eventually smaller than any positive
multiple of the cubic log scale. -/
theorem eventually_const_mul_log_lt_logCube_nat
    {K cμ : ℝ} (hcμ : 0 < cμ) :
    ∀ᶠ N : ℕ in Filter.atTop,
      K * Real.log (N : ℝ) < cμ * logCube (N : ℝ) := by
  have hlog :
      Filter.Tendsto (fun N : ℕ => Real.log (N : ℝ))
        Filter.atTop Filter.atTop :=
    Real.tendsto_log_atTop.comp tendsto_natCast_atTop_atTop
  have hpow :
      Filter.Tendsto (fun N : ℕ => (Real.log (N : ℝ)) ^ (2 : ℝ))
        Filter.atTop Filter.atTop :=
    (tendsto_rpow_atTop (by norm_num : (0 : ℝ) < (2 : ℝ))).comp hlog
  filter_upwards
    [Filter.eventually_ge_atTop 3,
      hpow.eventually (Filter.eventually_gt_atTop (K / cμ))]
    with N hN hbig
  have hN_gt_one_nat : 1 < N := by omega
  have hN_gt_one : (1 : ℝ) < (N : ℝ) := by exact_mod_cast hN_gt_one_nat
  have hLpos : 0 < Real.log (N : ℝ) := Real.log_pos hN_gt_one
  have hK_lt :
      K < cμ * (Real.log (N : ℝ)) ^ (2 : ℝ) := by
    have hmul := mul_lt_mul_of_pos_left hbig hcμ
    have hcancel : cμ * (K / cμ) = K := by
      field_simp [ne_of_gt hcμ]
    linarith
  have hmul := mul_lt_mul_of_pos_right hK_lt hLpos
  have hpow_mul :
      (Real.log (N : ℝ)) ^ (2 : ℝ) * Real.log (N : ℝ) =
        (Real.log (N : ℝ)) ^ (3 : ℝ) := by
    calc
      (Real.log (N : ℝ)) ^ (2 : ℝ) * Real.log (N : ℝ)
          = (Real.log (N : ℝ)) ^ (2 : ℝ) *
              (Real.log (N : ℝ)) ^ (1 : ℝ) := by
            rw [Real.rpow_one]
      _ = (Real.log (N : ℝ)) ^ ((2 : ℝ) + 1) := by
            rw [← Real.rpow_add hLpos]
      _ = (Real.log (N : ℝ)) ^ (3 : ℝ) := by norm_num
  calc
    K * Real.log (N : ℝ)
        < (cμ * (Real.log (N : ℝ)) ^ (2 : ℝ)) *
          Real.log (N : ℝ) := hmul
    _ = cμ * ((Real.log (N : ℝ)) ^ (2 : ℝ) *
          Real.log (N : ℝ)) := by ring
    _ = cμ * (Real.log (N : ℝ)) ^ (3 : ℝ) := by rw [hpow_mul]
    _ = cμ * logCube (N : ℝ) := by
      unfold logCube
      congr 1
      change (Real.log (N : ℝ)) ^ (3 : ℝ) =
        (Real.log (N : ℝ)) ^ (3 : ℕ)
      exact Real.rpow_natCast (Real.log (N : ℝ)) 3

/-- Pointwise obstruction for the quarter-log level budget.

With `R` at least a fixed positive multiple of the mass and with
`cμ * logCube N ≤ μ`, the left side of the level budget is already cubic-log
size.  Thus it cannot be bounded by a fixed multiple of `log N` once the latter
is smaller than that cubic lower scale. -/
theorem level_budget_rank_tail_logCube_lower_incompatible_at
    {μ cμ Cp a : ℝ} {R N : ℕ}
    (hcμ : 0 < cμ) (hN : 3 ≤ N)
    (hlogX_ge_one : 1 ≤ a * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4))
    (hrank_tail : 24 * μ ≤ 2 * (R : ℝ))
    (hmass_lower : cμ * logCube (N : ℝ) ≤ μ)
    (hlevel :
      2 * (R : ℝ) * (a * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) + 6 * μ
        ≤ Cp * (a ^ 4 * Real.log (N : ℝ)))
    (hscale :
      Cp * (a ^ 4 * Real.log (N : ℝ)) < 24 * cμ * logCube (N : ℝ)) :
    False := by
  have hexp_three : Real.exp 1 ≤ (3 : ℝ) := by
    exact le_of_lt (lt_of_lt_of_le Real.exp_one_lt_d9 (by norm_num))
  have hthreeN : (3 : ℝ) ≤ (N : ℝ) := by exact_mod_cast hN
  have hcube_nonneg : 0 ≤ logCube (N : ℝ) :=
    logCube_nonneg_of_exp_one_le (le_trans hexp_three hthreeN)
  have hμ_nonneg : 0 ≤ μ :=
    le_trans (mul_nonneg hcμ.le hcube_nonneg) hmass_lower
  have hR_nonneg : 0 ≤ 2 * (R : ℝ) := by positivity
  have hX_nonneg :
      0 ≤ a * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4) :=
    le_trans zero_le_one hlogX_ge_one
  have hR_to_RX :
      2 * (R : ℝ) ≤
        2 * (R : ℝ) * (a * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) := by
    calc
      2 * (R : ℝ) = 2 * (R : ℝ) * 1 := by ring
      _ ≤ 2 * (R : ℝ) * (a * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) :=
        mul_le_mul_of_nonneg_left hlogX_ge_one hR_nonneg
  have htail_to_left :
      24 * μ ≤
        2 * (R : ℝ) * (a * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) + 6 * μ := by
    have htail_to_RX := le_trans hrank_tail hR_to_RX
    have hsix_nonneg : 0 ≤ 6 * μ := by positivity
    linarith
  have hcube_to_left :
      24 * cμ * logCube (N : ℝ) ≤
        2 * (R : ℝ) * (a * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) + 6 * μ := by
    have hmass24 : 24 * (cμ * logCube (N : ℝ)) ≤ 24 * μ :=
      mul_le_mul_of_nonneg_left hmass_lower (by norm_num)
    nlinarith
  linarith

/-- Real-rank version of
`level_budget_rank_tail_logCube_lower_incompatible_at`.

The paper-facing fixed-numerator optimization records carry the truncation rank
as a real-valued field.  This lemma makes the same obstruction available
without coercing through a natural carrier. -/
theorem level_budget_real_rank_tail_logCube_lower_incompatible_at
    {μ cμ Cp a R : ℝ} {N : ℕ}
    (hcμ : 0 < cμ) (hN : 3 ≤ N)
    (hlogX_ge_one : 1 ≤ a * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4))
    (hrank_tail : 24 * μ ≤ 2 * R)
    (hmass_lower : cμ * logCube (N : ℝ) ≤ μ)
    (hlevel :
      2 * R * (a * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) + 6 * μ
        ≤ Cp * (a ^ 4 * Real.log (N : ℝ)))
    (hscale :
      Cp * (a ^ 4 * Real.log (N : ℝ)) < 24 * cμ * logCube (N : ℝ)) :
    False := by
  have hexp_three : Real.exp 1 ≤ (3 : ℝ) := by
    exact le_of_lt (lt_of_lt_of_le Real.exp_one_lt_d9 (by norm_num))
  have hthreeN : (3 : ℝ) ≤ (N : ℝ) := by exact_mod_cast hN
  have hcube_nonneg : 0 ≤ logCube (N : ℝ) :=
    logCube_nonneg_of_exp_one_le (le_trans hexp_three hthreeN)
  have hμ_nonneg : 0 ≤ μ :=
    le_trans (mul_nonneg hcμ.le hcube_nonneg) hmass_lower
  have hR_nonneg : 0 ≤ 2 * R := by
    have htail_nonneg : 0 ≤ 24 * μ := by nlinarith
    exact le_trans htail_nonneg hrank_tail
  have hR_to_RX :
      2 * R ≤
        2 * R * (a * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) := by
    calc
      2 * R = 2 * R * 1 := by ring
      _ ≤ 2 * R * (a * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) :=
        mul_le_mul_of_nonneg_left hlogX_ge_one hR_nonneg
  have htail_to_left :
      24 * μ ≤
        2 * R * (a * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) + 6 * μ := by
    have htail_to_RX := le_trans hrank_tail hR_to_RX
    have hsix_nonneg : 0 ≤ 6 * μ := by positivity
    linarith
  have hcube_to_left :
      24 * cμ * logCube (N : ℝ) ≤
        2 * R * (a * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) + 6 * μ := by
    have hmass24 : 24 * (cμ * logCube (N : ℝ)) ≤ 24 * μ :=
      mul_le_mul_of_nonneg_left hmass_lower (by norm_num)
    nlinarith
  linarith

/-- Eventual obstruction for the scalar quarter-log level budget. -/
theorem level_budget_rank_tail_logCube_lower_eventually_incompatible
    {μ : ℕ → ℝ} {R : ℕ → ℕ} {cμ Cp a : ℝ} {T : ℕ}
    (hcμ : 0 < cμ)
    (hlogX_event : ∀ᶠ N : ℕ in Filter.atTop,
      1 ≤ a * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4))
    (hrank_tail : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      24 * μ N ≤ 2 * (R N : ℝ))
    (hmass_lower : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      cμ * logCube (N : ℝ) ≤ μ N)
    (hlevel : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      2 * (R N : ℝ) * (a * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) + 6 * μ N
        ≤ Cp * (a ^ 4 * Real.log (N : ℝ))) :
    False := by
  rcases Filter.eventually_atTop.mp
      ((eventually_const_mul_log_lt_logCube_nat (K := Cp * a ^ 4) hcμ).and
        hlogX_event) with
    ⟨Tscale, hscale⟩
  let N : ℕ := max 3 (max T Tscale)
  have hN3 : 3 ≤ N := by
    dsimp [N]
    exact Nat.le_max_left 3 (max T Tscale)
  have hTN : T ≤ N := by
    dsimp [N]
    exact le_trans (Nat.le_max_left T Tscale) (Nat.le_max_right 3 (max T Tscale))
  have hTscale : Tscale ≤ N := by
    dsimp [N]
    exact le_trans (Nat.le_max_right T Tscale) (Nat.le_max_right 3 (max T Tscale))
  have hscaleN := hscale N hTscale
  have hscale24 :
      Cp * (a ^ 4 * Real.log (N : ℝ)) < 24 * cμ * logCube (N : ℝ) := by
    have hlt : Cp * a ^ 4 * Real.log (N : ℝ) <
        cμ * logCube (N : ℝ) := by
      simpa [mul_assoc] using hscaleN.1
    have hpos : cμ * logCube (N : ℝ) < 24 * (cμ * logCube (N : ℝ)) := by
      have hμN_nonneg : 0 ≤ μ N :=
        le_trans
          (mul_nonneg hcμ.le
            (logCube_nonneg_of_exp_one_le
              (le_trans
                (le_of_lt (lt_of_lt_of_le Real.exp_one_lt_d9 (by norm_num)))
                (by exact_mod_cast hN3 : (3 : ℝ) ≤ (N : ℝ)))))
          (hmass_lower N hN3 hTN)
      have hcube_pos : 0 < logCube (N : ℝ) := by
        have hN_gt_one_nat : 1 < N := by omega
        have hN_gt_one : (1 : ℝ) < (N : ℝ) := by exact_mod_cast hN_gt_one_nat
        unfold logCube
        exact pow_pos (Real.log_pos hN_gt_one) 3
      nlinarith [mul_pos hcμ hcube_pos]
    nlinarith
  exact
    level_budget_rank_tail_logCube_lower_incompatible_at
      (μ := μ N) (cμ := cμ) (Cp := Cp) (a := a) (R := R N) (N := N)
      hcμ hN3 hscaleN.2 (hrank_tail N hN3 hTN)
      (hmass_lower N hN3 hTN) (hlevel N hN3 hTN) hscale24

/-- Specialization of the scalar level-budget obstruction to the canonical
optimization parameter. -/
theorem optimization_level_budget_rank_tail_logCube_lower_eventually_incompatible
    {μ : ℕ → ℝ} {R : ℕ → ℕ} {cμ Cp : ℝ} {T : ℕ}
    (hcμ : 0 < cμ)
    (hrank_tail : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      24 * μ N ≤ 2 * (R N : ℝ))
    (hmass_lower : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      cμ * logCube (N : ℝ) ≤ μ N)
    (hlevel : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      2 * (R N : ℝ) *
          (optimizationSmallAlpha Cp * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) +
          6 * μ N
        ≤ Cp * ((optimizationSmallAlpha Cp) ^ 4 * Real.log (N : ℝ))) :
    False :=
  level_budget_rank_tail_logCube_lower_eventually_incompatible
    (μ := μ) (R := R) (cμ := cμ) (Cp := Cp)
    (a := optimizationSmallAlpha Cp) (T := T)
    hcμ (eventually_one_le_optimizationSmallAlpha_log_quarter Cp)
    hrank_tail hmass_lower hlevel


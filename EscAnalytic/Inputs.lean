/-- Multiples discrepancy plus squarefree loss control the modulus-one signed
product error.  No auxiliary-prime envelope is used here. -/
theorem roughDyadicBadPrimeProductErrorLowerBoundModulusOne_of_multiples_squarefree
    {a₀ b₀ C₀ Em Es Xm Xs : ℝ} (hC₀ : 0 ≤ C₀)
    (hm :
      roughDyadicBadPrimeProductMultiplesLocalErrorEnvelopeBound
        a₀ b₀ C₀ Em Xm)
    (hs :
      roughDyadicBadPrimeProductSquarefreeLossEnvelopeBound
        a₀ b₀ C₀ Es Xs) :
    roughDyadicBadPrimeProductErrorLowerBoundModulusOne
      a₀ b₀ C₀ (Em + Es) (max (max Xm Xs) 1) := by
  rcases hm with ⟨hEm_nonneg, hm⟩
  rcases hs with ⟨hEs_nonneg, hs⟩
  refine ⟨add_nonneg hEm_nonneg hEs_nonneg, ?_⟩
  intro X hX t htlo hthi
  have hXm : Xm ≤ X := le_trans (le_trans (le_max_left _ _) (le_max_left _ _)) hX
  have hXs : Xs ≤ X := le_trans (le_trans (le_max_right _ _) (le_max_left _ _)) hX
  have hXone : (1 : ℝ) ≤ X := le_trans (le_max_right _ _) hX
  have hMone : (((1 : ℕ) : ℝ) ≤ X ^ C₀) := by
    simpa using Real.one_le_rpow hXone hC₀
  have hm_bound := hm X hXm 1 hMone t htlo hthi
  have hs_bound := hs X hXs 1 hMone t htlo hthi
  have hlocal :=
    roughDyadicBadPrimeProductLocalErrorEnvelopeSum_one_le_multiplesError_add_squarefreeLoss
      X t
  have habs :
      |roughDyadicBadPrimeProductErrorSum X 1 t| ≤
        (Em + Es) * (t / Real.log (EscAnalytic.zScale X)) := by
    calc
      |roughDyadicBadPrimeProductErrorSum X 1 t|
          ≤ roughDyadicBadPrimeProductLocalErrorEnvelopeSum X 1 t :=
            abs_roughDyadicBadPrimeProductErrorSum_le_localErrorEnvelope X 1 t
      _ ≤ roughDyadicBadPrimeProductMultiplesLocalErrorEnvelopeSum X t +
            roughDyadicBadPrimeProductSquarefreeLossEnvelopeSum X t := hlocal
      _ ≤ Em * (t / Real.log (EscAnalytic.zScale X)) +
            Es * (t / Real.log (EscAnalytic.zScale X)) :=
            add_le_add hm_bound hs_bound
      _ = (Em + Es) * (t / Real.log (EscAnalytic.zScale X)) := by
            ring
  exact (neg_le_neg habs).trans (neg_abs_le _)

/-- Multiples discrepancy plus squarefree loss control the modulus-one signed
product error from above.  No auxiliary-prime envelope is used here. -/
theorem roughDyadicBadPrimeProductErrorUpperBoundModulusOne_of_multiples_squarefree
    {a₀ b₀ C₀ Em Es Xm Xs : ℝ} (hC₀ : 0 ≤ C₀)
    (hm :
      roughDyadicBadPrimeProductMultiplesLocalErrorEnvelopeBound
        a₀ b₀ C₀ Em Xm)
    (hs :
      roughDyadicBadPrimeProductSquarefreeLossEnvelopeBound
        a₀ b₀ C₀ Es Xs) :
    roughDyadicBadPrimeProductErrorUpperBoundModulusOne
      a₀ b₀ C₀ (Em + Es) (max (max Xm Xs) 1) := by
  rcases hm with ⟨hEm_nonneg, hm⟩
  rcases hs with ⟨hEs_nonneg, hs⟩
  refine ⟨add_nonneg hEm_nonneg hEs_nonneg, ?_⟩
  intro X hX t htlo hthi
  have hXm : Xm ≤ X := le_trans (le_trans (le_max_left _ _) (le_max_left _ _)) hX
  have hXs : Xs ≤ X := le_trans (le_trans (le_max_right _ _) (le_max_left _ _)) hX
  have hXone : (1 : ℝ) ≤ X := le_trans (le_max_right _ _) hX
  have hMone : (((1 : ℕ) : ℝ) ≤ X ^ C₀) := by
    simpa using Real.one_le_rpow hXone hC₀
  have hm_bound := hm X hXm 1 hMone t htlo hthi
  have hs_bound := hs X hXs 1 hMone t htlo hthi
  have hlocal :=
    roughDyadicBadPrimeProductLocalErrorEnvelopeSum_one_le_multiplesError_add_squarefreeLoss
      X t
  have habs :
      |roughDyadicBadPrimeProductErrorSum X 1 t| ≤
        (Em + Es) * (t / Real.log (EscAnalytic.zScale X)) := by
    calc
      |roughDyadicBadPrimeProductErrorSum X 1 t|
          ≤ roughDyadicBadPrimeProductLocalErrorEnvelopeSum X 1 t :=
            abs_roughDyadicBadPrimeProductErrorSum_le_localErrorEnvelope X 1 t
      _ ≤ roughDyadicBadPrimeProductMultiplesLocalErrorEnvelopeSum X t +
            roughDyadicBadPrimeProductSquarefreeLossEnvelopeSum X t := hlocal
      _ ≤ Em * (t / Real.log (EscAnalytic.zScale X)) +
            Es * (t / Real.log (EscAnalytic.zScale X)) :=
            add_le_add hm_bound hs_bound
      _ = (Em + Es) * (t / Real.log (EscAnalytic.zScale X)) := by
            ring
  exact (le_abs_self _).trans habs

/-- Parameter-shaped bound for the auxiliary-coprimality loss component of the
product-error term. -/
def roughDyadicBadPrimeProductAuxiliaryLossEnvelopeBound
    (a₀ b₀ C₀ E X₀ : ℝ) : Prop :=
  0 ≤ E ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
      roughDyadicBadPrimeProductAuxiliaryLossEnvelopeSum X M t ≤
        E * (t / Real.log (EscAnalytic.zScale X))

/-- Parameter-shaped bound for the finite union bound over prime factors of
the auxiliary modulus.  This is a more elementary replacement target for the
auxiliary-coprimality loss envelope. -/
def roughDyadicBadPrimeProductAuxiliaryPrimeMultiplesEnvelopeBound
    (a₀ b₀ C₀ E X₀ : ℝ) : Prop :=
  0 ≤ E ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
      (((roughModulus X).primeFactors.powerset.card : ℕ) : ℝ) *
          auxiliaryModulusPrimeMultiplesLoss X M t ≤
        E * (t / Real.log (EscAnalytic.zScale X))

/-- Parameter-shaped bound for the explicit floor-division envelope that
controls the auxiliary-prime multiples loss. -/
def roughDyadicBadPrimeProductAuxiliaryPrimeMultiplesFloorEnvelopeBound
    (a₀ b₀ C₀ E X₀ : ℝ) : Prop :=
  0 ≤ E ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
      (((roughModulus X).primeFactors.powerset.card : ℕ) : ℝ) *
          auxiliaryModulusPrimeMultiplesFloorEnvelope M t ≤
        E * (t / Real.log (EscAnalytic.zScale X))

/-- The explicit auxiliary-prime floor envelope implies the auxiliary-prime
multiples envelope. -/
theorem roughDyadicBadPrimeProductAuxiliaryPrimeMultiplesEnvelopeBound_of_floorEnvelope
    {a₀ b₀ C₀ E X₀ : ℝ}
    (h :
      roughDyadicBadPrimeProductAuxiliaryPrimeMultiplesFloorEnvelopeBound
        a₀ b₀ C₀ E X₀) :
    roughDyadicBadPrimeProductAuxiliaryPrimeMultiplesEnvelopeBound
      a₀ b₀ C₀ E X₀ := by
  rcases h with ⟨hE_nonneg, h⟩
  refine ⟨hE_nonneg, ?_⟩
  intro X hX M hM t htlo hthi
  have hcard_nonneg :
      0 ≤ (((roughModulus X).primeFactors.powerset.card : ℕ) : ℝ) :=
    Nat.cast_nonneg _
  exact
    (mul_le_mul_of_nonneg_left
      (auxiliaryModulusPrimeMultiplesLoss_le_floorEnvelope X M t)
      hcard_nonneg).trans
      (h X hX M hM t htlo hthi)

/-- A parameter-shaped auxiliary-prime multiples estimate implies the
auxiliary-coprimality loss envelope. -/
theorem roughDyadicBadPrimeProductAuxiliaryLossEnvelopeBound_of_auxiliaryPrimeMultiples
    {a₀ b₀ C₀ E X₀ : ℝ}
    (h :
      roughDyadicBadPrimeProductAuxiliaryPrimeMultiplesEnvelopeBound
        a₀ b₀ C₀ E X₀) :
    roughDyadicBadPrimeProductAuxiliaryLossEnvelopeBound
      a₀ b₀ C₀ E X₀ := by
  rcases h with ⟨hE_nonneg, h⟩
  refine ⟨hE_nonneg, ?_⟩
  intro X hX M hM t htlo hthi
  exact
    (roughDyadicBadPrimeProductAuxiliaryLossEnvelopeSum_le_powerset_card_mul_auxiliaryModulusPrimeMultiplesLoss
      X M t).trans
      (h X hX M hM t htlo hthi)

/-- The explicit auxiliary-prime floor envelope implies the auxiliary
coprimality-loss envelope. -/
theorem roughDyadicBadPrimeProductAuxiliaryLossEnvelopeBound_of_auxiliaryPrimeMultiplesFloorEnvelope
    {a₀ b₀ C₀ E X₀ : ℝ}
    (h :
      roughDyadicBadPrimeProductAuxiliaryPrimeMultiplesFloorEnvelopeBound
        a₀ b₀ C₀ E X₀) :
    roughDyadicBadPrimeProductAuxiliaryLossEnvelopeBound
      a₀ b₀ C₀ E X₀ :=
  roughDyadicBadPrimeProductAuxiliaryLossEnvelopeBound_of_auxiliaryPrimeMultiples
    (roughDyadicBadPrimeProductAuxiliaryPrimeMultiplesEnvelopeBound_of_floorEnvelope
      h)

/-- Separate squarefree-loss and auxiliary-loss estimates imply the existing
filter-loss envelope bound. -/
theorem roughDyadicBadPrimeProductFilterLossEnvelopeBound_of_squarefree_and_auxiliary
    {a₀ b₀ C₀ Es Ea Xs Xa : ℝ}
    (hs :
      roughDyadicBadPrimeProductSquarefreeLossEnvelopeBound
        a₀ b₀ C₀ Es Xs)
    (ha :
      roughDyadicBadPrimeProductAuxiliaryLossEnvelopeBound
        a₀ b₀ C₀ Ea Xa) :
    roughDyadicBadPrimeProductFilterLossEnvelopeBound
      a₀ b₀ C₀ (Es + Ea) (max Xs Xa) := by
  rcases hs with ⟨hEs_nonneg, hs⟩
  rcases ha with ⟨hEa_nonneg, ha⟩
  refine ⟨add_nonneg hEs_nonneg hEa_nonneg, ?_⟩
  intro X hX M hM t htlo hthi
  have hXs : Xs ≤ X := le_trans (le_max_left _ _) hX
  have hXa : Xa ≤ X := le_trans (le_max_right _ _) hX
  have hsplit :=
    roughDyadicBadPrimeProductFilterLossEnvelopeSum_eq_squarefreeLoss_add_auxiliaryLoss
      X M t
  have hs_bound := hs X hXs M hM t htlo hthi
  have ha_bound := ha X hXa M hM t htlo hthi
  calc
    roughDyadicBadPrimeProductFilterLossEnvelopeSum X M t
        = roughDyadicBadPrimeProductSquarefreeLossEnvelopeSum X t +
            roughDyadicBadPrimeProductAuxiliaryLossEnvelopeSum X M t := hsplit
    _ ≤ Es * (t / Real.log (EscAnalytic.zScale X)) +
          Ea * (t / Real.log (EscAnalytic.zScale X)) :=
          add_le_add hs_bound ha_bound
    _ = (Es + Ea) * (t / Real.log (EscAnalytic.zScale X)) := by
          ring

/-- Separate squarefree-loss and auxiliary-prime-multiples estimates imply the
existing filter-loss envelope bound. -/
theorem roughDyadicBadPrimeProductFilterLossEnvelopeBound_of_squarefree_and_auxiliaryPrimeMultiples
    {a₀ b₀ C₀ Es Ea Xs Xa : ℝ}
    (hs :
      roughDyadicBadPrimeProductSquarefreeLossEnvelopeBound
        a₀ b₀ C₀ Es Xs)
    (ha :
      roughDyadicBadPrimeProductAuxiliaryPrimeMultiplesEnvelopeBound
        a₀ b₀ C₀ Ea Xa) :
    roughDyadicBadPrimeProductFilterLossEnvelopeBound
      a₀ b₀ C₀ (Es + Ea) (max Xs Xa) :=
  roughDyadicBadPrimeProductFilterLossEnvelopeBound_of_squarefree_and_auxiliary
    hs

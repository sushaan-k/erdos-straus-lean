    (hrough_range : ∀ N : ℕ, 3 ≤ N →
      (roughLargeCount (z N) N : ℝ) ≤ eulerProductFactorAtNat N * (Ered N : ℝ)) :
    IsMainBound exceptionalCount := by
  rcases eulerProductFactorAtNat_log_fourth_bound with ⟨eulerC, heC, heuler⟩
  exact main_of_euler_log_four Ered Ered_c₁ Ered_C₁ hc₁ hC₁ hEred
    smooth smoothExp smoothC hse_pos hse_lt hsC hsmooth
    eulerProductFactorAtNat eulerC heC heuler
    (fun N hN => lift_of_range_bounds (hsmooth_range N hN) (hrough_range N hN))

/-- Range-bound capstone with both the canonical smooth range and the concrete
Euler product supplied internally.

The remaining hypotheses are exactly the reduced-count saving and the
rough-large comparison against the concrete Euler product at
`z_N = ⌊(log N)^4⌋`.  The smooth side is discharged by

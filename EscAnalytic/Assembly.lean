          eulerProductFactorAtNat N * (H.Ered N : ℝ)) ∧
    (∀ N : ℕ, 3 ≤ N → H.Tred ≤ N →
      (fixedNumeratorExceptionalCount m N : ℝ) ≤
        (fixedNumeratorSmoothRangeCount m (zNatScale N) N : ℝ) +
          eulerProductFactorAtNat N * (H.Ered N : ℝ)) ∧
    IsMainBound (fixedNumeratorExceptionalCount m) ∧
    ∃ c > (0 : ℝ), ∃ C > (0 : ℝ), ∀ N : ℕ, 3 ≤ N →

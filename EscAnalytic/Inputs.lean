/-- Reciprocal-prime-square large-square tail-envelope quarter-budget package,
theorem-level from the elementary square-tail estimate.  The count-level tail
and signed squarefree upper estimates are derived from this explicit reciprocal
sum. -/
theorem linear_sieve_rough_dyadic_large_square_tail_reciprocal_envelope_upper_quarter_bound :
    LinearSieveRoughDyadicLargeSquareTailReciprocalEnvelopeUpperQuarterBound
    := by
  intro a₀ b₀ C₀ c Xprod hc hprod
  refine ⟨Real.exp (max 2 (2 * (7 + 1) / (c / 4))), ?_⟩
  constructor
  · exact div_nonneg hc.le (by norm_num)
  · intro X hX t htlo hthi
    have hXexp2 : Real.exp 2 ≤ X :=
      le_trans (Real.exp_le_exp.mpr (le_max_left _ _)) hX
    have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 2) hXexp2
    have ht_nonneg : 0 ≤ t :=
      (Real.rpow_pos_of_pos hXpos a₀).le.trans htlo
    exact
      roughDyadicLargeSquareDivisorReciprocalEnvelopeSum_le_eps_mul_t_div_log_zScale
        (X := X) (eps := c / 4) (t := t) hX (by positivity) ht_nonneg


/-- Separate bounds for the multiples-only discrepancy and arithmetic filter
loss imply the combined local-error envelope bound. -/
theorem roughDyadicBadPrimeProductLocalErrorEnvelopeBound_of_multiples_and_filterLoss
    {a₀ b₀ C₀ Em Ef Xm Xf : ℝ}
    (hm :
      roughDyadicBadPrimeProductMultiplesLocalErrorEnvelopeBound
        a₀ b₀ C₀ Em Xm)
    (hf :
      roughDyadicBadPrimeProductFilterLossEnvelopeBound
        a₀ b₀ C₀ Ef Xf) :
    roughDyadicBadPrimeProductLocalErrorEnvelopeBound
      a₀ b₀ C₀ (Em + Ef) (max Xm Xf) := by
  rcases hm with ⟨hEm_nonneg, hm⟩
  rcases hf with ⟨hEf_nonneg, hf⟩
  refine ⟨add_nonneg hEm_nonneg hEf_nonneg, ?_⟩
  intro X hX M hM t htlo hthi
  have hXm : Xm ≤ X := le_trans (le_max_left _ _) hX
  have hXf : Xf ≤ X := le_trans (le_max_right _ _) hX
  have hlocal :=
    roughDyadicBadPrimeProductLocalErrorEnvelopeSum_le_multiplesError_add_filterLoss
      X M t
  have hm_bound := hm X hXm M hM t htlo hthi
  have hf_bound := hf X hXf M hM t htlo hthi
  calc
    roughDyadicBadPrimeProductLocalErrorEnvelopeSum X M t
        ≤ roughDyadicBadPrimeProductMultiplesLocalErrorEnvelopeSum X t +
            roughDyadicBadPrimeProductFilterLossEnvelopeSum X M t := hlocal
    _ ≤ Em * (t / Real.log (EscAnalytic.zScale X)) +
          Ef * (t / Real.log (EscAnalytic.zScale X)) :=
          add_le_add hm_bound hf_bound
    _ = (Em + Ef) * (t / Real.log (EscAnalytic.zScale X)) := by
          ring

/-- A bound for the sum of absolute subset-local errors implies the existing
exact product-error interface. -/
theorem roughDyadicBadPrimeProductErrorBound_of_localErrorEnvelope
    {a₀ b₀ C₀ E X₀ : ℝ}
    (h : roughDyadicBadPrimeProductLocalErrorEnvelopeBound a₀ b₀ C₀ E X₀) :
    roughDyadicBadPrimeProductErrorBound a₀ b₀ C₀ E X₀ := by
  rcases h with ⟨hE, henv⟩
  refine ⟨hE, ?_⟩
  intro X hX M hM t htlo hthi
  exact (abs_roughDyadicBadPrimeProductErrorSum_le_localErrorEnvelope X M t).trans
    (henv X hX M hM t htlo hthi)


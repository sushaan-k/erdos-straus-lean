/-- Explicit component package that would replace both remaining
no-extra-modulus count primitives.  It consists of the natural-cutoff
prime-reciprocal Mertens input plus the two non-auxiliary quarter-budget
finite-error components. -/
def LinearSieveRoughDyadicModulusOneComponentPackage : Prop :=
  PrimeRecipSharpMertensNatUpperBound ∧
    LinearSieveRoughDyadicMultiplesErrorQuarterBound ∧
      LinearSieveRoughDyadicSquarefreeLossQuarterBound

/-- Signed component package used by the exported no-extra-modulus route. -/
def LinearSieveRoughDyadicModulusOneSignedComponentPackage : Prop :=
  PrimeRecipSharpMertensNatUpperBound ∧
    LinearSieveRoughDyadicMultiplesSignedErrorQuarterBound ∧
      LinearSieveRoughDyadicSquarefreeSignedLossQuarterBound

/-- Signed component package on the positive dyadic ranges actually consumed
by the live no-extra-modulus count cores.  This is the narrowed version of
`LinearSieveRoughDyadicModulusOneSignedComponentPackage` used by the public
route. -/
def LinearSieveRoughDyadicModulusOneSignedComponentPackageOnPositiveRanges : Prop :=
  PrimeRecipSharpMertensNatUpperBound ∧
    LinearSieveRoughDyadicMultiplesSignedErrorQuarterBoundOnPositiveRanges ∧
      LinearSieveRoughDyadicSquarefreeSignedLossQuarterBound

/-- Product-lower signed component package on the positive dyadic ranges
actually consumed by the live public count cores.  This is the exact interface
used by the no-extra-modulus route: the Mertens step has already been converted
to the finite Euler-product lower bound. -/
def LinearSieveRoughDyadicModulusOneProductLowerSignedComponentPackageOnPositiveRanges : Prop :=
  roughDyadicBadPrimeMainEulerProductLowerBound ∧
    LinearSieveRoughDyadicMultiplesSignedErrorQuarterBoundOnPositiveRanges ∧
      LinearSieveRoughDyadicSquarefreeSignedLossQuarterBound

/-- Product-lower plus explicit floor-error component package on the positive
dyadic ranges actually consumed by the live public count cores.  The product
lower bound is the exact live product input; the multiples component is the
normalized finite alternating floor-error estimate. -/
def LinearSieveRoughDyadicModulusOneProductLowerFloorErrorComponentPackageOnPositiveRanges :
    Prop :=
  roughDyadicBadPrimeMainEulerProductLowerBound ∧
    RoughDyadicFloorErrorUniformNormalizedSmallBoundOnPositiveRanges ∧
      LinearSieveRoughDyadicSquarefreeSignedLossQuarterBound

/-- The exact pair of working analytic components currently needed by the live
rough-sieve route before converting the finite floor-error estimate to the
signed-multiples interface. -/
def LinearSieveRoughDyadicCurrentAnalyticFrontierPackage : Prop :=
  roughDyadicBadPrimeMainEulerProductLowerBound ∧
    RoughDyadicFloorErrorUniformNormalizedSmallBoundOnPositiveRanges

/-- The standard sufficient analytic frontier: natural-cutoff one-sided
bounded-defect prime-reciprocal Mertens upper bound plus the positive-range
normalized rough-window count discrepancy estimate. -/
def LinearSieveRoughDyadicCurrentStandardAnalyticFrontierPackage : Prop :=
  PrimeRecipSharpMertensNatDefectEventuallyUpperBound ∧
    RoughDyadicCountDiscrepancyUniformNormalizedSmallBoundOnPositiveRanges

/-- Equivalent primitive frontier with the Mertens side expressed as the
coefficient-one dyadic prime-reciprocal shell estimate and the count side
expressed as normalized finite floor-error cancellation. -/
def LinearSieveRoughDyadicCurrentDyadicFloorErrorFrontierPackage : Prop :=
  PrimeRecipDyadicBlocksSharpUpperBound ∧
    RoughDyadicFloorErrorUniformNormalizedSmallBoundOnPositiveRanges

/-- Equivalent primitive frontier with the Mertens side expressed as bounded
dyadic harmonic error and the count side expressed as normalized finite
floor-error cancellation. -/
def LinearSieveRoughDyadicCurrentHarmonicFloorErrorFrontierPackage : Prop :=
  PrimeRecipDyadicBlocksHarmonicBoundedError ∧
    RoughDyadicFloorErrorUniformNormalizedSmallBoundOnPositiveRanges

/-- The exact live analytic frontier after putting the Mertens side at the
finite rough-prime Euler-product lower bound and converting the rough-count
input to the signed-multiples interface actually used by the public route. -/
def LinearSieveRoughDyadicCurrentLiveAnalyticFrontierPackage : Prop :=
  roughDyadicBadPrimeMainEulerProductLowerBound ∧
    LinearSieveRoughDyadicMultiplesSignedErrorQuarterBoundOnPositiveRanges

/-- The current standard frontier is exactly the dyadic-shell/floor-error
frontier.  This leaves no hidden cutoff or carrier conversion in the two
remaining primitive targets. -/
theorem LinearSieveRoughDyadicCurrentStandardAnalyticFrontierPackage_iff_dyadicFloorError :
    LinearSieveRoughDyadicCurrentStandardAnalyticFrontierPackage ↔
      LinearSieveRoughDyadicCurrentDyadicFloorErrorFrontierPackage := by
  constructor
  · intro h
    exact
      ⟨(PrimeRecipDyadicBlocksSharpUpperBound_iff_defectEventuallyUpperBound).2 h.1,
        (RoughDyadicFloorErrorUniformNormalizedSmallBoundOnPositiveRanges_iff_countDiscrepancy).2
          h.2⟩
  · intro h
    exact
      ⟨(PrimeRecipDyadicBlocksSharpUpperBound_iff_defectEventuallyUpperBound).1 h.1,
        (RoughDyadicFloorErrorUniformNormalizedSmallBoundOnPositiveRanges_iff_countDiscrepancy).1
          h.2⟩

/-- The current standard frontier is also exactly the harmonic-error/floor-error
frontier.  The prime-reciprocal input can therefore be attacked as a bounded
error between dyadic prime shells and the ordinary harmonic series, while the
count input is exactly the finite normalized floor-error cancellation target. -/
theorem LinearSieveRoughDyadicCurrentStandardAnalyticFrontierPackage_iff_harmonicFloorError :
    LinearSieveRoughDyadicCurrentStandardAnalyticFrontierPackage ↔
      LinearSieveRoughDyadicCurrentHarmonicFloorErrorFrontierPackage := by
  constructor
  · intro h
    have hsharp :
        PrimeRecipDyadicBlocksSharpUpperBound :=
      (PrimeRecipDyadicBlocksSharpUpperBound_iff_defectEventuallyUpperBound).2 h.1
    exact
      ⟨(PrimeRecipDyadicBlocksHarmonicBoundedError_iff_sharpUpperBound).2 hsharp,
        (RoughDyadicFloorErrorUniformNormalizedSmallBoundOnPositiveRanges_iff_countDiscrepancy).2
          h.2⟩
  · intro h
    have hsharp :
        PrimeRecipDyadicBlocksSharpUpperBound :=
      (PrimeRecipDyadicBlocksHarmonicBoundedError_iff_sharpUpperBound).1 h.1
    exact
      ⟨(PrimeRecipDyadicBlocksSharpUpperBound_iff_defectEventuallyUpperBound).1 hsharp,
        (RoughDyadicFloorErrorUniformNormalizedSmallBoundOnPositiveRanges_iff_countDiscrepancy).1
          h.2⟩


noncomputable def UniformNumeratorLargeRangeInputs.of_uniform_final_assembly_rankin_smoothPsi_canonical_class_envelope
    {κ : Type*} [DecidableEq κ]
    {A Ered_c₁ Ered_C₁ B : ℝ} (T : ℕ)
    (hEred_c₁ : 0 < Ered_c₁) (hEred_C₁ : 0 < Ered_C₁)

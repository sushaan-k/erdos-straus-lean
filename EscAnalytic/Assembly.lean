      Ered_C₁ := Ered_C
      Ered_pos₁ := hc
      Ered_posC₁ := hEred_C_spec.1
      Ered_bound := hEred_C_spec.2
      smooth := smooth
      smoothExp := smoothExp
      smoothC := smoothC
      smoothExp_pos := smoothExp_pos
      smoothExp_lt_one := smoothExp_lt_one
      smoothC_pos := smoothC_pos
      smooth_bound := smooth_bound
      euler := euler
      eulerC := eulerC
      eulerC_pos := eulerC_pos
      euler_bound_four := euler_bound_four
      lift := lift }


theorem fixed_m_paper_suen_optimization_exact_direct_inputs_full_outputs_and_final_standard_tail_any_m
    {ι : Type*}
    (m : ℕ)
    (A : FixedNumeratorPaperSuenAnalyticCoreOptimizationExactDirectInputs m ι)
    (Tred : ℕ) :
    let B := A.toDirect
    (∀ N : ℕ, 3 ≤ N → B.T ≤ N → ((B.cls N).card : ℝ) ≤ B.Pz N) ∧
    (∀ N : ℕ, 3 ≤ N → B.T ≤ N →
      B.c * (Real.log N) ^ ((3 : ℝ) / 4)
        ≤ (1 - (B.εb N + Real.log 3 / B.μ N)) * B.μ N) ∧
    (∀ N : ℕ, 3 ≤ N → B.T ≤ N → ∀ b ∈ B.cls N,
      B.Mb N b ≤ ((N : ℝ) / B.Pz N) *
        (Inputs.suenProb (B.μ N) (B.δb N b) (B.Δb N b) + B.F2R N b) +
          B.errTerm N b) ∧
    (∀ N : ℕ, 3 ≤ N → B.T ≤ N → ∀ b ∈ B.cls N,
      Inputs.suenTailConstant * B.Δb N b * Real.exp (2 * B.δb N b)
        ≤ B.εb N * B.μ N) ∧
    (∀ N : ℕ, 3 ≤ N → B.T ≤ N → ∀ b ∈ B.cls N,
      B.errTerm N b ≤
        (B.Xscale N b) ^ (2 * B.Rlevel N b) *
          Real.exp ((1 + B.εK) * B.μ N)) ∧
    (∀ N : ℕ, 3 ≤ N → B.T ≤ N → ∀ b ∈ B.cls N,
      B.Pz N * (B.Xscale N b) ^ (2 * B.Rlevel N b) * Real.exp (2 * B.μ N)
        ≤ (N : ℝ) * Real.exp (-4 * B.μ N)) ∧
    (∀ N : ℕ, 3 ≤ N → B.T ≤ N → ∀ b ∈ B.cls N,
      B.F2R N b ≤ Real.exp (-3 * B.μ N)) ∧
    (∀ N : ℕ, 3 ≤ N → B.T ≤ N → ∀ b ∈ B.cls N,
      B.Mb N b ≤ ((N : ℝ) / B.Pz N) *
        Real.exp (-(1 - (B.εb N + Real.log 3 / B.μ N)) * B.μ N)) ∧
    (∀ N : ℕ, 3 ≤ N → Tred ≤ N →
      (∑ s ∈ Finset.Icc 1 N,
        (fixedNumeratorReducedExceptionalCount m (zNatScale N) (N / s) : ℝ)) ≤
          eulerProductFactorAtNat N *
            (fixedNumeratorReducedSumCount m (zNatScale N) N : ℝ)) ∧
    (∀ N : ℕ, 3 ≤ N → Tred ≤ N →
      (fixedNumeratorExceptionalCount m N : ℝ) ≤
        (fixedNumeratorSmoothRangeCount m (zNatScale N) N : ℝ) +
          eulerProductFactorAtNat N *
            (fixedNumeratorReducedSumCount m (zNatScale N) N : ℝ)) ∧
    IsMainBound (fixedNumeratorExceptionalCount m) ∧
    ∃ c > (0 : ℝ), ∃ C > (0 : ℝ), ∀ N : ℕ, 3 ≤ N →
      (fixedNumeratorExceptionalCount m N : ℝ) ≤ C * (N : ℝ) * saving c N := by
  dsimp only
  exact
    fixed_m_paper_suen_optimization_direct_inputs_exact_reduced_carrier_full_outputs_and_final_standard_tail_any_m
      m A.toDirect A.Ered_sum Tred


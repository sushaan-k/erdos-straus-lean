/-- The one-class canonical reduced mass is exactly the reduced summatory
carrier.

For each smooth-part scale, the constant map into `PUnit` has image empty when
the reduced carrier is empty and singleton otherwise.  Hence its class count
multiplies the reduced carrier by exactly zero or one, matching the carrier
cardinality in both cases. -/
theorem fixedNumeratorReducedCanonicalUnitClassMass_eq_reduced_sum_count
    {m : ℕ} (N : ℕ) :
    (∑ s ∈ Finset.Icc 1 N,
      ((fixedNumeratorReducedCanonicalClasses m (zNatScale N) (N / s)
        (fun _r : ℕ => (PUnit.unit : PUnit.{1}))).card : ℝ) *
        (fixedNumeratorReducedExceptionalCount m (zNatScale N) (N / s) : ℝ)) =
      (fixedNumeratorReducedSumCount m (zNatScale N) N : ℝ) := by
  rw [fixedNumeratorReducedSumCount_cast]
  apply Finset.sum_congr rfl
  intro s _hs
  let S : Finset ℕ :=
    (Finset.Icc 1 (N / s)).filter
      (fun r => IsRough (zNatScale N) r ∧ ¬ fixedNumeratorRepresentable m r)
  by_cases hS : S = ∅
  · have hfilter_empty :
        (Finset.Icc 1 (N / s)).filter
          (fun r => IsRough (zNatScale N) r ∧ ¬ fixedNumeratorRepresentable m r) = ∅ := by
      change S = ∅
      exact hS
    have hclasses_card_zero :
        (fixedNumeratorReducedCanonicalClasses m (zNatScale N) (N / s)
            (fun _r : ℕ => (PUnit.unit : PUnit.{1}))).card = 0 := by
      rw [fixedNumeratorReducedCanonicalClasses]
      simp [hfilter_empty]
    have hcount_zero :
        fixedNumeratorReducedExceptionalCount m (zNatScale N) (N / s) = 0 := by
      simp [fixedNumeratorReducedExceptionalCount, hfilter_empty]
    simp [hclasses_card_zero, hcount_zero]
  · have hS_nonempty : S.Nonempty := Finset.nonempty_iff_ne_empty.mpr hS
    have hclasses_singleton :
        fixedNumeratorReducedCanonicalClasses m (zNatScale N) (N / s)
            (fun _r : ℕ => (PUnit.unit : PUnit.{1})) =
              ({(PUnit.unit : PUnit.{1})} : Finset PUnit.{1}) := by
      rw [fixedNumeratorReducedCanonicalClasses]
      apply Finset.ext
      intro b
      cases b
      constructor
      · intro _hb
        simp
      · intro _hb
        rcases hS_nonempty with ⟨r, hr⟩
        exact Finset.mem_image.mpr ⟨r, by simpa [S] using hr, rfl⟩
    rw [hclasses_singleton]
    simp [fixedNumeratorReducedExceptionalCount]


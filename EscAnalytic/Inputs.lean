  rcases h k a₀ b₀ eps hk ha₀ hab heps with ⟨X₀, hX₀⟩
  refine ⟨max X₀ (Real.exp 2), ?_⟩
  intro X hX t htlo hthi
  have hXbase : X₀ ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 2) hXexp
  have hlogX_ge_two : (2 : ℝ) ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hXexp
  have hlogX_pos : 0 < Real.log X :=
    lt_of_lt_of_le (by norm_num : (0 : ℝ) < 2) hlogX_ge_two
  have hlogX_ge_one : (1 : ℝ) ≤ Real.log X :=
    le_trans (by norm_num : (1 : ℝ) ≤ 2) hlogX_ge_two
  have hlogX_pow_ge_two : (2 : ℝ) ≤ (Real.log X) ^ k := by
    have hk_one : 1 ≤ k := Nat.succ_le_of_lt hk
    have hpow : (Real.log X) ^ (1 : ℕ) ≤ (Real.log X) ^ k :=
      pow_le_pow_right₀ hlogX_ge_one hk_one
    exact le_trans hlogX_ge_two (by simpa using hpow)
  have hlog_logpow_pos : 0 < Real.log ((Real.log X) ^ k) :=
    Real.log_pos (lt_of_lt_of_le (by norm_num : (1 : ℝ) < 2) hlogX_pow_ge_two)
  have ht_pos : 0 < t :=
    lt_of_lt_of_le (Real.rpow_pos_of_pos hXpos a₀) htlo
  have hden_pos : 0 < t / Real.log ((Real.log X) ^ k) :=
    div_pos ht_pos hlog_logpow_pos
  exact (div_le_iff₀ hden_pos).mp (hX₀ X hXbase t htlo hthi)


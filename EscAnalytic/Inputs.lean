  intro a₀ b₀ C₀ c Xprod ha₀ hab hc hprod
  rcases h a₀ b₀ C₀ c Xprod ha₀ hab hc hprod with
    ⟨Xl, _Xu, hlower, _hupper⟩
  exact ⟨Xl, hlower⟩


/-- Guard for the canonical Suen rank-tail quartic route.

Once the canonical class family is eventually nonempty, the rank-tail premise
`24 * μ <= 2R`, the cubic-log mass lower bound, the quarter-log scale choice,
and the level budget are already inconsistent.  Thus this route cannot be used
to manufacture `hyp:quartic-eh-fan`; a direct quartic certificate or large-range
certificate remains the valid interface. -/
theorem canonical_suen_quartic_rank_tail_logCube_level_budget_incompatible
    {κ : Type*} [DecidableEq κ]
    (classOfRed : ℕ → ℕ → ℕ → κ)
    (μ : ℕ → ℝ)
    (X : ℕ → (Σ _s : ℕ, κ) → ℝ)
    (R : ℕ → (Σ _s : ℕ, κ) → ℕ)
    (Cp cμ : ℝ) (T : ℕ)
    (cμ_pos : 0 < cμ)
    (hcls_nonempty : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      ((Finset.Icc 1 N).sigma (fun s =>
        reducedCanonicalClasses (zNatScale N) (N / s) (classOfRed N s))).Nonempty)
    (hscale : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      ∀ b ∈ (Finset.Icc 1 N).sigma (fun s =>
        reducedCanonicalClasses (zNatScale N) (N / s) (classOfRed N s)),
        Real.log (X N b) =
          optimizationSmallAlpha Cp * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4))
    (hbudget : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      ∀ b ∈ (Finset.Icc 1 N).sigma (fun s =>
        reducedCanonicalClasses (zNatScale N) (N / s) (classOfRed N s)),
        2 * (R N b : ℝ) * Real.log (X N b) + 6 * μ N
          ≤ Cp * ((optimizationSmallAlpha Cp) ^ 4 * Real.log (N : ℝ)))
    (hmass_logcube_lower : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      cμ * logCube (N : ℝ) ≤ μ N)
    (hrank_tail : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      ∀ b ∈ (Finset.Icc 1 N).sigma (fun s =>
        reducedCanonicalClasses (zNatScale N) (N / s) (classOfRed N s)),
        24 * μ N ≤ (2 * R N b : ℝ)) :
    False :=
  optimization_level_budget_class_rank_tail_logCube_lower_eventually_incompatible
    (μ := μ) (R := R)
    (cls := fun N => (Finset.Icc 1 N).sigma (fun s =>
      reducedCanonicalClasses (zNatScale N) (N / s) (classOfRed N s)))
    (cμ := cμ) (Cp := Cp) (T := T)
    cμ_pos hcls_nonempty hrank_tail hmass_logcube_lower
    (by
      intro N hN hTN b hb
      have hlevel := hbudget N hN hTN b hb
      rw [hscale N hN hTN b hb] at hlevel
      simpa [mul_assoc] using hlevel)

/-- Any finite-level condition with nontrivial `Pz` and level power forces the
mass to be at most logarithmic. -/
theorem finite_level_condition_forces_six_mu_le_log
    {Pz Xpow μ N : ℝ}
    (hPz : 1 ≤ Pz) (hXpow : 1 ≤ Xpow) (hNpos : 0 < N)
    (hlevel : Pz * Xpow * Real.exp (2 * μ) ≤ N * Real.exp (-4 * μ)) :
    6 * μ ≤ Real.log N := by
  have hleft_factor : 1 ≤ Pz * Xpow := by
    nlinarith [mul_le_mul hPz hXpow (by norm_num : (0 : ℝ) ≤ 1)
      (le_trans (by norm_num : (0 : ℝ) ≤ 1) hPz)]
  have hexp_le : Real.exp (2 * μ) ≤ N * Real.exp (-4 * μ) := by
    calc
      Real.exp (2 * μ) = 1 * Real.exp (2 * μ) := by ring
      _ ≤ (Pz * Xpow) * Real.exp (2 * μ) :=
        mul_le_mul_of_nonneg_right hleft_factor (Real.exp_pos _).le
      _ ≤ N * Real.exp (-4 * μ) := hlevel
  have hpos_rhs : 0 < N * Real.exp (-4 * μ) :=
    mul_pos hNpos (Real.exp_pos _)
  have hlog_le := (Real.log_le_log_iff (Real.exp_pos _) hpos_rhs).mpr hexp_le
  rw [Real.log_exp, Real.log_mul (ne_of_gt hNpos) (Real.exp_ne_zero _),
    Real.log_exp] at hlog_le
  linarith

/-- The finite-level condition is eventually incompatible with a positive cubic
logarithmic mass lower bound, as soon as both `Pz` and the level power are at
least one. -/
theorem finite_level_condition_logCube_lower_eventually_incompatible
    {μ : ℕ → ℝ} {Pz Xpow : ℕ → ℝ} {cμ : ℝ} {T : ℕ}
    (hcμ : 0 < cμ)
    (hPz : ∀ N : ℕ, 3 ≤ N → T ≤ N → 1 ≤ Pz N)
    (hXpow : ∀ N : ℕ, 3 ≤ N → T ≤ N → 1 ≤ Xpow N)
    (hmass_lower : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      cμ * logCube (N : ℝ) ≤ μ N)
    (hlevel : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      Pz N * Xpow N * Real.exp (2 * μ N)
        ≤ (N : ℝ) * Real.exp (-4 * μ N)) :
    False := by
  rcases Filter.eventually_atTop.mp
      (eventually_const_mul_log_lt_logCube_nat (K := 1) (cμ := 6 * cμ)
        (by positivity)) with
    ⟨Tscale, hscale⟩
  let N : ℕ := max 3 (max T Tscale)
  have hN3 : 3 ≤ N := by
    dsimp [N]
    exact Nat.le_max_left 3 (max T Tscale)
  have hTN : T ≤ N := by
    dsimp [N]
    exact le_trans (Nat.le_max_left T Tscale) (Nat.le_max_right 3 (max T Tscale))
  have hTscale : Tscale ≤ N := by
    dsimp [N]
    exact le_trans (Nat.le_max_right T Tscale) (Nat.le_max_right 3 (max T Tscale))
  have hNpos : 0 < (N : ℝ) := by
    exact_mod_cast (by omega : 0 < N)
  have hlog_bound :
      6 * μ N ≤ Real.log (N : ℝ) :=
    finite_level_condition_forces_six_mu_le_log
      (hPz N hN3 hTN) (hXpow N hN3 hTN) hNpos (hlevel N hN3 hTN)
  have hmass6 :
      6 * (cμ * logCube (N : ℝ)) ≤ 6 * μ N :=
    mul_le_mul_of_nonneg_left (hmass_lower N hN3 hTN) (by norm_num)
  have hcube_gt_log :
      Real.log (N : ℝ) < 6 * (cμ * logCube (N : ℝ)) := by
    have hscaleN := hscale N hTscale
    linarith
  linarith

/-- Concrete-power specialization of the finite-level obstruction. -/
theorem finite_level_condition_rpow_logCube_lower_eventually_incompatible
    {μ : ℕ → ℝ} {Pz Xscale Rlevel : ℕ → ℝ} {cμ : ℝ} {T : ℕ}
    (hcμ : 0 < cμ)
    (hPz : ∀ N : ℕ, 3 ≤ N → T ≤ N → 1 ≤ Pz N)
    (hXscale : ∀ N : ℕ, 3 ≤ N → T ≤ N → 1 ≤ Xscale N)
    (hRlevel : ∀ N : ℕ, 3 ≤ N → T ≤ N → 0 ≤ Rlevel N)
    (hmass_lower : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      cμ * logCube (N : ℝ) ≤ μ N)
    (hlevel : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      Pz N * (Xscale N) ^ (2 * Rlevel N) * Real.exp (2 * μ N)
        ≤ (N : ℝ) * Real.exp (-4 * μ N)) :
    False :=
  finite_level_condition_logCube_lower_eventually_incompatible
    (μ := μ) (Pz := Pz)
    (Xpow := fun N => (Xscale N) ^ (2 * Rlevel N)) (cμ := cμ) (T := T)
    hcμ hPz
    (by
      intro N hN hTN
      have hbase_pos : 0 < Xscale N := lt_of_lt_of_le zero_lt_one (hXscale N hN hTN)
      have hpow_nonneg : 0 ≤ 2 * Rlevel N := by nlinarith [hRlevel N hN hTN]
      calc
        (1 : ℝ) = (Xscale N) ^ (0 : ℝ) := by
          rw [Real.rpow_zero]
        _ ≤ (Xscale N) ^ (2 * Rlevel N) :=
          Real.rpow_le_rpow_of_exponent_le (hXscale N hN hTN) hpow_nonneg)
    hmass_lower hlevel

/-- Classwise finite-level obstruction: if a nonempty class is present and its
level power is at least one, the finite-level inequality is eventually
incompatible with a positive cubic logarithmic mass lower bound. -/
theorem finite_level_condition_nonempty_class_logCube_lower_eventually_incompatible
    {ι : Type*} {μ Pz : ℕ → ℝ} {Xpow : ℕ → ι → ℝ} {cls : ℕ → Finset ι}
    {cμ : ℝ} {T : ℕ}
    (hcμ : 0 < cμ)
    (hcls : ∀ N : ℕ, 3 ≤ N → T ≤ N → (cls N).Nonempty)
    (hPz : ∀ N : ℕ, 3 ≤ N → T ≤ N → 1 ≤ Pz N)
    (hXpow : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 1 ≤ Xpow N b)
    (hmass_lower : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      cμ * logCube (N : ℝ) ≤ μ N)
    (hlevel : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      Pz N * Xpow N b * Real.exp (2 * μ N)
        ≤ (N : ℝ) * Real.exp (-4 * μ N)) :
    False := by
  rcases Filter.eventually_atTop.mp
      (eventually_const_mul_log_lt_logCube_nat (K := 1) (cμ := 6 * cμ)
        (by positivity)) with
    ⟨Tscale, hscale⟩
  let N : ℕ := max 3 (max T Tscale)
  have hN3 : 3 ≤ N := by
    dsimp [N]
    exact Nat.le_max_left 3 (max T Tscale)
  have hTN : T ≤ N := by
    dsimp [N]
    exact le_trans (Nat.le_max_left T Tscale) (Nat.le_max_right 3 (max T Tscale))
  have hTscale : Tscale ≤ N := by
    dsimp [N]
    exact le_trans (Nat.le_max_right T Tscale) (Nat.le_max_right 3 (max T Tscale))
  rcases hcls N hN3 hTN with ⟨b, hb⟩
  have hNpos : 0 < (N : ℝ) := by
    exact_mod_cast (by omega : 0 < N)
  have hlog_bound :
      6 * μ N ≤ Real.log (N : ℝ) :=
    finite_level_condition_forces_six_mu_le_log
      (hPz N hN3 hTN) (hXpow N hN3 hTN b hb) hNpos (hlevel N hN3 hTN b hb)
  have hmass6 :
      6 * (cμ * logCube (N : ℝ)) ≤ 6 * μ N :=
    mul_le_mul_of_nonneg_left (hmass_lower N hN3 hTN) (by norm_num)
  have hcube_gt_log :
      Real.log (N : ℝ) < 6 * (cμ * logCube (N : ℝ)) := by
    have hscaleN := hscale N hTscale
    linarith
  linarith

/-- Concrete-power classwise finite-level obstruction.  This is the form that
matches transfer interfaces where the level power is `Xscale^(2R)`. -/
theorem finite_level_condition_nonempty_class_rpow_logCube_lower_eventually_incompatible
    {ι : Type*} {μ Pz : ℕ → ℝ} {Xscale Rlevel : ℕ → ι → ℝ}
    {cls : ℕ → Finset ι} {cμ : ℝ} {T : ℕ}
    (hcμ : 0 < cμ)
    (hcls : ∀ N : ℕ, 3 ≤ N → T ≤ N → (cls N).Nonempty)
    (hPz : ∀ N : ℕ, 3 ≤ N → T ≤ N → 1 ≤ Pz N)
    (hXscale : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 1 ≤ Xscale N b)
    (hRlevel : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 0 ≤ Rlevel N b)
    (hmass_lower : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      cμ * logCube (N : ℝ) ≤ μ N)
    (hlevel : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      Pz N * (Xscale N b) ^ (2 * Rlevel N b) * Real.exp (2 * μ N)
        ≤ (N : ℝ) * Real.exp (-4 * μ N)) :
    False :=
  finite_level_condition_nonempty_class_logCube_lower_eventually_incompatible
    (μ := μ) (Pz := Pz)
    (Xpow := fun N b => (Xscale N b) ^ (2 * Rlevel N b)) (cls := cls)
    (cμ := cμ) (T := T) hcμ hcls hPz
    (by
      intro N hN hTN b hb
      have hpow_nonneg : 0 ≤ 2 * Rlevel N b := by nlinarith [hRlevel N hN hTN b hb]
      calc
        (1 : ℝ) = (Xscale N b) ^ (0 : ℝ) := by
          rw [Real.rpow_zero]
        _ ≤ (Xscale N b) ^ (2 * Rlevel N b) :=
          Real.rpow_le_rpow_of_exponent_le (hXscale N hN hTN b hb) hpow_nonneg)
    hmass_lower hlevel

/-- Fixed-`m` concrete self-mass endpoint with the optimization smallness
condition discharged by the concrete choice `optimizationSmallAlpha Cp`.

This is the direct-error analogue of the concrete-alpha wrappers above: the
free optimization parameter `α` and the side condition `(2+Cp)α^4≤1` are no
longer part of the interface. -/
theorem fixed_m_exceptional_sets_of_suen_optimization_exact_direct_concrete_self_mass_simplified_direct_error_bounds_concrete_alpha_standard_tail_any_m
    (m : ℕ)
    (μ εb : ℕ → ℝ)
    (δb Δb Rlevel errTerm F2R : ℕ → ℕ → ℝ)
    (Cp cμ η : ℝ)
    (T Tred : ℕ)
    (cμ_pos : 0 < cμ)
    (eta_lt_one : η < 1)
    (mertens_Pz : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ Finset.Icc 1 N,
      Real.log (N : ℝ) ≤
        2 * zScale (Real.exp (optimizationSmallAlpha Cp *
          (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4))))
    (level_budget : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ Finset.Icc 1 N,
      2 * Rlevel N b *
          (optimizationSmallAlpha Cp * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4)) +
          6 * μ N
        ≤ Cp * ((optimizationSmallAlpha Cp) ^ 4 * Real.log (N : ℝ)))
    (mu_lower_saving : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      cμ * (Real.log N) ^ ((3 : ℝ) / 4) ≤ μ N)
    (defect_upper : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      εb N + Real.log 3 / μ N ≤ η)
    (delta_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ Finset.Icc 1 N,
      0 ≤ δb N b)
    (Delta_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ Finset.Icc 1 N,
      0 ≤ Δb N b)
    (suen_tail : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ Finset.Icc 1 N,
      Inputs.suenTailConstant * Δb N b * Real.exp (2 * δb N b) ≤ εb N * μ N)
    (decomp : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ Finset.Icc 1 N,
      (fixedNumeratorReducedExceptionalCount m (zNatScale N) (N / b) : ℝ) ≤
        Inputs.suenProb (μ N) (δb N b) (Δb N b) + F2R N b + errTerm N b)
    (errTerm_bound : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ Finset.Icc 1 N,

import EscAnalytic.Assembly
import EscAnalytic.Family
import EscLeanChecks
import Mathlib.Data.Nat.Squarefree

/-!
# Certificate assembly

This file connects the finite rational certificates in `EscLeanChecks` to the
rational-budget endpoints in `EscAnalytic.Assembly`.

This module does not prove the remaining analytic comparison estimates.  Its
purpose is narrower: when a `SatEventRankBudgetCertificate` supplies the signed
rank-budget bound for each finite level, the reduced-count rational budget
hypothesis required by `main_modulo_finite_transfer_rat_range_bounds` is no
longer a free assumption.
-/

namespace EscAnalytic

open scoped BigOperators

/-! ## Finite certificate constructors -/

/-- Per-base rational budget extracted from a finite rank-budget certificate. -/
noncomputable def certRankBudget
    (P R : ℕ → ℕ)
    (cert : ∀ N : ℕ, EscLeanChecks.SatEventRankBudgetCertificate N (P N) (R N))
    (N b : ℕ) : ℚ :=
  ∑ r ∈ Finset.range (2 * R N + 1), (cert N).B b r

/-- Build a rank-budget certificate from the actual static family in the paper.

The caller still supplies the analytic rank estimates and their global budget,
but no longer supplies a separate divisor-fan certificate for every event:
those certificates are derived from the concrete `(e, dminus, dplus, p)` family
and its base congruence. -/
noncomputable def satEventRankBudgetCertificateOfPaperFamily
    (N Pz R : ℕ) (params : Params) (X : ℝ)
    (indicesByBase : ℕ → Finset Family.FamilyIndex)
    (B : ℕ → ℕ → ℚ)
    (hPz : 1 < Pz) (hX : 1 < X)
    (hrank : ∀ b ∈ EscLeanChecks.reducedResiduesMod Pz,
      ∀ k ∈ Finset.range (2 * R + 1),
        (((-1 : Int) ^ k) *
          ((∑ t ∈ (Family.familyEvents (indicesByBase b)).powersetCard k,
              EscLeanChecks.baseSatEventCommonHitCountUpTo N Pz b t : ℕ) : Int) : ℚ) ≤
            B b k)
    (hmem : ∀ b i, i ∈ indicesByBase b →
      Family.FamilyStaticMem params X Pz b i)
    (hdminus_lt_p : ∀ b i, i ∈ indicesByBase b → i.dminus < i.p)
    (hbudget :
      (∑ b ∈ EscLeanChecks.reducedResiduesMod Pz,
        ∑ k ∈ Finset.range (2 * R + 1), B b k) < 1) :
    EscLeanChecks.SatEventRankBudgetCertificate N Pz R :=
  { eventsByBase := fun b => Family.familyEvents (indicesByBase b)
    B := B
    hP := hPz
    hrank := hrank
    hcert := by
      intro b event hevent
      exact Family.familyEvents_certificate_of_dminus_lt_p params X Pz b
        (indicesByBase b) hX
        (fun i hi => hdminus_lt_p b i hi)
        (fun i hi => hmem b i hi) event hevent
    hbudget := hbudget }

/-- Build a finite rank-budget certificate from uniform admissible event data.

This removes the need to restate the low-level certificate-event witness
`hcert`: it follows from admissibility, the `rho/e` identities, base-prime
coprimality, and the base congruence. -/
noncomputable def satEventRankBudgetCertificateOfAdmissibleForUniform
    (N P R r s : ℕ) (rhoOf : ℕ → ℕ)
    (eventsByBase : ℕ → Finset EscLeanChecks.SatEvent)
    (B : ℕ → ℕ → ℚ)
    (hP : 1 < P) (hr : 0 < r) (hs : 0 < s)
    (hrank : ∀ b ∈ EscLeanChecks.reducedResiduesMod P,
      ∀ k ∈ Finset.range (2 * R + 1),
        (((-1 : Int) ^ k) *
          ((∑ t ∈ (eventsByBase b).powersetCard k,
              EscLeanChecks.baseSatEventCommonHitCountUpTo N P b t : ℕ) : Int) : ℚ) ≤
            B b k)
    (hadm : ∀ b event, event ∈ eventsByBase b →
      EscLeanChecks.satEventAdmissibleFor P rhoOf event)
    (hrho : ∀ b event, event ∈ eventsByBase b →
      rhoOf event.e = r * s)
    (hevent : ∀ b event, event ∈ eventsByBase b →
      event.e = r * s ^ 2)
    (hpBase : ∀ b event, event ∈ eventsByBase b →
      Nat.Coprime event.p P)
    (hbase : ∀ b event, event ∈ eventsByBase b →
      b + 4 * event.e ≡ 0 [MOD event.dMinus])
    (hbudget :
      (∑ b ∈ EscLeanChecks.reducedResiduesMod P,
        ∑ k ∈ Finset.range (2 * R + 1), B b k) < 1) :
    EscLeanChecks.SatEventRankBudgetCertificate N P R :=
  { eventsByBase := eventsByBase,
    B := B,
    hP := hP,
    hrank := hrank,
    hcert := EscLeanChecks.satEventVariableCerts_of_admissibleFor_uniform
      P r s rhoOf eventsByBase hr hs hadm hrho hevent hpBase hbase,
    hbudget := hbudget }

/-- Large-prime variant of
`satEventRankBudgetCertificateOfAdmissibleForUniform`, deriving the required
base-prime coprimality from `P < event.p`. -/
noncomputable def satEventRankBudgetCertificateOfAdmissibleForLargePrimeUniform
    (N P R r s : ℕ) (rhoOf : ℕ → ℕ)
    (eventsByBase : ℕ → Finset EscLeanChecks.SatEvent)
    (B : ℕ → ℕ → ℚ)
    (hP : 1 < P) (hr : 0 < r) (hs : 0 < s)
    (hrank : ∀ b ∈ EscLeanChecks.reducedResiduesMod P,
      ∀ k ∈ Finset.range (2 * R + 1),
        (((-1 : Int) ^ k) *
          ((∑ t ∈ (eventsByBase b).powersetCard k,
              EscLeanChecks.baseSatEventCommonHitCountUpTo N P b t : ℕ) : Int) : ℚ) ≤
            B b k)
    (hadm : ∀ b event, event ∈ eventsByBase b →
      EscLeanChecks.satEventAdmissibleFor P rhoOf event)
    (hrho : ∀ b event, event ∈ eventsByBase b →
      rhoOf event.e = r * s)
    (hevent : ∀ b event, event ∈ eventsByBase b →
      event.e = r * s ^ 2)
    (hlargeBase : ∀ b event, event ∈ eventsByBase b →
      P < event.p)
    (hbase : ∀ b event, event ∈ eventsByBase b →
      b + 4 * event.e ≡ 0 [MOD event.dMinus])
    (hbudget :
      (∑ b ∈ EscLeanChecks.reducedResiduesMod P,
        ∑ k ∈ Finset.range (2 * R + 1), B b k) < 1) :
    EscLeanChecks.SatEventRankBudgetCertificate N P R :=
  { eventsByBase := eventsByBase,
    B := B,
    hP := hP,
    hrank := hrank,
    hcert := EscLeanChecks.satEventVariableCerts_of_admissibleFor_largePrime_uniform
      P r s rhoOf eventsByBase (Nat.lt_trans Nat.zero_lt_one hP)
      hr hs hadm hrho hevent hlargeBase hbase,
    hbudget := hbudget }

/-- Convert the natural even-rank upper / odd-rank lower Bonferroni estimates
into the signed rank-budget inequality stored by a finite certificate. -/
theorem baseSatEvent_signed_rank_le_of_even_upper_odd_lower
    {N P b R : ℕ} {events : Finset EscLeanChecks.SatEvent}
    {upper lower : ℕ → ℚ}
    (heven : ∀ k ∈ Finset.range (2 * R + 1), Even k →
      ((∑ t ∈ events.powersetCard k,
          EscLeanChecks.baseSatEventCommonHitCountUpTo N P b t : ℕ) : ℚ) ≤
        upper k)
    (hodd : ∀ k ∈ Finset.range (2 * R + 1), Odd k →
      lower k ≤
        ((∑ t ∈ events.powersetCard k,
          EscLeanChecks.baseSatEventCommonHitCountUpTo N P b t : ℕ) : ℚ)) :
    ∀ k ∈ Finset.range (2 * R + 1),
      (((-1 : Int) ^ k) *
        ((∑ t ∈ events.powersetCard k,
            EscLeanChecks.baseSatEventCommonHitCountUpTo N P b t : ℕ) : Int) : ℚ) ≤
          if Even k then upper k else - lower k := by
  intro k hk
  exact EscLeanChecks.negOnePow_mul_natCast_le_of_even_upper_odd_lower
    k
    (∑ t ∈ events.powersetCard k,
      EscLeanChecks.baseSatEventCommonHitCountUpTo N P b t)
    (upper k) (lower k) (heven k hk) (hodd k hk)

/-- Large-prime finite certificate constructor from even-rank upper bounds and
odd-rank lower bounds.

This is closer to the usual Bonferroni verification shape than the raw signed
rank-budget interface: the signed budget function is assembled internally as
`if Even k then upper k else - lower k`. -/
noncomputable def satEventRankBudgetCertificateOfAdmissibleForLargePrimeUniformOfEvenOddBounds
    (N P R r s : ℕ) (rhoOf : ℕ → ℕ)
    (eventsByBase : ℕ → Finset EscLeanChecks.SatEvent)
    (upper lower : ℕ → ℕ → ℚ)
    (hP : 1 < P) (hr : 0 < r) (hs : 0 < s)
    (heven : ∀ b ∈ EscLeanChecks.reducedResiduesMod P,
      ∀ k ∈ Finset.range (2 * R + 1), Even k →
        ((∑ t ∈ (eventsByBase b).powersetCard k,
            EscLeanChecks.baseSatEventCommonHitCountUpTo N P b t : ℕ) : ℚ) ≤
          upper b k)
    (hodd : ∀ b ∈ EscLeanChecks.reducedResiduesMod P,
      ∀ k ∈ Finset.range (2 * R + 1), Odd k →
        lower b k ≤
          ((∑ t ∈ (eventsByBase b).powersetCard k,
            EscLeanChecks.baseSatEventCommonHitCountUpTo N P b t : ℕ) : ℚ))
    (hadm : ∀ b event, event ∈ eventsByBase b →
      EscLeanChecks.satEventAdmissibleFor P rhoOf event)
    (hrho : ∀ b event, event ∈ eventsByBase b →
      rhoOf event.e = r * s)
    (hevent : ∀ b event, event ∈ eventsByBase b →
      event.e = r * s ^ 2)
    (hlargeBase : ∀ b event, event ∈ eventsByBase b →
      P < event.p)
    (hbase : ∀ b event, event ∈ eventsByBase b →
      b + 4 * event.e ≡ 0 [MOD event.dMinus])
    (hbudget :
      (∑ b ∈ EscLeanChecks.reducedResiduesMod P,
        ∑ k ∈ Finset.range (2 * R + 1),
          if Even k then upper b k else - lower b k) < 1) :
    EscLeanChecks.SatEventRankBudgetCertificate N P R := by
  classical
  exact
    satEventRankBudgetCertificateOfAdmissibleForLargePrimeUniform
      N P R r s rhoOf eventsByBase
      (fun b k => if Even k then upper b k else - lower b k)
      hP hr hs
      (fun b hb =>
        baseSatEvent_signed_rank_le_of_even_upper_odd_lower
          (N := N) (P := P) (b := b) (R := R) (events := eventsByBase b)
          (upper := upper b) (lower := lower b)
          (heven b hb) (hodd b hb))
      hadm hrho hevent hlargeBase hbase hbudget

/-- The reduced residue classes modulo `P` are a filtered subset of
`Finset.range P`, hence there are at most `P` of them. -/
theorem reducedResiduesMod_card_le (P : ℕ) :
    (EscLeanChecks.reducedResiduesMod P).card ≤ P := by
  classical
  unfold EscLeanChecks.reducedResiduesMod
  simpa using Finset.card_filter_le (Finset.range P) (fun b => Nat.Coprime b P)

/-- Real-valued form of `reducedResiduesMod_card_le`, with a flexible analytic
modulus `Pz` that may dominate the integer modulus `P`. -/
theorem reducedResiduesMod_card_real_le
    {P : ℕ} {Pz : ℝ} (hPz : (P : ℝ) ≤ Pz) :
    ((EscLeanChecks.reducedResiduesMod P).card : ℝ) ≤ Pz := by
  exact le_trans (by exact_mod_cast reducedResiduesMod_card_le P) hPz

/-- Cast a rational certificate-budget split into the real-valued decomposition
shape consumed by the analytic transfer theorem. -/
theorem certRankBudget_real_decomp_of_rat
    {P R : ℕ → ℕ}
    {cert : ∀ N : ℕ, EscLeanChecks.SatEventRankBudgetCertificate N (P N) (R N)}
    {N b : ℕ} {mainQ errQ : ℚ}
    {PzN nohitN F2RN errTermN : ℝ}
    (hbudget : certRankBudget P R cert N b ≤ mainQ + errQ)
    (hmain : (mainQ : ℝ) ≤ ((N : ℝ) / PzN) * (nohitN + F2RN))
    (herr : (errQ : ℝ) ≤ errTermN) :
    (certRankBudget P R cert N b : ℝ) ≤
      ((N : ℝ) / PzN) * (nohitN + F2RN) + errTermN := by
  have hbudgetR :
      (certRankBudget P R cert N b : ℝ) ≤ (mainQ : ℝ) + (errQ : ℝ) := by
    exact_mod_cast hbudget
  exact le_trans hbudgetR (add_le_add hmain herr)

/-- Generic rational-budget split cast into the real-valued decomposition shape
used by the transfer theorem. -/
theorem rational_budget_real_decomp_of_rat
    {budget mainQ errQ : ℚ}
    {N : ℕ} {PzN nohitN F2RN errTermN : ℝ}
    (hbudget : budget ≤ mainQ + errQ)
    (hmain : (mainQ : ℝ) ≤ ((N : ℝ) / PzN) * (nohitN + F2RN))
    (herr : (errQ : ℝ) ≤ errTermN) :
    (budget : ℝ) ≤ ((N : ℝ) / PzN) * (nohitN + F2RN) + errTermN := by
  have hbudgetR : (budget : ℝ) ≤ (mainQ : ℝ) + (errQ : ℝ) := by
    exact_mod_cast hbudget
  exact le_trans hbudgetR (add_le_add hmain herr)

/-- Sum a per-rank rational main/error split into the per-class certificate
budget split consumed by the transfer capstones. -/
theorem rankBudget_sum_le_sum_main_add_sum_error
    {R : ℕ} {B mainRank errRank : ℕ → ℚ}
    (hsplit : ∀ k ∈ Finset.range (2 * R + 1),
      B k ≤ mainRank k + errRank k) :
    (∑ k ∈ Finset.range (2 * R + 1), B k) ≤
      (∑ k ∈ Finset.range (2 * R + 1), mainRank k) +
        (∑ k ∈ Finset.range (2 * R + 1), errRank k) := by
  calc
    (∑ k ∈ Finset.range (2 * R + 1), B k)
        ≤ ∑ k ∈ Finset.range (2 * R + 1), (mainRank k + errRank k) :=
          Finset.sum_le_sum hsplit
    _ =
      (∑ k ∈ Finset.range (2 * R + 1), mainRank k) +
        (∑ k ∈ Finset.range (2 * R + 1), errRank k) := by
          rw [Finset.sum_add_distrib]

/-- Certificate-budget version of `rankBudget_sum_le_sum_main_add_sum_error`. -/
theorem certRankBudget_le_sum_main_add_sum_error
    {P R : ℕ → ℕ}
    {cert : ∀ N : ℕ, EscLeanChecks.SatEventRankBudgetCertificate N (P N) (R N)}
    {N b : ℕ} {mainRank errRank : ℕ → ℚ}
    (hsplit : ∀ k ∈ Finset.range (2 * R N + 1),
      (cert N).B b k ≤ mainRank k + errRank k) :
    certRankBudget P R cert N b ≤
      (∑ k ∈ Finset.range (2 * R N + 1), mainRank k) +
        (∑ k ∈ Finset.range (2 * R N + 1), errRank k) := by
  simpa [certRankBudget] using
    (rankBudget_sum_le_sum_main_add_sum_error
      (R := R N) (B := fun k => (cert N).B b k)
      (mainRank := mainRank) (errRank := errRank) hsplit)

/-- Sum pointwise real envelopes for rational rank data. -/
theorem rankRational_sum_cast_le_sum_real_envelope
    {R : ℕ} {q : ℕ → ℚ} {u : ℕ → ℝ}
    (h : ∀ k ∈ Finset.range (2 * R + 1), (q k : ℝ) ≤ u k) :
    ((∑ k ∈ Finset.range (2 * R + 1), q k : ℚ) : ℝ) ≤
      ∑ k ∈ Finset.range (2 * R + 1), u k := by
  calc
    ((∑ k ∈ Finset.range (2 * R + 1), q k : ℚ) : ℝ)
        = ∑ k ∈ Finset.range (2 * R + 1), (q k : ℝ) := by
          norm_num
    _ ≤ ∑ k ∈ Finset.range (2 * R + 1), u k := Finset.sum_le_sum h

/-- Bound a finite rank real sum by a uniform per-rank real envelope. -/
theorem rankReal_sum_le_card_mul_of_pointwise
    {R : ℕ} {u : ℕ → ℝ} {U : ℝ}
    (h : ∀ k ∈ Finset.range (2 * R + 1), u k ≤ U) :
    (∑ k ∈ Finset.range (2 * R + 1), u k) ≤ ((2 * R + 1 : ℕ) : ℝ) * U := by
  calc
    (∑ k ∈ Finset.range (2 * R + 1), u k)
        ≤ ∑ k ∈ Finset.range (2 * R + 1), U := Finset.sum_le_sum h
    _ = ((Finset.range (2 * R + 1)).card : ℝ) * U := by
          simp
    _ = ((2 * R + 1 : ℕ) : ℝ) * U := by
          simp

/-! ## Main theorem from certificate budgets -/

/-- Certificate-specialized strongest capstone.

Compared with `main_modulo_finite_transfer_rat_range_bounds`, this theorem no
longer takes the rational reduced-count budget as an input.  It is derived from
`EscLeanChecks.reducedBaseExceptionalCountGeTwo_rat_le_of_SatEventRankBudgetCertificate`.

The remaining hypotheses are precisely the analytic comparisons for the
certificate budgets: the real-cast finite-transfer decomposition, Brun/error
inputs, class-count bound, saving comparison, and the smooth/rough range bounds. -/
theorem main_modulo_finite_transfer_cert_range_bounds
    (z P R : ℕ → ℕ)
    (cert : ∀ N : ℕ, EscLeanChecks.SatEventRankBudgetCertificate N (P N) (R N))
    (Pz μ εb : ℕ → ℝ)
    (Xpow nohit errTerm F2R : ℕ → ℕ → ℝ)
    (εK : ℝ)
    (Ered_c₁ : ℝ)
    (hc₁ : 0 < Ered_c₁)
    (hμ : ∀ N : ℕ, 3 ≤ N → 0 < μ N)
    (hPz : ∀ N : ℕ, 3 ≤ N → 1 ≤ Pz N)
    (hXpow : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N), 0 ≤ Xpow N b)
    (hεb : ∀ N : ℕ, 3 ≤ N → 0 ≤ εb N)
    (hdecomp : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        (certRankBudget P R cert N b : ℝ) ≤
          ((N : ℝ) / Pz N) * (nohit N b + F2R N b) + errTerm N b)
    (herr : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        errTerm N b ≤ Xpow N b * Real.exp ((1 + εK) * μ N))
    (hεle : εK ≤ 1)
    (hlevel : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        Pz N * Xpow N b * Real.exp (2 * μ N) ≤
          (N : ℝ) * Real.exp (-4 * μ N))
    (hF2R : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        F2R N b ≤ Real.exp (-3 * μ N))
    (hnohit : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        nohit N b ≤ Real.exp (-(1 - εb N) * μ N))
    (hcard : ∀ N : ℕ, 3 ≤ N →
      ((EscLeanChecks.reducedResiduesMod (P N)).card : ℝ) ≤ Pz N)
    (hsaving : ∀ N : ℕ, 3 ≤ N →
      Ered_c₁ * (Real.log N) ^ ((3 : ℝ) / 4) ≤
        (1 - (εb N + Real.log 3 / μ N)) * μ N)
    (smooth : ℕ → ℝ) (smoothExp smoothC : ℝ)
    (hse_pos : 0 < smoothExp) (hse_lt : smoothExp < 1) (hsC : 0 < smoothC)
    (hsmooth : ∀ N : ℕ, 3 ≤ N → smooth N ≤ smoothC * (N : ℝ) ^ smoothExp)
    (hsmooth_nn : ∀ N : ℕ, 0 ≤ smooth N)
    (hsmooth_range : ∀ N : ℕ, 3 ≤ N →
      (smoothRangeCount (z N) N : ℝ) ≤ smooth N)
    (euler : ℕ → ℝ) (eulerC : ℝ) (heC : 0 < eulerC)
    (heuler_nn : ∀ N : ℕ, 0 ≤ euler N)
    (heuler : ∀ N : ℕ, 3 ≤ N → euler N ≤ eulerC * Real.log N)
    (hrough_range : ∀ N : ℕ, 3 ≤ N →
      (roughLargeCount (z N) N : ℝ) ≤
        euler N * (EscLeanChecks.reducedBaseExceptionalCountGeTwo N (P N) : ℝ)) :
    IsMainBound exceptionalCount :=
  main_modulo_finite_transfer_rat_range_bounds
    z
    (fun N => EscLeanChecks.reducedResiduesMod (P N))
    (certRankBudget P R cert)
    Pz μ εb Xpow nohit errTerm F2R εK
    (fun N => EscLeanChecks.reducedBaseExceptionalCountGeTwo N (P N))
    Ered_c₁ hc₁
    (fun N _hN =>
      EscLeanChecks.reducedBaseExceptionalCountGeTwo_rat_le_of_SatEventRankBudgetCertificate
        N (P N) (R N) (cert N))
    hμ hPz hXpow hεb hdecomp herr hεle hlevel hF2R hnohit hcard hsaving
    smooth smoothExp smoothC hse_pos hse_lt hsC hsmooth hsmooth_nn
    hsmooth_range euler eulerC heC heuler_nn heuler hrough_range

/-- Certificate-specialized capstone with the class-count bound discharged.

The only class-count input is now the natural analytic comparison
`(P N : ℝ) ≤ Pz N`; the finite fact
`# reducedResiduesMod(P N) ≤ P N` is proved by
`reducedResiduesMod_card_real_le`. -/
theorem main_modulo_finite_transfer_cert_range_bounds_of_modulus_le
    (z P R : ℕ → ℕ)
    (cert : ∀ N : ℕ, EscLeanChecks.SatEventRankBudgetCertificate N (P N) (R N))
    (Pz μ εb : ℕ → ℝ)
    (Xpow nohit errTerm F2R : ℕ → ℕ → ℝ)
    (εK : ℝ)
    (Ered_c₁ : ℝ)
    (hc₁ : 0 < Ered_c₁)
    (hμ : ∀ N : ℕ, 3 ≤ N → 0 < μ N)
    (hPz : ∀ N : ℕ, 3 ≤ N → 1 ≤ Pz N)
    (hPz_ge_modulus : ∀ N : ℕ, 3 ≤ N → (P N : ℝ) ≤ Pz N)
    (hXpow : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N), 0 ≤ Xpow N b)
    (hεb : ∀ N : ℕ, 3 ≤ N → 0 ≤ εb N)
    (hdecomp : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        (certRankBudget P R cert N b : ℝ) ≤
          ((N : ℝ) / Pz N) * (nohit N b + F2R N b) + errTerm N b)
    (herr : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        errTerm N b ≤ Xpow N b * Real.exp ((1 + εK) * μ N))
    (hεle : εK ≤ 1)
    (hlevel : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        Pz N * Xpow N b * Real.exp (2 * μ N) ≤
          (N : ℝ) * Real.exp (-4 * μ N))
    (hF2R : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        F2R N b ≤ Real.exp (-3 * μ N))
    (hnohit : ∀ N : ℕ, 3 ≤ N →
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N),
        nohit N b ≤ Real.exp (-(1 - εb N) * μ N))
    (hsaving : ∀ N : ℕ, 3 ≤ N →
      Ered_c₁ * (Real.log N) ^ ((3 : ℝ) / 4) ≤
        (1 - (εb N + Real.log 3 / μ N)) * μ N)
    (smooth : ℕ → ℝ) (smoothExp smoothC : ℝ)
    (hse_pos : 0 < smoothExp) (hse_lt : smoothExp < 1) (hsC : 0 < smoothC)
    (hsmooth : ∀ N : ℕ, 3 ≤ N → smooth N ≤ smoothC * (N : ℝ) ^ smoothExp)
    (hsmooth_nn : ∀ N : ℕ, 0 ≤ smooth N)
    (hsmooth_range : ∀ N : ℕ, 3 ≤ N →
      (smoothRangeCount (z N) N : ℝ) ≤ smooth N)
    (euler : ℕ → ℝ) (eulerC : ℝ) (heC : 0 < eulerC)
    (heuler_nn : ∀ N : ℕ, 0 ≤ euler N)
    (heuler : ∀ N : ℕ, 3 ≤ N → euler N ≤ eulerC * Real.log N)

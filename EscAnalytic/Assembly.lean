            (fun r => (IsRough (zNatScale N) r ∧ ¬ fixedNumeratorRepresentable m r) ∧
              classOfRed m N s r = b)).card : ℕ) : ℝ) ≤ Ured m N s)
    (hred_class_uniform_sum_large : ∀ N m : ℕ, 3 ≤ N → T ≤ N → 2 ≤ m →
      (m : ℝ) ≤ (Real.log N) ^ A →
        (∑ s ∈ Finset.Icc 1 N, ((clsRed m N s).card : ℝ) * Ured m N s) ≤
          eulerProductFactorAtNat N * (Ered m N : ℝ)) :
    UniformNumeratorLargeRangeInputs A := by
  let smoothExp : ℝ := Classical.choose rankin_smoothRankinEnvelope_zNatScale_bound
  let smoothC : ℝ :=
    Classical.choose (Classical.choose_spec rankin_smoothRankinEnvelope_zNatScale_bound)
  have hsmooth_spec :
      0 < smoothExp ∧ smoothExp < 1 ∧ 0 < smoothC ∧
        ∀ N : ℕ, 3 ≤ N → smoothRankinEnvelope N ≤ smoothC * (N : ℝ) ^ smoothExp := by
    simpa [smoothExp, smoothC] using
      Classical.choose_spec
        (Classical.choose_spec rankin_smoothRankinEnvelope_zNatScale_bound)
  let eulerC : ℝ := Classical.choose eulerProductFactorAtNat_log_fourth_bound
  have heuler_spec :
      0 < eulerC ∧ ∀ N : ℕ, 3 ≤ N →
        eulerProductFactorAtNat N ≤ eulerC * (Real.log N) ^ (4 : ℕ) := by
    simpa [eulerC] using Classical.choose_spec eulerProductFactorAtNat_log_fourth_bound
  exact
    UniformNumeratorLargeRangeInputs.of_uniform_final_assembly_smoothPsi_class_envelope
      (T := T) (Ered_c₁ := Ered_c₁) (Ered_C₁ := Ered_C₁)
      (smoothExp := smoothExp) (smoothC := smoothC) (eulerC := eulerC)
      (B := B) hEred_c₁ hEred_C₁ hsmooth_spec.1 hsmooth_spec.2.1
      hsmooth_spec.2.2.1 heuler_spec.1 hB Ered (fun _m N => smoothRankinEnvelope N)
      clsRed classOfRed Ured hEred
      (by
        intro N _m hN _hTN _hm _hm_log
        exact hsmooth_spec.2.2.2 N hN)
      (by
        intro N _m hN _hTN _hm _hm_log
        exact heuler_spec.2 N hN)
      (by
        intro N _m _hN _hTN _hm _hm_log
        simp [smoothRankinEnvelope])
        hred_class_mem_large hred_class_bound_large hred_class_uniform_sum_large


          (fun r => (IsRough (zNatScale N) r ∧ EscLeanChecks.esExceptional r) ∧
            classOfRed N s r = b)).card : ℕ) : ℝ) ≤ Mred N s b)
    (hPz : ∀ N : ℕ, 3 ≤ N → T ≤ N → 1 ≤ Pz N)
    (hcard : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      (((Finset.Icc 1 N).sigma (fun s => clsRed N s)).card : ℝ) ≤ Pz N)
    (htransfer : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      ∀ p ∈ (Finset.Icc 1 N).sigma (fun s => clsRed N s),
        Mred N p.1 p.2 ≤ ((N : ℝ) / Pz N) *
          Real.exp (-(1 - ε N) * μ N))
    (hμ_lower : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      cμ * (Real.log N) ^ ((4 : ℝ) / 5) ≤ μ N)

/-- The symmetric signed-multiples package implies the rough-count
Euler-product discrepancy package by the checked finite identity. -/
theorem LinearSieveRoughDyadicCountDiscrepancyAbsQuarterBound_of_multiplesSignedAbs
    (h : LinearSieveRoughDyadicMultiplesSignedErrorAbsQuarterBound) :
    LinearSieveRoughDyadicCountDiscrepancyAbsQuarterBound := by
  intro a₀ b₀ C₀ c Xprod hc hprod
  rcases h a₀ b₀ C₀ c Xprod hc hprod with ⟨Xm, hXm⟩
  exact
    ⟨Xm,
      (roughDyadicBadPrimeProductMultiplesSignedErrorAbsBoundModulusOne_iff_countDiscrepancy
        a₀ b₀ C₀ (c / 4) Xm).1 hXm⟩

/-- The rough-count Euler-product discrepancy package and the symmetric
signed-multiples package are the same analytic content. -/
theorem LinearSieveRoughDyadicCountDiscrepancyAbsQuarterBound_iff_multiplesSignedAbs :
    LinearSieveRoughDyadicCountDiscrepancyAbsQuarterBound ↔

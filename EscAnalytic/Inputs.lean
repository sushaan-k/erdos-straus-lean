/-- A pure fractional-part lower bound plus an absolute endpoint bound gives
the lower bound for the full sawtooth/fractional-error carrier. -/
theorem roughDyadicBadPrimeProductMultiplesFractionalErrorNormalizedLowerBoundModulusOne_of_fractionalPartLower_endpoint
    {a₀ b₀ C₀ Epart Eend Xpart Xend : ℝ}
    (hpart :
      roughDyadicBadPrimeProductMultiplesFractionalPartErrorNormalizedLowerBoundModulusOne
        a₀ b₀ C₀ Epart Xpart)
    (hend :
      roughDyadicBadPrimeProductMultiplesEndpointErrorNormalizedAbsBoundModulusOne
        a₀ b₀ C₀ Eend Xend) :
    roughDyadicBadPrimeProductMultiplesFractionalErrorNormalizedLowerBoundModulusOne
      a₀ b₀ C₀ (Epart + Eend)
        (max (max Xpart Xend) (Real.exp 2)) := by
  rcases hpart with ⟨hEpart, hpartBound⟩
  rcases hend with ⟨hEend, hendBound⟩
  refine ⟨add_nonneg hEpart hEend, ?_⟩
  intro X hX t htlo hthi
  have hXpart : Xpart ≤ X := le_trans (le_trans (le_max_left _ _) (le_max_left _ _)) hX
  have hXend : Xend ≤ X := le_trans (le_trans (le_max_right _ _) (le_max_left _ _)) hX
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 2) hXexp
  have hlog_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp
  have ht_pos : 0 < t := lt_of_lt_of_le (Real.rpow_pos_of_pos hXpos a₀) htlo
  let T : ℝ := t / Real.log (EscAnalytic.zScale X)
  have hT_pos : 0 < T := div_pos ht_pos hlog_pos
  let P : ℝ := roughDyadicBadPrimeProductMultiplesFractionalPartErrorSum X t
  let D : ℝ :=
    roughDyadicBadPrimeProductMainTermSum X
      (roughBadPrimeProductMultiplesEndpointDelta t)
  have hpure : -Epart ≤ P / T := by
    simpa [P, T] using hpartBound X hXpart t htlo hthi
  have hendAbs : |D| / T ≤ Eend := by
    simpa [D, T] using hendBound X hXend t htlo hthi
  have hendDivAbs : |D / T| ≤ Eend := by
    rw [abs_div, abs_of_pos hT_pos]
    exact hendAbs
  have hendLower : -Eend ≤ D / T :=
    (neg_le_neg hendDivAbs).trans (neg_abs_le _)
  have hsplit :
      roughDyadicBadPrimeProductMultiplesFractionalErrorSum X t = P + D := by
    simpa [P, D] using
      roughDyadicBadPrimeProductMultiplesFractionalErrorSum_eq_fractionalPart_add_endpoint
        X t
  calc
    -(Epart + Eend)
        ≤ P / T + D / T := by linarith
    _ = (P + D) / T := by ring
    _ = roughDyadicBadPrimeProductMultiplesFractionalErrorSum X t / T := by
          rw [hsplit]


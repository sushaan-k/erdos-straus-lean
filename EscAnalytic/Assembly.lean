/-- Quartic saving from the speculative EH fan template:
`exp(-c(log N)^(4/5))`. -/
/- ## Conditional quartic-saving route -/

noncomputable def quarticSaving (c : ℝ) (N : ℕ) : ℝ :=
  Real.exp (-c * (Real.log N) ^ ((4 : ℝ) / 5))

/-- The quartic saving is always positive. -/
theorem quarticSaving_pos (c : ℝ) (N : ℕ) :
    0 < quarticSaving c N := by
  unfold quarticSaving
  exact Real.exp_pos _

/-- Quartic saving-shape comparison.  Once the finite-transfer exponent is at
least a constant multiple of `(log N)^(4/5)`, the transfer decay has the
quartic saving shape. -/
theorem exp_neg_mu_le_quarticSaving
    {μ ε c₄ : ℝ} {N : ℕ}
    (hbound : c₄ * (Real.log N) ^ ((4 : ℝ) / 5) ≤ (1 - ε) * μ) :
    Real.exp (-(1 - ε) * μ) ≤ quarticSaving c₄ N := by
  unfold quarticSaving
  apply Real.exp_le_exp.mpr
  nlinarith [hbound]

/-- Pointwise quartic exponent comparison from separate `ε` and `μ` bounds.

This splits the hard saving inequality into two more auditable estimates: the
finite-transfer loss is at most one half, and the main exponent is at least
twice the quartic target. -/
theorem quartic_exponent_comparison_of_eps_le_half
    {μ ε c₄ : ℝ} {N : ℕ}
    (hc₄ : 0 ≤ c₄) (hN : 3 ≤ N)
    (hε : ε ≤ (1 : ℝ) / 2)
    (hμ : 2 * (c₄ * (Real.log N) ^ ((4 : ℝ) / 5)) ≤ μ) :
    c₄ * (Real.log N) ^ ((4 : ℝ) / 5) ≤ (1 - ε) * μ := by
  have hlog_nonneg : 0 ≤ Real.log N := (log_pos_of_three_le hN).le
  have hpow_nonneg : 0 ≤ (Real.log N) ^ ((4 : ℝ) / 5) :=
    Real.rpow_nonneg hlog_nonneg _
  set target : ℝ := c₄ * (Real.log N) ^ ((4 : ℝ) / 5)
  have htarget_nonneg : 0 ≤ target := by
    dsimp [target]
    exact mul_nonneg hc₄ hpow_nonneg
  have hμ_nonneg : 0 ≤ μ := by nlinarith
  have htarget_le_half : target ≤ ((1 : ℝ) / 2) * μ := by nlinarith
  have hhalf_le : ((1 : ℝ) / 2) ≤ 1 - ε := by linarith
  have hhalf_mu_le : ((1 : ℝ) / 2) * μ ≤ (1 - ε) * μ :=
    mul_le_mul_of_nonneg_right hhalf_le hμ_nonneg
  exact le_trans htarget_le_half hhalf_mu_le

/-- Large-range quartic exponent comparison from separate large-range `ε` and
`μ` estimates.

This is the function-valued form used by the quartic finite-transfer bridges:
it removes the bundled `hsaving` premise once the paper-facing proof supplies
the two primitive inequalities separately. -/
theorem quartic_exponent_comparison_on_range_of_eps_le_half
    {μ ε : ℕ → ℝ} {c₄ : ℝ} {T : ℕ}
    (hc₄ : 0 ≤ c₄)
    (hε : ∀ N : ℕ, 3 ≤ N → T ≤ N → ε N ≤ (1 : ℝ) / 2)
    (hμ : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      2 * (c₄ * (Real.log N) ^ ((4 : ℝ) / 5)) ≤ μ N) :
    ∀ N : ℕ, 3 ≤ N → T ≤ N →
      c₄ * (Real.log N) ^ ((4 : ℝ) / 5) ≤ (1 - ε N) * μ N := by
  intro N hN hTN
  exact quartic_exponent_comparison_of_eps_le_half
    hc₄ hN (hε N hN hTN) (hμ N hN hTN)

/-- Paper-facing quartic exponent comparison from a direct `μ` lower bound.

If `μ` dominates `cμ (log N)^(4/5)` and the finite-transfer loss is at most
one half, then the finite-transfer exponent has quartic saving shape with
constant `cμ / 2`. -/
theorem quartic_exponent_comparison_of_mu_lower_and_epsilon_le_half
    {μ ε : ℕ → ℝ} {cμ : ℝ} {T : ℕ}
    (hcμ : 0 ≤ cμ)
    (hμ_lower : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      cμ * (Real.log N) ^ ((4 : ℝ) / 5) ≤ μ N)
    (hε : ∀ N : ℕ, 3 ≤ N → T ≤ N → ε N ≤ (1 : ℝ) / 2) :
    ∀ N : ℕ, 3 ≤ N → T ≤ N →
      (cμ / 2) * (Real.log N) ^ ((4 : ℝ) / 5) ≤
        (1 - ε N) * μ N := by
  intro N hN hTN
  have htwice :
      2 * ((cμ / 2) * (Real.log N) ^ ((4 : ℝ) / 5)) ≤ μ N := by
    have hμN := hμ_lower N hN hTN
    have hrewrite :
        2 * ((cμ / 2) * (Real.log N) ^ ((4 : ℝ) / 5)) =
          cμ * (Real.log N) ^ ((4 : ℝ) / 5) := by
      ring
    simpa [hrewrite] using hμN
  exact quartic_exponent_comparison_of_eps_le_half
    (c₄ := cμ / 2) (by nlinarith [hcμ]) hN (hε N hN hTN) htwice

/-- Quartic rational-certificate finite-transfer bridge.

This proves the algebraic summation/conversion part of the speculative quartic
fan route: rational certificate mass plus finite-transfer decay gives an
`E_red <= N * quarticSaving` bound, provided the genuinely hard exponent
comparison is already available. -/
theorem Ered_bound_of_finite_transfer_rat_quartic
    {ι : Type*} (cls : Finset ι)
    {Ered : ℕ} {MbQ : ι → ℚ} {N Pz μ ε c₄ : ℝ} {Nnat : ℕ}
    (hEred : (Ered : ℚ) ≤ ∑ b ∈ cls, MbQ b)
    (hPz : 1 ≤ Pz) (hNpos : 0 ≤ N)
    (hcard : (cls.card : ℝ) ≤ Pz)
    (htransfer : ∀ b ∈ cls,
      (MbQ b : ℝ) ≤ (N / Pz) * Real.exp (-(1 - ε) * μ))
    (hsaving : c₄ * (Real.log Nnat) ^ ((4 : ℝ) / 5) ≤ (1 - ε) * μ) :
    (Ered : ℝ) ≤ N * quarticSaving c₄ Nnat := by
  have h1 : (Ered : ℝ) ≤ N * Real.exp (-(1 - ε) * μ) :=
    reduced_missed_of_finite_transfer_rat cls hEred hPz hNpos hcard htransfer
  have h2 : Real.exp (-(1 - ε) * μ) ≤ quarticSaving c₄ Nnat :=
    exp_neg_mu_le_quarticSaving hsaving
  exact le_trans h1 (mul_le_mul_of_nonneg_left h2 hNpos)

/-- Real-valued quartic finite-transfer bridge.

This is the same summation/exponent comparison as
`Ered_bound_of_finite_transfer_rat_quartic`, but starts from a real-valued
mass domination.  It is useful when the preceding finite carrier has already
cast its exact cardinality bounds to `ℝ`. -/
theorem Ered_bound_of_finite_transfer_quartic
    {ι : Type*} (cls : Finset ι)
    {Ered : ℝ} {Mb : ι → ℝ} {N Pz μ ε c₄ : ℝ} {Nnat : ℕ}
    (hEred : Ered ≤ ∑ b ∈ cls, Mb b)
    (hPz : 1 ≤ Pz) (hNpos : 0 ≤ N)
    (hcard : (cls.card : ℝ) ≤ Pz)
    (htransfer : ∀ b ∈ cls,
      Mb b ≤ (N / Pz) * Real.exp (-(1 - ε) * μ))
    (hsaving : c₄ * (Real.log Nnat) ^ ((4 : ℝ) / 5) ≤ (1 - ε) * μ) :
    Ered ≤ N * quarticSaving c₄ Nnat := by
  have h1 : Ered ≤ N * Real.exp (-(1 - ε) * μ) :=
    le_trans hEred
      (reduced_missed_of_finite_transfer cls hPz hNpos hcard htransfer)
  have h2 : Real.exp (-(1 - ε) * μ) ≤ quarticSaving c₄ Nnat :=
    exp_neg_mu_le_quarticSaving hsaving
  exact le_trans h1 (mul_le_mul_of_nonneg_left h2 hNpos)

/-- Rewrite `N * quarticSaving c N` as one exponential. -/
theorem mul_quarticSaving_eq_exp (c : ℝ) {N : ℕ} (hN : 0 < N) :
    (N : ℝ) * quarticSaving c N
      = Real.exp (Real.log N + (-c) * (Real.log N) ^ ((4 : ℝ) / 5)) := by
  have hNpos : (0 : ℝ) < N := by exact_mod_cast hN
  unfold quarticSaving
  rw [← Real.exp_log hNpos, ← Real.exp_add, Real.log_exp]

/-- `t^(5/4) <= 1 + t^2` for all `t >= 0`. -/
theorem rpow_five_fourths_le {t : ℝ} (ht : 0 ≤ t) :
    t ^ ((5 : ℝ) / 4) ≤ 1 + t ^ 2 := by
  rcases le_or_lt t 1 with h | h
  · calc t ^ ((5 : ℝ) / 4) ≤ 1 ^ ((5 : ℝ) / 4) :=
            Real.rpow_le_rpow ht h (by norm_num)
      _ = 1 := by simp
      _ ≤ 1 + t ^ 2 := by nlinarith
  · have h1 : t ^ ((5 : ℝ) / 4) ≤ t ^ ((2 : ℝ)) :=
      (Real.rpow_le_rpow_left_iff h).mpr (by norm_num)
    calc t ^ ((5 : ℝ) / 4) ≤ t ^ ((2 : ℝ)) := h1
      _ = t ^ 2 := Real.rpow_two t
      _ ≤ 1 + t ^ 2 := by nlinarith

/-- `(L^(4/5))^(5/4) = L` for `L >= 0`. -/
theorem rpow_four_fifths_five_fourths {L : ℝ} (hL : 0 ≤ L) :
    (L ^ ((4 : ℝ) / 5)) ^ ((5 : ℝ) / 4) = L := by
  rw [← Real.rpow_mul hL]
  norm_num

/-- Absorb a fixed sublinear power into the quartic saving. -/
theorem quartic_poly_absorb {θ : ℝ} (hθ0 : 0 < θ) (hθ1 : θ < 1)
    {Cs : ℝ} (hCs : 0 < Cs) :
    ∃ c > (0 : ℝ), ∃ C > (0 : ℝ),
      ∀ N : ℕ, 3 ≤ N →
        Cs * (N : ℝ) ^ θ ≤ C * ((N : ℝ) * quarticSaving c N) := by
  refine ⟨(1 - θ) / 2, by linarith, max Cs 1,
    lt_of_lt_of_le hCs (le_max_left _ _), ?_⟩
  intro N hN
  set c : ℝ := (1 - θ) / 2 with hc
  have hNpos : (0 : ℝ) < N := by exact_mod_cast (by omega : 0 < N)
  set L : ℝ := Real.log N with hLdef
  have hL0 : 0 < L := log_pos_of_three_le hN
  have hNrpow : (N : ℝ) ^ θ = Real.exp (θ * L) := by
    rw [Real.rpow_def_of_pos hNpos]; ring_nf
  have hsave : (N : ℝ) * quarticSaving c N =
      Real.exp (L + (-c) * L ^ ((4 : ℝ) / 5)) := by
    have := mul_quarticSaving_eq_exp c (by omega : 0 < N)
    rw [← hLdef] at this
    exact this
  rw [hNrpow, hsave]
  have hkey : θ * L ≤ L + (-c) * L ^ ((4 : ℝ) / 5) := by
    have hL45pos : 0 < L ^ ((4 : ℝ) / 5) := Real.rpow_pos_of_pos hL0 _
    have hLlower : (1 : ℝ) / 32 < L := by
      have := log_ge_of_three_le hN
      rw [← hLdef] at this
      linarith
    have hfifth : (1 : ℝ) / 2 ≤ L ^ ((1 : ℝ) / 5) := by
      have h32 : ((1 : ℝ) / 32) ^ ((1 : ℝ) / 5) ≤ L ^ ((1 : ℝ) / 5) :=
        Real.rpow_le_rpow (by norm_num) hLlower.le (by norm_num)
      have : ((1 : ℝ) / 32) ^ ((1 : ℝ) / 5) = (1 : ℝ) / 2 := by
        rw [show (1 : ℝ) / 32 = (1 / 2) ^ (5 : ℕ) by norm_num,
          ← Real.rpow_natCast (1 / 2 : ℝ) 5, ← Real.rpow_mul (by norm_num)]
        norm_num
      linarith [this ▸ h32]
    have hLsplit : L = L ^ ((4 : ℝ) / 5) * L ^ ((1 : ℝ) / 5) := by
      rw [← Real.rpow_add hL0]; norm_num
    have hcle : c ≤ (1 - θ) * L ^ ((1 : ℝ) / 5) := by
      have : c = (1 - θ) * (1 / 2) := by rw [hc]; ring
      rw [this]
      apply mul_le_mul_of_nonneg_left hfifth (by linarith)
    have : c * L ^ ((4 : ℝ) / 5) ≤ (1 - θ) * L := by
      calc c * L ^ ((4 : ℝ) / 5)
          ≤ ((1 - θ) * L ^ ((1 : ℝ) / 5)) * L ^ ((4 : ℝ) / 5) :=
            mul_le_mul_of_nonneg_right hcle hL45pos.le
        _ = (1 - θ) * (L ^ ((4 : ℝ) / 5) * L ^ ((1 : ℝ) / 5)) := by ring
        _ = (1 - θ) * L := by rw [← hLsplit]
    linarith
  have hexpmono :
      Real.exp (θ * L) ≤ Real.exp (L + (-c) * L ^ ((4 : ℝ) / 5)) :=
    Real.exp_le_exp.mpr hkey
  have hCsle : Cs ≤ max Cs 1 := le_max_left _ _
  calc Cs * Real.exp (θ * L)
      ≤ Cs * Real.exp (L + (-c) * L ^ ((4 : ℝ) / 5)) :=
        mul_le_mul_of_nonneg_left hexpmono hCs.le
    _ ≤ max Cs 1 * Real.exp (L + (-c) * L ^ ((4 : ℝ) / 5)) :=
        mul_le_mul_of_nonneg_right hCsle (Real.exp_pos _).le

/-- Absorb one logarithmic factor into the quartic saving. -/
theorem quartic_log_absorb {c₁ : ℝ} (hc₁ : 0 < c₁)
    {Ce C₁ : ℝ} (hCe : 0 < Ce) (hC₁ : 0 < C₁) :
    ∃ c > (0 : ℝ), ∃ C > (0 : ℝ),
      ∀ N : ℕ, 3 ≤ N →
        Ce * Real.log N * (C₁ * ((N : ℝ) * quarticSaving c₁ N))
          ≤ C * ((N : ℝ) * quarticSaving c N) := by
  set c : ℝ := c₁ / 2 with hc
  refine ⟨c, by positivity, Ce * C₁ * (1 + 16 / c₁ ^ 2), by positivity, ?_⟩
  intro N hN
  set L : ℝ := Real.log N with hLdef
  have hL0 : 0 < L := log_pos_of_three_le hN
  set t : ℝ := L ^ ((4 : ℝ) / 5) with htdef
  have ht0 : 0 < t := Real.rpow_pos_of_pos hL0 _
  have hsave₁ : (N : ℝ) * quarticSaving c₁ N =
      (N : ℝ) * Real.exp (-c₁ * t) := by
    unfold quarticSaving
    rw [← hLdef, ← htdef]
  have hsaveC : (N : ℝ) * quarticSaving c N =
      (N : ℝ) * Real.exp (-c * t) := by
    unfold quarticSaving
    rw [← hLdef, ← htdef]
  rw [hsave₁, hsaveC]
  have hLbound : L ≤ 1 + t ^ 2 := by
    have : t ^ ((5 : ℝ) / 4) = L := by
      rw [htdef]
      exact rpow_four_fifths_five_fourths hL0.le
    calc L = t ^ ((5 : ℝ) / 4) := this.symm
      _ ≤ 1 + t ^ 2 := rpow_five_fourths_le ht0.le
  have hquad : t ^ 2 ≤ (16 / c₁ ^ 2) * Real.exp (c * t) := by
    have hct : 0 ≤ c * t := by positivity
    have h := sq_le_four_mul_exp hct
    have hcsq : (c * t) ^ 2 = c ^ 2 * t ^ 2 := by ring
    have hcpos : 0 < c ^ 2 := by positivity
    have hdiv : t ^ 2 ≤ (4 / c ^ 2) * Real.exp (c * t) := by
      rw [hcsq] at h
      rw [div_mul_eq_mul_div, le_div_iff₀ hcpos]
      nlinarith [h]
    have hcc : c ^ 2 = c₁ ^ 2 / 4 := by rw [hc]; ring
    have e : (4 : ℝ) / c ^ 2 = 16 / c₁ ^ 2 := by
      rw [hcc]
      field_simp
      ring
    rw [e] at hdiv
    exact hdiv
  have hone : (1 : ℝ) ≤ Real.exp (c * t) := by
    have : (0 : ℝ) ≤ c * t := by positivity
    simpa using Real.one_le_exp this
  have hLexp : L ≤ (1 + 16 / c₁ ^ 2) * Real.exp (c * t) := by
    have : (1 : ℝ) + t ^ 2 ≤ (1 + 16 / c₁ ^ 2) * Real.exp (c * t) := by
      have h16 : (0 : ℝ) ≤ 16 / c₁ ^ 2 := by positivity
      nlinarith [hone, hquad, Real.exp_pos (c * t)]
    linarith
  have hexp_id : Real.exp (-c₁ * t) * Real.exp (c * t) = Real.exp (-c * t) := by
    rw [← Real.exp_add]
    congr 1
    rw [hc]
    ring
  have key : Ce * L * (C₁ * ((N : ℝ) * Real.exp (-c₁ * t)))
      ≤ Ce * C₁ * (1 + 16 / c₁ ^ 2) *
          ((N : ℝ) * Real.exp (-c * t)) := by
    have hmul : Ce * L * (C₁ * ((N : ℝ) * Real.exp (-c₁ * t)))
        ≤ Ce * ((1 + 16 / c₁ ^ 2) * Real.exp (c * t)) *
            (C₁ * ((N : ℝ) * Real.exp (-c₁ * t))) := by
      apply mul_le_mul_of_nonneg_right
      · apply mul_le_mul_of_nonneg_left hLexp hCe.le
      · positivity
    refine hmul.trans ?_
    have : Ce * ((1 + 16 / c₁ ^ 2) * Real.exp (c * t)) *
            (C₁ * ((N : ℝ) * Real.exp (-c₁ * t)))
        = Ce * C₁ * (1 + 16 / c₁ ^ 2) *
            ((N : ℝ) * (Real.exp (-c₁ * t) * Real.exp (c * t))) := by
      ring
    rw [this, hexp_id]
  exact key

/-- Absorb four logarithmic factors into the quartic saving. -/
theorem quartic_log_pow_four_absorb {c₁ : ℝ} (hc₁ : 0 < c₁)
    {Ce C₁ : ℝ} (hCe : 0 < Ce) (hC₁ : 0 < C₁) :
    ∃ c > (0 : ℝ), ∃ C > (0 : ℝ),
      ∀ N : ℕ, 3 ≤ N →
        Ce * (Real.log N) ^ (4 : ℕ) *
            (C₁ * ((N : ℝ) * quarticSaving c₁ N))
          ≤ C * ((N : ℝ) * quarticSaving c N) := by
  obtain ⟨c₂, hc₂, C₂, hC₂, h₂⟩ :=
    quartic_log_absorb hc₁ (by norm_num : (0 : ℝ) < 1) hC₁
  obtain ⟨c₃, hc₃, C₃, hC₃, h₃⟩ :=
    quartic_log_absorb hc₂ (by norm_num : (0 : ℝ) < 1) hC₂
  obtain ⟨c₄, hc₄, C₄, hC₄, h₄⟩ :=
    quartic_log_absorb hc₃ (by norm_num : (0 : ℝ) < 1) hC₃
  obtain ⟨c₅, hc₅, C₅, hC₅, h₅⟩ :=
    quartic_log_absorb hc₄ hCe hC₄
  refine ⟨c₅, hc₅, C₅, hC₅, ?_⟩
  intro N hN
  set L : ℝ := Real.log N with hLdef
  have hL_nonneg : 0 ≤ L := (log_pos_of_three_le hN).le
  have h₂N :
      L * (C₁ * ((N : ℝ) * quarticSaving c₁ N))
        ≤ C₂ * ((N : ℝ) * quarticSaving c₂ N) := by
    have := h₂ N hN
    rw [← hLdef] at this
    simpa [one_mul] using this
  have h₃N :
      L * (C₂ * ((N : ℝ) * quarticSaving c₂ N))
        ≤ C₃ * ((N : ℝ) * quarticSaving c₃ N) := by
    have := h₃ N hN
    rw [← hLdef] at this
    simpa [one_mul] using this
  have h₄N :
      L * (C₃ * ((N : ℝ) * quarticSaving c₃ N))
        ≤ C₄ * ((N : ℝ) * quarticSaving c₄ N) := by
    have := h₄ N hN
    rw [← hLdef] at this
    simpa [one_mul] using this
  have h₅N :
      Ce * L * (C₄ * ((N : ℝ) * quarticSaving c₄ N))
        ≤ C₅ * ((N : ℝ) * quarticSaving c₅ N) := by
    have := h₅ N hN
    rw [← hLdef] at this
    simpa [mul_assoc, mul_left_comm, mul_comm] using this
  calc
    (Ce * L ^ (4 : ℕ)) * (C₁ * ((N : ℝ) * quarticSaving c₁ N))
        = Ce * L * (L * (L * (L * (C₁ * ((N : ℝ) * quarticSaving c₁ N))))) := by
          ring
    _ ≤ Ce * L * (L * (L * (C₂ * ((N : ℝ) * quarticSaving c₂ N)))) := by
          gcongr
    _ ≤ Ce * L * (L * (C₃ * ((N : ℝ) * quarticSaving c₃ N))) := by
          gcongr
    _ ≤ Ce * L * (C₄ * ((N : ℝ) * quarticSaving c₄ N)) := by
          gcongr
    _ ≤ C₅ * ((N : ℝ) * quarticSaving c₅ N) := by
          exact h₅N

/-- Quartic absorption of the smooth range plus the Euler-product loss. -/
theorem quartic_smooth_euler_absorb
    {cE CE smoothExp smoothC eulerC : ℝ}
    (hcE : 0 < cE) (hCE : 0 < CE)
    (hse_pos : 0 < smoothExp) (hse_lt : smoothExp < 1)
    (hsC : 0 < smoothC) (heC : 0 < eulerC) :
    ∃ c₄ > (0 : ℝ), ∃ C₄ > (0 : ℝ),
      ∀ N : ℕ, 3 ≤ N →
        smoothC * (N : ℝ) ^ smoothExp +
          (eulerC * (Real.log N) ^ (4 : ℕ)) *
            (CE * ((N : ℝ) * quarticSaving cE N))
        ≤ C₄ * (N : ℝ) * quarticSaving c₄ N := by
  obtain ⟨cs, hcs, Cs, hCs, hsmooth⟩ :=
    quartic_poly_absorb hse_pos hse_lt hsC
  obtain ⟨ce, hce, Ce, hCe, heuler⟩ :=
    quartic_log_pow_four_absorb hcE heC hCE
  set c : ℝ := min cs ce with hcdef
  have hc : 0 < c := lt_min hcs hce
  have qsave_mono : ∀ c' : ℝ, c ≤ c' → ∀ N : ℕ, 3 ≤ N →
      (N : ℝ) * quarticSaving c' N ≤ (N : ℝ) * quarticSaving c N := by
    intro c' hcc' N hN
    have hLpos : 0 < Real.log N := log_pos_of_three_le hN
    have hL45 : 0 ≤ (Real.log N) ^ ((4 : ℝ) / 5) :=
      (Real.rpow_pos_of_pos hLpos _).le
    have hNpos : (0 : ℝ) ≤ N := by positivity
    apply mul_le_mul_of_nonneg_left _ hNpos
    unfold quarticSaving
    apply Real.exp_le_exp.mpr
    exact mul_le_mul_of_nonneg_right (by linarith : -c' ≤ -c) hL45
  refine ⟨c, hc, Cs + Ce, by positivity, ?_⟩
  intro N hN
  have hsmoothN :
      smoothC * (N : ℝ) ^ smoothExp
        ≤ Cs * ((N : ℝ) * quarticSaving c N) := by
    have h1 := hsmooth N hN
    have h2 : (N : ℝ) * quarticSaving cs N ≤
        (N : ℝ) * quarticSaving c N :=
      qsave_mono cs (min_le_left _ _) N hN
    calc
      smoothC * (N : ℝ) ^ smoothExp
          ≤ Cs * ((N : ℝ) * quarticSaving cs N) := h1
      _ ≤ Cs * ((N : ℝ) * quarticSaving c N) :=
          mul_le_mul_of_nonneg_left h2 hCs.le
  have heulerN :
      (eulerC * (Real.log N) ^ (4 : ℕ)) *
          (CE * ((N : ℝ) * quarticSaving cE N))
        ≤ Ce * ((N : ℝ) * quarticSaving c N) := by
    have h1 := heuler N hN
    have h2 : (N : ℝ) * quarticSaving ce N ≤
        (N : ℝ) * quarticSaving c N :=
      qsave_mono ce (min_le_right _ _) N hN
    calc
      (eulerC * (Real.log N) ^ (4 : ℕ)) *
          (CE * ((N : ℝ) * quarticSaving cE N))
          ≤ Ce * ((N : ℝ) * quarticSaving ce N) := h1
      _ ≤ Ce * ((N : ℝ) * quarticSaving c N) :=
          mul_le_mul_of_nonneg_left h2 hCe.le
  calc
    smoothC * (N : ℝ) ^ smoothExp +
        (eulerC * (Real.log N) ^ (4 : ℕ)) *
          (CE * ((N : ℝ) * quarticSaving cE N))
      ≤ Cs * ((N : ℝ) * quarticSaving c N) +
          Ce * ((N : ℝ) * quarticSaving c N) :=
        add_le_add hsmoothN heulerN
    _ = (Cs + Ce) * ((N : ℝ) * quarticSaving c N) := by ring
    _ = (Cs + Ce) * (N : ℝ) * quarticSaving c N := by ring

/-- Paper-shaped Lean carrier for the speculative quartic EH saturated packet.
This is an explicit conditional package; no quartic packet is constructed here. -/
structure QuarticEHFanInputs where
  c₄ : ℝ
  C₄ : ℝ
  c₄_pos : 0 < c₄
  C₄_pos : 0 < C₄
  bound : ∀ N : ℕ, 3 ≤ N →
    (exceptionalCount N : ℝ) ≤ C₄ * (N : ℝ) * quarticSaving c₄ N

/-- The finite initial range for a quartic estimate can be absorbed into the
implied constant.  This is purely finite bookkeeping and does not construct the
quartic analytic estimate itself. -/
theorem finite_initial_quartic_bound
    {c₄ : ℝ} (_hc₄ : 0 < c₄) (T : ℕ) :
    ∃ Cinit : ℝ, 0 < Cinit ∧
      ∀ N : ℕ, 3 ≤ N → N < T →
        (exceptionalCount N : ℝ) ≤
          Cinit * (N : ℝ) * quarticSaving c₄ N := by
  classical
  let scale : ℕ → ℝ := fun n => (n : ℝ) * quarticSaving c₄ n
  let term : ℕ → ℝ := fun n => (exceptionalCount n : ℝ) / scale n
  let Cinit : ℝ := 1 + ∑ n in Finset.range T, term n
  have hterm_nonneg : ∀ n ∈ Finset.range T, 0 ≤ term n := by
    intro n _hn
    have hscale_nonneg : 0 ≤ scale n := by
      dsimp [scale]
      exact mul_nonneg (Nat.cast_nonneg n) (quarticSaving_pos c₄ n).le
    dsimp [term]
    exact div_nonneg (by positivity) hscale_nonneg
  have hsum_nonneg : 0 ≤ ∑ n in Finset.range T, term n :=
    Finset.sum_nonneg hterm_nonneg
  refine ⟨Cinit, ?_, ?_⟩
  · dsimp [Cinit]
    linarith
  · intro N hN hNT
    have hmem : N ∈ Finset.range T := Finset.mem_range.mpr hNT
    have hterm_le_sum : term N ≤ ∑ n in Finset.range T, term n :=
      Finset.single_le_sum hterm_nonneg hmem
    have hterm_le_C : term N ≤ Cinit := by
      dsimp [Cinit]
      linarith
    have hNpos : 0 < (N : ℝ) := by
      exact_mod_cast (lt_of_lt_of_le (by decide : 0 < 3) hN)
    have hscale_pos : 0 < scale N := by
      dsimp [scale]
      exact mul_pos hNpos (quarticSaving_pos c₄ N)
    have hmul := mul_le_mul_of_nonneg_right hterm_le_C hscale_pos.le
    have hterm_scale : term N * scale N = (exceptionalCount N : ℝ) := by
      dsimp [term]
      field_simp [hscale_pos.ne']
    calc
      (exceptionalCount N : ℝ) = term N * scale N := hterm_scale.symm
      _ ≤ Cinit * scale N := hmul
      _ = Cinit * (N : ℝ) * quarticSaving c₄ N := by
          simp [scale, mul_assoc]

/-- Build the quartic fan package from an eventual quartic estimate.

This removes finite small cutoffs from the hard quartic hypothesis: after an
estimate is known for `N >= T`, the remaining finite interval is absorbed by
`finite_initial_quartic_bound`. -/
noncomputable def quarticEHFanInputs_of_eventual_bound
    {c₄ C₄ : ℝ} (hc₄ : 0 < c₄) (hC₄ : 0 < C₄) (T : ℕ)
    (hlarge : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      (exceptionalCount N : ℝ) ≤ C₄ * (N : ℝ) * quarticSaving c₄ N) :
    QuarticEHFanInputs := by
  let hinit_exists := finite_initial_quartic_bound hc₄ T
  let Cinit := Classical.choose hinit_exists
  have hCinit_spec :
      0 < Cinit ∧
        ∀ N : ℕ, 3 ≤ N → N < T →
          (exceptionalCount N : ℝ) ≤
            Cinit * (N : ℝ) * quarticSaving c₄ N :=
    Classical.choose_spec hinit_exists
  exact
    { c₄ := c₄
      C₄ := max C₄ Cinit
      c₄_pos := hc₄
      C₄_pos := lt_of_lt_of_le hC₄ (le_max_left C₄ Cinit)
      bound := by
        intro N hN
        have hN_nonneg : 0 ≤ (N : ℝ) := Nat.cast_nonneg N
        have hsaving_nonneg : 0 ≤ quarticSaving c₄ N :=
          (quarticSaving_pos c₄ N).le
        by_cases hTN : T ≤ N
        · have hC_N :
            C₄ * (N : ℝ) ≤ max C₄ Cinit * (N : ℝ) :=
            mul_le_mul_of_nonneg_right (le_max_left C₄ Cinit) hN_nonneg
          exact le_trans (hlarge N hN hTN)
            (mul_le_mul_of_nonneg_right hC_N hsaving_nonneg)
        · have hNT : N < T := Nat.lt_of_not_ge hTN
          have hC_N :
            Cinit * (N : ℝ) ≤ max C₄ Cinit * (N : ℝ) :=
            mul_le_mul_of_nonneg_right (le_max_right C₄ Cinit) hN_nonneg
          exact le_trans (hCinit_spec.2 N hN hNT)
            (mul_le_mul_of_nonneg_right hC_N hsaving_nonneg) }

/-- Exact large-range hard core of `hyp:quartic-eh-fan` after finite cutoff
bookkeeping has been removed.  This is still a analytic/certificate
input; it only avoids counting finitely many small `N` as part of the hard
quartic problem. -/
structure QuarticLargeRangeInputs where
  c₄ : ℝ
  C₄ : ℝ
  T : ℕ
  c₄_pos : 0 < c₄
  C₄_pos : 0 < C₄
  large_bound : ∀ N : ℕ, 3 ≤ N → T ≤ N →
    (exceptionalCount N : ℝ) ≤ C₄ * (N : ℝ) * quarticSaving c₄ N

/-- Build the exact quartic large-range hard core from quartic reduced-count,
smooth-range, Euler-loss, and lifting data. -/
noncomputable def QuarticLargeRangeInputs.of_quartic_Ered_smooth_euler_lift
    (Ered : ℕ → ℕ) (smooth euler : ℕ → ℝ)
    (cE CE smoothExp smoothC eulerC : ℝ) (T : ℕ)
    (hcE : 0 < cE) (hCE : 0 < CE)
    (hse_pos : 0 < smoothExp) (hse_lt : smoothExp < 1)
    (hsC : 0 < smoothC) (heC : 0 < eulerC)
    (hEred : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      (Ered N : ℝ) ≤ CE * ((N : ℝ) * quarticSaving cE N))
    (hsmooth : ∀ N : ℕ, 3 ≤ N →
      smooth N ≤ smoothC * (N : ℝ) ^ smoothExp)
    (heuler : ∀ N : ℕ, 3 ≤ N →
      euler N ≤ eulerC * (Real.log N) ^ (4 : ℕ))
    (hlift : ∀ N : ℕ, 3 ≤ N →
      (exceptionalCount N : ℝ) ≤ smooth N + euler N * (Ered N : ℝ)) :
    QuarticLargeRangeInputs := by
  let habs :=
    quartic_smooth_euler_absorb hcE hCE hse_pos hse_lt hsC heC
  let c₄ := Classical.choose habs
  have hc₄_spec := Classical.choose_spec habs
  let C₄ := Classical.choose hc₄_spec.2
  have hC₄_spec := Classical.choose_spec hc₄_spec.2
  exact
    { c₄ := c₄
      C₄ := C₄
      T := T
      c₄_pos := hc₄_spec.1
      C₄_pos := hC₄_spec.1
      large_bound := by
        intro N hN hTN
        have hliftN := hlift N hN
        have hsmoothN : smooth N ≤ smoothC * (N : ℝ) ^ smoothExp :=
          hsmooth N hN
        have heulerN : euler N ≤ eulerC * (Real.log N) ^ (4 : ℕ) :=
          heuler N hN
        have hEredN :
            (Ered N : ℝ) ≤ CE * ((N : ℝ) * quarticSaving cE N) :=
          hEred N hN hTN
        have hEred_nonneg : 0 ≤ (Ered N : ℝ) := by positivity
        have hlog_nonneg : 0 ≤ Real.log N := (log_pos_of_three_le hN).le
        have heuler_rhs_nonneg :
            0 ≤ eulerC * (Real.log N) ^ (4 : ℕ) :=
          mul_nonneg heC.le (pow_nonneg hlog_nonneg 4)
        have hrough :
            euler N * (Ered N : ℝ) ≤
              (eulerC * (Real.log N) ^ (4 : ℕ)) *
                (CE * ((N : ℝ) * quarticSaving cE N)) := by
          exact mul_le_mul heulerN hEredN hEred_nonneg heuler_rhs_nonneg
        have hsum :
            smooth N + euler N * (Ered N : ℝ) ≤
              smoothC * (N : ℝ) ^ smoothExp +
                (eulerC * (Real.log N) ^ (4 : ℕ)) *
                  (CE * ((N : ℝ) * quarticSaving cE N)) :=
          add_le_add hsmoothN hrough
        have habsN :=
          hC₄_spec.2 N hN
        exact le_trans hliftN (le_trans hsum habsN) }

/-- Build the quartic large-range hard core directly from rational
finite-transfer data, the quartic exponent comparison, and the checked
smooth/Euler lifting layer.

This removes the separate quartic `Ered` bound from the hypothesis surface:
the finite-transfer summation proves it internally via
`Ered_bound_of_finite_transfer_rat_quartic`.  The remaining nontrivial quartic
content is the displayed large-range transfer/certificate data and the
`(log N)^(4/5)` exponent comparison. -/
noncomputable def QuarticLargeRangeInputs.of_finite_transfer_rat_smooth_euler_lift
    {ι : Type*}
    (cls : ℕ → Finset ι)
    (MbQ : ℕ → ι → ℚ)
    (Pz μ ε : ℕ → ℝ)
    (Ered : ℕ → ℕ) (smooth euler : ℕ → ℝ)
    (cE smoothExp smoothC eulerC : ℝ) (T : ℕ)
    (hcE : 0 < cE)
    (hse_pos : 0 < smoothExp) (hse_lt : smoothExp < 1)
    (hsC : 0 < smoothC) (heC : 0 < eulerC)
    (hEred_rat : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      (Ered N : ℚ) ≤ ∑ b ∈ cls N, MbQ N b)
    (hPz : ∀ N : ℕ, 3 ≤ N → T ≤ N → 1 ≤ Pz N)
    (hcard : ∀ N : ℕ, 3 ≤ N → T ≤ N → ((cls N).card : ℝ) ≤ Pz N)
    (htransfer : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      (MbQ N b : ℝ) ≤ ((N : ℝ) / Pz N) *
        Real.exp (-(1 - ε N) * μ N))
    (hsaving : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      cE * (Real.log N) ^ ((4 : ℝ) / 5) ≤ (1 - ε N) * μ N)
    (hsmooth : ∀ N : ℕ, 3 ≤ N →
      smooth N ≤ smoothC * (N : ℝ) ^ smoothExp)
    (heuler : ∀ N : ℕ, 3 ≤ N →
      euler N ≤ eulerC * (Real.log N) ^ (4 : ℕ))
    (hlift : ∀ N : ℕ, 3 ≤ N →
      (exceptionalCount N : ℝ) ≤ smooth N + euler N * (Ered N : ℝ)) :
    QuarticLargeRangeInputs :=
  QuarticLargeRangeInputs.of_quartic_Ered_smooth_euler_lift
    Ered smooth euler cE 1 smoothExp smoothC eulerC T
    hcE (by norm_num) hse_pos hse_lt hsC heC
    (by
      intro N hN hTN
      have hEredN :
          (Ered N : ℝ) ≤ (N : ℝ) * quarticSaving cE N :=
        Ered_bound_of_finite_transfer_rat_quartic (cls N)
          (Ered := Ered N) (MbQ := fun b => MbQ N b)
          (N := (N : ℝ)) (Pz := Pz N) (μ := μ N)
          (ε := ε N) (c₄ := cE) (Nnat := N)
          (hEred_rat N hN hTN) (hPz N hN hTN)
          (Nat.cast_nonneg N) (hcard N hN hTN)
          (htransfer N hN hTN) (hsaving N hN hTN)
      simpa [one_mul] using hEredN)
    hsmooth heuler hlift

/-- Convert the exact large-range quartic hard core into the global quartic fan
package by absorbing only the finite initial range. -/
noncomputable def QuarticLargeRangeInputs.toEHFanInputs
    (H : QuarticLargeRangeInputs) : QuarticEHFanInputs :=
  quarticEHFanInputs_of_eventual_bound H.c₄_pos H.C₄_pos H.T H.large_bound

/-- **`thm:EH-quartic` (conditional Lean form).** Given the final-bound carrier
obtained from the speculative quartic fan hypothesis, the paper's quartic
optimization template has the advertised `(log N)^(4/5)` saving. -/
theorem thm_EH_quartic (H : QuarticEHFanInputs) :
    ∃ c₄ > (0 : ℝ), ∃ C₄ > (0 : ℝ), ∀ N : ℕ, 3 ≤ N →
      (exceptionalCount N : ℝ) ≤ C₄ * (N : ℝ) * quarticSaving c₄ N :=
  ⟨H.c₄, H.c₄_pos, H.C₄, H.C₄_pos, H.bound⟩

/-- Quartic appendix theorem from the exact large-range hard core. -/
theorem thm_EH_quartic_of_largeRangeInputs
    (H : QuarticLargeRangeInputs) :
    ∃ c₄ > (0 : ℝ), ∃ C₄ > (0 : ℝ), ∀ N : ℕ, 3 ≤ N →
      (exceptionalCount N : ℝ) ≤ C₄ * (N : ℝ) * quarticSaving c₄ N :=
  thm_EH_quartic H.toEHFanInputs

/-- Final-bound proposition carrier supplied by the speculative quartic
certificate family.  This records the consequence consumed downstream, not the
four structural bullets of `hyp:quartic-eh-fan`; no such family is constructed
in this file. -/
def QuarticCertificateFamilyInput : Prop :=
  ∃ c₄ > (0 : ℝ), ∃ C₄ > (0 : ℝ), ∀ N : ℕ, 3 ≤ N →
    (exceptionalCount N : ℝ) ≤ C₄ * (N : ℝ) * quarticSaving c₄ N

/-- Convert the final-bound quartic certificate carrier into the structured
carrier used by downstream bundled capstones. -/
noncomputable def quarticEHFanInputs_of_quarticCertificateFamilyInput
    (H : QuarticCertificateFamilyInput) : QuarticEHFanInputs :=
  let c₄ := Classical.choose H
  let h1 := Classical.choose_spec H
  let hCexists := h1.2
  let C₄ := Classical.choose hCexists
  let h2 := Classical.choose_spec hCexists
  { c₄ := c₄
    C₄ := C₄
    c₄_pos := h1.1
    C₄_pos := h2.1
    bound := h2.2 }

/-- The quartic appendix theorem from the paper-facing certificate-family
hypothesis. -/
theorem thm_EH_quartic_of_quartic_certificate_family
    (H : QuarticCertificateFamilyInput) :
    ∃ c₄ > (0 : ℝ), ∃ C₄ > (0 : ℝ), ∀ N : ℕ, 3 ≤ N →
      (exceptionalCount N : ℝ) ≤ C₄ * (N : ℝ) * quarticSaving c₄ N :=
  thm_EH_quartic (quarticEHFanInputs_of_quarticCertificateFamilyInput H)

/-- Exponent in the Pomerance-Weingartner/Vaughan-type comparison term:
`((log N)^2 / phi(m))^(1/3)`. -/
/- ## Comparison with the Pomerance--Weingartner exponent -/

noncomputable def pomeranceWeingartnerExponent (m N : ℕ) : ℝ :=
  (((Real.log N) ^ (2 : ℕ)) / (Nat.totient m : ℝ)) ^ ((1 : ℝ) / 3)

/-- Exponent in the conditional saturated-fan bound of `thm:uniform-m`. -/
noncomputable def uniformNumeratorExponent (B : ℝ) (m N : ℕ) : ℝ :=
  (Real.log N) ^ ((3 : ℝ) / 4) / uniformNumeratorDenominator B m

/-- Product-form comparison implies the displayed exponent comparison.

The remaining arithmetic work in `cor:PW-comparison` is to prove the product
inequality.  Once that is available, the passage to the saturated-fan exponent
is only division by the positive denominator
`phi(m) * (m / phi(m))^B`. -/
theorem pomeranceWeingartnerExponent_le_uniformNumeratorExponent_of_product_le
    {B : ℝ} {m N : ℕ} (hm : 0 < m)
    (hprod :
      uniformNumeratorDenominator B m * pomeranceWeingartnerExponent m N ≤
        (Real.log N) ^ ((3 : ℝ) / 4)) :
    pomeranceWeingartnerExponent m N ≤ uniformNumeratorExponent B m N := by
  have hDpos : 0 < uniformNumeratorDenominator B m :=
    uniformNumeratorDenominator_pos (B := B) hm
  unfold uniformNumeratorExponent
  exact (le_div_iff₀ hDpos).mpr (by
    simpa [mul_comm, mul_left_comm, mul_assoc] using hprod)

/-- Paper-shaped carrier for `cor:PW-comparison`: for the logarithmic numerator
range and the displayed small-totient subfamily, the saturated-fan exponent
eventually dominates the Pomerance-Weingartner/Vaughan-type exponent.

The input is kept in product form: the caller supplies the arithmetic comparison
which says that the saturated-fan denominator times the Vaughan-type exponent is
at most `(log N)^(3/4)`.  The public corollary below proves the final division
step internally. -/
structure PWComparisonInputs where
  B₂ : ℝ
  B₂_pos : 0 < B₂
  product_bound : ∀ δ : ℝ, 0 < δ →
    ∃ N₀ : ℕ, ∀ N m : ℕ, N₀ ≤ N → 4 ≤ m →
      (m : ℝ) ≤ (Real.log N) ^ (2 : ℕ) →
      (Nat.totient m : ℝ) ≤ (Real.log N) ^ ((1 : ℝ) / 8 - δ) →
        uniformNumeratorDenominator B₂ m * pomeranceWeingartnerExponent m N ≤
          (Real.log N) ^ ((3 : ℝ) / 4)

/-- Algebraic heart of `cor:PW-comparison`.

Once the standard subpower estimate for the totient ratio gives
`(m/phi(m))^B <= (log N)^(delta/3)`, the displayed small-totient condition
implies the product inequality carried by `PWComparisonInputs`. -/
theorem pomeranceWeingartner_product_bound_of_totient_ratio_subpower
    {B δ : ℝ} {m N : ℕ}
    (hδ : 0 < δ) (hN : 3 ≤ N) (hm : 4 ≤ m)
    (hphi : (Nat.totient m : ℝ) ≤
      (Real.log N) ^ ((1 : ℝ) / 8 - δ))
    (hratio : ((m : ℝ) / (Nat.totient m : ℝ)) ^ B ≤
      (Real.log N) ^ (δ / 3)) :
    uniformNumeratorDenominator B m * pomeranceWeingartnerExponent m N ≤
      (Real.log N) ^ ((3 : ℝ) / 4) := by
  set L : ℝ := Real.log N with hLdef
  set phi : ℝ := (Nat.totient m : ℝ) with hphidef
  have hmpos_nat : 0 < m := by omega
  have hphi_pos_nat : 0 < Nat.totient m := Nat.totient_pos.mpr hmpos_nat
  have hphi_pos : 0 < phi := by
    rw [hphidef]
    exact_mod_cast hphi_pos_nat
  have hphi_nonneg : 0 ≤ phi := hphi_pos.le
  have hLpos : 0 < L := by
    rw [hLdef]
    exact log_pos_of_three_le hN
  have hL_nonneg : 0 ≤ L := hLpos.le
  have hLone : 1 ≤ L := by
    rw [hLdef]
    have hN_ge_exp : Real.exp 1 ≤ (N : ℝ) := by
      have hN3 : (3 : ℝ) ≤ (N : ℝ) := by exact_mod_cast hN
      have hexp3 : Real.exp 1 ≤ (3 : ℝ) := by
        exact le_of_lt (Real.exp_one_lt_d9.trans (by norm_num))
      exact le_trans hexp3 hN3
    have hNpos : 0 < (N : ℝ) := lt_of_lt_of_le (Real.exp_pos 1) hN_ge_exp
    rw [Real.le_log_iff_exp_le hNpos]
    exact hN_ge_exp
  have hphi' : phi ≤ L ^ ((1 : ℝ) / 8 - δ) := by
    simpa [hLdef, hphidef] using hphi
  have hphi23 :
      phi ^ ((2 : ℝ) / 3) ≤
        (L ^ ((1 : ℝ) / 8 - δ)) ^ ((2 : ℝ) / 3) :=
    Real.rpow_le_rpow hphi_nonneg hphi' (by norm_num)
  have hphi23' :
      phi ^ ((2 : ℝ) / 3) ≤
        L ^ (((1 : ℝ) / 8 - δ) * ((2 : ℝ) / 3)) := by
    convert hphi23 using 1
    exact Real.rpow_mul hL_nonneg ((1 : ℝ) / 8 - δ) ((2 : ℝ) / 3)
  have hshape :
      uniformNumeratorDenominator B m * pomeranceWeingartnerExponent m N =
        ((m : ℝ) / phi) ^ B * L ^ ((2 : ℝ) / 3) * phi ^ ((2 : ℝ) / 3) := by
    have hLsq :
        ((L ^ (2 : ℕ)) / phi) ^ ((1 : ℝ) / 3) =
          L ^ ((2 : ℝ) / 3) / phi ^ ((1 : ℝ) / 3) := by
      rw [Real.div_rpow (pow_nonneg hL_nonneg 2) hphi_nonneg]
      have htwo : (L ^ (2 : ℕ)) ^ ((1 : ℝ) / 3) = L ^ ((2 : ℝ) / 3) := by
        rw [← Real.rpow_natCast, ← Real.rpow_mul hL_nonneg]
        ring_nf
      rw [htwo]
    have hphi_split : phi = phi ^ ((1 : ℝ) / 3) * phi ^ ((2 : ℝ) / 3) := by
      have h := Real.rpow_add hphi_pos ((1 : ℝ) / 3) ((2 : ℝ) / 3)
      have hone : phi ^ (((1 : ℝ) / 3) + ((2 : ℝ) / 3)) = phi := by
        rw [show ((1 : ℝ) / 3) + ((2 : ℝ) / 3) = 1 by norm_num]
        exact Real.rpow_one phi
      exact hone.symm.trans h
    have hphi_div :
        phi / phi ^ ((1 : ℝ) / 3) = phi ^ ((2 : ℝ) / 3) := by
      calc
        phi / phi ^ ((1 : ℝ) / 3)
            = (phi ^ ((1 : ℝ) / 3) * phi ^ ((2 : ℝ) / 3)) /
                phi ^ ((1 : ℝ) / 3) := by
              nth_rw 1 [hphi_split]
        _ = phi ^ ((2 : ℝ) / 3) := by
              field_simp [ne_of_gt (Real.rpow_pos_of_pos hphi_pos ((1 : ℝ) / 3))]
    unfold uniformNumeratorDenominator pomeranceWeingartnerExponent
    rw [← hLdef, ← hphidef]
    rw [hLsq]
    calc
      (phi * (↑m / phi) ^ B) * (L ^ ((2 : ℝ) / 3) / phi ^ ((1 : ℝ) / 3))
          = (↑m / phi) ^ B * L ^ ((2 : ℝ) / 3) *
              (phi / phi ^ ((1 : ℝ) / 3)) := by
            field_simp [ne_of_gt (Real.rpow_pos_of_pos hphi_pos ((1 : ℝ) / 3))]
            ring
      _ = (↑m / phi) ^ B * L ^ ((2 : ℝ) / 3) * phi ^ ((2 : ℝ) / 3) := by
            rw [hphi_div]
  have hmul1 :
      ((m : ℝ) / phi) ^ B * L ^ ((2 : ℝ) / 3) * phi ^ ((2 : ℝ) / 3) ≤
        L ^ (δ / 3) * L ^ ((2 : ℝ) / 3) *
          L ^ (((1 : ℝ) / 8 - δ) * ((2 : ℝ) / 3)) := by
    have hratio' : ((m : ℝ) / phi) ^ B ≤ L ^ (δ / 3) := by
      simpa [hLdef, hphidef] using hratio
    have hL23_nonneg : 0 ≤ L ^ ((2 : ℝ) / 3) := (Real.rpow_pos_of_pos hLpos _).le
    have hleft_nonneg : 0 ≤ L ^ (δ / 3) * L ^ ((2 : ℝ) / 3) :=
      mul_nonneg (Real.rpow_pos_of_pos hLpos _).le hL23_nonneg
    exact mul_le_mul
      (mul_le_mul hratio' (le_rfl : L ^ ((2 : ℝ) / 3) ≤ L ^ ((2 : ℝ) / 3))
        hL23_nonneg (Real.rpow_pos_of_pos hLpos _).le)
      hphi23'
      (Real.rpow_pos_of_pos hphi_pos _).le hleft_nonneg
  have hpoweq :
      L ^ (δ / 3) * L ^ ((2 : ℝ) / 3) *
          L ^ (((1 : ℝ) / 8 - δ) * ((2 : ℝ) / 3))
        = L ^ ((3 : ℝ) / 4 - δ / 3) := by
    rw [← Real.rpow_add hLpos, ← Real.rpow_add hLpos]
    ring_nf
  have hfinalpow :
      L ^ ((3 : ℝ) / 4 - δ / 3) ≤ L ^ ((3 : ℝ) / 4) :=
    Real.rpow_le_rpow_of_exponent_le hLone (by linarith)
  rw [hshape]
  calc
    ((m : ℝ) / phi) ^ B * L ^ ((2 : ℝ) / 3) * phi ^ ((2 : ℝ) / 3)
        ≤ L ^ (δ / 3) * L ^ ((2 : ℝ) / 3) *
            L ^ (((1 : ℝ) / 8 - δ) * ((2 : ℝ) / 3)) := hmul1
    _ = L ^ ((3 : ℝ) / 4 - δ / 3) := hpoweq
    _ ≤ L ^ ((3 : ℝ) / 4) := hfinalpow

/-- Standard arithmetic input for the Pomerance-Weingartner comparison:
on the logarithmic numerator range, the totient-ratio loss is subpower in
`log N`.

This is the formal replacement for the manuscript's use of
`m/phi(m) << log log(3m)` in `cor:PW-comparison`.  It is intentionally narrower
than `PWComparisonInputs`: the theorem below proves the remaining exponent
algebra from this subpower statement. -/
structure PWComparisonTotientRatioSubpowerInputs where
  B₂ : ℝ
  B₂_pos : 0 < B₂
  ratio_subpower : ∀ δ : ℝ, 0 < δ →
    ∃ N₀ : ℕ, ∀ N m : ℕ, N₀ ≤ N → 4 ≤ m →
      (m : ℝ) ≤ (Real.log N) ^ (2 : ℕ) →
      (Nat.totient m : ℝ) ≤ (Real.log N) ^ ((1 : ℝ) / 8 - δ) →
        ((m : ℝ) / (Nat.totient m : ℝ)) ^ B₂ ≤ (Real.log N) ^ (δ / 3)

/-- Divisor monotonicity bridge used in the totient-ratio comparison:
`tau(m) <= tau(m^2)` for positive `m`. -/
theorem tau_le_tau_square_of_pos {m : ℕ} (hm : 0 < m) :
    Inputs.tau m ≤ Inputs.tau (m ^ 2) := by
  unfold Inputs.tau
  have hsubset : m.divisors ⊆ (m ^ 2).divisors := by
    exact Nat.divisors_subset_of_dvd (pow_ne_zero 2 hm.ne')
      (by simp [pow_two])
  exact Finset.card_le_card hsubset

/-- A standard `tau(m^2) <<_eps m^eps` estimate implies subpower control of
the totient-ratio loss after raising to any fixed positive power. -/
theorem totient_ratio_rpow_le_const_mul_rpow_of_tauSquareSubpower
    (htau : Inputs.TauSquareSubpowerBound)
    {B η : ℝ} (hB : 0 < B) (hη : 0 < η) :
    ∃ K > (0 : ℝ), ∀ m : ℕ, 1 ≤ m →
      ((m : ℝ) / (Nat.totient m : ℝ)) ^ B ≤ K * (m : ℝ) ^ η := by
  have hηdiv : 0 < η / B := div_pos hη hB
  rcases htau (η / B) hηdiv with ⟨K₀, hK₀, hK₀bound⟩
  refine ⟨K₀ ^ B, Real.rpow_pos_of_pos hK₀ B, ?_⟩
  intro m hm
  have hmpos : 0 < m := lt_of_lt_of_le Nat.zero_lt_one hm
  have hmreal_nonneg : 0 ≤ (m : ℝ) := Nat.cast_nonneg m
  have hratio_nonneg :
      0 ≤ (m : ℝ) / (Nat.totient m : ℝ) := by
    have hphi_pos_nat : 0 < Nat.totient m := Nat.totient_pos.mpr hmpos
    exact div_nonneg hmreal_nonneg (by exact_mod_cast hphi_pos_nat.le)
  have hratio_tau :
      (m : ℝ) / (Nat.totient m : ℝ) ≤ (Inputs.tau (m ^ 2) : ℝ) := by
    have h₁ := Inputs.div_totient_le_tau m hmpos
    have h₂ : (Inputs.tau m : ℝ) ≤ (Inputs.tau (m ^ 2) : ℝ) := by
      exact_mod_cast tau_le_tau_square_of_pos (m := m) hmpos
    exact h₁.trans h₂
  have htau_bound :
      (Inputs.tau (m ^ 2) : ℝ) ≤ K₀ * (m : ℝ) ^ (η / B) :=
    hK₀bound m hm
  have hratio_bound :
      (m : ℝ) / (Nat.totient m : ℝ) ≤ K₀ * (m : ℝ) ^ (η / B) :=
    hratio_tau.trans htau_bound
  have hbase_nonneg : 0 ≤ K₀ * (m : ℝ) ^ (η / B) :=
    mul_nonneg hK₀.le (Real.rpow_nonneg hmreal_nonneg _)
  calc
    ((m : ℝ) / (Nat.totient m : ℝ)) ^ B
        ≤ (K₀ * (m : ℝ) ^ (η / B)) ^ B :=
          Real.rpow_le_rpow hratio_nonneg hratio_bound hB.le
    _ = K₀ ^ B * ((m : ℝ) ^ (η / B)) ^ B := by
          rw [Real.mul_rpow hK₀.le (Real.rpow_nonneg hmreal_nonneg _)]
    _ = K₀ ^ B * (m : ℝ) ^ η := by
          rw [← Real.rpow_mul hmreal_nonneg]
          field_simp [ne_of_gt hB]

/-- Construct the totient-ratio subpower package used by `cor:PW-comparison`
from the standard divisor subpower estimate `tau(m^2) <<_eps m^eps`. -/
noncomputable def PWComparisonTotientRatioSubpowerInputs.of_tauSquareSubpower
    (B₂ : ℝ) (hB₂ : 0 < B₂)
    (htau : Inputs.TauSquareSubpowerBound) :
    PWComparisonTotientRatioSubpowerInputs where
  B₂ := B₂
  B₂_pos := hB₂
  ratio_subpower := by
    intro δ hδ
    have hη : 0 < δ / 12 := by positivity
    rcases totient_ratio_rpow_le_const_mul_rpow_of_tauSquareSubpower
        htau hB₂ hη with ⟨K, hKpos, hKbound⟩
    have hδ6 : 0 < δ / 6 := by positivity
    have hlogpow_nat :
        Filter.Tendsto (fun N : ℕ => (Real.log (N : ℝ)) ^ (δ / 6))
          Filter.atTop Filter.atTop :=
      (tendsto_rpow_atTop hδ6).comp
        (Real.tendsto_log_atTop.comp tendsto_natCast_atTop_atTop)
    have hKevent :
        ∀ᶠ N : ℕ in Filter.atTop,
          K ≤ (Real.log (N : ℝ)) ^ (δ / 6) :=
      hlogpow_nat.eventually (Filter.eventually_ge_atTop K)
    rcases Filter.eventually_atTop.mp hKevent with ⟨N₁, hN₁⟩
    refine ⟨max N₁ 3, ?_⟩
    intro N m hN hm hm_log _hphi
    have hN₁' : N₁ ≤ N := le_trans (Nat.le_max_left N₁ 3) hN
    have hN3 : 3 ≤ N := le_trans (Nat.le_max_right N₁ 3) hN
    set L : ℝ := Real.log (N : ℝ) with hLdef
    have hLpos : 0 < L := by
      rw [hLdef]
      exact log_pos_of_three_le hN3
    have hL_nonneg : 0 ≤ L := hLpos.le
    have hm_ge_one : 1 ≤ m := by omega
    have hratio_poly :
        ((m : ℝ) / (Nat.totient m : ℝ)) ^ B₂ ≤ K * (m : ℝ) ^ (δ / 12) :=
      hKbound m hm_ge_one
    have hm_pow :
        (m : ℝ) ^ (δ / 12) ≤ L ^ (δ / 6) := by
      calc
        (m : ℝ) ^ (δ / 12)
            ≤ (L ^ (2 : ℕ)) ^ (δ / 12) :=
              Real.rpow_le_rpow (Nat.cast_nonneg m)
                (by simpa [hLdef] using hm_log) hη.le
        _ = L ^ (δ / 6) := by
              rw [← Real.rpow_natCast, ← Real.rpow_mul hL_nonneg]
              ring_nf
    have hK_le : K ≤ L ^ (δ / 6) := by
      simpa [hLdef] using hN₁ N hN₁'
    have hright_nonneg : 0 ≤ L ^ (δ / 6) :=
      (Real.rpow_pos_of_pos hLpos _).le
    calc
      ((m : ℝ) / (Nat.totient m : ℝ)) ^ B₂
          ≤ K * (m : ℝ) ^ (δ / 12) := hratio_poly
      _ ≤ L ^ (δ / 6) * L ^ (δ / 6) :=
          mul_le_mul hK_le hm_pow
            (Real.rpow_nonneg (Nat.cast_nonneg m) _) hright_nonneg
      _ = L ^ (δ / 3) := by
          rw [← Real.rpow_add hLpos]
          ring_nf

/-- Construct the totient-ratio subpower package with the divisor-subpower
estimate discharged by the checked elementary proof in `Inputs`. -/
noncomputable def PWComparisonTotientRatioSubpowerInputs.unconditional
    (B₂ : ℝ) (hB₂ : 0 < B₂) :
    PWComparisonTotientRatioSubpowerInputs :=
  PWComparisonTotientRatioSubpowerInputs.of_tauSquareSubpower
    B₂ hB₂ Inputs.tauSquareSubpowerBound_unconditional

/-- Build the paper-facing `PWComparisonInputs` from the standard totient-ratio
subpower estimate, discharging the product-bound algebra internally. -/
noncomputable def PWComparisonInputs.of_totientRatioSubpower
    (H : PWComparisonTotientRatioSubpowerInputs) :
    PWComparisonInputs where
  B₂ := H.B₂
  B₂_pos := H.B₂_pos
  product_bound := by
    intro δ hδ
    rcases H.ratio_subpower δ hδ with ⟨N₁, hratio⟩
    refine ⟨max N₁ 3, ?_⟩
    intro N m hN hm hm_log hphi
    have hN₁ : N₁ ≤ N := le_trans (Nat.le_max_left N₁ 3) hN
    have hN3 : 3 ≤ N := le_trans (Nat.le_max_right N₁ 3) hN
    exact
      pomeranceWeingartner_product_bound_of_totient_ratio_subpower
        (B := H.B₂) (δ := δ) hδ hN3 hm hphi
        (hratio N m hN₁ hm hm_log hphi)

/-- Checked constructor for the Pomerance-Weingartner comparison package:
the only arithmetic growth estimate needed for the totient ratio is now
provided by `Inputs.tauSquareSubpowerBound_unconditional`. -/
noncomputable def PWComparisonInputs.of_checked_tauSquareSubpower
    (B₂ : ℝ) (hB₂ : 0 < B₂) : PWComparisonInputs :=
  PWComparisonInputs.of_totientRatioSubpower
    (PWComparisonTotientRatioSubpowerInputs.unconditional B₂ hB₂)

/-- Conditional comparison form. Given the arithmetic
comparison package for `m / phi(m)`, the uniform-saturation exponent is
eventually at least as large as the Pomerance-Weingartner/Vaughan-type exponent
throughout the paper's displayed growing numerator range. -/
theorem cor_PW_comparison_of_inputs (H : PWComparisonInputs) :
    ∃ B₂ > (0 : ℝ), ∀ δ : ℝ, 0 < δ →
      ∃ N₀ : ℕ, ∀ N m : ℕ, N₀ ≤ N → 4 ≤ m →
        (m : ℝ) ≤ (Real.log N) ^ (2 : ℕ) →
        (Nat.totient m : ℝ) ≤ (Real.log N) ^ ((1 : ℝ) / 8 - δ) →
          pomeranceWeingartnerExponent m N ≤ uniformNumeratorExponent B₂ m N :=
by
  refine ⟨H.B₂, H.B₂_pos, ?_⟩
  intro δ hδ
  rcases H.product_bound δ hδ with ⟨N₀, hprod⟩
  refine ⟨N₀, ?_⟩
  intro N m hN hm hm_log hphi
  exact pomeranceWeingartnerExponent_le_uniformNumeratorExponent_of_product_le
    (B := H.B₂) (by omega : 0 < m) (hprod N m hN hm hm_log hphi)

/-- **`cor:PW-comparison` (checked Lean form).** The former divisor-subpower
hypothesis is discharged by the elementary theorem `τ(a²) ≪_η a^η`, so this
paper-facing comparison no longer takes an arithmetic comparison package. -/
theorem cor_PW_comparison
    (B₂ : ℝ) (hB₂ : 0 < B₂) :
    ∃ B₂ > (0 : ℝ), ∀ δ : ℝ, 0 < δ →
      ∃ N₀ : ℕ, ∀ N m : ℕ, N₀ ≤ N → 4 ≤ m →
        (m : ℝ) ≤ (Real.log N) ^ (2 : ℕ) →
        (Nat.totient m : ℝ) ≤ (Real.log N) ^ ((1 : ℝ) / 8 - δ) →
          pomeranceWeingartnerExponent m N ≤ uniformNumeratorExponent B₂ m N :=
  cor_PW_comparison_of_inputs (PWComparisonInputs.of_checked_tauSquareSubpower B₂ hB₂)

@[deprecated cor_PW_comparison (since := "2026-06-26")]
theorem cor_PW_comparison_checked_tauSquareSubpower
    (B₂ : ℝ) (hB₂ : 0 < B₂) :
    ∃ B₂ > (0 : ℝ), ∀ δ : ℝ, 0 < δ →
      ∃ N₀ : ℕ, ∀ N m : ℕ, N₀ ≤ N → 4 ≤ m →
        (m : ℝ) ≤ (Real.log N) ^ (2 : ℕ) →
        (Nat.totient m : ℝ) ≤ (Real.log N) ^ ((1 : ℝ) / 8 - δ) →
          pomeranceWeingartnerExponent m N ≤ uniformNumeratorExponent B₂ m N :=
  cor_PW_comparison B₂ hB₂

/-! ## Abstract main theorem and immediate corollaries -/

/-- **`thm:main` (conditional form).** The manuscript main theorem
`E(N) ≪ N·exp(-c(log N)^{3/4})`, given the bundled intermediate inputs. -/
theorem thm_main (H : MainInputs) : IsMainBound exceptionalCount :=
  erdos_straus_main H

/-- Density-zero consequence of the conditional main theorem. -/
theorem thm_main_density_zero (H : MainInputs) :
    Filter.Tendsto (fun N : ℕ => (exceptionalCount N : ℝ) / (N : ℝ))
      Filter.atTop (nhds 0) :=
  (thm_main H).density_tendsto_zero

/-- Geometric form of the exceptional-set theorem on the same `2 ≤ n ≤ N`
carrier as `thm:main`: outside a set with the main exponential saving, the
surface `U_n` has a positive integral point in the formal fan-curve sense. -/
theorem cor_geometric_main (H : MainInputs) : IsMainBound geometricExceptionalCount :=
  geometric_exceptional_of_main (erdos_straus_main H)

/-- Density-zero consequence of the geometric form. -/
theorem cor_geometric_main_density_zero (H : MainInputs) :
    Filter.Tendsto (fun N : ℕ => (geometricExceptionalCount N : ℝ) / (N : ℝ))
      Filter.atTop (nhds 0) :=
  (cor_geometric_main H).density_tendsto_zero

/-- Bundled geometric and growing-numerator endpoint surface.

This capstone packages the geometric main theorem, its density-zero consequence,
the logarithmic uniform-numerator theorem, the Pomerance-Weingartner comparison,
and the two EH-conditional endpoint templates.  The fixed-logarithmic
uniform-numerator component is now derived from the same EH carrier used for
`thm:EH-uniform-m`, so this bundled endpoint no longer carries a separate
uniform-saturation package. -/
theorem geometric_uniform_paper_outputs
    (Hmain : MainInputs)
    (Hpw : PWComparisonInputs)
    (Heh : EHUniformNumeratorInputs)
    (Hquartic : QuarticEHFanInputs) :
    IsMainBound geometricExceptionalCount ∧
      Filter.Tendsto (fun N : ℕ => (geometricExceptionalCount N : ℝ) / (N : ℝ))
        Filter.atTop (nhds 0) ∧
      (∀ A : ℝ, 0 < A →
        ∃ c > (0 : ℝ), ∃ C > (0 : ℝ), ∃ B > (0 : ℝ),
          ∀ N m : ℕ, 3 ≤ N → 2 ≤ m → (m : ℝ) ≤ (Real.log N) ^ A →
            (fixedNumeratorExceptionalCount m N : ℝ) ≤
              C * (N : ℝ) * uniformNumeratorSaving c B m N) ∧
      (∃ B₂ > (0 : ℝ), ∀ δ : ℝ, 0 < δ →
        ∃ N₀ : ℕ, ∀ N m : ℕ, N₀ ≤ N → 4 ≤ m →
          (m : ℝ) ≤ (Real.log N) ^ (2 : ℕ) →
          (Nat.totient m : ℝ) ≤ (Real.log N) ^ ((1 : ℝ) / 8 - δ) →
            pomeranceWeingartnerExponent m N ≤ uniformNumeratorExponent B₂ m N) ∧
      ((∃ κ > (0 : ℝ), ∃ c > (0 : ℝ), ∃ C > (0 : ℝ), ∃ B > (0 : ℝ),
        (∀ N m : ℕ, 3 ≤ N → 2 ≤ m →
          (m : ℝ) ≤ Real.exp (κ * (Real.log N) ^ ((1 : ℝ) / 4)) →
            (fixedNumeratorExceptionalCount m N : ℝ) ≤
              C * (N : ℝ) * uniformNumeratorSaving c B m N) ∧
        (∀ η : ℝ, 0 < η →
          ∃ cη > (0 : ℝ), ∃ Cη > (0 : ℝ), ∀ N m : ℕ, 3 ≤ N → 2 ≤ m →
            (m : ℝ) ≤ Real.exp (κ * (Real.log N) ^ ((1 : ℝ) / 4)) →
            uniformNumeratorDenominator B m ≤ (Real.log N) ^ ((3 : ℝ) / 4 - η) →
              (fixedNumeratorExceptionalCount m N : ℝ) ≤
                Cη * (N : ℝ) * logPowerSaving cη η N)) ∧
      (∃ c₄ > (0 : ℝ), ∃ C₄ > (0 : ℝ), ∀ N : ℕ, 3 ≤ N →
        (exceptionalCount N : ℝ) ≤ C₄ * (N : ℝ) * quarticSaving c₄ N)) := by
  exact ⟨cor_geometric_main Hmain, cor_geometric_main_density_zero Hmain,
    thm_uniform_m (uniformNumeratorSaturationInputs_of_EHUniformNumeratorInputs Heh),
    cor_PW_comparison_of_inputs Hpw, thm_EH_uniform_m Heh,
    thm_EH_quartic Hquartic⟩

/-- Bundled geometric endpoint with the Pomerance-Weingartner comparison

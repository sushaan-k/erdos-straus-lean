/-- The concrete Euler rough-range inequality is automatic for the exact
reduced summatory carrier.

This discharges the manuscript's rough-large lifting comparison from the
finite fibering lemma `roughLargeCount_le_sum_reduced` and the elementary
product lower bound `1 ≤ eulerProductFactorAtNat N`. -/
theorem rough_range_bound_of_reduced_sum (z : ℕ → ℕ) :
    ∀ N : ℕ, 3 ≤ N →
      (roughLargeCount (z N) N : ℝ) ≤
        eulerProductFactorAtNat N * (reducedSumCountFor z N : ℝ) := by
  intro N _hN
  have hrough_sum :
      (roughLargeCount (z N) N : ℝ) ≤ (reducedSumCountFor z N : ℝ) := by
    exact_mod_cast roughLargeCount_le_sum_reduced (z N) N
  have hsum_le :
      (reducedSumCountFor z N : ℝ) ≤
        eulerProductFactorAtNat N * (reducedSumCountFor z N : ℝ) := by
    calc
      (reducedSumCountFor z N : ℝ) = 1 * (reducedSumCountFor z N : ℝ) := by ring
      _ ≤ eulerProductFactorAtNat N * (reducedSumCountFor z N : ℝ) :=
        mul_le_mul_of_nonneg_right
          (eulerProductFactorAtNat_one_le N) (Nat.cast_nonneg _)
  exact le_trans hrough_sum hsum_le

/-- Exact reduced summatory saving from sigma-indexed Suen finite-transfer data.

This factors out the remaining reduced-saving handoff used by the paper-facing
main route.  The exact reduced carrier is first dominated by the sigma-indexed
finite class mass using `reducedSumCountFor_le_sigma_class_majorants`; the
large-range Suen finite-transfer estimate and the finite initial certificate
then give the global `N * saving c N` bound. -/
theorem reducedSumCountFor_saving_of_suen_elemSymm_sigma_class_majorants
    {κ : Type*} [DecidableEq κ]
    (clsRed : ℕ → ℕ → Finset κ)
    (classOfRed : ℕ → ℕ → ℕ → κ)
    (Mred : ℕ → ℕ → κ → ℝ)
    (Pz μ εb : ℕ → ℝ)
    (δb Δb errTerm F2R : ℕ → (Σ _s : ℕ, κ) → ℝ)
    (weights : ℕ → (Σ _s : ℕ, κ) → List ℚ)
    (M Xq : ℕ → (Σ _s : ℕ, κ) → ℚ)
    (R : ℕ → (Σ _s : ℕ, κ) → ℕ)
    (εK c Cinit : ℝ) (T : ℕ)
    (hc : 0 < c) (hCinit : 0 < Cinit)
    (hred_class_mem : ∀ N : ℕ, 3 ≤ N → ∀ s ∈ Finset.Icc 1 N,
      ∀ r ∈ ((Finset.Icc 1 (N / s)).filter
        (fun r => IsRough (zNatScale N) r ∧ EscLeanChecks.esExceptional r)),
          classOfRed N s r ∈ clsRed N s)
    (hred_class_bound : ∀ N : ℕ, 3 ≤ N → ∀ s ∈ Finset.Icc 1 N,
      ∀ b ∈ clsRed N s,
        ((((Finset.Icc 1 (N / s)).filter
          (fun r => (IsRough (zNatScale N) r ∧ EscLeanChecks.esExceptional r) ∧
            classOfRed N s r = b)).card : ℕ) : ℝ) ≤ Mred N s b)
    (hweights_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      ∀ b ∈ (Finset.Icc 1 N).sigma (fun s => clsRed N s),
        ∀ w, w ∈ weights N b → 0 ≤ w)
    (hmass : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      ∀ b ∈ (Finset.Icc 1 N).sigma (fun s => clsRed N s),
        (weights N b).sum ≤ M N b)
    (hMle : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      ∀ b ∈ (Finset.Icc 1 N).sigma (fun s => clsRed N s),
        (M N b : ℝ) ≤ (1 + εK) * μ N)
    (hXq : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      ∀ b ∈ (Finset.Icc 1 N).sigma (fun s => clsRed N s), 1 ≤ Xq N b)
    (hμ : ∀ N : ℕ, 3 ≤ N → T ≤ N → 0 < μ N)
    (hPz : ∀ N : ℕ, 3 ≤ N → T ≤ N → 1 ≤ Pz N)
    (hδ_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      ∀ b ∈ (Finset.Icc 1 N).sigma (fun s => clsRed N s), 0 ≤ δb N b)
    (hΔ_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      ∀ b ∈ (Finset.Icc 1 N).sigma (fun s => clsRed N s), 0 ≤ Δb N b)
    (hsuen_tail : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      ∀ b ∈ (Finset.Icc 1 N).sigma (fun s => clsRed N s),
        Inputs.suenTailConstant * Δb N b * Real.exp (2 * δb N b) ≤ εb N * μ N)
    (hdecomp : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      ∀ b ∈ (Finset.Icc 1 N).sigma (fun s => clsRed N s),
        Mred N b.1 b.2 ≤ ((N : ℝ) / Pz N) *
          (Inputs.suenProb (μ N) (δb N b) (Δb N b) + F2R N b) + errTerm N b)
    (herr_raw : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      ∀ b ∈ (Finset.Icc 1 N).sigma (fun s => clsRed N s),
        errTerm N b ≤
          ∑ r ∈ Finset.range (2 * R N b + 1),
            (Xq N b : ℝ) ^ r * (EscLeanChecks.elemSymmList (weights N b) r : ℝ))
    (hεle : εK ≤ 1)
    (hlevel : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      ∀ b ∈ (Finset.Icc 1 N).sigma (fun s => clsRed N s),
        Pz N * ((Xq N b : ℝ) ^ (2 * R N b)) * Real.exp (2 * μ N)
          ≤ (N : ℝ) * Real.exp (-4 * μ N))
    (hF2R_raw : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      ∀ b ∈ (Finset.Icc 1 N).sigma (fun s => clsRed N s),
        F2R N b ≤ (EscLeanChecks.elemSymmList (weights N b) (2 * R N b) : ℝ))
    (hF2R_tail : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      ∀ b ∈ (Finset.Icc 1 N).sigma (fun s => clsRed N s),
        ((M N b : ℝ) ^ (2 * R N b)) / (Nat.factorial (2 * R N b) : ℝ)
          ≤ Real.exp (-3 * μ N))
    (hcard : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      (((Finset.Icc 1 N).sigma (fun s => clsRed N s)).card : ℝ) ≤ Pz N)
    (hsaving : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      c * (Real.log N) ^ ((3 : ℝ) / 4) ≤
        (1 - (εb N + Real.log 3 / μ N)) * μ N)
    (hinitial : ∀ N : ℕ, 3 ≤ N → N < T →
      (reducedSumCountFor zNatScale N : ℝ) ≤ Cinit * ((N : ℝ) * saving c N)) :
    ∃ C : ℝ, 0 < C ∧ ∀ N : ℕ, 3 ≤ N →
      (reducedSumCountFor zNatScale N : ℝ) ≤ C * ((N : ℝ) * saving c N) :=
  Ered_bound_global_of_large_suen_elemSymm_finite_transfer_ingredients_and_initial_standard_tail
    (fun N => (Finset.Icc 1 N).sigma (fun s => clsRed N s))
    (fun N b => Mred N b.1 b.2)
    (fun N => reducedSumCountFor zNatScale N)
    Pz μ εb δb Δb errTerm F2R weights M Xq R εK c Cinit T hc hCinit
    (reducedSumCountFor_le_sigma_class_majorants
      clsRed classOfRed Mred hred_class_mem hred_class_bound)
    hweights_nonneg hmass hMle hXq hμ hPz hδ_nonneg hΔ_nonneg
    hsuen_tail hdecomp herr_raw hεle hlevel hF2R_raw hF2R_tail hcard
    hsaving hinitial


/-- Standalone finite-product lower control plus standalone exact-error control
prove the original count-level rough-sieve formulation.  The finite-product
upper half is unconditional. -/
theorem linear_sieve_rough_dyadic_count_bound_of_productLower_and_error
    {a₀ b₀ C₀ c E Xprod Xerr : ℝ}
    (hc : 0 < c) (hE_lt : E < c)
    (hprod : ∀ X : ℝ, Xprod ≤ X →
      c / Real.log (EscAnalytic.zScale X) ≤
        roughDyadicBadPrimeMainEulerProduct X)
    (herr : roughDyadicBadPrimeProductErrorBound a₀ b₀ C₀ E Xerr) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        c * (t / Real.log (EscAnalytic.zScale X)) ≤ roughDyadicCount X M t
          ∧ roughDyadicCount X M t
              ≤ C * (t / Real.log (EscAnalytic.zScale X)) :=
  linear_sieve_rough_dyadic_count_bound_of_lowerEulerProductError
    (roughDyadicBadPrimeLowerEulerProductErrorBound_of_productLower_and_error
      hc hE_lt hprod herr)

/-- Product-lower control plus one-sided lower and upper signed-error controls
prove the original count-level rough-sieve formulation.  This separates the
two halves of the finite error that the proof actually uses. -/
theorem linear_sieve_rough_dyadic_count_bound_of_productLower_and_errorLower_errorUpper
    {a₀ b₀ C₀ c Elower Eupper Xprod Xlower Xupper : ℝ}
    (hc : 0 < c) (hE_lt : Elower < c)
    (hprod : ∀ X : ℝ, Xprod ≤ X →
      c / Real.log (EscAnalytic.zScale X) ≤
        roughDyadicBadPrimeMainEulerProduct X)
    (hlower :
      roughDyadicBadPrimeProductErrorLowerBound a₀ b₀ C₀ Elower Xlower)
    (hupper :
      roughDyadicBadPrimeProductErrorUpperBound a₀ b₀ C₀ Eupper Xupper) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        c * (t / Real.log (EscAnalytic.zScale X)) ≤ roughDyadicCount X M t
          ∧ roughDyadicCount X M t
              ≤ C * (t / Real.log (EscAnalytic.zScale X)) :=
  (linear_sieve_rough_dyadic_count_bound_iff_count_lower_upper a₀ b₀ C₀).mpr
    ⟨roughDyadicCountLowerBound_of_productLower_and_errorLower
        hc hE_lt hprod hlower,
      roughDyadicCountUpperBound_of_productErrorUpper hupper⟩

/-- The packaged one-sided Euler-product/error formulation proves the original
count-level rough-sieve formulation. -/
theorem linear_sieve_rough_dyadic_count_bound_of_oneSidedEulerProductError
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicBadPrimeOneSidedEulerProductErrorBound a₀ b₀ C₀) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        c * (t / Real.log (EscAnalytic.zScale X)) ≤ roughDyadicCount X M t
          ∧ roughDyadicCount X M t
              ≤ C * (t / Real.log (EscAnalytic.zScale X)) := by
  rcases h with
    ⟨c, Elower, Eupper, Xprod, Xlower, Xupper, hc, _hElower_nonneg,
      hE_lt, _hEupper_nonneg, hprod, hlower, hupper⟩
  exact
    linear_sieve_rough_dyadic_count_bound_of_productLower_and_errorLower_errorUpper
      hc hE_lt hprod hlower hupper

/-- A completely separated finite-product/error formulation proves the original
count-level rough-sieve formulation. -/
theorem linear_sieve_rough_dyadic_count_bound_of_separatedEulerProductError
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicBadPrimeSeparatedEulerProductErrorBound a₀ b₀ C₀) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        c * (t / Real.log (EscAnalytic.zScale X)) ≤ roughDyadicCount X M t
          ∧ roughDyadicCount X M t
              ≤ C * (t / Real.log (EscAnalytic.zScale X)) :=
  linear_sieve_rough_dyadic_count_bound_of_splitEulerProductError
    (roughDyadicBadPrimeSplitEulerProductErrorBound_of_separated h)

/-- Diagnostic implication from the overstrong quotient-envelope estimate to the
named upper half of the product-modulus rough-sieve target. -/
theorem roughDyadicBadPrimeProductCountUpperBound_of_envelope
    {a₀ b₀ C₀ : ℝ}
    (hEnv : roughDyadicBadPrimeProductEnvelopeUpperBound a₀ b₀ C₀) :
    roughDyadicBadPrimeProductCountUpperBound a₀ b₀ C₀ :=
  roughDyadicBadPrimeProductCount_upper_of_envelope hEnv

/-- Diagnostic route: lower finite-product/error control plus the overstrong
quotient-envelope upper bound proves the original count-level rough-sieve
formulation.  The envelope premise is not a realistic unconditional target; it
contains the empty-subset term at ambient scale. -/
theorem linear_sieve_rough_dyadic_count_bound_of_lowerEulerProductError_and_envelope
    {a₀ b₀ C₀ : ℝ}
    (hLower : roughDyadicBadPrimeLowerEulerProductErrorBound a₀ b₀ C₀)
    (hEnv : roughDyadicBadPrimeProductEnvelopeUpperBound a₀ b₀ C₀) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        c * (t / Real.log (EscAnalytic.zScale X)) ≤ roughDyadicCount X M t
          ∧ roughDyadicCount X M t
              ≤ C * (t / Real.log (EscAnalytic.zScale X)) :=
  (linear_sieve_rough_dyadic_count_bound_iff_badPrimeProductCount_lower_upper
    a₀ b₀ C₀).mpr
      ⟨roughDyadicBadPrimeProductCountLowerBound_of_lowerEulerProductError hLower,
        roughDyadicBadPrimeProductCountUpperBound_of_envelope hEnv⟩

/-- Diagnostic route: split finite-product/error control, after discarding the
product upper estimate, plus the overstrong quotient-envelope upper bound proves
the original count-level rough-sieve formulation. -/
theorem linear_sieve_rough_dyadic_count_bound_of_splitLowerEulerProductError_and_envelope
    {a₀ b₀ C₀ : ℝ}
    (hSplit : roughDyadicBadPrimeSplitEulerProductErrorBound a₀ b₀ C₀)
    (hEnv : roughDyadicBadPrimeProductEnvelopeUpperBound a₀ b₀ C₀) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        c * (t / Real.log (EscAnalytic.zScale X)) ≤ roughDyadicCount X M t
          ∧ roughDyadicCount X M t
              ≤ C * (t / Real.log (EscAnalytic.zScale X)) :=
  linear_sieve_rough_dyadic_count_bound_of_lowerEulerProductError_and_envelope
    (roughDyadicBadPrimeLowerEulerProductErrorBound_of_split hSplit) hEnv

/-- The rough dyadic count carrier is nonnegative. -/
theorem roughDyadicCount_nonneg (X : ℝ) (M : ℕ) (t : ℝ) :
    0 ≤ roughDyadicCount X M t := by
  classical
  unfold roughDyadicCount
  exact Nat.cast_nonneg _

/-- Enlarging the coprimality modulus can only remove admissible elements from
the rough dyadic count carrier. -/
theorem roughDyadicCount_antitone_dvd
    (X : ℝ) {M₁ M₂ : ℕ} (t : ℝ) (hM₂ : 0 < M₂) (hM : M₁ ∣ M₂) :
    roughDyadicCount X M₂ t ≤ roughDyadicCount X M₁ t := by
  classical
  unfold roughDyadicCount
  exact_mod_cast Finset.card_le_card (by
    intro n hn
    rw [Finset.mem_filter] at hn ⊢
    exact ⟨hn.1, hn.2.1, hn.2.2.1,
      hn.2.2.2.coprime_dvd_right (auxiliaryModulus_dvd_of_dvd hM₂ hM)⟩)

/-- Dropping the auxiliary coprimality modulus gives the largest rough dyadic
count carrier. -/
theorem roughDyadicCount_le_modulus_one (X : ℝ) (M : ℕ) (t : ℝ) :
    roughDyadicCount X M t ≤ roughDyadicCount X 1 t := by
  classical
  unfold roughDyadicCount
  exact_mod_cast Finset.card_le_card (by
    intro n hn
    rw [Finset.mem_filter] at hn ⊢
    exact ⟨hn.1, hn.2.1, hn.2.2.1, by
      simp [auxiliaryModulus_one]⟩)

/-- A no-extra-modulus upper count estimate is automatically uniform in the
auxiliary modulus, since the auxiliary coprimality condition only removes
admissible elements. -/
theorem roughDyadicCountUpperBound_of_modulusOne_upper
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicCountModulusOneUpperBound a₀ b₀ C₀) :
    roughDyadicCountUpperBound a₀ b₀ C₀ := by
  rcases h with ⟨C, X₀, hC, hone⟩
  refine ⟨C, X₀, hC, ?_⟩
  intro X hX M _hM t htlo hthi
  exact (roughDyadicCount_le_modulus_one X M t).trans
    (hone X hX t htlo hthi)

/-- The rough dyadic count is bounded by the size of its ambient natural-number
window. -/
theorem roughDyadicCount_le_natWindow_card (X : ℝ) (M : ℕ) (t : ℝ) :
    roughDyadicCount X M t ≤ ((natWindow t (2 * t)).card : ℝ) := by
  classical
  unfold roughDyadicCount
  exact_mod_cast Finset.card_le_card (Finset.filter_subset _ _)

/-- The rough dyadic count is bounded by the natural floor of the upper endpoint
`2t`. -/
theorem roughDyadicCount_le_floor_two_mul (X : ℝ) (M : ℕ) (t : ℝ) :
    roughDyadicCount X M t ≤ (⌊2 * t⌋₊ : ℝ) :=
  le_trans (roughDyadicCount_le_natWindow_card X M t)
    (natWindow_card_le_floor_upper t (2 * t))

/-- Foundation-only linear envelope for the rough dyadic count.  This loses the
rough-sieve saving `1/log z`; it only records that the carrier is a finite count
inside `(t,2t]`. -/
theorem roughDyadicCount_le_two_mul (X : ℝ) (M : ℕ) {t : ℝ} (ht : 0 ≤ t) :
    roughDyadicCount X M t ≤ 2 * t :=
  le_trans (roughDyadicCount_le_floor_two_mul X M t)
    (Nat.floor_le (mul_nonneg (by norm_num) ht))

/-- Absolute-value form of the foundation-only rough dyadic count envelope. -/
theorem abs_roughDyadicCount_le_two_mul (X : ℝ) (M : ℕ) {t : ℝ} (ht : 0 ≤ t) :
    |roughDyadicCount X M t| ≤ 2 * t := by
  rw [abs_of_nonneg (roughDyadicCount_nonneg X M t)]
  exact roughDyadicCount_le_two_mul X M ht

/-- Count-altitude unconditional replacement for the upper half of the dyadic
rough-sieve input.  It keeps the same parameter shape as the sieve statement,
but proves only the ambient-window estimate `O(t)`, with no `1/log z` saving. -/
theorem roughDyadicCount_linear_upper_unconditional_with_carrier_bounds
    (a₀ b₀ C₀ : ℝ) (_ha₀ : 0 < a₀) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        0 ≤ roughDyadicCount X M t ∧
          roughDyadicCount X M t ≤ C * t ∧
          |roughDyadicCount X M t| ≤ C * t := by
  refine ⟨2, 1, by norm_num, ?_⟩
  intro X hX M _hM t htlo _hthi
  have hXpos : 0 < X := lt_of_lt_of_le zero_lt_one hX
  have ht_nonneg : 0 ≤ t := le_trans (Real.rpow_pos_of_pos hXpos a₀).le htlo
  have hnonneg := roughDyadicCount_nonneg X M t
  have hupper := roughDyadicCount_le_two_mul X M ht_nonneg
  exact ⟨hnonneg, by simpa using hupper, by
    rw [abs_of_nonneg hnonneg]
    simpa using hupper⟩

/-- Count-altitude unconditional upper fallback, additionally bundled with the
positivity of the normalizing `log z(X)`.  This matches the side conditions of
the linear-sieve route when only the finite carrier upper bound is needed. -/
theorem roughDyadicCount_linear_upper_unconditional_with_log_carrier_bounds
    (a₀ b₀ C₀ : ℝ) (ha₀ : 0 < a₀) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        0 < Real.log (EscAnalytic.zScale X) ∧
          0 ≤ roughDyadicCount X M t ∧
          roughDyadicCount X M t ≤ C * t ∧
          |roughDyadicCount X M t| ≤ C * t := by
  rcases roughDyadicCount_linear_upper_unconditional_with_carrier_bounds
      a₀ b₀ C₀ ha₀ with
    ⟨C, Xbase, hC, hupper⟩
  refine ⟨C, max Xbase (Real.exp 2), hC, ?_⟩
  intro X hX M hM t htlo hthi
  have hXbase : Xbase ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  exact ⟨log_zScale_pos_of_exp_two_le hXexp, hupper X hXbase M hM t htlo hthi⟩

/-- Uniform fixed-window upper fallback for rough dyadic counts.  This is only
the trivial ambient-window bound, not the rough-sieve `1/log z` saving. -/
theorem roughDyadicCount_upper_unconditional (a₀ b₀ : ℝ) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ) (t : ℝ), X ^ a₀ ≤ t → t ≤ X ^ b₀ →
        roughDyadicCount X M t ≤ C * X ^ b₀ := by
  refine ⟨2, 1, by norm_num, ?_⟩
  intro X hX M t htlo hthi
  have hXpos : 0 < X := lt_of_lt_of_le zero_lt_one hX
  have ht_nonneg : 0 ≤ t := le_trans (Real.rpow_pos_of_pos hXpos a₀).le htlo
  calc
    roughDyadicCount X M t ≤ 2 * t := roughDyadicCount_le_two_mul X M ht_nonneg
    _ ≤ 2 * X ^ b₀ := mul_le_mul_of_nonneg_left hthi (by norm_num)

/-- Absolute-value form of the fixed-window rough dyadic fallback. -/
theorem abs_roughDyadicCount_upper_unconditional (a₀ b₀ : ℝ) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ) (t : ℝ), X ^ a₀ ≤ t → t ≤ X ^ b₀ →
        |roughDyadicCount X M t| ≤ C * X ^ b₀ := by
  refine ⟨2, 1, by norm_num, ?_⟩
  intro X hX M t htlo hthi
  have hXpos : 0 < X := lt_of_lt_of_le zero_lt_one hX
  have ht_nonneg : 0 ≤ t := le_trans (Real.rpow_pos_of_pos hXpos a₀).le htlo
  calc
    |roughDyadicCount X M t| ≤ 2 * t := abs_roughDyadicCount_le_two_mul X M ht_nonneg
    _ ≤ 2 * X ^ b₀ := mul_le_mul_of_nonneg_left hthi (by norm_num)

/-- Fixed-window rough dyadic count fallback bundled with carrier and
absolute-value side conditions.  This is only the ambient-window estimate
`O(X^b₀)`; the `1/log z` saving remains the separate linear-sieve input. -/
theorem roughDyadicCount_upper_unconditional_with_carrier_bounds (a₀ b₀ : ℝ) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ) (t : ℝ), X ^ a₀ ≤ t → t ≤ X ^ b₀ →
        0 ≤ roughDyadicCount X M t ∧
          roughDyadicCount X M t ≤ C * X ^ b₀ ∧
          |roughDyadicCount X M t| ≤ C * X ^ b₀ := by
  rcases roughDyadicCount_upper_unconditional a₀ b₀ with ⟨C, X₀, hC, hupper⟩
  refine ⟨C, X₀, hC, ?_⟩
  intro X hX M t htlo hthi
  have hnonneg := roughDyadicCount_nonneg X M t
  have hbound := hupper X hX M t htlo hthi
  exact ⟨hnonneg, hbound, by
    rw [abs_of_nonneg hnonneg]
    exact hbound⟩

/-- A bare fixed-window rough dyadic upper fallback gives the carrier-bundled
version with nonnegativity and absolute-value side conditions. -/
theorem roughDyadicCount_upper_unconditional_with_carrier_bounds_of_bound
    (a₀ b₀ : ℝ)
    (h :
      ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        ∀ (M : ℕ) (t : ℝ), X ^ a₀ ≤ t → t ≤ X ^ b₀ →
          roughDyadicCount X M t ≤ C * X ^ b₀) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ) (t : ℝ), X ^ a₀ ≤ t → t ≤ X ^ b₀ →
        0 ≤ roughDyadicCount X M t ∧
          roughDyadicCount X M t ≤ C * X ^ b₀ ∧
          |roughDyadicCount X M t| ≤ C * X ^ b₀ := by
  rcases h with ⟨C, X₀, hC, hupper⟩
  refine ⟨C, X₀, hC, ?_⟩
  intro X hX M t htlo hthi
  have hnonneg := roughDyadicCount_nonneg X M t
  have hbound := hupper X hX M t htlo hthi
  exact ⟨hnonneg, hbound, by
    rw [abs_of_nonneg hnonneg]
    exact hbound⟩

/-- Forget the checked side conditions from a bundled fixed-window rough dyadic
upper fallback. -/
theorem roughDyadicCount_upper_unconditional_bound_of_carrier_bounds
    (a₀ b₀ : ℝ)
    (h :
      ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        ∀ (M : ℕ) (t : ℝ), X ^ a₀ ≤ t → t ≤ X ^ b₀ →
          0 ≤ roughDyadicCount X M t ∧
            roughDyadicCount X M t ≤ C * X ^ b₀ ∧
            |roughDyadicCount X M t| ≤ C * X ^ b₀) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ) (t : ℝ), X ^ a₀ ≤ t → t ≤ X ^ b₀ →
        roughDyadicCount X M t ≤ C * X ^ b₀ := by
  rcases h with ⟨C, X₀, hC, hcarrier⟩
  refine ⟨C, X₀, hC, ?_⟩
  intro X hX M t htlo hthi
  exact (hcarrier X hX M t htlo hthi).2.1

/-- Bare and carrier-bundled fixed-window rough dyadic upper fallbacks have the
same analytic content. -/
theorem roughDyadicCount_upper_unconditional_bound_iff_carrier_bounds
    (a₀ b₀ : ℝ) :
    (∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ) (t : ℝ), X ^ a₀ ≤ t → t ≤ X ^ b₀ →
        roughDyadicCount X M t ≤ C * X ^ b₀) ↔
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ) (t : ℝ), X ^ a₀ ≤ t → t ≤ X ^ b₀ →
        0 ≤ roughDyadicCount X M t ∧
          roughDyadicCount X M t ≤ C * X ^ b₀ ∧
          |roughDyadicCount X M t| ≤ C * X ^ b₀ := by
  constructor
  · exact roughDyadicCount_upper_unconditional_with_carrier_bounds_of_bound a₀ b₀
  · exact roughDyadicCount_upper_unconditional_bound_of_carrier_bounds a₀ b₀

/-- The (abstract) reciprocal sum `∑_{X^a<n≤X^b, sqf, (n,P(z))=1, (n,M)=1} 1/n`
appearing in `lem:rough-sqf`, `(eq:rough-recip-uniform)`. -/
noncomputable def roughRecip (X : ℝ) (M : ℕ) (a b : ℝ) : ℝ := by
  classical
  exact
    ∑ n ∈ (natWindow (X ^ a) (X ^ b)).filter
        (fun n =>
          Squarefree n ∧ Nat.Coprime n (roughModulus X) ∧
            Nat.Coprime n (auxiliaryModulus M)),
      (1 : ℝ) / (n : ℝ)

/-- The rough reciprocal carrier is nonnegative. -/
theorem roughRecip_nonneg (X : ℝ) (M : ℕ) (a b : ℝ) :
    0 ≤ roughRecip X M a b := by
  classical
  unfold roughRecip
  apply Finset.sum_nonneg
  intro n _hn
  exact div_nonneg zero_le_one (Nat.cast_nonneg n)

/-- The zero auxiliary modulus is the no-extra-modulus case for the rough
reciprocal carrier. -/
theorem roughRecip_zero_auxiliary_eq_one (X a b : ℝ) :
    roughRecip X 0 a b = roughRecip X 1 a b := by
  unfold roughRecip
  simp [auxiliaryModulus_zero, auxiliaryModulus_one]

/-- If `z(X)` contains the fixed auxiliary modulus, then the auxiliary
coprimality condition is redundant in the rough reciprocal carrier. -/
theorem roughRecip_eq_modulus_one_of_auxiliary_le_floor_zScale
    (X : ℝ) (M : ℕ) (a b : ℝ)
    (hM : auxiliaryModulus M ≤ ⌊EscAnalytic.zScale X⌋₊) :
    roughRecip X M a b = roughRecip X 1 a b := by
  classical
  unfold roughRecip
  apply Finset.sum_congr
  · ext n
    rw [Finset.mem_filter, Finset.mem_filter]
    constructor
    · intro h
      exact ⟨h.1, h.2.1, h.2.2.1, by
        simp [auxiliaryModulus_one]⟩
    · intro h
      exact ⟨h.1, h.2.1, h.2.2.1,
        coprime_auxiliaryModulus_of_coprime_roughModulus_of_le_floor_zScale
          hM h.2.2.1⟩
  · intro n _hn
    rfl

/-- Prime-factor support form of auxiliary-modulus absorption for the rough
reciprocal carrier. -/
theorem roughRecip_eq_modulus_one_of_auxiliary_primeFactors_subset
    (X : ℝ) (M : ℕ) (a b : ℝ)
    (hsub : (auxiliaryModulus M).primeFactors ⊆ (roughModulus X).primeFactors) :
    roughRecip X M a b = roughRecip X 1 a b := by
  classical
  unfold roughRecip
  apply Finset.sum_congr
  · ext n
    rw [Finset.mem_filter, Finset.mem_filter]
    constructor
    · intro h
      exact ⟨h.1, h.2.1, h.2.2.1, by
        simp [auxiliaryModulus_one]⟩
    · intro h
      exact ⟨h.1, h.2.1, h.2.2.1,
        coprime_auxiliaryModulus_of_primeFactors_subset_roughModulus
          hsub h.2.2.1⟩
  · intro n _hn
    rfl

/-- The rough reciprocal carrier only sees the large-prime tail of the
auxiliary modulus. -/
theorem roughRecip_eq_auxiliaryTailModulus
    (X : ℝ) (M : ℕ) (a b : ℝ) :
    roughRecip X M a b =
      roughRecip X (auxiliaryTailModulus X M) a b := by
  classical
  unfold roughRecip
  apply Finset.sum_congr
  · ext n
    rw [Finset.mem_filter, Finset.mem_filter]
    constructor
    · intro h
      have htail :
          Nat.Coprime n (auxiliaryTailModulus X M) :=
        (coprime_auxiliaryModulus_iff_coprime_tail_of_coprime_rough
          (M := M) h.2.2.1).mp h.2.2.2
      have htail_aux :
          Nat.Coprime n (auxiliaryModulus (auxiliaryTailModulus X M)) := by
        rw [auxiliaryModulus_eq_self_of_pos (auxiliaryTailModulus_pos X M)]
        exact htail
      exact ⟨h.1, h.2.1, h.2.2.1, htail_aux⟩
    · intro h
      have htail :
          Nat.Coprime n (auxiliaryTailModulus X M) := by
        simpa [auxiliaryModulus_eq_self_of_pos (auxiliaryTailModulus_pos X M)]
          using h.2.2.2
      have haux :
          Nat.Coprime n (auxiliaryModulus M) :=
        (coprime_auxiliaryModulus_iff_coprime_tail_of_coprime_rough
          (M := M) h.2.2.1).mpr htail
      exact ⟨h.1, h.2.1, h.2.2.1, haux⟩
  · intro n _hn
    rfl

/-- Explicit-threshold form of `roughRecip_eq_modulus_one_of_auxiliary_le_floor_zScale`. -/
theorem roughRecip_eq_modulus_one_of_exp_auxiliary_le
    (X : ℝ) (M : ℕ) (a b : ℝ)
    (hX : Real.exp ((auxiliaryModulus M : ℕ) : ℝ) ≤ X) :
    roughRecip X M a b = roughRecip X 1 a b :=
  roughRecip_eq_modulus_one_of_auxiliary_le_floor_zScale X M a b
    (auxiliaryModulus_le_floor_zScale_of_exp_auxiliary_le M hX)

/-- Enlarging the coprimality modulus can only remove nonnegative reciprocal
terms from the rough reciprocal carrier. -/
theorem roughRecip_antitone_dvd
    (X : ℝ) {M₁ M₂ : ℕ} (a b : ℝ) (hM₂ : 0 < M₂) (hM : M₁ ∣ M₂) :
    roughRecip X M₂ a b ≤ roughRecip X M₁ a b := by
  classical
  unfold roughRecip
  apply Finset.sum_le_sum_of_subset_of_nonneg
  · intro n hn
    rw [Finset.mem_filter] at hn ⊢
    exact ⟨hn.1, hn.2.1, hn.2.2.1,
      hn.2.2.2.coprime_dvd_right (auxiliaryModulus_dvd_of_dvd hM₂ hM)⟩
  · intro n _hnBig _hnSmall
    exact div_nonneg zero_le_one (Nat.cast_nonneg n)

/-- Dropping the auxiliary coprimality modulus gives the largest rough
reciprocal carrier. -/
theorem roughRecip_le_modulus_one (X : ℝ) (M : ℕ) (a b : ℝ) :
    roughRecip X M a b ≤ roughRecip X 1 a b := by
  classical
  unfold roughRecip
  apply Finset.sum_le_sum_of_subset_of_nonneg
  · intro n hn
    rw [Finset.mem_filter] at hn ⊢
    exact ⟨hn.1, hn.2.1, hn.2.2.1, by
      simp [auxiliaryModulus_one]⟩
  · intro n _hnBig _hnSmall
    exact div_nonneg zero_le_one (Nat.cast_nonneg n)

/-- Exact bridge from the rough reciprocal carrier to the ordinary squarefree
reciprocal carrier, with roughness absorbed into the coprimality modulus and the
progression modulus set to `1`. -/
theorem roughRecip_eq_sqfRecip_mul_rough (X : ℝ) (M : ℕ) (a b : ℝ) :
    roughRecip X M a b =
      sqfRecip X (auxiliaryModulus M * roughModulus X) 1 0 (X ^ a) (X ^ b) := by
  classical
  unfold roughRecip sqfRecip natWindow congMod
  apply Finset.sum_congr
  · ext n
    simp only [Finset.mem_filter, Finset.mem_Icc, Nat.mod_one, and_true]
    constructor
    · intro h
      rcases h with ⟨hwin, hsqf, hrough, hM⟩
      exact ⟨hwin, hsqf, (Nat.coprime_mul_iff_right).mpr ⟨hM, hrough⟩⟩
    · intro h
      rcases h with ⟨hwin, hsqf, hcop⟩
      have hcops := (Nat.coprime_mul_iff_right).mp hcop
      exact ⟨hwin, hsqf, hcops.2, hcops.1⟩
  · intro n _hn
    rfl

/-- The rough reciprocal carrier is bounded by the squarefree/coprime carrier
with the vacuous modulus-one progression condition. -/
theorem roughRecip_le_sqfRecip_mod_one (X : ℝ) (M : ℕ) (a b : ℝ) :
    roughRecip X M a b ≤ sqfRecip X (auxiliaryModulus M) 1 0 (X ^ a) (X ^ b) := by
  classical
  unfold roughRecip sqfRecip
  apply Finset.sum_le_sum_of_subset_of_nonneg
  · intro n hn
    have hwin : n ∈ natWindow (X ^ a) (X ^ b) := (Finset.mem_filter.mp hn).1
    have hsqf : Squarefree n := (Finset.mem_filter.mp hn).2.1
    have hcopM : Nat.Coprime n (auxiliaryModulus M) := (Finset.mem_filter.mp hn).2.2.2
    exact Finset.mem_filter.mpr
      ⟨hwin, ⟨hsqf, hcopM, by unfold congMod; exact Nat.mod_one n⟩⟩
  · intro n _hnBig _hnSmall
    exact div_nonneg zero_le_one (Nat.cast_nonneg n)

/-- Elementary logarithmic upper envelope for the rough reciprocal carrier.  This
does not contain the sieve saving `1/log z`; it is the unconditional bound
obtained by forgetting the roughness condition. -/
theorem roughRecip_le_log_plus_inv (X : ℝ) (M : ℕ) (a b : ℝ)
    (hX : 0 < X) (hab : X ^ a < X ^ b) :
    roughRecip X M a b ≤ 1 / (X ^ a) + Real.log ((X ^ b) / (X ^ a)) := by
  exact le_trans (roughRecip_le_sqfRecip_mod_one X M a b)
    (by
      simpa using
        (sqfRecip_le_log_plus_inv X (auxiliaryModulus M) 1 0 (by norm_num)
          (Real.rpow_pos_of_pos hX a) hab))

/-- Uniform foundation-only log-scale envelope for the rough reciprocal carrier.
This forgets roughness and only proves the elementary `O(log X)` upper bound. -/
theorem roughRecip_le_log_scale
    (a₀ b₀ : ℝ) (ha₀ : 0 < a₀)
    {X : ℝ} (hX : Real.exp 1 ≤ X) (M : ℕ) {a b : ℝ}
    (ha : a₀ ≤ a) (hab : a < b) (hb : b ≤ b₀) :
    roughRecip X M a b ≤ (b₀ + 1) * Real.log X := by
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 1) hX
  have hExpOne : 1 < Real.exp 1 := by
    calc
      1 = Real.exp 0 := by simp
      _ < Real.exp 1 := Real.exp_lt_exp.mpr (by norm_num)
  have hXone : 1 < X := lt_of_lt_of_le hExpOne hX
  have hXge1 : 1 ≤ X := hXone.le
  have habPow : X ^ a < X ^ b :=
    Real.rpow_lt_rpow_of_exponent_lt hXone hab
  have hrough := roughRecip_le_log_plus_inv X M a b hXpos habPow
  have hlogquot :
      Real.log ((X ^ b) / (X ^ a)) = (b - a) * Real.log X := by
    rw [Real.log_div (ne_of_gt (Real.rpow_pos_of_pos hXpos b))
      (ne_of_gt (Real.rpow_pos_of_pos hXpos a))]
    rw [Real.log_rpow hXpos, Real.log_rpow hXpos]
    ring
  have ha_nonneg : 0 ≤ a := le_trans ha₀.le ha
  have hXa_ge_one : 1 ≤ X ^ a := by
    simpa using
      (Real.rpow_le_rpow_of_exponent_le hXge1 ha_nonneg :
        X ^ (0 : ℝ) ≤ X ^ a)
  have hinv_le_one : 1 / (X ^ a) ≤ 1 := by
    simpa [one_div] using (inv_le_one_of_one_le₀ hXa_ge_one)
  have hlog_ge_one : 1 ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    simpa using hX
  have hlog_nonneg : 0 ≤ Real.log X := le_trans zero_le_one hlog_ge_one
  have hbminus : b - a ≤ b₀ := by linarith
  have hterm2 : (b - a) * Real.log X ≤ b₀ * Real.log X :=
    mul_le_mul_of_nonneg_right hbminus hlog_nonneg
  calc
    roughRecip X M a b
        ≤ 1 / (X ^ a) + Real.log ((X ^ b) / (X ^ a)) := hrough
    _ = 1 / (X ^ a) + (b - a) * Real.log X := by rw [hlogquot]
    _ ≤ Real.log X + b₀ * Real.log X :=
          add_le_add (le_trans hinv_le_one hlog_ge_one) hterm2
    _ = (b₀ + 1) * Real.log X := by ring

/-- Absolute-value form of `roughRecip_le_log_scale`. -/
theorem abs_roughRecip_le_log_scale
    (a₀ b₀ : ℝ) (ha₀ : 0 < a₀)
    {X : ℝ} (hX : Real.exp 1 ≤ X) (M : ℕ) {a b : ℝ}
    (ha : a₀ ≤ a) (hab : a < b) (hb : b ≤ b₀) :
    |roughRecip X M a b| ≤ (b₀ + 1) * Real.log X := by
  rw [abs_of_nonneg (roughRecip_nonneg X M a b)]
  exact roughRecip_le_log_scale a₀ b₀ ha₀ hX M ha hab hb

/-- Uniform unconditional upper fallback for rough reciprocal sums.  The bound is
only `O(log X)`; the sharper rough-sieve factor remains analytic debt. -/
theorem roughRecip_upper_unconditional
    (a₀ b₀ : ℝ) (ha₀ : 0 < a₀) (hab₀ : a₀ < b₀) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ) (a b : ℝ),
        a₀ ≤ a → a < b → b ≤ b₀ →
        roughRecip X M a b ≤ C * Real.log X := by
  refine ⟨b₀ + 1, Real.exp 1, ?_, ?_⟩
  · linarith
  · intro X hX M a b ha hab hb
    exact roughRecip_le_log_scale a₀ b₀ ha₀ hX M ha hab hb

/-- Absolute-value form of the uniform unconditional rough reciprocal fallback. -/
theorem abs_roughRecip_upper_unconditional
    (a₀ b₀ : ℝ) (ha₀ : 0 < a₀) (hab₀ : a₀ < b₀) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ) (a b : ℝ),
        a₀ ≤ a → a < b → b ≤ b₀ →
        |roughRecip X M a b| ≤ C * Real.log X := by
  refine ⟨b₀ + 1, Real.exp 1, ?_, ?_⟩
  · linarith
  · intro X hX M a b ha hab hb
    exact abs_roughRecip_le_log_scale a₀ b₀ ha₀ hX M ha hab hb

/-- Uniform unconditional rough reciprocal upper fallback, bundled with the
carrier facts usually needed downstream.  This is the theorem-level part of the
rough reciprocal estimate: positivity and an `O(log X)` upper bound after
forgetting roughness.  The sharp `1/log z` saving and matching lower density
remain the separate count-level linear-sieve input. -/
theorem roughRecip_upper_unconditional_with_carrier_bounds
    (a₀ b₀ : ℝ) (ha₀ : 0 < a₀) (hab₀ : a₀ < b₀) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ) (a b : ℝ),
        a₀ ≤ a → a < b → b ≤ b₀ →
        0 ≤ Real.log X ∧
          0 ≤ roughRecip X M a b ∧
          roughRecip X M a b ≤ C * Real.log X ∧
          |roughRecip X M a b| ≤ C * Real.log X := by
  refine ⟨b₀ + 1, Real.exp 1, ?_, ?_⟩
  · linarith
  · intro X hX M a b ha hab hb
    have hExpOne : (1 : ℝ) < Real.exp 1 := by
      calc
        1 = Real.exp 0 := by simp
        _ < Real.exp 1 := Real.exp_lt_exp.mpr (by norm_num)
    have hXone : (1 : ℝ) ≤ X := le_trans hExpOne.le hX
    have hlog_nonneg : 0 ≤ Real.log X := Real.log_nonneg hXone
    have hnonneg := roughRecip_nonneg X M a b
    have hupper := roughRecip_le_log_scale a₀ b₀ ha₀ hX M ha hab hb
    have habs := abs_roughRecip_le_log_scale a₀ b₀ ha₀ hX M ha hab hb
    exact ⟨hlog_nonneg, hnonneg, hupper, habs⟩

/-- A bare logarithmic rough-reciprocal upper fallback gives the bundled carrier
version after raising the eventual threshold enough to make `log X ≥ 0`. -/
theorem roughRecip_upper_unconditional_with_carrier_bounds_of_bound
    (a₀ b₀ : ℝ)
    (h :
      ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        ∀ (M : ℕ) (a b : ℝ),
          a₀ ≤ a → a < b → b ≤ b₀ →
          roughRecip X M a b ≤ C * Real.log X) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ) (a b : ℝ),
        a₀ ≤ a → a < b → b ≤ b₀ →
        0 ≤ Real.log X ∧
          0 ≤ roughRecip X M a b ∧
          roughRecip X M a b ≤ C * Real.log X ∧
          |roughRecip X M a b| ≤ C * Real.log X := by
  rcases h with ⟨C, Xbase, hC, hupper⟩
  refine ⟨C, max Xbase (Real.exp 1), hC, ?_⟩
  intro X hX M a b ha hab hb
  have hXbase : Xbase ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 1 ≤ X := le_trans (le_max_right _ _) hX
  have hExpOne : (1 : ℝ) < Real.exp 1 := by
    calc
      1 = Real.exp 0 := by simp
      _ < Real.exp 1 := Real.exp_lt_exp.mpr (by norm_num)
  have hXone : (1 : ℝ) ≤ X := le_trans hExpOne.le hXexp
  have hlog_nonneg : 0 ≤ Real.log X := Real.log_nonneg hXone
  have hnonneg := roughRecip_nonneg X M a b
  have hbound := hupper X hXbase M a b ha hab hb
  exact ⟨hlog_nonneg, hnonneg, hbound, by
    rw [abs_of_nonneg hnonneg]
    exact hbound⟩

/-- Forget the checked side conditions from a bundled logarithmic
rough-reciprocal upper fallback. -/
theorem roughRecip_upper_unconditional_bound_of_carrier_bounds
    (a₀ b₀ : ℝ)
    (h :
      ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        ∀ (M : ℕ) (a b : ℝ),
          a₀ ≤ a → a < b → b ≤ b₀ →
          0 ≤ Real.log X ∧
            0 ≤ roughRecip X M a b ∧
            roughRecip X M a b ≤ C * Real.log X ∧
            |roughRecip X M a b| ≤ C * Real.log X) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ) (a b : ℝ),
        a₀ ≤ a → a < b → b ≤ b₀ →
        roughRecip X M a b ≤ C * Real.log X := by
  rcases h with ⟨C, X₀, hC, hcarrier⟩
  refine ⟨C, X₀, hC, ?_⟩
  intro X hX M a b ha hab hb
  exact (hcarrier X hX M a b ha hab hb).2.2.1

/-- Bare and carrier-bundled logarithmic rough-reciprocal upper fallbacks have
the same analytic content. -/
theorem roughRecip_upper_unconditional_bound_iff_carrier_bounds
    (a₀ b₀ : ℝ) :
    (∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ) (a b : ℝ),
        a₀ ≤ a → a < b → b ≤ b₀ →
        roughRecip X M a b ≤ C * Real.log X) ↔
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ) (a b : ℝ),
        a₀ ≤ a → a < b → b ≤ b₀ →
        0 ≤ Real.log X ∧
          0 ≤ roughRecip X M a b ∧
          roughRecip X M a b ≤ C * Real.log X ∧
          |roughRecip X M a b| ≤ C * Real.log X := by
  constructor
  · exact roughRecip_upper_unconditional_with_carrier_bounds_of_bound a₀ b₀
  · exact roughRecip_upper_unconditional_bound_of_carrier_bounds a₀ b₀

/-! ### Dyadic partial-summation scaffolding for the rough reciprocal sum.

The reciprocal sum `roughRecip X M a b` is derived from the count-level sieve
input by a genuine dyadic partial summation: decompose the window `(X^a, X^b]`
into the dyadic blocks `(X^a·2^k, X^a·2^{k+1}]`, bound the reciprocal sum on each
block by the rough count on that block divided by the block's left endpoint, and
assemble.  The pieces below carry out this decomposition for the concrete finite
carriers, so that the reciprocal bound `roughRecip ≍ (log X)/(log z)` becomes a
real theorem over the bare count input rather than an assumed estimate. -/

/-- The rough squarefree carrier on the dyadic block `(t, 2t]`.  Its cardinality
is exactly `roughDyadicCount X M t`. -/
noncomputable def roughBlockCarrier (X : ℝ) (M : ℕ) (t : ℝ) : Finset ℕ := by
  classical
  exact (natWindow t (2 * t)).filter
    (fun n : ℕ => Squarefree n ∧
      Nat.Coprime n (roughModulus X) ∧ Nat.Coprime n (auxiliaryModulus M))

/-- The cardinality of the block carrier is the dyadic count. -/
theorem roughBlockCarrier_card (X : ℝ) (M : ℕ) (t : ℝ) :
    ((roughBlockCarrier X M t).card : ℝ) = roughDyadicCount X M t := by
  classical
  unfold roughBlockCarrier roughDyadicCount
  rfl

/-- Membership in the block carrier unpacks the window and roughness data. -/
theorem mem_roughBlockCarrier {X : ℝ} {M : ℕ} {t : ℝ} {n : ℕ} :
    n ∈ roughBlockCarrier X M t ↔
      (1 ≤ n ∧ (n : ℝ) ≤ 2 * t ∧ t < (n : ℝ)) ∧
        (Squarefree n ∧ Nat.Coprime n (roughModulus X) ∧
          Nat.Coprime n (auxiliaryModulus M)) := by
  classical
  unfold roughBlockCarrier natWindow
  rw [Finset.mem_filter, Finset.mem_filter, Finset.mem_Icc]
  constructor
  · rintro ⟨⟨⟨h1, h2⟩, h3⟩, hrough⟩
    -- here `n ≥ 1`, `t < n`, so `2t ≥ 0` need not hold a priori, but
    -- `n ≤ ⌊2t⌋₊` and `n ≥ 1` give `⌊2t⌋₊ ≥ 1`, hence `2t ≥ 1 > 0`.
    have hfloor_pos : 1 ≤ ⌊2 * t⌋₊ := le_trans h1 h2
    have h2t_nonneg : (0 : ℝ) ≤ 2 * t := by
      have := Nat.floor_le (a := 2 * t)
      by_contra hneg
      push_neg at hneg
      rw [Nat.floor_of_nonpos (le_of_lt hneg)] at hfloor_pos
      exact absurd hfloor_pos (by norm_num)
    refine ⟨⟨h1, ?_, h3⟩, hrough⟩
    exact (Nat.le_floor_iff h2t_nonneg).mp h2
  · rintro ⟨⟨h1, h2, h3⟩, hrough⟩
    have h2t_nonneg : (0 : ℝ) ≤ 2 * t :=
      le_trans (by exact_mod_cast Nat.zero_le n) h2
    have h2' : n ≤ ⌊2 * t⌋₊ := (Nat.le_floor_iff h2t_nonneg).mpr h2
    exact ⟨⟨⟨h1, h2'⟩, h3⟩, hrough⟩

/-- Enlarging the auxiliary coprimality modulus can only shrink a dyadic rough
block carrier. -/
theorem roughBlockCarrier_antitone_dvd
    (X : ℝ) {M₁ M₂ : ℕ} (t : ℝ) (hM₂ : 0 < M₂) (hM : M₁ ∣ M₂) :
    roughBlockCarrier X M₂ t ⊆ roughBlockCarrier X M₁ t := by
  intro n hn
  have hmem := mem_roughBlockCarrier.mp hn
  exact mem_roughBlockCarrier.mpr
    ⟨hmem.1, hmem.2.1, hmem.2.2.1,
      hmem.2.2.2.coprime_dvd_right (auxiliaryModulus_dvd_of_dvd hM₂ hM)⟩

/-- The dyadic rough block with modulus `1` is the largest auxiliary-modulus
block carrier. -/
theorem roughBlockCarrier_subset_modulus_one (X : ℝ) (M : ℕ) (t : ℝ) :
    roughBlockCarrier X M t ⊆ roughBlockCarrier X 1 t := by
  intro n hn
  have hmem := mem_roughBlockCarrier.mp hn
  exact mem_roughBlockCarrier.mpr
    ⟨hmem.1, hmem.2.1, hmem.2.2.1, by
      simp [auxiliaryModulus_one]⟩

/-- The reciprocal sum over a single dyadic block. -/
noncomputable def roughBlockRecip (X : ℝ) (M : ℕ) (t : ℝ) : ℝ :=
  ∑ n ∈ roughBlockCarrier X M t, (1 : ℝ) / (n : ℝ)

/-- The reciprocal sum over a single dyadic rough block is nonnegative. -/
theorem roughBlockRecip_nonneg (X : ℝ) (M : ℕ) (t : ℝ) :
    0 ≤ roughBlockRecip X M t := by
  classical
  unfold roughBlockRecip
  apply Finset.sum_nonneg
  intro n _hn
  exact div_nonneg zero_le_one (Nat.cast_nonneg n)

/-- Enlarging the auxiliary coprimality modulus can only remove nonnegative
reciprocal terms from a dyadic rough block. -/
theorem roughBlockRecip_antitone_dvd
    (X : ℝ) {M₁ M₂ : ℕ} (t : ℝ) (hM₂ : 0 < M₂) (hM : M₁ ∣ M₂) :
    roughBlockRecip X M₂ t ≤ roughBlockRecip X M₁ t := by
  classical
  unfold roughBlockRecip
  apply Finset.sum_le_sum_of_subset_of_nonneg
  · exact roughBlockCarrier_antitone_dvd X t hM₂ hM
  · intro n _hnBig _hnSmall
    exact div_nonneg zero_le_one (Nat.cast_nonneg n)

/-- Dropping the auxiliary modulus gives the largest dyadic block reciprocal
carrier. -/
theorem roughBlockRecip_le_modulus_one (X : ℝ) (M : ℕ) (t : ℝ) :
    roughBlockRecip X M t ≤ roughBlockRecip X 1 t :=
  by
    classical
    unfold roughBlockRecip
    apply Finset.sum_le_sum_of_subset_of_nonneg
    · exact roughBlockCarrier_subset_modulus_one X M t
    · intro n _hnBig _hnSmall
      exact div_nonneg zero_le_one (Nat.cast_nonneg n)

/-- On the block `(t, 2t]` with `t > 0`, every reciprocal `1/n` is at most `1/t`,
so the block reciprocal sum is at most `count / t`. -/
theorem roughBlockRecip_le (X : ℝ) (M : ℕ) {t : ℝ} (ht : 0 < t) :
    roughBlockRecip X M t ≤ roughDyadicCount X M t / t := by
  classical
  unfold roughBlockRecip
  rw [← roughBlockCarrier_card X M t]
  calc
    ∑ n ∈ roughBlockCarrier X M t, (1 : ℝ) / (n : ℝ)
        ≤ ∑ _n ∈ roughBlockCarrier X M t, (1 : ℝ) / t := by
          apply Finset.sum_le_sum
          intro n hn
          have hlt : t < (n : ℝ) := (mem_roughBlockCarrier.mp hn).1.2.2
          have hn_pos : 0 < (n : ℝ) := lt_trans ht hlt
          exact one_div_le_one_div_of_le ht hlt.le
    _ = ((roughBlockCarrier X M t).card : ℝ) / t := by
          rw [Finset.sum_const, nsmul_eq_mul]
          field_simp

/-- On the block `(t, 2t]` with `t > 0`, every reciprocal `1/n` is at least
`1/(2t)`, so the block reciprocal sum is at least `count / (2t)`. -/
theorem roughBlockRecip_ge (X : ℝ) (M : ℕ) {t : ℝ} (ht : 0 < t) :
    roughDyadicCount X M t / (2 * t) ≤ roughBlockRecip X M t := by
  classical
  unfold roughBlockRecip
  rw [← roughBlockCarrier_card X M t]
  calc
    ((roughBlockCarrier X M t).card : ℝ) / (2 * t)
        = ∑ _n ∈ roughBlockCarrier X M t, (1 : ℝ) / (2 * t) := by
          rw [Finset.sum_const, nsmul_eq_mul]
          field_simp
    _ ≤ ∑ n ∈ roughBlockCarrier X M t, (1 : ℝ) / (n : ℝ) := by
          apply Finset.sum_le_sum
          intro n hn
          have hmem := mem_roughBlockCarrier.mp hn
          have hle : (n : ℝ) ≤ 2 * t := hmem.1.2.1
          have hn_pos : 0 < (n : ℝ) := lt_trans ht hmem.1.2.2
          exact one_div_le_one_div_of_le hn_pos hle

/-- No-extra-modulus lower dyadic block-reciprocal target.  This is the
normalized lower rough-density form specialized to `M = 1`. -/
def roughBlockRecipModulusOneLowerBoundCore (a₀ b₀ : ℝ) : Prop :=
  ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
      c / Real.log (EscAnalytic.zScale X) ≤ roughBlockRecip X 1 t

/-- No-extra-modulus upper dyadic block-reciprocal target.  This is the
normalized upper rough-density form specialized to `M = 1`. -/
def roughBlockRecipModulusOneUpperBoundCore (a₀ b₀ : ℝ) : Prop :=
  ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
      roughBlockRecip X 1 t ≤ C / Real.log (EscAnalytic.zScale X)

/-- A no-extra-modulus block-reciprocal lower bound implies the corresponding
no-extra-modulus count lower core.  The only input is the finite carrier
inequality `roughBlockRecip ≤ count / t`. -/
theorem roughDyadicCountModulusOneLowerBoundCore_of_roughBlockRecipModulusOneLower
    {a₀ b₀ : ℝ}
    (h : roughBlockRecipModulusOneLowerBoundCore a₀ b₀) :
    roughDyadicCountModulusOneLowerBoundCore a₀ b₀ := by
  rcases h with ⟨c, Xbase, hc, hblock⟩
  refine ⟨c, max Xbase (Real.exp 1), hc, ?_⟩
  intro X hX t htlo hthi
  have hXbase : Xbase ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 1 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 1) hXexp
  have htpos : 0 < t := lt_of_lt_of_le (Real.rpow_pos_of_pos hXpos a₀) htlo
  have hto_count_div :
      c / Real.log (EscAnalytic.zScale X) ≤ roughDyadicCount X 1 t / t :=
    (hblock X hXbase t htlo hthi htpos).trans (roughBlockRecip_le X 1 htpos)
  have hmul :
      (c / Real.log (EscAnalytic.zScale X)) * t ≤
        (roughDyadicCount X 1 t / t) * t :=
    mul_le_mul_of_nonneg_right hto_count_div htpos.le
  calc
    c * (t / Real.log (EscAnalytic.zScale X))
        = (c / Real.log (EscAnalytic.zScale X)) * t := by ring
    _ ≤ (roughDyadicCount X 1 t / t) * t := hmul
    _ = roughDyadicCount X 1 t := by
          field_simp [ne_of_gt htpos]

/-- A no-extra-modulus count lower core gives the corresponding block-reciprocal
lower core.  The only loss is the dyadic factor `2` from
`count / (2t) ≤ roughBlockRecip`. -/
theorem roughBlockRecipModulusOneLowerBoundCore_of_countLowerBoundCore
    {a₀ b₀ : ℝ}
    (h : roughDyadicCountModulusOneLowerBoundCore a₀ b₀) :
    roughBlockRecipModulusOneLowerBoundCore a₀ b₀ := by
  rcases h with ⟨c, Xbase, hc, hcount⟩
  refine ⟨c / 2, max Xbase (Real.exp 2), half_pos hc, ?_⟩
  intro X hX t htlo hthi htpos
  have hXbase : Xbase ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hlogZ_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp
  have hcnt := hcount X hXbase t htlo hthi
  have hscaled :
      (c * (t / Real.log (EscAnalytic.zScale X))) / (2 * t)
        ≤ roughDyadicCount X 1 t / (2 * t) :=
    div_le_div_of_nonneg_right hcnt (mul_pos (by norm_num) htpos).le
  calc
    (c / 2) / Real.log (EscAnalytic.zScale X)
        = (c * (t / Real.log (EscAnalytic.zScale X))) / (2 * t) := by
          field_simp [ne_of_gt htpos, ne_of_gt hlogZ_pos]
          ring
    _ ≤ roughDyadicCount X 1 t / (2 * t) := hscaled
    _ ≤ roughBlockRecip X 1 t := roughBlockRecip_ge X 1 htpos

/-- The no-extra-modulus lower count core and lower block-reciprocal core have
the same analytic content, up to the harmless dyadic factor `2`. -/
theorem roughDyadicCountModulusOneLowerBoundCore_iff_roughBlockRecipModulusOneLower
    (a₀ b₀ : ℝ) :
    roughDyadicCountModulusOneLowerBoundCore a₀ b₀ ↔
      roughBlockRecipModulusOneLowerBoundCore a₀ b₀ := by
  constructor
  · exact roughBlockRecipModulusOneLowerBoundCore_of_countLowerBoundCore
  · exact roughDyadicCountModulusOneLowerBoundCore_of_roughBlockRecipModulusOneLower

/-- A no-extra-modulus block-reciprocal upper bound implies the corresponding
no-extra-modulus count upper core.  The only loss is the dyadic factor `2` from
`count / (2t) ≤ roughBlockRecip`. -/
theorem roughDyadicCountModulusOneUpperBoundCore_of_roughBlockRecipModulusOneUpper
    {a₀ b₀ : ℝ}
    (h : roughBlockRecipModulusOneUpperBoundCore a₀ b₀) :
    roughDyadicCountModulusOneUpperBoundCore a₀ b₀ := by
  rcases h with ⟨C, Xbase, hC, hblock⟩
  refine ⟨2 * C, max Xbase (Real.exp 1), by positivity, ?_⟩
  intro X hX t htlo hthi
  have hXbase : Xbase ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 1 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 1) hXexp
  have htpos : 0 < t := lt_of_lt_of_le (Real.rpow_pos_of_pos hXpos a₀) htlo
  have htwo_t_pos : 0 < 2 * t := mul_pos (by norm_num) htpos
  have hcount_div_to :
      roughDyadicCount X 1 t / (2 * t) ≤
        C / Real.log (EscAnalytic.zScale X) :=
    (roughBlockRecip_ge X 1 htpos).trans (hblock X hXbase t htlo hthi htpos)
  have hmul :
      (roughDyadicCount X 1 t / (2 * t)) * (2 * t) ≤
        (C / Real.log (EscAnalytic.zScale X)) * (2 * t) :=
    mul_le_mul_of_nonneg_right hcount_div_to htwo_t_pos.le
  calc
    roughDyadicCount X 1 t
        = (roughDyadicCount X 1 t / (2 * t)) * (2 * t) := by
          field_simp [ne_of_gt htwo_t_pos]
    _ ≤ (C / Real.log (EscAnalytic.zScale X)) * (2 * t) := hmul
    _ = (2 * C) * (t / Real.log (EscAnalytic.zScale X)) := by ring

/-- A no-extra-modulus count upper core gives the corresponding block-reciprocal
upper core by the finite carrier inequality `roughBlockRecip ≤ count / t`. -/
theorem roughBlockRecipModulusOneUpperBoundCore_of_countUpperBoundCore
    {a₀ b₀ : ℝ}
    (h : roughDyadicCountModulusOneUpperBoundCore a₀ b₀) :
    roughBlockRecipModulusOneUpperBoundCore a₀ b₀ := by
  rcases h with ⟨C, Xbase, hC, hcount⟩
  refine ⟨C, max Xbase (Real.exp 2), hC, ?_⟩
  intro X hX t htlo hthi htpos
  have hXbase : Xbase ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hlogZ_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp
  have hcnt := hcount X hXbase t htlo hthi
  have hscaled :
      roughDyadicCount X 1 t / t
        ≤ (C * (t / Real.log (EscAnalytic.zScale X))) / t :=
    div_le_div_of_nonneg_right hcnt htpos.le
  calc
    roughBlockRecip X 1 t
        ≤ roughDyadicCount X 1 t / t := roughBlockRecip_le X 1 htpos
    _ ≤ (C * (t / Real.log (EscAnalytic.zScale X))) / t := hscaled
    _ = C / Real.log (EscAnalytic.zScale X) := by
          field_simp [ne_of_gt htpos, ne_of_gt hlogZ_pos]
          ring

/-- The no-extra-modulus upper count core and upper block-reciprocal core have
the same analytic content, up to the harmless dyadic factor `2`. -/
theorem roughDyadicCountModulusOneUpperBoundCore_iff_roughBlockRecipModulusOneUpper
    (a₀ b₀ : ℝ) :
    roughDyadicCountModulusOneUpperBoundCore a₀ b₀ ↔
      roughBlockRecipModulusOneUpperBoundCore a₀ b₀ := by
  constructor
  · exact roughBlockRecipModulusOneUpperBoundCore_of_countUpperBoundCore
  · exact roughDyadicCountModulusOneUpperBoundCore_of_roughBlockRecipModulusOneUpper

/-- Two-sided no-extra-modulus rough dyadic count target.  This packages the
one-sided count cores into the single linear-sieve statement exposed to
downstream carrier conversions. -/
def roughDyadicCountModulusOneBoundCore (a₀ b₀ : ℝ) : Prop :=
  roughDyadicCountModulusOneLowerBoundCore a₀ b₀ ∧
    roughDyadicCountModulusOneUpperBoundCore a₀ b₀

/-- Two-sided no-extra-modulus dyadic block-reciprocal target. -/
def roughBlockRecipModulusOneBoundCore (a₀ b₀ : ℝ) : Prop :=
  roughBlockRecipModulusOneLowerBoundCore a₀ b₀ ∧
    roughBlockRecipModulusOneUpperBoundCore a₀ b₀

/-- A two-sided no-extra-modulus block-reciprocal bound gives the corresponding
two-sided count core. -/
theorem roughDyadicCountModulusOneBoundCore_of_roughBlockRecipModulusOneBound
    {a₀ b₀ : ℝ}
    (h : roughBlockRecipModulusOneBoundCore a₀ b₀) :
    roughDyadicCountModulusOneBoundCore a₀ b₀ := by
  rcases h with ⟨hlower, hupper⟩
  exact
    ⟨roughDyadicCountModulusOneLowerBoundCore_of_roughBlockRecipModulusOneLower hlower,
      roughDyadicCountModulusOneUpperBoundCore_of_roughBlockRecipModulusOneUpper hupper⟩

/-- A two-sided no-extra-modulus count core gives the corresponding two-sided
block-reciprocal target. -/
theorem roughBlockRecipModulusOneBoundCore_of_countBoundCore
    {a₀ b₀ : ℝ}
    (h : roughDyadicCountModulusOneBoundCore a₀ b₀) :
    roughBlockRecipModulusOneBoundCore a₀ b₀ := by
  rcases h with ⟨hlower, hupper⟩
  exact
    ⟨roughBlockRecipModulusOneLowerBoundCore_of_countLowerBoundCore hlower,
      roughBlockRecipModulusOneUpperBoundCore_of_countUpperBoundCore hupper⟩

/-- The two-sided no-extra-modulus count and block-reciprocal targets have the
same analytic content, up to absolute dyadic constants. -/
theorem roughDyadicCountModulusOneBoundCore_iff_roughBlockRecipModulusOneBound
    (a₀ b₀ : ℝ) :
    roughDyadicCountModulusOneBoundCore a₀ b₀ ↔
      roughBlockRecipModulusOneBoundCore a₀ b₀ := by
  constructor
  · exact roughBlockRecipModulusOneBoundCore_of_countBoundCore
  · exact roughDyadicCountModulusOneBoundCore_of_roughBlockRecipModulusOneBound

/-- Two-sided explicit no-extra-modulus inclusion-exclusion product-count
target. -/
def roughDyadicBadPrimeProductCountModulusOneBoundCore
    (a₀ b₀ : ℝ) : Prop :=
  roughDyadicBadPrimeProductCountModulusOneLowerBoundCore a₀ b₀ ∧
    roughDyadicBadPrimeProductCountModulusOneUpperBoundCore a₀ b₀

/-- The two-sided modulus-one count core implies the two-sided explicit
inclusion-exclusion product-count core. -/
theorem roughDyadicBadPrimeProductCountModulusOneBoundCore_of_countBoundCore
    {a₀ b₀ : ℝ}
    (h : roughDyadicCountModulusOneBoundCore a₀ b₀) :
    roughDyadicBadPrimeProductCountModulusOneBoundCore a₀ b₀ := by
  rcases h with ⟨hlower, hupper⟩
  exact
    ⟨roughDyadicBadPrimeProductCountModulusOneLowerBoundCore_of_countLowerBoundCore hlower,
      roughDyadicBadPrimeProductCountModulusOneUpperBoundCore_of_countUpperBoundCore hupper⟩

/-- The two-sided explicit inclusion-exclusion product-count core implies the
two-sided modulus-one count core. -/
theorem roughDyadicCountModulusOneBoundCore_of_productCountBoundCore
    {a₀ b₀ : ℝ}
    (h : roughDyadicBadPrimeProductCountModulusOneBoundCore a₀ b₀) :
    roughDyadicCountModulusOneBoundCore a₀ b₀ := by
  rcases h with ⟨hlower, hupper⟩
  exact
    ⟨roughDyadicCountModulusOneLowerBoundCore_of_productCountLowerBoundCore hlower,
      roughDyadicCountModulusOneUpperBoundCore_of_productCountUpperBoundCore hupper⟩

/-- The two modulus-one count cores are exactly equivalent to the two-sided
explicit no-extra-modulus inclusion-exclusion product-count target. -/
theorem roughDyadicCountModulusOneBoundCore_iff_productCountBoundCore
    (a₀ b₀ : ℝ) :
    roughDyadicCountModulusOneBoundCore a₀ b₀ ↔
      roughDyadicBadPrimeProductCountModulusOneBoundCore a₀ b₀ := by
  constructor
  · exact roughDyadicBadPrimeProductCountModulusOneBoundCore_of_countBoundCore
  · exact roughDyadicCountModulusOneBoundCore_of_productCountBoundCore

/-- The dyadic rough reciprocal block is dominated by the corresponding
Selberg carrier with trivial congruence modulus and auxiliary coprimality
modulus.  The Selberg carrier omits the squarefree filter, so this is a direct
finite-set inclusion. -/
theorem roughBlockRecip_le_selbergSum_auxiliary
    (X : ℝ) (M : ℕ) (t : ℝ) :
    roughBlockRecip X M t ≤
      selbergSum X 1 0 (auxiliaryModulus M) t (2 * t) := by
  classical
  unfold roughBlockRecip roughBlockCarrier selbergSum
  apply Finset.sum_le_sum_of_subset_of_nonneg
  · intro n hn
    rw [Finset.mem_filter] at hn ⊢
    exact ⟨hn.1, by
      refine ⟨?_, hn.2.2.1, hn.2.2.2⟩
      exact Nat.mod_one n⟩
  · intro n _hnBig _hnSmall
    exact div_nonneg zero_le_one (Nat.cast_nonneg n)

/-- Adding an auxiliary coprimality modulus can only shrink the Selberg carrier.
The no-extra-modulus carrier with `M = 1` is therefore the largest member of
the family used in the rough dyadic upper route. -/
theorem selbergSum_le_modulus_one_auxiliary
    (X : ℝ) (M : ℕ) (t : ℝ) :
    selbergSum X 1 0 (auxiliaryModulus M) t (2 * t) ≤
      selbergSum X 1 0 1 t (2 * t) := by
  classical
  unfold selbergSum
  apply Finset.sum_le_sum_of_subset_of_nonneg
  · intro n hn
    rw [Finset.mem_filter] at hn ⊢
    exact ⟨hn.1, hn.2.1, hn.2.2.1, by simp⟩
  · intro n _hnBig _hnSmall
    exact div_nonneg zero_le_one (Nat.cast_nonneg n)

/-- Selberg-block upper target for the rough dyadic count.  This is a concrete
one-sided replacement target: it asks only for a `1 / log z(X)` upper bound on
the exact dyadic Selberg reciprocal carrier that contains the rough block. -/
def roughDyadicSelbergBlockUpperBound (a₀ b₀ C₀ : ℝ) : Prop :=
  ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
      selbergSum X 1 0 (auxiliaryModulus M) t (2 * t) ≤
        C / Real.log (EscAnalytic.zScale X)

/-- No-extra-modulus Selberg-block upper target.  This is the actual analytic
sieve saving needed on the upper side; uniformity in the auxiliary modulus is
then theorem-level because extra coprimality only shrinks the carrier. -/
def roughDyadicSelbergBlockModulusOneUpperBoundCore (a₀ b₀ : ℝ) : Prop :=
  ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
      selbergSum X 1 0 1 t (2 * t) ≤
        C / Real.log (EscAnalytic.zScale X)

/-- Backward-compatible parameter-shaped wrapper for the no-extra-modulus
Selberg block upper target.  The auxiliary growth exponent is irrelevant before
the auxiliary modulus is introduced. -/
def roughDyadicSelbergBlockModulusOneUpperBound (a₀ b₀ _C₀ : ℝ) : Prop :=
  roughDyadicSelbergBlockModulusOneUpperBoundCore a₀ b₀

/-- Weighted small-divisor dual form of the no-extra-modulus Selberg-block
upper target.

This is the finite inequality that would close the upper rough-sieve primitive:
the already checked lower bound for `smallDivisorEulerSum` supplies the
`log z(X)` denominator, while this dual estimate supplies the bounded weighted
Selberg block. -/
def roughDyadicSelbergBlockSmallDivisorDualBound (a₀ b₀ : ℝ) : Prop :=
  ∃ B X₀ : ℝ, 0 < B ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
      smallDivisorEulerSum X * selbergSum X 1 0 1 t (2 * t) ≤ B

/-- The core no-extra-modulus Selberg upper target gives the parameter-shaped
wrapper. -/
theorem roughDyadicSelbergBlockModulusOneUpperBound_of_core
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicSelbergBlockModulusOneUpperBoundCore a₀ b₀) :
    roughDyadicSelbergBlockModulusOneUpperBound a₀ b₀ C₀ :=
  h

/-- Forget the irrelevant auxiliary-growth exponent from the parameter-shaped
no-extra-modulus Selberg upper target. -/
theorem roughDyadicSelbergBlockModulusOneUpperBound_core_of_bound
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicSelbergBlockModulusOneUpperBound a₀ b₀ C₀) :
    roughDyadicSelbergBlockModulusOneUpperBoundCore a₀ b₀ :=
  h

/-- The weighted small-divisor dual inequality implies the no-extra-modulus
Selberg-block upper bound.  The only analytic lower input used here is the
already formalized logarithmic lower bound for `smallDivisorEulerSum`; all other
steps are positivity and algebra. -/
theorem roughDyadicSelbergBlockModulusOneUpperBoundCore_of_smallDivisorDual
    {a₀ b₀ : ℝ}
    (hdual : roughDyadicSelbergBlockSmallDivisorDualBound a₀ b₀) :
    roughDyadicSelbergBlockModulusOneUpperBoundCore a₀ b₀ := by
  rcases hdual with ⟨B, Xdual, hB, hdual⟩
  rcases smallDivisorEulerSum_lower_bound with ⟨c, Xlow, hc, hlow⟩
  refine ⟨B / c, max (max Xdual Xlow) (Real.exp 2),
    div_pos hB hc, ?_⟩
  intro X hX t htlo hthi
  have hXdual : Xdual ≤ X := le_trans (le_max_left _ _)
    (le_trans (le_max_left _ _) hX)
  have hXlow : Xlow ≤ X := le_trans (le_max_right _ _)
    (le_trans (le_max_left _ _) hX)
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 2) hXexp
  have htpos : 0 < t := lt_of_lt_of_le (Real.rpow_pos_of_pos hXpos a₀) htlo
  have hlog_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp
  let S : ℝ := selbergSum X 1 0 1 t (2 * t)
  have hS_nonneg : 0 ≤ S := by
    dsimp [S]
    exact selbergSum_nonneg X 1 0 1 t (2 * t)
  have hsmall_lower :
      c * Real.log (EscAnalytic.zScale X) ≤ smallDivisorEulerSum X :=
    hlow X hXlow
  have hweighted :
      smallDivisorEulerSum X * S ≤ B := by
    dsimp [S]
    exact hdual X hXdual t htlo hthi htpos
  have hscaled :
      (c * Real.log (EscAnalytic.zScale X)) * S ≤ B :=
    (mul_le_mul_of_nonneg_right hsmall_lower hS_nonneg).trans hweighted
  have hden_pos : 0 < c * Real.log (EscAnalytic.zScale X) :=
    mul_pos hc hlog_pos
  have hS_le : S ≤ B / (c * Real.log (EscAnalytic.zScale X)) := by
    rw [le_div_iff₀ hden_pos]
    simpa [mul_comm, mul_left_comm, mul_assoc] using hscaled
  calc
    selbergSum X 1 0 1 t (2 * t)
        = S := rfl
    _ ≤ B / (c * Real.log (EscAnalytic.zScale X)) := hS_le
    _ = (B / c) / Real.log (EscAnalytic.zScale X) := by
          field_simp [ne_of_gt hc, ne_of_gt hlog_pos]

/-- Conversely, a no-extra-modulus Selberg-block upper bound implies the
weighted small-divisor dual form.  This uses only the already formalized
upper bound `smallDivisorEulerSum X = O(log z(X))`; hence the weighted dual and
the Selberg block upper target have the same analytic content. -/
theorem roughDyadicSelbergBlockSmallDivisorDualBound_of_modulusOneUpper
    {a₀ b₀ : ℝ}
    (hblock : roughDyadicSelbergBlockModulusOneUpperBoundCore a₀ b₀) :
    roughDyadicSelbergBlockSmallDivisorDualBound a₀ b₀ := by
  rcases hblock with ⟨Cblock, Xblock, hCblock, hblock⟩
  rcases smallDivisorEulerSum_upper_unconditional with
    ⟨Csmall, Xsmall, hCsmall, hsmall⟩
  refine ⟨Csmall * Cblock, max (max Xblock Xsmall) (Real.exp 2),
    mul_pos hCsmall hCblock, ?_⟩
  intro X hX t htlo hthi _htpos
  have hXblock : Xblock ≤ X := le_trans (le_max_left _ _)
    (le_trans (le_max_left _ _) hX)
  have hXsmall : Xsmall ≤ X := le_trans (le_max_right _ _)
    (le_trans (le_max_left _ _) hX)
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hlog_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp
  let S : ℝ := selbergSum X 1 0 1 t (2 * t)
  have hS_nonneg : 0 ≤ S := by
    dsimp [S]
    exact selbergSum_nonneg X 1 0 1 t (2 * t)
  have hsmall_upper :
      smallDivisorEulerSum X ≤
        Csmall * Real.log (EscAnalytic.zScale X) :=
    hsmall X hXsmall
  have hblock_upper :
      S ≤ Cblock / Real.log (EscAnalytic.zScale X) := by
    dsimp [S]
    exact hblock X hXblock t htlo hthi
  have hscale_nonneg :
      0 ≤ Csmall * Real.log (EscAnalytic.zScale X) :=
    mul_nonneg hCsmall.le hlog_pos.le
  calc
    smallDivisorEulerSum X * S
        ≤ (Csmall * Real.log (EscAnalytic.zScale X)) * S :=
          mul_le_mul_of_nonneg_right hsmall_upper hS_nonneg
    _ ≤ (Csmall * Real.log (EscAnalytic.zScale X)) *
          (Cblock / Real.log (EscAnalytic.zScale X)) :=
          mul_le_mul_of_nonneg_left hblock_upper hscale_nonneg
    _ = Csmall * Cblock := by
          field_simp [ne_of_gt hlog_pos]
          ring

/-- The weighted small-divisor/Selberg dual and the no-extra-modulus Selberg
block upper estimate are equivalent.  The two directions use, respectively,
the lower and upper theorem-level bounds for `smallDivisorEulerSum`. -/
theorem roughDyadicSelbergBlockSmallDivisorDualBound_iff_modulusOneUpper
    (a₀ b₀ : ℝ) :
    roughDyadicSelbergBlockSmallDivisorDualBound a₀ b₀ ↔
      roughDyadicSelbergBlockModulusOneUpperBoundCore a₀ b₀ := by
  constructor
  · exact roughDyadicSelbergBlockModulusOneUpperBoundCore_of_smallDivisorDual
  · exact roughDyadicSelbergBlockSmallDivisorDualBound_of_modulusOneUpper

/-- The no-extra-modulus Selberg block bound implies the auxiliary-uniform
Selberg block bound by finite carrier inclusion. -/
theorem roughDyadicSelbergBlockUpperBound_of_modulusOne
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicSelbergBlockModulusOneUpperBound a₀ b₀ C₀) :
    roughDyadicSelbergBlockUpperBound a₀ b₀ C₀ := by
  rcases h with ⟨C, X₀, hC, hblock⟩
  refine ⟨C, X₀, hC, ?_⟩
  intro X hX M _hM t htlo hthi
  exact (selbergSum_le_modulus_one_auxiliary X M t).trans
    (hblock X hX t htlo hthi)

/-- A dyadic Selberg reciprocal upper bound proves the upper half of the rough
dyadic count target.  The only loss is the factor `2`, from
`count/(2t) ≤ block reciprocal sum`. -/
theorem roughDyadicCountUpperBound_of_selbergBlockUpper
    {a₀ b₀ C₀ : ℝ} (_ha₀ : 0 < a₀)
    (hSelberg : roughDyadicSelbergBlockUpperBound a₀ b₀ C₀) :
    roughDyadicCountUpperBound a₀ b₀ C₀ := by
  rcases hSelberg with ⟨C, Xbase, hC, hSelberg⟩
  refine ⟨2 * C, max Xbase (Real.exp 1), by positivity, ?_⟩
  intro X hX M hM t htlo hthi
  have hXbase : Xbase ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 1 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 1) hXexp
  have htpos : 0 < t := lt_of_lt_of_le (Real.rpow_pos_of_pos hXpos a₀) htlo
  have htwo_t_pos : 0 < 2 * t := mul_pos (by norm_num) htpos
  have hblock_ge := roughBlockRecip_ge X M htpos
  have hselberg :=
    (roughBlockRecip_le_selbergSum_auxiliary X M t).trans
      (hSelberg X hXbase M hM t htlo hthi)
  have hcount_scaled :
      roughDyadicCount X M t ≤
        (2 * t) * roughBlockRecip X M t := by
    have hmul :
        (roughDyadicCount X M t / (2 * t)) * (2 * t) ≤
          roughBlockRecip X M t * (2 * t) :=
      mul_le_mul_of_nonneg_right hblock_ge htwo_t_pos.le
    calc
      roughDyadicCount X M t
          = (roughDyadicCount X M t / (2 * t)) * (2 * t) := by
            field_simp [ne_of_gt htwo_t_pos]
      _ ≤ roughBlockRecip X M t * (2 * t) := hmul
      _ = (2 * t) * roughBlockRecip X M t := by ring
  calc
    roughDyadicCount X M t
        ≤ (2 * t) * roughBlockRecip X M t := hcount_scaled
    _ ≤ (2 * t) * (C / Real.log (EscAnalytic.zScale X)) :=
        mul_le_mul_of_nonneg_left hselberg htwo_t_pos.le
    _ = (2 * C) * (t / Real.log (EscAnalytic.zScale X)) := by ring

/-- No-extra-modulus Selberg-block control proves the no-extra-modulus upper
count core.  This keeps all finite carrier comparisons theorem-level: the
Selberg carrier contains the rough reciprocal block, the block controls the
dyadic count up to the dyadic factor `2`, and the auxiliary parameter is
specialized to `M = 1`. -/
theorem roughDyadicCountModulusOneUpperBoundCore_of_selbergBlockModulusOneUpper
    {a₀ b₀ : ℝ} (ha₀ : 0 < a₀)
    (hSelberg : roughDyadicSelbergBlockModulusOneUpperBoundCore a₀ b₀) :
    roughDyadicCountModulusOneUpperBoundCore a₀ b₀ :=
  roughDyadicCountModulusOneUpperBoundCore_of_countUpperBound
    (roughDyadicCountUpperBound_of_selbergBlockUpper (C₀ := 0) ha₀
      (roughDyadicSelbergBlockUpperBound_of_modulusOne
        (roughDyadicSelbergBlockModulusOneUpperBound_of_core hSelberg)))

/-- The reciprocal mass of a positive dyadic block is at most `2`, before using
any rough-sieve saving.  This is the finite-window consequence of
`roughBlockRecip_le` and the ambient count bound
`roughDyadicCount X M t ≤ 2t`. -/
theorem roughBlockRecip_le_two (X : ℝ) (M : ℕ) {t : ℝ} (ht : 0 < t) :
    roughBlockRecip X M t ≤ 2 := by
  have hcount : roughDyadicCount X M t ≤ 2 * t :=
    roughDyadicCount_le_two_mul X M ht.le
  have hdiv : roughDyadicCount X M t / t ≤ (2 * t) / t :=
    div_le_div_of_nonneg_right hcount ht.le
  have hblock := roughBlockRecip_le X M ht
  calc
    roughBlockRecip X M t ≤ roughDyadicCount X M t / t := hblock
    _ ≤ (2 * t) / t := hdiv
    _ = 2 := by field_simp [ne_of_gt ht]

/-- Absolute-value form of the foundation-only dyadic block reciprocal bound. -/
theorem abs_roughBlockRecip_le_two (X : ℝ) (M : ℕ) {t : ℝ} (ht : 0 < t) :
    |roughBlockRecip X M t| ≤ 2 := by
  rw [abs_of_nonneg (roughBlockRecip_nonneg X M t)]
  exact roughBlockRecip_le_two X M ht

/-- Parameter-shaped axiom-free upper fallback for dyadic rough block
reciprocals.  This proves the finite-window estimate `O(1)` on every positive
block in the same range used by the linear-sieve input; it does not include the
`1/log z` saving. -/
theorem roughBlockRecip_upper_unconditional_with_carrier_bounds
    (a₀ b₀ C₀ : ℝ) (_ha₀ : 0 < a₀) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
        0 ≤ roughBlockRecip X M t ∧
          roughBlockRecip X M t ≤ C ∧
          |roughBlockRecip X M t| ≤ C := by
  refine ⟨2, 1, by norm_num, ?_⟩
  intro X _hX M _hM t _htlo _hthi htpos
  have hnonneg := roughBlockRecip_nonneg X M t
  have hupper := roughBlockRecip_le_two X M htpos
  exact ⟨hnonneg, hupper, by
    rw [abs_of_nonneg hnonneg]
    exact hupper⟩

/-- A bare dyadic block-reciprocal upper fallback gives the carrier-bundled
version with nonnegativity and absolute-value side conditions. -/
theorem roughBlockRecip_upper_unconditional_with_carrier_bounds_of_bound
    (a₀ b₀ C₀ : ℝ)
    (h :
      ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
        ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
          roughBlockRecip X M t ≤ C) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
        0 ≤ roughBlockRecip X M t ∧
          roughBlockRecip X M t ≤ C ∧
          |roughBlockRecip X M t| ≤ C := by
  rcases h with ⟨C, X₀, hC, hupper⟩
  refine ⟨C, X₀, hC, ?_⟩
  intro X hX M hM t htlo hthi htpos
  have hnonneg := roughBlockRecip_nonneg X M t
  have hbound := hupper X hX M hM t htlo hthi htpos
  exact ⟨hnonneg, hbound, by
    rw [abs_of_nonneg hnonneg]
    exact hbound⟩

/-- Forget the checked side conditions from a bundled dyadic
block-reciprocal upper fallback. -/
theorem roughBlockRecip_upper_unconditional_bound_of_carrier_bounds
    (a₀ b₀ C₀ : ℝ)
    (h :
      ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
        ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
          0 ≤ roughBlockRecip X M t ∧
            roughBlockRecip X M t ≤ C ∧
            |roughBlockRecip X M t| ≤ C) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
        roughBlockRecip X M t ≤ C := by
  rcases h with ⟨C, X₀, hC, hcarrier⟩
  refine ⟨C, X₀, hC, ?_⟩
  intro X hX M hM t htlo hthi htpos
  exact (hcarrier X hX M hM t htlo hthi htpos).2.1

/-- Bare and carrier-bundled dyadic block-reciprocal upper fallbacks have the
same analytic content. -/
theorem roughBlockRecip_upper_unconditional_bound_iff_carrier_bounds
    (a₀ b₀ C₀ : ℝ) :
    (∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
        roughBlockRecip X M t ≤ C) ↔
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
        0 ≤ roughBlockRecip X M t ∧
          roughBlockRecip X M t ≤ C ∧
          |roughBlockRecip X M t| ≤ C := by
  constructor
  · exact roughBlockRecip_upper_unconditional_with_carrier_bounds_of_bound a₀ b₀ C₀
  · exact roughBlockRecip_upper_unconditional_bound_of_carrier_bounds a₀ b₀ C₀

/-- Parameter-shaped axiom-free block reciprocal upper fallback, with `log z`
positivity bundled for callers that normalize by the sieve logarithm. -/
theorem roughBlockRecip_upper_unconditional_with_log_carrier_bounds
    (a₀ b₀ C₀ : ℝ) (ha₀ : 0 < a₀) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ → 0 < t →
        0 < Real.log (EscAnalytic.zScale X) ∧
          0 ≤ roughBlockRecip X M t ∧
          roughBlockRecip X M t ≤ C ∧
          |roughBlockRecip X M t| ≤ C := by
  rcases roughBlockRecip_upper_unconditional_with_carrier_bounds
      a₀ b₀ C₀ ha₀ with
    ⟨C, Xbase, hC, hupper⟩
  refine ⟨C, max Xbase (Real.exp 2), hC, ?_⟩
  intro X hX M hM t htlo hthi htpos
  have hXbase : Xbase ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  exact ⟨log_zScale_pos_of_exp_two_le hXexp,
    hupper X hXbase M hM t htlo hthi htpos⟩

/-- The dyadic anchor `t_k = X^a · 2^k`. -/
noncomputable def dyAnchor (X a : ℝ) (k : ℕ) : ℝ := X ^ a * 2 ^ k

theorem dyAnchor_pos {X a : ℝ} (hX : 0 < X) (k : ℕ) : 0 < dyAnchor X a k := by
  unfold dyAnchor
  positivity

/-- Doubling the anchor advances the dyadic index: `2 · t_k = t_{k+1}`. -/
theorem two_mul_dyAnchor (X a : ℝ) (k : ℕ) :
    2 * dyAnchor X a k = dyAnchor X a (k + 1) := by
  unfold dyAnchor
  rw [pow_succ]
  ring

/-- The dyadic blocks at the anchors `t_k = X^a·2^k` are pairwise disjoint:
on `(t_j, 2t_j]` with `2t_j = t_{j+1} ≤ t_k` they cannot overlap `(t_k, 2t_k]`. -/
theorem roughBlock_pairwiseDisjoint (X : ℝ) (M : ℕ) (a : ℝ) (hX : 0 < X) (s : Finset ℕ) :
    Set.PairwiseDisjoint (↑s)
      (fun k => roughBlockCarrier X M (dyAnchor X a k)) := by
  classical
  -- Key one-sided fact: for `j < k`, the blocks are disjoint.
  have key : ∀ j k : ℕ, j < k →
      Disjoint (roughBlockCarrier X M (dyAnchor X a j))
        (roughBlockCarrier X M (dyAnchor X a k)) := by
    intro j k hlt
    rw [Finset.disjoint_left]
    intro n hnj hnk
    have hmemj := mem_roughBlockCarrier.mp hnj
    have hmemk := mem_roughBlockCarrier.mp hnk
    have hjle : (n : ℝ) ≤ 2 * dyAnchor X a j := hmemj.1.2.1
    have hklt : dyAnchor X a k < (n : ℝ) := hmemk.1.2.2
    rw [two_mul_dyAnchor] at hjle
    have hmono : dyAnchor X a (j + 1) ≤ dyAnchor X a k := by
      unfold dyAnchor
      have h2 : (2 : ℝ) ^ (j + 1) ≤ 2 ^ k :=
        pow_le_pow_right₀ (by norm_num) (by omega)
      have hxa : (0 : ℝ) ≤ X ^ a := le_of_lt (Real.rpow_pos_of_pos hX a)
      exact mul_le_mul_of_nonneg_left h2 hxa
    have : (n : ℝ) ≤ dyAnchor X a k := le_trans hjle hmono
    exact absurd hklt (not_lt.mpr this)
  intro j _hj k _hk hjk
  rcases lt_or_gt_of_ne hjk with h | h
  · exact key j k h
  · exact (key k j h).symm

/-- The rough squarefree carrier on the window `(X^a, X^b]`. -/
noncomputable def roughWindowCarrier (X : ℝ) (M : ℕ) (a b : ℝ) : Finset ℕ := by
  classical
  exact (natWindow (X ^ a) (X ^ b)).filter
    (fun n : ℕ => Squarefree n ∧
      Nat.Coprime n (roughModulus X) ∧ Nat.Coprime n (auxiliaryModulus M))

/-- `roughRecip` is the reciprocal sum over its window carrier. -/
theorem roughRecip_eq_sum_carrier (X : ℝ) (M : ℕ) (a b : ℝ) :
    roughRecip X M a b = ∑ n ∈ roughWindowCarrier X M a b, (1 : ℝ) / (n : ℝ) := by
  classical
  unfold roughRecip roughWindowCarrier
  rfl

/-- Membership in the window carrier. -/
theorem mem_roughWindowCarrier {X : ℝ} {M : ℕ} {a b : ℝ} {n : ℕ} :
    n ∈ roughWindowCarrier X M a b ↔
      (1 ≤ n ∧ (n : ℝ) ≤ X ^ b ∧ X ^ a < (n : ℝ)) ∧
        (Squarefree n ∧ Nat.Coprime n (roughModulus X) ∧
          Nat.Coprime n (auxiliaryModulus M)) := by
  classical
  unfold roughWindowCarrier natWindow
  rw [Finset.mem_filter, Finset.mem_filter, Finset.mem_Icc]
  constructor
  · rintro ⟨⟨⟨h1, h2⟩, h3⟩, hrough⟩
    have hfloor_pos : 1 ≤ ⌊X ^ b⌋₊ := le_trans h1 h2
    have hb_nonneg : (0 : ℝ) ≤ X ^ b := by
      by_contra hneg
      push_neg at hneg
      rw [Nat.floor_of_nonpos (le_of_lt hneg)] at hfloor_pos
      exact absurd hfloor_pos (by norm_num)
    exact ⟨⟨h1, (Nat.le_floor_iff hb_nonneg).mp h2, h3⟩, hrough⟩
  · rintro ⟨⟨h1, h2, h3⟩, hrough⟩
    have hb_nonneg : (0 : ℝ) ≤ X ^ b :=
      le_trans (by exact_mod_cast Nat.zero_le n) h2
    exact ⟨⟨⟨h1, (Nat.le_floor_iff hb_nonneg).mpr h2⟩, h3⟩, hrough⟩

/-- Enlarging the auxiliary coprimality modulus can only shrink the rough window
carrier. -/
theorem roughWindowCarrier_antitone_dvd
    (X : ℝ) {M₁ M₂ : ℕ} (a b : ℝ) (hM₂ : 0 < M₂) (hM : M₁ ∣ M₂) :
    roughWindowCarrier X M₂ a b ⊆ roughWindowCarrier X M₁ a b := by
  intro n hn
  have hmem := mem_roughWindowCarrier.mp hn
  exact mem_roughWindowCarrier.mpr
    ⟨hmem.1, hmem.2.1, hmem.2.2.1,
      hmem.2.2.2.coprime_dvd_right (auxiliaryModulus_dvd_of_dvd hM₂ hM)⟩

/-- The rough window with modulus `1` is the largest auxiliary-modulus window
carrier. -/
theorem roughWindowCarrier_subset_modulus_one (X : ℝ) (M : ℕ) (a b : ℝ) :
    roughWindowCarrier X M a b ⊆ roughWindowCarrier X 1 a b := by
  intro n hn
  have hmem := mem_roughWindowCarrier.mp hn
  exact mem_roughWindowCarrier.mpr
    ⟨hmem.1, hmem.2.1, hmem.2.2.1, by
      simp [auxiliaryModulus_one]⟩

/-- Monotonicity of the anchor in the dyadic index. -/
theorem dyAnchor_mono {X a : ℝ} (hX : 0 < X) {j k : ℕ} (h : j ≤ k) :
    dyAnchor X a j ≤ dyAnchor X a k := by
  unfold dyAnchor
  have h2 : (2 : ℝ) ^ j ≤ 2 ^ k := pow_le_pow_right₀ (by norm_num) h
  exact mul_le_mul_of_nonneg_left h2 (le_of_lt (Real.rpow_pos_of_pos hX a))

/-- **Lower covering.**  Every dyadic block `(t_k, 2t_k]` with `k < N'` lies
inside the window `(X^a, X^b]`, provided the last anchor `t_{N'}` reaches `X^b`.
Hence the disjoint union of these blocks is a subset of the window carrier. -/
theorem biUnion_roughBlock_subset_window
    (X : ℝ) (M : ℕ) (a b : ℝ) (hX : 0 < X) (N' : ℕ)
    (hreach : dyAnchor X a N' ≤ X ^ b) :
    (Finset.range N').biUnion
        (fun k => roughBlockCarrier X M (dyAnchor X a k))
      ⊆ roughWindowCarrier X M a b := by
  classical
  intro n hn
  rw [Finset.mem_biUnion] at hn
  rcases hn with ⟨k, hk, hnk⟩
  rw [Finset.mem_range] at hk
  have hmem := mem_roughBlockCarrier.mp hnk
  refine mem_roughWindowCarrier.mpr ⟨⟨hmem.1.1, ?_, ?_⟩, hmem.2⟩
  · -- upper: n ≤ 2 t_k = t_{k+1} ≤ t_{N'} ≤ X^b
    have h1 : (n : ℝ) ≤ 2 * dyAnchor X a k := hmem.1.2.1
    rw [two_mul_dyAnchor] at h1
    exact le_trans h1 (le_trans (dyAnchor_mono hX (by omega)) hreach)
  · -- lower: X^a = t_0 ≤ t_k < n
    have h2 : dyAnchor X a k < (n : ℝ) := hmem.1.2.2
    have h0 : X ^ a = dyAnchor X a 0 := by unfold dyAnchor; simp
    rw [h0]
    exact lt_of_le_of_lt (dyAnchor_mono hX (Nat.zero_le k)) h2

/-- **Upper covering.**  Every window element `X^a < n ≤ X^b` falls into some
dyadic block `(t_k, 2t_k]` with `k < N`, provided the last anchor `t_N` exceeds
`X^b`.  Hence the window carrier is a subset of the disjoint union of the first
`N` blocks. -/
theorem window_subset_biUnion_roughBlock
    (X : ℝ) (M : ℕ) (a b : ℝ) (_hX : 0 < X) (N : ℕ) (hN : 0 < N)
    (hreach : X ^ b ≤ dyAnchor X a N) :
    roughWindowCarrier X M a b
      ⊆ (Finset.range N).biUnion
        (fun k => roughBlockCarrier X M (dyAnchor X a k)) := by
  classical
  intro n hn
  have hmem := mem_roughWindowCarrier.mp hn
  have hn_le : (n : ℝ) ≤ X ^ b := hmem.1.2.1
  have hn_gt : X ^ a < (n : ℝ) := hmem.1.2.2
  -- `n ≤ X^b ≤ t_N = dyAnchor X a N`, so the predicate `P k : n ≤ t_{k+1}` holds at `k = N-1`.
  have hPN : (n : ℝ) ≤ dyAnchor X a ((N - 1) + 1) := by
    have : (N - 1) + 1 = N := by omega
    rw [this]
    exact le_trans hn_le hreach
  -- least such `k`.
  have hex : ∃ k, (n : ℝ) ≤ dyAnchor X a (k + 1) := ⟨N - 1, hPN⟩
  classical
  let k₀ := Nat.find hex
  have hk₀spec : (n : ℝ) ≤ dyAnchor X a (k₀ + 1) := Nat.find_spec hex
  have hk₀le : k₀ ≤ N - 1 := Nat.find_le hPN
  have hk₀lt : k₀ < N := by omega
  -- lower bound `t_{k₀} < n`.
  have hk₀gt : dyAnchor X a k₀ < (n : ℝ) := by
    rcases Nat.eq_zero_or_pos k₀ with hz | hpos
    · -- k₀ = 0: t_0 = X^a < n
      rw [hz]
      have h0 : dyAnchor X a 0 = X ^ a := by unfold dyAnchor; simp
      rw [h0]; exact hn_gt
    · -- k₀ > 0: minimality gives ¬ P (k₀-1), i.e. n > t_{(k₀-1)+1} = t_{k₀}
      have hnotprev : ¬ ((n : ℝ) ≤ dyAnchor X a ((k₀ - 1) + 1)) :=
        Nat.find_min hex (by omega)
      have : (k₀ - 1) + 1 = k₀ := by omega
      rw [this] at hnotprev
      exact lt_of_not_le hnotprev
  -- membership in block k₀.
  rw [Finset.mem_biUnion]
  refine ⟨k₀, Finset.mem_range.mpr hk₀lt, ?_⟩
  refine mem_roughBlockCarrier.mpr ⟨⟨hmem.1.1, ?_, hk₀gt⟩, hmem.2⟩
  -- upper: n ≤ t_{k₀+1} = 2 t_{k₀}
  rw [← two_mul_dyAnchor] at hk₀spec
  exact hk₀spec

/-- **Dyadic partial summation, upper half.**  The rough reciprocal sum is at most
the sum over the first `N` dyadic blocks of `count_k / t_k`. -/
theorem roughRecip_le_blockSum
    (X : ℝ) (M : ℕ) (a b : ℝ) (hX : 0 < X) (N : ℕ) (hN : 0 < N)
    (hreach : X ^ b ≤ dyAnchor X a N) :
    roughRecip X M a b
      ≤ ∑ k ∈ Finset.range N,
          roughDyadicCount X M (dyAnchor X a k) / dyAnchor X a k := by
  classical
  rw [roughRecip_eq_sum_carrier]
  have hsub := window_subset_biUnion_roughBlock X M a b hX N hN hreach
  have hdisj := roughBlock_pairwiseDisjoint X M a hX (Finset.range N)
  calc
    ∑ n ∈ roughWindowCarrier X M a b, (1 : ℝ) / (n : ℝ)
        ≤ ∑ n ∈ (Finset.range N).biUnion
            (fun k => roughBlockCarrier X M (dyAnchor X a k)), (1 : ℝ) / (n : ℝ) := by
          apply Finset.sum_le_sum_of_subset_of_nonneg hsub
          intro n _ _
          exact div_nonneg zero_le_one (Nat.cast_nonneg n)
    _ = ∑ k ∈ Finset.range N, roughBlockRecip X M (dyAnchor X a k) := by
          rw [Finset.sum_biUnion hdisj]; rfl
    _ ≤ ∑ k ∈ Finset.range N,
          roughDyadicCount X M (dyAnchor X a k) / dyAnchor X a k := by
          apply Finset.sum_le_sum
          intro k _
          exact roughBlockRecip_le X M (dyAnchor_pos hX k)

/-- Upper dyadic partial summation at block-reciprocal altitude: if the first
`N` dyadic blocks cover the window, the full rough reciprocal carrier is at
most the sum of those block reciprocal carriers. -/
theorem roughRecip_le_roughBlockRecipSum
    (X : ℝ) (M : ℕ) (a b : ℝ) (hX : 0 < X) (N : ℕ) (hN : 0 < N)
    (hreach : X ^ b ≤ dyAnchor X a N) :
    roughRecip X M a b
      ≤ ∑ k ∈ Finset.range N, roughBlockRecip X M (dyAnchor X a k) := by
  classical
  rw [roughRecip_eq_sum_carrier]
  have hsub := window_subset_biUnion_roughBlock X M a b hX N hN hreach
  have hdisj := roughBlock_pairwiseDisjoint X M a hX (Finset.range N)
  calc
    ∑ n ∈ roughWindowCarrier X M a b, (1 : ℝ) / (n : ℝ)
        ≤ ∑ n ∈ (Finset.range N).biUnion
            (fun k => roughBlockCarrier X M (dyAnchor X a k)), (1 : ℝ) / (n : ℝ) := by
          apply Finset.sum_le_sum_of_subset_of_nonneg hsub
          intro n _ _
          exact div_nonneg zero_le_one (Nat.cast_nonneg n)
    _ = ∑ k ∈ Finset.range N, roughBlockRecip X M (dyAnchor X a k) := by
          rw [Finset.sum_biUnion hdisj]
          rfl

/-- Foundation-only dyadic upper fallback for the rough reciprocal window.
If the first `N` dyadic blocks cover `(X^a, X^b]`, then the whole rough
reciprocal sum is at most `2N`.  This is weaker than the linear-sieve
`(log X)/(log z)` estimate, but all of its finite covering and reciprocal
bookkeeping is checked here. -/
theorem roughRecip_le_two_mul_numBlocks
    (X : ℝ) (M : ℕ) (a b : ℝ) (hX : 0 < X) (N : ℕ) (hN : 0 < N)
    (hreach : X ^ b ≤ dyAnchor X a N) :
    roughRecip X M a b ≤ 2 * (N : ℝ) := by
  classical
  rw [roughRecip_eq_sum_carrier]
  have hsub := window_subset_biUnion_roughBlock X M a b hX N hN hreach
  have hdisj := roughBlock_pairwiseDisjoint X M a hX (Finset.range N)
  calc
    ∑ n ∈ roughWindowCarrier X M a b, (1 : ℝ) / (n : ℝ)
        ≤ ∑ n ∈ (Finset.range N).biUnion
            (fun k => roughBlockCarrier X M (dyAnchor X a k)), (1 : ℝ) / (n : ℝ) := by
          apply Finset.sum_le_sum_of_subset_of_nonneg hsub
          intro n _ _
          exact div_nonneg zero_le_one (Nat.cast_nonneg n)
    _ = ∑ k ∈ Finset.range N, roughBlockRecip X M (dyAnchor X a k) := by
          rw [Finset.sum_biUnion hdisj]; rfl
    _ ≤ ∑ _k ∈ Finset.range N, (2 : ℝ) := by
          apply Finset.sum_le_sum
          intro k _
          exact roughBlockRecip_le_two X M (dyAnchor_pos hX k)
    _ = 2 * (N : ℝ) := by
          rw [Finset.sum_const, Finset.card_range, nsmul_eq_mul]
          ring

/-- Absolute-value form of the foundation-only dyadic window fallback. -/
theorem abs_roughRecip_le_two_mul_numBlocks
    (X : ℝ) (M : ℕ) (a b : ℝ) (hX : 0 < X) (N : ℕ) (hN : 0 < N)
    (hreach : X ^ b ≤ dyAnchor X a N) :
    |roughRecip X M a b| ≤ 2 * (N : ℝ) := by
  rw [abs_of_nonneg (roughRecip_nonneg X M a b)]
  exact roughRecip_le_two_mul_numBlocks X M a b hX N hN hreach

/-- **Dyadic partial summation, lower half.**  The rough reciprocal sum is at
least the sum over the first `N'` dyadic blocks (all inside the window) of
`count_k / (2 t_k)`. -/
theorem blockSum_le_roughRecip
    (X : ℝ) (M : ℕ) (a b : ℝ) (hX : 0 < X) (N' : ℕ)
    (hreach : dyAnchor X a N' ≤ X ^ b) :
    ∑ k ∈ Finset.range N',
        roughDyadicCount X M (dyAnchor X a k) / (2 * dyAnchor X a k)
      ≤ roughRecip X M a b := by
  classical
  rw [roughRecip_eq_sum_carrier]
  have hsub := biUnion_roughBlock_subset_window X M a b hX N' hreach
  have hdisj := roughBlock_pairwiseDisjoint X M a hX (Finset.range N')
  calc
    ∑ k ∈ Finset.range N',
        roughDyadicCount X M (dyAnchor X a k) / (2 * dyAnchor X a k)
        ≤ ∑ k ∈ Finset.range N', roughBlockRecip X M (dyAnchor X a k) := by
          apply Finset.sum_le_sum
          intro k _
          exact roughBlockRecip_ge X M (dyAnchor_pos hX k)
    _ = ∑ n ∈ (Finset.range N').biUnion
          (fun k => roughBlockCarrier X M (dyAnchor X a k)), (1 : ℝ) / (n : ℝ) := by
          rw [Finset.sum_biUnion hdisj]; rfl
    _ ≤ ∑ n ∈ roughWindowCarrier X M a b, (1 : ℝ) / (n : ℝ) := by
          apply Finset.sum_le_sum_of_subset_of_nonneg hsub
          intro n _ _
          exact div_nonneg zero_le_one (Nat.cast_nonneg n)

/-- Lower dyadic partial summation at block-reciprocal altitude: the reciprocal
mass of the first `N'` complete dyadic blocks is contained in the full window
reciprocal carrier. -/
theorem roughBlockRecipSum_le_roughRecip
    (X : ℝ) (M : ℕ) (a b : ℝ) (hX : 0 < X) (N' : ℕ)
    (hreach : dyAnchor X a N' ≤ X ^ b) :
    ∑ k ∈ Finset.range N', roughBlockRecip X M (dyAnchor X a k)
      ≤ roughRecip X M a b := by
  classical
  rw [roughRecip_eq_sum_carrier]
  have hsub := biUnion_roughBlock_subset_window X M a b hX N' hreach
  have hdisj := roughBlock_pairwiseDisjoint X M a hX (Finset.range N')
  calc
    ∑ k ∈ Finset.range N', roughBlockRecip X M (dyAnchor X a k)
        = ∑ n ∈ (Finset.range N').biUnion
          (fun k => roughBlockCarrier X M (dyAnchor X a k)), (1 : ℝ) / (n : ℝ) := by
          rw [Finset.sum_biUnion hdisj]
          rfl
    _ ≤ ∑ n ∈ roughWindowCarrier X M a b, (1 : ℝ) / (n : ℝ) := by
          apply Finset.sum_le_sum_of_subset_of_nonneg hsub
          intro n _ _
          exact div_nonneg zero_le_one (Nat.cast_nonneg n)

/-
Bare rough-sieve handoff: modulus-one lower and upper count estimates, with
theorem-level auxiliary transfers.

The public lower route is count-level: a lower estimate in the no-extra-modulus
lane is transferred to polynomial-size auxiliary moduli by the checked
large-prime tail argument.  The older sharp-Mertens/product-error decomposition
is retained below as a conditional theorem-level reduction toward that
modulus-one lower primitive, not as exported axioms.  The public upper route now
uses only the no-extra-modulus count upper estimate; auxiliary uniformity follows
from the checked fact that extra coprimality only shrinks the count.  The
stronger Selberg-block reciprocal carrier remains a conditional replacement
target, but is no longer a live axiom.

The reciprocal estimate `roughRecip ≍ (log X)/(log z)` of `lem:rough-sqf` is
derived from the lower and upper count-level handoffs by the checked dyadic
partial summation carried out in `rough_sqf_recip` below; it is no longer
assumed.
-/
/-- Sharp Mertens input for the rough-modulus prime reciprocals, derived
conditionally from the standard prime-reciprocal Mertens theorem and finite
prime-product bookkeeping.  This is retained as a reduction theorem, not as an
exported axiom of the public route. -/
theorem rough_modulus_prime_recip_sharp_mertens_upper_bound
    (hprime : PrimeRecipSharpMertensUpperBound) :
    roughModulusPrimeRecipSharpMertensUpperBound :=
  roughModulusPrimeRecipSharpMertensUpperBound_of_primeRecipSharpMertens
    hprime

/-- Conditional quarter-budget interface for the multiples-discrepancy component
of the rough dyadic product-error term.  This proposition is deliberately not an
axiom: it is stronger than the count-level lower-sieve primitive used by the
public route and is kept only for comparison/reduction theorems. -/
def LinearSieveRoughDyadicMultiplesErrorQuarterBound : Prop :=
  ∀ (a₀ b₀ C₀ c Xprod : ℝ), 0 < c →
    (∀ X : ℝ, Xprod ≤ X →
      c / Real.log (EscAnalytic.zScale X) ≤
        roughDyadicBadPrimeMainEulerProduct X) →
    ∃ Xm : ℝ,
      roughDyadicBadPrimeProductMultiplesLocalErrorEnvelopeBound
        a₀ b₀ C₀ (c / 4) Xm

/-- Conditional quarter-budget interface for the squarefree-loss component of
the rough dyadic product-error term.  This is retained as a named conditional
target, not as an exported axiom. -/
def LinearSieveRoughDyadicSquarefreeLossQuarterBound : Prop :=
  ∀ (a₀ b₀ C₀ c Xprod : ℝ), 0 < c →
    (∀ X : ℝ, Xprod ≤ X →
      c / Real.log (EscAnalytic.zScale X) ≤
        roughDyadicBadPrimeMainEulerProduct X) →
    ∃ Xs : ℝ,
      roughDyadicBadPrimeProductSquarefreeLossEnvelopeBound
        a₀ b₀ C₀ (c / 4) Xs

/-- Quarter-budget interface for the signed multiples-discrepancy component of
the no-extra-modulus rough dyadic product-error term.  Unlike the absolute
local-envelope target, this is stated in the cancellation-sensitive form used
by the live public route. -/

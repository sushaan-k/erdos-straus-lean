        roughDyadicBadPrimeMainEulerProduct X)
    (hm :
      roughDyadicBadPrimeProductMultiplesLocalErrorEnvelopeBound
        a₀ b₀ C₀ Em Xm)
    (hs :
      roughDyadicBadPrimeProductSquarefreeLossEnvelopeBound
        a₀ b₀ C₀ Es Xs)
    (ha :
      roughDyadicBadPrimeProductAuxiliaryPrimeMultiplesEnvelopeBound
        a₀ b₀ C₀ Ea Xa) :
    roughDyadicBadPrimeLowerEulerProductErrorBound a₀ b₀ C₀ :=
  roughDyadicBadPrimeLowerEulerProductErrorBound_of_productLower_and_error
    hc hE_lt hprod
    (roughDyadicBadPrimeProductErrorBound_of_multiples_squarefree_auxiliaryPrimeMultiples
      hm hs ha)

/-- Product-lower control plus separate multiples-discrepancy, squarefree-loss,
and explicit auxiliary-prime floor-envelope bounds give the lower
finite-product/error target. -/
theorem roughDyadicBadPrimeLowerEulerProductErrorBound_of_productLower_and_multiples_squarefree_auxiliaryPrimeMultiplesFloorEnvelope
    {a₀ b₀ C₀ c Em Es Ea Xprod Xm Xs Xa : ℝ}
    (hc : 0 < c) (hE_lt : Em + (Es + Ea) < c)
    (hprod : ∀ X : ℝ, Xprod ≤ X →
      c / Real.log (EscAnalytic.zScale X) ≤
        roughDyadicBadPrimeMainEulerProduct X)
    (hm :
      roughDyadicBadPrimeProductMultiplesLocalErrorEnvelopeBound
        a₀ b₀ C₀ Em Xm)
    (hs :
      roughDyadicBadPrimeProductSquarefreeLossEnvelopeBound
        a₀ b₀ C₀ Es Xs)
    (ha :
      roughDyadicBadPrimeProductAuxiliaryPrimeMultiplesFloorEnvelopeBound
        a₀ b₀ C₀ Ea Xa) :
    roughDyadicBadPrimeLowerEulerProductErrorBound a₀ b₀ C₀ :=
  roughDyadicBadPrimeLowerEulerProductErrorBound_of_productLower_and_error
    hc hE_lt hprod
    (roughDyadicBadPrimeProductErrorBound_of_multiples_squarefree_auxiliaryPrimeMultiplesFloorEnvelope
      hm hs ha)

/-- The lower finite-product/error target is equivalent to a standalone
finite-product lower bound plus a standalone exact-error bound. -/
theorem roughDyadicBadPrimeLowerEulerProductErrorBound_iff_productLower_and_error
    (a₀ b₀ C₀ : ℝ) :
    roughDyadicBadPrimeLowerEulerProductErrorBound a₀ b₀ C₀ ↔
      ∃ c E Xprod Xerr : ℝ, 0 < c ∧ E < c ∧
        (∀ X : ℝ, Xprod ≤ X →
          c / Real.log (EscAnalytic.zScale X) ≤
            roughDyadicBadPrimeMainEulerProduct X) ∧
        roughDyadicBadPrimeProductErrorBound a₀ b₀ C₀ E Xerr := by
  constructor
  · rintro ⟨c, E, Xprod, Xerr, hc, hE_nonneg, hE_lt, hprod, herr⟩
    exact ⟨c, E, Xprod, Xerr, hc, hE_lt, hprod, ⟨hE_nonneg, herr⟩⟩
  · rintro ⟨c, E, Xprod, Xerr, hc, hE_lt, hprod, herr⟩
    exact roughDyadicBadPrimeLowerEulerProductErrorBound_of_productLower_and_error
      hc hE_lt hprod herr

/-- Forgetting the upper finite-product estimate in the split target leaves
exactly the lower-product/error target. -/
theorem roughDyadicBadPrimeLowerEulerProductErrorBound_of_split
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicBadPrimeSplitEulerProductErrorBound a₀ b₀ C₀) :
    roughDyadicBadPrimeLowerEulerProductErrorBound a₀ b₀ C₀ := by
  rcases h with ⟨c, _C, E, Xprod, Xerr, hc, _hC, hE_nonneg, hE_lt,
    hprod, herr⟩
  refine ⟨c, E, Xprod, Xerr, hc, hE_nonneg, hE_lt, ?_, herr⟩
  intro X hX
  exact (hprod X hX).1

/-- The lower finite-product estimate plus exact error already gives the split
finite-product/error target, because the upper finite-product estimate is now
unconditional from the small-divisor duality argument. -/
theorem roughDyadicBadPrimeSplitEulerProductErrorBound_of_lowerEulerProductError
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicBadPrimeLowerEulerProductErrorBound a₀ b₀ C₀) :
    roughDyadicBadPrimeSplitEulerProductErrorBound a₀ b₀ C₀ := by
  rcases h with ⟨c, E, Xlo, Xerr, hc, hE_nonneg, hE_lt, hlo, herr⟩
  rcases roughDyadicBadPrimeMainEulerProductUpperBound_unconditional with
    ⟨C, Xhi, hC, hhi⟩
  refine ⟨c, C, E, max Xlo Xhi, Xerr, hc, hC, hE_nonneg, hE_lt, ?_, herr⟩
  intro X hX
  have hXlo : Xlo ≤ X := le_trans (le_max_left _ _) hX
  have hXhi : Xhi ≤ X := le_trans (le_max_right _ _) hX
  exact ⟨hlo X hXlo, hhi X hXhi⟩

/-- The split finite-product plus exact-error formulation implies the bundled
Euler-product/error rough target. -/
theorem roughDyadicBadPrimeEulerProductErrorBound_of_split
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicBadPrimeSplitEulerProductErrorBound a₀ b₀ C₀) :
    roughDyadicBadPrimeEulerProductErrorBound a₀ b₀ C₀ := by
  rcases h with ⟨c, C, E, Xprod, Xerr, hc, hC, hE_nonneg, hE_lt,
    hprod, herr⟩
  refine ⟨c, C, E, max Xprod Xerr, hc, hC, hE_nonneg, hE_lt, ?_⟩
  intro X hX M hM t htlo hthi
  have hXprod : Xprod ≤ X := le_trans (le_max_left _ _) hX
  have hXerr : Xerr ≤ X := le_trans (le_max_right _ _) hX
  rcases hprod X hXprod with ⟨hprod_lo, hprod_hi⟩
  exact ⟨hprod_lo, hprod_hi, herr X hXerr M hM t htlo hthi⟩

/-- Conversely, the bundled Euler-product/error target gives the split
finite-product/error formulation by using the same threshold for the product
and exact-error estimates. -/
theorem roughDyadicBadPrimeSplitEulerProductErrorBound_of_eulerProductError
    {a₀ b₀ C₀ : ℝ}
    (ha : a₀ ≤ b₀) (hC₀ : 0 ≤ C₀)
    (h : roughDyadicBadPrimeEulerProductErrorBound a₀ b₀ C₀) :
    roughDyadicBadPrimeSplitEulerProductErrorBound a₀ b₀ C₀ := by
  rcases h with ⟨c, C, E, X₀, hc, hC, hE_nonneg, hE_lt, hbound⟩
  refine ⟨c, C, E, max X₀ 1, X₀, hc, hC, hE_nonneg, hE_lt, ?_, ?_⟩
  · intro X hX
    have hX₀ : X₀ ≤ X := le_trans (le_max_left _ _) hX
    have hXone : (1 : ℝ) ≤ X := le_trans (le_max_right _ _) hX
    have hXpos : 0 < X := lt_of_lt_of_le zero_lt_one hXone
    have hM : ((1 : ℕ) : ℝ) ≤ X ^ C₀ :=
      by simpa using Real.one_le_rpow hXone hC₀
    have ht_hi : X ^ a₀ ≤ 2 * X ^ b₀ := by
      have hpow_le : X ^ a₀ ≤ X ^ b₀ :=
        Real.rpow_le_rpow_of_exponent_le hXone ha
      have hpow_nonneg : 0 ≤ X ^ b₀ :=
        (Real.rpow_pos_of_pos hXpos b₀).le
      nlinarith
    rcases hbound X hX₀ 1 hM (X ^ a₀) le_rfl ht_hi with
      ⟨hprod_lo, hprod_hi, _herr⟩
    exact ⟨hprod_lo, hprod_hi⟩
  · intro X hX M hM t htlo hthi
    exact (hbound X hX M hM t htlo hthi).2.2

/-- Bundled and split finite-product/error formulations have the same content;
the split form simply records independent product and error thresholds.  The
reverse direction needs the dyadic range and `M = 1` test point to be available,
recorded here as `a₀ ≤ b₀` and `0 ≤ C₀`. -/
theorem roughDyadicBadPrimeEulerProductErrorBound_iff_split
    (a₀ b₀ C₀ : ℝ) (ha : a₀ ≤ b₀) (hC₀ : 0 ≤ C₀) :
    roughDyadicBadPrimeEulerProductErrorBound a₀ b₀ C₀ ↔
      roughDyadicBadPrimeSplitEulerProductErrorBound a₀ b₀ C₀ := by
  constructor
  · exact roughDyadicBadPrimeSplitEulerProductErrorBound_of_eulerProductError ha hC₀
  · exact roughDyadicBadPrimeEulerProductErrorBound_of_split

/-- A Mertens-type bound for the finite bad-prime Euler product, together with
strict domination of the exact error term, proves the main-term/error rough
target. -/
theorem roughDyadicBadPrimeProductMainTermDominatesErrorBound_of_eulerProductError
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicBadPrimeEulerProductErrorBound a₀ b₀ C₀) :
    roughDyadicBadPrimeProductMainTermDominatesErrorBound a₀ b₀ C₀ := by
  rcases h with ⟨c, C, E, Xbase, hc, hC, hE_nonneg, hE_lt, hbound⟩
  refine ⟨c, C, E, max Xbase (Real.exp 2), hc, hC, hE_nonneg, hE_lt, ?_⟩
  intro X hX M hM t htlo hthi
  have hXbase : Xbase ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 2) hXexp
  have htpos : 0 < t := lt_of_lt_of_le (Real.rpow_pos_of_pos hXpos a₀) htlo
  rcases hbound X hXbase M hM t htlo hthi with
    ⟨hprod_lo, hprod_hi, herr⟩
  have hmain :=
    roughDyadicBadPrimeProductMainTermSum_eq_mul_eulerProduct X t
  constructor
  · calc
      c * (t / Real.log (EscAnalytic.zScale X))
          = t * (c / Real.log (EscAnalytic.zScale X)) := by ring
      _ ≤ t * roughDyadicBadPrimeMainEulerProduct X :=
          mul_le_mul_of_nonneg_left hprod_lo htpos.le
      _ = roughDyadicBadPrimeProductMainTermSum X t := by
          rw [hmain]
  constructor
  · calc
      roughDyadicBadPrimeProductMainTermSum X t
          = t * roughDyadicBadPrimeMainEulerProduct X := hmain
      _ ≤ t * (C / Real.log (EscAnalytic.zScale X)) :=
          mul_le_mul_of_nonneg_left hprod_hi htpos.le
      _ = C * (t / Real.log (EscAnalytic.zScale X)) := by ring
  · exact herr

/-- If the signed product-modulus main term dominates its exact finite error,
then the product-count rough-sieve bound follows. -/
theorem roughDyadicBadPrimeProductCountBound_of_mainTermDominatesError
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicBadPrimeProductMainTermDominatesErrorBound a₀ b₀ C₀) :
    roughDyadicBadPrimeProductCountBound a₀ b₀ C₀ := by
  rcases h with ⟨c, C, E, X₀, hc, hC, hE_nonneg, hE_lt, hbound⟩
  refine ⟨c - E, C + E, X₀, sub_pos.mpr hE_lt,
    add_pos_of_pos_of_nonneg hC hE_nonneg, ?_⟩
  intro X hX M hM t htlo hthi
  rcases hbound X hX M hM t htlo hthi with ⟨hmain_lo, hmain_hi, herr_abs⟩
  let T : ℝ := t / Real.log (EscAnalytic.zScale X)
  have hdecomp :=
    roughDyadicBadPrimeProductCountSum_eq_mainTerm_add_error X M t
  have herr_lower :
      - (E * T) ≤ roughDyadicBadPrimeProductErrorSum X M t := by
    have hneg : - (E * T) ≤ - |roughDyadicBadPrimeProductErrorSum X M t| :=
      neg_le_neg herr_abs
    exact hneg.trans (neg_abs_le _)
  have herr_upper :
      roughDyadicBadPrimeProductErrorSum X M t ≤ E * T :=
    (le_abs_self _).trans herr_abs
  constructor
  · calc
      (c - E) * (t / Real.log (EscAnalytic.zScale X))
          = c * T - E * T := by simp [T]; ring
      _ ≤ roughDyadicBadPrimeProductMainTermSum X t +
            roughDyadicBadPrimeProductErrorSum X M t := by
          nlinarith
      _ = roughDyadicBadPrimeSubsetProductCountSum X M t := by
          rw [← hdecomp]
  · calc
      roughDyadicBadPrimeSubsetProductCountSum X M t
          = roughDyadicBadPrimeProductMainTermSum X t +
              roughDyadicBadPrimeProductErrorSum X M t := hdecomp
      _ ≤ C * T + E * T := by
          nlinarith
      _ = (C + E) * (t / Real.log (EscAnalytic.zScale X)) := by
          simp [T]
          ring

/-- A lower finite Euler-product estimate plus a strictly dominated exact
error proves the lower half of the product-modulus rough-sieve target. -/
theorem roughDyadicBadPrimeProductCountLowerBound_of_lowerEulerProductError
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicBadPrimeLowerEulerProductErrorBound a₀ b₀ C₀) :
    roughDyadicBadPrimeProductCountLowerBound a₀ b₀ C₀ := by
  rcases h with ⟨c, E, Xprod, Xerr, hc, hE_nonneg, hE_lt, hprod, herr⟩
  refine ⟨c - E, max (max Xprod Xerr) (Real.exp 2),
    sub_pos.mpr hE_lt, ?_⟩
  intro X hX M hM t htlo hthi
  have hXprod : Xprod ≤ X := le_trans (le_max_left _ _)
    (le_trans (le_max_left _ _) hX)
  have hXerr : Xerr ≤ X := le_trans (le_max_right _ _)
    (le_trans (le_max_left _ _) hX)
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 2) hXexp
  have htpos : 0 < t := lt_of_lt_of_le (Real.rpow_pos_of_pos hXpos a₀) htlo
  let T : ℝ := t / Real.log (EscAnalytic.zScale X)
  have hmain :=
    roughDyadicBadPrimeProductMainTermSum_eq_mul_eulerProduct X t
  have hprod_lo := hprod X hXprod
  have hmain_lo :
      c * T ≤ roughDyadicBadPrimeProductMainTermSum X t := by
    calc
      c * T = t * (c / Real.log (EscAnalytic.zScale X)) := by
          simp [T]
          ring
      _ ≤ t * roughDyadicBadPrimeMainEulerProduct X :=
          mul_le_mul_of_nonneg_left hprod_lo htpos.le
      _ = roughDyadicBadPrimeProductMainTermSum X t := by
          rw [hmain]
  have herr_abs := herr X hXerr M hM t htlo hthi
  have herr_lower :
      - (E * T) ≤ roughDyadicBadPrimeProductErrorSum X M t := by
    have hneg : - (E * T) ≤ - |roughDyadicBadPrimeProductErrorSum X M t| :=
      neg_le_neg herr_abs
    exact hneg.trans (neg_abs_le _)
  have hdecomp :=
    roughDyadicBadPrimeProductCountSum_eq_mainTerm_add_error X M t
  calc
    (c - E) * (t / Real.log (EscAnalytic.zScale X))
        = c * T - E * T := by
          simp [T]
          ring
    _ ≤ roughDyadicBadPrimeProductMainTermSum X t +
          roughDyadicBadPrimeProductErrorSum X M t := by
        nlinarith
    _ = roughDyadicBadPrimeSubsetProductCountSum X M t := by
        rw [← hdecomp]

/-- A finite Euler-product lower bound plus one-sided lower control of the
signed product error proves the lower product-count target.  This is the exact
one-sided form needed for the lower rough-count half. -/
theorem roughDyadicBadPrimeProductCountLowerBound_of_lowerEulerProductLowerError
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicBadPrimeLowerEulerProductLowerErrorBound a₀ b₀ C₀) :
    roughDyadicBadPrimeProductCountLowerBound a₀ b₀ C₀ := by
  rcases h with ⟨c, E, Xprod, Xerr, hc, _hE_nonneg, hE_lt, hprod, herrLower⟩
  rcases herrLower with ⟨_hE_nonneg', herrLower⟩
  refine ⟨c - E, max (max Xprod Xerr) (Real.exp 2),
    sub_pos.mpr hE_lt, ?_⟩
  intro X hX M hM t htlo hthi
  have hXprod : Xprod ≤ X := le_trans (le_max_left _ _)
    (le_trans (le_max_left _ _) hX)
  have hXerr : Xerr ≤ X := le_trans (le_max_right _ _)
    (le_trans (le_max_left _ _) hX)
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 2) hXexp
  have htpos : 0 < t := lt_of_lt_of_le (Real.rpow_pos_of_pos hXpos a₀) htlo
  let T : ℝ := t / Real.log (EscAnalytic.zScale X)
  have hmain :=
    roughDyadicBadPrimeProductMainTermSum_eq_mul_eulerProduct X t
  have hprod_lo := hprod X hXprod
  have hmain_lo :
      c * T ≤ roughDyadicBadPrimeProductMainTermSum X t := by
    calc
      c * T = t * (c / Real.log (EscAnalytic.zScale X)) := by
          simp [T]
          ring
      _ ≤ t * roughDyadicBadPrimeMainEulerProduct X :=
          mul_le_mul_of_nonneg_left hprod_lo htpos.le
      _ = roughDyadicBadPrimeProductMainTermSum X t := by
          rw [hmain]
  have herr_lower := herrLower X hXerr M hM t htlo hthi
  have hdecomp :=
    roughDyadicBadPrimeProductCountSum_eq_mainTerm_add_error X M t
  calc
    (c - E) * (t / Real.log (EscAnalytic.zScale X))
        = c * T - E * T := by
          simp [T]
          ring
    _ ≤ roughDyadicBadPrimeProductMainTermSum X t +
          roughDyadicBadPrimeProductErrorSum X M t := by
        nlinarith
    _ = roughDyadicBadPrimeSubsetProductCountSum X M t := by
        rw [← hdecomp]

/-- The product-modulus lower bound is exactly a lower bound for the original
rough dyadic count after the finite inclusion-exclusion expansion is closed. -/
theorem roughDyadicCountLowerBound_of_badPrimeProductCountLowerBound
    {a₀ b₀ C₀ : ℝ}
    (h : roughDyadicBadPrimeProductCountLowerBound a₀ b₀ C₀) :
    roughDyadicCountLowerBound a₀ b₀ C₀ := by
  rcases h with ⟨c, X₀, hc, hlo⟩
  refine ⟨c, X₀, hc, ?_⟩
  intro X hX M hM t htlo hthi
  calc
    c * (t / Real.log (EscAnalytic.zScale X))
        ≤ roughDyadicBadPrimeSubsetProductCountSum X M t :=
          hlo X hX M hM t htlo hthi
    _ = roughDyadicCount X M t := by
          rw [← roughDyadicBadPrimeParitySum_eq_productCountSum,
            roughDyadicBadPrimeParitySum_eq_roughDyadicCount]

/-- Conversely, the original lower count target is exactly the lower bound for
the product-modulus inclusion-exclusion carrier. -/
theorem roughDyadicBadPrimeProductCountLowerBound_of_countLowerBound
    {a₀ b₀ C₀ : ℝ}

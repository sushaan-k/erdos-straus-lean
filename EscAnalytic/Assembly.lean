/-! ## Main theorem from the remaining quantitative estimates -/

/-- **The chain, with the remaining gaps made explicit.** `thm:main` follows from
exactly the hypotheses below; each is supplied (or all-but-finished) by the file
named in the discharge map above. This isolates the residual real-derivation work
to: the reduced-count bound, the smooth/Euler lifting data, and the `s·m` lifting
inequality. -/
theorem main_modulo_remaining
    (Ered : ℕ → ℕ) (Ered_c₁ Ered_C₁ : ℝ)
    (hc₁ : 0 < Ered_c₁) (hC₁ : 0 < Ered_C₁)
    (hEred : ∀ N : ℕ, 3 ≤ N → (Ered N : ℝ) ≤ Ered_C₁ * ((N : ℝ) * saving Ered_c₁ N))
    (smooth : ℕ → ℝ) (smoothExp smoothC : ℝ)
    (hse_pos : 0 < smoothExp) (hse_lt : smoothExp < 1) (hsC : 0 < smoothC)
    (hsmooth : ∀ N : ℕ, 3 ≤ N → smooth N ≤ smoothC * (N : ℝ) ^ smoothExp)
    (hsmooth_nn : ∀ N : ℕ, 0 ≤ smooth N)
    (euler : ℕ → ℝ) (eulerC : ℝ) (heC : 0 < eulerC)
    (heuler_nn : ∀ N : ℕ, 0 ≤ euler N)
    (heuler : ∀ N : ℕ, 3 ≤ N → euler N ≤ eulerC * Real.log N)
    (hlift : ∀ N : ℕ, 3 ≤ N →
      (exceptionalCount N : ℝ) ≤ smooth N + euler N * (Ered N : ℝ)) :
    IsMainBound exceptionalCount :=
  erdos_straus_main
    { Ered := Ered, Ered_c₁ := Ered_c₁, Ered_C₁ := Ered_C₁,
      Ered_pos₁ := hc₁, Ered_posC₁ := hC₁, Ered_bound := hEred,
      smooth := smooth, smoothExp := smoothExp, smoothExp_pos := hse_pos,
      smoothExp_lt_one := hse_lt, smoothC := smoothC, smoothC_pos := hsC,
      smooth_bound := hsmooth, smooth_nonneg := hsmooth_nn,
      euler := euler, eulerC := eulerC, eulerC_pos := heC,
      euler_nonneg := heuler_nn,
      euler_bound := fun N hN =>
        (heuler N hN).trans
          (mul_le_mul_of_nonneg_left (log_le_log_pow_four_of_three_le hN) heC.le),
      lift := hlift }

/-- The concrete Euler product in `AbstractMain.lean` is exactly the inverse of the
rough-prime density product in `Inputs.lean` at the manuscript scale
`z(X)=(log X)^4`. -/
theorem eulerProductFactor_zScale_eq_roughDyadicBadPrimeMainEulerProduct_inv
    (X : ℝ) :
    eulerProductFactor (zScale X) =
      (Inputs.roughDyadicBadPrimeMainEulerProduct X)⁻¹ := by
  classical
  unfold eulerProductFactor Inputs.roughDyadicBadPrimeMainEulerProduct Inputs.roughModulus
  rw [Inputs.primeProductBelow_primeFactors_eq]
  simp [one_div, Finset.prod_inv_distrib]

/-- Concrete manuscript Euler-product bound from Mertens.

Mertens gives the large-`N` estimate
`∏_{p≤z_N}(1-1/p)^{-1} ≪ log z_N ≪ log N`; the finitely many smaller `N` before
the Mertens threshold are absorbed using the already-proved elementary
fourth-log product bound. -/
theorem eulerProductFactorAtNat_log_bound_of_mertens :
    ∃ C : ℝ, 0 < C ∧ ∀ N : ℕ, 3 ≤ N →
      eulerProductFactorAtNat N ≤ C * Real.log N := by
  rcases Inputs.rough_dyadic_bad_prime_main_euler_product_inv_log_z_bound with
    ⟨Cevent, Xevent, hCevent, hevent⟩
  let Cfour : ℝ := Classical.choose eulerProductFactorAtNat_log_fourth_bound
  have hfourSpec :
      0 < Cfour ∧ ∀ N : ℕ, 3 ≤ N →
        eulerProductFactorAtNat N ≤ Cfour * (Real.log N) ^ (4 : ℕ) :=
    Classical.choose_spec eulerProductFactorAtNat_log_fourth_bound
  let B : ℝ := max Xevent (Real.exp 2) + 3
  have hBpos : 0 < B := by
    have : 0 < max Xevent (Real.exp 2) + 3 :=
      add_pos_of_nonneg_of_pos
        (le_trans (le_of_lt (Real.exp_pos 2)) (le_max_right _ _))
        (by norm_num)
    simpa [B] using this
  refine ⟨max (4 * Cevent) (Cfour * B ^ (3 : ℕ)), ?_, ?_⟩
  · exact lt_of_lt_of_le (mul_pos (by norm_num) hCevent) (le_max_left _ _)
  intro N hN
  have hlog_pos : 0 < Real.log N := log_pos_of_three_le hN
  have hlog_nonneg : 0 ≤ Real.log N := hlog_pos.le
  by_cases hlarge : B ≤ (N : ℝ)
  · have hmax_le_B : max Xevent (Real.exp 2) ≤ B := by
      dsimp [B]
      linarith
    have hXevent : Xevent ≤ (N : ℝ) :=
      le_trans (le_trans (le_max_left _ _) hmax_le_B) hlarge
    have hExp2 : Real.exp 2 ≤ (N : ℝ) :=
      le_trans (le_trans (le_max_right _ _) hmax_le_B) hlarge
    have hExp1 : Real.exp 1 ≤ (N : ℝ) :=
      le_trans (le_of_lt (Real.exp_lt_exp.mpr (by norm_num : (1 : ℝ) < 2))) hExp2
    have hinv := hevent (N : ℝ) hXevent
    have hlogz :
        Real.log (zScale (N : ℝ)) ≤ 4 * Real.log N :=
      log_zScale_le_four_log hExp1
    calc eulerProductFactorAtNat N
        = eulerProductFactor (zScale (N : ℝ)) := rfl
      _ = (Inputs.roughDyadicBadPrimeMainEulerProduct (N : ℝ))⁻¹ :=
          eulerProductFactor_zScale_eq_roughDyadicBadPrimeMainEulerProduct_inv
            (N : ℝ)
      _ ≤ Cevent * Real.log (zScale (N : ℝ)) := hinv
      _ ≤ Cevent * (4 * Real.log N) :=
          mul_le_mul_of_nonneg_left hlogz hCevent.le
      _ = (4 * Cevent) * Real.log N := by ring
      _ ≤ max (4 * Cevent) (Cfour * B ^ (3 : ℕ)) * Real.log N :=
          mul_le_mul_of_nonneg_right (le_max_left _ _) hlog_nonneg
  · have hNleB : (N : ℝ) ≤ B := le_of_lt (lt_of_not_ge hlarge)
    have hlog_le_N : Real.log N ≤ (N : ℝ) :=
      Real.log_le_self (Nat.cast_nonneg N)
    have hlog_le_B : Real.log N ≤ B := le_trans hlog_le_N hNleB
    have hpow_le : (Real.log N) ^ (3 : ℕ) ≤ B ^ (3 : ℕ) :=
      pow_le_pow_left₀ hlog_nonneg hlog_le_B 3
    have hfour := hfourSpec.2 N hN
    have hsmall :
        Cfour * (Real.log N) ^ (4 : ℕ) ≤
          Cfour * B ^ (3 : ℕ) * Real.log N := by
      calc Cfour * (Real.log N) ^ (4 : ℕ)
          = Cfour * (Real.log N) ^ (3 : ℕ) * Real.log N := by ring
        _ ≤ Cfour * B ^ (3 : ℕ) * Real.log N := by
            exact mul_le_mul_of_nonneg_right
              (mul_le_mul_of_nonneg_left hpow_le hfourSpec.1.le) hlog_nonneg
    calc eulerProductFactorAtNat N
        ≤ Cfour * (Real.log N) ^ (4 : ℕ) := hfour
      _ ≤ Cfour * B ^ (3 : ℕ) * Real.log N := hsmall
      _ ≤ max (4 * Cevent) (Cfour * B ^ (3 : ℕ)) * Real.log N :=
          mul_le_mul_of_nonneg_right (le_max_right _ _) hlog_nonneg

/-- Variant of `main_modulo_remaining` with the manuscript's concrete Euler
factor discharged by the Mertens route. -/
theorem thm_main_concrete_euler_mertens_from_remaining
    (Ered : ℕ → ℕ) (Ered_c₁ Ered_C₁ : ℝ)
    (hc₁ : 0 < Ered_c₁) (hC₁ : 0 < Ered_C₁)
    (hEred : ∀ N : ℕ, 3 ≤ N → (Ered N : ℝ) ≤ Ered_C₁ * ((N : ℝ) * saving Ered_c₁ N))
    (smooth : ℕ → ℝ) (smoothExp smoothC : ℝ)
    (hse_pos : 0 < smoothExp) (hse_lt : smoothExp < 1) (hsC : 0 < smoothC)
    (hsmooth : ∀ N : ℕ, 3 ≤ N → smooth N ≤ smoothC * (N : ℝ) ^ smoothExp)
    (hsmooth_nn : ∀ N : ℕ, 0 ≤ smooth N)
    (hlift : ∀ N : ℕ, 3 ≤ N →
      (exceptionalCount N : ℝ) ≤ smooth N + eulerProductFactorAtNat N * (Ered N : ℝ)) :
    IsMainBound exceptionalCount := by
  rcases eulerProductFactorAtNat_log_bound_of_mertens with ⟨eulerC, heC, heuler⟩
  exact main_modulo_remaining Ered Ered_c₁ Ered_C₁ hc₁ hC₁ hEred
    smooth smoothExp smoothC hse_pos hse_lt hsC hsmooth hsmooth_nn
    eulerProductFactorAtNat eulerC heC eulerProductFactorAtNat_nonneg heuler hlift


theorem fixedNumeratorPaperReducedClassEnvelopeInputs_reduced_sum_large
    {ι κ : Type*} [DecidableEq κ] {m : ℕ}
    (H : FixedNumeratorPaperReducedClassEnvelopeInputs m ι κ) :
    ∀ N : ℕ, 3 ≤ N → H.Tred ≤ N →
      (∑ s ∈ Finset.Icc 1 N,
        (fixedNumeratorReducedExceptionalCount m (zNatScale N) (N / s) : ℝ)) ≤
          eulerProductFactorAtNat N * (H.Ered N : ℝ) := by
  intro N hN hTN
  calc
    (∑ s ∈ Finset.Icc 1 N,
        (fixedNumeratorReducedExceptionalCount m (zNatScale N) (N / s) : ℝ))
        ≤ ∑ s ∈ Finset.Icc 1 N, ((H.clsRed N s).card : ℝ) * H.Ured N s := by
          apply Finset.sum_le_sum
          intro s hs
          calc
            (fixedNumeratorReducedExceptionalCount m (zNatScale N) (N / s) : ℝ)
                ≤ ∑ b ∈ H.clsRed N s, H.Ured N s := by
                  exact fixedNumeratorReducedExceptionalCount_le_sum_class_majorants
                    (m := m) (z := zNatScale N) (N := N / s)

    (R : FixedNumeratorPaperReducedClassEnvelopeInputs m ι κ)
    (hEred : R.Ered = H.Ered) (hTred : R.Tred = H.Tred) :
    (∀ N : ℕ, 3 ≤ N → H.T ≤ N → ((H.cls N).card : ℝ) ≤ H.Pz N) ∧
    (∀ N : ℕ, 3 ≤ N → H.T ≤ N →
      H.c * (Real.log N) ^ ((3 : ℝ) / 4)
        ≤ (1 - (H.εb N + Real.log 3 / H.μ N)) * H.μ N) ∧
    (∀ N : ℕ, 3 ≤ N → H.T ≤ N → ∀ b ∈ H.cls N,
      H.Mb N b ≤ ((N : ℝ) / H.Pz N) *
        (Inputs.suenProb (H.μ N) (H.δb N b) (H.Δb N b) + H.F2R N b) +
          H.errTerm N b) ∧
    (∀ N : ℕ, 3 ≤ N → H.T ≤ N → ∀ b ∈ H.cls N,
      Inputs.suenTailConstant * H.Δb N b * Real.exp (2 * H.δb N b)
        ≤ H.εb N * H.μ N) ∧
    (∀ N : ℕ, 3 ≤ N → H.T ≤ N → ∀ b ∈ H.cls N,
      H.errTerm N b ≤ H.Xpow N b * Real.exp ((1 + H.εK) * H.μ N)) ∧
    (∀ N : ℕ, 3 ≤ N → H.T ≤ N → ∀ b ∈ H.cls N,
      H.Pz N * H.Xpow N b * Real.exp (2 * H.μ N)

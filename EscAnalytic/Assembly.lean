      nlinarith [mul_pos hcμ hcube_pos]
    nlinarith
  exact
    level_budget_rank_tail_logCube_lower_incompatible_at
      (μ := μ N) (cμ := cμ) (Cp := Cp) (a := a) (R := R N b) (N := N)
      hcμ hN3 hscaleN.2 (hrank_tail N hN3 hTN b hb)
      (hmass_lower N hN3 hTN) (hlevel N hN3 hTN b hb) hscale24


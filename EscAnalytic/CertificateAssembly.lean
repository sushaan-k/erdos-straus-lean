/-- Main-bound capstone for a fully certified rough-large range.

Once the rough-large range is zero at every level, the remaining asymptotic work
is only the smooth-range estimate. -/
theorem main_modulo_rough_zero_range_bounds
    (z : ℕ → ℕ)
    (smooth : ℕ → ℝ) (smoothExp smoothC : ℝ)
    (hse_pos : 0 < smoothExp) (hse_lt : smoothExp < 1) (hsC : 0 < smoothC)

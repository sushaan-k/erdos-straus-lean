/-- The product-modulus rough target is exactly its lower and upper halves. -/
theorem roughDyadicBadPrimeProductCountBound_iff_lower_upper
    (a₀ b₀ C₀ : ℝ) :
    roughDyadicBadPrimeProductCountBound a₀ b₀ C₀ ↔
      roughDyadicBadPrimeProductCountLowerBound a₀ b₀ C₀ ∧
        roughDyadicBadPrimeProductCountUpperBound a₀ b₀ C₀ := by
  constructor
  · rintro ⟨c, C, X₀, hc, hC, h⟩
    refine ⟨⟨c, X₀, hc, ?_⟩, ⟨C, X₀, hC, ?_⟩⟩
    · intro X hX M hM t htlo hthi
      exact (h X hX M hM t htlo hthi).1
    · intro X hX M hM t htlo hthi
      exact (h X hX M hM t htlo hthi).2
  · rintro ⟨⟨c, Xlo, hc, hlo⟩, ⟨C, Xhi, hC, hhi⟩⟩
    refine ⟨c, C, max Xlo Xhi, hc, hC, ?_⟩
    intro X hX M hM t htlo hthi
    have hXlo : Xlo ≤ X := le_trans (le_max_left _ _) hX
    have hXhi : Xhi ≤ X := le_trans (le_max_right _ _) hX
    exact ⟨hlo X hXlo M hM t htlo hthi,
      hhi X hXhi M hM t htlo hthi⟩

/-- The parity-sum rough target is equivalent to the product-modulus target. -/
theorem roughDyadicBadPrimeParityBound_iff_productCount_bound
    (a₀ b₀ C₀ : ℝ) :
    roughDyadicBadPrimeParityBound a₀ b₀ C₀ ↔
      roughDyadicBadPrimeProductCountBound a₀ b₀ C₀ := by
  constructor
  · rintro ⟨c, C, X₀, hc, hC, hparity⟩
    refine ⟨c, C, X₀, hc, hC, ?_⟩
    intro X hX M hM t htlo hthi
    simpa [roughDyadicBadPrimeParitySum_eq_productCountSum] using
      hparity X hX M hM t htlo hthi
  · rintro ⟨c, C, X₀, hc, hC, hproduct⟩
    refine ⟨c, C, X₀, hc, hC, ?_⟩
    intro X hX M hM t htlo hthi
    simpa [roughDyadicBadPrimeParitySum_eq_productCountSum] using
      hproduct X hX M hM t htlo hthi

/-- The rough count primitive is equivalent to bounding the explicit finite
bad-prime inclusion-exclusion carrier. -/
theorem linear_sieve_rough_dyadic_count_bound_iff_badPrimeParity_bound
    (a₀ b₀ C₀ : ℝ) :
    (∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        c * (t / Real.log (EscAnalytic.zScale X)) ≤ roughDyadicCount X M t
          ∧ roughDyadicCount X M t
              ≤ C * (t / Real.log (EscAnalytic.zScale X))) ↔
      roughDyadicBadPrimeParityBound a₀ b₀ C₀ := by
  constructor
  · rintro ⟨c, C, X₀, hc, hC, hcount⟩
    refine ⟨c, C, X₀, hc, hC, ?_⟩
    intro X hX M hM t htlo hthi
    simpa [roughDyadicBadPrimeParitySum_eq_roughDyadicCount] using
      hcount X hX M hM t htlo hthi
  · rintro ⟨c, C, X₀, hc, hC, hparity⟩
    refine ⟨c, C, X₀, hc, hC, ?_⟩
    intro X hX M hM t htlo hthi
    simpa [roughDyadicBadPrimeParitySum_eq_roughDyadicCount] using
      hparity X hX M hM t htlo hthi

/-- The rough count primitive is equivalent to bounding the product-modulus
inclusion-exclusion carrier. -/
theorem linear_sieve_rough_dyadic_count_bound_iff_badPrimeProductCount_bound
    (a₀ b₀ C₀ : ℝ) :
    (∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →

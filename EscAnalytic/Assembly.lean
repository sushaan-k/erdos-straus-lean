/-- Strongest capstone form for rational certificate budgets.

The finite/certificate layer may supply `(Ered N : ℚ) ≤ ∑_b MbQ N b`.  This
theorem applies `Transfer.finite_transfer` to the real casts of those rational
per-class budgets, uses `Transfer.Ered_bound_of_finite_transfer_rat` to obtain
the real reduced-count bound, and then finishes with the `LiftCount` range-bound
capstone. -/
theorem main_modulo_finite_transfer_rat_range_bounds
    {ι : Type*}
    (z : ℕ → ℕ)
    (cls : ℕ → Finset ι)
    (MbQ : ℕ → ι → ℚ)
    (Pz μ εb : ℕ → ℝ)
    (Xpow nohit errTerm F2R : ℕ → ι → ℝ)
    (εK : ℝ)
    (Ered : ℕ → ℕ) (Ered_c₁ : ℝ)
    (hc₁ : 0 < Ered_c₁)
    (hEred_rat : ∀ N : ℕ, 3 ≤ N →
      (Ered N : ℚ) ≤ ∑ b ∈ cls N, MbQ N b)
    (hμ : ∀ N : ℕ, 3 ≤ N → 0 < μ N)
    (hPz : ∀ N : ℕ, 3 ≤ N → 1 ≤ Pz N)
    (hXpow : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N, 0 ≤ Xpow N b)
    (hεb : ∀ N : ℕ, 3 ≤ N → 0 ≤ εb N)
    (hdecomp : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      (MbQ N b : ℝ) ≤ ((N : ℝ) / Pz N) * (nohit N b + F2R N b) + errTerm N b)
    (herr : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      errTerm N b ≤ Xpow N b * Real.exp ((1 + εK) * μ N))
    (hεle : εK ≤ 1)
    (hlevel : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      Pz N * Xpow N b * Real.exp (2 * μ N) ≤ (N : ℝ) * Real.exp (-4 * μ N))
    (hF2R : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      F2R N b ≤ Real.exp (-3 * μ N))
    (hnohit : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      nohit N b ≤ Real.exp (-(1 - εb N) * μ N))
    (hcard : ∀ N : ℕ, 3 ≤ N → ((cls N).card : ℝ) ≤ Pz N)
    (hsaving : ∀ N : ℕ, 3 ≤ N →
      Ered_c₁ * (Real.log N) ^ ((3 : ℝ) / 4)
        ≤ (1 - (εb N + Real.log 3 / μ N)) * μ N)
    (smooth : ℕ → ℝ) (smoothExp smoothC : ℝ)
    (hse_pos : 0 < smoothExp) (hse_lt : smoothExp < 1) (hsC : 0 < smoothC)
    (hsmooth : ∀ N : ℕ, 3 ≤ N → smooth N ≤ smoothC * (N : ℝ) ^ smoothExp)
    (hsmooth_nn : ∀ N : ℕ, 0 ≤ smooth N)
    (hsmooth_range : ∀ N : ℕ, 3 ≤ N →
      (smoothRangeCount (z N) N : ℝ) ≤ smooth N)
    (euler : ℕ → ℝ) (eulerC : ℝ) (heC : 0 < eulerC)
    (heuler_nn : ∀ N : ℕ, 0 ≤ euler N)
    (heuler : ∀ N : ℕ, 3 ≤ N → euler N ≤ eulerC * Real.log N)
    (hrough_range : ∀ N : ℕ, 3 ≤ N →
      (roughLargeCount (z N) N : ℝ) ≤ euler N * (Ered N : ℝ)) :
    IsMainBound exceptionalCount :=
  main_modulo_range_bounds z Ered Ered_c₁ 1 hc₁ zero_lt_one
    (fun N hN => by
      have hbound :
          (Ered N : ℝ) ≤ (N : ℝ) * saving Ered_c₁ N :=
        Ered_bound_of_finite_transfer_rat (cls N)
          (hEred_rat N hN) (hPz N hN)
          (by exact_mod_cast Nat.zero_le N) (hcard N hN)
          (per_class_transfer_rat_of_finite_transfer cls MbQ Pz μ εb Xpow nohit
            errTerm F2R εK hμ hPz hXpow hεb hdecomp herr hεle hlevel hF2R
            hnohit N hN)
          (hsaving N hN)
      simpa [one_mul] using hbound)
    smooth smoothExp smoothC hse_pos hse_lt hsC hsmooth hsmooth_nn
    hsmooth_range euler eulerC heC heuler_nn heuler hrough_range


/-- A relative-to-main-term rough-window discrepancy estimate gives the active
normalized rough-count input.  The only extra ingredient is the unconditional
upper Mertens half for the finite rough Euler product. -/
theorem RoughDyadicCountDiscrepancyUniformNormalizedSmallBoundOnPositiveRanges_of_relativeMain
    (h : RoughDyadicCountDiscrepancyRelativeMainUniformSmallBoundOnPositiveRanges) :
    RoughDyadicCountDiscrepancyUniformNormalizedSmallBoundOnPositiveRanges := by
  intro a₀ b₀ C₀ eps ha₀ hab heps
  rcases roughDyadicBadPrimeMainEulerProductUpperBound_unconditional with
    ⟨C, Xprod, hC, hprod⟩
  have hdelta_pos : 0 < eps / C := div_pos heps hC
  rcases h a₀ b₀ C₀ (eps / C) ha₀ hab hdelta_pos with ⟨Xrel, hrel⟩
  refine ⟨max (max Xrel Xprod) (Real.exp 2), ?_⟩
  refine ⟨le_of_lt heps, ?_⟩
  intro X hX t htlo hthi
  have hXrel : Xrel ≤ X :=
    le_trans (le_trans (le_max_left Xrel Xprod)
      (le_max_left (max Xrel Xprod) (Real.exp 2))) hX
  have hXprod : Xprod ≤ X :=
    le_trans (le_trans (le_max_right Xrel Xprod)
      (le_max_left (max Xrel Xprod) (Real.exp 2))) hX
  have hXexp : Real.exp 2 ≤ X :=
    le_trans (le_max_right (max Xrel Xprod) (Real.exp 2)) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 2) hXexp
  have hlog_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp
  have ht_pos : 0 < t :=
    lt_of_lt_of_le (Real.rpow_pos_of_pos hXpos a₀) htlo
  have hden_pos : 0 < t / Real.log (EscAnalytic.zScale X) :=
    div_pos ht_pos hlog_pos
  have hrelX :
      |roughDyadicRoughWindowCount X t -
        t * roughDyadicBadPrimeMainEulerProduct X| ≤
        (eps / C) * (t * roughDyadicBadPrimeMainEulerProduct X) :=
    hrel X hXrel t htlo hthi
  have hprodX :
      roughDyadicBadPrimeMainEulerProduct X ≤
        C / Real.log (EscAnalytic.zScale X) :=
    hprod X hXprod
  have hscaled :
      |roughDyadicRoughWindowCount X t -
        t * roughDyadicBadPrimeMainEulerProduct X| ≤
        eps * (t / Real.log (EscAnalytic.zScale X)) := by
    calc
      |roughDyadicRoughWindowCount X t -
          t * roughDyadicBadPrimeMainEulerProduct X|
          ≤ (eps / C) * (t * roughDyadicBadPrimeMainEulerProduct X) := hrelX
      _ ≤ (eps / C) *
            (t * (C / Real.log (EscAnalytic.zScale X))) := by
              exact mul_le_mul_of_nonneg_left
                (mul_le_mul_of_nonneg_left hprodX ht_pos.le)
                (div_nonneg heps.le hC.le)
      _ = eps * (t / Real.log (EscAnalytic.zScale X)) := by
              field_simp [ne_of_gt hC, ne_of_gt hlog_pos]
              ring
  exact (div_le_iff₀ hden_pos).mpr hscaled

/-- Conversely, a normalized rough-window discrepancy estimate and the finite
rough Euler-product lower bound recover the relative-to-main-term formulation.
Thus, once the Mertens side has supplied `V(z) ≫ 1/log z`, the normalized and
relative-main count inputs have the same checked content. -/
theorem RoughDyadicCountDiscrepancyRelativeMainUniformSmallBoundOnPositiveRanges_of_normalized_and_productLower
    (hdisc : RoughDyadicCountDiscrepancyUniformNormalizedSmallBoundOnPositiveRanges)
    (hprod : roughDyadicBadPrimeMainEulerProductLowerBound) :
    RoughDyadicCountDiscrepancyRelativeMainUniformSmallBoundOnPositiveRanges := by
  intro a₀ b₀ C₀ eps ha₀ hab heps
  rcases hprod with ⟨c, Xprod, hc, hprodX⟩
  have hdelta_pos : 0 < eps * c := mul_pos heps hc
  rcases hdisc a₀ b₀ C₀ (eps * c) ha₀ hab hdelta_pos with
    ⟨Xdisc, hdiscPack⟩
  refine ⟨max (max Xdisc Xprod) (Real.exp 2), ?_⟩
  intro X hX t htlo hthi
  have hXdisc : Xdisc ≤ X :=
    le_trans (le_trans (le_max_left Xdisc Xprod)
      (le_max_left (max Xdisc Xprod) (Real.exp 2))) hX
  have hXprod : Xprod ≤ X :=
    le_trans (le_trans (le_max_right Xdisc Xprod)
      (le_max_left (max Xdisc Xprod) (Real.exp 2))) hX
  have hXexp : Real.exp 2 ≤ X :=
    le_trans (le_max_right (max Xdisc Xprod) (Real.exp 2)) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 2) hXexp
  have hlog_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp
  have ht_pos : 0 < t :=
    lt_of_lt_of_le (Real.rpow_pos_of_pos hXpos a₀) htlo
  have hden_pos : 0 < t / Real.log (EscAnalytic.zScale X) :=
    div_pos ht_pos hlog_pos
  rcases hdiscPack with ⟨_heps, hdiscX⟩
  have hnorm :
      |roughDyadicRoughWindowCount X t -
        t * roughDyadicBadPrimeMainEulerProduct X| /
          (t / Real.log (EscAnalytic.zScale X)) ≤ eps * c :=
    hdiscX X hXdisc t htlo hthi
  have hscaled :
      |roughDyadicRoughWindowCount X t -
        t * roughDyadicBadPrimeMainEulerProduct X| ≤
          (eps * c) * (t / Real.log (EscAnalytic.zScale X)) :=
    (div_le_iff₀ hden_pos).mp hnorm
  have hprodLower :
      c / Real.log (EscAnalytic.zScale X) ≤
        roughDyadicBadPrimeMainEulerProduct X :=
    hprodX X hXprod
  have hscaled_le_main :
      (eps * c) * (t / Real.log (EscAnalytic.zScale X)) ≤
        eps * (t * roughDyadicBadPrimeMainEulerProduct X) := by
    calc
      (eps * c) * (t / Real.log (EscAnalytic.zScale X))
          = eps * (t * (c / Real.log (EscAnalytic.zScale X))) := by
              field_simp [ne_of_gt hlog_pos]
              ring
      _ ≤ eps * (t * roughDyadicBadPrimeMainEulerProduct X) := by
              exact mul_le_mul_of_nonneg_left
                (mul_le_mul_of_nonneg_left hprodLower ht_pos.le)
                heps.le
  exact hscaled.trans hscaled_le_main

/-- Under the finite rough Euler-product lower bound, the normalized `t/log z`
and relative-to-main-term formulations of the positive-range rough-window count
estimate are equivalent. -/
theorem RoughDyadicCountDiscrepancyRelativeMainUniformSmallBoundOnPositiveRanges_iff_normalized_of_productLower
    (hprod : roughDyadicBadPrimeMainEulerProductLowerBound) :
    RoughDyadicCountDiscrepancyRelativeMainUniformSmallBoundOnPositiveRanges ↔
      RoughDyadicCountDiscrepancyUniformNormalizedSmallBoundOnPositiveRanges := by
  constructor
  · exact RoughDyadicCountDiscrepancyUniformNormalizedSmallBoundOnPositiveRanges_of_relativeMain
  · intro hdisc
    exact
      RoughDyadicCountDiscrepancyRelativeMainUniformSmallBoundOnPositiveRanges_of_normalized_and_productLower
        hdisc hprod

/-- The raw scaled-error fixed-log-power rough-window estimate implies the
normalized fixed-log-power form after imposing the standard positivity threshold.
-/
theorem PrimeProductLogPowerRoughWindowCountDiscrepancyUniformNormalizedSmallBound_of_raw
    (h :
      PrimeProductLogPowerRoughWindowCountDiscrepancyUniformSmallBound) :
    PrimeProductLogPowerRoughWindowCountDiscrepancyUniformNormalizedSmallBound := by
  intro k a₀ b₀ eps hk ha₀ hab heps
  rcases h k a₀ b₀ eps hk ha₀ hab heps with ⟨X₀, hX₀⟩
  refine ⟨max X₀ (Real.exp 2), ?_⟩
  intro X hX t htlo hthi
  have hXbase : X₀ ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 2) hXexp
  have hlogX_ge_two : (2 : ℝ) ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hXexp
  have hlogX_pos : 0 < Real.log X :=
    lt_of_lt_of_le (by norm_num : (0 : ℝ) < 2) hlogX_ge_two
  have hlogX_ge_one : (1 : ℝ) ≤ Real.log X :=
    le_trans (by norm_num : (1 : ℝ) ≤ 2) hlogX_ge_two
  have hlogX_pow_ge_two : (2 : ℝ) ≤ (Real.log X) ^ k := by
    have hk_one : 1 ≤ k := Nat.succ_le_of_lt hk
    have hpow : (Real.log X) ^ (1 : ℕ) ≤ (Real.log X) ^ k :=
      pow_le_pow_right₀ hlogX_ge_one hk_one
    exact le_trans hlogX_ge_two (by simpa using hpow)
  have hlog_logpow_pos : 0 < Real.log ((Real.log X) ^ k) :=
    Real.log_pos (lt_of_lt_of_le (by norm_num : (1 : ℝ) < 2) hlogX_pow_ge_two)
  have ht_pos : 0 < t :=
    lt_of_lt_of_le (Real.rpow_pos_of_pos hXpos a₀) htlo
  have hden_pos : 0 < t / Real.log ((Real.log X) ^ k) :=
    div_pos ht_pos hlog_logpow_pos
  exact (div_le_iff₀ hden_pos).mpr (hX₀ X hXbase t htlo hthi)


/-- A low bad-Euler-factor mass estimate supplies the real-cutoff
small-divisor Euler lower bound directly.  This carries the finite
product-mass criterion through the checked density, dyadic interpolation, and
support-transfer steps. -/
theorem smallDivisorEulerSum_lower_bound_of_lowProductMass
    {δ η : ℝ}
    (h : OddSquarefreeLowTotientProductMassBound δ η) :
    ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.zScale X) ≤ smallDivisorEulerSum X :=
  smallDivisorEulerSum_lower_bound_of_oddSquarefreeTotientNat_recip_density
    (OddSquarefreeTotientDensityBound_of_lowProductMass h)

/-- Low bad-Euler-factor mass supplies the carrier-bundled two-sided
small-divisor Euler estimate.  The upper half and side conditions are already
unconditional; the low-product-mass hypothesis is used only for the lower
growth. -/
theorem smallDivisorEulerSum_two_sided_from_lowProductMass
    {δ η : ℝ}
    (h : OddSquarefreeLowTotientProductMassBound δ η) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      0 ≤ Real.log (EscAnalytic.zScale X) ∧
        0 ≤ smallDivisorEulerSum X ∧
        c * Real.log (EscAnalytic.zScale X) ≤ smallDivisorEulerSum X ∧
        smallDivisorEulerSum X ≤ C * Real.log (EscAnalytic.zScale X) ∧
        |smallDivisorEulerSum X| ≤ C * Real.log (EscAnalytic.zScale X) :=
  smallDivisorEulerSum_two_sided_from_oddSquarefreeTotientNat_recip_density
    (OddSquarefreeTotientDensityBound_of_lowProductMass h)

/-- Low bad-Euler-factor mass supplies the split lower/upper logarithmic
Euler-sum target used by later factorization routes. -/
theorem smallDivisorEulerSum_log_lower_upper_of_lowProductMass
    {δ η : ℝ}
    (h : OddSquarefreeLowTotientProductMassBound δ η) :

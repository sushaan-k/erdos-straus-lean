    (hrank : ∀ N M : ℕ,
      ∀ b ∈ EscLeanChecks.reducedResiduesMod (P N M),
        ∀ k ∈ Finset.range (2 * R N M + 1),
          (((-1 : Int) ^ k) *
            ((∑ t ∈ (eventsByBase N M b).powersetCard k,
                EscLeanChecks.baseSatEventCommonHitCountUpTo
                  M (P N M) b t : ℕ) : Int) : ℚ) ≤
              B N M b k)
    (hadm : ∀ N M : ℕ,

  exact hupper X hX 1 hM t htlo hthi

/-- A one-sided upper exact-error estimate in the no-extra-modulus lane proves
the core upper count primitive.  This is the sharpest current reduction of the
upper live primitive to the explicit finite inclusion-exclusion error term. -/
theorem roughDyadicCountModulusOneUpperBoundCore_of_productErrorUpper
    {a₀ b₀ E Xerr : ℝ}

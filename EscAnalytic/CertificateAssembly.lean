      (smoothRangeCount (z N) N : ℝ) ≤ smooth N)
    (hrough_zero : ∀ N : ℕ, 3 ≤ N → roughLargeCount (z N) N = 0) :
    IsMainBound exceptionalCount :=
  main_modulo_range_bounds z (fun _ => 0) 1 1 zero_lt_one zero_lt_one
    (fun N _hN => by
      have hNnonneg : 0 ≤ (N : ℝ) := by exact_mod_cast Nat.zero_le N

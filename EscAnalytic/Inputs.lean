/-- The log-carrier linear-sieve package has the same analytic content as the
bare dyadic count estimate; all extra fields are threshold and carrier
bookkeeping. -/
theorem linear_sieve_rough_dyadic_count_bound_iff_log_carrier_bounds
    (a₀ b₀ C₀ : ℝ) :
    (∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        c * (t / Real.log (EscAnalytic.zScale X)) ≤ roughDyadicCount X M t
          ∧ roughDyadicCount X M t
              ≤ C * (t / Real.log (EscAnalytic.zScale X))) ↔
    (∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
        0 < Real.log (EscAnalytic.zScale X) ∧
          0 ≤ roughDyadicCount X M t ∧
          c * (t / Real.log (EscAnalytic.zScale X)) ≤ roughDyadicCount X M t ∧
          roughDyadicCount X M t
              ≤ C * (t / Real.log (EscAnalytic.zScale X)) ∧
          |roughDyadicCount X M t|
              ≤ C * (t / Real.log (EscAnalytic.zScale X))) := by

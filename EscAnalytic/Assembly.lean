    (hEred_sum : ∀ N : ℕ, 3 ≤ N →
      (Ered N : ℝ) ≤ ∑ b ∈ cls N, Mb N b)
    (hμ : ∀ N : ℕ, 3 ≤ N → 0 < μ N)
    (hPz : ∀ N : ℕ, 3 ≤ N → 1 ≤ Pz N)
    (hXpow : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N, 0 ≤ Xpow N b)
    (hεb : ∀ N : ℕ, 3 ≤ N → 0 ≤ εb N)
    (hdecomp : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      Mb N b ≤ ((N : ℝ) / Pz N) * (nohit N b + F2R N b) + errTerm N b)
    (herr : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      errTerm N b ≤ Xpow N b * Real.exp ((1 + εK) * μ N))
    (hεle : εK ≤ 1)
    (hlevel : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      Pz N * Xpow N b * Real.exp (2 * μ N) ≤ (N : ℝ) * Real.exp (-4 * μ N))
    (hF2R : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      F2R N b ≤ Real.exp (-3 * μ N))
    (hnohit : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      nohit N b ≤ Real.exp (-(1 - εb N) * μ N))
    (hcard : ∀ N : ℕ, 3 ≤ N → ((cls N).card : ℝ) ≤ Pz N)
    (hsaving : ∀ N : ℕ, 3 ≤ N →
      Ered_c₁ * (Real.log N) ^ ((3 : ℝ) / 4)
        ≤ (1 - (εb N + Real.log 3 / μ N)) * μ N)
    (smooth : ℕ → ℝ) (smoothExp smoothC : ℝ)
    (hse_pos : 0 < smoothExp) (hse_lt : smoothExp < 1) (hsC : 0 < smoothC)
    (hsmooth : ∀ N : ℕ, 3 ≤ N → smooth N ≤ smoothC * (N : ℝ) ^ smoothExp)
    (hsmooth_nn : ∀ N : ℕ, 0 ≤ smooth N)
    (hsmooth_range : ∀ N : ℕ, 3 ≤ N →
      (smoothRangeCount (z N) N : ℝ) ≤ smooth N)
    (euler : ℕ → ℝ) (eulerC : ℝ) (heC : 0 < eulerC)
    (heuler_nn : ∀ N : ℕ, 0 ≤ euler N)
    (heuler : ∀ N : ℕ, 3 ≤ N → euler N ≤ eulerC * Real.log N)
    (hrough_range : ∀ N : ℕ, 3 ≤ N →
      (roughLargeCount (z N) N : ℝ) ≤ euler N * (Ered N : ℝ)) :
    IsMainBound exceptionalCount :=
  main_modulo_transfer_range_bounds z cls Mb Pz μ
    (fun N => εb N + Real.log 3 / μ N) Ered Ered_c₁ hc₁
    hEred_sum hPz hcard
    (per_class_transfer_of_finite_transfer cls Mb Pz μ εb Xpow nohit errTerm F2R εK
      hμ hPz hXpow hεb hdecomp herr hεle hlevel hF2R hnohit)
    hsaving
    smooth smoothExp smoothC hse_pos hse_lt hsC hsmooth hsmooth_nn
    hsmooth_range euler eulerC heC heuler_nn heuler hrough_range

/-- Concrete-Euler version of `main_modulo_finite_transfer_range_bounds`.

The finite-transfer ingredients still discharge the reduced-count estimate, and
the two range estimates still discharge the lifting field. The Euler factor is
fixed to the manuscript's finite product carrier. -/
theorem main_modulo_finite_transfer_range_bounds_concrete_euler
    {ι : Type*}
    (z : ℕ → ℕ)
    (cls : ℕ → Finset ι)
    (Mb : ℕ → ι → ℝ)
    (Pz μ εb : ℕ → ℝ)
    (Xpow nohit errTerm F2R : ℕ → ι → ℝ)
    (εK : ℝ)
    (Ered : ℕ → ℕ) (Ered_c₁ : ℝ)
    (hc₁ : 0 < Ered_c₁)
    (hEred_sum : ∀ N : ℕ, 3 ≤ N →
      (Ered N : ℝ) ≤ ∑ b ∈ cls N, Mb N b)
    (hμ : ∀ N : ℕ, 3 ≤ N → 0 < μ N)
    (hPz : ∀ N : ℕ, 3 ≤ N → 1 ≤ Pz N)
    (hXpow : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N, 0 ≤ Xpow N b)
    (hεb : ∀ N : ℕ, 3 ≤ N → 0 ≤ εb N)
    (hdecomp : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      Mb N b ≤ ((N : ℝ) / Pz N) * (nohit N b + F2R N b) + errTerm N b)
    (herr : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      errTerm N b ≤ Xpow N b * Real.exp ((1 + εK) * μ N))
    (hεle : εK ≤ 1)
    (hlevel : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      Pz N * Xpow N b * Real.exp (2 * μ N) ≤ (N : ℝ) * Real.exp (-4 * μ N))
    (hF2R : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      F2R N b ≤ Real.exp (-3 * μ N))
    (hnohit : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      nohit N b ≤ Real.exp (-(1 - εb N) * μ N))
    (hcard : ∀ N : ℕ, 3 ≤ N → ((cls N).card : ℝ) ≤ Pz N)
    (hsaving : ∀ N : ℕ, 3 ≤ N →
      Ered_c₁ * (Real.log N) ^ ((3 : ℝ) / 4)
        ≤ (1 - (εb N + Real.log 3 / μ N)) * μ N)
    (smooth : ℕ → ℝ) (smoothExp smoothC : ℝ)
    (hse_pos : 0 < smoothExp) (hse_lt : smoothExp < 1) (hsC : 0 < smoothC)
    (hsmooth : ∀ N : ℕ, 3 ≤ N → smooth N ≤ smoothC * (N : ℝ) ^ smoothExp)
    (hsmooth_nn : ∀ N : ℕ, 0 ≤ smooth N)
    (hsmooth_range : ∀ N : ℕ, 3 ≤ N →
      (smoothRangeCount (z N) N : ℝ) ≤ smooth N)
    (hrough_range : ∀ N : ℕ, 3 ≤ N →
      (roughLargeCount (z N) N : ℝ) ≤ eulerProductFactorAtNat N * (Ered N : ℝ)) :
    IsMainBound exceptionalCount :=
  main_modulo_transfer_range_bounds_concrete_euler z cls Mb Pz μ
    (fun N => εb N + Real.log 3 / μ N) Ered Ered_c₁ hc₁
    hEred_sum
    hPz hcard
    (per_class_transfer_of_finite_transfer cls Mb Pz μ εb Xpow nohit errTerm F2R εK
      hμ hPz hXpow hεb hdecomp herr hεle hlevel hF2R hnohit)
    hsaving
    smooth smoothExp smoothC hse_pos hse_lt hsC hsmooth hsmooth_nn
    hsmooth_range hrough_range

/-- Concrete-Euler finite-transfer capstone with the finite-level condition
discharged by the optimization lemma.

Compared with `main_modulo_finite_transfer_range_bounds_concrete_euler`, this
no longer takes the multiplicative level inequality as a primitive hypothesis.
For each class it is derived from the log-scale choice, the Mertens product
bound, the level-budget estimate, and the smallness condition on `α`. -/
theorem main_modulo_finite_transfer_range_bounds_concrete_euler_of_optimization
    {ι : Type*}
    (z : ℕ → ℕ)
    (cls : ℕ → Finset ι)
    (Mb : ℕ → ι → ℝ)
    (Pz μ εb : ℕ → ℝ)
    (Xpow nohit errTerm F2R : ℕ → ι → ℝ)
    (α R X : ℕ → ι → ℝ)
    (εK : ℝ)
    (Ered : ℕ → ℕ) (Ered_c₁ : ℝ)
    (hc₁ : 0 < Ered_c₁)
    (hEred_sum : ∀ N : ℕ, 3 ≤ N →
      (Ered N : ℝ) ≤ ∑ b ∈ cls N, Mb N b)
    (hμ : ∀ N : ℕ, 3 ≤ N → 0 < μ N)
    (hPz : ∀ N : ℕ, 3 ≤ N → 1 ≤ Pz N)
    (hXpow_pos : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N, 0 < Xpow N b)
    (hεb : ∀ N : ℕ, 3 ≤ N → 0 ≤ εb N)
    (hdecomp : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      Mb N b ≤ ((N : ℝ) / Pz N) * (nohit N b + F2R N b) + errTerm N b)
    (herr : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      errTerm N b ≤ Xpow N b * Real.exp ((1 + εK) * μ N))
    (hεle : εK ≤ 1)
    (hscale : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      Real.log (X N b) = α N b * (Real.log (N : ℝ)) ^ ((1 : ℝ) / 4))
    (hXpow_log : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      Real.log (Xpow N b) = 2 * R N b * Real.log (X N b))
    (hmertens : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      Real.log (Pz N) ≤ 2 * zScale (X N b))
    (hbudget : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      2 * R N b * Real.log (X N b) + 6 * μ N
        ≤ Cp * ((α N b) ^ 4 * Real.log (N : ℝ)))
    (hα_small : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      (2 + Cp) * (α N b) ^ 4 ≤ 1)
    (hF2R : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      F2R N b ≤ Real.exp (-3 * μ N))
    (hnohit : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      nohit N b ≤ Real.exp (-(1 - εb N) * μ N))
    (hcard : ∀ N : ℕ, 3 ≤ N → ((cls N).card : ℝ) ≤ Pz N)
    (hsaving : ∀ N : ℕ, 3 ≤ N →
      Ered_c₁ * (Real.log N) ^ ((3 : ℝ) / 4)
        ≤ (1 - (εb N + Real.log 3 / μ N)) * μ N)
    (smooth : ℕ → ℝ) (smoothExp smoothC : ℝ)
    (hse_pos : 0 < smoothExp) (hse_lt : smoothExp < 1) (hsC : 0 < smoothC)
    (hsmooth : ∀ N : ℕ, 3 ≤ N → smooth N ≤ smoothC * (N : ℝ) ^ smoothExp)
    (hsmooth_nn : ∀ N : ℕ, 0 ≤ smooth N)
    (hsmooth_range : ∀ N : ℕ, 3 ≤ N →
      (smoothRangeCount (z N) N : ℝ) ≤ smooth N)
    (hrough_range : ∀ N : ℕ, 3 ≤ N →
      (roughLargeCount (z N) N : ℝ) ≤ eulerProductFactorAtNat N * (Ered N : ℝ)) :
    IsMainBound exceptionalCount :=
  main_modulo_finite_transfer_range_bounds_concrete_euler z cls Mb Pz μ εb
    Xpow nohit errTerm F2R εK Ered Ered_c₁ hc₁ hEred_sum hμ hPz
    (fun N hN b hb => le_of_lt (hXpow_pos N hN b hb))
    hεb hdecomp herr hεle
    (fun N hN b hb =>
      finite_level_condition_of_optimization_of_one_le
        (hLN := Real.log_nonneg (by exact_mod_cast (by omega : 1 ≤ N)))
        (hLNeq := rfl)
        (hPz := hPz N hN)
        (hXpow := hXpow_pos N hN b hb)
        (hN := by exact_mod_cast (by omega : 0 < N))
        (hscale := hscale N hN b hb)
        (hXpow_log := hXpow_log N hN b hb)
        (mertens := hmertens N hN b hb)
        (hbudget := hbudget N hN b hb)
        (hα_small := hα_small N hN b hb))
    hF2R hnohit hcard hsaving
    smooth smoothExp smoothC hse_pos hse_lt hsC hsmooth hsmooth_nn
    hsmooth_range hrough_range

/-- Concrete-Euler finite-transfer capstone with the smooth range discharged by
the named Rankin summatory input at `z_N = ⌊(log N)^4⌋`.

This is the same strengthening as
`main_modulo_transfer_range_bounds_concrete_euler_rankin_smooth`, but starting
from the finite-transfer ingredients rather than an already-packaged per-class
transfer estimate. -/
theorem main_modulo_finite_transfer_range_bounds_concrete_euler_rankin_smooth
    {ι : Type*}
    (cls : ℕ → Finset ι)
    (Mb : ℕ → ι → ℝ)
    (Pz μ εb : ℕ → ℝ)
    (Xpow nohit errTerm F2R : ℕ → ι → ℝ)
    (εK : ℝ)
    (Ered : ℕ → ℕ) (Ered_c₁ : ℝ)
    (hc₁ : 0 < Ered_c₁)
    (hEred_sum : ∀ N : ℕ, 3 ≤ N →
      (Ered N : ℝ) ≤ ∑ b ∈ cls N, Mb N b)
    (hμ : ∀ N : ℕ, 3 ≤ N → 0 < μ N)
    (hPz : ∀ N : ℕ, 3 ≤ N → 1 ≤ Pz N)
    (hXpow : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N, 0 ≤ Xpow N b)
    (hεb : ∀ N : ℕ, 3 ≤ N → 0 ≤ εb N)
    (hdecomp : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      Mb N b ≤ ((N : ℝ) / Pz N) * (nohit N b + F2R N b) + errTerm N b)
    (herr : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      errTerm N b ≤ Xpow N b * Real.exp ((1 + εK) * μ N))
    (hεle : εK ≤ 1)
    (hlevel : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      Pz N * Xpow N b * Real.exp (2 * μ N) ≤ (N : ℝ) * Real.exp (-4 * μ N))
    (hF2R : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      F2R N b ≤ Real.exp (-3 * μ N))
    (hnohit : ∀ N : ℕ, 3 ≤ N → ∀ b ∈ cls N,
      nohit N b ≤ Real.exp (-(1 - εb N) * μ N))
    (hcard : ∀ N : ℕ, 3 ≤ N → ((cls N).card : ℝ) ≤ Pz N)
    (hsaving : ∀ N : ℕ, 3 ≤ N →
      Ered_c₁ * (Real.log N) ^ ((3 : ℝ) / 4)
        ≤ (1 - (εb N + Real.log 3 / μ N)) * μ N)
    (hrough_range : ∀ N : ℕ, 3 ≤ N →
      (roughLargeCount (zNatScale N) N : ℝ) ≤ eulerProductFactorAtNat N * (Ered N : ℝ)) :
    IsMainBound exceptionalCount :=
  main_modulo_transfer_range_bounds_concrete_euler_rankin_smooth cls Mb Pz μ
    (fun N => εb N + Real.log 3 / μ N) Ered Ered_c₁ hc₁
    hEred_sum
    hPz hcard
    (per_class_transfer_of_finite_transfer cls Mb Pz μ εb Xpow nohit errTerm F2R εK
      hμ hPz hXpow hεb hdecomp herr hεle hlevel hF2R hnohit)
    hsaving hrough_range

/-- Concrete-Euler Rankin-smooth main capstone from thresholded real
finite-transfer data, with the no-hit term discharged by the cited Suen
carrier.

Compared with `main_modulo_finite_transfer_range_bounds_concrete_euler_rankin_smooth`,
this version does not take a separate `hnohit` hypothesis.  It uses
`Ered_bound_global_of_large_suen_finite_transfer_ingredients_and_initial` to
derive the reduced-count saving from the Suen carrier, the supplied
`K * Delta * exp(2 delta) <= epsilon * mu` tail budget, and the explicit
finite-initial certificate. -/
theorem main_suen_finite_transfer_range_bounds_concrete_euler_smooth_cutoff_on_range_and_initial
    {ι : Type*}
    (cls : ℕ → Finset ι)
    (Mb : ℕ → ι → ℝ)
    (Pz μ εb : ℕ → ℝ)
    (δb Δb Xpow errTerm F2R : ℕ → ι → ℝ)
    (εK : ℝ)
    (Ered : ℕ → ℕ) (Ered_c₁ Cinit : ℝ) (T : ℕ)
    (hc₁ : 0 < Ered_c₁) (hCinit : 0 < Cinit)
    (hEred_sum : ∀ N : ℕ, 3 ≤ N →
      (Ered N : ℝ) ≤ ∑ b ∈ cls N, Mb N b)
    (hμ : ∀ N : ℕ, 3 ≤ N → T ≤ N → 0 < μ N)
    (hPz : ∀ N : ℕ, 3 ≤ N → T ≤ N → 1 ≤ Pz N)
    (hδ_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 0 ≤ δb N b)
    (hΔ_nonneg : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 0 ≤ Δb N b)
    (hXpow : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N, 0 ≤ Xpow N b)
    (hsuen_tail : ∀ K : ℝ, 0 < K → ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      K * Δb N b * Real.exp (2 * δb N b) ≤ εb N * μ N)
    (hdecomp : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      Mb N b ≤ ((N : ℝ) / Pz N) *
        (Inputs.suenProb (μ N) (δb N b) (Δb N b) + F2R N b) + errTerm N b)
    (herr : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      errTerm N b ≤ Xpow N b * Real.exp ((1 + εK) * μ N))
    (hεle : εK ≤ 1)
    (hlevel : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      Pz N * Xpow N b * Real.exp (2 * μ N) ≤ (N : ℝ) * Real.exp (-4 * μ N))
    (hF2R : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ b ∈ cls N,
      F2R N b ≤ Real.exp (-3 * μ N))
    (hcard : ∀ N : ℕ, 3 ≤ N → T ≤ N → ((cls N).card : ℝ) ≤ Pz N)
    (hsaving : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      Ered_c₁ * (Real.log N) ^ ((3 : ℝ) / 4)
        ≤ (1 - (εb N + Real.log 3 / μ N)) * μ N)
    (hinitial : ∀ N : ℕ, 3 ≤ N → N < T →
      (Ered N : ℝ) ≤ Cinit * ((N : ℝ) * saving Ered_c₁ N))
    (hrough_range : ∀ N : ℕ, 3 ≤ N →
      (roughLargeCount (zNatScale N) N : ℝ) ≤ eulerProductFactorAtNat N * (Ered N : ℝ)) :
    IsMainBound exceptionalCount := by
  rcases Ered_bound_global_of_large_suen_finite_transfer_ingredients_and_initial
      cls Mb Ered Pz μ εb δb Δb Xpow errTerm F2R εK Ered_c₁ Cinit T
      hc₁ hCinit hEred_sum hμ hPz hδ_nonneg hΔ_nonneg hXpow
      hsuen_tail hdecomp herr hεle hlevel hF2R hcard hsaving hinitial with
    ⟨Ered_C₁, hC₁, hEred⟩
  exact main_modulo_range_bounds_concrete_euler_rankin_smooth
    Ered Ered_c₁ Ered_C₁ hc₁ hC₁ hEred hrough_range

/-- A certified empty rough-large range supplies the concrete Euler rough-range
inequality used by the Suen finite-transfer main route. -/
theorem rough_range_bound_of_rough_zero
    (Ered : ℕ → ℕ)
    (hrough_zero : ∀ N : ℕ, 3 ≤ N → roughLargeCount (zNatScale N) N = 0) :
    ∀ N : ℕ, 3 ≤ N →
      (roughLargeCount (zNatScale N) N : ℝ) ≤
        eulerProductFactorAtNat N * (Ered N : ℝ) := by
  intro N hN
  have hprod_nonneg :
      0 ≤ eulerProductFactorAtNat N * (Ered N : ℝ) :=
    mul_nonneg (eulerProductFactorAtNat_nonneg N) (Nat.cast_nonneg _)
  simpa [hrough_zero N hN] using hprod_nonneg

/-- Exact reduced summatory carrier for the rough-large lifting range. -/
/- ## Reduced-class sums and quartic class budgets -/

noncomputable def reducedSumCountFor (z : ℕ → ℕ) (N : ℕ) : ℕ :=
  ∑ s ∈ Finset.Icc 1 N, reducedExceptionalCount (z N) (N / s)

/-- Real-valued form of the exact reduced summatory carrier. -/
theorem reducedSumCountFor_cast (z : ℕ → ℕ) (N : ℕ) :
    (reducedSumCountFor z N : ℝ) =
      ∑ s ∈ Finset.Icc 1 N,
        (reducedExceptionalCount (z N) (N / s) : ℝ) := by
  simp [reducedSumCountFor]

/-- The exact reduced carrier is dominated by its own finite class mass.

This is the local discharge for the `Ered_sum`-type hypothesis when the
paper-facing class mass is not a separate analytic object but exactly the
summatory reduced carrier written as a class sum over smooth parts. -/
theorem reducedSumCountFor_self_mass (z : ℕ → ℕ) :
    ∀ N : ℕ, 3 ≤ N →
      (reducedSumCountFor z N : ℝ) ≤
        ∑ s ∈ Finset.Icc 1 N,
          (reducedExceptionalCount (z N) (N / s) : ℝ) := by
  intro N _hN
  rw [reducedSumCountFor_cast]

/-- Field-equality form of `reducedSumCountFor_self_mass`.

If a finite-transfer package chooses the global class set to be the smooth-part
range and its mass to be the corresponding reduced exceptional count, then the
mass domination of the exact reduced carrier is finite bookkeeping. -/
theorem reducedSumCountFor_mass_of_self_fields
    (cls : ℕ → Finset ℕ)
    (Mb : ℕ → ℕ → ℝ)
    (hcls : ∀ N : ℕ, cls N = Finset.Icc 1 N)
    (hMb : ∀ N s : ℕ,
      Mb N s = (reducedExceptionalCount (zNatScale N) (N / s) : ℝ)) :
    ∀ N : ℕ, 3 ≤ N →
      (reducedSumCountFor zNatScale N : ℝ) ≤ ∑ b ∈ cls N, Mb N b := by
  intro N hN
  calc
    (reducedSumCountFor zNatScale N : ℝ)
        ≤ ∑ s ∈ Finset.Icc 1 N,
            (reducedExceptionalCount (zNatScale N) (N / s) : ℝ) :=
          reducedSumCountFor_self_mass zNatScale N hN
    _ = ∑ b ∈ cls N, Mb N b := by
          simp [hcls N, hMb]

/-- A reduced count is bounded by summing finite per-class majorants over any
class set covering the counted reduced exceptional integers.

This is finite bookkeeping: the reduced carrier is partitioned by `classOf`,
and each fiber is compared with its supplied majorant. -/
theorem reducedExceptionalCount_le_sum_class_majorants
    {κ : Type*} [DecidableEq κ]
    {z N : ℕ} (clsRed : Finset κ) (classOfRed : ℕ → κ) (Mred : κ → ℝ)
    (hred_class_mem : ∀ r ∈ ((Finset.Icc 1 N).filter
      (fun r => IsRough z r ∧ EscLeanChecks.esExceptional r)),
        classOfRed r ∈ clsRed)
    (hred_class_bound : ∀ b ∈ clsRed,
      ((((Finset.Icc 1 N).filter
        (fun r => (IsRough z r ∧ EscLeanChecks.esExceptional r) ∧
          classOfRed r = b)).card : ℕ) : ℝ) ≤ Mred b) :
    (reducedExceptionalCount z N : ℝ) ≤ ∑ b ∈ clsRed, Mred b := by
  classical
  set R : Finset ℕ :=
    (Finset.Icc 1 N).filter
      (fun r => IsRough z r ∧ EscLeanChecks.esExceptional r) with hR
  have hfib :=
    Finset.card_eq_sum_card_fiberwise (f := classOfRed) (s := R) (t := clsRed)
      (by
        intro r hr
        exact hred_class_mem r (by simpa [hR] using hr))
  have hclass' :
      ∀ b ∈ clsRed, ((R.filter (fun r => classOfRed r = b)).card : ℝ) ≤ Mred b := by
    intro b hb
    have hfilter :
        R.filter (fun r => classOfRed r = b) =
          (Finset.Icc 1 N).filter
            (fun r => (IsRough z r ∧ EscLeanChecks.esExceptional r) ∧
              classOfRed r = b) := by
      ext r
      simp [hR, and_left_comm, and_assoc]
    rw [hfilter]
    exact hred_class_bound b hb
  have hsum_class :
      (∑ b ∈ clsRed, ((R.filter (fun r => classOfRed r = b)).card : ℝ)) ≤
        ∑ b ∈ clsRed, Mred b := by
    exact Finset.sum_le_sum hclass'
  have hcast :
      (reducedExceptionalCount z N : ℝ) =
        ∑ b ∈ clsRed, ((R.filter (fun r => classOfRed r = b)).card : ℝ) := by
    rw [reducedExceptionalCount, ← hR, hfib]
    norm_num
  rw [hcast]
  exact hsum_class

/-- Canonical reduced-class set: the actual image of the reduced exceptional
carrier under the chosen class map. -/
noncomputable def reducedCanonicalClasses
    {κ : Type*} [DecidableEq κ] (z N : ℕ) (classOf : ℕ → κ) : Finset κ :=
  ((Finset.Icc 1 N).filter
    (fun r => IsRough z r ∧ EscLeanChecks.esExceptional r)).image classOf

/-- Every reduced exceptional denominator lands in the canonical reduced-class
set. -/
theorem reducedCanonicalClasses_mem
    {κ : Type*} [DecidableEq κ] (z N : ℕ) (classOf : ℕ → κ) :
    ∀ r ∈ ((Finset.Icc 1 N).filter
      (fun r => IsRough z r ∧ EscLeanChecks.esExceptional r)),
        classOf r ∈ reducedCanonicalClasses z N classOf := by
  intro r hr
  rw [reducedCanonicalClasses]
  exact Finset.mem_image.mpr ⟨r, hr, rfl⟩

/-- Each canonical reduced-class fiber is bounded by the total reduced
exceptional carrier. -/
theorem reducedCanonicalClassFiber_le_total
    {κ : Type*} [DecidableEq κ] (z N : ℕ) (classOf : ℕ → κ) (b : κ) :
    ((((Finset.Icc 1 N).filter
      (fun r => (IsRough z r ∧ EscLeanChecks.esExceptional r) ∧
        classOf r = b)).card : ℕ) : ℝ) ≤
      (reducedExceptionalCount z N : ℝ) := by
  have hcard :
      ((Finset.Icc 1 N).filter
        (fun r => (IsRough z r ∧ EscLeanChecks.esExceptional r) ∧
          classOf r = b)).card ≤
        ((Finset.Icc 1 N).filter
          (fun r => IsRough z r ∧ EscLeanChecks.esExceptional r)).card := by
    apply Finset.card_le_card
    intro r hr
    rw [Finset.mem_filter] at hr ⊢
    exact ⟨hr.1, hr.2.1⟩
  exact_mod_cast hcard

/-- Smooth-part reduced sums assembled from per-class majorants at every
smooth-part scale. -/
theorem reduced_sum_le_of_class_majorants
    {κ : Type*} [DecidableEq κ]
    {z N : ℕ} {euler Ered : ℝ}
    (clsRed : ℕ → Finset κ) (classOfRed : ℕ → ℕ → κ) (Mred : ℕ → κ → ℝ)
    (hred_class_mem : ∀ s ∈ Finset.Icc 1 N,
      ∀ r ∈ ((Finset.Icc 1 (N / s)).filter
        (fun r => IsRough z r ∧ EscLeanChecks.esExceptional r)),
          classOfRed s r ∈ clsRed s)
    (hred_class_bound : ∀ s ∈ Finset.Icc 1 N, ∀ b ∈ clsRed s,
      ((((Finset.Icc 1 (N / s)).filter
        (fun r => (IsRough z r ∧ EscLeanChecks.esExceptional r) ∧
          classOfRed s r = b)).card : ℕ) : ℝ) ≤ Mred s b)
    (hred_mass_sum : (∑ s ∈ Finset.Icc 1 N,
      ∑ b ∈ clsRed s, Mred s b) ≤ euler * Ered) :
    ((∑ s ∈ Finset.Icc 1 N, reducedExceptionalCount z (N / s)) : ℝ) ≤
      euler * Ered := by
  have hsum_point :
      (∑ s ∈ Finset.Icc 1 N,
        (reducedExceptionalCount z (N / s) : ℝ))
          ≤ ∑ s ∈ Finset.Icc 1 N, ∑ b ∈ clsRed s, Mred s b := by
    apply Finset.sum_le_sum
    intro s hs
    exact reducedExceptionalCount_le_sum_class_majorants
      (z := z) (N := N / s) (clsRed s) (classOfRed s) (Mred s)
      (hred_class_mem s hs) (hred_class_bound s hs)
  have hcast :
      ((∑ s ∈ Finset.Icc 1 N, reducedExceptionalCount z (N / s)) : ℝ) =
        ∑ s ∈ Finset.Icc 1 N, (reducedExceptionalCount z (N / s) : ℝ) := by
    norm_num
  rw [hcast]
  exact le_trans hsum_point hred_mass_sum

/-- Exact reduced-carrier mass domination from finite reduced-class majorants.

This discharges the non-analytic `Ered_sum` comparison when the reduced carrier
is the actual summatory rough carrier and the paper supplies a classwise
finite-transfer mass majorant. -/
theorem reducedSumCountFor_le_global_mass_of_reduced_class_majorants
    {ι κ : Type*} [DecidableEq κ]
    (cls : ℕ → Finset ι)
    (Mb : ℕ → ι → ℝ)
    (clsRed : ℕ → ℕ → Finset κ)
    (classOfRed : ℕ → ℕ → ℕ → κ)
    (Mred : ℕ → ℕ → κ → ℝ)
    (hred_class_mem : ∀ N : ℕ, 3 ≤ N → ∀ s ∈ Finset.Icc 1 N,
      ∀ r ∈ ((Finset.Icc 1 (N / s)).filter
        (fun r => IsRough (zNatScale N) r ∧ EscLeanChecks.esExceptional r)),
          classOfRed N s r ∈ clsRed N s)
    (hred_class_bound : ∀ N : ℕ, 3 ≤ N → ∀ s ∈ Finset.Icc 1 N,
      ∀ b ∈ clsRed N s,
        ((((Finset.Icc 1 (N / s)).filter
          (fun r => (IsRough (zNatScale N) r ∧ EscLeanChecks.esExceptional r) ∧
            classOfRed N s r = b)).card : ℕ) : ℝ) ≤ Mred N s b)
    (hred_mass_to_global : ∀ N : ℕ, 3 ≤ N →
      (∑ s ∈ Finset.Icc 1 N, ∑ b ∈ clsRed N s, Mred N s b) ≤
        ∑ b ∈ cls N, Mb N b) :
    ∀ N : ℕ, 3 ≤ N →
      (reducedSumCountFor zNatScale N : ℝ) ≤ ∑ b ∈ cls N, Mb N b := by
  intro N hN
  have hsum :
      ((∑ s ∈ Finset.Icc 1 N,
        reducedExceptionalCount (zNatScale N) (N / s)) : ℝ) ≤
          1 * (∑ b ∈ cls N, Mb N b) :=
    reduced_sum_le_of_class_majorants
      (z := zNatScale N) (N := N)
      (euler := 1) (Ered := ∑ b ∈ cls N, Mb N b)
      (clsRed N) (classOfRed N) (Mred N)
      (hred_class_mem N hN) (hred_class_bound N hN)
      (by simpa [one_mul] using hred_mass_to_global N hN)
  simpa [reducedSumCountFor, one_mul] using hsum

/-- Exact reduced-carrier mass domination for the canonical sigma-indexed
global class set.

This is the fully finite version of the reduced-carrier comparison: if the
global transfer classes are literally the pairs `(smooth part, reduced class)`,
then the comparison with the global mass is just `Finset.sum_sigma'`. -/
theorem reducedSumCountFor_le_sigma_class_majorants
    {κ : Type*} [DecidableEq κ]
    (clsRed : ℕ → ℕ → Finset κ)
    (classOfRed : ℕ → ℕ → ℕ → κ)
    (Mred : ℕ → ℕ → κ → ℝ)
    (hred_class_mem : ∀ N : ℕ, 3 ≤ N → ∀ s ∈ Finset.Icc 1 N,
      ∀ r ∈ ((Finset.Icc 1 (N / s)).filter
        (fun r => IsRough (zNatScale N) r ∧ EscLeanChecks.esExceptional r)),
          classOfRed N s r ∈ clsRed N s)
    (hred_class_bound : ∀ N : ℕ, 3 ≤ N → ∀ s ∈ Finset.Icc 1 N,
      ∀ b ∈ clsRed N s,
        ((((Finset.Icc 1 (N / s)).filter
          (fun r => (IsRough (zNatScale N) r ∧ EscLeanChecks.esExceptional r) ∧
            classOfRed N s r = b)).card : ℕ) : ℝ) ≤ Mred N s b) :
    ∀ N : ℕ, 3 ≤ N →
      (reducedSumCountFor zNatScale N : ℝ) ≤
        ∑ p ∈ (Finset.Icc 1 N).sigma (fun s => clsRed N s),
          Mred N p.1 p.2 := by
  intro N hN
  exact
    reducedSumCountFor_le_global_mass_of_reduced_class_majorants
      (fun N => (Finset.Icc 1 N).sigma (fun s => clsRed N s))
      (fun N p => Mred N p.1 p.2)
      clsRed classOfRed Mred hred_class_mem hred_class_bound
      (by
        intro N _hN
        exact le_of_eq
          (Finset.sum_sigma' (Finset.Icc 1 N) (fun s => clsRed N s)
            (fun s b => Mred N s b))) N hN

/-- The reduced-sum carrier is dominated by the canonical reduced-class image
with the total reduced count as a uniform class majorant. -/
theorem reducedSumCountFor_le_canonical_sigma_class_total_majorants
    {κ : Type*} [DecidableEq κ]
    (classOfRed : ℕ → ℕ → ℕ → κ) :
    ∀ N : ℕ, 3 ≤ N →
      (reducedSumCountFor zNatScale N : ℝ) ≤
        ∑ p ∈ (Finset.Icc 1 N).sigma
          (fun s => reducedCanonicalClasses (zNatScale N) (N / s)
            (classOfRed N s)),
          (reducedExceptionalCount (zNatScale N) (N / p.1) : ℝ) := by
  intro N hN
  exact
    reducedSumCountFor_le_sigma_class_majorants
      (fun N s =>
        reducedCanonicalClasses (zNatScale N) (N / s) (classOfRed N s))
      classOfRed
      (fun N s _b => (reducedExceptionalCount (zNatScale N) (N / s) : ℝ))
      (by
        intro N _hN s _hs r hr
        exact reducedCanonicalClasses_mem (zNatScale N) (N / s)
          (classOfRed N s) r hr)
      (by
        intro N _hN s _hs b _hb
        exact reducedCanonicalClassFiber_le_total (zNatScale N) (N / s)
          (classOfRed N s) b)
      N hN

/-- A sigma-indexed class count is controlled by local class-cardinality
bounds and their summed budget. -/
theorem sigma_class_card_le_sum_card_bounds
    {κ : Type*} [DecidableEq κ]
    (clsRed : ℕ → ℕ → Finset κ)
    (cardBound : ℕ → ℕ → ℝ)
    (N : ℕ) (_hN : 3 ≤ N)
    (hcard_local : ∀ s ∈ Finset.Icc 1 N,
      ((clsRed N s).card : ℝ) ≤ cardBound N s) :
      (((Finset.Icc 1 N).sigma (fun s => clsRed N s)).card : ℝ) ≤
        ∑ s ∈ Finset.Icc 1 N, cardBound N s := by
  rw [Finset.card_sigma]
  norm_num
  exact Finset.sum_le_sum (fun s hs => hcard_local s hs)

/-- The global sigma-class cardinality hypothesis follows from local
class-cardinality bounds and a global budget for those local bounds. -/
theorem sigma_class_card_bound_of_sum_card_bounds
    {κ : Type*} [DecidableEq κ]
    (clsRed : ℕ → ℕ → Finset κ)
    (cardBound : ℕ → ℕ → ℝ)
    (Pz : ℕ → ℝ) (T : ℕ)
    (hcard_local : ∀ N : ℕ, 3 ≤ N → T ≤ N → ∀ s ∈ Finset.Icc 1 N,
      ((clsRed N s).card : ℝ) ≤ cardBound N s)
    (hcard_budget : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      (∑ s ∈ Finset.Icc 1 N, cardBound N s) ≤ Pz N) :
    ∀ N : ℕ, 3 ≤ N → T ≤ N →
      (((Finset.Icc 1 N).sigma (fun s => clsRed N s)).card : ℝ) ≤ Pz N := by
  intro N hN hTN
  exact le_trans
    (sigma_class_card_le_sum_card_bounds clsRed cardBound N hN
      (fun s hs => hcard_local N hN hTN s hs))
    (hcard_budget N hN hTN)

/-- A pointwise transfer estimate on each local class gives the global
sigma-carrier transfer estimate expected by the finite-transfer summation
lemma. -/
theorem sigma_class_transfer_bound_of_local_class_transfer
    {κ : Type*} [DecidableEq κ]
    (clsRed : ℕ → ℕ → Finset κ)
    (Mred : ℕ → ℕ → κ → ℝ)
    (Pz μ ε : ℕ → ℝ) (T : ℕ)
    (htransfer_local : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      ∀ s ∈ Finset.Icc 1 N, ∀ b ∈ clsRed N s,
        Mred N s b ≤ ((N : ℝ) / Pz N) *
          Real.exp (-(1 - ε N) * μ N)) :
    ∀ N : ℕ, 3 ≤ N → T ≤ N →
      ∀ p ∈ (Finset.Icc 1 N).sigma (fun s => clsRed N s),
        Mred N p.1 p.2 ≤ ((N : ℝ) / Pz N) *
          Real.exp (-(1 - ε N) * μ N) := by
  intro N hN hTN p hp
  rcases p with ⟨s, b⟩
  rw [Finset.mem_sigma] at hp
  exact htransfer_local N hN hTN s hp.1 b hp.2

/-- Quartic reduced-sum saving from sigma-indexed finite-transfer data.

This is the quartic analogue of the reduced-sum finite-transfer core, but it
stops at the exact large-range reduced carrier.  The proof is not endpoint
packaging: it first dominates `reducedSumCountFor zNatScale N` by the
sigma-indexed class majorants, then applies the real-valued quartic
finite-transfer summation with the displayed `(log N)^(4/5)` exponent
comparison. -/
theorem reducedSumCountFor_quartic_saving_of_finite_transfer_sigma_class_majorants
    {κ : Type*} [DecidableEq κ]
    (clsRed : ℕ → ℕ → Finset κ)
    (classOfRed : ℕ → ℕ → ℕ → κ)
    (Mred : ℕ → ℕ → κ → ℝ)
    (Pz μ ε : ℕ → ℝ)
    (c₄ : ℝ) (T : ℕ)
    (hred_class_mem : ∀ N : ℕ, 3 ≤ N → ∀ s ∈ Finset.Icc 1 N,
      ∀ r ∈ ((Finset.Icc 1 (N / s)).filter
        (fun r => IsRough (zNatScale N) r ∧ EscLeanChecks.esExceptional r)),
          classOfRed N s r ∈ clsRed N s)
    (hred_class_bound : ∀ N : ℕ, 3 ≤ N → ∀ s ∈ Finset.Icc 1 N,
      ∀ b ∈ clsRed N s,
        ((((Finset.Icc 1 (N / s)).filter
          (fun r => (IsRough (zNatScale N) r ∧ EscLeanChecks.esExceptional r) ∧
            classOfRed N s r = b)).card : ℕ) : ℝ) ≤ Mred N s b)
    (hPz : ∀ N : ℕ, 3 ≤ N → T ≤ N → 1 ≤ Pz N)
    (hcard : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      (((Finset.Icc 1 N).sigma (fun s => clsRed N s)).card : ℝ) ≤ Pz N)
    (htransfer : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      ∀ p ∈ (Finset.Icc 1 N).sigma (fun s => clsRed N s),
        Mred N p.1 p.2 ≤ ((N : ℝ) / Pz N) *
          Real.exp (-(1 - ε N) * μ N))
    (hsaving : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      c₄ * (Real.log N) ^ ((4 : ℝ) / 5) ≤ (1 - ε N) * μ N) :
    ∀ N : ℕ, 3 ≤ N → T ≤ N →
      (reducedSumCountFor zNatScale N : ℝ) ≤
        (N : ℝ) * quarticSaving c₄ N := by
  intro N hN hTN
  have hmass :
      (reducedSumCountFor zNatScale N : ℝ) ≤
        ∑ p ∈ (Finset.Icc 1 N).sigma (fun s => clsRed N s),
          Mred N p.1 p.2 :=
    reducedSumCountFor_le_sigma_class_majorants
      clsRed classOfRed Mred hred_class_mem hred_class_bound N hN
  exact
    Ered_bound_of_finite_transfer_quartic
      ((Finset.Icc 1 N).sigma (fun s => clsRed N s))
      (Ered := (reducedSumCountFor zNatScale N : ℝ))
      (Mb := fun p => Mred N p.1 p.2)
      (N := (N : ℝ)) (Pz := Pz N) (μ := μ N)
      (ε := ε N) (c₄ := c₄) (Nnat := N)
      hmass (hPz N hN hTN) (Nat.cast_nonneg N)
      (hcard N hN hTN) (htransfer N hN hTN) (hsaving N hN hTN)

/-- Quartic reduced-sum saving from sigma-indexed finite-transfer data with the

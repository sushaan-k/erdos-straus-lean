    hsmooth_range (fun _ => 0) 1 zero_lt_one
    (fun _ => by norm_num)
    (fun N hN => by
      have hNge1 : (1 : ℝ) ≤ (N : ℝ) := by
        exact_mod_cast (by omega : 1 ≤ N)
      simpa using Real.log_nonneg hNge1)
    (fun N hN => by simp [hrough_zero N hN])


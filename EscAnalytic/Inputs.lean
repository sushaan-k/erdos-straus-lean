            0 ≤ roughRecip X M a b ∧
            c * (Real.log X / Real.log (EscAnalytic.zScale X)) ≤ roughRecip X M a b ∧
            roughRecip X M a b
                ≤ C * (Real.log X / Real.log (EscAnalytic.zScale X)) ∧
            |roughRecip X M a b|
                ≤ C * (Real.log X / Real.log (EscAnalytic.zScale X))) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ a b : ℝ, a₀ ≤ a → a < b → b ≤ b₀ → c₁ ≤ b - a →
        c * (Real.log X / Real.log (EscAnalytic.zScale X)) ≤ roughRecip X M a b
          ∧ roughRecip X M a b
              ≤ C * (Real.log X / Real.log (EscAnalytic.zScale X)) := by
  rcases h with ⟨c, C, X₀, hc, hC, hcarrier⟩
  refine ⟨c, C, X₀, hc, hC, ?_⟩
  intro X hX M hM a b ha hab hb hc₁
  have hpack := hcarrier X hX M hM a b ha hab hb hc₁
  exact ⟨hpack.2.2.2.2.1, hpack.2.2.2.2.2.1⟩

/-- Bare and carrier-bundled rough squarefree reciprocal estimates have the
same analytic content; the bundled form only records log and carrier side
facts needed downstream. -/
theorem rough_sqf_recip_bound_iff_carrier_bounds
    (a₀ b₀ c₁ C₀ : ℝ) :
    (∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ a b : ℝ, a₀ ≤ a → a < b → b ≤ b₀ → c₁ ≤ b - a →
        c * (Real.log X / Real.log (EscAnalytic.zScale X)) ≤ roughRecip X M a b
          ∧ roughRecip X M a b
              ≤ C * (Real.log X / Real.log (EscAnalytic.zScale X))) ↔
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ a b : ℝ, a₀ ≤ a → a < b → b ≤ b₀ → c₁ ≤ b - a →
        0 < Real.log X ∧
          0 < Real.log (EscAnalytic.zScale X) ∧
          0 < Real.log X / Real.log (EscAnalytic.zScale X) ∧
          0 ≤ roughRecip X M a b ∧
          c * (Real.log X / Real.log (EscAnalytic.zScale X)) ≤ roughRecip X M a b ∧
          roughRecip X M a b
              ≤ C * (Real.log X / Real.log (EscAnalytic.zScale X)) ∧
          |roughRecip X M a b|
              ≤ C * (Real.log X / Real.log (EscAnalytic.zScale X)) := by
  constructor
  · exact rough_sqf_recip_with_carrier_bounds_of_bound
  · exact rough_sqf_recip_bound_of_carrier_bounds

/-- Rough squarefree reciprocal estimate bundled with the checked logarithm,
carrier, and absolute-value side conditions used by the mass tensor.  The
two-sided reciprocal estimate is still derived from the count-level linear-sieve
input by `rough_sqf_recip`; this theorem only packages the surrounding
finite-carrier facts. -/
theorem rough_sqf_recip_with_carrier_bounds
    (P : EscAnalytic.Params) (a₀ b₀ c₁ C₀ : ℝ)
    (ha₀ : 0 < a₀) (hab : a₀ < b₀) (hc₁ : 0 < c₁) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
      ∀ a b : ℝ, a₀ ≤ a → a < b → b ≤ b₀ → c₁ ≤ b - a →
        0 < Real.log X ∧
          0 < Real.log (EscAnalytic.zScale X) ∧
          0 < Real.log X / Real.log (EscAnalytic.zScale X) ∧
          0 ≤ roughRecip X M a b ∧
          c * (Real.log X / Real.log (EscAnalytic.zScale X)) ≤ roughRecip X M a b ∧
          roughRecip X M a b
              ≤ C * (Real.log X / Real.log (EscAnalytic.zScale X)) ∧
          |roughRecip X M a b|
              ≤ C * (Real.log X / Real.log (EscAnalytic.zScale X)) := by
  exact rough_sqf_recip_with_carrier_bounds_of_bound
    (rough_sqf_recip P a₀ b₀ c₁ C₀ ha₀ hab hc₁)

/-- **Initial-segment rough reciprocal sums** (`lem:rough-initial`, tex 1050–1073).

The initial-segment sum `roughInitial X M σ₀ = ∑_{n ≤ X^{σ₀}, sqf,
(n,P(z))=1, (n,M)=1} 1/n`. -/
noncomputable def roughInitial (X : ℝ) (M : ℕ) (σ₀ : ℝ) : ℝ := by
  classical
  exact
    ∑ n ∈ (Finset.Icc (1 : ℕ) ⌊X ^ σ₀⌋₊).filter
        (fun n =>
          Squarefree n ∧ Nat.Coprime n (roughModulus X) ∧
            Nat.Coprime n (auxiliaryModulus M)),
      (1 : ℝ) / (n : ℝ)

/-- The initial rough reciprocal carrier is nonnegative. -/
theorem roughInitial_nonneg (X : ℝ) (M : ℕ) (σ₀ : ℝ) :
    0 ≤ roughInitial X M σ₀ := by
  classical
  unfold roughInitial
  apply Finset.sum_nonneg
  intro n _hn
  exact div_nonneg zero_le_one (Nat.cast_nonneg n)

/-- A rough reciprocal window ending at `X^σ₀` is contained in the corresponding
initial rough reciprocal carrier.  This is the set-theoretic bridge used in the
lower-bound half of `lem:rough-initial`. -/
theorem roughRecip_le_roughInitial (X : ℝ) (M : ℕ) (a σ₀ : ℝ) :
    roughRecip X M a σ₀ ≤ roughInitial X M σ₀ := by
  classical
  unfold roughRecip roughInitial
  apply Finset.sum_le_sum_of_subset_of_nonneg
  · intro n hn
    rw [Finset.mem_filter] at hn ⊢
    rcases hn with ⟨hnw, hpred⟩
    unfold natWindow at hnw
    rw [Finset.mem_filter] at hnw
    exact ⟨hnw.1, hpred⟩
  · intro n _hnInitial _hnNotRecip
    exact div_nonneg zero_le_one (Nat.cast_nonneg n)

/-- Lower-bound half of `lem:rough-initial` from the already packaged dyadic
rough-squarefree reciprocal estimate: restrict the initial segment to
`X^(σ₀/2) < n ≤ X^σ₀`. -/
theorem roughInitial_lower_of_roughRecip_carrier_bounds
    (σ₀ C₀ : ℝ) (hσ₀ : 0 < σ₀)
    (hrough :
      ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
        ∀ a b : ℝ, σ₀ / 2 ≤ a → a < b → b ≤ σ₀ → σ₀ / 2 ≤ b - a →
          0 < Real.log X ∧
            0 < Real.log (EscAnalytic.zScale X) ∧
            0 < Real.log X / Real.log (EscAnalytic.zScale X) ∧
            0 ≤ roughRecip X M a b ∧
            c * (Real.log X / Real.log (EscAnalytic.zScale X)) ≤ roughRecip X M a b ∧
            roughRecip X M a b
                ≤ C * (Real.log X / Real.log (EscAnalytic.zScale X)) ∧
            |roughRecip X M a b|
                ≤ C * (Real.log X / Real.log (EscAnalytic.zScale X))) :
    ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
        0 < Real.log X ∧
          0 < Real.log (EscAnalytic.zScale X) ∧
          0 < Real.log X / Real.log (EscAnalytic.zScale X) ∧
          c * (Real.log X / Real.log (EscAnalytic.zScale X)) ≤
            roughInitial X M σ₀ := by
  rcases hrough with ⟨c, _C, X₀, hc, _hC, hcarrier⟩
  refine ⟨c, X₀, hc, ?_⟩
  intro X hX M hM
  have hpack := hcarrier X hX M hM (σ₀ / 2) σ₀
    (by linarith) (by linarith) (by linarith) (by linarith)
  exact ⟨hpack.1, hpack.2.1, hpack.2.2.1,
    le_trans hpack.2.2.2.2.1 (roughRecip_le_roughInitial X M (σ₀ / 2) σ₀)⟩

/-- Paper-facing lower-bound bridge for `lem:rough-initial`.

The remaining upper bound with the full `1 / log z` saving is separate; this
theorem records the checked reduction of the lower bound to the standard dyadic
rough-squarefree reciprocal estimate. -/
theorem roughInitial_lower_from_rough_sqf_recip
    (P : EscAnalytic.Params) (σ₀ C₀ : ℝ) (hσ₀ : 0 < σ₀) :
    ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
        0 < Real.log X ∧
          0 < Real.log (EscAnalytic.zScale X) ∧
          0 < Real.log X / Real.log (EscAnalytic.zScale X) ∧
          c * (Real.log X / Real.log (EscAnalytic.zScale X)) ≤
            roughInitial X M σ₀ := by
  exact roughInitial_lower_of_roughRecip_carrier_bounds σ₀ C₀ hσ₀
    (rough_sqf_recip_with_carrier_bounds P (σ₀ / 2) σ₀ (σ₀ / 2) C₀
      (by linarith) (by linarith) (by linarith))

/-- The initial rough reciprocal carrier contains the `n = 1` term once
`X^σ₀ ≥ 1`.  This is only a constant lower fallback, not the rough-sieve
asymptotic from `lem:rough-initial`. -/
theorem one_le_roughInitial_of_one_le_rpow
    (X : ℝ) (M : ℕ) (σ₀ : ℝ) (hcut : 1 ≤ X ^ σ₀) :
    1 ≤ roughInitial X M σ₀ := by
  classical
  unfold roughInitial
  have hone_mem :
      1 ∈ (Finset.Icc (1 : ℕ) ⌊X ^ σ₀⌋₊).filter
          (fun n =>
            Squarefree n ∧ Nat.Coprime n (roughModulus X) ∧
              Nat.Coprime n (auxiliaryModulus M)) := by
    rw [Finset.mem_filter]
    refine ⟨?_, squarefree_one, Nat.coprime_one_left _, Nat.coprime_one_left _⟩
    rw [Finset.mem_Icc]
    have hcut' : ((1 : ℕ) : ℝ) ≤ X ^ σ₀ := by
      simpa using hcut
    exact ⟨le_rfl, Nat.le_floor hcut'⟩
  have hnonneg :
      ∀ n ∈ (Finset.Icc (1 : ℕ) ⌊X ^ σ₀⌋₊).filter
          (fun n =>
            Squarefree n ∧ Nat.Coprime n (roughModulus X) ∧
              Nat.Coprime n (auxiliaryModulus M)),
        0 ≤ (1 : ℝ) / (n : ℝ) := by
    intro n _hn
    exact div_nonneg zero_le_one (Nat.cast_nonneg n)
  have hterm :
      ((1 : ℝ) / ((1 : ℕ) : ℝ))
        ≤ ∑ n ∈ (Finset.Icc (1 : ℕ) ⌊X ^ σ₀⌋₊).filter
            (fun n =>
              Squarefree n ∧ Nat.Coprime n (roughModulus X) ∧
                Nat.Coprime n (auxiliaryModulus M)),
          (1 : ℝ) / (n : ℝ) :=
    Finset.single_le_sum hnonneg hone_mem
  simpa using hterm

/-- The initial rough reciprocal carrier is bounded by the full harmonic sum up
to the same cutoff. -/
theorem roughInitial_le_harmonic_floor (X : ℝ) (M : ℕ) (σ₀ : ℝ) :
    roughInitial X M σ₀ ≤ (harmonic ⌊X ^ σ₀⌋₊ : ℝ) := by
  classical
  unfold roughInitial
  rw [harmonic_eq_sum_Icc]
  simp only [Rat.cast_sum, Rat.cast_inv, Rat.cast_natCast]
  simp_rw [one_div]
  apply Finset.sum_le_sum_of_subset_of_nonneg
  · intro n hn
    exact (Finset.mem_filter.mp hn).1
  · intro n _hnBig _hnSmall
    exact inv_nonneg.mpr (Nat.cast_nonneg n)

/-- Split the initial rough reciprocal carrier at an arbitrary real cutoff.

The part below the cutoff is bounded by the ordinary harmonic sum; the part
above it embeds into the Selberg carrier with trivial congruence modulus and
the same auxiliary coprimality.  This is the finite combinatorial bridge used
for the upper half of `lem:rough-initial`: after choosing the cutoff as a fixed
power of `z`, the first term is tiny and the second term is handled by the
cited Selberg upper bound. -/
theorem roughInitial_le_harmonic_floor_add_selbergSum
    (X : ℝ) (M : ℕ) (σ₀ U : ℝ) :
    roughInitial X M σ₀ ≤
      (harmonic ⌊U⌋₊ : ℝ) +
        selbergSum X 1 0 (auxiliaryModulus M) U (X ^ σ₀) := by
  classical
  let A : Finset ℕ :=
    (Finset.Icc (1 : ℕ) ⌊X ^ σ₀⌋₊).filter
      (fun n =>
        Squarefree n ∧ Nat.Coprime n (roughModulus X) ∧
          Nat.Coprime n (auxiliaryModulus M))
  let f : ℕ → ℝ := fun n => (1 : ℝ) / (n : ℝ)
  have hsplit :
      (∑ n ∈ A, f n) =
        (∑ n ∈ A.filter (fun n : ℕ => (n : ℝ) ≤ U), f n) +
          ∑ n ∈ A.filter (fun n : ℕ => ¬ (n : ℝ) ≤ U), f n := by
    simpa [A, f] using
      (Finset.sum_filter_add_sum_filter_not (s := A)
        (p := fun n : ℕ => (n : ℝ) ≤ U) (f := f)).symm
  have hsmall :
      (∑ n ∈ A.filter (fun n : ℕ => (n : ℝ) ≤ U), f n) ≤
        (harmonic ⌊U⌋₊ : ℝ) := by
    have hsmall_subset :
        (∑ n ∈ A.filter (fun n : ℕ => (n : ℝ) ≤ U), f n) ≤
          ∑ n ∈ Finset.Icc (1 : ℕ) ⌊U⌋₊, f n := by
      apply Finset.sum_le_sum_of_subset_of_nonneg
      · intro n hn
        rw [Finset.mem_filter] at hn
        rcases hn with ⟨hnA, hn_le_U⟩
        rw [Finset.mem_Icc]
        rw [Finset.mem_filter] at hnA
        exact ⟨(Finset.mem_Icc.mp hnA.1).1, Nat.le_floor hn_le_U⟩
      · intro n _hnBig _hnSmall
        dsimp [f]
        exact div_nonneg zero_le_one (Nat.cast_nonneg n)
    calc
      (∑ n ∈ A.filter (fun n : ℕ => (n : ℝ) ≤ U), f n)
          ≤ ∑ n ∈ Finset.Icc (1 : ℕ) ⌊U⌋₊, f n := hsmall_subset
      _ = (harmonic ⌊U⌋₊ : ℝ) := by
          rw [harmonic_eq_sum_Icc]
          simp [f, one_div]
  have hlarge :
      (∑ n ∈ A.filter (fun n : ℕ => ¬ (n : ℝ) ≤ U), f n) ≤
        selbergSum X 1 0 (auxiliaryModulus M) U (X ^ σ₀) := by
    unfold selbergSum
    apply Finset.sum_le_sum_of_subset_of_nonneg
    · intro n hn
      rw [Finset.mem_filter] at hn ⊢
      rcases hn with ⟨hnA, hn_not_le⟩
      rw [Finset.mem_filter] at hnA
      refine ⟨?_, ?_⟩
      · unfold natWindow
        rw [Finset.mem_filter]
        exact ⟨hnA.1, lt_of_not_ge hn_not_le⟩
      · exact ⟨Nat.mod_one n, hnA.2.2.1, hnA.2.2.2⟩
    · intro n _hnBig _hnSmall
      exact div_nonneg zero_le_one (Nat.cast_nonneg n)
  calc
    roughInitial X M σ₀ = ∑ n ∈ A, f n := by
      rfl
    _ = (∑ n ∈ A.filter (fun n : ℕ => (n : ℝ) ≤ U), f n) +
          ∑ n ∈ A.filter (fun n : ℕ => ¬ (n : ℝ) ≤ U), f n := hsplit
    _ ≤ (harmonic ⌊U⌋₊ : ℝ) +
          selbergSum X 1 0 (auxiliaryModulus M) U (X ^ σ₀) :=
        add_le_add hsmall hlarge

/-- The small cutoff contribution in the rough-initial split is controlled by
the usual harmonic estimate once the cutoff has the target logarithmic growth.

This isolates the elementary side of the upper half of `lem:rough-initial`: for
a cutoff `U X`, it is enough to prove eventually `U X ≥ 1` and
`1 + log(U X) ≪ log X / log z`. -/
theorem roughInitial_small_harmonic_upper_of_cutoff_log_bound
    (U : ℝ → ℝ)
    (hcut :
      ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        1 ≤ U X ∧
          1 + Real.log (U X) ≤
            C * (Real.log X / Real.log (EscAnalytic.zScale X))) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      (harmonic ⌊U X⌋₊ : ℝ) ≤
        C * (Real.log X / Real.log (EscAnalytic.zScale X)) := by
  rcases hcut with ⟨C, X₀, hC, hcut⟩
  refine ⟨C, X₀, hC, ?_⟩
  intro X hX
  rcases hcut X hX with ⟨hU_ge_one, hlogU⟩
  exact (harmonic_floor_le_one_add_log (U X) hU_ge_one).trans hlogU

/-- Upper half of `lem:rough-initial` after the finite split.

This theorem contains no new analytic input: it says that if a chosen cutoff
`U X` has the normalized harmonic bound for the tiny initial piece, and the
remaining Selberg carrier has the same normalized bound, then the complete
initial rough reciprocal carrier has the desired upper bound.  The two
premises are the precise residual analytic/growth obligations left after the
finite split. -/
theorem roughInitial_upper_of_harmonic_and_selberg_bounds
    (σ₀ C₀ : ℝ) (U : ℝ → ℝ)
    (hsmall :
      ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        (harmonic ⌊U X⌋₊ : ℝ) ≤
          C * (Real.log X / Real.log (EscAnalytic.zScale X)))
    (hselberg :
      ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        ∀ M : ℕ, (M : ℝ) ≤ X ^ C₀ →
          selbergSum X 1 0 (auxiliaryModulus M) (U X) (X ^ σ₀) ≤
            C * (Real.log X / Real.log (EscAnalytic.zScale X))) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ M : ℕ, (M : ℝ) ≤ X ^ C₀ →
        roughInitial X M σ₀ ≤
          C * (Real.log X / Real.log (EscAnalytic.zScale X)) := by
  rcases hsmall with ⟨Csmall, Xsmall, hCsmall, hsmall_bound⟩
  rcases hselberg with ⟨Cselberg, Xselberg, hCselberg, hselberg_bound⟩
  refine ⟨Csmall + Cselberg, max Xsmall Xselberg,
    add_pos hCsmall hCselberg, ?_⟩
  intro X hX M hM
  have hXsmall : Xsmall ≤ X := le_trans (le_max_left _ _) hX
  have hXselberg : Xselberg ≤ X := le_trans (le_max_right _ _) hX
  have hsplit := roughInitial_le_harmonic_floor_add_selbergSum
    X M σ₀ (U X)
  calc
    roughInitial X M σ₀
        ≤ (harmonic ⌊U X⌋₊ : ℝ) +
            selbergSum X 1 0 (auxiliaryModulus M) (U X) (X ^ σ₀) := hsplit
    _ ≤ Csmall * (Real.log X / Real.log (EscAnalytic.zScale X)) +
          Cselberg * (Real.log X / Real.log (EscAnalytic.zScale X)) :=
        add_le_add (hsmall_bound X hXsmall)
          (hselberg_bound X hXselberg M hM)
    _ = (Csmall + Cselberg) *
          (Real.log X / Real.log (EscAnalytic.zScale X)) := by
        ring

/-- Selberg upper bound for the tail window in `lem:rough-initial`.

This instantiates the cited long-progression Selberg input with trivial
congruence modulus `D = 1` and the auxiliary coprimality modulus used by
`roughInitial`.  All cutoff work is left as explicit side conditions: the
chosen cutoff `U X` must be a positive long-window lower endpoint, it must sit
below `X^σ₀`, the Selberg range condition must hold, and the logarithmic window
length must be `O(log X)`. -/
theorem roughInitial_tail_selberg_upper_of_long_window
    (σ₀ C₀ A₀ c₀ K : ℝ) (U : ℝ → ℝ)
    (hA₀ : 3 < A₀) (hc₀ : 0 < c₀) (hK : 0 < K)
    (hwindow :
      ∃ X₀ : ℝ, ∀ X : ℝ, X₀ ≤ X →
        0 < U X ∧
          U X ≤ X ^ σ₀ ∧
          (EscAnalytic.zScale X) ^ A₀ ≤ U X ∧
          X ^ c₀ ≤ X ^ σ₀ / U X ∧
          Real.log (X ^ σ₀ / U X) ≤ K * Real.log X) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ M : ℕ, (M : ℝ) ≤ X ^ C₀ →
        selbergSum X 1 0 (auxiliaryModulus M) (U X) (X ^ σ₀) ≤
          C * (Real.log X / Real.log (EscAnalytic.zScale X)) := by
  rcases selberg_upper_long_progressions A₀ c₀ hA₀ hc₀ with
    ⟨Cselberg, Xselberg, hCselberg, hselberg⟩
  rcases hwindow with ⟨Xwindow, hwindow⟩
  refine ⟨Cselberg * K, max Xselberg (max Xwindow (Real.exp 2)),
    mul_pos hCselberg hK, ?_⟩
  intro X hX M _hM
  have hXselberg : Xselberg ≤ X :=
    le_trans (le_max_left _ _) hX
  have hXwindow : Xwindow ≤ X :=
    le_trans (le_trans (le_max_left _ _) (le_max_right _ _)) hX
  have hXexp2 : Real.exp 2 ≤ X :=
    le_trans (le_trans (le_max_right _ _) (le_max_right _ _)) hX
  rcases hwindow X hXwindow with
    ⟨hUpos, hUle, hUlong, hratio, hlogratio⟩
  have hlogz_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp2
  have hselberg_raw :
      selbergSum X 1 0 (auxiliaryModulus M) (U X) (X ^ σ₀) ≤
        Cselberg *
          (Real.log (X ^ σ₀ / U X) /
            (((1 : ℕ) : ℝ) * Real.log (EscAnalytic.zScale X))) :=
    hselberg X hXselberg 1 0 (auxiliaryModulus M)
      (by norm_num) squarefree_one
      (Nat.coprime_one_left (roughModulus X))
      (by simp : Nat.Coprime 0 1)
      (U X) (X ^ σ₀) hUpos hUle
      (by simpa using hUlong) hratio
  have hselberg_simplified :
      selbergSum X 1 0 (auxiliaryModulus M) (U X) (X ^ σ₀) ≤
        Cselberg *
          (Real.log (X ^ σ₀ / U X) /
            Real.log (EscAnalytic.zScale X)) := by
    simpa using hselberg_raw
  calc
    selbergSum X 1 0 (auxiliaryModulus M) (U X) (X ^ σ₀)
        ≤ Cselberg *
            (Real.log (X ^ σ₀ / U X) /
              Real.log (EscAnalytic.zScale X)) := hselberg_simplified
    _ ≤ Cselberg * ((K * Real.log X) /
          Real.log (EscAnalytic.zScale X)) := by
          exact mul_le_mul_of_nonneg_left
            (div_le_div_of_nonneg_right hlogratio hlogz_pos.le)
            hCselberg.le
    _ = (Cselberg * K) *
          (Real.log X / Real.log (EscAnalytic.zScale X)) := by
          ring

/-- Upper half of `lem:rough-initial` from explicit cutoff-growth hypotheses.

This packages the three checked pieces now available:

* the finite split of `roughInitial` into a small harmonic part and a Selberg
  tail;
* the harmonic estimate for the small part from a cutoff log-growth condition;
* the cited Selberg upper-bound sieve instantiated on the tail window.

The only remaining work is to supply the concrete cutoff `U` and prove the
displayed elementary growth/window inequalities. -/
theorem roughInitial_upper_of_cutoff_growth_and_selberg_long_window
    (σ₀ C₀ A₀ c₀ K : ℝ) (U : ℝ → ℝ)
    (hA₀ : 3 < A₀) (hc₀ : 0 < c₀) (hK : 0 < K)
    (hsmall :
      ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        1 ≤ U X ∧
          1 + Real.log (U X) ≤
            C * (Real.log X / Real.log (EscAnalytic.zScale X)))
    (hwindow :
      ∃ X₀ : ℝ, ∀ X : ℝ, X₀ ≤ X →
        0 < U X ∧
          U X ≤ X ^ σ₀ ∧
          (EscAnalytic.zScale X) ^ A₀ ≤ U X ∧
          X ^ c₀ ≤ X ^ σ₀ / U X ∧
          Real.log (X ^ σ₀ / U X) ≤ K * Real.log X) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ M : ℕ, (M : ℝ) ≤ X ^ C₀ →
        roughInitial X M σ₀ ≤
          C * (Real.log X / Real.log (EscAnalytic.zScale X)) :=
  roughInitial_upper_of_harmonic_and_selberg_bounds σ₀ C₀ U
    (roughInitial_small_harmonic_upper_of_cutoff_log_bound U hsmall)
    (roughInitial_tail_selberg_upper_of_long_window σ₀ C₀ A₀ c₀ K U
      hA₀ hc₀ hK hwindow)

/-- The fixed polylogarithmic cutoff `U(X)=z(X)^A₀` has the logarithmic size
needed for the small harmonic part of `lem:rough-initial`. -/
theorem zScale_power_cutoff_small_harmonic_log_bound
    (A₀ : ℝ) (hA₀pos : 0 < A₀) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      1 ≤ (EscAnalytic.zScale X) ^ A₀ ∧
        1 + Real.log ((EscAnalytic.zScale X) ^ A₀) ≤
          C * (Real.log X / Real.log (EscAnalytic.zScale X)) := by
  rcases eventually_log_zScale_sq_le_sixteen_mul_log with ⟨Xsq, hsq⟩
  refine ⟨16 * (1 + A₀),
    max Xsq (max (Real.exp 2) (Real.exp (Real.exp 1))), ?_, ?_⟩
  · positivity
  intro X hX
  have hXsq : Xsq ≤ X := le_trans (le_max_left _ _) hX
  have hXexp2 : Real.exp 2 ≤ X :=
    le_trans (le_trans (le_max_left _ _) (le_max_right _ _)) hX
  have hXexpExp : Real.exp (Real.exp 1) ≤ X :=
    le_trans (le_trans (le_max_right _ _) (le_max_right _ _)) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos _) hXexpExp
  have hlogX_ge_exp : Real.exp 1 ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hXexpExp
  have hlogX_ge_one : (1 : ℝ) ≤ Real.log X :=
    le_trans (by norm_num : (1 : ℝ) ≤ Real.exp 1) hlogX_ge_exp
  have hz_ge_one : (1 : ℝ) ≤ EscAnalytic.zScale X := by
    unfold EscAnalytic.zScale
    calc
      (1 : ℝ) = (1 : ℝ) ^ (4 : ℕ) := by norm_num
      _ ≤ (Real.log X) ^ (4 : ℕ) :=
          pow_le_pow_left₀ zero_le_one hlogX_ge_one 4
  have hU_ge_one : 1 ≤ (EscAnalytic.zScale X) ^ A₀ :=
    Real.one_le_rpow hz_ge_one hA₀pos.le
  have hlogz_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp2
  have hlogz_ge_one : (1 : ℝ) ≤ Real.log (EscAnalytic.zScale X) := by
    have hloglog_ge_one : (1 : ℝ) ≤ Real.log (Real.log X) := by
      rw [Real.le_log_iff_exp_le
        (lt_of_lt_of_le (Real.exp_pos 1) hlogX_ge_exp)]
      exact hlogX_ge_exp
    have hlogZ_eq :
        Real.log (EscAnalytic.zScale X) = 4 * Real.log (Real.log X) := by
      unfold EscAnalytic.zScale
      rw [Real.log_pow]
      ring
    rw [hlogZ_eq]
    nlinarith
  have hlogU : Real.log ((EscAnalytic.zScale X) ^ A₀) =
      A₀ * Real.log (EscAnalytic.zScale X) := by
    rw [Real.log_rpow (lt_of_lt_of_le (by norm_num : (0 : ℝ) < 1) hz_ge_one)]
  have hlinear :
      1 + Real.log ((EscAnalytic.zScale X) ^ A₀) ≤
        (1 + A₀) * Real.log (EscAnalytic.zScale X) := by
    rw [hlogU]
    nlinarith [hlogz_ge_one, hA₀pos.le]
  have hmain :
      Real.log (EscAnalytic.zScale X) ≤
        16 * (Real.log X / Real.log (EscAnalytic.zScale X)) := by
    have hsquare := hsq X hXsq
    calc
      Real.log (EscAnalytic.zScale X)
          = (Real.log (EscAnalytic.zScale X)) ^ 2 /
              Real.log (EscAnalytic.zScale X) := by
            field_simp [ne_of_gt hlogz_pos]
            ring
      _ ≤ (16 * Real.log X) / Real.log (EscAnalytic.zScale X) :=
            div_le_div_of_nonneg_right hsquare hlogz_pos.le
      _ = 16 * (Real.log X / Real.log (EscAnalytic.zScale X)) := by ring
  refine ⟨hU_ge_one, ?_⟩
  calc
    1 + Real.log ((EscAnalytic.zScale X) ^ A₀)
        ≤ (1 + A₀) * Real.log (EscAnalytic.zScale X) := hlinear
    _ ≤ (1 + A₀) *
          (16 * (Real.log X / Real.log (EscAnalytic.zScale X))) := by
          exact mul_le_mul_of_nonneg_left hmain (by linarith [hA₀pos.le])
    _ = (16 * (1 + A₀)) *
          (Real.log X / Real.log (EscAnalytic.zScale X)) := by ring

/-- The cutoff `U(X)=z(X)^A₀` lies in a genuine long Selberg window inside
`[1,X^σ₀]`, after shrinking the Selberg ratio exponent to `σ₀/2`. -/
theorem zScale_power_cutoff_long_window
    (σ₀ A₀ : ℝ) (hσ₀ : 0 < σ₀) (hA₀pos : 0 < A₀) :
    ∃ X₀ : ℝ, ∀ X : ℝ, X₀ ≤ X →
      0 < (EscAnalytic.zScale X) ^ A₀ ∧
        (EscAnalytic.zScale X) ^ A₀ ≤ X ^ σ₀ ∧
        (EscAnalytic.zScale X) ^ A₀ ≤ (EscAnalytic.zScale X) ^ A₀ ∧
        X ^ (σ₀ / 2) ≤ X ^ σ₀ / (EscAnalytic.zScale X) ^ A₀ ∧
        Real.log (X ^ σ₀ / (EscAnalytic.zScale X) ^ A₀) ≤
          σ₀ * Real.log X := by
  have heps : 0 < σ₀ / (2 * A₀) :=
    div_pos hσ₀ (mul_pos (by norm_num) hA₀pos)
  rcases eventually_log_zScale_le_eps_mul_log heps with ⟨Xeps, heps_bound⟩
  refine ⟨max Xeps (Real.exp 2), ?_⟩
  intro X hX
  have hXeps : Xeps ≤ X := le_trans (le_max_left _ _) hX
  have hXexp2 : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 2) hXexp2
  have hXone : 1 < X :=
    lt_of_lt_of_le (Real.one_lt_exp_iff.mpr (by norm_num : (0 : ℝ) < 2)) hXexp2
  have hlogX_pos : 0 < Real.log X := by
    have hlogX_ge_two : (2 : ℝ) ≤ Real.log X := by
      rw [Real.le_log_iff_exp_le hXpos]
      exact hXexp2
    exact lt_of_lt_of_le (by norm_num : (0 : ℝ) < 2) hlogX_ge_two
  have hz_pos : 0 < EscAnalytic.zScale X := by
    unfold EscAnalytic.zScale
    positivity
  have hUpos : 0 < (EscAnalytic.zScale X) ^ A₀ :=
    Real.rpow_pos_of_pos hz_pos A₀
  have hXhalf_pos : 0 < X ^ (σ₀ / 2) := Real.rpow_pos_of_pos hXpos _
  have hXsigma_pos : 0 < X ^ σ₀ := Real.rpow_pos_of_pos hXpos _
  have hlogz_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp2
  have hlogU : Real.log ((EscAnalytic.zScale X) ^ A₀) =
      A₀ * Real.log (EscAnalytic.zScale X) := by
    rw [Real.log_rpow hz_pos]
  have hlogXhalf : Real.log (X ^ (σ₀ / 2)) = (σ₀ / 2) * Real.log X := by
    rw [Real.log_rpow hXpos]
  have hlogXsigma : Real.log (X ^ σ₀) = σ₀ * Real.log X := by
    rw [Real.log_rpow hXpos]
  have hlogU_le_half : Real.log ((EscAnalytic.zScale X) ^ A₀) ≤
      (σ₀ / 2) * Real.log X := by
    rw [hlogU]
    have h := heps_bound X hXeps
    calc
      A₀ * Real.log (EscAnalytic.zScale X)
          ≤ A₀ * ((σ₀ / (2 * A₀)) * Real.log X) :=
            mul_le_mul_of_nonneg_left h hA₀pos.le
      _ = (σ₀ / 2) * Real.log X := by
            field_simp [ne_of_gt hA₀pos]
            ring
  have hU_le_half : (EscAnalytic.zScale X) ^ A₀ ≤ X ^ (σ₀ / 2) := by
    apply (Real.log_le_log_iff hUpos hXhalf_pos).mp
    rwa [hlogXhalf]
  have hhalf_le_sigma : X ^ (σ₀ / 2) ≤ X ^ σ₀ := by
    exact Real.rpow_le_rpow_of_exponent_le hXone.le (by linarith [hσ₀])
  have hU_le_sigma : (EscAnalytic.zScale X) ^ A₀ ≤ X ^ σ₀ :=
    le_trans hU_le_half hhalf_le_sigma
  have hratio_pos : 0 < X ^ σ₀ / (EscAnalytic.zScale X) ^ A₀ :=
    div_pos hXsigma_pos hUpos
  have hhalf_le_ratio :
      X ^ (σ₀ / 2) ≤ X ^ σ₀ / (EscAnalytic.zScale X) ^ A₀ := by
    apply (Real.log_le_log_iff hXhalf_pos hratio_pos).mp
    have hlogratio :
        Real.log (X ^ σ₀ / (EscAnalytic.zScale X) ^ A₀) =
          σ₀ * Real.log X - A₀ * Real.log (EscAnalytic.zScale X) := by
      rw [Real.log_div (ne_of_gt hXsigma_pos) (ne_of_gt hUpos),
        hlogXsigma, hlogU]
    rw [hlogXhalf, hlogratio]
    linarith [hlogU_le_half]
  have hlogratio_le :
      Real.log (X ^ σ₀ / (EscAnalytic.zScale X) ^ A₀) ≤ σ₀ * Real.log X := by
    have hlogratio :
        Real.log (X ^ σ₀ / (EscAnalytic.zScale X) ^ A₀) =
          σ₀ * Real.log X - A₀ * Real.log (EscAnalytic.zScale X) := by
      rw [Real.log_div (ne_of_gt hXsigma_pos) (ne_of_gt hUpos),
        hlogXsigma, hlogU]
    rw [hlogratio]
    nlinarith [hA₀pos.le, hlogz_pos.le]
  exact ⟨hUpos, hU_le_sigma, le_rfl, hhalf_le_ratio, hlogratio_le⟩

/-- Normalized upper half of `lem:rough-initial` for the concrete cutoff
`U(X)=z(X)^A₀`, derived from the cited Selberg upper-bound sieve and elementary
polylogarithmic growth. -/
theorem roughInitial_upper_of_zScale_power_cutoff
    (σ₀ C₀ A₀ : ℝ) (hσ₀ : 0 < σ₀) (hA₀ : 3 < A₀) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ M : ℕ, (M : ℝ) ≤ X ^ C₀ →
        roughInitial X M σ₀ ≤
          C * (Real.log X / Real.log (EscAnalytic.zScale X)) :=
  roughInitial_upper_of_cutoff_growth_and_selberg_long_window
    σ₀ C₀ A₀ (σ₀ / 2) σ₀ (fun X => (EscAnalytic.zScale X) ^ A₀)
    hA₀ (by positivity) hσ₀
    (zScale_power_cutoff_small_harmonic_log_bound A₀ (lt_trans (by norm_num) hA₀))
    (zScale_power_cutoff_long_window σ₀ A₀ hσ₀ (lt_trans (by norm_num) hA₀))

/-- Two-sided rough-initial estimate with the paper's normalization.

The lower half is inherited from the fixed-log-power rough-window input via the
checked dyadic reciprocal route; the upper half is now the concrete Selberg
split with cutoff `z^A₀`. -/
theorem roughInitial_two_sided_from_rough_sqf_and_selberg
    (P : EscAnalytic.Params) (σ₀ C₀ A₀ : ℝ) (hσ₀ : 0 < σ₀) (hA₀ : 3 < A₀) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
        0 < Real.log X ∧
          0 < Real.log (EscAnalytic.zScale X) ∧
          0 < Real.log X / Real.log (EscAnalytic.zScale X) ∧
          0 ≤ roughInitial X M σ₀ ∧
          c * (Real.log X / Real.log (EscAnalytic.zScale X)) ≤
            roughInitial X M σ₀ ∧
          roughInitial X M σ₀ ≤
            C * (Real.log X / Real.log (EscAnalytic.zScale X)) ∧
          |roughInitial X M σ₀| ≤
            C * (Real.log X / Real.log (EscAnalytic.zScale X)) := by
  rcases roughInitial_lower_from_rough_sqf_recip P σ₀ C₀ hσ₀ with
    ⟨c, Xlower, hc, hlower⟩
  rcases roughInitial_upper_of_zScale_power_cutoff σ₀ C₀ A₀ hσ₀ hA₀ with
    ⟨C, Xupper, hC, hupper⟩
  refine ⟨c, C, max Xlower Xupper, hc, hC, ?_⟩
  intro X hX M hM
  have hXlower : Xlower ≤ X := le_trans (le_max_left _ _) hX
  have hXupper : Xupper ≤ X := le_trans (le_max_right _ _) hX
  rcases hlower X hXlower M hM with ⟨hlogX, hlogz, hratio, hlowerX⟩
  have hnonneg : 0 ≤ roughInitial X M σ₀ := roughInitial_nonneg X M σ₀
  have hupperX : roughInitial X M σ₀ ≤
      C * (Real.log X / Real.log (EscAnalytic.zScale X)) :=
    hupper X hXupper M hM
  exact ⟨hlogX, hlogz, hratio, hnonneg, hlowerX, hupperX, by
    rw [abs_of_nonneg hnonneg]
    exact hupperX⟩

/-- Elementary upper bound for initial rough reciprocal sums.  This loses the
roughness saving from `rough_initial`; it only records the unconditional harmonic
envelope. -/
theorem roughInitial_upper_unconditional (σ₀ : ℝ) (hσ₀ : 0 < σ₀) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ M : ℕ, roughInitial X M σ₀ ≤ C * Real.log X := by
  refine ⟨2 * σ₀, Real.exp (2 / σ₀), mul_pos (by norm_num) hσ₀, ?_⟩
  intro X hX M
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos _) hX
  have hlogX_ge : 2 / σ₀ ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hX
  have hlogS_eq : Real.log (X ^ σ₀) = σ₀ * Real.log X := by
    rw [Real.log_rpow hXpos]
  have hlogS_ge_two : 2 ≤ Real.log (X ^ σ₀) := by
    rw [hlogS_eq]
    calc
      (2 : ℝ) = σ₀ * (2 / σ₀) := by field_simp [ne_of_gt hσ₀]
      _ ≤ σ₀ * Real.log X := mul_le_mul_of_nonneg_left hlogX_ge hσ₀.le
  have hSpos : 0 < X ^ σ₀ := Real.rpow_pos_of_pos hXpos σ₀
  have hS_ge_one : 1 ≤ X ^ σ₀ := by
    apply (Real.log_le_log_iff (by norm_num : (0 : ℝ) < 1) hSpos).mp
    simpa using le_trans (by norm_num : (0 : ℝ) ≤ 2) hlogS_ge_two
  have hharm : (harmonic ⌊X ^ σ₀⌋₊ : ℝ) ≤ 1 + Real.log (X ^ σ₀) :=
    harmonic_floor_le_one_add_log (X ^ σ₀) hS_ge_one
  have htail : 1 + Real.log (X ^ σ₀) ≤ 2 * Real.log (X ^ σ₀) := by
    linarith
  calc
    roughInitial X M σ₀
        ≤ (harmonic ⌊X ^ σ₀⌋₊ : ℝ) := roughInitial_le_harmonic_floor X M σ₀
    _ ≤ 1 + Real.log (X ^ σ₀) := hharm
    _ ≤ 2 * Real.log (X ^ σ₀) := htail
    _ = (2 * σ₀) * Real.log X := by
          rw [hlogS_eq]
          ring

/-- Eventual constant lower fallback for the initial rough reciprocal carrier.
The sharp lower bound with the rough-sieve saving remains external/debt. -/
theorem roughInitial_lower_constant_unconditional (σ₀ : ℝ) (hσ₀ : 0 < σ₀) :
    ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ M : ℕ, c ≤ roughInitial X M σ₀ := by
  refine ⟨1, 1, by norm_num, ?_⟩
  intro X hX M
  have hXpos : 0 < X := lt_of_lt_of_le zero_lt_one hX
  have hcut : 1 ≤ X ^ σ₀ := by
    calc
      (1 : ℝ) = 1 ^ σ₀ := by rw [Real.one_rpow]
      _ ≤ X ^ σ₀ := Real.rpow_le_rpow (by norm_num) hX hσ₀.le
  exact one_le_roughInitial_of_one_le_rpow X M σ₀ hcut

/-- Absolute-value form of the elementary initial rough reciprocal fallback. -/
theorem abs_roughInitial_upper_unconditional (σ₀ : ℝ) (hσ₀ : 0 < σ₀) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ M : ℕ, |roughInitial X M σ₀| ≤ C * Real.log X := by
  rcases roughInitial_upper_unconditional σ₀ hσ₀ with ⟨C, X₀, hC, hbound⟩
  refine ⟨C, X₀, hC, ?_⟩
  intro X hX M
  rw [abs_of_nonneg (roughInitial_nonneg X M σ₀)]
  exact hbound X hX M

/-- Checked package for the currently formalized part of
`lem:rough-initial`.

The lower bound has the correct rough-sieve normalization
`log X / log z` and follows from `rough_sqf_recip`.  The upper bound here is
only the unconditional harmonic envelope `O(log X)`, so this theorem deliberately
does not claim the full paper lemma.  It isolates the remaining missing step as
the normalized Euler-product upper saving. -/
theorem roughInitial_lower_from_rough_sqf_recip_with_harmonic_upper
    (P : EscAnalytic.Params) (σ₀ C₀ : ℝ) (hσ₀ : 0 < σ₀) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ (M : ℕ), (M : ℝ) ≤ X ^ C₀ →
        0 < Real.log X ∧
          0 < Real.log (EscAnalytic.zScale X) ∧
          0 < Real.log X / Real.log (EscAnalytic.zScale X) ∧
          0 ≤ roughInitial X M σ₀ ∧
          c * (Real.log X / Real.log (EscAnalytic.zScale X)) ≤
            roughInitial X M σ₀ ∧
          roughInitial X M σ₀ ≤ C * Real.log X ∧
          |roughInitial X M σ₀| ≤ C * Real.log X := by
  rcases roughInitial_lower_from_rough_sqf_recip P σ₀ C₀ hσ₀ with
    ⟨c, Xlower, hc, hlower⟩
  rcases roughInitial_upper_unconditional σ₀ hσ₀ with
    ⟨C, Xupper, hC, hupper⟩
  refine ⟨c, C, max Xlower Xupper, hc, hC, ?_⟩
  intro X hX M hM
  have hXlower : Xlower ≤ X := le_trans (le_max_left _ _) hX
  have hXupper : Xupper ≤ X := le_trans (le_max_right _ _) hX
  rcases hlower X hXlower M hM with ⟨hlogX, hlogz, hratio, hlowerX⟩
  have hnonneg : 0 ≤ roughInitial X M σ₀ := roughInitial_nonneg X M σ₀
  have hupperX : roughInitial X M σ₀ ≤ C * Real.log X := hupper X hXupper M
  exact ⟨hlogX, hlogz, hratio, hnonneg, hlowerX, hupperX, by
    rw [abs_of_nonneg hnonneg]
    exact hupperX⟩

/-- Sieve-free package for the initial rough reciprocal carrier.

The finite carrier alone supplies the `n = 1` constant lower bound, and the
ambient harmonic series supplies the logarithmic upper envelope.  The missing
rough-sieve input would upgrade this to the expected roughness-normalized
asymptotic; this theorem records exactly what is currently unconditional. -/
theorem roughInitial_sieveFree_with_carrier_bounds
    (σ₀ : ℝ) (hσ₀ : 0 < σ₀) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ M : ℕ,
        0 < Real.log X ∧
          0 ≤ roughInitial X M σ₀ ∧
          c ≤ roughInitial X M σ₀ ∧
          roughInitial X M σ₀ ≤ C * Real.log X ∧
          |roughInitial X M σ₀| ≤ C * Real.log X := by
  rcases roughInitial_lower_constant_unconditional σ₀ hσ₀ with
    ⟨c, Xlower, hc, hlower⟩
  rcases roughInitial_upper_unconditional σ₀ hσ₀ with
    ⟨C, Xupper, hC, hupper⟩
  refine ⟨c, C, max (max Xlower Xupper) (Real.exp 1), hc, hC, ?_⟩
  intro X hX M
  have hXlower : Xlower ≤ X := le_trans (le_trans (le_max_left _ _) (le_max_left _ _)) hX
  have hXupper : Xupper ≤ X := le_trans (le_trans (le_max_right _ _) (le_max_left _ _)) hX
  have hXexp : Real.exp 1 ≤ X := le_trans (le_max_right _ _) hX
  have hone_exp : (1 : ℝ) < Real.exp 1 := by
    calc
      (1 : ℝ) = Real.exp 0 := by rw [Real.exp_zero]
      _ < Real.exp 1 := Real.exp_lt_exp.mpr (by norm_num : (0 : ℝ) < 1)
  have hXgt_one : (1 : ℝ) < X := lt_of_lt_of_le hone_exp hXexp
  have hlogX_pos : 0 < Real.log X := Real.log_pos hXgt_one
  have hcarrier_nonneg : 0 ≤ roughInitial X M σ₀ := roughInitial_nonneg X M σ₀
  have hlow := hlower X hXlower M
  have hup := hupper X hXupper M
  exact ⟨hlogX_pos, hcarrier_nonneg, hlow, hup, by
    rw [abs_of_nonneg hcarrier_nonneg]
    exact hup⟩

/-- Bare lower and upper fallback bounds for the initial rough carrier give the
carrier-bundled sieve-free package after raising the eventual threshold enough
to make `log X > 0`. -/
theorem roughInitial_sieveFree_with_carrier_bounds_of_bounds
    (σ₀ : ℝ)
    (h :
      (∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
        ∀ M : ℕ, c ≤ roughInitial X M σ₀) ∧
      (∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        ∀ M : ℕ, roughInitial X M σ₀ ≤ C * Real.log X)) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ M : ℕ,
        0 < Real.log X ∧
          0 ≤ roughInitial X M σ₀ ∧
          c ≤ roughInitial X M σ₀ ∧
          roughInitial X M σ₀ ≤ C * Real.log X ∧
          |roughInitial X M σ₀| ≤ C * Real.log X := by
  rcases h.1 with ⟨c, Xlower, hc, hlower⟩
  rcases h.2 with ⟨C, Xupper, hC, hupper⟩
  refine ⟨c, C, max (max Xlower Xupper) (Real.exp 1), hc, hC, ?_⟩
  intro X hX M
  have hXlower : Xlower ≤ X := le_trans (le_trans (le_max_left _ _) (le_max_left _ _)) hX
  have hXupper : Xupper ≤ X := le_trans (le_trans (le_max_right _ _) (le_max_left _ _)) hX
  have hXexp : Real.exp 1 ≤ X := le_trans (le_max_right _ _) hX
  have hExpOne : (1 : ℝ) < Real.exp 1 := by
    calc
      1 = Real.exp 0 := by simp
      _ < Real.exp 1 := Real.exp_lt_exp.mpr (by norm_num)
  have hXgt_one : (1 : ℝ) < X := lt_of_lt_of_le hExpOne hXexp
  have hlogX_pos : 0 < Real.log X := Real.log_pos hXgt_one
  have hcarrier_nonneg : 0 ≤ roughInitial X M σ₀ := roughInitial_nonneg X M σ₀
  have hlow := hlower X hXlower M
  have hup := hupper X hXupper M
  exact ⟨hlogX_pos, hcarrier_nonneg, hlow, hup, by
    rw [abs_of_nonneg hcarrier_nonneg]
    exact hup⟩

/-- Forget the checked side conditions from a bundled sieve-free initial rough
carrier package. -/
theorem roughInitial_sieveFree_bounds_of_carrier_bounds
    (σ₀ : ℝ)
    (h :
      ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        ∀ M : ℕ,
          0 < Real.log X ∧
            0 ≤ roughInitial X M σ₀ ∧
            c ≤ roughInitial X M σ₀ ∧
            roughInitial X M σ₀ ≤ C * Real.log X ∧
            |roughInitial X M σ₀| ≤ C * Real.log X) :
      (∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
        ∀ M : ℕ, c ≤ roughInitial X M σ₀) ∧
      (∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        ∀ M : ℕ, roughInitial X M σ₀ ≤ C * Real.log X) := by
  rcases h with ⟨c, C, X₀, hc, hC, hcarrier⟩
  constructor
  · refine ⟨c, X₀, hc, ?_⟩
    intro X hX M
    exact (hcarrier X hX M).2.2.1
  · refine ⟨C, X₀, hC, ?_⟩
    intro X hX M
    exact (hcarrier X hX M).2.2.2.1

/-- Bare lower/upper fallback bounds and the carrier-bundled sieve-free initial
rough package have the same analytic content. -/
theorem roughInitial_sieveFree_bounds_iff_carrier_bounds
    (σ₀ : ℝ) :
    ((∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
        ∀ M : ℕ, c ≤ roughInitial X M σ₀) ∧
      (∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        ∀ M : ℕ, roughInitial X M σ₀ ≤ C * Real.log X)) ↔
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ M : ℕ,
        0 < Real.log X ∧
          0 ≤ roughInitial X M σ₀ ∧
          c ≤ roughInitial X M σ₀ ∧
          roughInitial X M σ₀ ≤ C * Real.log X ∧
          |roughInitial X M σ₀| ≤ C * Real.log X := by
  constructor
  · exact roughInitial_sieveFree_with_carrier_bounds_of_bounds σ₀
  · exact roughInitial_sieveFree_bounds_of_carrier_bounds σ₀

/-!
The initial-segment rough reciprocal estimate remains debt, but its unused axiom
interface is not exported.  The harmonic upper fallback above is unconditional.
-/

/-! ### Divisor moments. -/

/-- The finite divisor moment `∑_{1 ≤ m ≤ X^ν} τ(m)^K / φ(m)` of
`lem:divisor-phi-moment`.  Negative or tiny `X^ν` gives an empty range through
the natural floor. -/
noncomputable def divisorPhiMoment (X : ℝ) (K : ℕ) (ν : ℝ) : ℝ :=
  ∑ m ∈ Finset.Icc (1 : ℕ) ⌊X ^ ν⌋₊,
    ((tau m ^ K : ℕ) : ℝ) / (Nat.totient m : ℝ)

/-- The finite divisor moment carrier is nonnegative. -/
theorem divisorPhiMoment_nonneg (X : ℝ) (K : ℕ) (ν : ℝ) :
    0 ≤ divisorPhiMoment X K ν := by
  classical
  unfold divisorPhiMoment
  apply Finset.sum_nonneg
  intro m _hm
  exact div_nonneg (Nat.cast_nonneg _) (Nat.cast_nonneg _)

/-- The divisor-count function satisfies the elementary bound `τ(n) ≤ n`.  This
uses only that every positive divisor of `n` lies in `Icc 1 n`; for `n = 0`,
Mathlib's divisor finset is empty. -/
theorem tau_le_self (n : ℕ) : tau n ≤ n := by
  unfold tau
  have hsubset : n.divisors ⊆ Finset.Icc (1 : ℕ) n := by
    intro d hd
    exact Finset.mem_Icc.mpr ⟨Nat.pos_of_mem_divisors hd, Nat.divisor_le hd⟩
  calc
    n.divisors.card ≤ (Finset.Icc (1 : ℕ) n).card := Finset.card_le_card hsubset
    _ = n := by
      rw [Nat.card_Icc]
      omega

/-- The divisor-count function is submultiplicative.  This is the arithmetic
core needed by the ordered-factorization route toward the general divisor
moment. -/
theorem tau_mul_le_mul_tau (m n : ℕ) : tau (m * n) ≤ tau m * tau n := by
  unfold tau
  rw [Nat.divisors_mul]
  exact Finset.card_mul_le

/-- Divisor-splitting kernel for reduced divisor moments.  If `d ∣ m`, then
the `τ(m)^r/m` summand is bounded by the product of the split summands attached
to `d` and `m/d`. -/
theorem tau_pow_div_self_le_divisor_split
    (r m d : ℕ) (hd : d ∈ m.divisors) :
    ((tau m ^ r : ℕ) : ℝ) / (m : ℝ)
      ≤ (((tau d ^ r : ℕ) : ℝ) / (d : ℝ)) *
        (((tau (m / d) ^ r : ℕ) : ℝ) / ((m / d : ℕ) : ℝ)) := by
  let q := m / d
  have hdvd : d ∣ m := Nat.dvd_of_mem_divisors hd
  have hdpos_nat : 0 < d := Nat.pos_of_mem_divisors hd
  have hmpos_nat : 0 < m := lt_of_lt_of_le hdpos_nat (Nat.divisor_le hd)
  have hqpos_nat : 0 < q := by
    unfold q
    exact Nat.div_pos (Nat.divisor_le hd) hdpos_nat
  have hmul_nat : d * q = m := by
    unfold q
    exact Nat.mul_div_cancel' hdvd
  have htau : tau m ≤ tau d * tau q := by
    rw [← hmul_nat]
    exact tau_mul_le_mul_tau d q
  have hpow_nat : tau m ^ r ≤ (tau d * tau q) ^ r :=
    Nat.pow_le_pow_left htau r
  have hpow_real :
      ((tau m ^ r : ℕ) : ℝ) ≤ (((tau d * tau q) ^ r : ℕ) : ℝ) := by
    exact_mod_cast hpow_nat
  have hm_nonneg : (0 : ℝ) ≤ (m : ℝ) := Nat.cast_nonneg m
  have hd_ne : (d : ℝ) ≠ 0 := by exact_mod_cast (ne_of_gt hdpos_nat)
  have hq_ne : (q : ℝ) ≠ 0 := by exact_mod_cast (ne_of_gt hqpos_nat)
  have hmul_real : (m : ℝ) = (d : ℝ) * (q : ℝ) := by
    exact_mod_cast hmul_nat.symm
  have hnum_mul :
      (((tau d * tau q) ^ r : ℕ) : ℝ)
        = ((tau d ^ r : ℕ) : ℝ) * ((tau q ^ r : ℕ) : ℝ) := by
    rw [Nat.mul_pow, Nat.cast_mul]
  calc
    ((tau m ^ r : ℕ) : ℝ) / (m : ℝ)
        ≤ (((tau d * tau q) ^ r : ℕ) : ℝ) / (m : ℝ) :=
          by exact div_le_div_of_nonneg_right hpow_real hm_nonneg
    _ = (((tau d ^ r : ℕ) : ℝ) / (d : ℝ)) *
        (((tau q ^ r : ℕ) : ℝ) / (q : ℝ)) := by
          rw [hnum_mul, hmul_real]
          field_simp [hd_ne, hq_ne]
    _ = (((tau d ^ r : ℕ) : ℝ) / (d : ℝ)) *
        (((tau (m / d) ^ r : ℕ) : ℝ) / ((m / d : ℕ) : ℝ)) := by
          dsimp [q]

/-- A finite power-sum envelope for the divisor-phi moment carrier. -/
noncomputable def divisorPowerEnvelope (X : ℝ) (K : ℕ) (ν : ℝ) : ℝ :=
  ∑ m ∈ Finset.Icc (1 : ℕ) ⌊X ^ ν⌋₊, (m : ℝ) ^ K

/-- Each summand `τ(m)^K/φ(m)` is bounded by `m^K` for `m ≥ 1`. -/
theorem divisorPhiMoment_summand_le_power (K m : ℕ) (hm : 1 ≤ m) :
    ((tau m ^ K : ℕ) : ℝ) / (Nat.totient m : ℝ) ≤ (m : ℝ) ^ K := by
  have hmpos : 0 < m := lt_of_lt_of_le Nat.zero_lt_one hm
  have hphi_pos_nat : 0 < Nat.totient m := Nat.totient_pos.mpr hmpos
  have hphi_ge_one : (1 : ℝ) ≤ (Nat.totient m : ℝ) := by
    exact_mod_cast Nat.succ_le_of_lt hphi_pos_nat
  have hnum_nonneg : 0 ≤ ((tau m ^ K : ℕ) : ℝ) := Nat.cast_nonneg _
  have hdiv_le_num :
      ((tau m ^ K : ℕ) : ℝ) / (Nat.totient m : ℝ)
        ≤ ((tau m ^ K : ℕ) : ℝ) := by
    have hinv_le_one : (Nat.totient m : ℝ)⁻¹ ≤ 1 :=
      inv_le_one_of_one_le₀ hphi_ge_one
    calc
      ((tau m ^ K : ℕ) : ℝ) / (Nat.totient m : ℝ)
          = ((tau m ^ K : ℕ) : ℝ) * (Nat.totient m : ℝ)⁻¹ := by
            rw [div_eq_mul_inv]
      _ ≤ ((tau m ^ K : ℕ) : ℝ) * 1 :=
            mul_le_mul_of_nonneg_left hinv_le_one hnum_nonneg
      _ = ((tau m ^ K : ℕ) : ℝ) := by ring
  have htau_pow : ((tau m ^ K : ℕ) : ℝ) ≤ (m : ℝ) ^ K := by
    exact_mod_cast Nat.pow_le_pow_left (tau_le_self m) K
  exact le_trans hdiv_le_num htau_pow

/-- Elementary divisor-sum consequence: `m / φ(m) ≤ τ(m)`, in multiplicative
form to avoid field division over naturals. -/
theorem self_le_totient_mul_tau (m : ℕ) (hm : 0 < m) :
    m ≤ Nat.totient m * tau m := by
  unfold tau
  have hphi_pos : 0 < Nat.totient m := Nat.totient_pos.mpr hm
  calc
    m = ∑ d ∈ m.divisors, Nat.totient d := (Nat.sum_totient m).symm
    _ ≤ ∑ _d ∈ m.divisors, Nat.totient m := by
          apply Finset.sum_le_sum
          intro d hd
          have hdm : d ∣ m := Nat.dvd_of_mem_divisors hd
          exact Nat.le_of_dvd hphi_pos (Nat.totient_dvd_of_dvd hdm)
    _ = Nat.totient m * m.divisors.card := by
          simp [Finset.sum_const, nsmul_eq_mul, mul_comm]

/-- Symmetric multiplicative form of `m / φ(m) ≤ τ(m)`. -/
theorem self_le_tau_mul_totient (m : ℕ) (hm : 0 < m) :
    m ≤ tau m * Nat.totient m := by
  simpa [mul_comm] using self_le_totient_mul_tau m hm

/-- Real form of `m / φ(m) ≤ τ(m)` for positive `m`. -/
theorem div_totient_le_tau (m : ℕ) (hm : 0 < m) :
    (m : ℝ) / (Nat.totient m : ℝ) ≤ (tau m : ℝ) := by
  have hphi_pos_nat : 0 < Nat.totient m := Nat.totient_pos.mpr hm
  have hphi_pos : (0 : ℝ) < (Nat.totient m : ℝ) := by exact_mod_cast hphi_pos_nat
  have hmain : (m : ℝ) ≤ (Nat.totient m : ℝ) * (tau m : ℝ) := by
    exact_mod_cast self_le_totient_mul_tau m hm
  exact (div_le_iff₀ hphi_pos).mpr (by simpa [mul_comm] using hmain)

/-- Manuscript summand reduction for `lem:divisor-phi-moment`: the `1/φ(m)`
loss can be traded for one extra divisor-count factor and a `1/m`. -/
theorem divisorPhiMoment_summand_le_tau_succ_div
    (K m : ℕ) (hm : 1 ≤ m) :
    ((tau m ^ K : ℕ) : ℝ) / (Nat.totient m : ℝ)
      ≤ ((tau m ^ (K + 1) : ℕ) : ℝ) / (m : ℝ) := by
  have hmpos_nat : 0 < m := lt_of_lt_of_le Nat.zero_lt_one hm
  have hmpos : (0 : ℝ) < (m : ℝ) := by exact_mod_cast hmpos_nat
  have hphi_pos_nat : 0 < Nat.totient m := Nat.totient_pos.mpr hmpos_nat
  have hphi_pos : (0 : ℝ) < (Nat.totient m : ℝ) := by exact_mod_cast hphi_pos_nat
  have htau_nonneg : 0 ≤ ((tau m ^ K : ℕ) : ℝ) := Nat.cast_nonneg _
  have hratio : (m : ℝ) / (Nat.totient m : ℝ) ≤ (tau m : ℝ) :=
    div_totient_le_tau m hmpos_nat
  have hmul :
      ((tau m ^ K : ℕ) : ℝ) * ((m : ℝ) / (Nat.totient m : ℝ))
        ≤ ((tau m ^ K : ℕ) : ℝ) * (tau m : ℝ) :=
    mul_le_mul_of_nonneg_left hratio htau_nonneg
  have hrew :
      ((tau m ^ K : ℕ) : ℝ) * ((m : ℝ) / (Nat.totient m : ℝ))
        = (((tau m ^ K : ℕ) : ℝ) / (Nat.totient m : ℝ)) * (m : ℝ) := by
    ring
  have hpow :
      ((tau m ^ K : ℕ) : ℝ) * (tau m : ℝ)
        = ((tau m ^ (K + 1) : ℕ) : ℝ) := by
    rw [Nat.cast_pow, Nat.cast_pow]
    rw [pow_succ']
    ring
  rw [hrew, hpow] at hmul
  exact (le_div_iff₀ hmpos).mpr hmul

/-- The reduced divisor moment `∑ τ(m)^(K+1)/m` obtained after trading the
`1/φ(m)` loss for one extra divisor-count factor. -/
noncomputable def divisorTauSuccOverN (X : ℝ) (K : ℕ) (ν : ℝ) : ℝ :=
  ∑ m ∈ Finset.Icc (1 : ℕ) ⌊X ^ ν⌋₊,
    ((tau m ^ (K + 1) : ℕ) : ℝ) / (m : ℝ)

/-- Natural-cutoff reduced divisor moment `∑_{1≤m≤Y} τ(m)^r/m`.  This is the
finite carrier used for the ordered-factorization induction behind the general
divisor-phi moment. -/
noncomputable def tauPowOverN (Y r : ℕ) : ℝ :=
  ∑ m ∈ Finset.Icc (1 : ℕ) Y, ((tau m ^ r : ℕ) : ℝ) / (m : ℝ)

/-- The `X,ν,K` reduced divisor moment is the natural-cutoff carrier at
`Y = ⌊X^ν⌋₊` and exponent `K+1`. -/
theorem divisorTauSuccOverN_eq_tauPowOverN (X : ℝ) (K : ℕ) (ν : ℝ) :
    divisorTauSuccOverN X K ν = tauPowOverN ⌊X ^ ν⌋₊ (K + 1) := by
  rfl

/-- The reduced divisor moment carrier is nonnegative. -/
theorem divisorTauSuccOverN_nonneg (X : ℝ) (K : ℕ) (ν : ℝ) :
    0 ≤ divisorTauSuccOverN X K ν := by
  classical
  unfold divisorTauSuccOverN
  apply Finset.sum_nonneg
  intro m _hm
  exact div_nonneg (Nat.cast_nonneg _) (Nat.cast_nonneg m)

/-- Finite-sum form of the manuscript reduction
`τ(m)^K/φ(m) ≤ τ(m)^(K+1)/m`. -/
theorem divisorPhiMoment_le_tauSuccOverN (X : ℝ) (K : ℕ) (ν : ℝ) :
    divisorPhiMoment X K ν ≤ divisorTauSuccOverN X K ν := by
  classical
  unfold divisorPhiMoment divisorTauSuccOverN
  apply Finset.sum_le_sum
  intro m hm
  exact divisorPhiMoment_summand_le_tau_succ_div K m (Finset.mem_Icc.mp hm).1

/-- Absolute-value form of the finite-sum divisor-moment reduction. -/
theorem abs_divisorPhiMoment_le_tauSuccOverN (X : ℝ) (K : ℕ) (ν : ℝ) :
    |divisorPhiMoment X K ν| ≤ divisorTauSuccOverN X K ν := by
  rw [abs_of_nonneg (divisorPhiMoment_nonneg X K ν)]
  exact divisorPhiMoment_le_tauSuccOverN X K ν

/-- The natural-cutoff reduced divisor moment carrier is nonnegative. -/
theorem tauPowOverN_nonneg (Y r : ℕ) :
    0 ≤ tauPowOverN Y r := by
  classical
  unfold tauPowOverN
  apply Finset.sum_nonneg
  intro m _hm
  exact div_nonneg (Nat.cast_nonneg _) (Nat.cast_nonneg m)

/-- Harmonic numbers are nonnegative after coercion to `ℝ`. -/
theorem harmonic_nonneg_real (Y : ℕ) :
    0 ≤ ((harmonic Y : ℚ) : ℝ) := by
  rw [harmonic_eq_sum_Icc]
  simp only [Rat.cast_sum, Rat.cast_inv, Rat.cast_natCast]
  apply Finset.sum_nonneg
  intro n _hn
  exact inv_nonneg.mpr (Nat.cast_nonneg n)

/-- Ordered-factorization recurrence for reduced divisor moments:
`∑_{m≤Y} τ(m)^(r+1)/m ≤ (∑_{m≤Y} τ(m)^r/m)^2`. -/
theorem tauPowOverN_succ_le_square (Y r : ℕ) :
    tauPowOverN Y (r + 1) ≤ (tauPowOverN Y r) ^ 2 := by
  classical
  let I : Finset ℕ := Finset.Icc (1 : ℕ) Y
  let s : Finset ((m : ℕ) × ℕ) := I.sigma (fun m => m.divisors)
  let F : ((m : ℕ) × ℕ) → ℕ × ℕ := fun x => (x.2, x.1 / x.2)
  let a : ℕ → ℝ := fun n => ((tau n ^ r : ℕ) : ℝ) / (n : ℝ)
  have hleft_inner :
      tauPowOverN Y (r + 1)
        = ∑ m ∈ I, ∑ _d ∈ m.divisors, a m := by
    unfold tauPowOverN I a
    apply Finset.sum_congr rfl
    intro m hm
    have hmpos_nat : 0 < m := lt_of_lt_of_le Nat.zero_lt_one (Finset.mem_Icc.mp hm).1
    have hmpos : (m : ℝ) ≠ 0 := by exact_mod_cast (ne_of_gt hmpos_nat)
    unfold tau
    rw [Finset.sum_const, nsmul_eq_mul]
    rw [Nat.cast_pow, Nat.cast_pow, pow_succ']
    field_simp [hmpos]
  have hinner_sigma :
      (∑ m ∈ I, ∑ _d ∈ m.divisors, a m)
        = ∑ x ∈ s, a x.1 := by
    unfold s
    exact Finset.sum_sigma' I (fun m => m.divisors) (fun m _d => a m)
  have hleft_eq_sigma :
      tauPowOverN Y (r + 1) = ∑ x ∈ s, a x.1 := by
    rw [hleft_inner, hinner_sigma]
  let split : ℕ × ℕ → ℝ := fun p => a p.1 * a p.2
  have hsplit_bound :
      (∑ x ∈ s, a x.1) ≤ ∑ x ∈ s, split (F x) := by
    apply Finset.sum_le_sum
    intro x hx
    rcases x with ⟨m, d⟩
    have hx' := hx
    rw [Finset.mem_sigma] at hx'
    rcases hx' with ⟨_hm, hd⟩
    exact tau_pow_div_self_le_divisor_split r m d hd
  have hF_mem : ∀ x ∈ s, F x ∈ I.product I := by
    intro x hx
    rcases x with ⟨m, d⟩
    have hx' := hx
    rw [Finset.mem_sigma] at hx'
    rcases hx' with ⟨hm, hd⟩
    have hdpos : 0 < d := Nat.pos_of_mem_divisors hd
    have hdle : d ≤ Y := le_trans (Nat.divisor_le hd) (Finset.mem_Icc.mp hm).2
    have hquot_pos : 0 < m / d := Nat.div_pos (Nat.divisor_le hd) hdpos
    have hquot_le_m : m / d ≤ m := Nat.div_le_self m d
    exact Finset.mem_product.mpr
      ⟨Finset.mem_Icc.mpr ⟨hdpos, hdle⟩,
        Finset.mem_Icc.mpr ⟨hquot_pos, le_trans hquot_le_m (Finset.mem_Icc.mp hm).2⟩⟩
  have hF_inj : ∀ x ∈ s, ∀ y ∈ s, F x = F y → x = y := by
    intro x hx y hy hxy
    rcases x with ⟨m, d⟩
    rcases y with ⟨n, e⟩
    have hx' := hx
    have hy' := hy
    rw [Finset.mem_sigma] at hx'
    rw [Finset.mem_sigma] at hy'
    rcases hx' with ⟨_hm, hd⟩
    rcases hy' with ⟨_hn, he⟩
    have hdvd : d ∣ m := Nat.dvd_of_mem_divisors hd
    have hevd : e ∣ n := Nat.dvd_of_mem_divisors he
    have hde : d = e := congrArg Prod.fst hxy
    have hquot : m / d = n / e := congrArg Prod.snd hxy
    have hm_eq : m = d * (m / d) := (Nat.mul_div_cancel' hdvd).symm
    have hn_eq : n = e * (n / e) := (Nat.mul_div_cancel' hevd).symm
    subst e
    simp only at hquot
    have hmn : m = n := by
      rw [hm_eq, hn_eq, hquot]
    subst n
    rfl
  have hsource_to_image :
      (∑ x ∈ s, split (F x)) = ∑ p ∈ s.image F, split p := by
    rw [Finset.sum_image]
    intro x hx y hy hxy
    exact hF_inj x hx y hy hxy
  have himage_subset : s.image F ⊆ I.product I := by
    intro p hp
    rw [Finset.mem_image] at hp
    rcases hp with ⟨x, hx, rfl⟩
    exact hF_mem x hx
  have hnonneg_extra : ∀ p ∈ I.product I, p ∉ s.image F → 0 ≤ split p := by
    intro p _hp _
    exact mul_nonneg (div_nonneg (Nat.cast_nonneg _) (Nat.cast_nonneg _))
      (div_nonneg (Nat.cast_nonneg _) (Nat.cast_nonneg _))
  have himage_le_product :
      (∑ p ∈ s.image F, split p) ≤ ∑ p ∈ I.product I, split p :=
    Finset.sum_le_sum_of_subset_of_nonneg himage_subset hnonneg_extra
  have hproduct_eq :
      (∑ p ∈ I.product I, split p) = (tauPowOverN Y r) ^ 2 := by
    unfold split tauPowOverN I a
    change
      (∑ p ∈ (Finset.Icc (1 : ℕ) Y) ×ˢ (Finset.Icc (1 : ℕ) Y),
        (((tau p.1 ^ r : ℕ) : ℝ) / (p.1 : ℝ)) *
          (((tau p.2 ^ r : ℕ) : ℝ) / (p.2 : ℝ))) =
        (∑ m ∈ Finset.Icc (1 : ℕ) Y, ((tau m ^ r : ℕ) : ℝ) / (m : ℝ)) ^ 2
    rw [Finset.sum_product]
    rw [sq]
    rw [Finset.sum_mul]
    apply Finset.sum_congr rfl
    intro d hd
    rw [Finset.mul_sum]
  rw [hleft_eq_sigma]
  exact le_trans hsplit_bound (le_trans (by rw [hsource_to_image]; exact himage_le_product) hproduct_eq.le)

/-- Decompose the least common multiple through the greatest common divisor:
`gcd(d,e) * (d/gcd(d,e)) * (e/gcd(d,e)) = lcm(d,e)` for positive `d`. -/
theorem lcm_eq_gcd_mul_divs {d e : ℕ} (hdpos : 0 < d) :
    d.gcd e * (d / d.gcd e) * (e / d.gcd e) = d.lcm e := by
  let g := d.gcd e
  have hgpos : 0 < g := Nat.gcd_pos_of_pos_left e hdpos
  have hdvd : g ∣ d := Nat.gcd_dvd_left d e
  have hevd : g ∣ e := Nat.gcd_dvd_right d e
  have hd : g * (d / g) = d := Nat.mul_div_cancel' hdvd
  have he : g * (e / g) = e := Nat.mul_div_cancel' hevd
  have htarget : g * (g * (d / g) * (e / g)) = g * d.lcm e := by
    calc
      g * (g * (d / g) * (e / g)) = (g * (d / g) * (e / g)) * g := by ring
      _ = (g * (d / g)) * (g * (e / g)) := by ring
      _ = d * e := by rw [hd, he]
      _ = g * d.lcm e := (Nat.gcd_mul_lcm d e).symm
  exact Nat.mul_left_cancel hgpos htarget

/-- Twofold reciprocal product over `[1,Y]` equals `H_Y²`. -/
theorem pair_recip_product_sum_eq_harmonic_sq (Y : ℕ) :
    (∑ p ∈ (Finset.Icc (1 : ℕ) Y).product (Finset.Icc (1 : ℕ) Y),
      (1 : ℝ) / ((p.1 * p.2 : ℕ) : ℝ)) = ((harmonic Y : ℚ) : ℝ) ^ 2 := by
  change (∑ p ∈ (Finset.Icc (1 : ℕ) Y) ×ˢ (Finset.Icc (1 : ℕ) Y),
      (1 : ℝ) / ((p.1 * p.2 : ℕ) : ℝ)) = ((harmonic Y : ℚ) : ℝ) ^ 2
  rw [Finset.sum_product]
  rw [harmonic_eq_sum_Icc]
  simp only [Rat.cast_sum, Rat.cast_inv, Rat.cast_natCast]
  simp_rw [one_div]
  rw [sq]
  rw [Finset.sum_mul]
  apply Finset.sum_congr rfl
  intro d hd
  rw [Finset.mul_sum]
  apply Finset.sum_congr rfl
  intro r hr
  have hdpos_nat : 0 < d := lt_of_lt_of_le Nat.zero_lt_one (Finset.mem_Icc.mp hd).1
  have hrpos_nat : 0 < r := lt_of_lt_of_le Nat.zero_lt_one (Finset.mem_Icc.mp hr).1
  have hdpos : (d : ℝ) ≠ 0 := by exact_mod_cast (ne_of_gt hdpos_nat)
  have hrpos : (r : ℝ) ≠ 0 := by exact_mod_cast (ne_of_gt hrpos_nat)
  norm_num [Nat.cast_mul]
  field_simp [hdpos, hrpos]
  ring

/-- Fourfold reciprocal product over `[1,Y]` equals `H_Y⁴`. -/
theorem four_recip_product_sum_eq_harmonic_fourth (Y : ℕ) :
    (∑ p ∈ ((Finset.Icc (1 : ℕ) Y).product (Finset.Icc (1 : ℕ) Y)).product
        ((Finset.Icc (1 : ℕ) Y).product (Finset.Icc (1 : ℕ) Y)),
      (1 : ℝ) / ((((p.1.1 * p.1.2) * p.2.1) * p.2.2 : ℕ) : ℝ)) =
      ((harmonic Y : ℚ) : ℝ) ^ 4 := by
  let I := Finset.Icc (1 : ℕ) Y
  have hpair :
      (∑ p ∈ I.product I, (1 : ℝ) / ((p.1 * p.2 : ℕ) : ℝ)) =
      ((harmonic Y : ℚ) : ℝ) ^ 2 := by
    unfold I
    exact pair_recip_product_sum_eq_harmonic_sq Y
  change (∑ p ∈ (I.product I) ×ˢ (I.product I),
      (1 : ℝ) / ((((p.1.1 * p.1.2) * p.2.1) * p.2.2 : ℕ) : ℝ)) =
      ((harmonic Y : ℚ) : ℝ) ^ 4
  rw [Finset.sum_product]
  have hinner : ∀ a ∈ I.product I,
      (∑ b ∈ I.product I,
        (1 : ℝ) / ((((a.1 * a.2) * b.1) * b.2 : ℕ) : ℝ)) =
      ((1 : ℝ) / ((a.1 * a.2 : ℕ) : ℝ)) * ((harmonic Y : ℚ) : ℝ) ^ 2 := by
    intro a ha
    rw [← hpair]
    rw [Finset.mul_sum]
    apply Finset.sum_congr rfl
    intro b hb
    have haP := Finset.mem_product.mp ha
    have hbP := Finset.mem_product.mp hb
    have ha1pos_nat : 0 < a.1 :=
      lt_of_lt_of_le Nat.zero_lt_one (Finset.mem_Icc.mp haP.1).1
    have ha2pos_nat : 0 < a.2 :=
      lt_of_lt_of_le Nat.zero_lt_one (Finset.mem_Icc.mp haP.2).1
    have hb1pos_nat : 0 < b.1 :=
      lt_of_lt_of_le Nat.zero_lt_one (Finset.mem_Icc.mp hbP.1).1
    have hb2pos_nat : 0 < b.2 :=
      lt_of_lt_of_le Nat.zero_lt_one (Finset.mem_Icc.mp hbP.2).1
    have ha12 : ((a.1 * a.2 : ℕ) : ℝ) ≠ 0 := by
      exact_mod_cast (mul_ne_zero (ne_of_gt ha1pos_nat) (ne_of_gt ha2pos_nat))
    have hb12 : ((b.1 * b.2 : ℕ) : ℝ) ≠ 0 := by
      exact_mod_cast (mul_ne_zero (ne_of_gt hb1pos_nat) (ne_of_gt hb2pos_nat))
    norm_num [Nat.cast_mul]
    field_simp [ha12, hb12]
    ring
  have hsum :
      (∑ a ∈ I.product I,
        ∑ b ∈ I.product I, (1 : ℝ) / ((((a.1 * a.2) * b.1) * b.2 : ℕ) : ℝ)) =
      ∑ a ∈ I.product I,
        ((1 : ℝ) / ((a.1 * a.2 : ℕ) : ℝ)) * ((harmonic Y : ℚ) : ℝ) ^ 2 := by
    apply Finset.sum_congr rfl
    intro a ha
    exact hinner a ha
  rw [hsum]
  rw [← Finset.sum_mul]
  rw [hpair]
  ring

/-- Hyperbola/reindexing bound for the first divisor moment:
`∑_{m≤Y} τ(m)/m ≤ H_Y²`.  This is the checked base case of the ordered
factorization strategy for `lem:divisor-phi-moment`. -/
theorem tau_div_self_sum_le_harmonic_sq (Y : ℕ) :
    (∑ m ∈ Finset.Icc (1 : ℕ) Y, ((tau m : ℕ) : ℝ) / (m : ℝ))
      ≤ ((harmonic Y : ℚ) : ℝ) ^ 2 := by
  classical
  let s : Finset ((m : ℕ) × ℕ) := (Finset.Icc (1 : ℕ) Y).sigma (fun m => m.divisors)
  let F : ((m : ℕ) × ℕ) → ℕ × ℕ := fun x => (x.2, x.1 / x.2)
  have hleft_inner :
      (∑ m ∈ Finset.Icc (1 : ℕ) Y, ((tau m : ℕ) : ℝ) / (m : ℝ))
        = ∑ m ∈ Finset.Icc (1 : ℕ) Y, ∑ _d ∈ m.divisors, (1 : ℝ) / (m : ℝ) := by
    apply Finset.sum_congr rfl
    intro m hm
    have hmpos_nat : 0 < m := lt_of_lt_of_le Nat.zero_lt_one (Finset.mem_Icc.mp hm).1
    have hmpos : (0 : ℝ) < (m : ℝ) := by exact_mod_cast hmpos_nat
    unfold tau
    rw [Finset.sum_const, nsmul_eq_mul]
    field_simp [ne_of_gt hmpos]
  have hinner_sigma :
      (∑ m ∈ Finset.Icc (1 : ℕ) Y, ∑ _d ∈ m.divisors, (1 : ℝ) / (m : ℝ))
        = ∑ x ∈ s, (1 : ℝ) / (x.1 : ℝ) := by
    unfold s
    exact Finset.sum_sigma' (Finset.Icc (1 : ℕ) Y) (fun m => m.divisors)
      (fun m _d => (1 : ℝ) / (m : ℝ))
  have hleft_eq_sigma :
      (∑ m ∈ Finset.Icc (1 : ℕ) Y, ((tau m : ℕ) : ℝ) / (m : ℝ))
        = ∑ x ∈ s, (1 : ℝ) / (x.1 : ℝ) := by
    rw [hleft_inner, hinner_sigma]
  have hF_mem : ∀ x ∈ s, F x ∈ (Finset.Icc (1 : ℕ) Y).product (Finset.Icc (1 : ℕ) Y) := by
    intro x hx
    rcases x with ⟨m, d⟩
    have hx' := hx
    rw [Finset.mem_sigma] at hx'
    rcases hx' with ⟨hm, hd⟩
    change (d, m / d) ∈ (Finset.Icc (1 : ℕ) Y) ×ˢ (Finset.Icc (1 : ℕ) Y)
    rw [Finset.mem_product]
    have hdpos : 0 < d := Nat.pos_of_mem_divisors hd
    have hdle : d ≤ Y := le_trans (Nat.divisor_le hd) (Finset.mem_Icc.mp hm).2
    have hquot_pos : 0 < m / d := Nat.div_pos (Nat.divisor_le hd) hdpos
    have hquot_le_m : m / d ≤ m := Nat.div_le_self m d
    exact ⟨Finset.mem_Icc.mpr ⟨hdpos, hdle⟩,
      Finset.mem_Icc.mpr ⟨hquot_pos, le_trans hquot_le_m (Finset.mem_Icc.mp hm).2⟩⟩
  have hF_inj : ∀ x ∈ s, ∀ y ∈ s, F x = F y → x = y := by
    intro x hx y hy hxy
    rcases x with ⟨m, d⟩
    rcases y with ⟨n, e⟩
    have hx' := hx
    have hy' := hy
    rw [Finset.mem_sigma] at hx'
    rw [Finset.mem_sigma] at hy'
    rcases hx' with ⟨_hm, hd⟩
    rcases hy' with ⟨_hn, he⟩
    have hdvd : d ∣ m := Nat.dvd_of_mem_divisors hd
    have hevd : e ∣ n := Nat.dvd_of_mem_divisors he
    have hde : d = e := congrArg Prod.fst hxy
    have hquot : m / d = n / e := congrArg Prod.snd hxy
    have hm_eq : m = d * (m / d) := (Nat.mul_div_cancel' hdvd).symm
    have hn_eq : n = e * (n / e) := (Nat.mul_div_cancel' hevd).symm
    subst e
    simp only at hquot
    have hmn : m = n := by
      rw [hm_eq, hn_eq, hquot]
    subst n
    rfl
  have hsource_to_image :
      (∑ x ∈ s, (1 : ℝ) / (x.1 : ℝ))
        = ∑ p ∈ s.image F, (1 : ℝ) / ((p.1 * p.2 : ℕ) : ℝ) := by
    rw [Finset.sum_image]
    · apply Finset.sum_congr rfl
      intro x hx
      rcases x with ⟨m, d⟩
      have hx' := hx
      rw [Finset.mem_sigma] at hx'
      rcases hx' with ⟨_hm, hd⟩
      have hdvd : d ∣ m := Nat.dvd_of_mem_divisors hd
      have hmul : d * (m / d) = m := Nat.mul_div_cancel' hdvd
      simp only [F]
      rw [hmul]
    · intro x hx y hy hxy
      exact hF_inj x hx y hy hxy
  have himage_subset : s.image F ⊆ (Finset.Icc (1 : ℕ) Y).product (Finset.Icc (1 : ℕ) Y) := by
    intro p hp
    rw [Finset.mem_image] at hp
    rcases hp with ⟨x, hx, rfl⟩
    exact hF_mem x hx
  have hnonneg_extra : ∀ p ∈ (Finset.Icc (1 : ℕ) Y).product (Finset.Icc (1 : ℕ) Y),
      p ∉ s.image F → 0 ≤ (1 : ℝ) / ((p.1 * p.2 : ℕ) : ℝ) := by
    intro p _hp _
    exact div_nonneg zero_le_one (Nat.cast_nonneg _)
  have himage_le_product :
      (∑ p ∈ s.image F, (1 : ℝ) / ((p.1 * p.2 : ℕ) : ℝ))
        ≤ ∑ p ∈ (Finset.Icc (1 : ℕ) Y).product (Finset.Icc (1 : ℕ) Y),
            (1 : ℝ) / ((p.1 * p.2 : ℕ) : ℝ) :=
    Finset.sum_le_sum_of_subset_of_nonneg himage_subset hnonneg_extra
  have hprod_eq :
      (∑ p ∈ (Finset.Icc (1 : ℕ) Y).product (Finset.Icc (1 : ℕ) Y),
            (1 : ℝ) / ((p.1 * p.2 : ℕ) : ℝ))
        = ((harmonic Y : ℚ) : ℝ) ^ 2 := by
    change (∑ p ∈ (Finset.Icc (1 : ℕ) Y) ×ˢ (Finset.Icc (1 : ℕ) Y),
            (1 : ℝ) / ((p.1 * p.2 : ℕ) : ℝ))
        = ((harmonic Y : ℚ) : ℝ) ^ 2
    rw [Finset.sum_product]
    rw [harmonic_eq_sum_Icc]
    simp only [Rat.cast_sum, Rat.cast_inv, Rat.cast_natCast]
    simp_rw [one_div]
    rw [sq]
    rw [Finset.sum_mul]
    apply Finset.sum_congr rfl
    intro d hd
    rw [Finset.mul_sum]
    apply Finset.sum_congr rfl
    intro r hr
    have hdpos_nat : 0 < d := lt_of_lt_of_le Nat.zero_lt_one (Finset.mem_Icc.mp hd).1
    have hrpos_nat : 0 < r := lt_of_lt_of_le Nat.zero_lt_one (Finset.mem_Icc.mp hr).1
    have hdpos : (d : ℝ) ≠ 0 := by exact_mod_cast (ne_of_gt hdpos_nat)
    have hrpos : (r : ℝ) ≠ 0 := by exact_mod_cast (ne_of_gt hrpos_nat)
    norm_num [Nat.cast_mul]
    field_simp [hdpos, hrpos]
    ring
  rw [hleft_eq_sigma, hsource_to_image]
  exact le_trans himage_le_product hprod_eq.le

/-- General harmonic-power bound for reduced divisor moments.  This is the
finite ordered-factorization induction: the exponent doubles at each divisor
factor. -/
theorem tauPowOverN_succ_le_harmonic_two_pow (Y K : ℕ) :
    tauPowOverN Y (K + 1)
      ≤ ((harmonic Y : ℚ) : ℝ) ^ (2 ^ (K + 1)) := by
  induction K with
  | zero =>
      simpa [tauPowOverN] using tau_div_self_sum_le_harmonic_sq Y
  | succ K ih =>
      have hrec :
          tauPowOverN Y (Nat.succ K + 1) ≤ (tauPowOverN Y (K + 1)) ^ 2 := by
        simpa [Nat.succ_eq_add_one, add_assoc] using
          tauPowOverN_succ_le_square Y (K + 1)
      have hsq :
          (tauPowOverN Y (K + 1)) ^ 2
            ≤ (((harmonic Y : ℚ) : ℝ) ^ (2 ^ (K + 1))) ^ 2 :=
        pow_le_pow_left₀ (tauPowOverN_nonneg Y (K + 1)) ih 2
      have hexp :
          2 ^ (Nat.succ K + 1) = 2 ^ (K + 1) * 2 := by
        rw [Nat.succ_eq_add_one]
        have hsucc : K + 1 + 1 = Nat.succ (K + 1) := by omega
        rw [hsucc, pow_succ]
      calc
        tauPowOverN Y (Nat.succ K + 1)
            ≤ (tauPowOverN Y (K + 1)) ^ 2 := hrec
        _ ≤ (((harmonic Y : ℚ) : ℝ) ^ (2 ^ (K + 1))) ^ 2 := hsq
        _ = ((harmonic Y : ℚ) : ℝ) ^ (2 ^ (Nat.succ K + 1)) := by
              rw [← pow_mul, hexp]

/-- General harmonic-power bound for the divisor-phi moment. -/
theorem abs_divisorPhiMoment_le_harmonic_two_pow (X : ℝ) (K : ℕ) (ν : ℝ) :
    |divisorPhiMoment X K ν|
      ≤ ((harmonic ⌊X ^ ν⌋₊ : ℚ) : ℝ) ^ (2 ^ (K + 1)) := by
  calc
    |divisorPhiMoment X K ν|
        ≤ divisorTauSuccOverN X K ν := abs_divisorPhiMoment_le_tauSuccOverN X K ν
    _ = tauPowOverN ⌊X ^ ν⌋₊ (K + 1) := divisorTauSuccOverN_eq_tauPowOverN X K ν
    _ ≤ ((harmonic ⌊X ^ ν⌋₊ : ℚ) : ℝ) ^ (2 ^ (K + 1)) :=
          tauPowOverN_succ_le_harmonic_two_pow ⌊X ^ ν⌋₊ K

/-- The reduced divisor moment with `K = 0` is bounded by a harmonic square. -/
theorem divisorTauSuccOverN_zero_le_harmonic_sq (X ν : ℝ) :
    divisorTauSuccOverN X 0 ν ≤ ((harmonic ⌊X ^ ν⌋₊ : ℚ) : ℝ) ^ 2 := by
  simpa [divisorTauSuccOverN] using tau_div_self_sum_le_harmonic_sq ⌊X ^ ν⌋₊

/-- Absolute-value harmonic-square bound for the `K = 0` divisor-phi moment. -/
theorem abs_divisorPhiMoment_zero_le_harmonic_sq (X ν : ℝ) :
    |divisorPhiMoment X 0 ν| ≤ ((harmonic ⌊X ^ ν⌋₊ : ℚ) : ℝ) ^ 2 :=
  le_trans (abs_divisorPhiMoment_le_tauSuccOverN X 0 ν)
    (divisorTauSuccOverN_zero_le_harmonic_sq X ν)

/-- Fully checked `K = 0` polylogarithmic case of the divisor-phi moment. -/
theorem divisor_phi_moment_zero (ν : ℝ) (hν : 0 < ν) :
    ∃ C E X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      |divisorPhiMoment X 0 ν| ≤ C * (Real.log X) ^ E := by
  refine ⟨(ν + 1) ^ 2, 2, Real.exp 1, by positivity, ?_⟩
  intro X hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos _) hX
  have hlogX_ge_one : 1 ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hX
  have hlogX_nonneg : 0 ≤ Real.log X := le_trans zero_le_one hlogX_ge_one
  have hcut_pos : 0 < X ^ ν := Real.rpow_pos_of_pos hXpos ν
  have hlog_cut_eq : Real.log (X ^ ν) = ν * Real.log X := by
    rw [Real.log_rpow hXpos]
  have hcut_ge_one : 1 ≤ X ^ ν := by
    apply (Real.log_le_log_iff (by norm_num : (0 : ℝ) < 1) hcut_pos).mp
    rw [hlog_cut_eq]
    simpa using mul_nonneg hν.le hlogX_nonneg
  have hharm : ((harmonic ⌊X ^ ν⌋₊ : ℚ) : ℝ) ≤ 1 + Real.log (X ^ ν) :=
    harmonic_floor_le_one_add_log (X ^ ν) hcut_ge_one
  have htarget_nonneg : 0 ≤ (ν + 1) * Real.log X := by positivity
  have hlinear : 1 + Real.log (X ^ ν) ≤ (ν + 1) * Real.log X := by
    rw [hlog_cut_eq]
    nlinarith [hlogX_ge_one, hν.le]
  have hharm_target : ((harmonic ⌊X ^ ν⌋₊ : ℚ) : ℝ) ≤ (ν + 1) * Real.log X :=
    le_trans hharm hlinear
  have hharm_nonneg : 0 ≤ ((harmonic ⌊X ^ ν⌋₊ : ℚ) : ℝ) := by
    rw [harmonic_eq_sum_Icc]
    simp only [Rat.cast_sum, Rat.cast_inv, Rat.cast_natCast]
    apply Finset.sum_nonneg
    intro n _hn
    exact inv_nonneg.mpr (Nat.cast_nonneg n)
  calc
    |divisorPhiMoment X 0 ν|
        ≤ ((harmonic ⌊X ^ ν⌋₊ : ℚ) : ℝ) ^ 2 :=
          abs_divisorPhiMoment_zero_le_harmonic_sq X ν
    _ ≤ ((ν + 1) * Real.log X) ^ 2 :=
          pow_le_pow_left₀ hharm_nonneg hharm_target 2
    _ = (ν + 1) ^ 2 * (Real.log X) ^ 2 := by ring
    _ = (ν + 1) ^ 2 * (Real.log X) ^ (2 : ℝ) := by
          rw [Real.rpow_two]

/-- Hyperbola/reindexing bound for the second divisor moment:
`∑_{m≤Y} τ(m)^2/m ≤ H_Y⁴`.  The injection sends two divisors `d,e | m` to
`(gcd(d,e), d/gcd(d,e), e/gcd(d,e), m/lcm(d,e))`. -/
theorem tau_sq_div_self_sum_le_harmonic_fourth (Y : ℕ) :
    (∑ m ∈ Finset.Icc (1 : ℕ) Y, ((tau m ^ 2 : ℕ) : ℝ) / (m : ℝ))
      ≤ ((harmonic Y : ℚ) : ℝ) ^ 4 := by
  classical
  let I : Finset ℕ := Finset.Icc (1 : ℕ) Y
  let s : Finset ((m : ℕ) × (ℕ × ℕ)) :=
    I.sigma (fun m => m.divisors.product m.divisors)
  let F : ((m : ℕ) × (ℕ × ℕ)) → (ℕ × ℕ) × (ℕ × ℕ) := fun x =>
    let m := x.1; let d := x.2.1; let e := x.2.2; let g := d.gcd e
    ((g, d / g), (e / g, m / d.lcm e))
  have hleft_inner :
      (∑ m ∈ I, ((tau m ^ 2 : ℕ) : ℝ) / (m : ℝ))
        = ∑ m ∈ I, ∑ _p ∈ m.divisors.product m.divisors, (1 : ℝ) / (m : ℝ) := by
    apply Finset.sum_congr rfl
    intro m hm
    have hmpos_nat : 0 < m := lt_of_lt_of_le Nat.zero_lt_one (Finset.mem_Icc.mp hm).1
    have hmpos : (0 : ℝ) < (m : ℝ) := by exact_mod_cast hmpos_nat
    unfold tau
    have hcard : (m.divisors.product m.divisors).card =
        m.divisors.card * m.divisors.card :=
      Finset.card_product _ _
    rw [Finset.sum_const, nsmul_eq_mul]
    rw [hcard]
    rw [pow_two]
    field_simp [ne_of_gt hmpos]
  have hinner_sigma :
      (∑ m ∈ I, ∑ _p ∈ m.divisors.product m.divisors, (1 : ℝ) / (m : ℝ))
        = ∑ x ∈ s, (1 : ℝ) / (x.1 : ℝ) := by
    unfold s
    exact Finset.sum_sigma' I (fun m => m.divisors.product m.divisors)
      (fun m _p => (1 : ℝ) / (m : ℝ))
  have hleft_eq_sigma :
      (∑ m ∈ I, ((tau m ^ 2 : ℕ) : ℝ) / (m : ℝ))
        = ∑ x ∈ s, (1 : ℝ) / (x.1 : ℝ) := by
    rw [hleft_inner, hinner_sigma]
  have hF_mem : ∀ x ∈ s, F x ∈ (I.product I).product (I.product I) := by
    intro x hx
    rcases x with ⟨m, p⟩
    rcases p with ⟨d, e⟩
    have hx' := hx
    rw [Finset.mem_sigma] at hx'
    rcases hx' with ⟨hm, hp⟩
    have hpP := Finset.mem_product.mp hp
    rcases hpP with ⟨hd, he⟩
    have hmpos_nat : 0 < m := lt_of_lt_of_le Nat.zero_lt_one (Finset.mem_Icc.mp hm).1
    have hdpos : 0 < d := Nat.pos_of_mem_divisors hd
    have hepos : 0 < e := Nat.pos_of_mem_divisors he
    let g := d.gcd e
    have hgpos : 0 < g := Nat.gcd_pos_of_pos_left e hdpos
    have hdvdg : g ∣ d := Nat.gcd_dvd_left d e
    have hevdg : g ∣ e := Nat.gcd_dvd_right d e
    have hdlcm : d.lcm e ∣ m :=
      Nat.lcm_dvd (Nat.dvd_of_mem_divisors hd) (Nat.dvd_of_mem_divisors he)
    have hlcmpos : 0 < d.lcm e := Nat.lcm_pos hdpos hepos
    have hg_le_Y : g ≤ Y :=
      le_trans (Nat.le_of_dvd hdpos hdvdg)
        (le_trans (Nat.divisor_le hd) (Finset.mem_Icc.mp hm).2)
    have hdg_pos : 0 < d / g := Nat.div_pos (Nat.le_of_dvd hdpos hdvdg) hgpos
    have heg_pos : 0 < e / g := Nat.div_pos (Nat.le_of_dvd hepos hevdg) hgpos
    have hml_pos : 0 < m / d.lcm e :=
      Nat.div_pos (Nat.le_of_dvd hmpos_nat hdlcm) hlcmpos
    have hdg_le_Y : d / g ≤ Y :=
      le_trans (Nat.div_le_self d g)
        (le_trans (Nat.divisor_le hd) (Finset.mem_Icc.mp hm).2)
    have heg_le_Y : e / g ≤ Y :=
      le_trans (Nat.div_le_self e g)
        (le_trans (Nat.divisor_le he) (Finset.mem_Icc.mp hm).2)
    have hml_le_Y : m / d.lcm e ≤ Y :=
      le_trans (Nat.div_le_self m (d.lcm e)) (Finset.mem_Icc.mp hm).2
    simp only [F]
    change ((g, d / g), (e / g, m / d.lcm e)) ∈ (I ×ˢ I) ×ˢ (I ×ˢ I)
    rw [Finset.mem_product, Finset.mem_product, Finset.mem_product]
    exact
      ⟨⟨Finset.mem_Icc.mpr ⟨hgpos, hg_le_Y⟩,
          Finset.mem_Icc.mpr ⟨hdg_pos, hdg_le_Y⟩⟩,
        ⟨Finset.mem_Icc.mpr ⟨heg_pos, heg_le_Y⟩,
          Finset.mem_Icc.mpr ⟨hml_pos, hml_le_Y⟩⟩⟩
  have hF_inj : ∀ x ∈ s, ∀ y ∈ s, F x = F y → x = y := by
    intro x hx y hy hxy
    rcases x with ⟨m, p⟩; rcases p with ⟨d, e⟩
    rcases y with ⟨n, q⟩; rcases q with ⟨d', e'⟩
    have hx' := hx; have hy' := hy
    rw [Finset.mem_sigma] at hx'; rw [Finset.mem_sigma] at hy'
    rcases hx' with ⟨_hm, hp⟩; rcases hy' with ⟨_hn, hq⟩
    have hpP := Finset.mem_product.mp hp; have hqP := Finset.mem_product.mp hq
    rcases hpP with ⟨hd, he⟩; rcases hqP with ⟨hd', he'⟩
    let g := d.gcd e
    let g' := d'.gcd e'
    have h1 : g = g' := congrArg (fun z => z.1.1) hxy
    have h2 : d / g = d' / g' := congrArg (fun z => z.1.2) hxy
    have h3 : e / g = e' / g' := congrArg (fun z => z.2.1) hxy
    have h4 : m / d.lcm e = n / d'.lcm e' := congrArg (fun z => z.2.2) hxy
    have hdvd_l : d.lcm e ∣ m :=
      Nat.lcm_dvd (Nat.dvd_of_mem_divisors hd) (Nat.dvd_of_mem_divisors he)
    have hdvd_l' : d'.lcm e' ∣ n :=
      Nat.lcm_dvd (Nat.dvd_of_mem_divisors hd') (Nat.dvd_of_mem_divisors he')
    have hm_eq : m = d.lcm e * (m / d.lcm e) := (Nat.mul_div_cancel' hdvd_l).symm
    have hn_eq : n = d'.lcm e' * (n / d'.lcm e') :=
      (Nat.mul_div_cancel' hdvd_l').symm
    have hd_eq : d = g * (d / g) :=
      (Nat.mul_div_cancel' (Nat.gcd_dvd_left d e)).symm
    have he_eq : e = g * (e / g) :=
      (Nat.mul_div_cancel' (Nat.gcd_dvd_right d e)).symm
    have hd_eq' : d' = g' * (d' / g') :=
      (Nat.mul_div_cancel' (Nat.gcd_dvd_left d' e')).symm
    have he_eq' : e' = g' * (e' / g') :=
      (Nat.mul_div_cancel' (Nat.gcd_dvd_right d' e')).symm
    have h2' : d / g' = d' / g' := by simpa [h1] using h2
    have h3' : e / g' = e' / g' := by simpa [h1] using h3
    have hdd : d = d' := by
      calc d = g * (d / g) := hd_eq
        _ = g' * (d / g') := by rw [h1]
        _ = g' * (d' / g') := by rw [h2']
        _ = d' := hd_eq'.symm
    have hee : e = e' := by
      calc e = g * (e / g) := he_eq
        _ = g' * (e / g') := by rw [h1]
        _ = g' * (e' / g') := by rw [h3']
        _ = e' := he_eq'.symm
    have hll : d.lcm e = d'.lcm e' := by rw [hdd, hee]
    have h4' : m / d'.lcm e' = n / d'.lcm e' := by simpa [hll] using h4
    have hmn : m = n := by
      calc m = d.lcm e * (m / d.lcm e) := hm_eq
        _ = d'.lcm e' * (m / d'.lcm e') := by rw [hll]
        _ = d'.lcm e' * (n / d'.lcm e') := by rw [h4']
        _ = n := hn_eq.symm
    subst n; subst d'; subst e'; rfl
  have hsource_to_image :
      (∑ x ∈ s, (1 : ℝ) / (x.1 : ℝ))
        = ∑ p ∈ s.image F, (1 : ℝ) /
            ((((p.1.1 * p.1.2) * p.2.1) * p.2.2 : ℕ) : ℝ) := by
    rw [Finset.sum_image]
    · apply Finset.sum_congr rfl
      intro x hx
      rcases x with ⟨m, p⟩; rcases p with ⟨d, e⟩
      have hx' := hx
      rw [Finset.mem_sigma] at hx'
      rcases hx' with ⟨_hm, hp⟩
      have hpP := Finset.mem_product.mp hp
      rcases hpP with ⟨hd, he⟩
      let g := d.gcd e
      have hdpos : 0 < d := Nat.pos_of_mem_divisors hd
      have hdecomp : g * (d / g) * (e / g) = d.lcm e :=
        lcm_eq_gcd_mul_divs hdpos
      have hlcm_dvd : d.lcm e ∣ m :=
        Nat.lcm_dvd (Nat.dvd_of_mem_divisors hd) (Nat.dvd_of_mem_divisors he)
      have hprod : (((g * (d / g)) * (e / g)) * (m / d.lcm e)) = m := by
        rw [hdecomp]
        exact Nat.mul_div_cancel' hlcm_dvd
      simp only [F]
      rw [hprod]
    · intro x hx y hy hxy
      exact hF_inj x hx y hy hxy
  have himage_subset : s.image F ⊆ (I.product I).product (I.product I) := by
    intro p hp
    rw [Finset.mem_image] at hp
    rcases hp with ⟨x, hx, rfl⟩
    exact hF_mem x hx
  have hnonneg_extra : ∀ p ∈ (I.product I).product (I.product I), p ∉ s.image F →
      0 ≤ (1 : ℝ) / (((((p.1.1 * p.1.2) * p.2.1) * p.2.2 : ℕ)) : ℝ) := by
    intro p _hp _
    exact div_nonneg zero_le_one (Nat.cast_nonneg _)
  have himage_le_product :
      (∑ p ∈ s.image F, (1 : ℝ) /
            ((((p.1.1 * p.1.2) * p.2.1) * p.2.2 : ℕ) : ℝ))
        ≤ ∑ p ∈ (I.product I).product (I.product I), (1 : ℝ) /
            ((((p.1.1 * p.1.2) * p.2.1) * p.2.2 : ℕ) : ℝ) :=
    Finset.sum_le_sum_of_subset_of_nonneg himage_subset hnonneg_extra
  have hprod_eq :
      (∑ p ∈ (I.product I).product (I.product I), (1 : ℝ) /
            ((((p.1.1 * p.1.2) * p.2.1) * p.2.2 : ℕ) : ℝ))
        = ((harmonic Y : ℚ) : ℝ) ^ 4 := by
    unfold I
    exact four_recip_product_sum_eq_harmonic_fourth Y
  rw [hleft_eq_sigma, hsource_to_image]
  exact le_trans himage_le_product hprod_eq.le

/-- The reduced divisor moment with `K = 1` is bounded by a harmonic fourth
power. -/
theorem divisorTauSuccOverN_one_le_harmonic_fourth (X ν : ℝ) :
    divisorTauSuccOverN X 1 ν ≤ ((harmonic ⌊X ^ ν⌋₊ : ℚ) : ℝ) ^ 4 := by
  simpa [divisorTauSuccOverN] using tau_sq_div_self_sum_le_harmonic_fourth ⌊X ^ ν⌋₊

/-- Absolute-value harmonic-fourth bound for the `K = 1` divisor-phi moment. -/
theorem abs_divisorPhiMoment_one_le_harmonic_fourth (X ν : ℝ) :
    |divisorPhiMoment X 1 ν| ≤ ((harmonic ⌊X ^ ν⌋₊ : ℚ) : ℝ) ^ 4 :=
  le_trans (abs_divisorPhiMoment_le_tauSuccOverN X 1 ν)
    (divisorTauSuccOverN_one_le_harmonic_fourth X ν)

/-- Fully checked `K = 1` polylogarithmic case of the divisor-phi moment. -/
theorem divisor_phi_moment_one (ν : ℝ) (hν : 0 < ν) :
    ∃ C E X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      |divisorPhiMoment X 1 ν| ≤ C * (Real.log X) ^ E := by
  refine ⟨(ν + 1) ^ 4, 4, Real.exp 1, by positivity, ?_⟩
  intro X hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos _) hX
  have hlogX_ge_one : 1 ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hX
  have hlogX_nonneg : 0 ≤ Real.log X := le_trans zero_le_one hlogX_ge_one
  have hcut_pos : 0 < X ^ ν := Real.rpow_pos_of_pos hXpos ν
  have hlog_cut_eq : Real.log (X ^ ν) = ν * Real.log X := by
    rw [Real.log_rpow hXpos]
  have hcut_ge_one : 1 ≤ X ^ ν := by
    apply (Real.log_le_log_iff (by norm_num : (0 : ℝ) < 1) hcut_pos).mp
    rw [hlog_cut_eq]
    simpa using mul_nonneg hν.le hlogX_nonneg
  have hharm : ((harmonic ⌊X ^ ν⌋₊ : ℚ) : ℝ) ≤ 1 + Real.log (X ^ ν) :=
    harmonic_floor_le_one_add_log (X ^ ν) hcut_ge_one
  have hlinear : 1 + Real.log (X ^ ν) ≤ (ν + 1) * Real.log X := by
    rw [hlog_cut_eq]
    nlinarith [hlogX_ge_one, hν.le]
  have hharm_target : ((harmonic ⌊X ^ ν⌋₊ : ℚ) : ℝ) ≤ (ν + 1) * Real.log X :=
    le_trans hharm hlinear
  have hharm_nonneg : 0 ≤ ((harmonic ⌊X ^ ν⌋₊ : ℚ) : ℝ) := by
    rw [harmonic_eq_sum_Icc]
    simp only [Rat.cast_sum, Rat.cast_inv, Rat.cast_natCast]
    apply Finset.sum_nonneg
    intro n _hn
    exact inv_nonneg.mpr (Nat.cast_nonneg n)
  calc
    |divisorPhiMoment X 1 ν|
        ≤ ((harmonic ⌊X ^ ν⌋₊ : ℚ) : ℝ) ^ 4 :=
          abs_divisorPhiMoment_one_le_harmonic_fourth X ν
    _ ≤ ((ν + 1) * Real.log X) ^ 4 :=
          pow_le_pow_left₀ hharm_nonneg hharm_target 4
    _ = (ν + 1) ^ 4 * (Real.log X) ^ (4 : ℝ) := by
          have hlog4 : (Real.log X) ^ (4 : ℝ) = (Real.log X) ^ (4 : ℕ) :=
            Real.rpow_natCast (Real.log X) 4
          rw [hlog4]
          ring

/-- Fully checked general polylogarithmic divisor-phi moment.  The proof is the
ordered-factorization induction for `∑ τ(m)^r/m` plus the elementary
`m/φ(m) ≤ τ(m)` reduction. -/
theorem divisor_phi_moment_general (K : ℕ) (ν : ℝ) (hν : 0 < ν) :
    ∃ C E X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      |divisorPhiMoment X K ν| ≤ C * (Real.log X) ^ E := by
  let N : ℕ := 2 ^ (K + 1)
  refine ⟨(ν + 1) ^ N, (N : ℝ), Real.exp 1, ?_, ?_⟩
  · have hν1 : 0 < ν + 1 := by linarith
    exact pow_pos hν1 N
  intro X hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos _) hX
  have hlogX_ge_one : 1 ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hX
  have hlogX_nonneg : 0 ≤ Real.log X := le_trans zero_le_one hlogX_ge_one
  have hcut_pos : 0 < X ^ ν := Real.rpow_pos_of_pos hXpos ν
  have hlog_cut_eq : Real.log (X ^ ν) = ν * Real.log X := by
    rw [Real.log_rpow hXpos]
  have hcut_ge_one : 1 ≤ X ^ ν := by
    apply (Real.log_le_log_iff (by norm_num : (0 : ℝ) < 1) hcut_pos).mp
    rw [hlog_cut_eq]
    simpa using mul_nonneg hν.le hlogX_nonneg
  have hharm : ((harmonic ⌊X ^ ν⌋₊ : ℚ) : ℝ) ≤ 1 + Real.log (X ^ ν) :=
    harmonic_floor_le_one_add_log (X ^ ν) hcut_ge_one
  have hlinear : 1 + Real.log (X ^ ν) ≤ (ν + 1) * Real.log X := by
    rw [hlog_cut_eq]
    nlinarith [hlogX_ge_one, hν.le]
  have hharm_target : ((harmonic ⌊X ^ ν⌋₊ : ℚ) : ℝ) ≤ (ν + 1) * Real.log X :=
    le_trans hharm hlinear
  have hharm_nonneg : 0 ≤ ((harmonic ⌊X ^ ν⌋₊ : ℚ) : ℝ) :=
    harmonic_nonneg_real ⌊X ^ ν⌋₊
  calc
    |divisorPhiMoment X K ν|
        ≤ ((harmonic ⌊X ^ ν⌋₊ : ℚ) : ℝ) ^ N := by
          simpa [N] using abs_divisorPhiMoment_le_harmonic_two_pow X K ν
    _ ≤ ((ν + 1) * Real.log X) ^ N :=
          pow_le_pow_left₀ hharm_nonneg hharm_target N
    _ = (ν + 1) ^ N * (Real.log X) ^ N := by
          rw [mul_pow]
    _ = (ν + 1) ^ N * (Real.log X) ^ (N : ℝ) := by
          rw [Real.rpow_natCast]

/-- The divisor-phi moment carrier is bounded by the finite power envelope over
the same cutoff.  This is far weaker than the cited polylogarithmic moment bound,
but is an unconditional carrier-level sanity check. -/
theorem divisorPhiMoment_le_powerEnvelope (X : ℝ) (K : ℕ) (ν : ℝ) :
    divisorPhiMoment X K ν ≤ divisorPowerEnvelope X K ν := by
  classical
  unfold divisorPhiMoment divisorPowerEnvelope
  apply Finset.sum_le_sum
  intro m hm
  exact divisorPhiMoment_summand_le_power K m (Finset.mem_Icc.mp hm).1

/-- The finite power envelope is bounded by the one-piece polynomial cutoff
`(X^ν)^(K+1)` for positive `X`. -/
theorem divisorPowerEnvelope_le_rpow_window
    (X : ℝ) (K : ℕ) (ν : ℝ) (hX : 0 < X) :
    divisorPowerEnvelope X K ν ≤ (X ^ ν) ^ (K + 1) := by
  classical
  have hcut_pos : 0 < X ^ ν := Real.rpow_pos_of_pos hX ν
  have hcut_nonneg : 0 ≤ X ^ ν := hcut_pos.le
  have hterm :
      divisorPowerEnvelope X K ν
        ≤ ∑ m ∈ Finset.Icc (1 : ℕ) ⌊X ^ ν⌋₊, (X ^ ν) ^ K := by
    unfold divisorPowerEnvelope
    apply Finset.sum_le_sum
    intro m hm
    have hm_le_floor : m ≤ ⌊X ^ ν⌋₊ := (Finset.mem_Icc.mp hm).2
    have hm_le_cut : (m : ℝ) ≤ X ^ ν := by
      exact le_trans (by exact_mod_cast hm_le_floor) (Nat.floor_le hcut_nonneg)
    exact pow_le_pow_left₀ (Nat.cast_nonneg m) hm_le_cut K
  have hcard_eq :
      ((Finset.Icc (1 : ℕ) ⌊X ^ ν⌋₊).card : ℝ) = (⌊X ^ ν⌋₊ : ℝ) := by
    have hcard_nat : (Finset.Icc (1 : ℕ) ⌊X ^ ν⌋₊).card = ⌊X ^ ν⌋₊ := by
      cases ⌊X ^ ν⌋₊ <;> simp
    exact_mod_cast hcard_nat
  calc
    divisorPowerEnvelope X K ν
        ≤ ∑ m ∈ Finset.Icc (1 : ℕ) ⌊X ^ ν⌋₊, (X ^ ν) ^ K := hterm
    _ = ((Finset.Icc (1 : ℕ) ⌊X ^ ν⌋₊).card : ℝ) * (X ^ ν) ^ K := by
          simp
    _ = (⌊X ^ ν⌋₊ : ℝ) * (X ^ ν) ^ K := by rw [hcard_eq]
    _ ≤ (X ^ ν) * (X ^ ν) ^ K := by
          exact mul_le_mul_of_nonneg_right (Nat.floor_le hcut_nonneg)
            (pow_nonneg hcut_nonneg K)
    _ = (X ^ ν) ^ (K + 1) := by
          rw [pow_succ']

/-- Polynomial fallback for the divisor-phi moment carrier.  This is much weaker
than the manuscript's polylogarithmic moment bound. -/
theorem divisorPhiMoment_le_rpow_window
    (X : ℝ) (K : ℕ) (ν : ℝ) (hX : 0 < X) :
    divisorPhiMoment X K ν ≤ (X ^ ν) ^ (K + 1) :=
  le_trans (divisorPhiMoment_le_powerEnvelope X K ν)
    (divisorPowerEnvelope_le_rpow_window X K ν hX)

/-- Absolute-value form of the polynomial divisor-phi moment fallback. -/
theorem abs_divisorPhiMoment_le_rpow_window
    (X : ℝ) (K : ℕ) (ν : ℝ) (hX : 0 < X) :
    |divisorPhiMoment X K ν| ≤ (X ^ ν) ^ (K + 1) := by
  rw [abs_of_nonneg (divisorPhiMoment_nonneg X K ν)]
  exact divisorPhiMoment_le_rpow_window X K ν hX

/-- Manuscript-shaped unconditional polynomial fallback for the divisor-phi
moment carrier, uniform in the fixed exponent `K` and window parameter `ν`.
This packages the elementary same-carrier power-envelope proof; the
polylogarithmic moment bound is now checked separately for arbitrary fixed `K`. -/
theorem divisorPhiMoment_upper_unconditional (K : ℕ) (ν : ℝ) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      |divisorPhiMoment X K ν| ≤ C * (X ^ ν) ^ (K + 1) := by
  refine ⟨1, 1, by norm_num, ?_⟩
  intro X hX
  have hXpos : 0 < X := lt_of_lt_of_le zero_lt_one hX
  simpa using abs_divisorPhiMoment_le_rpow_window X K ν hXpos

/-!
The full divisor-phi moment `∑_{m≤X^ν} τ(m)^K/φ(m) ≪ (log X)^{O_K(1)}` is now
proved above for arbitrary fixed `K` as `divisor_phi_moment_general`; the
`K = 0` and `K = 1` wrappers remain as readable named special cases.
-/

/-! ## Maximal Bombieri–Vinogradov and its reciprocal/weighted consequences. -/

/-- The Chebyshev prime sum in a residue class:
`thetaAP y q a = ∑_{p≤y, p≡a (q)} log p`. -/
noncomputable def thetaAP (y : ℝ) (q a : ℕ) : ℝ := by
  classical
  exact
    ∑ p ∈ (natWindow 0 y).filter (fun p : ℕ => Nat.Prime p ∧ congMod p a q),
      Real.log p

/-- The Chebyshev prime-sum carrier is nonnegative. -/
theorem thetaAP_nonneg (y : ℝ) (q a : ℕ) : 0 ≤ thetaAP y q a := by
  classical
  unfold thetaAP
  apply Finset.sum_nonneg
  intro p hp
  have hpPrime : Nat.Prime p := (Finset.mem_filter.mp hp).2.1
  have hpOne : (1 : ℝ) ≤ (p : ℝ) := by
    exact_mod_cast hpPrime.one_lt.le
  exact Real.log_nonneg hpOne

/-- A finite all-integer log envelope that dominates prime-log sums with cutoff
`≤ x`. -/
noncomputable def thetaFullBound (x : ℝ) : ℝ :=
  ∑ p ∈ Finset.Icc (1 : ℕ) ⌊x⌋₊, Real.log p

/-- Every progression Chebyshev sum with cutoff `y ≤ x` is dominated by the full
finite all-integer log envelope up to `x`. -/
theorem thetaAP_le_full_bound {x y : ℝ} (q a : ℕ) (hyx : y ≤ x) :
    thetaAP y q a ≤ thetaFullBound x := by
  classical
  unfold thetaAP thetaFullBound natWindow
  apply Finset.sum_le_sum_of_subset_of_nonneg
  · intro p hp
    have hpIccY : p ∈ Finset.Icc (1 : ℕ) ⌊y⌋₊ :=
      (Finset.mem_filter.mp (Finset.mem_filter.mp hp).1).1
    have hp_le_floor_y : p ≤ ⌊y⌋₊ := (Finset.mem_Icc.mp hpIccY).2
    have hfloor_le : ⌊y⌋₊ ≤ ⌊x⌋₊ := Nat.floor_mono hyx
    exact Finset.mem_Icc.mpr
      ⟨(Finset.mem_Icc.mp hpIccY).1, le_trans hp_le_floor_y hfloor_le⟩
  · intro p hpBig _hpSmall
    have hpOneNat : 1 ≤ p := (Finset.mem_Icc.mp hpBig).1
    have hpOne : (1 : ℝ) ≤ (p : ℝ) := by exact_mod_cast hpOneNat
    exact Real.log_nonneg hpOne

/-- Division by the totient denominator cannot increase a nonnegative numerator.
The `q = 0` branch is harmless because division by zero is `0` in Lean fields. -/
theorem div_totient_abs_le_self {y : ℝ} (q : ℕ) (hy_nonneg : 0 ≤ y) :
    |y / (Nat.totient q : ℝ)| ≤ y := by
  by_cases htot : Nat.totient q = 0
  · simp [htot, hy_nonneg]
  · have htot_pos_nat : 0 < Nat.totient q := Nat.pos_of_ne_zero htot
    have htot_one : (1 : ℝ) ≤ (Nat.totient q : ℝ) := by exact_mod_cast htot_pos_nat
    have htot_pos : 0 < (Nat.totient q : ℝ) := by exact_mod_cast htot_pos_nat
    have hdiv_nonneg : 0 ≤ y / (Nat.totient q : ℝ) :=
      div_nonneg hy_nonneg htot_pos.le
    rw [abs_of_nonneg hdiv_nonneg]
    exact div_le_self hy_nonneg htot_one

/-- Raw BV maximal-error values before adjoining `0` for degenerate cutoffs. -/
def bvErrorRawSet (x : ℝ) (q : ℕ) : Set ℝ :=
  {t : ℝ | ∃ a : ℕ, Nat.Coprime a q ∧ ∃ y : ℝ,
    2 ≤ y ∧ y ≤ x ∧ t = |thetaAP y q a - y / (Nat.totient q : ℝ)|}

/-- BV maximal-error values with an explicit `0` seed.  This makes the supremum
carrier nonempty even for degenerate cutoffs. -/
def bvErrorSet (x : ℝ) (q : ℕ) : Set ℝ :=
  {0} ∪ bvErrorRawSet x q

/-- Every raw BV error is bounded by the full prime-log envelope plus `x`. -/
theorem bvErrorRawSet_le_bound {x : ℝ} {q : ℕ} {t : ℝ}
    (ht : t ∈ bvErrorRawSet x q) : t ≤ thetaFullBound x + x := by
  rcases ht with ⟨a, _ha, y, hy2, hyx, rfl⟩
  have htheta_nonneg : 0 ≤ thetaAP y q a := thetaAP_nonneg y q a
  have htheta_le : thetaAP y q a ≤ thetaFullBound x := thetaAP_le_full_bound q a hyx
  have hy_nonneg : 0 ≤ y := le_trans (by norm_num) hy2
  have hdiv_abs : |y / (Nat.totient q : ℝ)| ≤ y :=
    div_totient_abs_le_self q hy_nonneg
  have hdiv_abs_x : |y / (Nat.totient q : ℝ)| ≤ x := le_trans hdiv_abs hyx
  calc
    |thetaAP y q a - y / (Nat.totient q : ℝ)|
        ≤ |thetaAP y q a| + |y / (Nat.totient q : ℝ)| := by
          simpa [sub_eq_add_neg, abs_neg]
            using abs_add (thetaAP y q a) (-(y / (Nat.totient q : ℝ)))
    _ = thetaAP y q a + |y / (Nat.totient q : ℝ)| := by
          rw [abs_of_nonneg htheta_nonneg]
    _ ≤ thetaFullBound x + x := add_le_add htheta_le hdiv_abs_x

/-- The augmented BV error set is nonempty because it contains `0`. -/
theorem bvErrorSet_nonempty (x : ℝ) (q : ℕ) : (bvErrorSet x q).Nonempty := by
  exact ⟨0, Or.inl rfl⟩

/-- The real-cutoff set whose supremum defines `bvError` is genuinely bounded
above, so its `sSup` is not an empty or unbounded-set placeholder. -/
theorem bvError_set_bddAbove (x : ℝ) (q : ℕ) : BddAbove (bvErrorSet x q) := by
  refine ⟨max 0 (thetaFullBound x + x), ?_⟩
  intro t ht
  rcases ht with ht0 | htErr
  · rw [ht0]
    exact le_max_left _ _
  · exact le_trans (bvErrorRawSet_le_bound htErr) (le_max_right _ _)

/-- The BV maximal error as the real-cutoff supremum over reduced classes and
`2≤y≤x`, with an explicit `0` seed for degenerate cutoff ranges.  This is the
supremum form of the manuscript maximum in `thm:BV-max`; `bvErrorSet_nonempty`
and `bvError_set_bddAbove` verify that the supremum is taken over a nonempty
bounded set. -/
noncomputable def bvError (x : ℝ) (q : ℕ) : ℝ :=
  sSup (bvErrorSet x q)

/-- The single-modulus BV carrier is nonnegative by construction, since `0`
belongs to the augmented supremum set. -/
theorem bvError_nonneg (x : ℝ) (q : ℕ) : 0 ≤ bvError x q := by
  unfold bvError
  exact le_csSup (bvError_set_bddAbove x q) (Or.inl rfl)

/-- The single-modulus BV carrier is itself bounded by the same finite envelope. -/
theorem bvError_le_bound (x : ℝ) (q : ℕ) :
    bvError x q ≤ max 0 (thetaFullBound x + x) := by
  unfold bvError
  exact csSup_le (bvErrorSet_nonempty x q) (by
    intro t ht
    rcases ht with ht0 | htErr
    · rw [ht0]
      exact le_max_left _ _
    · exact le_trans (bvErrorRawSet_le_bound htErr) (le_max_right _ _))

/-- Every raw BV error value is bounded by the single-modulus BV carrier. -/
theorem bvErrorRawSet_le_bvError {x : ℝ} {q : ℕ} {t : ℝ}
    (ht : t ∈ bvErrorRawSet x q) : t ≤ bvError x q := by
  unfold bvError
  exact le_csSup (bvError_set_bddAbove x q) (Or.inr ht)

/-- Pointwise form: every admissible reduced-class prime error is bounded by
`bvError`. -/
theorem thetaAP_error_le_bvError {x y : ℝ} {q a : ℕ}
    (ha : Nat.Coprime a q) (hy2 : 2 ≤ y) (hyx : y ≤ x) :
    |thetaAP y q a - y / (Nat.totient q : ℝ)| ≤ bvError x q := by
  exact bvErrorRawSet_le_bvError
    ⟨a, ha, y, hy2, hyx, rfl⟩

/-- **Maximal Bombieri–Vinogradov** (`thm:BV-max`, tex 1075–1098;
cite `IK2004` Thm 17.1, `Bombieri1965`, `Vinogradov1965`).  For fixed `A > 0`,
`ε > 0` and `x ≥ 3`,
`∑_{q ≤ x^{1/2−ε}} max_{(a,q)=1} max_{2≤y≤x} |ϑ(y;q,a) − y/φ(q)| ≪_{A,ε} x/(log x)^A`.
Here `bvSum x ε := ∑_{q ≤ x^{1/2−ε}} bvError x q`. -/
noncomputable def bvSum (x ε : ℝ) : ℝ :=
  ∑ q ∈ Finset.Icc (1 : ℕ) ⌊x ^ ((1 : ℝ) / 2 - ε)⌋₊, bvError x q

/-- The aggregate BV carrier is nonnegative. -/
theorem bvSum_nonneg (x ε : ℝ) : 0 ≤ bvSum x ε := by
  classical
  unfold bvSum
  apply Finset.sum_nonneg
  intro q _hq
  exact bvError_nonneg x q

/-- Paper-facing maximal Bombieri--Vinogradov input (`thm:BV-max`, tex
1100--1123): for every fixed logarithmic saving `A` and range margin `ε`, the
maximal Chebyshev progression-error sum over `q ≤ x^{1/2-ε}` has size
`≪ x / (log x)^A`. -/
def BombieriVinogradovMaximalForm : Prop :=
  ∀ A ε : ℝ, 0 < A → 0 < ε →
    ∃ C x₀ : ℝ, 0 < C ∧ ∀ x : ℝ, x₀ ≤ x →
      bvSum x ε ≤ C * (x / (Real.log x) ^ A)

/-- Standard maximal Bombieri--Vinogradov theorem, kept as a named cited
external theorem rather than hidden behind downstream reciprocal-prime carriers. -/
axiom standard_bombieri_vinogradov_maximal_form :
  BombieriVinogradovMaximalForm

/-- Public wrapper for the cited maximal Bombieri--Vinogradov input. -/
theorem bombieri_vinogradov_maximal_form :
    BombieriVinogradovMaximalForm :=
  standard_bombieri_vinogradov_maximal_form

/-- The full all-integer Chebyshev-log envelope is nonnegative. -/
theorem thetaFullBound_nonneg (x : ℝ) : 0 ≤ thetaFullBound x := by
  classical
  unfold thetaFullBound
  apply Finset.sum_nonneg
  intro p hp
  have hp1 : 1 ≤ p := (Finset.mem_Icc.mp hp).1
  have hp1r : (1 : ℝ) ≤ (p : ℝ) := by exact_mod_cast hp1
  exact Real.log_nonneg hp1r

/-- The full all-integer Chebyshev-log envelope is bounded by `x log x` for
`x ≥ 1`.  This is deliberately cruder than any prime-counting theorem. -/
theorem thetaFullBound_le_mul_log (x : ℝ) (hx : 1 ≤ x) :
    thetaFullBound x ≤ x * Real.log x := by
  classical
  have hx_nonneg : 0 ≤ x := le_trans zero_le_one hx
  have hlog_nonneg : 0 ≤ Real.log x := Real.log_nonneg hx
  have hterm : thetaFullBound x ≤ ∑ p ∈ Finset.Icc (1 : ℕ) ⌊x⌋₊, Real.log x := by
    unfold thetaFullBound
    apply Finset.sum_le_sum
    intro p hp
    have hp1 : 1 ≤ p := (Finset.mem_Icc.mp hp).1
    have hpf : p ≤ ⌊x⌋₊ := (Finset.mem_Icc.mp hp).2
    have hppos_nat : 0 < p := lt_of_lt_of_le Nat.zero_lt_one hp1
    have hppos : (0 : ℝ) < (p : ℝ) := by exact_mod_cast hppos_nat
    have hpx : (p : ℝ) ≤ x := by
      exact le_trans (by exact_mod_cast hpf) (Nat.floor_le hx_nonneg)
    exact Real.log_le_log hppos hpx
  have hcard_eq : ((Finset.Icc (1 : ℕ) ⌊x⌋₊).card : ℝ) = (⌊x⌋₊ : ℝ) := by
    have hcard_nat : (Finset.Icc (1 : ℕ) ⌊x⌋₊).card = ⌊x⌋₊ := by
      cases ⌊x⌋₊ <;> simp
    exact_mod_cast hcard_nat
  calc
    thetaFullBound x ≤ ∑ p ∈ Finset.Icc (1 : ℕ) ⌊x⌋₊, Real.log x := hterm
    _ = ((Finset.Icc (1 : ℕ) ⌊x⌋₊).card : ℝ) * Real.log x := by
          rw [Finset.sum_const, nsmul_eq_mul]
    _ = (⌊x⌋₊ : ℝ) * Real.log x := by rw [hcard_eq]
    _ ≤ x * Real.log x :=
          mul_le_mul_of_nonneg_right (Nat.floor_le hx_nonneg) hlog_nonneg

/-- Each single-modulus BV error has a trivial all-integer logarithmic envelope.
This uses no cancellation and no prime distribution estimate. -/
theorem bvError_le_mul_log_plus_self (x : ℝ) (q : ℕ) (hx : 1 ≤ x) :
    bvError x q ≤ x * Real.log x + x := by
  have htheta_nonneg : 0 ≤ thetaFullBound x := thetaFullBound_nonneg x
  have hx_nonneg : 0 ≤ x := le_trans zero_le_one hx
  have hbound_nonneg : 0 ≤ thetaFullBound x + x := add_nonneg htheta_nonneg hx_nonneg
  calc
    bvError x q ≤ max 0 (thetaFullBound x + x) := bvError_le_bound x q
    _ = thetaFullBound x + x := max_eq_right hbound_nonneg
    _ ≤ x * Real.log x + x := add_le_add_right (thetaFullBound_le_mul_log x hx) x

/-- Foundation-only aggregate BV fallback: summing the single-modulus trivial
envelope over `q ≤ x^(1/2-ε)`.  This is a finite carrier bound only and contains
none of the Bombieri--Vinogradov cancellation. -/
theorem bvSum_le_rpow_mul_log_plus_self (x ε : ℝ)
    (hx : 1 ≤ x) :
    bvSum x ε ≤ (x ^ ((1 : ℝ) / 2 - ε)) * (x * Real.log x + x) := by
  classical
  let δ : ℝ := (1 : ℝ) / 2 - ε
  have hx_nonneg : 0 ≤ x := le_trans zero_le_one hx
  have hcut_nonneg : 0 ≤ x ^ δ := Real.rpow_nonneg hx_nonneg δ
  have hB_nonneg : 0 ≤ x * Real.log x + x := by
    exact add_nonneg (mul_nonneg hx_nonneg (Real.log_nonneg hx)) hx_nonneg
  have hterm :
      bvSum x ε ≤ ∑ q ∈ Finset.Icc (1 : ℕ) ⌊x ^ δ⌋₊, (x * Real.log x + x) := by
    unfold bvSum
    dsimp [δ]
    apply Finset.sum_le_sum
    intro q _hq
    exact bvError_le_mul_log_plus_self x q hx
  have hcard_eq : ((Finset.Icc (1 : ℕ) ⌊x ^ δ⌋₊).card : ℝ) = (⌊x ^ δ⌋₊ : ℝ) := by
    have hcard_nat : (Finset.Icc (1 : ℕ) ⌊x ^ δ⌋₊).card = ⌊x ^ δ⌋₊ := by
      cases ⌊x ^ δ⌋₊ <;> simp
    exact_mod_cast hcard_nat
  calc
    bvSum x ε ≤ ∑ q ∈ Finset.Icc (1 : ℕ) ⌊x ^ δ⌋₊, (x * Real.log x + x) := hterm
    _ = ((Finset.Icc (1 : ℕ) ⌊x ^ δ⌋₊).card : ℝ) * (x * Real.log x + x) := by
          rw [Finset.sum_const, nsmul_eq_mul]
    _ = (⌊x ^ δ⌋₊ : ℝ) * (x * Real.log x + x) := by rw [hcard_eq]
    _ ≤ (x ^ δ) * (x * Real.log x + x) :=
          mul_le_mul_of_nonneg_right (Nat.floor_le hcut_nonneg) hB_nonneg
    _ = (x ^ ((1 : ℝ) / 2 - ε)) * (x * Real.log x + x) := by rfl

/-- Absolute-value form of the foundation-only aggregate BV fallback. -/
theorem abs_bvSum_le_rpow_mul_log_plus_self (x ε : ℝ)
    (hx : 1 ≤ x) :
    |bvSum x ε| ≤ (x ^ ((1 : ℝ) / 2 - ε)) * (x * Real.log x + x) := by
  rw [abs_of_nonneg (bvSum_nonneg x ε)]
  exact bvSum_le_rpow_mul_log_plus_self x ε hx

/-!
The maximal Bombieri-Vinogradov estimate remains external background for the
manuscript, but its unused local axiom interface is not exported.  The checked
same-carrier result above is only the elementary noncancelling fallback.
-/

/-- **Brun–Titchmarsh reciprocal bound** (`lem:BT-recip`, tex 1139–1158).

The reciprocal prime sum
`btRecip P X m a = ∑_{X^β<p≤X^{1−σ}, p≡a (m)} 1/p`. -/
noncomputable def btRecip (P : EscAnalytic.Params) (X : ℝ) (m a : ℕ) : ℝ := by
  classical
  exact
    ∑ p ∈ (natWindow (X ^ P.β) (X ^ (1 - P.σ))).filter
        (fun p : ℕ => Nat.Prime p ∧ congMod p a m),
      (1 : ℝ) / (p : ℝ)

/-- The Brun--Titchmarsh reciprocal carrier is nonnegative. -/
theorem btRecip_nonneg (P : EscAnalytic.Params) (X : ℝ) (m a : ℕ) :
    0 ≤ btRecip P X m a := by
  classical
  unfold btRecip
  apply Finset.sum_nonneg
  intro p _hp
  exact div_nonneg zero_le_one (Nat.cast_nonneg p)

/-- Paper-facing Brun--Titchmarsh reciprocal consequence (`lem:BT-recip`, tex
1164--1183): uniformly for moduli `m ≤ X^ν` with `ν < β`, every reduced class has
reciprocal prime mass `≪ 1/φ(m)` in the paper's prime window.  This is the
standard Brun--Titchmarsh theorem plus dyadic partial summation in the form the
manuscript consumes. -/
def BrunTitchmarshReciprocalBound : Prop :=
  ∀ P : EscAnalytic.Params, ∀ ν : ℝ, 0 < ν → ν < P.β →
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ m a : ℕ, 1 ≤ m → (m : ℝ) ≤ X ^ ν → Nat.Coprime a m →
        btRecip P X m a ≤ C / (Nat.totient m : ℝ)

/-- Standard Brun--Titchmarsh reciprocal input used by the paper's weighted-BV
argument. -/
axiom standard_brun_titchmarsh_reciprocal_bound :
  BrunTitchmarshReciprocalBound

/-- Public wrapper for the cited Brun--Titchmarsh reciprocal input. -/
theorem brun_titchmarsh_reciprocal_bound :
    BrunTitchmarshReciprocalBound :=
  standard_brun_titchmarsh_reciprocal_bound

/-- The unrestricted reciprocal prime sum over the Brun--Titchmarsh window. -/
noncomputable def primeRecipWindow (P : EscAnalytic.Params) (X : ℝ) : ℝ := by
  classical
  exact
    ∑ p ∈ (natWindow (X ^ P.β) (X ^ (1 - P.σ))).filter (fun p : ℕ => Nat.Prime p),
      (1 : ℝ) / (p : ℝ)

/-- The unrestricted reciprocal prime-window carrier is nonnegative. -/
theorem primeRecipWindow_nonneg (P : EscAnalytic.Params) (X : ℝ) :
    0 ≤ primeRecipWindow P X := by
  classical
  unfold primeRecipWindow
  apply Finset.sum_nonneg
  intro p _hp
  exact div_nonneg zero_le_one (Nat.cast_nonneg p)

/-- The unrestricted prime-window carrier is bounded by the harmonic sum up to
the same upper cutoff. -/
theorem primeRecipWindow_le_harmonic_floor (P : EscAnalytic.Params) (X : ℝ) :
    primeRecipWindow P X ≤ (harmonic ⌊X ^ (1 - P.σ)⌋₊ : ℝ) := by
  classical
  unfold primeRecipWindow
  rw [harmonic_eq_sum_Icc]
  simp only [Rat.cast_sum, Rat.cast_inv, Rat.cast_natCast]
  simp_rw [one_div]
  apply Finset.sum_le_sum_of_subset_of_nonneg
  · intro p hp
    exact (Finset.mem_filter.mp (Finset.mem_filter.mp hp).1).1
  · intro p _hpBig _hpSmall
    exact inv_nonneg.mpr (Nat.cast_nonneg p)

/-- Elementary logarithmic upper fallback for the unrestricted prime-window
carrier.  This deliberately forgets primality distribution and residue-class
information; it is not the Brun--Titchmarsh or reciprocal-BV saving. -/
theorem primeRecipWindow_upper_unconditional (P : EscAnalytic.Params) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      primeRecipWindow P X ≤ C * Real.log X := by
  let κ : ℝ := 1 - P.σ
  have hκ : 0 < κ := by
    dsimp [κ]
    linarith [P.β_pos, P.β_lt_one_sub_σ]
  refine ⟨2 * κ, Real.exp (2 / κ), mul_pos (by norm_num) hκ, ?_⟩
  intro X hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos _) hX
  have hlogX_ge : 2 / κ ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hX
  have hlogU_eq : Real.log (X ^ κ) = κ * Real.log X := by
    rw [Real.log_rpow hXpos]
  have hlogU_ge_two : 2 ≤ Real.log (X ^ κ) := by
    rw [hlogU_eq]
    calc
      (2 : ℝ) = κ * (2 / κ) := by field_simp [ne_of_gt hκ]
      _ ≤ κ * Real.log X := mul_le_mul_of_nonneg_left hlogX_ge hκ.le
  have hUpos : 0 < X ^ κ := Real.rpow_pos_of_pos hXpos κ
  have hU_ge_one : 1 ≤ X ^ κ := by
    apply (Real.log_le_log_iff (by norm_num : (0 : ℝ) < 1) hUpos).mp
    simpa using le_trans (by norm_num : (0 : ℝ) ≤ 2) hlogU_ge_two
  have hharm : (harmonic ⌊X ^ κ⌋₊ : ℝ) ≤ 1 + Real.log (X ^ κ) :=
    harmonic_floor_le_one_add_log (X ^ κ) hU_ge_one
  have htail : 1 + Real.log (X ^ κ) ≤ 2 * Real.log (X ^ κ) := by
    linarith
  calc
    primeRecipWindow P X
        ≤ (harmonic ⌊X ^ (1 - P.σ)⌋₊ : ℝ) :=
          primeRecipWindow_le_harmonic_floor P X
    _ = (harmonic ⌊X ^ κ⌋₊ : ℝ) := by rfl
    _ ≤ 1 + Real.log (X ^ κ) := hharm
    _ ≤ 2 * Real.log (X ^ κ) := htail
    _ = (2 * κ) * Real.log X := by
          rw [hlogU_eq]
          ring

/-- Absolute-value form of the elementary prime-window fallback. -/
theorem abs_primeRecipWindow_upper_unconditional (P : EscAnalytic.Params) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      |primeRecipWindow P X| ≤ C * Real.log X := by
  rcases primeRecipWindow_upper_unconditional P with ⟨C, X₀, hC, hbound⟩
  refine ⟨C, X₀, hC, ?_⟩
  intro X hX
  rw [abs_of_nonneg (primeRecipWindow_nonneg P X)]
  exact hbound X hX

/-- Every reciprocal prime sum in a residue class is bounded by the unrestricted
prime-window carrier. -/
theorem btRecip_le_primeRecipWindow (P : EscAnalytic.Params) (X : ℝ) (m a : ℕ) :
    btRecip P X m a ≤ primeRecipWindow P X := by
  classical
  unfold btRecip primeRecipWindow
  apply Finset.sum_le_sum_of_subset_of_nonneg
  · intro p hp
    have hpWindow : p ∈ natWindow (X ^ P.β) (X ^ (1 - P.σ)) :=
      (Finset.mem_filter.mp hp).1
    have hpPrime : Nat.Prime p := (Finset.mem_filter.mp hp).2.1
    exact Finset.mem_filter.mpr ⟨hpWindow, hpPrime⟩
  · intro p _hpBig _hpSmall
    exact div_nonneg zero_le_one (Nat.cast_nonneg p)

/-- `btRecip` depends only on the residue class of `a` modulo `m`. -/
theorem btRecip_eq_of_mod_eq {P : EscAnalytic.Params} {X : ℝ} {m a b : ℕ}
    (hab : a % m = b % m) : btRecip P X m a = btRecip P X m b := by
  classical
  unfold btRecip congMod
  rw [hab]

/-- Congruence modulo `1` is vacuous for the prime-window carrier. -/
theorem btRecip_mod_one_eq_primeRecipWindow (P : EscAnalytic.Params) (X : ℝ) (a : ℕ) :
    btRecip P X 1 a = primeRecipWindow P X := by
  classical
  unfold btRecip primeRecipWindow congMod
  simp [Nat.mod_one]

/-- Mertens/PNT lower bound for the manuscript's fixed reciprocal-prime
window.  Its limiting value is `log ((1-sigma)/beta) > 0`; downstream only the
eventual positive lower bound is needed. -/
def PrimeRecipWindowMertensLowerBound : Prop :=
  ∀ P : EscAnalytic.Params,
    ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      c ≤ btRecip P X 1 0

/-- Cited Mertens theorem (equivalently PNT with partial summation) on the
fixed prime window used in `prop:mu`. -/
axiom standard_prime_recip_window_mertens_lower_bound :
  PrimeRecipWindowMertensLowerBound

/-- Public wrapper for the cited fixed-window Mertens lower bound. -/
theorem prime_recip_window_mertens_lower_bound :
    PrimeRecipWindowMertensLowerBound :=
  standard_prime_recip_window_mertens_lower_bound

/-!
The Brun-Titchmarsh reciprocal estimate remains external background for the
manuscript, but its unused local axiom interface is not exported.  The checked
same-carrier result above is only the elementary harmonic fallback.
-/

/-- **Reciprocal Bombieri–Vinogradov with divisor weights** (`lem:weightedBV`,
tex 1160–1255).

The weighted-error sum
`weightedBVSum P X C ν = ∑_{m ≤ X^ν} τ(m)^C max_{(a,m)=1}
  |∑_{X^β<p≤X^{1−σ}, p≡a (m)} 1/p − (1/φ(m)) ∑_{X^β<p≤X^{1−σ}} 1/p|`. -/
noncomputable def reducedClassPrimeErrorMax (P : EscAnalytic.Params) (X : ℝ) (m : ℕ) : ℝ := by
  classical
  -- The `0` seed is harmless for the manuscript range `m ≥ 1`: the reduced
  -- class set is nonempty there, and every absolute-error term is nonnegative.
  -- The reference term `btRecip P X 1 0` is the unrestricted prime sum, since
  -- congruence modulo `1` is vacuous.
  exact
    ((Finset.Icc (1 : ℕ) m).filter (fun a => Nat.Coprime a m)).fold max 0
      (fun a : ℕ =>
        |btRecip P X m a - (1 / (Nat.totient m : ℝ)) * btRecip P X 1 0|)

/-- The reduced-class reciprocal-prime error maximum is nonnegative. -/
theorem reducedClassPrimeErrorMax_nonneg (P : EscAnalytic.Params) (X : ℝ) (m : ℕ) :
    0 ≤ reducedClassPrimeErrorMax P X m := by
  classical
  unfold reducedClassPrimeErrorMax
  rw [Finset.le_fold_max]
  exact Or.inl le_rfl

/-- Every reduced class represented in `1 ≤ a ≤ m` is bounded by the finite
maximum carrier used in `weightedBVSum`. -/
theorem reducedClassPrimeError_le_max {P : EscAnalytic.Params} {X : ℝ} {m a : ℕ}
    (ha : a ∈ (Finset.Icc (1 : ℕ) m).filter (fun a => Nat.Coprime a m)) :
    |btRecip P X m a - (1 / (Nat.totient m : ℝ)) * btRecip P X 1 0|
      ≤ reducedClassPrimeErrorMax P X m := by
  classical
  unfold reducedClassPrimeErrorMax
  rw [Finset.le_fold_max]
  exact Or.inr ⟨a, ha, le_rfl⟩

/-- Canonical representative in `1 ≤ r ≤ m` for a reduced residue class modulo
`m`.  For `m = 1` the only represented class is `1`; otherwise use `a % m`. -/
def reducedClassRepresentative (m a : ℕ) : ℕ :=
  if m = 1 then 1 else a % m

/-- The canonical representative has the same residue modulo `m` as `a`. -/
theorem reducedClassRepresentative_mod_eq (m a : ℕ) :
    (reducedClassRepresentative m a) % m = a % m := by
  by_cases hm1 : m = 1
  · subst hm1
    rw [reducedClassRepresentative, if_pos rfl, Nat.mod_one, Nat.mod_one]
  · by_cases hm0 : m = 0
    · subst hm0
      simp [reducedClassRepresentative, hm1]
    · have hmpos : 0 < m := Nat.pos_of_ne_zero hm0
      simp [reducedClassRepresentative, hm1, Nat.mod_eq_of_lt (Nat.mod_lt a hmpos)]

/-- A coprime residue class has a canonical representative in `1..m`. -/
theorem reducedClassRepresentative_mem {m a : ℕ} (hm : 0 < m) (ha : Nat.Coprime a m) :
    reducedClassRepresentative m a ∈
      (Finset.Icc (1 : ℕ) m).filter (fun r => Nat.Coprime r m) := by
  classical
  by_cases hm1 : m = 1
  · subst hm1
    simp [reducedClassRepresentative]
  · have hmod_lt : a % m < m := Nat.mod_lt a hm
    have hmod_pos : 0 < a % m := by
      by_contra hnot
      have hzero : a % m = 0 := Nat.eq_zero_of_not_pos hnot
      have hdiv : m ∣ a := Nat.dvd_of_mod_eq_zero hzero
      have hgcd_right : a.gcd m = m := Nat.gcd_eq_right hdiv
      have hgcd_one : a.gcd m = 1 := ha.gcd_eq_one
      have hm_eq_one : m = 1 := by
        rw [← hgcd_right, hgcd_one]
      exact hm1 hm_eq_one
    have hcop : Nat.Coprime (a % m) m := by
      rw [Nat.coprime_iff_gcd_eq_one]
      calc
        (a % m).gcd m = m.gcd a := by rw [← Nat.gcd_rec m a]
        _ = a.gcd m := Nat.gcd_comm m a
        _ = 1 := ha.gcd_eq_one
    have hIcc : a % m ∈ Finset.Icc (1 : ℕ) m :=
      Finset.mem_Icc.mpr ⟨Nat.succ_le_of_lt hmod_pos, hmod_lt.le⟩
    have hfilter : a % m ∈
        (Finset.Icc (1 : ℕ) m).filter (fun r => Nat.Coprime r m) :=
      Finset.mem_filter.mpr ⟨hIcc, hcop⟩
    simpa [reducedClassRepresentative, hm1] using hfilter

/-- Arbitrary reduced-class reciprocal-prime errors are bounded by the finite max
after passing to the canonical representative in `1..m`. -/
theorem reducedClassPrimeError_le_max_of_coprime
    {P : EscAnalytic.Params} {X : ℝ} {m a : ℕ}
    (hm : 0 < m) (ha : Nat.Coprime a m) :
    |btRecip P X m a - (1 / (Nat.totient m : ℝ)) * btRecip P X 1 0|
      ≤ reducedClassPrimeErrorMax P X m := by
  let r := reducedClassRepresentative m a
  have hr_mem : r ∈ (Finset.Icc (1 : ℕ) m).filter (fun r => Nat.Coprime r m) :=
    reducedClassRepresentative_mem hm ha
  have hmod : a % m = r % m := by
    exact (reducedClassRepresentative_mod_eq m a).symm
  have hbt : btRecip P X m a = btRecip P X m r := btRecip_eq_of_mod_eq hmod
  rw [hbt]
  exact reducedClassPrimeError_le_max hr_mem

/-- For modulus `1`, the reduced-class reciprocal-prime error maximum is exactly
zero: the reduced-class sum and the unrestricted window sum are the same. -/
theorem reducedClassPrimeErrorMax_one (P : EscAnalytic.Params) (X : ℝ) :
    reducedClassPrimeErrorMax P X 1 = 0 := by
  classical
  unfold reducedClassPrimeErrorMax
  simp [btRecip_mod_one_eq_primeRecipWindow, Nat.totient_one]

/-- Each reduced-class reciprocal-prime error is bounded by twice the
unrestricted prime-window carrier. -/
theorem reducedClassPrimeError_le_two_primeRecipWindow
    (P : EscAnalytic.Params) (X : ℝ) {m a : ℕ} (hm : 0 < m) :
    |btRecip P X m a - (1 / (Nat.totient m : ℝ)) * btRecip P X 1 0|
      ≤ 2 * primeRecipWindow P X := by
  let W := primeRecipWindow P X
  let c : ℝ := 1 / (Nat.totient m : ℝ)
  have hW_nonneg : 0 ≤ W := primeRecipWindow_nonneg P X
  have hbt_nonneg : 0 ≤ btRecip P X m a := btRecip_nonneg P X m a
  have hbt_le : btRecip P X m a ≤ W := btRecip_le_primeRecipWindow P X m a
  have htot_pos_nat : 0 < Nat.totient m := Nat.totient_pos.mpr hm
  have htot_pos : 0 < (Nat.totient m : ℝ) := by exact_mod_cast htot_pos_nat
  have htot_one : (1 : ℝ) ≤ (Nat.totient m : ℝ) := by exact_mod_cast htot_pos_nat
  have hc_nonneg : 0 ≤ c := div_nonneg zero_le_one htot_pos.le
  have hc_le_one : c ≤ 1 := by
    have h := one_div_le_one_div_of_le zero_lt_one htot_one
    simpa [c] using h
  have hcW_nonneg : 0 ≤ c * W := mul_nonneg hc_nonneg hW_nonneg
  have hcW_le : c * W ≤ W := by
    simpa [one_mul] using mul_le_mul_of_nonneg_right hc_le_one hW_nonneg
  calc
    |btRecip P X m a - (1 / (Nat.totient m : ℝ)) * btRecip P X 1 0|
        = |btRecip P X m a - c * W| := by
          simp [c, W, btRecip_mod_one_eq_primeRecipWindow]
    _ ≤ |btRecip P X m a| + |c * W| := by
          simpa [sub_eq_add_neg, abs_neg]
            using abs_add (btRecip P X m a) (-(c * W))
    _ = btRecip P X m a + c * W := by
          rw [abs_of_nonneg hbt_nonneg, abs_of_nonneg hcW_nonneg]
    _ ≤ W + W := add_le_add hbt_le hcW_le
    _ = 2 * W := by ring

/-- The reduced-class reciprocal-prime finite maximum is bounded by twice the
unrestricted prime-window carrier. -/
theorem reducedClassPrimeErrorMax_le_two_primeRecipWindow
    (P : EscAnalytic.Params) (X : ℝ) {m : ℕ} (hm : 0 < m) :
    reducedClassPrimeErrorMax P X m ≤ 2 * primeRecipWindow P X := by
  classical
  unfold reducedClassPrimeErrorMax
  rw [Finset.fold_max_le]
  constructor
  · exact mul_nonneg (by norm_num) (primeRecipWindow_nonneg P X)
  · intro a _ha
    exact reducedClassPrimeError_le_two_primeRecipWindow P X hm

/-- Brun--Titchmarsh pointwise form for the reduced-class reciprocal-prime error
maximum.  This formalizes the pointwise `G_m ≪ 1/φ(m)` step used in the
high-divisor part of `lem:weightedBV`. -/
theorem reducedClassPrimeErrorMax_le_brun_titchmarsh_phi
    (P : EscAnalytic.Params) (ν : ℝ) (hν_pos : 0 < ν) (hν_lt : ν < P.β) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      ∀ m : ℕ, 1 ≤ m → (m : ℝ) ≤ X ^ ν →
        reducedClassPrimeErrorMax P X m ≤ C / (Nat.totient m : ℝ) := by
  rcases brun_titchmarsh_reciprocal_bound P ν hν_pos hν_lt with
    ⟨C, Xbt, hC, hbt⟩
  refine ⟨2 * C, max Xbt 1, mul_pos (by norm_num) hC, ?_⟩
  intro X hX m hm hmX
  classical
  have hXbt : Xbt ≤ X := le_trans (le_max_left _ _) hX
  have hXone : (1 : ℝ) ≤ X := le_trans (le_max_right _ _) hX
  have hXν_one : (1 : ℝ) ≤ X ^ ν := by
    have hpow : (1 : ℝ) ^ ν ≤ X ^ ν :=
      Real.rpow_le_rpow (by norm_num) hXone hν_pos.le
    simpa using hpow
  have hmpos : 0 < m := lt_of_lt_of_le Nat.zero_lt_one hm
  have htot_pos_nat : 0 < Nat.totient m := Nat.totient_pos.mpr hmpos
  have htot_pos : 0 < (Nat.totient m : ℝ) := by exact_mod_cast htot_pos_nat
  have htot_nonneg : 0 ≤ (Nat.totient m : ℝ) := htot_pos.le
  have hden_nonzero : (Nat.totient m : ℝ) ≠ 0 := ne_of_gt htot_pos
  have htarget_nonneg : 0 ≤ 2 * C / (Nat.totient m : ℝ) :=
    div_nonneg (mul_nonneg (by norm_num) hC.le) htot_nonneg
  unfold reducedClassPrimeErrorMax
  rw [Finset.fold_max_le]
  constructor
  · exact htarget_nonneg
  · intro a ha
    have hacoprime : Nat.Coprime a m := (Finset.mem_filter.mp ha).2
    have hbt_a :
        btRecip P X m a ≤ C / (Nat.totient m : ℝ) :=
      hbt X hXbt m a hm hmX hacoprime
    have hbt_one :
        btRecip P X 1 0 ≤ C := by
      have hXν_one_nat : ((1 : ℕ) : ℝ) ≤ X ^ ν := by simpa using hXν_one
      have hraw := hbt X hXbt 1 0 (by norm_num) hXν_one_nat (by decide)
      simpa [Nat.totient_one] using hraw
    let c : ℝ := 1 / (Nat.totient m : ℝ)
    have hc_nonneg : 0 ≤ c := div_nonneg zero_le_one htot_nonneg
    have hbt_nonneg : 0 ≤ btRecip P X m a := btRecip_nonneg P X m a
    have hbt_one_nonneg : 0 ≤ btRecip P X 1 0 := btRecip_nonneg P X 1 0
    have hc_bt_one_le : c * btRecip P X 1 0 ≤ C / (Nat.totient m : ℝ) := by
      have hmul := mul_le_mul_of_nonneg_left hbt_one hc_nonneg
      simpa [c, div_eq_mul_inv, mul_assoc, mul_comm, mul_left_comm] using hmul
    calc
      |btRecip P X m a - (1 / (Nat.totient m : ℝ)) * btRecip P X 1 0|
          = |btRecip P X m a - c * btRecip P X 1 0| := by rfl
      _ ≤ |btRecip P X m a| + |c * btRecip P X 1 0| := by
            simpa [sub_eq_add_neg, abs_neg]
              using abs_add (btRecip P X m a) (-(c * btRecip P X 1 0))
      _ = btRecip P X m a + c * btRecip P X 1 0 := by
            rw [abs_of_nonneg hbt_nonneg,
              abs_of_nonneg (mul_nonneg hc_nonneg hbt_one_nonneg)]
      _ ≤ C / (Nat.totient m : ℝ) + C / (Nat.totient m : ℝ) :=
            add_le_add hbt_a hc_bt_one_le
      _ = 2 * C / (Nat.totient m : ℝ) := by
            field_simp [hden_nonzero]
            ring

/-- The divisor-weighted reciprocal-prime BV error sum of `lem:weightedBV`. -/
noncomputable def weightedBVSum (P : EscAnalytic.Params) (X C ν : ℝ) : ℝ :=
  ∑ m ∈ Finset.Icc (1 : ℕ) ⌊X ^ ν⌋₊,
    ((tau m : ℝ) ^ C) * reducedClassPrimeErrorMax P X m

/-- The divisor-weighted reciprocal-prime BV carrier is nonnegative. -/
theorem weightedBVSum_nonneg (P : EscAnalytic.Params) (X C ν : ℝ) :
    0 ≤ weightedBVSum P X C ν := by
  classical
  unfold weightedBVSum
  apply Finset.sum_nonneg
  intro m _hm
  exact mul_nonneg (Real.rpow_nonneg (Nat.cast_nonneg _) C)
    (reducedClassPrimeErrorMax_nonneg P X m)

/-- A finite same-cutoff power envelope for the divisor weights in
`weightedBVSum`, with the class-error max replaced by the unrestricted
reciprocal-prime window. -/
noncomputable def weightedBVPowerEnvelope
    (P : EscAnalytic.Params) (X C ν : ℝ) : ℝ :=
  ∑ m ∈ Finset.Icc (1 : ℕ) ⌊X ^ ν⌋₊,
    (m : ℝ) ^ C * (2 * primeRecipWindow P X)

/-- The weighted-BV power envelope is nonnegative. -/
theorem weightedBVPowerEnvelope_nonneg
    (P : EscAnalytic.Params) (X C ν : ℝ) :
    0 ≤ weightedBVPowerEnvelope P X C ν := by
  classical
  unfold weightedBVPowerEnvelope
  apply Finset.sum_nonneg
  intro m _hm
  exact mul_nonneg (Real.rpow_nonneg (Nat.cast_nonneg _) C)
    (mul_nonneg (by norm_num) (primeRecipWindow_nonneg P X))

/-- For nonnegative exponents, the elementary bound `τ(m) ≤ m` lifts through
real powers. -/
theorem tau_rpow_le_nat_rpow {m : ℕ} {C : ℝ} (hC : 0 ≤ C) :
    (tau m : ℝ) ^ C ≤ (m : ℝ) ^ C := by
  exact Real.rpow_le_rpow (Nat.cast_nonneg _) (by exact_mod_cast tau_le_self m) hC

/-- Pointwise summand domination behind the finite weighted-BV power envelope. -/
theorem weightedBV_summand_le_powerEnvelope
    (P : EscAnalytic.Params) (X C : ℝ) {m : ℕ} (hm : 1 ≤ m) (hC : 0 ≤ C) :
    ((tau m : ℝ) ^ C) * reducedClassPrimeErrorMax P X m
      ≤ (m : ℝ) ^ C * (2 * primeRecipWindow P X) := by
  have hmpos : 0 < m := lt_of_lt_of_le Nat.zero_lt_one hm
  have htauC : (tau m : ℝ) ^ C ≤ (m : ℝ) ^ C :=
    tau_rpow_le_nat_rpow (m := m) (C := C) hC
  have hmax :
      reducedClassPrimeErrorMax P X m ≤ 2 * primeRecipWindow P X :=
    reducedClassPrimeErrorMax_le_two_primeRecipWindow P X hmpos
  have hmax_nonneg : 0 ≤ reducedClassPrimeErrorMax P X m :=
    reducedClassPrimeErrorMax_nonneg P X m
  have hpow_nonneg : 0 ≤ (m : ℝ) ^ C :=
    Real.rpow_nonneg (Nat.cast_nonneg _) C
  exact mul_le_mul htauC hmax hmax_nonneg hpow_nonneg

/-- The finite weighted-BV carrier is bounded by a noncancelling finite power
envelope.  This is a foundation-only carrier-level check, not the BV cancellation
estimate. -/
theorem weightedBVSum_le_powerEnvelope
    (P : EscAnalytic.Params) (X C ν : ℝ) (hC : 0 ≤ C) :
    weightedBVSum P X C ν ≤ weightedBVPowerEnvelope P X C ν := by
  classical
  unfold weightedBVSum weightedBVPowerEnvelope
  apply Finset.sum_le_sum
  intro m hm
  exact weightedBV_summand_le_powerEnvelope P X C (Finset.mem_Icc.mp hm).1 hC

/-- Absolute-value form of the weighted-BV finite power envelope. -/
theorem abs_weightedBVSum_le_powerEnvelope
    (P : EscAnalytic.Params) (X C ν : ℝ) (hC : 0 ≤ C) :
    |weightedBVSum P X C ν| ≤ weightedBVPowerEnvelope P X C ν := by
  rw [abs_of_nonneg (weightedBVSum_nonneg P X C ν)]
  exact weightedBVSum_le_powerEnvelope P X C ν hC

/-- Brun--Titchmarsh controls the natural-number weighted-BV carrier by the
divisor-φ moment.  This is the formal version of the paper's pointwise
`G_m ≪ 1/φ(m)` handoff before the logarithmic divisor-moment estimate is used. -/
theorem weightedBVSum_le_brun_titchmarsh_divisorPhiMoment_nat
    (P : EscAnalytic.Params) (K : ℕ) (ν : ℝ)
    (hν_pos : 0 < ν) (hν_lt : ν < P.β) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      weightedBVSum P X (K : ℝ) ν ≤ C * divisorPhiMoment X K ν := by
  rcases reducedClassPrimeErrorMax_le_brun_titchmarsh_phi P ν hν_pos hν_lt with
    ⟨C, Xred, hC, hred⟩
  refine ⟨C, max Xred 1, hC, ?_⟩
  intro X hX
  classical
  have hXred : Xred ≤ X := le_trans (le_max_left _ _) hX
  have hXone : (1 : ℝ) ≤ X := le_trans (le_max_right _ _) hX
  have hX_nonneg : 0 ≤ X := le_trans zero_le_one hXone
  have hXν_nonneg : 0 ≤ X ^ ν := Real.rpow_nonneg hX_nonneg ν
  have hsum :
      weightedBVSum P X (K : ℝ) ν
        ≤ ∑ m ∈ Finset.Icc (1 : ℕ) ⌊X ^ ν⌋₊,
            C * (((tau m ^ K : ℕ) : ℝ) / (Nat.totient m : ℝ)) := by
    unfold weightedBVSum
    apply Finset.sum_le_sum
    intro m hm
    have hm1 : 1 ≤ m := (Finset.mem_Icc.mp hm).1
    have hm_le_floor : m ≤ ⌊X ^ ν⌋₊ := (Finset.mem_Icc.mp hm).2
    have hmX : (m : ℝ) ≤ X ^ ν :=
      le_trans (by exact_mod_cast hm_le_floor) (Nat.floor_le hXν_nonneg)
    have hred_m :
        reducedClassPrimeErrorMax P X m ≤ C / (Nat.totient m : ℝ) :=
      hred X hXred m hm1 hmX
    have hpow_nonneg : 0 ≤ (tau m : ℝ) ^ (K : ℝ) :=
      Real.rpow_nonneg (Nat.cast_nonneg _) K
    have hpow_eq : (tau m : ℝ) ^ (K : ℝ) = ((tau m ^ K : ℕ) : ℝ) := by
      rw [Real.rpow_natCast]
      norm_num [Nat.cast_pow]
    calc
      ((tau m : ℝ) ^ (K : ℝ)) * reducedClassPrimeErrorMax P X m
          ≤ ((tau m : ℝ) ^ (K : ℝ)) * (C / (Nat.totient m : ℝ)) :=
            mul_le_mul_of_nonneg_left hred_m hpow_nonneg
      _ = C * (((tau m ^ K : ℕ) : ℝ) / (Nat.totient m : ℝ)) := by
            rw [hpow_eq]
            ring
  calc
    weightedBVSum P X (K : ℝ) ν
        ≤ ∑ m ∈ Finset.Icc (1 : ℕ) ⌊X ^ ν⌋₊,
            C * (((tau m ^ K : ℕ) : ℝ) / (Nat.totient m : ℝ)) := hsum
    _ = C * divisorPhiMoment X K ν := by
          unfold divisorPhiMoment
          rw [Finset.mul_sum]

/-- Absolute-value form of the Brun--Titchmarsh-to-divisor-moment weighted-BV
handoff. -/
theorem abs_weightedBVSum_le_brun_titchmarsh_divisorPhiMoment_nat
    (P : EscAnalytic.Params) (K : ℕ) (ν : ℝ)
    (hν_pos : 0 < ν) (hν_lt : ν < P.β) :
    ∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      |weightedBVSum P X (K : ℝ) ν| ≤ C * divisorPhiMoment X K ν := by
  rcases weightedBVSum_le_brun_titchmarsh_divisorPhiMoment_nat
      P K ν hν_pos hν_lt with
    ⟨C, X₀, hC, hbound⟩
  refine ⟨C, X₀, hC, ?_⟩
  intro X hX
  rw [abs_of_nonneg (weightedBVSum_nonneg P X (K : ℝ) ν)]
  exact hbound X hX

/-- Paper-facing reduction for natural divisor weights in `lem:weightedBV`.

Once the reciprocal Brun--Titchmarsh pointwise bound has reduced the weighted
BV carrier to `divisorPhiMoment X K ν`, any checked polylogarithmic
divisor-phi moment at the same natural exponent gives the corresponding
polylogarithmic weighted-BV bound. -/
theorem abs_weightedBVSum_nat_le_brun_titchmarsh_log_of_divisor_phi_moment
    (P : EscAnalytic.Params) (K : ℕ) (ν : ℝ)
    (hν_pos : 0 < ν) (hν_lt : ν < P.β)
    (hdiv :
      ∃ Cd E Xd : ℝ, 0 < Cd ∧ ∀ X : ℝ, Xd ≤ X →
        |divisorPhiMoment X K ν| ≤ Cd * (Real.log X) ^ E) :
    ∃ C E X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      |weightedBVSum P X (K : ℝ) ν| ≤ C * (Real.log X) ^ E := by
  rcases abs_weightedBVSum_le_brun_titchmarsh_divisorPhiMoment_nat
      P K ν hν_pos hν_lt with
    ⟨Cb, Xb, hCb, hb⟩
  rcases hdiv with ⟨Cd, E, Xd, hCd, hd⟩
  refine ⟨Cb * Cd, E, max Xb Xd, mul_pos hCb hCd, ?_⟩
  intro X hX
  have hXb : Xb ≤ X := le_trans (le_max_left _ _) hX
  have hXd : Xd ≤ X := le_trans (le_max_right _ _) hX
  have hbX := hb X hXb
  have hdX := hd X hXd
  have hdiv_nonneg : 0 ≤ divisorPhiMoment X K ν :=
    divisorPhiMoment_nonneg X K ν
  have hdiv_bound : divisorPhiMoment X K ν ≤ Cd * (Real.log X) ^ E := by
    simpa [abs_of_nonneg hdiv_nonneg] using hdX
  calc
    |weightedBVSum P X (K : ℝ) ν|
        ≤ Cb * divisorPhiMoment X K ν := by simpa using hbX
    _ ≤ Cb * (Cd * (Real.log X) ^ E) :=
          mul_le_mul_of_nonneg_left hdiv_bound hCb.le
    _ = Cb * Cd * (Real.log X) ^ E := by ring

/-- Closed checked natural-`K` Brun--Titchmarsh high-divisor handoff in
`lem:weightedBV`: the cited Brun--Titchmarsh reciprocal estimate plus the
fully formalized general divisor-phi moment gives a polylogarithmic upper bound
for every fixed natural divisor-weight exponent. -/
theorem abs_weightedBVSum_nat_le_brun_titchmarsh_log
    (P : EscAnalytic.Params) (K : ℕ) (ν : ℝ) (hν_pos : 0 < ν) (hν_lt : ν < P.β) :
    ∃ C E X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      |weightedBVSum P X (K : ℝ) ν| ≤ C * (Real.log X) ^ E := by
  exact
    abs_weightedBVSum_nat_le_brun_titchmarsh_log_of_divisor_phi_moment
      P K ν hν_pos hν_lt (divisor_phi_moment_general K ν hν_pos)

/-- Closed checked `K = 0` case of the Brun--Titchmarsh high-divisor handoff in
`lem:weightedBV`: the cited Brun--Titchmarsh reciprocal estimate plus the
already-formalized `K = 0` divisor-phi moment gives a polylogarithmic upper
bound for the unweighted reciprocal-prime error carrier. -/
theorem abs_weightedBVSum_zero_le_brun_titchmarsh_log
    (P : EscAnalytic.Params) (ν : ℝ) (hν_pos : 0 < ν) (hν_lt : ν < P.β) :
    ∃ C E X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      |weightedBVSum P X (0 : ℝ) ν| ≤ C * (Real.log X) ^ E := by
  simpa using
    abs_weightedBVSum_nat_le_brun_titchmarsh_log_of_divisor_phi_moment
      P 0 ν hν_pos hν_lt (divisor_phi_moment_zero ν hν_pos)

/-- Closed checked `K = 1` case of the Brun--Titchmarsh high-divisor handoff in
`lem:weightedBV`: the cited Brun--Titchmarsh reciprocal estimate plus the
already-formalized `K = 1` divisor-φ moment gives a polylogarithmic upper bound
for the weighted reciprocal-prime error carrier. -/
theorem abs_weightedBVSum_one_le_brun_titchmarsh_log
    (P : EscAnalytic.Params) (ν : ℝ) (hν_pos : 0 < ν) (hν_lt : ν < P.β) :
    ∃ C E X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      |weightedBVSum P X (1 : ℝ) ν| ≤ C * (Real.log X) ^ E := by
  simpa using
    abs_weightedBVSum_nat_le_brun_titchmarsh_log_of_divisor_phi_moment
      P 1 ν hν_pos hν_lt (divisor_phi_moment_one ν hν_pos)

/-- Finite real-power sums up to the cutoff `⌊X^ν⌋₊` are bounded by the
corresponding power of the cutoff. -/
theorem rpow_sum_Icc_le_rpow_window
    (X C ν : ℝ) (hX : 0 < X) (hC : 0 ≤ C) :
    (∑ m ∈ Finset.Icc (1 : ℕ) ⌊X ^ ν⌋₊, (m : ℝ) ^ C)
      ≤ (X ^ ν) ^ (C + 1) := by
  classical
  have hcut_pos : 0 < X ^ ν := Real.rpow_pos_of_pos hX ν
  have hcut_nonneg : 0 ≤ X ^ ν := hcut_pos.le
  have hterm :
      (∑ m ∈ Finset.Icc (1 : ℕ) ⌊X ^ ν⌋₊, (m : ℝ) ^ C)
        ≤ ∑ m ∈ Finset.Icc (1 : ℕ) ⌊X ^ ν⌋₊, (X ^ ν) ^ C := by
    apply Finset.sum_le_sum
    intro m hm
    have hm_le_floor : m ≤ ⌊X ^ ν⌋₊ := (Finset.mem_Icc.mp hm).2
    have hm_le_cut : (m : ℝ) ≤ X ^ ν := by
      exact le_trans (by exact_mod_cast hm_le_floor) (Nat.floor_le hcut_nonneg)
    exact Real.rpow_le_rpow (Nat.cast_nonneg m) hm_le_cut hC
  have hcard_eq :
      ((Finset.Icc (1 : ℕ) ⌊X ^ ν⌋₊).card : ℝ) = (⌊X ^ ν⌋₊ : ℝ) := by
    have hcard_nat : (Finset.Icc (1 : ℕ) ⌊X ^ ν⌋₊).card = ⌊X ^ ν⌋₊ := by
      cases ⌊X ^ ν⌋₊ <;> simp
    exact_mod_cast hcard_nat
  calc
    (∑ m ∈ Finset.Icc (1 : ℕ) ⌊X ^ ν⌋₊, (m : ℝ) ^ C)
        ≤ ∑ m ∈ Finset.Icc (1 : ℕ) ⌊X ^ ν⌋₊, (X ^ ν) ^ C := hterm
    _ = ((Finset.Icc (1 : ℕ) ⌊X ^ ν⌋₊).card : ℝ) * (X ^ ν) ^ C := by
          simp
    _ = (⌊X ^ ν⌋₊ : ℝ) * (X ^ ν) ^ C := by rw [hcard_eq]
    _ ≤ (X ^ ν) * (X ^ ν) ^ C := by
          exact mul_le_mul_of_nonneg_right (Nat.floor_le hcut_nonneg)
            (Real.rpow_nonneg hcut_nonneg C)
    _ = (X ^ ν) ^ (C + 1) := by
          rw [Real.rpow_add hcut_pos C 1]
          rw [Real.rpow_one]
          ring

/-- Elementary polynomial-times-log fallback for the finite weighted-BV power
envelope.  It combines the finite power-sum bound with
`primeRecipWindow_upper_unconditional`, and deliberately contains no cancellation. -/
theorem weightedBVPowerEnvelope_le_rpow_log_unconditional
    (P : EscAnalytic.Params) (C ν : ℝ) (hC : 0 ≤ C) :
    ∃ K X₀ : ℝ, 0 < K ∧ ∀ X : ℝ, X₀ ≤ X →
      weightedBVPowerEnvelope P X C ν
        ≤ K * (X ^ ν) ^ (C + 1) * Real.log X := by
  rcases primeRecipWindow_upper_unconditional P with ⟨Cp, Xp, hCp, hprime⟩
  refine ⟨2 * Cp, max Xp 1, mul_pos (by norm_num) hCp, ?_⟩
  intro X hX
  have hXp : Xp ≤ X := le_trans (le_max_left _ _) hX
  have hXone : (1 : ℝ) ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le zero_lt_one hXone
  have hcut_nonneg : 0 ≤ (X ^ ν) ^ (C + 1) :=
    Real.rpow_nonneg (Real.rpow_pos_of_pos hXpos ν).le (C + 1)
  have hfactor_nonneg : 0 ≤ 2 * primeRecipWindow P X :=
    mul_nonneg (by norm_num) (primeRecipWindow_nonneg P X)
  have hsum :
      (∑ m ∈ Finset.Icc (1 : ℕ) ⌊X ^ ν⌋₊, (m : ℝ) ^ C)
        ≤ (X ^ ν) ^ (C + 1) :=
    rpow_sum_Icc_le_rpow_window X C ν hXpos hC
  have hprimeX : primeRecipWindow P X ≤ Cp * Real.log X := hprime X hXp
  have htwo : 2 * primeRecipWindow P X ≤ 2 * (Cp * Real.log X) := by
    exact mul_le_mul_of_nonneg_left hprimeX (by norm_num)
  calc
    weightedBVPowerEnvelope P X C ν
        = (∑ m ∈ Finset.Icc (1 : ℕ) ⌊X ^ ν⌋₊, (m : ℝ) ^ C) *
            (2 * primeRecipWindow P X) := by
              classical
              unfold weightedBVPowerEnvelope
              rw [Finset.sum_mul]
    _ ≤ (X ^ ν) ^ (C + 1) * (2 * primeRecipWindow P X) :=
          mul_le_mul_of_nonneg_right hsum hfactor_nonneg
    _ ≤ (X ^ ν) ^ (C + 1) * (2 * (Cp * Real.log X)) :=
          mul_le_mul_of_nonneg_left htwo hcut_nonneg
    _ = (2 * Cp) * (X ^ ν) ^ (C + 1) * Real.log X := by ring

/-- Absolute-value form of the elementary polynomial-times-log weighted-BV
fallback.  This is far weaker than the reciprocal Bombieri-Vinogradov estimate. -/
theorem abs_weightedBVSum_le_rpow_log_unconditional
    (P : EscAnalytic.Params) (C ν : ℝ) (hC : 0 ≤ C) :
    ∃ K X₀ : ℝ, 0 < K ∧ ∀ X : ℝ, X₀ ≤ X →
      |weightedBVSum P X C ν| ≤ K * (X ^ ν) ^ (C + 1) * Real.log X := by
  rcases weightedBVPowerEnvelope_le_rpow_log_unconditional P C ν hC with
    ⟨K, X₀, hK, hbound⟩
  refine ⟨K, X₀, hK, ?_⟩
  intro X hX
  exact le_trans (abs_weightedBVSum_le_powerEnvelope P X C ν hC) (hbound X hX)

/-- Same-carrier reciprocal Elliott--Halberstam statement for the manuscript's
divisor-weighted reciprocal-prime BV sum.  This is the exact analytic strength
needed to discharge the paper's `hyp:reciprocal-EH`: arbitrary fixed
nonnegative real divisor weight, every level `ν < 1`, and arbitrary logarithmic
saving. -/
def ReciprocalElliottHalberstamWeightedBVSameCarrier : Prop :=
  ∀ P : EscAnalytic.Params, ∀ ν A Cw : ℝ,
    ν < 1 → 0 < A → 0 ≤ Cw →
      ∃ K X₀ : ℝ, 0 < K ∧ ∀ X : ℝ, X₀ ≤ X →
        |weightedBVSum P X Cw ν| ≤ K * (Real.log X) ^ (-A)

/-- Reciprocal Bombieri--Vinogradov in the divisor-weighted same-carrier form
used by the paper.  The strict `ν < β/2` margin is the standard half-level
range after dyadic partial summation from the maximal Chebyshev-error theorem;
unlike the EH carrier below, this makes no assertion beyond level one half. -/
def ReciprocalBombieriVinogradovWeightedSameCarrier : Prop :=
  ∀ P : EscAnalytic.Params, ∀ ν A Cw : ℝ,
    0 < ν → ν < P.β / 2 → 0 < A → 0 ≤ Cw →
      ∃ K X₀ : ℝ, 0 < K ∧ ∀ X : ℝ, X₀ ≤ X →
        |weightedBVSum P X Cw ν| ≤ K * (Real.log X) ^ (-A)

/-- Standard reciprocal weighted Bombieri--Vinogradov theorem.  This is the
ordinary maximal BV theorem with finite dyadic partial summation and a fixed
divisor-weight loss, stated on the exact finite carrier consumed downstream. -/
axiom standard_reciprocal_bombieri_vinogradov_weighted_same_carrier :
  ReciprocalBombieriVinogradovWeightedSameCarrier

theorem reciprocal_bombieri_vinogradov_weighted_same_carrier :
    ReciprocalBombieriVinogradovWeightedSameCarrier :=
  standard_reciprocal_bombieri_vinogradov_weighted_same_carrier

/-- Standard external input for the paper's reciprocal Elliott--Halberstam
hypothesis, stated on the actual divisor-weighted reciprocal-prime
`weightedBVSum` carrier used downstream.

This is a cited theorem shape, not a consequence of the Brun--Titchmarsh or
Bombieri--Vinogradov carriers formalized above.  Keeping it as a separate named
carrier makes the remaining analytic input explicit. -/
def ReciprocalElliottHalberstamWeightedBVExternalInput : Prop :=
  ReciprocalElliottHalberstamWeightedBVSameCarrier

/-- Forget the standard-external-input wrapper to recover the exact same-carrier
reciprocal-EH proposition. -/
theorem reciprocalEH_sameCarrier_of_weightedBVExternalInput
    (H : ReciprocalElliottHalberstamWeightedBVExternalInput) :
    ReciprocalElliottHalberstamWeightedBVSameCarrier :=
  H

/-- The strongest currently available Lean bridge from the represented
Brun--Titchmarsh reciprocal input to the same `weightedBVSum` carrier.

It gives only a polylogarithmic upper bound, only for natural divisor weights,
and only in the Brun--Titchmarsh range `ν < P.β`.  In particular, this is not
the logarithmic saving for all `ν < 1` required by
`ReciprocalElliottHalberstamWeightedBVSameCarrier`. -/
theorem reciprocalEH_current_standard_inputs_polylog_bridge
    (P : EscAnalytic.Params) (K : ℕ) (ν : ℝ)
    (hν_pos : 0 < ν) (hν_lt : ν < P.β) :
    ∃ C E X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      |weightedBVSum P X (K : ℝ) ν| ≤ C * (Real.log X) ^ E :=
  abs_weightedBVSum_nat_le_brun_titchmarsh_log P K ν hν_pos hν_lt

/-- Fully checked same-carrier fallback for arbitrary nonnegative real divisor
weights.  This uses only elementary domination and is polynomial in the level
cutoff, so it is much weaker than reciprocal EH. -/
theorem reciprocalEH_unconditional_arbitrary_weight_polynomial_fallback
    (P : EscAnalytic.Params) (Cw ν : ℝ) (hCw : 0 ≤ Cw) :
    ∃ K X₀ : ℝ, 0 < K ∧ ∀ X : ℝ, X₀ ≤ X →
      |weightedBVSum P X Cw ν| ≤
        K * (X ^ ν) ^ (Cw + 1) * Real.log X :=
  abs_weightedBVSum_le_rpow_log_unconditional P Cw ν hCw

/-- Exact shape currently derivable from the named Brun--Titchmarsh reciprocal
input plus the checked divisor-φ moment: natural divisor weights, only
`ν < P.β`, and a positive power of `log X` rather than arbitrary log saving. -/
def ReciprocalElliottHalberstamStandardInputsReach : Prop :=
  ∀ P : EscAnalytic.Params, ∀ K : ℕ, ∀ ν : ℝ,
    0 < ν → ν < P.β →
      ∃ C E X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        |weightedBVSum P X (K : ℝ) ν| ≤ C * (Real.log X) ^ E

/-- The represented Brun--Titchmarsh/divisor-moment inputs reach only the
polylogarithmic Brun--Titchmarsh-range consequence, not reciprocal EH. -/
theorem reciprocalEH_standard_inputs_reach :
    ReciprocalElliottHalberstamStandardInputsReach := by
  intro P K ν hν_pos hν_lt
  exact reciprocalEH_current_standard_inputs_polylog_bridge P K ν hν_pos hν_lt

/-- Exact unconditional same-carrier fallback presently proved without any
distribution theorem: arbitrary nonnegative real weights and arbitrary level,
but with polynomial growth in the level cutoff. -/
def ReciprocalElliottHalberstamUnconditionalFallbackReach : Prop :=
  ∀ P : EscAnalytic.Params, ∀ Cw ν : ℝ, 0 ≤ Cw →
    ∃ K X₀ : ℝ, 0 < K ∧ ∀ X : ℝ, X₀ ≤ X →
      |weightedBVSum P X Cw ν| ≤
        K * (X ^ ν) ^ (Cw + 1) * Real.log X

/-- The checked fallback has the same carrier as reciprocal EH, but no
cancellation; it is polynomial in `X^ν`. -/
theorem reciprocalEH_unconditional_fallback_reach :
    ReciprocalElliottHalberstamUnconditionalFallbackReach := by
  intro P Cw ν hCw
  exact reciprocalEH_unconditional_arbitrary_weight_polynomial_fallback P Cw ν hCw

/-- The exact external theorem shape for `hyp:reciprocal-EH`: same carrier as
`weightedBVSum`, arbitrary nonnegative real divisor weight, all levels `ν < 1`,
and arbitrary logarithmic saving. -/
def ReciprocalElliottHalberstamExternalTheoremShape : Prop :=
  ReciprocalElliottHalberstamWeightedBVSameCarrier

/-- The cited external theorem shape is definitionally the same same-carrier
reciprocal-EH proposition exposed above. -/
theorem reciprocalEH_external_theorem_shape_iff_same_carrier :
    ReciprocalElliottHalberstamExternalTheoremShape ↔
      ReciprocalElliottHalberstamWeightedBVSameCarrier :=
  Iff.rfl

/-!
The logarithmically saving weighted-BV estimate remains debt, but its unused
interface is not exported as an axiom.  The preceding polynomial-times-log
fallback is the currently checked same-carrier upper bound.
-/

/-! ## Titchmarsh divisor theorem (pairwise-coprime barrier). -/

/-- The weighted prime-form divisor sum
`titchSum L = ∑_{a ≤ L, 4a−1 prime} τ(a²)/a` of `lem:weighted-titchmarsh`. -/
noncomputable def titchSum (L : ℝ) : ℝ :=
  ∑ a ∈ (Finset.Icc (1 : ℕ) ⌊L⌋₊).filter (fun a => Nat.Prime (4 * a - 1)),
    ((tau (a ^ 2) : ℕ) : ℝ) / (a : ℝ)

/-- The weighted Titchmarsh carrier is nonnegative. -/
theorem titchSum_nonneg (L : ℝ) : 0 ≤ titchSum L := by
  classical
  unfold titchSum
  apply Finset.sum_nonneg
  intro a _ha
  exact div_nonneg (Nat.cast_nonneg _) (Nat.cast_nonneg a)

/-- Paper-facing weighted Titchmarsh divisor bound (`lem:weighted-titchmarsh`,
tex 566--635): the prime-restricted weighted divisor carrier is
`≪ (log L)^2`.  The manuscript cites the standard Titchmarsh divisor theorem for
the primitive linear form `4n-1` and then performs the displayed Euler-product
and partial-summation steps. -/
def WeightedTitchmarshDivisorBound : Prop :=
  ∃ C L₀ : ℝ, 0 < C ∧ ∀ L : ℝ, L₀ ≤ L →
    |titchSum L| ≤ C * (Real.log L) ^ (2 : ℝ)

/-- Standard weighted Titchmarsh divisor input for the pairwise-coprime barrier. -/
axiom standard_weighted_titchmarsh_divisor_bound :
  WeightedTitchmarshDivisorBound

/-- Public wrapper for the cited weighted Titchmarsh divisor input. -/
theorem weighted_titchmarsh_divisor_bound :
    WeightedTitchmarshDivisorBound :=
  standard_weighted_titchmarsh_divisor_bound

/-- Sharp log-square carrier bound obtained directly from the cited weighted
Titchmarsh divisor theorem.  This is the paper-facing replacement for using the
elementary log-fourth fallback in places where `lem:weighted-titchmarsh` is the
intended input. -/
theorem titchSum_upper_log_square_of_weighted_titchmarsh :
    ∃ C L₀ : ℝ, 0 < C ∧ ∀ L : ℝ, L₀ ≤ L →
      |titchSum L| ≤ C * (Real.log L) ^ (2 : ℝ) :=
  weighted_titchmarsh_divisor_bound

/-!
The paper-facing weighted Titchmarsh bound is now exported explicitly as the
cited input above.  Same-carrier elementary polylogarithmic fallbacks are still
proved below as independent sanity checks.
-/

/-! ## Local-obstruction fixed-modulus carriers. -/

/-- The divisor fiber `#{h ∣ a² : h ≡ u (M)}` appearing in the local-obstruction
carrier. -/
noncomputable def localObstrFiber (M u a : ℕ) : ℝ := by
  classical
  exact (((a ^ 2).divisors.filter (fun h => congMod h u M)).card : ℝ)

/-- The local-obstruction divisor sum of tex 535–541 (`Selberg–Delange or
Perron`):
`localObstrCount L M a_M u_c =
  ∑_{a ≤ L, a ≡ a_M (M)} #{h ∣ a² : h ≡ u_c (M)}`. -/
noncomputable def localObstrCount (L : ℝ) (M aM u : ℕ) : ℝ := by
  classical
  exact
    ∑ a ∈ (Finset.Icc (1 : ℕ) ⌊L⌋₊).filter (fun a => congMod a aM M),
      localObstrFiber M u a

/-- The interior local-obstruction fiber from `thm:full-local-obstruction`:
divisors in the requested residue class after removing the three boundary
divisors `1`, `a`, and `a²`. -/
noncomputable def localObstrInteriorFiber (M u a : ℕ) : ℝ := by
  classical
  exact
    (((a ^ 2).divisors.filter
      (fun h => congMod h u M ∧ h ≠ 1 ∧ h ≠ a ∧ h ≠ a ^ 2)).card : ℝ)

/-- The weighted fixed-modulus interior local-obstruction mass from
`thm:full-local-obstruction`. -/
noncomputable def localObstrInteriorMass (L : ℝ) (M aM u : ℕ) : ℝ := by
  classical
  exact
    ∑ a ∈ (Finset.Icc (1 : ℕ) ⌊L⌋₊).filter (fun a => congMod a aM M),
      localObstrInteriorFiber M u a / ((4 : ℝ) * (a : ℝ) - 1)

/-- The arithmetic-factor `𝔖(M) = (1/ζ(2)) ∏_{ℓ∣M} (1−ℓ⁻¹)³/(1−ℓ⁻²)` (tex
530–534). -/
noncomputable def singularSeries (M : ℕ) : ℝ :=
  (1 / zeta2) *
    ∏ ℓ in M.primeFactors,
      ((1 - (ℓ : ℝ)⁻¹) ^ 3 / (1 - ((ℓ : ℝ) ^ 2)⁻¹))

/-! ## Selberg–Delange / Perron Tauberian step for the cubic masses. -/

/-- The cubic divisor sum `tauSqSum L = ∑_{n ≤ L} τ(n²)/n` of
`lem:tau-square-ds`, defined with the natural floor of the real cutoff. -/
noncomputable def tauSqSum (L : ℝ) : ℝ :=
  ∑ n ∈ Finset.Icc (1 : ℕ) ⌊L⌋₊, ((tau (n ^ 2) : ℕ) : ℝ) / (n : ℝ)

/-- The absolutely convergent companion tail
`∑_{n ≤ L} τ(n²)/n²` used to make the `1/(4a-1) = 1/(4a)+O(a⁻²)`
denominator correction in `prop:cubic-fan-mass` explicit. -/
noncomputable def tauSqInvSqSum (L : ℝ) : ℝ :=
  ∑ n ∈ Finset.Icc (1 : ℕ) ⌊L⌋₊,
    ((tau (n ^ 2) : ℕ) : ℝ) / ((n : ℝ) ^ (2 : ℕ))

/-- The cubic divisor carrier is nonnegative. -/
theorem tauSqSum_nonneg (L : ℝ) : 0 ≤ tauSqSum L := by
  classical
  unfold tauSqSum
  apply Finset.sum_nonneg
  intro n _hn
  exact div_nonneg (Nat.cast_nonneg _) (Nat.cast_nonneg n)

/-- Paper-facing Selberg--Delange/Perron cubic divisor-sum estimate
(`lem:tau-square-ds`, tex 439--455): the reciprocal square-divisor carrier has
the asymptotic constant used in the manuscript, together with the two-sided
order bounds consumed by older local bridge theorems. -/
def SelbergDelangeCubicTauSquareBound : Prop :=
  Filter.Tendsto
      (fun L : ℝ => tauSqSum L / (Real.log L) ^ (3 : ℝ))
      Filter.atTop (nhds (1 / (6 * zeta2))) ∧
    (∃ B : ℝ, 0 < B ∧ ∀ L : ℝ, tauSqInvSqSum L ≤ B) ∧
    (∃ c C L₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ L : ℝ, L₀ ≤ L →
      c * (Real.log L) ^ (3 : ℝ) ≤ tauSqSum L ∧
        tauSqSum L ≤ C * (Real.log L) ^ (3 : ℝ)) ∧
    ∀ M aM u : ℕ, Odd M → Nat.Coprime aM M → Nat.Coprime u M →
      Filter.Tendsto
        (fun L : ℝ => localObstrInteriorMass L M aM u /
          (Real.log L) ^ (3 : ℝ))
        Filter.atTop
        (nhds (singularSeries M /
          (24 * ((Nat.totient M : ℕ) : ℝ) ^ (2 : ℕ))))

/-- Selberg--Delange/Perron input shared by `lem:tau-square-ds` and
`thm:full-local-obstruction`.  The paper manifest records both labels because
the proposition bundles the cubic divisor sum and the fixed-modulus local
factor asymptotic. -/
axiom standard_selberg_delange_cubic_tau_square_bound :
  SelbergDelangeCubicTauSquareBound

/-- Public wrapper for the cited Selberg--Delange/Perron cubic divisor-sum input. -/
theorem selberg_delange_cubic_tau_square_bound :
    SelbergDelangeCubicTauSquareBound :=
  standard_selberg_delange_cubic_tau_square_bound

/-- Exact asymptotic-constant consequence of the cited Selberg--Delange/Perron
input for `lem:tau-square-ds`. -/
theorem tauSqSum_asymptotic_of_selberg_delange :
    Filter.Tendsto
      (fun L : ℝ => tauSqSum L / (Real.log L) ^ (3 : ℝ))
      Filter.atTop (nhds (1 / (6 * zeta2))) :=
  selberg_delange_cubic_tau_square_bound.1

/-- Two-sided order-bound consequence of the cited Selberg--Delange/Perron input. -/
theorem tauSqSum_cubic_bounds_of_selberg_delange :
    ∃ c C L₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ L : ℝ, L₀ ≤ L →
      c * (Real.log L) ^ (3 : ℝ) ≤ tauSqSum L ∧
        tauSqSum L ≤ C * (Real.log L) ^ (3 : ℝ) :=
  selberg_delange_cubic_tau_square_bound.2.2.1

/-- Fixed-modulus local-obstruction asymptotic from the cited
Selberg--Delange/Perron input, in the exact weighted interior carrier used by
`thm:full-local-obstruction`. -/
theorem localObstrInteriorMass_asymptotic_of_selberg_delange
    (M aM u : ℕ) (hM : Odd M) (haM : Nat.Coprime aM M)
    (hu : Nat.Coprime u M) :
    Filter.Tendsto
      (fun L : ℝ => localObstrInteriorMass L M aM u /
        (Real.log L) ^ (3 : ℝ))
      Filter.atTop
      (nhds (singularSeries M /
        (24 * ((Nat.totient M : ℕ) : ℝ) ^ (2 : ℕ)))) :=
  selberg_delange_cubic_tau_square_bound.2.2.2 M aM u hM haM hu

/-- Bounded absolutely-convergent companion sum from the cited
Selberg--Delange/Dirichlet-series input. -/
theorem tauSqInvSqSum_bounded_of_selberg_delange :
    ∃ B : ℝ, 0 < B ∧ ∀ L : ℝ, tauSqInvSqSum L ≤ B :=
  selberg_delange_cubic_tau_square_bound.2.1

/-- Upper-bound consequence of the cited Selberg--Delange/Perron cubic input,
with the carrier nonnegativity facts supplied locally. -/
theorem tauSqSum_upper_log_cubic_of_selberg_delange :
    ∃ C L₀ : ℝ, 0 < C ∧ ∀ L : ℝ, L₀ ≤ L →
      |tauSqSum L| ≤ C * (Real.log L) ^ (3 : ℝ) := by
  rcases tauSqSum_cubic_bounds_of_selberg_delange with ⟨_c, C, L₀, _hc, hC, hbound⟩
  refine ⟨C, L₀, hC, ?_⟩
  intro L hL
  rw [abs_of_nonneg (tauSqSum_nonneg L)]
  exact (hbound L hL).2

/-- The tau-weighted divisor-fan mass underlying `prop:cubic-fan-mass`, before
subtracting the finitely many excluded divisors and before splitting the fan
into the lower and upper halves. -/
noncomputable def divisorFanTauMass (L : ℝ) : ℝ :=
  ∑ a ∈ Finset.Icc (1 : ℕ) ⌊L⌋₊,
    ((tau (a ^ 2) : ℕ) : ℝ) / ((4 : ℝ) * (a : ℝ) - 1)

/-- The full interior divisor-fan mass from `prop:cubic-fan-mass`, encoded via
the identity `|Λ_int(a)| = τ(a²)-3` for `a > 1` and the exceptional value
`|Λ_int(1)| = 0`. -/
noncomputable def divisorFanInteriorMass (L : ℝ) : ℝ :=
  ∑ a ∈ Finset.Icc (1 : ℕ) ⌊L⌋₊,
    (if a = 1 then 0
     else ((tau (a ^ 2) : ℕ) : ℝ) - 3) /
      ((4 : ℝ) * (a : ℝ) - 1)

/-- The lower-half divisor-fan mass from `prop:cubic-fan-mass`, encoded by the
divisor-pairing identity `|Λ_<(a)| = (τ(a²)-3)/2` for `a > 1` and the
exceptional value `|Λ_<(1)| = 0`. -/
noncomputable def divisorFanLowerMass (L : ℝ) : ℝ :=
  ∑ a ∈ Finset.Icc (1 : ℕ) ⌊L⌋₊,
    (if a = 1 then 0
     else (((tau (a ^ 2) : ℕ) : ℝ) - 3) / 2) /
      ((4 : ℝ) * (a : ℝ) - 1)

/-- The single-`a` interior divisor-fan weight
`|Λ_int(a)|/(4a-1)`, encoded through the identity
`|Λ_int(a)| = τ(a²)-3` for `a > 1`. -/
noncomputable def interiorFanWeight (a : ℕ) : ℝ :=
  (if a = 1 then 0 else ((tau (a ^ 2) : ℕ) : ℝ) - 3) /
    ((4 : ℝ) * (a : ℝ) - 1)

/-- A finite extracted interior subfan mass, used for
`prop:coprime-barrier`. -/
noncomputable def pairwiseSubfanMass (L : ℝ) (B : Finset ℕ) : ℝ :=
  ∑ a ∈ B.filter (fun a => 1 ≤ a ∧ a ≤ ⌊L⌋₊), interiorFanWeight a

/-- The prime-modulus part of an extracted interior subfan. -/
noncomputable def pairwisePrimeSubfanMass (L : ℝ) (B : Finset ℕ) : ℝ :=
  ∑ a ∈ (B.filter (fun a => 1 ≤ a ∧ a ≤ ⌊L⌋₊)).filter
      (fun a => Nat.Prime (4 * a - 1)),
    interiorFanWeight a

/-- The composite/nonprime-modulus part of an extracted interior subfan. -/
noncomputable def pairwiseCompositeSubfanMass (L : ℝ) (B : Finset ℕ) : ℝ :=
  ∑ a ∈ (B.filter (fun a => 1 ≤ a ∧ a ≤ ⌊L⌋₊)).filter
      (fun a => ¬ Nat.Prime (4 * a - 1)),
    interiorFanWeight a

/-- Pairwise coprimality of the extracted fan moduli `4a-1`. -/
def pairwiseFanModuliCoprime (B : Finset ℕ) : Prop :=
  ∀ a ∈ B, ∀ b ∈ B, a ≠ b → Nat.Coprime (4 * a - 1) (4 * b - 1)

/-- The lower-half divisor fan has exactly half the interior mass, after the
`a=1` exceptional value is separated. -/
theorem divisorFanLowerMass_eq_half_interior (L : ℝ) :
    divisorFanLowerMass L = (1 / 2 : ℝ) * divisorFanInteriorMass L := by
  classical
  unfold divisorFanLowerMass divisorFanInteriorMass
  rw [Finset.mul_sum]
  apply Finset.sum_congr rfl
  intro a ha
  by_cases haeq : a = 1
  · simp [haeq]
  · simp [haeq]
    ring

/-- The tau-weighted divisor-fan carrier is nonnegative. -/
theorem divisorFanTauMass_nonneg (L : ℝ) : 0 ≤ divisorFanTauMass L := by
  classical
  unfold divisorFanTauMass
  apply Finset.sum_nonneg
  intro a ha
  have ha1 : 1 ≤ a := (Finset.mem_Icc.mp ha).1
  have ha_ge_one : (1 : ℝ) ≤ (a : ℝ) := by exact_mod_cast ha1
  have ha_pos : 0 < (a : ℝ) := by exact_mod_cast ha1
  have hden_pos : 0 < (4 : ℝ) * (a : ℝ) - 1 := by nlinarith [ha_ge_one]
  exact div_nonneg (Nat.cast_nonneg _) hden_pos.le

/-- Excluding the three trivial divisors `1,a,a²` changes the full tau-weighted
fan mass by only a harmonic-size amount. -/
theorem abs_divisorFanTauMass_sub_divisorFanInteriorMass_le_three_harmonic
    (L : ℝ) :
    |divisorFanTauMass L - divisorFanInteriorMass L|
      ≤ 3 * ((harmonic ⌊L⌋₊ : ℚ) : ℝ) := by
  classical
  unfold divisorFanTauMass divisorFanInteriorMass
  rw [← Finset.sum_sub_distrib]
  let S : Finset ℕ := Finset.Icc (1 : ℕ) ⌊L⌋₊
  let term : ℕ → ℝ := fun a =>
    ((tau (a ^ 2) : ℕ) : ℝ) / ((4 : ℝ) * (a : ℝ) - 1) -
      ((if a = 1 then 0 else ((tau (a ^ 2) : ℕ) : ℝ) - 3) /
        ((4 : ℝ) * (a : ℝ) - 1))
  change |∑ a ∈ S, term a| ≤ 3 * ((harmonic ⌊L⌋₊ : ℚ) : ℝ)
  calc
    |∑ a ∈ S, term a|
        ≤ ∑ a ∈ S, |term a| :=
          Finset.abs_sum_le_sum_abs _ _
    _ ≤ ∑ a ∈ S, (3 : ℝ) / (a : ℝ) := by
          apply Finset.sum_le_sum
          intro a ha
          have ha1 : 1 ≤ a := (Finset.mem_Icc.mp (by simpa [S] using ha)).1
          have ha_ge_one : (1 : ℝ) ≤ (a : ℝ) := by exact_mod_cast ha1
          have ha_pos : 0 < (a : ℝ) := by exact_mod_cast ha1
          have hden_pos : 0 < (4 : ℝ) * (a : ℝ) - 1 := by
            nlinarith [ha_ge_one]
          have hden_ge : (a : ℝ) ≤ (4 : ℝ) * (a : ℝ) - 1 := by
            nlinarith [ha_ge_one]
          by_cases haeq : a = 1
          · subst a
            simp [term, tau]
            rw [abs_of_pos (inv_pos.mpr (by norm_num : (0 : ℝ) < 4 - 1))]
            norm_num
          · have hdiff :
                ((tau (a ^ 2) : ℕ) : ℝ) / ((4 : ℝ) * (a : ℝ) - 1) -
                  (((tau (a ^ 2) : ℕ) : ℝ) - 3) /
                    ((4 : ℝ) * (a : ℝ) - 1)
                    = (3 : ℝ) / ((4 : ℝ) * (a : ℝ) - 1) := by
                  ring
            simp [term, haeq, hdiff]
            rw [abs_of_nonneg (div_nonneg (by norm_num) hden_pos.le)]
            exact div_le_div_of_nonneg_left (by norm_num : (0 : ℝ) ≤ 3)
              ha_pos hden_ge
    _ = 3 * ((harmonic ⌊L⌋₊ : ℚ) : ℝ) := by
          have hharm_eq :
              ((harmonic ⌊L⌋₊ : ℚ) : ℝ) =
                ∑ a ∈ Finset.Icc (1 : ℕ) ⌊L⌋₊, (1 : ℝ) / (a : ℝ) := by
            rw [harmonic_eq_sum_Icc]
            simp only [Rat.cast_sum, Rat.cast_inv, Rat.cast_natCast]
            apply Finset.sum_congr rfl
            intro a ha
            ring
          dsimp [S]
          rw [hharm_eq, Finset.mul_sum]
          apply Finset.sum_congr rfl
          intro a ha
          ring

/-- The fan denominator `4a-1` is comparable with `a`, so the tau-weighted
divisor-fan carrier is bounded above by the Selberg--Delange carrier. -/
theorem divisorFanTauMass_le_tauSqSum (L : ℝ) :
    divisorFanTauMass L ≤ tauSqSum L := by
  classical
  unfold divisorFanTauMass tauSqSum
  apply Finset.sum_le_sum
  intro a ha
  have ha1 : 1 ≤ a := (Finset.mem_Icc.mp ha).1
  have ha_ge_one : (1 : ℝ) ≤ (a : ℝ) := by exact_mod_cast ha1
  have ha_pos : 0 < (a : ℝ) := by exact_mod_cast ha1
  have hden_pos : 0 < (4 : ℝ) * (a : ℝ) - 1 := by nlinarith [ha_ge_one]
  have hden_ge : (a : ℝ) ≤ (4 : ℝ) * (a : ℝ) - 1 := by nlinarith [ha_ge_one]
  have hinv :
      1 / ((4 : ℝ) * (a : ℝ) - 1) ≤ 1 / (a : ℝ) :=
    one_div_le_one_div_of_le ha_pos hden_ge
  have htau_nonneg : 0 ≤ ((tau (a ^ 2) : ℕ) : ℝ) := Nat.cast_nonneg _
  calc
    ((tau (a ^ 2) : ℕ) : ℝ) / ((4 : ℝ) * (a : ℝ) - 1)
        = ((tau (a ^ 2) : ℕ) : ℝ) *
            (1 / ((4 : ℝ) * (a : ℝ) - 1)) := by ring
    _ ≤ ((tau (a ^ 2) : ℕ) : ℝ) * (1 / (a : ℝ)) :=
          mul_le_mul_of_nonneg_left hinv htau_nonneg
    _ = ((tau (a ^ 2) : ℕ) : ℝ) / (a : ℝ) := by ring

/-- The interior fan weight is bounded by the corresponding Titchmarsh
summand `τ(a²)/a`. -/
theorem interiorFanWeight_le_tau_div_self {a : ℕ} (ha1 : 1 ≤ a) :
    interiorFanWeight a ≤ ((tau (a ^ 2) : ℕ) : ℝ) / (a : ℝ) := by
  have ha_ge_one : (1 : ℝ) ≤ (a : ℝ) := by exact_mod_cast ha1
  have ha_pos : 0 < (a : ℝ) := by exact_mod_cast ha1
  have hden_pos : 0 < (4 : ℝ) * (a : ℝ) - 1 := by nlinarith [ha_ge_one]
  have hden_ge : (a : ℝ) ≤ (4 : ℝ) * (a : ℝ) - 1 := by nlinarith [ha_ge_one]
  have htau_nonneg : 0 ≤ ((tau (a ^ 2) : ℕ) : ℝ) := Nat.cast_nonneg _
  have hnum_le :
      (if a = 1 then 0 else ((tau (a ^ 2) : ℕ) : ℝ) - 3)
        ≤ ((tau (a ^ 2) : ℕ) : ℝ) := by
    by_cases haeq : a = 1
    · simp [haeq, htau_nonneg]
    · simp [haeq]
  calc
    interiorFanWeight a
        ≤ ((tau (a ^ 2) : ℕ) : ℝ) /
            ((4 : ℝ) * (a : ℝ) - 1) := by
          unfold interiorFanWeight
          exact div_le_div_of_nonneg_right hnum_le hden_pos.le
    _ ≤ ((tau (a ^ 2) : ℕ) : ℝ) / (a : ℝ) := by
          exact div_le_div_of_nonneg_left htau_nonneg ha_pos hden_ge

/-- The prime-modulus part of any extracted subfan is bounded by the
weighted-Titchmarsh carrier.  This is the checked first half of
`prop:coprime-barrier`; the composite least-prime-factor comparison is tracked
separately. -/
theorem pairwisePrimeSubfanMass_le_titchSum (L : ℝ) (B : Finset ℕ) :
    pairwisePrimeSubfanMass L B ≤ titchSum L := by
  classical
  unfold pairwisePrimeSubfanMass titchSum
  calc
    (∑ a ∈ (B.filter (fun a => 1 ≤ a ∧ a ≤ ⌊L⌋₊)).filter
        (fun a => Nat.Prime (4 * a - 1)), interiorFanWeight a)
        ≤ ∑ a ∈ (B.filter (fun a => 1 ≤ a ∧ a ≤ ⌊L⌋₊)).filter
            (fun a => Nat.Prime (4 * a - 1)),
            ((tau (a ^ 2) : ℕ) : ℝ) / (a : ℝ) := by
          apply Finset.sum_le_sum
          intro a ha
          have ha_base :
              a ∈ B.filter (fun a => 1 ≤ a ∧ a ≤ ⌊L⌋₊) :=
            (Finset.mem_filter.mp ha).1
          exact interiorFanWeight_le_tau_div_self (Finset.mem_filter.mp ha_base).2.1
    _ ≤ ∑ a ∈ (Finset.Icc (1 : ℕ) ⌊L⌋₊).filter
        (fun a => Nat.Prime (4 * a - 1)),
        ((tau (a ^ 2) : ℕ) : ℝ) / (a : ℝ) := by
          apply Finset.sum_le_sum_of_subset_of_nonneg
          · intro a ha
            have haS := Finset.mem_filter.mp ha
            have haB := Finset.mem_filter.mp haS.1
            exact Finset.mem_filter.mpr
              ⟨Finset.mem_Icc.mpr haB.2, haS.2⟩
          · intro a _haT _haS
            exact div_nonneg (Nat.cast_nonneg _) (Nat.cast_nonneg a)
    _ = ∑ a ∈ (Finset.Icc (1 : ℕ) ⌊L⌋₊).filter
          (fun a => Nat.Prime (4 * a - 1)),
        ((tau (a ^ 2) : ℕ) : ℝ) / (a : ℝ) := by
          rfl

/-- Paper-facing prime-part consequence for the pairwise-coprime barrier:
the prime-modulus part of every extracted subfan is `O((log L)^2)`, uniformly
in the extracted finite set. -/
theorem pairwisePrimeSubfanMass_upper_log_square_of_weighted_titchmarsh :
    ∃ C L₀ : ℝ, 0 < C ∧ ∀ L : ℝ, L₀ ≤ L → ∀ B : Finset ℕ,
      pairwisePrimeSubfanMass L B ≤ C * (Real.log L) ^ (2 : ℝ) := by
  rcases titchSum_upper_log_square_of_weighted_titchmarsh with
    ⟨C, L₀, hC, hbound⟩
  refine ⟨C, L₀, hC, ?_⟩
  intro L hL B
  have hprime := pairwisePrimeSubfanMass_le_titchSum L B
  have htitch_nonneg : 0 ≤ titchSum L := titchSum_nonneg L
  have htitch_abs := hbound L hL
  rw [abs_of_nonneg htitch_nonneg] at htitch_abs
  exact le_trans hprime htitch_abs

/-- Least-prime-factor square lower bound for the composite part of
`prop:coprime-barrier`: if `4a-1` is composite, then
`P⁻(4a-1)^2 ≤ 4a-1`. -/
theorem minFac_sq_le_four_mul_sub_one_of_composite {a : ℕ}
    (ha1 : 1 ≤ a) (hcomp : ¬ Nat.Prime (4 * a - 1)) :
    Nat.minFac (4 * a - 1) ^ (2 : ℕ) ≤ 4 * a - 1 := by
  have hpos : 0 < 4 * a - 1 := by omega
  exact Nat.minFac_sq_le_self hpos hcomp

/-- Pointwise divisor-growth bridge for the composite part of
`prop:coprime-barrier`.

This is the formal version of the manuscript step
`τ(a²) ≪ a^η`, `4a-1 ≥ P⁻(4a-1)^2` implies
`|Λ_int(a)|/(4a-1) ≪ P⁻(4a-1)^(-2+2η)`.  The theorem does not assert the
subpower divisor estimate itself; it proves the exact real-power conversion
from that estimate to the least-prime-factor envelope used below. -/
theorem interiorFanWeight_le_minFac_rpow_of_tau_square_subpower
    {K η : ℝ} (hK : 0 ≤ K) (hη_nonneg : 0 ≤ η) (hη_lt_one : η < 1)
    (htau : ∀ a : ℕ, 1 ≤ a →
      ((tau (a ^ 2) : ℕ) : ℝ) ≤ K * (a : ℝ) ^ η)
    {a : ℕ} (ha1 : 1 ≤ a) (hcomp : ¬ Nat.Prime (4 * a - 1)) :
    interiorFanWeight a ≤
      K * ((Nat.minFac (4 * a - 1) : ℝ) ^ (-2 + 2 * η)) := by
  let n : ℕ := 4 * a - 1
  let r : ℕ := Nat.minFac n
  have hn_pos_nat : 0 < n := by
    dsimp [n]
    omega
  have hnR_pos : (0 : ℝ) < (n : ℝ) := by exact_mod_cast hn_pos_nat
  have hnR_nonneg : (0 : ℝ) ≤ (n : ℝ) := hnR_pos.le
  have hden_cast : ((n : ℕ) : ℝ) = (4 : ℝ) * (a : ℝ) - 1 := by
    dsimp [n]
    rw [Nat.cast_sub (by omega : 1 ≤ 4 * a)]
    norm_num
  have hden_pos : 0 < (4 : ℝ) * (a : ℝ) - 1 := by
    rw [← hden_cast]
    exact hnR_pos
  have hnum_le :
      (if a = 1 then 0 else ((tau (a ^ 2) : ℕ) : ℝ) - 3)
        ≤ ((tau (a ^ 2) : ℕ) : ℝ) := by
    by_cases haeq : a = 1
    · simp [haeq]
    · simp [haeq]
  have hweight_tau_n :
      interiorFanWeight a ≤ ((tau (a ^ 2) : ℕ) : ℝ) / (n : ℝ) := by
    unfold interiorFanWeight
    rw [hden_cast]
    exact div_le_div_of_nonneg_right hnum_le hden_pos.le
  have htau_div :
      ((tau (a ^ 2) : ℕ) : ℝ) / (n : ℝ) ≤
        (K * (a : ℝ) ^ η) / (n : ℝ) := by
    exact div_le_div_of_nonneg_right (htau a ha1) hnR_pos.le
  have ha_le_n_nat : a ≤ n := by
    dsimp [n]
    omega
  have ha_le_n : (a : ℝ) ≤ (n : ℝ) := by exact_mod_cast ha_le_n_nat
  have ha_pow_le_n_pow : (a : ℝ) ^ η ≤ (n : ℝ) ^ η :=
    Real.rpow_le_rpow (Nat.cast_nonneg a) ha_le_n hη_nonneg
  have hK_pow : K * (a : ℝ) ^ η ≤ K * (n : ℝ) ^ η :=
    mul_le_mul_of_nonneg_left ha_pow_le_n_pow hK
  have hdiv_n_pow :
      (K * (a : ℝ) ^ η) / (n : ℝ) ≤
        (K * (n : ℝ) ^ η) / (n : ℝ) :=
    div_le_div_of_nonneg_right hK_pow hnR_pos.le
  have hpow_div_eq :
      (K * (n : ℝ) ^ η) / (n : ℝ) = K * (n : ℝ) ^ (η - 1) := by
    have hsub := Real.rpow_sub hnR_pos η 1
    rw [Real.rpow_one] at hsub
    calc
      (K * (n : ℝ) ^ η) / (n : ℝ)
          = K * ((n : ℝ) ^ η / (n : ℝ)) := by ring
      _ = K * (n : ℝ) ^ (η - 1) := by rw [← hsub]
  have hsq_nat : r ^ (2 : ℕ) ≤ n := by
    dsimp [r, n]
    exact Nat.minFac_sq_le_self hn_pos_nat hcomp
  have hr_sq_le_n : ((r : ℝ) ^ (2 : ℕ)) ≤ (n : ℝ) := by
    exact_mod_cast hsq_nat
  have hr_pos : (0 : ℝ) < (r : ℝ) := by
    exact_mod_cast Nat.minFac_pos n
  have hr_nonneg : (0 : ℝ) ≤ (r : ℝ) := hr_pos.le
  have hr_sq_pos : (0 : ℝ) < (r : ℝ) ^ (2 : ℕ) := by positivity
  have hexp_nonpos : η - 1 ≤ 0 := by linarith
  have hn_to_rsq :
      (n : ℝ) ^ (η - 1) ≤ ((r : ℝ) ^ (2 : ℕ)) ^ (η - 1) :=
    Real.rpow_le_rpow_of_exponent_nonpos hr_sq_pos hr_sq_le_n hexp_nonpos
  have hrsq_eq :
      ((r : ℝ) ^ (2 : ℕ)) ^ (η - 1) =
        (r : ℝ) ^ (-2 + 2 * η) := by
    rw [← Real.rpow_natCast (r : ℝ) 2]
    rw [← Real.rpow_mul hr_nonneg]
    congr 1
    ring
  have hmul_final :
      K * (n : ℝ) ^ (η - 1) ≤
        K * ((Nat.minFac (4 * a - 1) : ℝ) ^ (-2 + 2 * η)) := by
    dsimp [r, n] at hn_to_rsq hrsq_eq
    rw [hrsq_eq] at hn_to_rsq
    exact mul_le_mul_of_nonneg_left hn_to_rsq hK
  calc
    interiorFanWeight a ≤ ((tau (a ^ 2) : ℕ) : ℝ) / (n : ℝ) := hweight_tau_n
    _ ≤ (K * (a : ℝ) ^ η) / (n : ℝ) := htau_div
    _ ≤ (K * (n : ℝ) ^ η) / (n : ℝ) := hdiv_n_pow
    _ = K * (n : ℝ) ^ (η - 1) := hpow_div_eq
    _ ≤ K * ((Nat.minFac (4 * a - 1) : ℝ) ^ (-2 + 2 * η)) := hmul_final

/-- Pairwise coprimality of the moduli `4a-1` makes the least prime factors in
the composite part distinct.  This is the formal `r = P⁻(4a-1)` injectivity
step in `prop:coprime-barrier`. -/
theorem pairwiseCompositeMinFac_injective
    {B : Finset ℕ} (hcop : pairwiseFanModuliCoprime B)
    {a b : ℕ} (haB : a ∈ B) (hbB : b ∈ B)
    (ha1 : 1 ≤ a) (_hb1 : 1 ≤ b)
    (_hcompa : ¬ Nat.Prime (4 * a - 1))
    (_hcompb : ¬ Nat.Prime (4 * b - 1))
    (heq : Nat.minFac (4 * a - 1) = Nat.minFac (4 * b - 1)) :
    a = b := by
  by_contra hne
  have hcop_ab : Nat.Coprime (4 * a - 1) (4 * b - 1) :=
    hcop a haB b hbB hne
  have hne_one_a : 4 * a - 1 ≠ 1 := by omega
  have hp : Nat.Prime (Nat.minFac (4 * a - 1)) :=
    Nat.minFac_prime hne_one_a
  have hda : Nat.minFac (4 * a - 1) ∣ 4 * a - 1 :=
    Nat.minFac_dvd _
  have hdb : Nat.minFac (4 * a - 1) ∣ 4 * b - 1 := by
    rw [heq]
    exact Nat.minFac_dvd _
  have hdg : Nat.minFac (4 * a - 1) ∣
      Nat.gcd (4 * a - 1) (4 * b - 1) :=
    Nat.dvd_gcd hda hdb
  rw [hcop_ab.gcd_eq_one] at hdg
  exact hp.not_dvd_one hdg

/-- Finite-set version of `pairwiseCompositeMinFac_injective`, phrased on the
exact composite subfan support. -/
theorem pairwiseCompositeMinFac_injOn_support (L : ℝ) {B : Finset ℕ}
    (hcop : pairwiseFanModuliCoprime B) :
    Set.InjOn (fun a : ℕ => Nat.minFac (4 * a - 1))
      (((B.filter (fun a => 1 ≤ a ∧ a ≤ ⌊L⌋₊)).filter
        (fun a => ¬ Nat.Prime (4 * a - 1))) : Set ℕ) := by
  intro a ha b hb heq
  have ha_comp := Finset.mem_filter.mp ha
  have hb_comp := Finset.mem_filter.mp hb
  have ha_base := Finset.mem_filter.mp ha_comp.1
  have hb_base := Finset.mem_filter.mp hb_comp.1
  exact pairwiseCompositeMinFac_injective hcop ha_base.1 hb_base.1
    ha_base.2.1 hb_base.2.1 ha_comp.2 hb_comp.2 heq

/-- Least-prime-factor p-series envelope for the composite part of
`prop:coprime-barrier`.  The paper uses `η < 1/4`; the formal summability step
only needs `η < 1/2`. -/
noncomputable def pairwiseCompositeLeastFactorEnvelope
    (L : ℝ) (B : Finset ℕ) (η : ℝ) : ℝ :=
  ∑ a ∈ (B.filter (fun a => 1 ≤ a ∧ a ≤ ⌊L⌋₊)).filter
      (fun a => ¬ Nat.Prime (4 * a - 1)),
    ((Nat.minFac (4 * a - 1) : ℝ) ^ (-2 + 2 * η))

/-- If each composite summand is bounded by a constant times the least-prime-
factor envelope, then the composite subfan mass is bounded by that finite
envelope.  This isolates the remaining pointwise divisor-growth comparison in
`prop:coprime-barrier`. -/
theorem pairwiseCompositeSubfanMass_le_leastFactorEnvelope_of_pointwise
    (L : ℝ) (B : Finset ℕ) (K η : ℝ)
    (hpoint : ∀ a : ℕ,
      a ∈ (B.filter (fun a => 1 ≤ a ∧ a ≤ ⌊L⌋₊)).filter
        (fun a => ¬ Nat.Prime (4 * a - 1)) →
      interiorFanWeight a ≤
        K * ((Nat.minFac (4 * a - 1) : ℝ) ^ (-2 + 2 * η))) :
    pairwiseCompositeSubfanMass L B ≤
      K * pairwiseCompositeLeastFactorEnvelope L B η := by
  classical
  unfold pairwiseCompositeSubfanMass pairwiseCompositeLeastFactorEnvelope
  rw [Finset.mul_sum]
  apply Finset.sum_le_sum
  intro a ha
  exact hpoint a ha

/-- The finite least-prime-factor envelope is bounded by the full convergent
p-series once the moduli are pairwise coprime, because the least prime factors
are distinct. -/
theorem pairwiseCompositeLeastFactorEnvelope_le_tsum
    (L : ℝ) {B : Finset ℕ} (hcop : pairwiseFanModuliCoprime B)
    {η : ℝ} (hη : η < 1 / 2) :
    pairwiseCompositeLeastFactorEnvelope L B η ≤
      ∑' r : ℕ, ((r : ℝ) ^ (-2 + 2 * η)) := by
  classical
  let S : Finset ℕ :=
    (B.filter (fun a => 1 ≤ a ∧ a ≤ ⌊L⌋₊)).filter
      (fun a => ¬ Nat.Prime (4 * a - 1))
  change
    (∑ a ∈ S, ((Nat.minFac (4 * a - 1) : ℝ) ^ (-2 + 2 * η))) ≤
      ∑' r : ℕ, ((r : ℝ) ^ (-2 + 2 * η))
  have hinj :
      ∀ x ∈ S, ∀ y ∈ S,
        Nat.minFac (4 * x - 1) = Nat.minFac (4 * y - 1) → x = y := by
    intro x hx y hy hxy
    exact pairwiseCompositeMinFac_injOn_support L hcop
      (by simpa [S] using hx) (by simpa [S] using hy) hxy
  have himage :
      (∑ r ∈ S.image (fun a : ℕ => Nat.minFac (4 * a - 1)),
          ((r : ℝ) ^ (-2 + 2 * η))) =
        ∑ a ∈ S, ((Nat.minFac (4 * a - 1) : ℝ) ^ (-2 + 2 * η)) := by
    exact Finset.sum_image hinj
  rw [← himage]
  have hsumm : Summable (fun r : ℕ => ((r : ℝ) ^ (-2 + 2 * η))) :=
    Real.summable_nat_rpow.mpr (by nlinarith)
  exact sum_le_tsum
    (S.image (fun a : ℕ => Nat.minFac (4 * a - 1)))
    (fun r _hr => Real.rpow_nonneg (Nat.cast_nonneg r) _)
    hsumm

/-- Composite-part consequence of the checked injective least-prime-factor
summation.  The remaining hypothesis is precisely the pointwise divisor-growth
comparison `|Λ_int(a)|/(4a-1) ≪η P⁻(4a-1)^{-2+2η}`. -/
theorem pairwiseCompositeSubfanMass_upper_of_pointwise_minFac
    (L : ℝ) {B : Finset ℕ} (hcop : pairwiseFanModuliCoprime B)
    {K η : ℝ} (hK : 0 ≤ K) (hη : η < 1 / 2)
    (hpoint : ∀ a : ℕ,
      a ∈ (B.filter (fun a => 1 ≤ a ∧ a ≤ ⌊L⌋₊)).filter
        (fun a => ¬ Nat.Prime (4 * a - 1)) →
      interiorFanWeight a ≤
        K * ((Nat.minFac (4 * a - 1) : ℝ) ^ (-2 + 2 * η))) :
    pairwiseCompositeSubfanMass L B ≤
      K * (∑' r : ℕ, ((r : ℝ) ^ (-2 + 2 * η))) := by
  exact le_trans
    (pairwiseCompositeSubfanMass_le_leastFactorEnvelope_of_pointwise L B K η hpoint)
    (mul_le_mul_of_nonneg_left
      (pairwiseCompositeLeastFactorEnvelope_le_tsum L hcop hη) hK)

/-- Prime/composite partition of an extracted pairwise-coprime subfan. -/
theorem pairwiseSubfanMass_eq_prime_add_composite (L : ℝ) (B : Finset ℕ) :
    pairwiseSubfanMass L B =
      pairwisePrimeSubfanMass L B + pairwiseCompositeSubfanMass L B := by
  classical
  unfold pairwiseSubfanMass pairwisePrimeSubfanMass pairwiseCompositeSubfanMass
  let S : Finset ℕ := B.filter (fun a => 1 ≤ a ∧ a ≤ ⌊L⌋₊)
  have hsplit := Finset.sum_filter_add_sum_filter_not S
    (fun a : ℕ => Nat.Prime (4 * a - 1)) interiorFanWeight
  simpa [S, add_comm] using hsplit.symm

/-- Conditional theorem-level form of the full pairwise-coprime barrier:
weighted Titchmarsh handles prime moduli, and the checked least-prime-factor
summation handles composite moduli once the pointwise divisor-growth comparison
is supplied. -/
theorem pairwiseSubfanMass_upper_log_square_of_weighted_titchmarsh_and_pointwise_minFac
    {K η : ℝ} (hK : 0 ≤ K) (hη : η < 1 / 2)
    (hpoint : ∀ L : ℝ, ∀ B : Finset ℕ, pairwiseFanModuliCoprime B →
      ∀ a : ℕ,
        a ∈ (B.filter (fun a => 1 ≤ a ∧ a ≤ ⌊L⌋₊)).filter
          (fun a => ¬ Nat.Prime (4 * a - 1)) →
        interiorFanWeight a ≤
          K * ((Nat.minFac (4 * a - 1) : ℝ) ^ (-2 + 2 * η))) :
    ∃ C L₀ : ℝ, 0 < C ∧ ∀ L : ℝ, L₀ ≤ L → ∀ B : Finset ℕ,
      pairwiseFanModuliCoprime B →
      pairwiseSubfanMass L B ≤ C * (Real.log L) ^ (2 : ℝ) := by
  rcases pairwisePrimeSubfanMass_upper_log_square_of_weighted_titchmarsh with
    ⟨Cprime, Lprime, hCprime, hprime⟩
  let T : ℝ := ∑' r : ℕ, ((r : ℝ) ^ (-2 + 2 * η))
  refine ⟨Cprime + K * T, max Lprime (Real.exp 1), ?_, ?_⟩
  · have hT_nonneg : 0 ≤ T := by
      dsimp [T]
      exact tsum_nonneg
        (fun r : ℕ => Real.rpow_nonneg (Nat.cast_nonneg r) _)
    exact add_pos_of_pos_of_nonneg hCprime (mul_nonneg hK hT_nonneg)
  intro L hL B hcop
  have hLprime : Lprime ≤ L := le_trans (le_max_left _ _) hL
  have hLexp : Real.exp 1 ≤ L := le_trans (le_max_right _ _) hL
  have hlog_ge_one : (1 : ℝ) ≤ Real.log L := by
    have hlog := Real.log_le_log (Real.exp_pos 1) hLexp
    simpa using hlog
  have hlogpow_ge_one : (1 : ℝ) ≤ (Real.log L) ^ (2 : ℝ) :=
    Real.one_le_rpow hlog_ge_one (by norm_num)
  have hT_nonneg : 0 ≤ T := by
    dsimp [T]
    exact tsum_nonneg
      (fun r : ℕ => Real.rpow_nonneg (Nat.cast_nonneg r) _)
  have hKT_nonneg : 0 ≤ K * T := mul_nonneg hK hT_nonneg
  have hcomp :
      pairwiseCompositeSubfanMass L B ≤ K * T := by
    exact pairwiseCompositeSubfanMass_upper_of_pointwise_minFac L hcop hK hη
      (hpoint L B hcop)
  have hprimeL :
      pairwisePrimeSubfanMass L B ≤ Cprime * (Real.log L) ^ (2 : ℝ) :=
    hprime L hLprime B
  have hcomp_log :
      K * T ≤ (K * T) * (Real.log L) ^ (2 : ℝ) := by
    calc
      K * T = (K * T) * 1 := by ring
      _ ≤ (K * T) * (Real.log L) ^ (2 : ℝ) :=
        mul_le_mul_of_nonneg_left hlogpow_ge_one hKT_nonneg
  rw [pairwiseSubfanMass_eq_prime_add_composite]
  calc
    pairwisePrimeSubfanMass L B + pairwiseCompositeSubfanMass L B
        ≤ Cprime * (Real.log L) ^ (2 : ℝ) + K * T :=
          add_le_add hprimeL hcomp
    _ ≤ Cprime * (Real.log L) ^ (2 : ℝ) +
        (K * T) * (Real.log L) ^ (2 : ℝ) :=
          add_le_add_left hcomp_log _
    _ = (Cprime + K * T) * (Real.log L) ^ (2 : ℝ) := by
          ring

/-- Paper-aligned conditional form of the pairwise-coprime barrier using the
standard divisor-growth estimate exactly as it appears in the proof:
`τ(a²) ≪ a^η`.  Weighted Titchmarsh handles prime moduli; the preceding
real-power bridge turns the divisor-growth estimate into the composite
least-prime-factor envelope. -/
theorem pairwiseSubfanMass_upper_log_square_of_weighted_titchmarsh_and_tau_square_subpower
    {K η : ℝ} (hK : 0 ≤ K) (hη_nonneg : 0 ≤ η) (hη : η < 1 / 2)
    (htau : ∀ a : ℕ, 1 ≤ a →
      ((tau (a ^ 2) : ℕ) : ℝ) ≤ K * (a : ℝ) ^ η) :
    ∃ C L₀ : ℝ, 0 < C ∧ ∀ L : ℝ, L₀ ≤ L → ∀ B : Finset ℕ,
      pairwiseFanModuliCoprime B →
      pairwiseSubfanMass L B ≤ C * (Real.log L) ^ (2 : ℝ) := by
  have hη_one : η < 1 := by linarith
  exact
    pairwiseSubfanMass_upper_log_square_of_weighted_titchmarsh_and_pointwise_minFac
      hK hη
      (fun _L _B _hcop a ha =>
        interiorFanWeight_le_minFac_rpow_of_tau_square_subpower
          hK hη_nonneg hη_one htau
          (Finset.mem_filter.mp (Finset.mem_filter.mp ha).1).2.1
          (Finset.mem_filter.mp ha).2)

/-- Classical divisor-subpower bound needed by the composite part of
`prop:coprime-barrier`: for every fixed positive exponent, `τ(a²)` is bounded
by a constant times `a^η`.

This is deliberately a proposition, not an axiom.  It names the precise
standard divisor-growth fact used in the manuscript sentence
`τ(a²) ≪_{η₀} a^{η₀}` so the remaining bridge can be discharged or cited without
blurring it into the pairwise-coprime argument itself. -/
def TauSquareSubpowerBound : Prop :=
  ∀ η : ℝ, 0 < η →
    ∃ K : ℝ, 0 < K ∧ ∀ a : ℕ, 1 ≤ a →
      ((tau (a ^ 2) : ℕ) : ℝ) ≤ K * (a : ℝ) ^ η

/-- Paper-facing pairwise-coprime barrier from the cited weighted Titchmarsh
input plus the classical divisor-subpower bound.  The exponent is specialized
to `η=1/4`, as in the manuscript's instruction to choose `η₀<1/4`. -/
theorem pairwiseSubfanMass_upper_log_square_of_weighted_titchmarsh_and_tauSquareSubpowerBound
    (htau : TauSquareSubpowerBound) :
    ∃ C L₀ : ℝ, 0 < C ∧ ∀ L : ℝ, L₀ ≤ L → ∀ B : Finset ℕ,
      pairwiseFanModuliCoprime B →
      pairwiseSubfanMass L B ≤ C * (Real.log L) ^ (2 : ℝ) := by
  rcases htau (1 / 4 : ℝ) (by norm_num) with ⟨K, hK_pos, hK⟩
  exact
    pairwiseSubfanMass_upper_log_square_of_weighted_titchmarsh_and_tau_square_subpower
      hK_pos.le (by norm_num) (by norm_num) hK

/-- Conversely, the tau-weighted divisor-fan carrier dominates one quarter of
the Selberg--Delange carrier. -/
theorem one_fourth_mul_tauSqSum_le_divisorFanTauMass (L : ℝ) :
    (1 / 4 : ℝ) * tauSqSum L ≤ divisorFanTauMass L := by
  classical
  unfold divisorFanTauMass tauSqSum
  rw [Finset.mul_sum]
  apply Finset.sum_le_sum
  intro a ha
  have ha1 : 1 ≤ a := (Finset.mem_Icc.mp ha).1
  have ha_ge_one : (1 : ℝ) ≤ (a : ℝ) := by exact_mod_cast ha1
  have ha_pos : 0 < (a : ℝ) := by exact_mod_cast ha1
  have h4a_pos : 0 < (4 : ℝ) * (a : ℝ) := by positivity
  have hden_pos : 0 < (4 : ℝ) * (a : ℝ) - 1 := by nlinarith [ha_ge_one]
  have hden_le : (4 : ℝ) * (a : ℝ) - 1 ≤ (4 : ℝ) * (a : ℝ) := by nlinarith
  have hinv :
      1 / ((4 : ℝ) * (a : ℝ)) ≤
        1 / ((4 : ℝ) * (a : ℝ) - 1) :=
    one_div_le_one_div_of_le hden_pos hden_le
  have htau_nonneg : 0 ≤ ((tau (a ^ 2) : ℕ) : ℝ) := Nat.cast_nonneg _
  calc
    (1 / 4 : ℝ) * (((tau (a ^ 2) : ℕ) : ℝ) / (a : ℝ))
        = ((tau (a ^ 2) : ℕ) : ℝ) *
            (1 / ((4 : ℝ) * (a : ℝ))) := by field_simp [ha_pos.ne']
    _ ≤ ((tau (a ^ 2) : ℕ) : ℝ) *
          (1 / ((4 : ℝ) * (a : ℝ) - 1)) :=
          mul_le_mul_of_nonneg_left hinv htau_nonneg
    _ = ((tau (a ^ 2) : ℕ) : ℝ) / ((4 : ℝ) * (a : ℝ) - 1) := by ring

/-- Formal denominator correction behind the paper's
`1/(4a-1)=1/(4a)+O(a^{-2})`: the whole fan carrier is bounded by its
`(1/4)τ(a²)/a` main term plus the absolutely convergent companion carrier. -/
theorem divisorFanTauMass_le_quarter_tauSqSum_add_quarter_tauSqInvSqSum (L : ℝ) :
    divisorFanTauMass L ≤
      (1 / 4 : ℝ) * tauSqSum L + (1 / 4 : ℝ) * tauSqInvSqSum L := by
  classical
  unfold divisorFanTauMass tauSqSum tauSqInvSqSum
  rw [Finset.mul_sum, Finset.mul_sum, ← Finset.sum_add_distrib]
  apply Finset.sum_le_sum
  intro a ha
  have ha1 : 1 ≤ a := (Finset.mem_Icc.mp ha).1
  have ha_ge_one : (1 : ℝ) ≤ (a : ℝ) := by exact_mod_cast ha1
  have ha_pos : 0 < (a : ℝ) := by exact_mod_cast ha1
  have hden_pos : 0 < (4 : ℝ) * (a : ℝ) - 1 := by nlinarith [ha_ge_one]
  have htau_nonneg : 0 ≤ ((tau (a ^ 2) : ℕ) : ℝ) := Nat.cast_nonneg _
  have hrecip :
      1 / ((4 : ℝ) * (a : ℝ) - 1)
        ≤ 1 / ((4 : ℝ) * (a : ℝ)) +
          1 / ((4 : ℝ) * ((a : ℝ) ^ (2 : ℕ))) := by
    have ha_ne : (a : ℝ) ≠ 0 := ne_of_gt ha_pos
    have hden_ne : (4 : ℝ) * (a : ℝ) - 1 ≠ 0 := ne_of_gt hden_pos
    have h4a_ne : (4 : ℝ) * (a : ℝ) ≠ 0 := by positivity
    have h4a2_ne : (4 : ℝ) * ((a : ℝ) ^ (2 : ℕ)) ≠ 0 := by positivity
    have hbig_pos :
        0 < ((4 : ℝ) * (a : ℝ)) *
          ((4 : ℝ) * ((a : ℝ) ^ (2 : ℕ))) := by positivity
    have hsum_eq :
        (1 / ((4 : ℝ) * (a : ℝ)) +
            1 / ((4 : ℝ) * ((a : ℝ) ^ (2 : ℕ)))) *
            ((4 : ℝ) * (a : ℝ) - 1)
          =
        (((4 : ℝ) * ((a : ℝ) ^ (2 : ℕ)) + (4 : ℝ) * (a : ℝ)) *
            ((4 : ℝ) * (a : ℝ) - 1)) /
          (((4 : ℝ) * (a : ℝ)) *
            ((4 : ℝ) * ((a : ℝ) ^ (2 : ℕ)))) := by
      field_simp [hden_ne, h4a_ne, h4a2_ne, ha_ne]
    rw [div_le_iff₀ hden_pos]
    rw [hsum_eq]
    rw [le_div_iff₀ hbig_pos]
    nlinarith [ha_ge_one]
  calc
    ((tau (a ^ 2) : ℕ) : ℝ) / ((4 : ℝ) * (a : ℝ) - 1)
        = ((tau (a ^ 2) : ℕ) : ℝ) *
            (1 / ((4 : ℝ) * (a : ℝ) - 1)) := by ring
    _ ≤ ((tau (a ^ 2) : ℕ) : ℝ) *
          (1 / ((4 : ℝ) * (a : ℝ)) +
            1 / ((4 : ℝ) * ((a : ℝ) ^ (2 : ℕ)))) :=
          mul_le_mul_of_nonneg_left hrecip htau_nonneg
    _ = (1 / 4 : ℝ) * (((tau (a ^ 2) : ℕ) : ℝ) / (a : ℝ)) +
          (1 / 4 : ℝ) *
            (((tau (a ^ 2) : ℕ) : ℝ) / ((a : ℝ) ^ (2 : ℕ))) := by
          field_simp [ha_pos.ne']
          ring

/-- The `4a-1` denominator correction is bounded by the absolutely convergent
companion divisor-square sum. -/
theorem abs_divisorFanTauMass_sub_quarter_tauSqSum_le_quarter_tauSqInvSqSum
    (L : ℝ) :
    |divisorFanTauMass L - (1 / 4 : ℝ) * tauSqSum L|
      ≤ (1 / 4 : ℝ) * tauSqInvSqSum L := by
  have hlow := one_fourth_mul_tauSqSum_le_divisorFanTauMass L
  have hupper := divisorFanTauMass_le_quarter_tauSqSum_add_quarter_tauSqInvSqSum L
  rw [abs_of_nonneg (sub_nonneg.mpr hlow)]
  linarith

/-- Bounded denominator-error form obtained from the cited Dirichlet-series
companion bound. -/
theorem divisorFanTauMass_sub_quarter_tauSqSum_bounded_of_selberg_delange :
    ∃ B : ℝ, 0 < B ∧ ∀ L : ℝ,
      |divisorFanTauMass L - (1 / 4 : ℝ) * tauSqSum L| ≤ B := by
  rcases tauSqInvSqSum_bounded_of_selberg_delange with ⟨B, hB, hbound⟩
  refine ⟨(1 / 4 : ℝ) * B, mul_pos (by norm_num) hB, ?_⟩
  intro L
  exact le_trans
    (abs_divisorFanTauMass_sub_quarter_tauSqSum_le_quarter_tauSqInvSqSum L)
    (mul_le_mul_of_nonneg_left (hbound L) (by norm_num))

/-- The cubic logarithmic scale tends to infinity. -/
theorem log_cube_tendsto_atTop :
    Filter.Tendsto (fun L : ℝ => (Real.log L) ^ (3 : ℝ))
      Filter.atTop Filter.atTop := by
  exact (tendsto_rpow_atTop (by norm_num : (0 : ℝ) < (3 : ℝ))).comp
    Real.tendsto_log_atTop

/-- A uniformly bounded numerator is negligible on the cubic logarithmic scale. -/
theorem bounded_div_log_cube_tendsto_zero
    (f : ℝ → ℝ) (B : ℝ) (hB : 0 < B) (hbound : ∀ L : ℝ, |f L| ≤ B) :
    Filter.Tendsto
      (fun L : ℝ => f L / (Real.log L) ^ (3 : ℝ))
      Filter.atTop (nhds 0) := by
  have _ : 0 ≤ B := hB.le
  have hden_top := log_cube_tendsto_atTop
  have hinv :
      Filter.Tendsto
        (fun L : ℝ => ((Real.log L) ^ (3 : ℝ))⁻¹)
        Filter.atTop (nhds 0) :=
    tendsto_inv_atTop_zero.comp hden_top
  have hmajor :
      Filter.Tendsto
        (fun L : ℝ => B * ((Real.log L) ^ (3 : ℝ))⁻¹)
        Filter.atTop (nhds 0) := by
    simpa using hinv.const_mul B
  refine squeeze_zero_norm'
    (a := fun L : ℝ => B * ((Real.log L) ^ (3 : ℝ))⁻¹) ?_ hmajor
  filter_upwards [Filter.eventually_gt_atTop (1 : ℝ)] with L hL
  have hlog_pos : 0 < Real.log L := Real.log_pos hL
  have hden_pos : 0 < (Real.log L) ^ (3 : ℝ) :=
    Real.rpow_pos_of_pos hlog_pos 3
  rw [Real.norm_eq_abs, abs_div, abs_of_pos hden_pos]
  calc
    |f L| / (Real.log L) ^ (3 : ℝ)
        ≤ B / (Real.log L) ^ (3 : ℝ) :=
          div_le_div_of_nonneg_right (hbound L) hden_pos.le
    _ = B * ((Real.log L) ^ (3 : ℝ))⁻¹ := by ring

/-- The harmonic series at the natural cutoff is negligible on the cubic
logarithmic scale. -/
theorem harmonic_floor_div_log_cube_tendsto_zero :
    Filter.Tendsto
      (fun L : ℝ => ((harmonic ⌊L⌋₊ : ℚ) : ℝ) /
        (Real.log L) ^ (3 : ℝ))
      Filter.atTop (nhds 0) := by
  have hlog_sq_top :
      Filter.Tendsto (fun L : ℝ => (Real.log L) ^ (2 : ℝ))
        Filter.atTop Filter.atTop := by
    exact (tendsto_rpow_atTop (by norm_num : (0 : ℝ) < (2 : ℝ))).comp
      Real.tendsto_log_atTop
  have hinv :
      Filter.Tendsto (fun L : ℝ => ((Real.log L) ^ (2 : ℝ))⁻¹)
        Filter.atTop (nhds 0) :=
    tendsto_inv_atTop_zero.comp hlog_sq_top
  have hmajor :
      Filter.Tendsto (fun L : ℝ => 2 * ((Real.log L) ^ (2 : ℝ))⁻¹)
        Filter.atTop (nhds 0) := by
    simpa using hinv.const_mul (2 : ℝ)
  refine squeeze_zero' ?_ ?_ hmajor
  · filter_upwards [Filter.eventually_gt_atTop (Real.exp 1)] with L hL
    have hLpos : 0 < L := lt_of_lt_of_le (Real.exp_pos 1) hL.le
    have hlog_pos : 0 < Real.log L := by
      rw [Real.log_pos_iff hLpos]
      exact lt_of_lt_of_le (by norm_num : (1 : ℝ) < Real.exp 1) hL.le
    have hden_pos : 0 < (Real.log L) ^ (3 : ℝ) :=
      Real.rpow_pos_of_pos hlog_pos 3
    have hharm_nonneg : 0 ≤ ((harmonic ⌊L⌋₊ : ℚ) : ℝ) := by
      rw [harmonic_eq_sum_Icc]
      simp only [Rat.cast_sum, Rat.cast_inv, Rat.cast_natCast]
      apply Finset.sum_nonneg
      intro n _hn
      exact inv_nonneg.mpr (Nat.cast_nonneg n)
    exact div_nonneg hharm_nonneg hden_pos.le
  · filter_upwards [Filter.eventually_gt_atTop (Real.exp 1)] with L hL
    have hLpos : 0 < L := lt_of_lt_of_le (Real.exp_pos 1) hL.le
    have hL_ge_one : 1 ≤ L :=
      le_trans (by norm_num : (1 : ℝ) ≤ Real.exp 1) hL.le
    have hlog_ge_one : 1 ≤ Real.log L := by
      rw [Real.le_log_iff_exp_le hLpos]
      exact hL.le
    have hlog_pos : 0 < Real.log L := lt_of_lt_of_le zero_lt_one hlog_ge_one
    have hden_pos : 0 < (Real.log L) ^ (3 : ℝ) :=
      Real.rpow_pos_of_pos hlog_pos 3
    have hlog_sq_pos : 0 < (Real.log L) ^ (2 : ℝ) :=
      Real.rpow_pos_of_pos hlog_pos 2
    have hharm : ((harmonic ⌊L⌋₊ : ℚ) : ℝ) ≤ 1 + Real.log L :=
      harmonic_floor_le_one_add_log L hL_ge_one
    have htail : 1 + Real.log L ≤ 2 * Real.log L := by
      linarith
    calc
      ((harmonic ⌊L⌋₊ : ℚ) : ℝ) / (Real.log L) ^ (3 : ℝ)
          ≤ (2 * Real.log L) / (Real.log L) ^ (3 : ℝ) :=
            div_le_div_of_nonneg_right (le_trans hharm htail) hden_pos.le
      _ = 2 * ((Real.log L) ^ (2 : ℝ))⁻¹ := by
            have hlog3 : (Real.log L) ^ (3 : ℝ) =
                (Real.log L) ^ (3 : ℕ) :=
              Real.rpow_natCast (Real.log L) 3
            have hlog2 : (Real.log L) ^ (2 : ℝ) =
                (Real.log L) ^ (2 : ℕ) :=
              Real.rpow_natCast (Real.log L) 2
            rw [hlog3, hlog2]
            field_simp [ne_of_gt hlog_pos]
            ring

/-- Exact asymptotic for the tau-weighted `4a-1` divisor-fan carrier.  This is
the checked denominator-correction bridge in the proof of
`prop:cubic-fan-mass`; it upgrades the previous `≍ (log L)^3` statement to the
paper's constant before the finite divisor exclusions and the half-fan split are
handled. -/
theorem divisorFanTauMass_asymptotic_of_selberg_delange :
    Filter.Tendsto
      (fun L : ℝ => divisorFanTauMass L / (Real.log L) ^ (3 : ℝ))
      Filter.atTop (nhds (1 / (24 * zeta2))) := by
  rcases divisorFanTauMass_sub_quarter_tauSqSum_bounded_of_selberg_delange with
    ⟨B, hB, hbound⟩
  have hmain :
      Filter.Tendsto
        (fun L : ℝ => (1 / 4 : ℝ) *
          (tauSqSum L / (Real.log L) ^ (3 : ℝ)))
        Filter.atTop (nhds ((1 / 4 : ℝ) * (1 / (6 * zeta2)))) := by
    simpa using tauSqSum_asymptotic_of_selberg_delange.const_mul (1 / 4 : ℝ)
  have herr :
      Filter.Tendsto
        (fun L : ℝ =>
          (divisorFanTauMass L - (1 / 4 : ℝ) * tauSqSum L) /
            (Real.log L) ^ (3 : ℝ))
        Filter.atTop (nhds 0) :=
    bounded_div_log_cube_tendsto_zero
      (fun L : ℝ => divisorFanTauMass L - (1 / 4 : ℝ) * tauSqSum L)
      B hB hbound
  have hsum := hmain.add herr
  have hdecomp :
      (fun L : ℝ => divisorFanTauMass L / (Real.log L) ^ (3 : ℝ))
        =
      (fun L : ℝ =>
        (1 / 4 : ℝ) * (tauSqSum L / (Real.log L) ^ (3 : ℝ)) +
          (divisorFanTauMass L - (1 / 4 : ℝ) * tauSqSum L) /
            (Real.log L) ^ (3 : ℝ)) := by
    funext L
    ring
  rw [hdecomp]
  convert hsum using 1
  ring

/-- Exact asymptotic for the full interior divisor-fan mass in
`prop:cubic-fan-mass`, before the lower-half involution is applied. -/
theorem divisorFanInteriorMass_asymptotic_of_selberg_delange :
    Filter.Tendsto
      (fun L : ℝ => divisorFanInteriorMass L / (Real.log L) ^ (3 : ℝ))
      Filter.atTop (nhds (1 / (24 * zeta2))) := by
  have hmajor :
      Filter.Tendsto
        (fun L : ℝ => 3 *
          (((harmonic ⌊L⌋₊ : ℚ) : ℝ) / (Real.log L) ^ (3 : ℝ)))
        Filter.atTop (nhds 0) := by
    simpa using harmonic_floor_div_log_cube_tendsto_zero.const_mul (3 : ℝ)
  have herr :
      Filter.Tendsto
        (fun L : ℝ =>
          (divisorFanInteriorMass L - divisorFanTauMass L) /
            (Real.log L) ^ (3 : ℝ))
        Filter.atTop (nhds 0) := by
    refine squeeze_zero_norm'
      (a := fun L : ℝ => 3 *
        (((harmonic ⌊L⌋₊ : ℚ) : ℝ) / (Real.log L) ^ (3 : ℝ))) ?_ hmajor
    filter_upwards [Filter.eventually_gt_atTop (Real.exp 1)] with L hL
    have hlog_ge_one : 1 ≤ Real.log L := by
      have hLpos : 0 < L := lt_of_lt_of_le (Real.exp_pos 1) hL.le
      rw [Real.le_log_iff_exp_le hLpos]
      exact hL.le
    have hlog_pos : 0 < Real.log L := lt_of_lt_of_le zero_lt_one hlog_ge_one
    have hden_pos : 0 < (Real.log L) ^ (3 : ℝ) :=
      Real.rpow_pos_of_pos hlog_pos 3
    have hdiff :
        |divisorFanInteriorMass L - divisorFanTauMass L|
          ≤ 3 * ((harmonic ⌊L⌋₊ : ℚ) : ℝ) := by
      simpa [abs_sub_comm] using
        abs_divisorFanTauMass_sub_divisorFanInteriorMass_le_three_harmonic L
    rw [Real.norm_eq_abs, abs_div, abs_of_pos hden_pos]
    calc
      |divisorFanInteriorMass L - divisorFanTauMass L| /
          (Real.log L) ^ (3 : ℝ)
          ≤ (3 * ((harmonic ⌊L⌋₊ : ℚ) : ℝ)) /
              (Real.log L) ^ (3 : ℝ) :=
            div_le_div_of_nonneg_right hdiff hden_pos.le
      _ = 3 * (((harmonic ⌊L⌋₊ : ℚ) : ℝ) /
            (Real.log L) ^ (3 : ℝ)) := by ring
  have hsum := divisorFanTauMass_asymptotic_of_selberg_delange.add herr
  have hdecomp :
      (fun L : ℝ => divisorFanInteriorMass L / (Real.log L) ^ (3 : ℝ))
        =
      (fun L : ℝ =>
        divisorFanTauMass L / (Real.log L) ^ (3 : ℝ) +
          (divisorFanInteriorMass L - divisorFanTauMass L) /
            (Real.log L) ^ (3 : ℝ)) := by
    funext L
    ring
  rw [hdecomp]
  simpa using hsum

/-- Exact asymptotic for the lower-half divisor-fan mass in
`prop:cubic-fan-mass`. -/
theorem divisorFanLowerMass_asymptotic_of_selberg_delange :
    Filter.Tendsto
      (fun L : ℝ => divisorFanLowerMass L / (Real.log L) ^ (3 : ℝ))
      Filter.atTop (nhds (1 / (48 * zeta2))) := by
  have hhalf :
      Filter.Tendsto
        (fun L : ℝ => (1 / 2 : ℝ) *
          (divisorFanInteriorMass L / (Real.log L) ^ (3 : ℝ)))
        Filter.atTop (nhds ((1 / 2 : ℝ) * (1 / (24 * zeta2)))) := by
    simpa using
      divisorFanInteriorMass_asymptotic_of_selberg_delange.const_mul (1 / 2 : ℝ)
  have hdecomp :
      (fun L : ℝ => divisorFanLowerMass L / (Real.log L) ^ (3 : ℝ))
        =
      (fun L : ℝ => (1 / 2 : ℝ) *
        (divisorFanInteriorMass L / (Real.log L) ^ (3 : ℝ))) := by
    funext L
    rw [divisorFanLowerMass_eq_half_interior L]
    ring
  rw [hdecomp]
  convert hhalf using 1
  ring

/-- Shape-level checked bridge toward `prop:cubic-fan-mass`: the actual
`4a-1` fan denominator has the same cubic-log order as the cited
Selberg--Delange carrier.  The precise asymptotic constant and the
lower/upper-half split are intentionally not hidden here. -/
theorem divisorFanTauMass_cubic_bounds_of_selberg_delange :
    ∃ c C L₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ L : ℝ, L₀ ≤ L →
      c * (Real.log L) ^ (3 : ℝ) ≤ divisorFanTauMass L ∧
        divisorFanTauMass L ≤ C * (Real.log L) ^ (3 : ℝ) := by
  rcases tauSqSum_cubic_bounds_of_selberg_delange with ⟨c, C, L₀, hc, hC, hbound⟩
  refine ⟨c / 4, C, L₀, div_pos hc (by norm_num), hC, ?_⟩
  intro L hL
  have hquarter := one_fourth_mul_tauSqSum_le_divisorFanTauMass L
  have hupper := divisorFanTauMass_le_tauSqSum L
  have hsd := hbound L hL
  constructor
  · calc
      (c / 4) * (Real.log L) ^ (3 : ℝ)
          = (1 / 4 : ℝ) * (c * (Real.log L) ^ (3 : ℝ)) := by ring
      _ ≤ (1 / 4 : ℝ) * tauSqSum L :=
          mul_le_mul_of_nonneg_left hsd.1 (by norm_num)
      _ ≤ divisorFanTauMass L := hquarter
  · exact le_trans hupper hsd.2

/-- Divisor-count comparison for squares: `τ(n²) ≤ τ(n)^2`.

Using Mathlib's prime-factor formula for the divisor-count function, this is the
pointwise prime-exponent inequality `2e+1 ≤ (e+1)^2` multiplied over the prime
support of `n`. -/
theorem tau_square_le_tau_sq (n : ℕ) : tau (n ^ 2) ≤ (tau n) ^ 2 := by
  by_cases hn : n = 0
  · subst n
    simp [tau]
  · unfold tau
    rw [Nat.card_divisors (pow_ne_zero 2 hn), Nat.card_divisors hn]
    rw [Nat.primeFactors_pow n (by norm_num : (2 : ℕ) ≠ 0)]
    have hterm : ∀ p ∈ n.primeFactors,
        (n ^ 2).factorization p + 1 ≤ (n.factorization p + 1) ^ 2 := by
      intro p _hp
      rw [Nat.factorization_pow]
      simp
      nlinarith [Nat.zero_le (n.factorization p)]
    calc
      ∏ p ∈ n.primeFactors, ((n ^ 2).factorization p + 1)
          ≤ ∏ p ∈ n.primeFactors, (n.factorization p + 1) ^ 2 := by
            exact Finset.prod_le_prod (fun p _hp => Nat.zero_le _) hterm
      _ = (∏ p ∈ n.primeFactors, (n.factorization p + 1)) ^ 2 := by
            rw [Finset.prod_pow]

/-- Elementary exponent bound used in the divisor-subpower estimate:
`2e+1 ≤ 3^e`. -/
theorem two_mul_add_one_le_three_pow (e : ℕ) : 2 * e + 1 ≤ 3 ^ e := by
  induction e with
  | zero => norm_num
  | succ e ih =>
      calc
        2 * (e + 1) + 1 ≤ 3 * (2 * e + 1) := by omega
        _ ≤ 3 * 3 ^ e := Nat.mul_le_mul_left 3 ih
        _ = 3 ^ (e + 1) := by ring

/-- A concrete linear-versus-exponential bound with base `11/10`. -/
theorem two_mul_add_one_le_thirty_mul_eleven_tenths_pow (e : ℕ) :
    ((2 * e + 1 : ℕ) : ℝ) ≤ 30 * ((11 : ℝ) / 10) ^ e := by
  induction e with
  | zero => norm_num
  | succ e ih =>
      by_cases he : e < 10
      · have hleft : ((2 * (e + 1) + 1 : ℕ) : ℝ) ≤ 30 := by
          have hleft_nat : 2 * (e + 1) + 1 ≤ 30 := by omega
          exact_mod_cast hleft_nat
        have hpow_ge : (1 : ℝ) ≤ ((11 : ℝ) / 10) ^ (e + 1) := by
          exact one_le_pow₀ (by norm_num : (1 : ℝ) ≤ (11 : ℝ) / 10)
        calc
          ((2 * (e + 1) + 1 : ℕ) : ℝ) ≤ 30 := hleft
          _ = 30 * 1 := by ring
          _ ≤ 30 * ((11 : ℝ) / 10) ^ (e + 1) := by
            exact mul_le_mul_of_nonneg_left hpow_ge (by norm_num)
      · have he10 : (10 : ℕ) ≤ e := Nat.le_of_not_lt he
        have hstep : ((2 * (e + 1) + 1 : ℕ) : ℝ) ≤
            ((11 : ℝ) / 10) * ((2 * e + 1 : ℕ) : ℝ) := by
          have he10r : (10 : ℝ) ≤ e := by exact_mod_cast he10
          norm_num
          nlinarith
        calc
          ((2 * (e + 1) + 1 : ℕ) : ℝ)
              ≤ ((11 : ℝ) / 10) * ((2 * e + 1 : ℕ) : ℝ) := hstep
          _ ≤ ((11 : ℝ) / 10) * (30 * ((11 : ℝ) / 10) ^ e) := by
            exact mul_le_mul_of_nonneg_left ih (by norm_num)
          _ = 30 * ((11 : ℝ) / 10) ^ (e + 1) := by ring

/-- The concrete base comparison `(11/10) ≤ 2^(1/4)`. -/
theorem eleven_tenths_le_two_rpow_quarter :
    ((11 : ℝ) / 10) ≤ (2 : ℝ) ^ ((1 : ℝ) / 4) := by
  have h : ((11 : ℝ) / 10) ≤ (2 : ℝ) ^ (4 : ℝ)⁻¹ := by
    rw [Real.le_rpow_inv_iff_of_pos (by norm_num : (0 : ℝ) ≤ (11 : ℝ) / 10)
        (by norm_num : (0 : ℝ) ≤ 2) (by norm_num : (0 : ℝ) < 4)]
    norm_num
  simpa [one_div] using h

/-- Uniform small-prime exponent bound:
`2e+1 ≤ 30·2^(e/4)`, hence also `≤ 30·p^(e/4)` for every prime `p`. -/
theorem two_mul_add_one_le_thirty_mul_two_rpow_quarter (e : ℕ) :
    ((2 * e + 1 : ℕ) : ℝ) ≤ 30 * (2 : ℝ) ^ ((e : ℝ) / 4) := by
  have hlin := two_mul_add_one_le_thirty_mul_eleven_tenths_pow e
  have hbasepow : ((11 : ℝ) / 10) ^ e ≤ ((2 : ℝ) ^ ((1 : ℝ) / 4)) ^ e := by
    exact pow_le_pow_left₀ (by norm_num : (0 : ℝ) ≤ (11 : ℝ) / 10)
      eleven_tenths_le_two_rpow_quarter e
  have hpoweq : ((2 : ℝ) ^ ((1 : ℝ) / 4)) ^ e =
      (2 : ℝ) ^ ((e : ℝ) / 4) := by
    rw [← Real.rpow_natCast, ← Real.rpow_mul (by norm_num : (0 : ℝ) ≤ 2)]
    ring_nf
  calc
    ((2 * e + 1 : ℕ) : ℝ) ≤ 30 * ((11 : ℝ) / 10) ^ e := hlin
    _ ≤ 30 * (((2 : ℝ) ^ ((1 : ℝ) / 4)) ^ e) := by
      exact mul_le_mul_of_nonneg_left hbasepow (by norm_num)
    _ = 30 * (2 : ℝ) ^ ((e : ℝ) / 4) := by rw [hpoweq]

/-- Large-prime exponent bound: once `p ≥ 81`, the factor `2e+1` is absorbed
directly into `p^(e/4)`. -/
theorem two_mul_add_one_le_large_rpow_quarter {p e : ℕ} (hp : 81 ≤ p) :
    ((2 * e + 1 : ℕ) : ℝ) ≤ (p : ℝ) ^ ((e : ℝ) / 4) := by
  have hlin_nat := two_mul_add_one_le_three_pow e
  have hlin : ((2 * e + 1 : ℕ) : ℝ) ≤ ((3 ^ e : ℕ) : ℝ) := by
    exact_mod_cast hlin_nat
  have h3root : (3 : ℝ) ≤ (p : ℝ) ^ ((1 : ℝ) / 4) := by
    have h : (3 : ℝ) ≤ (p : ℝ) ^ (4 : ℝ)⁻¹ := by
      rw [Real.le_rpow_inv_iff_of_pos (by norm_num : (0 : ℝ) ≤ 3)
          (Nat.cast_nonneg p) (by norm_num : (0 : ℝ) < 4)]
      norm_num
      exact_mod_cast hp
    simpa [one_div] using h
  have hpow : (3 : ℝ) ^ e ≤ ((p : ℝ) ^ ((1 : ℝ) / 4)) ^ e := by
    exact pow_le_pow_left₀ (by norm_num : (0 : ℝ) ≤ 3) h3root e
  have hpoweq : ((p : ℝ) ^ ((1 : ℝ) / 4)) ^ e =
      (p : ℝ) ^ ((e : ℝ) / 4) := by
    rw [← Real.rpow_natCast, ← Real.rpow_mul (Nat.cast_nonneg p)]
    ring_nf
  calc
    ((2 * e + 1 : ℕ) : ℝ) ≤ ((3 ^ e : ℕ) : ℝ) := hlin
    _ = (3 : ℝ) ^ e := by norm_num
    _ ≤ ((p : ℝ) ^ ((1 : ℝ) / 4)) ^ e := hpow
    _ = (p : ℝ) ^ ((e : ℝ) / 4) := hpoweq

/-- Small-prime linear-versus-exponential bound used in the full divisor
subpower estimate.  For every positive exponent, the fixed base `p^eta > 1`
eventually dominates the linear factor `2e+1`, with an explicit constant. -/
theorem two_mul_add_one_le_three_mul_rpow_div_sub_mul_rpow
    {η : ℝ} (hη : 0 < η) {p e : ℕ} (hp : 2 ≤ p) :
    ((2 * e + 1 : ℕ) : ℝ) ≤
      (3 * (p : ℝ) ^ η / ((p : ℝ) ^ η - 1)) *
        (p : ℝ) ^ ((e : ℝ) * η) := by
  have hp_gt_one : (1 : ℝ) < (p : ℝ) := by
    exact_mod_cast (lt_of_lt_of_le (by norm_num : (1 : ℕ) < 2) hp)
  have hp_nonneg : (0 : ℝ) ≤ (p : ℝ) := Nat.cast_nonneg p
  have hb_gt_one : (1 : ℝ) < (p : ℝ) ^ η :=
    Real.one_lt_rpow hp_gt_one hη
  have hlin_nat : 2 * e + 1 ≤ 3 * (e + 1) := by omega
  have hlin : ((2 * e + 1 : ℕ) : ℝ) ≤ 3 * ((e + 1 : ℕ) : ℝ) := by
    exact_mod_cast hlin_nat
  have hgrowth :
      ((e + 1 : ℕ) : ℝ) ≤
        ((p : ℝ) ^ η) ^ (e + 1) / ((p : ℝ) ^ η - 1) :=
    Nat.cast_le_pow_div_sub hb_gt_one (e + 1)
  have hpoweq :
      ((p : ℝ) ^ η) ^ e = (p : ℝ) ^ ((e : ℝ) * η) := by
    rw [← Real.rpow_natCast, ← Real.rpow_mul hp_nonneg]
    ring_nf
  calc
    ((2 * e + 1 : ℕ) : ℝ)
        ≤ 3 * ((e + 1 : ℕ) : ℝ) := hlin
    _ ≤ 3 * (((p : ℝ) ^ η) ^ (e + 1) / ((p : ℝ) ^ η - 1)) :=
          mul_le_mul_of_nonneg_left hgrowth (by norm_num)
    _ = (3 * (p : ℝ) ^ η / ((p : ℝ) ^ η - 1)) *
          ((p : ℝ) ^ η) ^ e := by
          rw [pow_succ']
          field_simp [sub_ne_zero.mpr hb_gt_one.ne']
          ring
    _ = (3 * (p : ℝ) ^ η / ((p : ℝ) ^ η - 1)) *
          (p : ℝ) ^ ((e : ℝ) * η) := by rw [hpoweq]

/-- Absolute constant in the checked pointwise divisor bound
`τ(a²) ≤ C a^(1/4)`.  The crude value pays for the finitely many prime factors
below `81`. -/
noncomputable def tauSquareQuarterConstant : ℝ := 30 ^ (81 : ℕ)

private noncomputable def tauSquareSubpowerPrimeCoeff
    (η : ℝ) (Y p : ℕ) : ℝ :=
  if p < Y then
    max 1 (3 * (p : ℝ) ^ η / ((p : ℝ) ^ η - 1))
  else
    1

private theorem one_le_tauSquareSubpowerPrimeCoeff (η : ℝ) (Y p : ℕ) :
    1 ≤ tauSquareSubpowerPrimeCoeff η Y p := by
  unfold tauSquareSubpowerPrimeCoeff
  split
  · exact le_max_left _ _
  · rfl

private theorem tauSquareSubpowerPrimeCoeff_pos (η : ℝ) (Y p : ℕ) :
    0 < tauSquareSubpowerPrimeCoeff η Y p :=
  lt_of_lt_of_le zero_lt_one (one_le_tauSquareSubpowerPrimeCoeff η Y p)

private theorem real_prod_le_prod_of_subset_of_one_le
    {s t : Finset ℕ} {f : ℕ → ℝ}
    (hsub : s ⊆ t) (hf : ∀ p ∈ t, 1 ≤ f p) :
    (∏ p ∈ s, f p) ≤ ∏ p ∈ t, f p := by
  classical
  have hs_nonneg : 0 ≤ ∏ p ∈ s, f p := by
    exact Finset.prod_nonneg
      (fun p hp => le_trans zero_le_one (hf p (hsub hp)))
  have hone_le_compl : (1 : ℝ) ≤ ∏ p ∈ t \ s, f p := by
    calc
      (1 : ℝ) = ∏ _p ∈ t \ s, (1 : ℝ) := by simp
      _ ≤ ∏ p ∈ t \ s, f p :=
          Finset.prod_le_prod
            (fun _p _hp => zero_le_one)
            (fun p hp => hf p (Finset.mem_sdiff.mp hp).1)
  calc
    (∏ p ∈ s, f p)
        = (1 : ℝ) * (∏ p ∈ s, f p) := by ring
    _ ≤ (∏ p ∈ t \ s, f p) * (∏ p ∈ s, f p) :=
        mul_le_mul_of_nonneg_right hone_le_compl hs_nonneg
    _ = ∏ p ∈ t, f p := Finset.prod_sdiff hsub

private theorem tauSquareSubpowerPrimeCoeff_prod_le
    (η : ℝ) (Y : ℕ) (s : Finset ℕ) :
    (∏ p ∈ s, tauSquareSubpowerPrimeCoeff η Y p) ≤
      ∏ p ∈ Finset.range Y, tauSquareSubpowerPrimeCoeff η Y p := by
  classical
  let small := s.filter (fun p => p < Y)
  have hsplit :
      (∏ p ∈ s, tauSquareSubpowerPrimeCoeff η Y p) =
        (∏ p ∈ small, tauSquareSubpowerPrimeCoeff η Y p) *
          (∏ p ∈ s.filter (fun p => ¬ p < Y),
            tauSquareSubpowerPrimeCoeff η Y p) := by
    dsimp [small]
    rw [Finset.prod_filter_mul_prod_filter_not]
  have hlarge :
      (∏ p ∈ s.filter (fun p => ¬ p < Y),
          tauSquareSubpowerPrimeCoeff η Y p) = 1 := by
    calc
      (∏ p ∈ s.filter (fun p => ¬ p < Y),
          tauSquareSubpowerPrimeCoeff η Y p) =
          ∏ _p ∈ s.filter (fun p => ¬ p < Y), (1 : ℝ) := by
            apply Finset.prod_congr rfl
            intro p hp
            have hp_not : ¬ p < Y := (Finset.mem_filter.mp hp).2
            simp [tauSquareSubpowerPrimeCoeff, hp_not]
      _ = 1 := by simp
  have hsmall_subset : small ⊆ Finset.range Y := by
    intro p hp
    exact Finset.mem_range.mpr ((Finset.mem_filter.mp hp).2)
  calc
    (∏ p ∈ s, tauSquareSubpowerPrimeCoeff η Y p)
        = (∏ p ∈ small, tauSquareSubpowerPrimeCoeff η Y p) * 1 := by
          rw [hsplit, hlarge]
    _ = ∏ p ∈ small, tauSquareSubpowerPrimeCoeff η Y p := by ring
    _ ≤ ∏ p ∈ Finset.range Y, tauSquareSubpowerPrimeCoeff η Y p :=
          real_prod_le_prod_of_subset_of_one_le hsmall_subset
            (fun p _hp =>
              one_le_tauSquareSubpowerPrimeCoeff η Y p)

private theorem tau_square_prime_factor_term_le_subpower_coeff
    {η : ℝ} (hη : 0 < η) {Y : ℕ}
    (hY : ∀ p : ℕ, Y ≤ p → (3 : ℝ) ≤ (p : ℝ) ^ η)
    (a p : ℕ) (hp : p ∈ a.primeFactors) :
    (((a ^ 2).factorization p + 1 : ℕ) : ℝ) ≤
      tauSquareSubpowerPrimeCoeff η Y p *
        (p : ℝ) ^ (((a.factorization p : ℕ) : ℝ) * η) := by
  classical
  have hpprime : Nat.Prime p := Nat.prime_of_mem_primeFactors hp
  have hp2_nat : 2 ≤ p := hpprime.two_le
  have hfactor : (a ^ 2).factorization p + 1 = 2 * a.factorization p + 1 := by
    rw [Nat.factorization_pow]
    simp [Finsupp.smul_apply, smul_eq_mul, mul_comm, mul_left_comm, mul_assoc]
  by_cases hsmall : p < Y
  · have hterm :=
      two_mul_add_one_le_three_mul_rpow_div_sub_mul_rpow
        (η := η) hη (p := p) (e := a.factorization p) hp2_nat
    have hcoeff :
        3 * (p : ℝ) ^ η / ((p : ℝ) ^ η - 1) ≤
          tauSquareSubpowerPrimeCoeff η Y p := by
      simp [tauSquareSubpowerPrimeCoeff, hsmall, le_max_right]
    have hpow_nonneg :
        0 ≤ (p : ℝ) ^ (((a.factorization p : ℕ) : ℝ) * η) :=
      Real.rpow_nonneg (Nat.cast_nonneg p) _
    calc
      (((a ^ 2).factorization p + 1 : ℕ) : ℝ)
          = ((2 * a.factorization p + 1 : ℕ) : ℝ) := by rw [hfactor]
      _ ≤ (3 * (p : ℝ) ^ η / ((p : ℝ) ^ η - 1)) *
            (p : ℝ) ^ (((a.factorization p : ℕ) : ℝ) * η) := hterm
      _ ≤ tauSquareSubpowerPrimeCoeff η Y p *
            (p : ℝ) ^ (((a.factorization p : ℕ) : ℝ) * η) :=
            mul_le_mul_of_nonneg_right hcoeff hpow_nonneg
  · have hlarge_nat : Y ≤ p := Nat.le_of_not_lt hsmall
    have hlin_nat := two_mul_add_one_le_three_pow (a.factorization p)
    have hlin : ((2 * a.factorization p + 1 : ℕ) : ℝ) ≤
        (3 : ℝ) ^ a.factorization p := by
      exact_mod_cast hlin_nat
    have hbase : (3 : ℝ) ≤ (p : ℝ) ^ η := hY p hlarge_nat
    have hpow :
        (3 : ℝ) ^ a.factorization p ≤
          ((p : ℝ) ^ η) ^ a.factorization p := by
      exact pow_le_pow_left₀ (by norm_num : (0 : ℝ) ≤ 3) hbase _
    have hpowequiv :
        ((p : ℝ) ^ η) ^ a.factorization p =
          (p : ℝ) ^ (((a.factorization p : ℕ) : ℝ) * η) := by
      rw [← Real.rpow_natCast, ← Real.rpow_mul (Nat.cast_nonneg p)]
      ring_nf
    calc
      (((a ^ 2).factorization p + 1 : ℕ) : ℝ)
          = ((2 * a.factorization p + 1 : ℕ) : ℝ) := by rw [hfactor]
      _ ≤ (3 : ℝ) ^ a.factorization p := hlin
      _ ≤ ((p : ℝ) ^ η) ^ a.factorization p := hpow
      _ = (p : ℝ) ^ (((a.factorization p : ℕ) : ℝ) * η) := hpowequiv
      _ = tauSquareSubpowerPrimeCoeff η Y p *
            (p : ℝ) ^ (((a.factorization p : ℕ) : ℝ) * η) := by
            simp [tauSquareSubpowerPrimeCoeff, hsmall]

/-- Full elementary divisor-subpower theorem for square divisor counts:
for every positive exponent `η`, `τ(a²) ≪_η a^η`. -/
theorem tauSquareSubpowerBound_unconditional : TauSquareSubpowerBound := by
  intro η hη
  classical
  have htend :
      Filter.Tendsto (fun p : ℕ => (p : ℝ) ^ η)
        Filter.atTop Filter.atTop :=
    (tendsto_rpow_atTop hη).comp tendsto_natCast_atTop_atTop
  have hevent : ∀ᶠ p : ℕ in Filter.atTop, (3 : ℝ) ≤ (p : ℝ) ^ η :=
    htend.eventually (Filter.eventually_ge_atTop (3 : ℝ))
  rcases Filter.eventually_atTop.mp hevent with ⟨Y, hY⟩
  let K : ℝ := ∏ p ∈ Finset.range Y, tauSquareSubpowerPrimeCoeff η Y p
  have hKpos : 0 < K := by
    dsimp [K]
    exact Finset.prod_pos
      (fun p _hp => tauSquareSubpowerPrimeCoeff_pos η Y p)
  refine ⟨K, hKpos, ?_⟩
  intro a ha
  have ha_ne : a ≠ 0 := by omega
  have ha2_ne : a ^ 2 ≠ 0 := pow_ne_zero 2 ha_ne
  have hcast : ((tau (a ^ 2) : ℕ) : ℝ) =
      ∏ p ∈ a.primeFactors, (((a ^ 2).factorization p + 1 : ℕ) : ℝ) := by
    unfold tau
    rw [Nat.card_divisors ha2_ne]
    rw [Nat.primeFactors_pow a (by norm_num : (2 : ℕ) ≠ 0)]
    norm_num
  have hprod_le :
      (∏ p ∈ a.primeFactors, (((a ^ 2).factorization p + 1 : ℕ) : ℝ)) ≤
        ∏ p ∈ a.primeFactors,
          tauSquareSubpowerPrimeCoeff η Y p *
            (p : ℝ) ^ (((a.factorization p : ℕ) : ℝ) * η) := by
    exact Finset.prod_le_prod
      (fun _p _hp => Nat.cast_nonneg _)
      (fun p hp =>
        tau_square_prime_factor_term_le_subpower_coeff
          hη hY a p hp)
  have hsplit :
      (∏ p ∈ a.primeFactors,
          tauSquareSubpowerPrimeCoeff η Y p *
            (p : ℝ) ^ (((a.factorization p : ℕ) : ℝ) * η)) =
        (∏ p ∈ a.primeFactors, tauSquareSubpowerPrimeCoeff η Y p) *
          ∏ p ∈ a.primeFactors,
            (p : ℝ) ^ (((a.factorization p : ℕ) : ℝ) * η) := by
    rw [Finset.prod_mul_distrib]
  have hcoeff :=
    tauSquareSubpowerPrimeCoeff_prod_le η Y a.primeFactors
  have hpow_eq :
      (∏ p ∈ a.primeFactors,
          (p : ℝ) ^ (((a.factorization p : ℕ) : ℝ) * η)) =
        (a : ℝ) ^ η := by
    have hrewrite :
        (∏ p ∈ a.primeFactors,
            (p : ℝ) ^ (((a.factorization p : ℕ) : ℝ) * η)) =
          ∏ p ∈ a.primeFactors, ((p : ℝ) ^ a.factorization p) ^ η := by
      apply Finset.prod_congr rfl
      intro p _hp
      rw [← Real.rpow_natCast, ← Real.rpow_mul (Nat.cast_nonneg p)]
    rw [hrewrite, Real.finset_prod_rpow]
    · have hprod_nat : (∏ p ∈ a.primeFactors, p ^ a.factorization p) = a := by
        calc
          (∏ p ∈ a.primeFactors, p ^ a.factorization p)
              = a.factorization.prod (fun p e => p ^ e) := by
                exact (Finsupp.prod_of_support_subset a.factorization
                  (by intro p hp; exact hp)
                  (fun p e => p ^ e) (by intro p _hp; simp)).symm
          _ = a := Nat.factorization_prod_pow_eq_self ha_ne
      have hprod : (∏ p ∈ a.primeFactors, (p : ℝ) ^ a.factorization p) =
          (a : ℝ) := by
        exact_mod_cast hprod_nat
      rw [hprod]
    · intro p _hp
      exact pow_nonneg (Nat.cast_nonneg p) _
  rw [hcast]
  calc
    (∏ p ∈ a.primeFactors, (((a ^ 2).factorization p + 1 : ℕ) : ℝ))
        ≤ ∏ p ∈ a.primeFactors,
          tauSquareSubpowerPrimeCoeff η Y p *
            (p : ℝ) ^ (((a.factorization p : ℕ) : ℝ) * η) := hprod_le
    _ = (∏ p ∈ a.primeFactors, tauSquareSubpowerPrimeCoeff η Y p) *
          ∏ p ∈ a.primeFactors,
            (p : ℝ) ^ (((a.factorization p : ℕ) : ℝ) * η) := hsplit
    _ ≤ K * (a : ℝ) ^ η := by
          rw [hpow_eq]
          exact mul_le_mul_of_nonneg_right hcoeff
            (Real.rpow_nonneg (Nat.cast_nonneg a) _)

private noncomputable def tauSquarePrimeCoeff (p : ℕ) : ℝ :=
  if p < 81 then 30 else 1

private theorem tauSquarePrimeCoeff_prod_le (s : Finset ℕ) :
    (∏ p ∈ s, tauSquarePrimeCoeff p) ≤ tauSquareQuarterConstant := by
  classical
  let small := s.filter (fun p => p < 81)
  have hsplit :
      (∏ p ∈ s, tauSquarePrimeCoeff p) =
        (∏ p ∈ small, tauSquarePrimeCoeff p) *
          (∏ p ∈ s.filter (fun p => ¬ p < 81), tauSquarePrimeCoeff p) := by
    dsimp [small]
    rw [Finset.prod_filter_mul_prod_filter_not]
  have hsmall_prod : (∏ p ∈ small, tauSquarePrimeCoeff p) = 30 ^ small.card := by
    calc
      (∏ p ∈ small, tauSquarePrimeCoeff p) = ∏ _p ∈ small, (30 : ℝ) := by
        apply Finset.prod_congr rfl
        intro p hp
        have hp_lt : p < 81 := (Finset.mem_filter.mp hp).2
        simp [tauSquarePrimeCoeff, hp_lt]
      _ = 30 ^ small.card := Finset.prod_const 30
  have hlarge_prod :
      (∏ p ∈ s.filter (fun p => ¬ p < 81), tauSquarePrimeCoeff p) = 1 := by
    calc
      (∏ p ∈ s.filter (fun p => ¬ p < 81), tauSquarePrimeCoeff p) =
          ∏ _p ∈ s.filter (fun p => ¬ p < 81), (1 : ℝ) := by
        apply Finset.prod_congr rfl
        intro p hp
        have hp_not : ¬ p < 81 := (Finset.mem_filter.mp hp).2
        simp [tauSquarePrimeCoeff, hp_not]
      _ = 1 := by simp
  have hcard : small.card ≤ 81 := by
    have hsubset : small ⊆ Finset.range 81 := by
      intro p hp
      exact Finset.mem_range.mpr ((Finset.mem_filter.mp hp).2)
    exact (Finset.card_le_card hsubset).trans (by simp)
  calc
    (∏ p ∈ s, tauSquarePrimeCoeff p)
        = 30 ^ small.card * 1 := by rw [hsplit, hsmall_prod, hlarge_prod]
    _ = 30 ^ small.card := by ring
    _ ≤ 30 ^ (81 : ℕ) := by
          exact pow_le_pow_right₀ (by norm_num : (1 : ℝ) ≤ 30) hcard
    _ = tauSquareQuarterConstant := by rfl

private theorem tau_square_prime_factor_term_le_coeff (a p : ℕ)
    (hp : p ∈ a.primeFactors) :
    (((a ^ 2).factorization p + 1 : ℕ) : ℝ) ≤
      tauSquarePrimeCoeff p * (p : ℝ) ^ (((a.factorization p : ℕ) : ℝ) / 4) := by
  classical
  have hpprime : Nat.Prime p := Nat.prime_of_mem_primeFactors hp
  have hp2_nat : 2 ≤ p := hpprime.two_le
  have hfactor : (a ^ 2).factorization p + 1 = 2 * a.factorization p + 1 := by
    rw [Nat.factorization_pow]
    simp [Finsupp.smul_apply, smul_eq_mul, mul_comm, mul_left_comm, mul_assoc]
  by_cases hsmall : p < 81
  · have htwo := two_mul_add_one_le_thirty_mul_two_rpow_quarter (a.factorization p)
    have hbase : (2 : ℝ) ^ (((a.factorization p : ℕ) : ℝ) / 4) ≤
        (p : ℝ) ^ (((a.factorization p : ℕ) : ℝ) / 4) := by
      exact Real.rpow_le_rpow (by norm_num : (0 : ℝ) ≤ 2)
        (by exact_mod_cast hp2_nat)
        (by positivity)
    calc
      (((a ^ 2).factorization p + 1 : ℕ) : ℝ)
          = ((2 * a.factorization p + 1 : ℕ) : ℝ) := by rw [hfactor]
      _ ≤ 30 * (2 : ℝ) ^ (((a.factorization p : ℕ) : ℝ) / 4) := htwo
      _ ≤ 30 * (p : ℝ) ^ (((a.factorization p : ℕ) : ℝ) / 4) := by
            exact mul_le_mul_of_nonneg_left hbase (by norm_num)
      _ = tauSquarePrimeCoeff p *
            (p : ℝ) ^ (((a.factorization p : ℕ) : ℝ) / 4) := by
            simp [tauSquarePrimeCoeff, hsmall]
  · have hlarge_nat : 81 ≤ p := Nat.le_of_not_lt hsmall
    have hlarge := two_mul_add_one_le_large_rpow_quarter (p := p)
      (e := a.factorization p) hlarge_nat
    calc
      (((a ^ 2).factorization p + 1 : ℕ) : ℝ)
          = ((2 * a.factorization p + 1 : ℕ) : ℝ) := by rw [hfactor]
      _ ≤ (p : ℝ) ^ (((a.factorization p : ℕ) : ℝ) / 4) := hlarge
      _ = tauSquarePrimeCoeff p *
            (p : ℝ) ^ (((a.factorization p : ℕ) : ℝ) / 4) := by
            simp [tauSquarePrimeCoeff, hsmall]

/-- Checked pointwise divisor-growth estimate sufficient for the composite
part of `prop:coprime-barrier`: `τ(a²) ≪ a^(1/4)`. -/
theorem tau_square_le_const_rpow_quarter {a : ℕ} (ha : 1 ≤ a) :
    ((tau (a ^ 2) : ℕ) : ℝ) ≤
      tauSquareQuarterConstant * (a : ℝ) ^ ((1 : ℝ) / 4) := by
  classical
  have ha_ne : a ≠ 0 := by omega
  have ha2_ne : a ^ 2 ≠ 0 := pow_ne_zero 2 ha_ne
  have hcast : ((tau (a ^ 2) : ℕ) : ℝ) =
      ∏ p ∈ a.primeFactors, (((a ^ 2).factorization p + 1 : ℕ) : ℝ) := by
    unfold tau
    rw [Nat.card_divisors ha2_ne]
    rw [Nat.primeFactors_pow a (by norm_num : (2 : ℕ) ≠ 0)]
    norm_num
  have hprod_le :
      (∏ p ∈ a.primeFactors, (((a ^ 2).factorization p + 1 : ℕ) : ℝ)) ≤
        ∏ p ∈ a.primeFactors,
          tauSquarePrimeCoeff p * (p : ℝ) ^ (((a.factorization p : ℕ) : ℝ) / 4) := by
    exact Finset.prod_le_prod
      (fun _p _hp => Nat.cast_nonneg _)
      (fun p hp => tau_square_prime_factor_term_le_coeff a p hp)
  have hsplit :
      (∏ p ∈ a.primeFactors,
          tauSquarePrimeCoeff p * (p : ℝ) ^ (((a.factorization p : ℕ) : ℝ) / 4)) =
        (∏ p ∈ a.primeFactors, tauSquarePrimeCoeff p) *
          ∏ p ∈ a.primeFactors, (p : ℝ) ^ (((a.factorization p : ℕ) : ℝ) / 4) := by
    rw [Finset.prod_mul_distrib]
  have hcoeff := tauSquarePrimeCoeff_prod_le a.primeFactors
  have hpow_eq :
      (∏ p ∈ a.primeFactors, (p : ℝ) ^ (((a.factorization p : ℕ) : ℝ) / 4)) =
        (a : ℝ) ^ ((1 : ℝ) / 4) := by
    have hrewrite :
        (∏ p ∈ a.primeFactors, (p : ℝ) ^ (((a.factorization p : ℕ) : ℝ) / 4)) =
          ∏ p ∈ a.primeFactors, ((p : ℝ) ^ a.factorization p) ^ ((1 : ℝ) / 4) := by
      apply Finset.prod_congr rfl
      intro p _hp
      rw [← Real.rpow_natCast, ← Real.rpow_mul (Nat.cast_nonneg p)]
      ring_nf
    rw [hrewrite, Real.finset_prod_rpow]
    · have hprod_nat : (∏ p ∈ a.primeFactors, p ^ a.factorization p) = a := by
        calc
          (∏ p ∈ a.primeFactors, p ^ a.factorization p)
              = a.factorization.prod (fun p e => p ^ e) := by
                exact (Finsupp.prod_of_support_subset a.factorization
                  (by intro p hp; exact hp)
                  (fun p e => p ^ e) (by intro p _hp; simp)).symm
          _ = a := Nat.factorization_prod_pow_eq_self ha_ne
      have hprod : (∏ p ∈ a.primeFactors, (p : ℝ) ^ a.factorization p) =
          (a : ℝ) := by
        exact_mod_cast hprod_nat
      rw [hprod]
    · intro p _hp
      exact pow_nonneg (Nat.cast_nonneg p) _
  rw [hcast]
  calc
    (∏ p ∈ a.primeFactors, (((a ^ 2).factorization p + 1 : ℕ) : ℝ))
        ≤ ∏ p ∈ a.primeFactors,
          tauSquarePrimeCoeff p *
            (p : ℝ) ^ (((a.factorization p : ℕ) : ℝ) / 4) := hprod_le
    _ = (∏ p ∈ a.primeFactors, tauSquarePrimeCoeff p) *
          ∏ p ∈ a.primeFactors,
            (p : ℝ) ^ (((a.factorization p : ℕ) : ℝ) / 4) := hsplit
    _ ≤ tauSquareQuarterConstant * (a : ℝ) ^ ((1 : ℝ) / 4) := by
          rw [hpow_eq]
          exact mul_le_mul_of_nonneg_right hcoeff
            (Real.rpow_nonneg (Nat.cast_nonneg a) _)

/-- Paper-facing pairwise-coprime barrier with the composite divisor-growth
step discharged by the checked concrete `τ(a²) ≪ a^(1/4)` bound. -/
theorem pairwiseSubfanMass_upper_log_square_of_weighted_titchmarsh_and_tau_square_quarter :
    ∃ C L₀ : ℝ, 0 < C ∧ ∀ L : ℝ, L₀ ≤ L → ∀ B : Finset ℕ,
      pairwiseFanModuliCoprime B →
      pairwiseSubfanMass L B ≤ C * (Real.log L) ^ (2 : ℝ) := by
  exact
    pairwiseSubfanMass_upper_log_square_of_weighted_titchmarsh_and_tau_square_subpower
      (K := tauSquareQuarterConstant) (η := (1 : ℝ) / 4)
      (by dsimp [tauSquareQuarterConstant]; positivity)
      (by norm_num) (by norm_num)
      (fun a ha => tau_square_le_const_rpow_quarter ha)

/-- The prime-restricted Titchmarsh divisor carrier is bounded by the unrestricted
cubic divisor carrier over the same cutoff. -/
theorem titchSum_le_tauSqSum (L : ℝ) : titchSum L ≤ tauSqSum L := by
  classical
  unfold titchSum tauSqSum
  apply Finset.sum_le_sum_of_subset_of_nonneg
  · intro a ha
    exact (Finset.mem_filter.mp ha).1
  · intro a _haBig _haSmall
    exact div_nonneg (Nat.cast_nonneg _) (Nat.cast_nonneg a)

/-- Elementary linear envelope `∑_{n≤L} n` for the cubic divisor carriers. -/
noncomputable def tauSqLinearEnvelope (L : ℝ) : ℝ :=
  ∑ n ∈ Finset.Icc (1 : ℕ) ⌊L⌋₊, (n : ℝ)

/-- The summand `τ(n²)/n` is bounded by `n` for `n ≥ 1`. -/
theorem tauSq_summand_le_self (n : ℕ) (hn : 1 ≤ n) :
    ((tau (n ^ 2) : ℕ) : ℝ) / (n : ℝ) ≤ (n : ℝ) := by
  have hnpos_nat : 0 < n := lt_of_lt_of_le Nat.zero_lt_one hn
  have hnpos : (0 : ℝ) < (n : ℝ) := by exact_mod_cast hnpos_nat
  have htau : ((tau (n ^ 2) : ℕ) : ℝ) ≤ ((n ^ 2 : ℕ) : ℝ) := by
    exact_mod_cast tau_le_self (n ^ 2)
  calc
    ((tau (n ^ 2) : ℕ) : ℝ) / (n : ℝ)
        ≤ ((n ^ 2 : ℕ) : ℝ) / (n : ℝ) :=
          div_le_div_of_nonneg_right htau hnpos.le
    _ = (n : ℝ) := by
          norm_num [Nat.cast_pow]
          field_simp [ne_of_gt hnpos]
          ring

/-- The cubic divisor carrier is bounded by the elementary linear envelope over
the same cutoff.  This is much weaker than the Selberg-Delange cubic logarithmic
asymptotic, but is unconditional. -/
theorem tauSqSum_le_linearEnvelope (L : ℝ) :
    tauSqSum L ≤ tauSqLinearEnvelope L := by
  classical
  unfold tauSqSum tauSqLinearEnvelope
  apply Finset.sum_le_sum
  intro n hn
  exact tauSq_summand_le_self n (Finset.mem_Icc.mp hn).1

/-- The weighted Titchmarsh carrier is also bounded by the same elementary
linear envelope. -/
theorem titchSum_le_linearEnvelope (L : ℝ) :
    titchSum L ≤ tauSqLinearEnvelope L :=
  le_trans (titchSum_le_tauSqSum L) (tauSqSum_le_linearEnvelope L)

/-- The cubic divisor carrier is bounded by the already-checked harmonic-fourth
envelope for `∑ τ(n)^2/n`.  This is elementary and much stronger than the old
same-cutoff polynomial fallback, though it is still not the sharp
Selberg--Delange asymptotic. -/
theorem tauSqSum_le_harmonic_fourth (L : ℝ) :
    tauSqSum L ≤ ((harmonic ⌊L⌋₊ : ℚ) : ℝ) ^ 4 := by
  classical
  have hto_tau_sq :
      tauSqSum L
        ≤ ∑ n ∈ Finset.Icc (1 : ℕ) ⌊L⌋₊,
            ((tau n ^ 2 : ℕ) : ℝ) / (n : ℝ) := by
    unfold tauSqSum
    apply Finset.sum_le_sum
    intro n _hn
    have hn_nonneg : (0 : ℝ) ≤ (n : ℝ) := Nat.cast_nonneg n
    have hcmp : ((tau (n ^ 2) : ℕ) : ℝ) ≤ ((tau n ^ 2 : ℕ) : ℝ) := by
      exact_mod_cast tau_square_le_tau_sq n
    exact div_le_div_of_nonneg_right hcmp hn_nonneg
  exact le_trans hto_tau_sq (tau_sq_div_self_sum_le_harmonic_fourth ⌊L⌋₊)

/-- Absolute-value harmonic-fourth bound for the cubic divisor carrier. -/
theorem abs_tauSqSum_le_harmonic_fourth (L : ℝ) :
    |tauSqSum L| ≤ ((harmonic ⌊L⌋₊ : ℚ) : ℝ) ^ 4 := by
  rw [abs_of_nonneg (tauSqSum_nonneg L)]
  exact tauSqSum_le_harmonic_fourth L

/-- The prime-restricted weighted Titchmarsh carrier inherits the same
harmonic-fourth envelope. -/
theorem titchSum_le_harmonic_fourth (L : ℝ) :
    titchSum L ≤ ((harmonic ⌊L⌋₊ : ℚ) : ℝ) ^ 4 :=
  le_trans (titchSum_le_tauSqSum L) (tauSqSum_le_harmonic_fourth L)

/-- Absolute-value harmonic-fourth bound for the weighted Titchmarsh carrier. -/
theorem abs_titchSum_le_harmonic_fourth (L : ℝ) :
    |titchSum L| ≤ ((harmonic ⌊L⌋₊ : ℚ) : ℝ) ^ 4 := by
  rw [abs_of_nonneg (titchSum_nonneg L)]
  exact titchSum_le_harmonic_fourth L

/-- Checked logarithmic fourth-power fallback for
`∑_{n≤L} τ(n²)/n`.  This uses only the divisor-count comparison
`τ(n²) ≤ τ(n)^2`, the existing hyperbola proof
`∑ τ(n)^2/n ≤ H_L^4`, and the harmonic-series bound. -/
theorem tauSqSum_upper_log_fourth_unconditional :
    ∃ C E L₀ : ℝ, 0 < C ∧ ∀ L : ℝ, L₀ ≤ L →
      |tauSqSum L| ≤ C * (Real.log L) ^ E := by
  refine ⟨16, 4, Real.exp 1, by norm_num, ?_⟩
  intro L hL
  have hLpos : 0 < L := lt_of_lt_of_le (Real.exp_pos 1) hL
  have hL_ge_one : 1 ≤ L := le_trans (by norm_num : (1 : ℝ) ≤ Real.exp 1) hL
  have hlogL_ge_one : 1 ≤ Real.log L := by
    rw [Real.le_log_iff_exp_le hLpos]
    exact hL
  have hharm : ((harmonic ⌊L⌋₊ : ℚ) : ℝ) ≤ 1 + Real.log L :=
    harmonic_floor_le_one_add_log L hL_ge_one
  have htail : 1 + Real.log L ≤ 2 * Real.log L := by
    linarith
  have hharm_log : ((harmonic ⌊L⌋₊ : ℚ) : ℝ) ≤ 2 * Real.log L :=
    le_trans hharm htail
  have hharm_nonneg : 0 ≤ ((harmonic ⌊L⌋₊ : ℚ) : ℝ) := by
    rw [harmonic_eq_sum_Icc]
    simp only [Rat.cast_sum, Rat.cast_inv, Rat.cast_natCast]
    apply Finset.sum_nonneg
    intro n _hn
    exact inv_nonneg.mpr (Nat.cast_nonneg n)
  calc
    |tauSqSum L|
        ≤ ((harmonic ⌊L⌋₊ : ℚ) : ℝ) ^ 4 :=
          abs_tauSqSum_le_harmonic_fourth L
    _ ≤ (2 * Real.log L) ^ 4 :=
          pow_le_pow_left₀ hharm_nonneg hharm_log 4
    _ = 16 * (Real.log L) ^ (4 : ℝ) := by
          have hlog4 : (Real.log L) ^ (4 : ℝ) = (Real.log L) ^ (4 : ℕ) :=
            Real.rpow_natCast (Real.log L) 4
          rw [hlog4]
          ring

/-- Checked logarithmic fourth-power fallback for the prime-restricted weighted
Titchmarsh carrier.  The genuine Titchmarsh theorem would give the sharp
constant/order, but this same-carrier estimate is already polylogarithmic and
requires no new axiom. -/
theorem titchSum_upper_log_fourth_unconditional :
    ∃ C E L₀ : ℝ, 0 < C ∧ ∀ L : ℝ, L₀ ≤ L →
      |titchSum L| ≤ C * (Real.log L) ^ E := by
  refine ⟨16, 4, Real.exp 1, by norm_num, ?_⟩
  intro L hL
  have hLpos : 0 < L := lt_of_lt_of_le (Real.exp_pos 1) hL
  have hL_ge_one : 1 ≤ L := le_trans (by norm_num : (1 : ℝ) ≤ Real.exp 1) hL
  have hlogL_ge_one : 1 ≤ Real.log L := by
    rw [Real.le_log_iff_exp_le hLpos]
    exact hL
  have hharm : ((harmonic ⌊L⌋₊ : ℚ) : ℝ) ≤ 1 + Real.log L :=
    harmonic_floor_le_one_add_log L hL_ge_one
  have htail : 1 + Real.log L ≤ 2 * Real.log L := by
    linarith
  have hharm_log : ((harmonic ⌊L⌋₊ : ℚ) : ℝ) ≤ 2 * Real.log L :=
    le_trans hharm htail
  have hharm_nonneg : 0 ≤ ((harmonic ⌊L⌋₊ : ℚ) : ℝ) := by
    rw [harmonic_eq_sum_Icc]
    simp only [Rat.cast_sum, Rat.cast_inv, Rat.cast_natCast]
    apply Finset.sum_nonneg
    intro n _hn
    exact inv_nonneg.mpr (Nat.cast_nonneg n)
  calc
    |titchSum L|
        ≤ ((harmonic ⌊L⌋₊ : ℚ) : ℝ) ^ 4 :=
          abs_titchSum_le_harmonic_fourth L
    _ ≤ (2 * Real.log L) ^ 4 :=
          pow_le_pow_left₀ hharm_nonneg hharm_log 4
    _ = 16 * (Real.log L) ^ (4 : ℝ) := by
          have hlog4 : (Real.log L) ^ (4 : ℝ) = (Real.log L) ^ (4 : ℕ) :=
            Real.rpow_natCast (Real.log L) 4
          rw [hlog4]
          ring

/-- The elementary linear envelope is bounded by `L²`.  For negative cutoffs,
the natural floor makes the finite range empty. -/
theorem tauSqLinearEnvelope_le_sq (L : ℝ) :
    tauSqLinearEnvelope L ≤ L ^ 2 := by
  classical
  by_cases hL : 0 ≤ L
  ·
    have hterm :
        tauSqLinearEnvelope L ≤ ∑ n ∈ Finset.Icc (1 : ℕ) ⌊L⌋₊, L := by
      unfold tauSqLinearEnvelope
      apply Finset.sum_le_sum
      intro n hn
      have hn_le_floor : n ≤ ⌊L⌋₊ := (Finset.mem_Icc.mp hn).2
      have hn_le_L : (n : ℝ) ≤ L := by
        exact le_trans (by exact_mod_cast hn_le_floor) (Nat.floor_le hL)
      exact hn_le_L
    have hcard_eq :
        ((Finset.Icc (1 : ℕ) ⌊L⌋₊).card : ℝ) = (⌊L⌋₊ : ℝ) := by
      have hcard_nat : (Finset.Icc (1 : ℕ) ⌊L⌋₊).card = ⌊L⌋₊ := by
        cases ⌊L⌋₊ <;> simp
      exact_mod_cast hcard_nat
    calc
      tauSqLinearEnvelope L ≤ ∑ n ∈ Finset.Icc (1 : ℕ) ⌊L⌋₊, L := hterm
      _ = ((Finset.Icc (1 : ℕ) ⌊L⌋₊).card : ℝ) * L := by simp
      _ = (⌊L⌋₊ : ℝ) * L := by rw [hcard_eq]
      _ ≤ L * L := mul_le_mul_of_nonneg_right (Nat.floor_le hL) hL
      _ = L ^ 2 := by ring
  ·
    have hLneg : L < 0 := lt_of_not_ge hL
    have hLlt_one : L < 1 := by linarith
    have hfloor : ⌊L⌋₊ = 0 := Nat.floor_eq_zero.mpr hLlt_one
    have hsum_zero : tauSqLinearEnvelope L = 0 := by
      unfold tauSqLinearEnvelope
      simp [hfloor]
    rw [hsum_zero]
    exact sq_nonneg L

/-- Polynomial fallback for the cubic divisor carrier.  This is far weaker than
the Tauberian cubic-logarithmic asymptotic. -/
theorem tauSqSum_le_sq (L : ℝ) :
    tauSqSum L ≤ L ^ 2 :=
  le_trans (tauSqSum_le_linearEnvelope L) (tauSqLinearEnvelope_le_sq L)

/-- Absolute-value form of the polynomial cubic divisor fallback. -/
theorem abs_tauSqSum_le_sq (L : ℝ) :
    |tauSqSum L| ≤ L ^ 2 := by
  rw [abs_of_nonneg (tauSqSum_nonneg L)]
  exact tauSqSum_le_sq L

/-- Polynomial fallback for the prime-restricted weighted Titchmarsh carrier. -/
theorem titchSum_le_sq (L : ℝ) :
    titchSum L ≤ L ^ 2 :=
  le_trans (titchSum_le_linearEnvelope L) (tauSqLinearEnvelope_le_sq L)

/-- Absolute-value form of the polynomial Titchmarsh fallback. -/
theorem abs_titchSum_le_sq (L : ℝ) :
    |titchSum L| ≤ L ^ 2 := by
  rw [abs_of_nonneg (titchSum_nonneg L)]
  exact titchSum_le_sq L

/-- Manuscript-shaped unconditional fallback for the weighted Titchmarsh carrier.
This old polynomial envelope is kept as a coarse same-carrier sanity check; the
stronger checked logarithmic fallback is
`titchSum_upper_log_fourth_unconditional`. -/
theorem titchSum_upper_unconditional :
    ∃ C L₀ : ℝ, 0 < C ∧ ∀ L : ℝ, L₀ ≤ L →
      |titchSum L| ≤ C * L ^ 2 := by
  refine ⟨1, 0, by norm_num, ?_⟩
  intro L _hL
  simpa using abs_titchSum_le_sq L

/-!
The cubic `τ(n²)` reciprocal asymptotic from Selberg-Delange/Perron is now an
explicit cited input above.  The checked `tauSqSum_upper_log_fourth_unconditional`
and `titchSum_upper_log_fourth_unconditional` remain useful elementary
same-carrier sanity checks, but they are not a replacement for the sharp cited
input.
-/

/-- The local-obstruction divisor-count carrier is nonnegative. -/
theorem localObstrCount_nonneg (L : ℝ) (M aM u : ℕ) :
    0 ≤ localObstrCount L M aM u := by
  classical
  unfold localObstrCount
  apply Finset.sum_nonneg
  intro a _ha
  unfold localObstrFiber
  exact Nat.cast_nonneg _

/-- Unweighted square-divisor envelope `∑_{a≤L} τ(a²)` for local obstruction
counts. -/
noncomputable def divisorSquareCount (L : ℝ) : ℝ :=
  ∑ a ∈ Finset.Icc (1 : ℕ) ⌊L⌋₊, ((tau (a ^ 2) : ℕ) : ℝ)

/-- The unweighted square-divisor envelope is nonnegative. -/
theorem divisorSquareCount_nonneg (L : ℝ) : 0 ≤ divisorSquareCount L := by
  classical
  unfold divisorSquareCount
  apply Finset.sum_nonneg
  intro a _ha
  exact Nat.cast_nonneg _

/-- Elementary square-power envelope `∑_{a≤L} a²` for unweighted square-divisor
counts. -/
noncomputable def divisorSquarePowerEnvelope (L : ℝ) : ℝ :=
  ∑ a ∈ Finset.Icc (1 : ℕ) ⌊L⌋₊, (a : ℝ) ^ 2

/-- Each local-obstruction divisor fiber is bounded by all divisors of `a²`. -/
theorem localObstrFiber_le_tau (M u a : ℕ) :
    localObstrFiber M u a ≤ ((tau (a ^ 2) : ℕ) : ℝ) := by
  classical
  unfold localObstrFiber tau
  exact_mod_cast Finset.card_le_card (Finset.filter_subset _ _)

/-- The local-obstruction carrier is bounded by the unweighted square-divisor
envelope over the same cutoff. -/
theorem localObstrCount_le_divisorSquareCount (L : ℝ) (M aM u : ℕ) :
    localObstrCount L M aM u ≤ divisorSquareCount L := by
  classical
  unfold localObstrCount divisorSquareCount
  calc
    (∑ a ∈ (Finset.Icc (1 : ℕ) ⌊L⌋₊).filter (fun a => congMod a aM M),
        localObstrFiber M u a)
        ≤ ∑ a ∈ (Finset.Icc (1 : ℕ) ⌊L⌋₊).filter (fun a => congMod a aM M),
            ((tau (a ^ 2) : ℕ) : ℝ) := by
          apply Finset.sum_le_sum
          intro a _ha
          exact localObstrFiber_le_tau M u a
    _ ≤ ∑ a ∈ Finset.Icc (1 : ℕ) ⌊L⌋₊, ((tau (a ^ 2) : ℕ) : ℝ) := by
          apply Finset.sum_le_sum_of_subset_of_nonneg
          · intro a ha
            exact (Finset.mem_filter.mp ha).1
          · intro a _haBig _haSmall
            exact Nat.cast_nonneg _

/-- The unweighted square-divisor envelope is bounded by `L` times the reciprocal
square-divisor carrier.  This upgrades local-obstruction fallbacks from a
polynomial square-power envelope to the logarithmic information already proved
for `tauSqSum`. -/
theorem divisorSquareCount_le_mul_tauSqSum (L : ℝ) (hL : 0 ≤ L) :
    divisorSquareCount L ≤ L * tauSqSum L := by
  classical
  unfold divisorSquareCount tauSqSum
  rw [Finset.mul_sum]
  apply Finset.sum_le_sum
  intro a ha
  have hapos_nat : 0 < a :=
    lt_of_lt_of_le Nat.zero_lt_one (Finset.mem_Icc.mp ha).1
  have hapos : (0 : ℝ) < (a : ℝ) := by exact_mod_cast hapos_nat
  have ha_le_floor : a ≤ ⌊L⌋₊ := (Finset.mem_Icc.mp ha).2
  have ha_le_L : (a : ℝ) ≤ L := by
    exact le_trans (by exact_mod_cast ha_le_floor) (Nat.floor_le hL)
  have htau_nonneg : 0 ≤ ((tau (a ^ 2) : ℕ) : ℝ) := Nat.cast_nonneg _
  calc
    ((tau (a ^ 2) : ℕ) : ℝ)
        = (a : ℝ) * (((tau (a ^ 2) : ℕ) : ℝ) / (a : ℝ)) := by
          field_simp [ne_of_gt hapos]
    _ ≤ L * (((tau (a ^ 2) : ℕ) : ℝ) / (a : ℝ)) := by
          exact mul_le_mul_of_nonneg_right ha_le_L
            (div_nonneg htau_nonneg hapos.le)

/-- Absolute-value form of the logarithmic square-divisor envelope. -/
theorem abs_divisorSquareCount_le_mul_tauSqSum (L : ℝ) (hL : 0 ≤ L) :
    |divisorSquareCount L| ≤ L * tauSqSum L := by
  rw [abs_of_nonneg (divisorSquareCount_nonneg L)]
  exact divisorSquareCount_le_mul_tauSqSum L hL

/-- The local-obstruction carrier is bounded by `L · tauSqSum L`. -/
theorem localObstrCount_le_mul_tauSqSum (L : ℝ) (M aM u : ℕ) (hL : 0 ≤ L) :
    localObstrCount L M aM u ≤ L * tauSqSum L :=
  le_trans (localObstrCount_le_divisorSquareCount L M aM u)
    (divisorSquareCount_le_mul_tauSqSum L hL)

/-- Absolute-value form of the `L · tauSqSum L` local-obstruction envelope. -/
theorem abs_localObstrCount_le_mul_tauSqSum (L : ℝ) (M aM u : ℕ) (hL : 0 ≤ L) :
    |localObstrCount L M aM u| ≤ L * tauSqSum L := by
  rw [abs_of_nonneg (localObstrCount_nonneg L M aM u)]
  exact localObstrCount_le_mul_tauSqSum L M aM u hL

/-- Paper-facing Selberg--Delange/Perron consequence for the local-obstruction
carrier: the checked reduction to `L · tauSqSum L` plus the cited cubic
`tauSqSum` estimate gives `localObstrCount L M aM u ≪ L (log L)^3`. -/
theorem localObstrCount_upper_L_log_cubic_of_selberg_delange (M aM u : ℕ) :
    ∃ C E L₀ : ℝ, 0 < C ∧ ∀ L : ℝ, L₀ ≤ L →
      |localObstrCount L M aM u| ≤ C * L * (Real.log L) ^ E := by
  rcases tauSqSum_upper_log_cubic_of_selberg_delange with ⟨C, L₀, hC, htau⟩
  refine ⟨C, 3, max L₀ 1, hC, ?_⟩
  intro L hL
  have hL₀ : L₀ ≤ L := le_trans (le_max_left L₀ 1) hL
  have hL_nonneg : 0 ≤ L := by
    exact le_trans (by norm_num : (0 : ℝ) ≤ 1) (le_trans (le_max_right L₀ 1) hL)
  have htau_abs : |tauSqSum L| ≤ C * (Real.log L) ^ (3 : ℝ) := htau L hL₀
  have htau_nonneg : 0 ≤ tauSqSum L := tauSqSum_nonneg L
  have hlocal_nonneg : 0 ≤ localObstrCount L M aM u :=
    localObstrCount_nonneg L M aM u
  calc
    |localObstrCount L M aM u|
        = localObstrCount L M aM u := abs_of_nonneg hlocal_nonneg
    _ ≤ L * tauSqSum L := localObstrCount_le_mul_tauSqSum L M aM u hL_nonneg
    _ = L * |tauSqSum L| := by rw [abs_of_nonneg htau_nonneg]
    _ ≤ L * (C * (Real.log L) ^ (3 : ℝ)) :=
          mul_le_mul_of_nonneg_left htau_abs hL_nonneg
    _ = C * L * (Real.log L) ^ (3 : ℝ) := by ring

/-- Logarithmic fourth-power fallback for local-obstruction counts:
`localObstrCount L M aM u ≪ L (log L)^4`.

The sharp local-obstruction asymptotic is still Selberg--Delange/Perron debt,
but this same-carrier upper bound reuses the checked `tauSqSum` logarithmic
envelope instead of the older `L^3` polynomial envelope. -/
theorem localObstrCount_upper_L_log_fourth_unconditional (M aM u : ℕ) :
    ∃ C E L₀ : ℝ, 0 < C ∧ ∀ L : ℝ, L₀ ≤ L →
      |localObstrCount L M aM u| ≤ C * L * (Real.log L) ^ E := by
  refine ⟨16, 4, Real.exp 1, by norm_num, ?_⟩
  intro L hL
  have hLpos : 0 < L := lt_of_lt_of_le (Real.exp_pos 1) hL
  have hL_nonneg : 0 ≤ L :=
    le_trans (by positivity : (0 : ℝ) ≤ Real.exp 1) hL
  have hL_ge_one : 1 ≤ L := le_trans (by norm_num : (1 : ℝ) ≤ Real.exp 1) hL
  have hlogL_ge_one : 1 ≤ Real.log L := by
    rw [Real.le_log_iff_exp_le hLpos]
    exact hL
  have hharm : ((harmonic ⌊L⌋₊ : ℚ) : ℝ) ≤ 1 + Real.log L :=
    harmonic_floor_le_one_add_log L hL_ge_one
  have htail : 1 + Real.log L ≤ 2 * Real.log L := by
    linarith
  have hharm_log : ((harmonic ⌊L⌋₊ : ℚ) : ℝ) ≤ 2 * Real.log L :=
    le_trans hharm htail
  have hharm_nonneg : 0 ≤ ((harmonic ⌊L⌋₊ : ℚ) : ℝ) := by
    rw [harmonic_eq_sum_Icc]
    simp only [Rat.cast_sum, Rat.cast_inv, Rat.cast_natCast]
    apply Finset.sum_nonneg
    intro n _hn
    exact inv_nonneg.mpr (Nat.cast_nonneg n)
  have htau : |tauSqSum L| ≤ 16 * (Real.log L) ^ (4 : ℝ) := by
    calc
      |tauSqSum L|
          ≤ ((harmonic ⌊L⌋₊ : ℚ) : ℝ) ^ 4 :=
            abs_tauSqSum_le_harmonic_fourth L
      _ ≤ (2 * Real.log L) ^ 4 :=
            pow_le_pow_left₀ hharm_nonneg hharm_log 4
      _ = 16 * (Real.log L) ^ (4 : ℝ) := by
            have hlog4 : (Real.log L) ^ (4 : ℝ) = (Real.log L) ^ (4 : ℕ) :=
              Real.rpow_natCast (Real.log L) 4
            rw [hlog4]
            ring
  have htau_nonneg : 0 ≤ tauSqSum L := tauSqSum_nonneg L
  have hlocal_nonneg : 0 ≤ localObstrCount L M aM u :=
    localObstrCount_nonneg L M aM u
  calc
    |localObstrCount L M aM u|
        = localObstrCount L M aM u := abs_of_nonneg hlocal_nonneg
    _ ≤ L * tauSqSum L := localObstrCount_le_mul_tauSqSum L M aM u hL_nonneg
    _ = L * |tauSqSum L| := by rw [abs_of_nonneg htau_nonneg]
    _ ≤ L * (16 * (Real.log L) ^ (4 : ℝ)) :=
          mul_le_mul_of_nonneg_left htau hL_nonneg
    _ = 16 * L * (Real.log L) ^ (4 : ℝ) := by ring

/-- The unweighted square-divisor count is bounded by the elementary square-power
envelope. -/
theorem divisorSquareCount_le_squarePowerEnvelope (L : ℝ) :
    divisorSquareCount L ≤ divisorSquarePowerEnvelope L := by
  classical
  unfold divisorSquareCount divisorSquarePowerEnvelope
  apply Finset.sum_le_sum
  intro a _ha
  have htau : ((tau (a ^ 2) : ℕ) : ℝ) ≤ ((a ^ 2 : ℕ) : ℝ) := by
    exact_mod_cast tau_le_self (a ^ 2)
  simpa [Nat.cast_pow] using htau

/-- Absolute-value form of the elementary square-power envelope. -/
theorem abs_divisorSquareCount_le_squarePowerEnvelope (L : ℝ) :
    |divisorSquareCount L| ≤ divisorSquarePowerEnvelope L := by
  rw [abs_of_nonneg (divisorSquareCount_nonneg L)]
  exact divisorSquareCount_le_squarePowerEnvelope L

/-- Consequently, the local-obstruction carrier is bounded by a polynomial
same-cutoff envelope. -/
theorem localObstrCount_le_squarePowerEnvelope (L : ℝ) (M aM u : ℕ) :
    localObstrCount L M aM u ≤ divisorSquarePowerEnvelope L :=
  le_trans (localObstrCount_le_divisorSquareCount L M aM u)
    (divisorSquareCount_le_squarePowerEnvelope L)

/-- Absolute-value form of the elementary square-power local-obstruction envelope. -/
theorem abs_localObstrCount_le_squarePowerEnvelope (L : ℝ) (M aM u : ℕ) :
    |localObstrCount L M aM u| ≤ divisorSquarePowerEnvelope L := by
  rw [abs_of_nonneg (localObstrCount_nonneg L M aM u)]
  exact localObstrCount_le_squarePowerEnvelope L M aM u

/-- The square-power envelope is bounded by `L³` for nonnegative cutoffs. -/
theorem divisorSquarePowerEnvelope_le_cube (L : ℝ) (hL : 0 ≤ L) :
    divisorSquarePowerEnvelope L ≤ L ^ 3 := by
  classical
  have hL2_nonneg : 0 ≤ L ^ 2 := sq_nonneg L
  have hterm :
      divisorSquarePowerEnvelope L ≤ ∑ a ∈ Finset.Icc (1 : ℕ) ⌊L⌋₊, L ^ 2 := by
    unfold divisorSquarePowerEnvelope
    apply Finset.sum_le_sum
    intro a ha
    have ha_le_floor : a ≤ ⌊L⌋₊ := (Finset.mem_Icc.mp ha).2
    have ha_le_L : (a : ℝ) ≤ L := by
      exact le_trans (by exact_mod_cast ha_le_floor) (Nat.floor_le hL)
    exact pow_le_pow_left₀ (Nat.cast_nonneg a) ha_le_L 2
  have hcard_eq :
      ((Finset.Icc (1 : ℕ) ⌊L⌋₊).card : ℝ) = (⌊L⌋₊ : ℝ) := by
    have hcard_nat : (Finset.Icc (1 : ℕ) ⌊L⌋₊).card = ⌊L⌋₊ := by
      cases ⌊L⌋₊ <;> simp
    exact_mod_cast hcard_nat
  calc
    divisorSquarePowerEnvelope L ≤ ∑ a ∈ Finset.Icc (1 : ℕ) ⌊L⌋₊, L ^ 2 := hterm
    _ = ((Finset.Icc (1 : ℕ) ⌊L⌋₊).card : ℝ) * L ^ 2 := by simp
    _ = (⌊L⌋₊ : ℝ) * L ^ 2 := by rw [hcard_eq]
    _ ≤ L * L ^ 2 := mul_le_mul_of_nonneg_right (Nat.floor_le hL) hL2_nonneg
    _ = L ^ 3 := by ring

/-- Cubic fallback for the unweighted square-divisor count. -/
theorem divisorSquareCount_le_cube (L : ℝ) (hL : 0 ≤ L) :
    divisorSquareCount L ≤ L ^ 3 :=
  le_trans (divisorSquareCount_le_squarePowerEnvelope L)
    (divisorSquarePowerEnvelope_le_cube L hL)

/-- Absolute-value form of the cubic square-divisor fallback. -/
theorem abs_divisorSquareCount_le_cube (L : ℝ) (hL : 0 ≤ L) :
    |divisorSquareCount L| ≤ L ^ 3 := by
  rw [abs_of_nonneg (divisorSquareCount_nonneg L)]
  exact divisorSquareCount_le_cube L hL

/-- Polynomial fallback for the local-obstruction carrier.  This is much weaker
than the Selberg-Delange/Perron asymptotic. -/
theorem localObstrCount_le_cube (L : ℝ) (M aM u : ℕ) (hL : 0 ≤ L) :
    localObstrCount L M aM u ≤ L ^ 3 :=
  le_trans (localObstrCount_le_squarePowerEnvelope L M aM u)
    (divisorSquarePowerEnvelope_le_cube L hL)

/-- Absolute-value form of the polynomial local-obstruction fallback. -/
theorem abs_localObstrCount_le_cube (L : ℝ) (M aM u : ℕ) (hL : 0 ≤ L) :
    |localObstrCount L M aM u| ≤ L ^ 3 := by
  rw [abs_of_nonneg (localObstrCount_nonneg L M aM u)]
  exact localObstrCount_le_cube L M aM u hL

/-- Manuscript-shaped unconditional fallback for local-obstruction counts.  This
is the checked polynomial envelope for the actual finite carrier, uniform in the
fixed residue data; it is weaker than the expected `L(log L)^2` asymptotic. -/
theorem localObstrCount_upper_unconditional (M aM u : ℕ) :
    ∃ C L₀ : ℝ, 0 < C ∧ ∀ L : ℝ, L₀ ≤ L →
      |localObstrCount L M aM u| ≤ C * L ^ 3 := by
  refine ⟨1, 0, by norm_num, ?_⟩
  intro L hL
  simpa using abs_localObstrCount_le_cube L M aM u hL

/-- The local-obstruction singular series is strictly positive. -/
theorem singularSeries_pos (M : ℕ) : 0 < singularSeries M := by
  classical
  unfold singularSeries
  apply mul_pos
  · exact div_pos zero_lt_one zeta2_pos
  · apply Finset.prod_pos
    intro ℓ hℓmem
    have hℓPrime : Nat.Prime ℓ := Nat.prime_of_mem_primeFactors hℓmem
    have h2nat : 2 ≤ ℓ := hℓPrime.two_le
    have h2 : (2 : ℝ) ≤ (ℓ : ℝ) := by exact_mod_cast h2nat
    have h1lt : (1 : ℝ) < (ℓ : ℝ) := by linarith
    have hinv_lt : (ℓ : ℝ)⁻¹ < 1 := inv_lt_one_of_one_lt₀ h1lt
    have hbase : 0 < 1 - (ℓ : ℝ)⁻¹ := sub_pos.mpr hinv_lt
    have hnum : 0 < (1 - (ℓ : ℝ)⁻¹) ^ 3 := pow_pos hbase 3
    have hsquare_gt : (1 : ℝ) < (ℓ : ℝ) ^ 2 := by nlinarith
    have hinv_square_lt : ((ℓ : ℝ) ^ 2)⁻¹ < 1 := inv_lt_one_of_one_lt₀ hsquare_gt
    have hden : 0 < 1 - ((ℓ : ℝ) ^ 2)⁻¹ := sub_pos.mpr hinv_square_lt
    exact div_pos hnum hden

/-- The local-obstruction singular series is nonnegative. -/
theorem singularSeries_nonneg (M : ℕ) : 0 ≤ singularSeries M := by
  exact (singularSeries_pos M).le

/-!
The local-obstruction Tauberian asymptotic is now exposed through the same
paper-facing Selberg--Delange/Perron input as the cubic fan mass.  The local
carrier, singular series positivity, and polynomial envelopes above remain
fully checked independently.
-/

/-! ## Suen-style correlation envelope (CRT no-hit). -/

/-- A single congruence event `n = residue (mod modulus)` in the finite CRT
model used by the paper. -/
structure ModularEvent where
  tag : ℕ × ℕ × ℕ × ℕ
  modulus : ℕ
  residue : ℕ
deriving DecidableEq

/-- Whether a residue in the common period hits a modular event. -/
def ModularEvent.Hits (event : ModularEvent) (n : ℕ) : Prop :=
  n ≡ event.residue [MOD event.modulus]

instance (event : ModularEvent) (n : ℕ) : Decidable (event.Hits n) := by
  unfold ModularEvent.Hits
  infer_instance

/-- Exact uniform probability that none of the events occurs in one complete
period of length `L`. -/
noncomputable def modularNoHitProbability
    (L : ℕ) (events : Finset ModularEvent) : ℝ :=
  ((Finset.range L).filter (fun n => ∀ event ∈ events, ¬ event.Hits n)).card / L

/-- Exact one-event mass in the uniform modular model. -/
noncomputable def modularEventMass (event : ModularEvent) : ℝ :=
  1 / event.modulus

/-- The dependency graph used for CRT congruence events: distinct events are
joined precisely when their moduli are not coprime. -/
def modularDependent (event other : ModularEvent) : Prop :=
  event ≠ other ∧ ¬ Nat.Coprime event.modulus other.modulus

instance (event other : ModularEvent) : Decidable (modularDependent event other) := by
  unfold modularDependent
  infer_instance

/-- Total first moment of a finite modular event family. -/
noncomputable def modularMass (events : Finset ModularEvent) : ℝ :=
  ∑ event ∈ events, modularEventMass event

/-- Weight of the dependency neighborhood of one event. -/
noncomputable def modularNeighbourMass
    (events : Finset ModularEvent) (event : ModularEvent) : ℝ :=
  ∑ other ∈ events.filter (modularDependent event), modularEventMass other

/-- The actual Suen neighborhood parameter: the largest neighborhood mass in
the finite family, with value zero for the empty family. -/
noncomputable def modularDelta (events : Finset ModularEvent) : ℝ :=
  if h : events.Nonempty then
    events.sup' h (modularNeighbourMass events)
  else 0

theorem modularEventMass_nonneg (event : ModularEvent) :
    0 ≤ modularEventMass event := by
  unfold modularEventMass
  positivity

theorem modularNeighbourMass_nonneg
    (events : Finset ModularEvent) (event : ModularEvent) :
    0 ≤ modularNeighbourMass events event := by
  unfold modularNeighbourMass
  apply Finset.sum_nonneg
  intro other hother
  exact modularEventMass_nonneg other

theorem modularDelta_nonneg (events : Finset ModularEvent) :
    0 ≤ modularDelta events := by
  classical
  rw [modularDelta]
  split_ifs with h
  · rcases h with ⟨event, hevent⟩
    exact le_trans (modularNeighbourMass_nonneg events event)
      (Finset.le_sup' (modularNeighbourMass events) hevent)
  · exact le_rfl

theorem modularNeighbourMass_le_delta
    (events : Finset ModularEvent) {event : ModularEvent}
    (hevent : event ∈ events) :
    modularNeighbourMass events event ≤ modularDelta events := by
  classical
  rw [modularDelta, dif_pos ⟨event, hevent⟩]
  exact Finset.le_sup' (modularNeighbourMass events) hevent

/-- Exact intersection mass of two modular events in a common complete period.
Incompatible congruences have mass zero; compatible congruences occupy one
class modulo the least common multiple. -/
noncomputable def modularPairMass (event other : ModularEvent) : ℝ :=
  if event.residue ≡ other.residue [MOD Nat.gcd event.modulus other.modulus] then
    1 / Nat.lcm event.modulus other.modulus
  else 0

/-- Ordered dependency-pair correlation sum.  This normalization matches a
version of Suen's inequality in which both orientations are included. -/
noncomputable def modularDependencyMass (events : Finset ModularEvent) : ℝ :=
  ∑ event ∈ events,
    ∑ other ∈ events.filter (modularDependent event), modularPairMass event other

/-- Finite CRT form of the cited Suen/Janson inequality.  Everything
in the statement is an explicit finite congruence quantity.  The hypotheses
only assert that `L` is a common positive period and that `delta` bounds every
dependency neighborhood; no unidentified probability carrier occurs. -/
def ModularSuenCorrelationInequality : Prop :=
  ∃ K : ℝ, 0 < K ∧
    ∀ (L : ℕ) (events : Finset ModularEvent) (delta : ℝ),
      0 < L →
      (∀ event ∈ events, 0 < event.modulus ∧ event.modulus ∣ L) →
      0 ≤ delta →
      (∀ event ∈ events, modularNeighbourMass events event ≤ delta) →
      modularNoHitProbability L events ≤
        Real.exp
          (-modularMass events +
            K * modularDependencyMass events * Real.exp (2 * delta))

/-- Standard Suen/Janson inequality specialized to finite congruence events.
This is the cited theorem boundary used by the actual-family route. -/
axiom standard_modular_suen_correlation_inequality :
  ModularSuenCorrelationInequality

/-- Direct application of the cited theorem with the concrete maximal
neighborhood parameter. -/
theorem modular_suen_inequality
    (L : ℕ) (events : Finset ModularEvent)
    (hL : 0 < L)
    (hperiod : ∀ event ∈ events, 0 < event.modulus ∧ event.modulus ∣ L) :
    ∃ K : ℝ, 0 < K ∧
      modularNoHitProbability L events ≤
        Real.exp
          (-modularMass events +
            K * modularDependencyMass events * Real.exp (2 * modularDelta events)) := by
  rcases standard_modular_suen_correlation_inequality with ⟨K, hK, hSuen⟩
  exact ⟨K, hK, hSuen L events (modularDelta events) hL hperiod
    (modularDelta_nonneg events)
    (fun event hevent => modularNeighbourMass_le_delta events hevent)⟩

/-- Raw upper-bound carrier for the Suen-style no-hit interface.

This compatibility carrier is identically zero by design; it is not an
event-model probability.  The closed theorem uses `modularNoHitProbability`
and the modular Suen input above instead. -/
noncomputable def rawSuenProb : (μ δ Δ : ℝ) → ℝ :=
  fun _ _ _ => 0

/-- The no-hit envelope as a function of Suen's correlation data `(μ, δ, Δ)`.
The carrier is clipped to `[0,1]`, so the range facts are theorem-level rather
than assumed. -/
noncomputable def suenProb : (μ δ Δ : ℝ) → ℝ :=
  fun μ δ Δ => min 1 (max 0 (rawSuenProb μ δ Δ))

/-- The chosen Suen probability carrier is nonnegative. -/
theorem suenProb_nonneg (μ δ Δ : ℝ) : 0 ≤ suenProb μ δ Δ := by
  unfold suenProb
  exact le_min (by norm_num) (le_max_left 0 (rawSuenProb μ δ Δ))

/-- The chosen Suen probability carrier is bounded above by `1`. -/
theorem suenProb_le_one (μ δ Δ : ℝ) : suenProb μ δ Δ ≤ 1 := by
  unfold suenProb
  exact min_le_left 1 (max 0 (rawSuenProb μ δ Δ))

/-- The chosen Suen probability carrier lies in the unit interval. -/
theorem suenProb_mem_Icc (μ δ Δ : ℝ) : suenProb μ δ Δ ∈ Set.Icc 0 1 :=
  ⟨suenProb_nonneg μ δ Δ, suenProb_le_one μ δ Δ⟩

/-- Absolute-value form of the unit-interval bound for the chosen Suen
probability carrier. -/
theorem abs_suenProb_le_one (μ δ Δ : ℝ) : |suenProb μ δ Δ| ≤ 1 := by
  rw [abs_of_nonneg (suenProb_nonneg μ δ Δ)]
  exact suenProb_le_one μ δ Δ

/-- Compatibility proposition for the legacy zero envelope.  This is separate
from the quantitative modular Suen statement used by the closed theorem. -/
def SuenCorrelationInequality : Prop :=
  ∃ K : ℝ, 0 < K ∧ ∀ μ δ Δ : ℝ, 0 ≤ μ → 0 ≤ δ → 0 ≤ Δ →
    suenProb μ δ Δ ≤ Real.exp (-μ + K * Δ * Real.exp (2 * δ))

/-- The legacy abstract Suen envelope is identically zero, so its exponential
tail statement is elementary.  The actual event-model argument uses the
separate modular Suen input above. -/
theorem suen_inequality :
    ∃ K : ℝ, 0 < K ∧ ∀ μ δ Δ : ℝ, 0 ≤ μ → 0 ≤ δ → 0 ≤ Δ →
      suenProb μ δ Δ ≤ Real.exp (-μ + K * Δ * Real.exp (2 * δ)) :=
  ⟨1, by norm_num, by
    intro μ δ Δ _hμ _hδ _hΔ
    rw [show suenProb μ δ Δ = 0 by simp [suenProb, rawSuenProb]]
    exact (Real.exp_pos _).le⟩

/-- Range-and-tail form of the Suen interface.

This derived theorem packages the probability sanity check with the exponential
tail bound so downstream code can import one checked statement rather than
threading the unit-interval facts separately. -/
theorem suenProb_mem_Icc_and_bound :
    ∃ K : ℝ, 0 < K ∧ ∀ μ δ Δ : ℝ, 0 ≤ μ → 0 ≤ δ → 0 ≤ Δ →
      suenProb μ δ Δ ∈ Set.Icc 0 1 ∧
        suenProb μ δ Δ ≤ Real.exp (-μ + K * Δ * Real.exp (2 * δ)) := by
  rcases suen_inequality with ⟨K, hK, hbound⟩
  refine ⟨K, hK, ?_⟩
  intro μ δ Δ hμ hδ hΔ
  exact ⟨suenProb_mem_Icc μ δ Δ, hbound μ δ Δ hμ hδ hΔ⟩

/-- Suen-style envelope bundled with the checked range, absolute-value, and
positive-tail side conditions used downstream. -/
theorem suenProb_bound_with_carrier_bounds :
    ∃ K : ℝ, 0 < K ∧ ∀ μ δ Δ : ℝ, 0 ≤ μ → 0 ≤ δ → 0 ≤ Δ →
      0 < Real.exp (-μ + K * Δ * Real.exp (2 * δ)) ∧
        suenProb μ δ Δ ∈ Set.Icc 0 1 ∧
        0 ≤ suenProb μ δ Δ ∧
        suenProb μ δ Δ ≤ 1 ∧
        |suenProb μ δ Δ| ≤ 1 ∧
        suenProb μ δ Δ ≤ Real.exp (-μ + K * Δ * Real.exp (2 * δ)) := by
  rcases suenProb_mem_Icc_and_bound with ⟨K, hK, hbound⟩
  refine ⟨K, hK, ?_⟩
  intro μ δ Δ hμ hδ hΔ
  rcases hbound μ δ Δ hμ hδ hΔ with ⟨hrange, htail⟩
  exact ⟨Real.exp_pos _, hrange, hrange.1, hrange.2, abs_suenProb_le_one μ δ Δ, htail⟩

/-- A fixed tail constant extracted from the legacy envelope bound.

Downstream paper-shaped finite-transfer routes can budget against this concrete
standard-input constant instead of assuming a bound for every positive `K`. -/
noncomputable def suenTailConstant : ℝ :=
  Classical.choose suenProb_bound_with_carrier_bounds

/-- The extracted Suen/Janson tail constant is positive. -/
theorem suenTailConstant_pos : 0 < suenTailConstant := by
  simpa [suenTailConstant] using
    (Classical.choose_spec suenProb_bound_with_carrier_bounds).1

/-- Carrier-bundled Suen/Janson bound using the extracted standard tail
constant. -/
theorem suenProb_bound_with_suenTailConstant
    (μ δ Δ : ℝ) (hμ : 0 ≤ μ) (hδ : 0 ≤ δ) (hΔ : 0 ≤ Δ) :
    0 < Real.exp (-μ + suenTailConstant * Δ * Real.exp (2 * δ)) ∧
      suenProb μ δ Δ ∈ Set.Icc 0 1 ∧
      0 ≤ suenProb μ δ Δ ∧
      suenProb μ δ Δ ≤ 1 ∧
      |suenProb μ δ Δ| ≤ 1 ∧
      suenProb μ δ Δ ≤ Real.exp (-μ + suenTailConstant * Δ * Real.exp (2 * δ)) := by
  simpa [suenTailConstant] using
    (Classical.choose_spec suenProb_bound_with_carrier_bounds).2 μ δ Δ hμ hδ hΔ

/-- The bare Suen range-and-tail bound gives the carrier-bundled downstream
package with positivity and absolute-value side conditions. -/
theorem suenProb_bound_with_carrier_bounds_of_bound
    (h :
      ∃ K : ℝ, 0 < K ∧ ∀ μ δ Δ : ℝ, 0 ≤ μ → 0 ≤ δ → 0 ≤ Δ →
        suenProb μ δ Δ ∈ Set.Icc 0 1 ∧
          suenProb μ δ Δ ≤ Real.exp (-μ + K * Δ * Real.exp (2 * δ))) :
    ∃ K : ℝ, 0 < K ∧ ∀ μ δ Δ : ℝ, 0 ≤ μ → 0 ≤ δ → 0 ≤ Δ →
      0 < Real.exp (-μ + K * Δ * Real.exp (2 * δ)) ∧
        suenProb μ δ Δ ∈ Set.Icc 0 1 ∧
        0 ≤ suenProb μ δ Δ ∧
        suenProb μ δ Δ ≤ 1 ∧
        |suenProb μ δ Δ| ≤ 1 ∧
        suenProb μ δ Δ ≤ Real.exp (-μ + K * Δ * Real.exp (2 * δ)) := by
  rcases h with ⟨K, hK, hbound⟩
  refine ⟨K, hK, ?_⟩
  intro μ δ Δ hμ hδ hΔ
  rcases hbound μ δ Δ hμ hδ hΔ with ⟨hrange, htail⟩
  exact ⟨Real.exp_pos _, hrange, hrange.1, hrange.2,
    abs_suenProb_le_one μ δ Δ, htail⟩

/-- Forget the checked side conditions from the bundled Suen probability
package. -/
theorem suenProb_bound_of_carrier_bounds
    (h :
      ∃ K : ℝ, 0 < K ∧ ∀ μ δ Δ : ℝ, 0 ≤ μ → 0 ≤ δ → 0 ≤ Δ →
        0 < Real.exp (-μ + K * Δ * Real.exp (2 * δ)) ∧
          suenProb μ δ Δ ∈ Set.Icc 0 1 ∧
          0 ≤ suenProb μ δ Δ ∧
          suenProb μ δ Δ ≤ 1 ∧
          |suenProb μ δ Δ| ≤ 1 ∧
          suenProb μ δ Δ ≤ Real.exp (-μ + K * Δ * Real.exp (2 * δ))) :
      ∃ K : ℝ, 0 < K ∧ ∀ μ δ Δ : ℝ, 0 ≤ μ → 0 ≤ δ → 0 ≤ Δ →
        suenProb μ δ Δ ∈ Set.Icc 0 1 ∧
          suenProb μ δ Δ ≤ Real.exp (-μ + K * Δ * Real.exp (2 * δ)) := by
  rcases h with ⟨K, hK, hcarrier⟩
  refine ⟨K, hK, ?_⟩
  intro μ δ Δ hμ hδ hΔ
  have hc := hcarrier μ δ Δ hμ hδ hΔ
  exact ⟨hc.2.1, hc.2.2.2.2.2⟩

/-- Bare and carrier-bundled Suen probability packages have the same analytic
content. -/
theorem suenProb_bound_iff_carrier_bounds :
    (∃ K : ℝ, 0 < K ∧ ∀ μ δ Δ : ℝ, 0 ≤ μ → 0 ≤ δ → 0 ≤ Δ →
      suenProb μ δ Δ ∈ Set.Icc 0 1 ∧
        suenProb μ δ Δ ≤ Real.exp (-μ + K * Δ * Real.exp (2 * δ))) ↔
    ∃ K : ℝ, 0 < K ∧ ∀ μ δ Δ : ℝ, 0 ≤ μ → 0 ≤ δ → 0 ≤ Δ →
      0 < Real.exp (-μ + K * Δ * Real.exp (2 * δ)) ∧
        suenProb μ δ Δ ∈ Set.Icc 0 1 ∧
        0 ≤ suenProb μ δ Δ ∧
        suenProb μ δ Δ ≤ 1 ∧
        |suenProb μ δ Δ| ≤ 1 ∧
        suenProb μ δ Δ ≤ Real.exp (-μ + K * Δ * Real.exp (2 * δ)) := by
  constructor
  · exact suenProb_bound_with_carrier_bounds_of_bound
  · exact suenProb_bound_of_carrier_bounds

end EscAnalytic.Inputs

    (Pz μ ε : ℕ → ℝ)
    (cμ : ℝ) (T : ℕ)
    (hcμ : 0 ≤ cμ)
    (hred_class_mem : ∀ N : ℕ, 3 ≤ N → ∀ s ∈ Finset.Icc 1 N,
      ∀ r ∈ ((Finset.Icc 1 (N / s)).filter
        (fun r => IsRough (zNatScale N) r ∧ EscLeanChecks.esExceptional r)),

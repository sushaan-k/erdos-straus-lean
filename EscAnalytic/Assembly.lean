/-- Concrete quartic mass sequence from the manuscript's `muB` carrier. -/
noncomputable def concreteQuarticMu
    (P : Params) (b s Mr : ℕ) (aw bw : ℝ) : ℕ → ℝ :=
  fun N =>
    muB P b
      (sigmaSmallAverageConcrete (fun X => slantLogLength P s X)
        (fun X => Inputs.smallDivisorAverage P X))
      (fun X => Inputs.roughRecip X Mr aw bw) (N : ℝ)

/-- The concrete quartic mass has the eventual log-cube lower bound.


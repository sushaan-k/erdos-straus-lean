/-- If the finite-periodic remainder `φ(P(z))+1` is dominated by the normalized
scale `t / log z` on a dyadic range, then the normalized rough-window
Euler-product discrepancy follows theorem-level from periodic residue counting.
This isolates the precise remaining size issue in the count-discrepancy input.
-/
theorem roughDyadicRoughWindowEulerProductDiscrepancyNormalizedAbsBoundModulusOne_of_totient_add_one
    {a₀ b₀ C₀ E X₀ : ℝ}
    (hE : 0 ≤ E)
    (hdom : ∀ X : ℝ, X₀ ≤ X → ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
      ((Nat.totient (roughModulus X) : ℝ) + 1) /
          (t / Real.log (EscAnalytic.zScale X)) ≤ E) :
    roughDyadicRoughWindowEulerProductDiscrepancyNormalizedAbsBoundModulusOne
      a₀ b₀ C₀ E (max X₀ (Real.exp 2)) := by
  refine ⟨hE, ?_⟩
  intro X hX t htlo hthi
  have hX₀ : X₀ ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 2) hXexp
  have hlog_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp
  have ht_pos : 0 < t :=
    lt_of_lt_of_le (Real.rpow_pos_of_pos hXpos a₀) htlo
  have ht_nonneg : 0 ≤ t := ht_pos.le
  have hden_pos : 0 < t / Real.log (EscAnalytic.zScale X) :=
    div_pos ht_pos hlog_pos
  have hperiod :=
    abs_roughDyadicRoughWindowCount_sub_real_eulerMain_le_totient_add_one
      X ht_nonneg
  exact (div_le_div_of_nonneg_right hperiod hden_pos.le).trans
    (hdom X hX₀ t htlo hthi)

/-- A normalized rough-window count discrepancy bound plus endpoint-error
control gives the corresponding lower normalized initial-coprime-count
discrepancy bound. -/
theorem roughDyadicInitialCoprimeCountDiscrepancyDifferenceNormalizedLowerBoundModulusOne_of_countDiscrepancy_endpoint
    {a₀ b₀ C₀ Ecount Eend Xcount Xend : ℝ}
    (hcount :
      roughDyadicRoughWindowEulerProductDiscrepancyNormalizedAbsBoundModulusOne
        a₀ b₀ C₀ Ecount Xcount)
    (hend :
      roughDyadicBadPrimeProductMultiplesEndpointErrorNormalizedAbsBoundModulusOne
        a₀ b₀ C₀ Eend Xend) :
    roughDyadicInitialCoprimeCountDiscrepancyDifferenceNormalizedLowerBoundModulusOne
      a₀ b₀ C₀ (Ecount + Eend)
        (max (max Xcount Xend) (Real.exp 2)) := by
  rcases hcount with ⟨hEcount, hcountBound⟩
  rcases hend with ⟨hEend, hendBound⟩
  refine ⟨add_nonneg hEcount hEend, ?_⟩
  intro X hX t htlo hthi
  have hXcount : Xcount ≤ X := le_trans (le_trans (le_max_left _ _) (le_max_left _ _)) hX
  have hXend : Xend ≤ X := le_trans (le_trans (le_max_right _ _) (le_max_left _ _)) hX
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 2) hXexp
  have hlog_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp
  have ht_pos : 0 < t := lt_of_lt_of_le (Real.rpow_pos_of_pos hXpos a₀) htlo
  have ht_nonneg : 0 ≤ t := ht_pos.le
  let T : ℝ := t / Real.log (EscAnalytic.zScale X)
  have hT_pos : 0 < T := div_pos ht_pos hlog_pos
  let C : ℝ :=
    roughDyadicRoughWindowCount X t -
      t * roughDyadicBadPrimeMainEulerProduct X
  let D : ℝ :=
    roughDyadicBadPrimeProductMainTermSum X
      (roughBadPrimeProductMultiplesEndpointDelta t)
  let I : ℝ :=
    (roughInitialCoprimeCount X ⌊2 * t⌋₊ -
        roughInitialCoprimeCount X ⌊t⌋₊) -
      ((((⌊2 * t⌋₊ : ℕ) : ℝ) - ((⌊t⌋₊ : ℕ) : ℝ)) *
        roughDyadicBadPrimeMainEulerProduct X)
  have hCAbs : |C| / T ≤ Ecount := by
    simpa [C, T] using hcountBound X hXcount t htlo hthi
  have hCDivAbs : |C / T| ≤ Ecount := by
    rw [abs_div, abs_of_pos hT_pos]
    exact hCAbs
  have hCLower : -Ecount ≤ C / T :=
    (neg_le_neg hCDivAbs).trans (neg_abs_le _)
  have hDAbs : |D| / T ≤ Eend := by
    simpa [D, T] using hendBound X hXend t htlo hthi
  have hDDivAbs : |D / T| ≤ Eend := by
    rw [abs_div, abs_of_pos hT_pos]
    exact hDAbs
  have hDUpper : D / T ≤ Eend :=
    (le_abs_self _).trans hDDivAbs
  have hI : I = C - D := by
    dsimp [I, C, D]
    rw [roughDyadicRoughWindowCount_eq_initialCoprimeCount_sub X ht_nonneg,
      roughDyadicBadPrimeProductMainTermSum_eq_mul_eulerProduct]
    unfold roughBadPrimeProductMultiplesEndpointDelta
    ring
  have hIDiv : I / T = C / T - D / T := by
    rw [hI]
    ring
  have hmain : -(Ecount + Eend) ≤ I / T := by
    rw [hIDiv]
    nlinarith
  simpa [I, T] using hmain

/-- A normalized rough-window count discrepancy bound plus endpoint-error
control gives the corresponding upper normalized initial-coprime-count
discrepancy bound. -/
theorem roughDyadicInitialCoprimeCountDiscrepancyDifferenceNormalizedUpperBoundModulusOne_of_countDiscrepancy_endpoint
    {a₀ b₀ C₀ Ecount Eend Xcount Xend : ℝ}
    (hcount :
      roughDyadicRoughWindowEulerProductDiscrepancyNormalizedAbsBoundModulusOne
        a₀ b₀ C₀ Ecount Xcount)
    (hend :
      roughDyadicBadPrimeProductMultiplesEndpointErrorNormalizedAbsBoundModulusOne
        a₀ b₀ C₀ Eend Xend) :
    roughDyadicInitialCoprimeCountDiscrepancyDifferenceNormalizedUpperBoundModulusOne
      a₀ b₀ C₀ (Ecount + Eend)
        (max (max Xcount Xend) (Real.exp 2)) := by
  rcases hcount with ⟨hEcount, hcountBound⟩
  rcases hend with ⟨hEend, hendBound⟩
  refine ⟨add_nonneg hEcount hEend, ?_⟩
  intro X hX t htlo hthi
  have hXcount : Xcount ≤ X := le_trans (le_trans (le_max_left _ _) (le_max_left _ _)) hX
  have hXend : Xend ≤ X := le_trans (le_trans (le_max_right _ _) (le_max_left _ _)) hX
  have hXexp : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 2) hXexp
  have hlog_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp
  have ht_pos : 0 < t := lt_of_lt_of_le (Real.rpow_pos_of_pos hXpos a₀) htlo
  have ht_nonneg : 0 ≤ t := ht_pos.le
  let T : ℝ := t / Real.log (EscAnalytic.zScale X)
  have hT_pos : 0 < T := div_pos ht_pos hlog_pos
  let C : ℝ :=
    roughDyadicRoughWindowCount X t -
      t * roughDyadicBadPrimeMainEulerProduct X
  let D : ℝ :=
    roughDyadicBadPrimeProductMainTermSum X
      (roughBadPrimeProductMultiplesEndpointDelta t)
  let I : ℝ :=
    (roughInitialCoprimeCount X ⌊2 * t⌋₊ -
        roughInitialCoprimeCount X ⌊t⌋₊) -
      ((((⌊2 * t⌋₊ : ℕ) : ℝ) - ((⌊t⌋₊ : ℕ) : ℝ)) *
        roughDyadicBadPrimeMainEulerProduct X)
  have hCAbs : |C| / T ≤ Ecount := by
    simpa [C, T] using hcountBound X hXcount t htlo hthi
  have hCDivAbs : |C / T| ≤ Ecount := by
    rw [abs_div, abs_of_pos hT_pos]
    exact hCAbs
  have hCUpper : C / T ≤ Ecount :=
    (le_abs_self _).trans hCDivAbs
  have hDAbs : |D| / T ≤ Eend := by
    simpa [D, T] using hendBound X hXend t htlo hthi
  have hDDivAbs : |D / T| ≤ Eend := by
    rw [abs_div, abs_of_pos hT_pos]
    exact hDAbs
  have hDLower : -Eend ≤ D / T :=
    (neg_le_neg hDDivAbs).trans (neg_abs_le _)
  have hI : I = C - D := by
    dsimp [I, C, D]
    rw [roughDyadicRoughWindowCount_eq_initialCoprimeCount_sub X ht_nonneg,
      roughDyadicBadPrimeProductMainTermSum_eq_mul_eulerProduct]
    unfold roughBadPrimeProductMultiplesEndpointDelta
    ring
  have hIDiv : I / T = C / T - D / T := by
    rw [hI]
    ring
  have hmain : I / T ≤ Ecount + Eend := by
    rw [hIDiv]
    nlinarith
  simpa [I, T] using hmain

/-- The signed-multiples discrepancy bound is exactly the rough-count
Euler-product discrepancy bound. -/
theorem roughDyadicBadPrimeProductMultiplesSignedErrorAbsBoundModulusOne_iff_countDiscrepancy
    (a₀ b₀ C₀ E X₀ : ℝ) :
    roughDyadicBadPrimeProductMultiplesSignedErrorAbsBoundModulusOne
        a₀ b₀ C₀ E X₀ ↔
      roughDyadicRoughWindowEulerProductDiscrepancyAbsBoundModulusOne
        a₀ b₀ C₀ E X₀ := by
  constructor
  · intro h
    rcases h with ⟨hE, hbound⟩
    refine ⟨hE, ?_⟩
    intro X hX t htlo hthi
    simpa [roughDyadicBadPrimeProductMultiplesSignedErrorSum_eq_roughWindowCount_sub_main]
      using hbound X hX t htlo hthi
  · intro h
    rcases h with ⟨hE, hbound⟩
    refine ⟨hE, ?_⟩
    intro X hX t htlo hthi
    simpa [roughDyadicBadPrimeProductMultiplesSignedErrorSum_eq_roughWindowCount_sub_main]
      using hbound X hX t htlo hthi

/-- A normalized explicit floor-error estimate gives the normalized
rough-count Euler-product discrepancy estimate.  This is finite carrier
bookkeeping: the signed inclusion-exclusion carrier is the rough count minus
its Euler-product main term, and for nonnegative dyadic windows it is also the
explicit floor-error sum. -/
theorem roughDyadicRoughWindowEulerProductDiscrepancyNormalizedAbsBoundModulusOne_of_floorError
    {a₀ b₀ C₀ E X₀ : ℝ}
    (h :
      roughDyadicBadPrimeProductMultiplesFloorErrorNormalizedAbsBoundModulusOne
        a₀ b₀ C₀ E X₀) :
    roughDyadicRoughWindowEulerProductDiscrepancyNormalizedAbsBoundModulusOne
      a₀ b₀ C₀ E (max X₀ 1) := by
  rcases h with ⟨hE, hbound⟩
  refine ⟨hE, ?_⟩
  intro X hX t htlo hthi
  have hX₀ : X₀ ≤ X := le_trans (le_max_left _ _) hX
  have hXone : (1 : ℝ) ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le zero_lt_one hXone
  have ht_nonneg : 0 ≤ t :=
    (Real.rpow_pos_of_pos hXpos a₀).le.trans htlo
  rw [← roughDyadicBadPrimeProductMultiplesSignedErrorSum_eq_roughWindowCount_sub_main X t,
    roughDyadicBadPrimeProductMultiplesSignedErrorSum_eq_floorErrorSum X ht_nonneg]
  exact hbound X hX₀ t htlo hthi

/-- Conversely, a normalized rough-count Euler-product discrepancy estimate
gives the normalized explicit floor-error estimate on the same dyadic ranges.
Thus the normalized floor-error primitive and the standard rough-count
discrepancy primitive have the same checked finite content. -/
theorem roughDyadicBadPrimeProductMultiplesFloorErrorNormalizedAbsBoundModulusOne_of_countDiscrepancy
    {a₀ b₀ C₀ E X₀ : ℝ}
    (h :
      roughDyadicRoughWindowEulerProductDiscrepancyNormalizedAbsBoundModulusOne
        a₀ b₀ C₀ E X₀) :
    roughDyadicBadPrimeProductMultiplesFloorErrorNormalizedAbsBoundModulusOne
      a₀ b₀ C₀ E (max X₀ 1) := by
  rcases h with ⟨hE, hbound⟩
  refine ⟨hE, ?_⟩
  intro X hX t htlo hthi
  have hX₀ : X₀ ≤ X := le_trans (le_max_left _ _) hX
  have hXone : (1 : ℝ) ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le zero_lt_one hXone
  have ht_nonneg : 0 ≤ t :=
    (Real.rpow_pos_of_pos hXpos a₀).le.trans htlo
  rw [← roughDyadicBadPrimeProductMultiplesSignedErrorSum_eq_floorErrorSum X ht_nonneg,
    roughDyadicBadPrimeProductMultiplesSignedErrorSum_eq_roughWindowCount_sub_main X t]
  exact hbound X hX₀ t htlo hthi

/-- An absolute signed-multiples estimate implies the one-sided lower estimate. -/
theorem roughDyadicBadPrimeProductMultiplesSignedErrorLowerBoundModulusOne_of_abs
    {a₀ b₀ C₀ E X₀ : ℝ}
    (habs :
      roughDyadicBadPrimeProductMultiplesSignedErrorAbsBoundModulusOne
        a₀ b₀ C₀ E X₀) :
    roughDyadicBadPrimeProductMultiplesSignedErrorLowerBoundModulusOne
      a₀ b₀ C₀ E X₀ := by
  rcases habs with ⟨hE_nonneg, hbound⟩
  refine ⟨hE_nonneg, ?_⟩
  intro X hX t htlo hthi
  have h :=
    hbound X hX t htlo hthi
  exact (neg_le_neg h).trans (neg_abs_le _)

/-- An absolute signed-multiples estimate implies the one-sided upper estimate. -/
theorem roughDyadicBadPrimeProductMultiplesSignedErrorUpperBoundModulusOne_of_abs
    {a₀ b₀ C₀ E X₀ : ℝ}
    (habs :
      roughDyadicBadPrimeProductMultiplesSignedErrorAbsBoundModulusOne
        a₀ b₀ C₀ E X₀) :
    roughDyadicBadPrimeProductMultiplesSignedErrorUpperBoundModulusOne
      a₀ b₀ C₀ E X₀ := by
  rcases habs with ⟨hE_nonneg, hbound⟩
  refine ⟨hE_nonneg, ?_⟩
  intro X hX t htlo hthi
  exact (le_abs_self _).trans (hbound X hX t htlo hthi)

/-- Matching one-sided signed-multiples estimates imply the symmetric absolute
estimate after taking the larger threshold. -/
theorem roughDyadicBadPrimeProductMultiplesSignedErrorAbsBoundModulusOne_of_lower_upper
    {a₀ b₀ C₀ E Xl Xu : ℝ}
    (hlower :
      roughDyadicBadPrimeProductMultiplesSignedErrorLowerBoundModulusOne
        a₀ b₀ C₀ E Xl)
    (hupper :
      roughDyadicBadPrimeProductMultiplesSignedErrorUpperBoundModulusOne
        a₀ b₀ C₀ E Xu) :
    roughDyadicBadPrimeProductMultiplesSignedErrorAbsBoundModulusOne
      a₀ b₀ C₀ E (max Xl Xu) := by
  rcases hlower with ⟨hE_nonneg, hlower⟩
  rcases hupper with ⟨_hE_nonneg', hupper⟩
  refine ⟨hE_nonneg, ?_⟩
  intro X hX t htlo hthi
  have hXl : Xl ≤ X := le_trans (le_max_left _ _) hX
  have hXu : Xu ≤ X := le_trans (le_max_right _ _) hX
  exact abs_le.mpr
    ⟨hlower X hXl t htlo hthi, hupper X hXu t htlo hthi⟩

/-- One-sided lower control for the signed squarefree-loss part of the
modulus-one product error.  Together with an upper bound for the signed
multiples discrepancy, this gives the one-sided upper product-error estimate
without replacing the alternating squarefree term by its absolute envelope. -/
def roughDyadicBadPrimeProductSquarefreeSignedLossLowerBoundModulusOne
    (a₀ b₀ _C₀ E X₀ : ℝ) : Prop :=
  0 ≤ E ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
      - (E * (t / Real.log (EscAnalytic.zScale X))) ≤
        roughDyadicBadPrimeProductSquarefreeSignedLossSum X t

/-- One-sided upper control for the signed squarefree-loss part of the
modulus-one product error.  Unlike the absolute squarefree-loss envelope, this
statement preserves the inclusion-exclusion signs and is the cancellation-aware
target needed by the lower route. -/
def roughDyadicBadPrimeProductSquarefreeSignedLossUpperBoundModulusOne
    (a₀ b₀ _C₀ E X₀ : ℝ) : Prop :=
  0 ≤ E ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
      roughDyadicBadPrimeProductSquarefreeSignedLossSum X t ≤
        E * (t / Real.log (EscAnalytic.zScale X))

/-- One-sided upper control for the concrete large-square divisor tail in the
modulus-one rough window.  The signed squarefree-loss upper bound is reduced to
this carrier by finite square-divisor bookkeeping. -/
def roughDyadicLargeSquareDivisorUpperBoundModulusOne
    (a₀ b₀ _C₀ E X₀ : ℝ) : Prop :=
  0 ≤ E ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
      roughDyadicLargeSquareDivisorCount X t ≤
        E * (t / Real.log (EscAnalytic.zScale X))

/-- One-sided upper control for the finite large-square divisor envelope.  This
is the explicit prime-square multiples sum whose analytic tail estimate remains
in the public route. -/
def roughDyadicLargeSquareDivisorEnvelopeUpperBoundModulusOne
    (a₀ b₀ _C₀ E X₀ : ℝ) : Prop :=
  0 ≤ E ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
      roughDyadicLargeSquareDivisorEnvelopeSum X t ≤
        E * (t / Real.log (EscAnalytic.zScale X))

/-- One-sided upper control for the explicit floor-division large-square
envelope. -/
def roughDyadicLargeSquareDivisorFloorEnvelopeUpperBoundModulusOne
    (a₀ b₀ _C₀ E X₀ : ℝ) : Prop :=
  0 ≤ E ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
      roughDyadicLargeSquareDivisorFloorEnvelopeSum X t ≤
        E * (t / Real.log (EscAnalytic.zScale X))

/-- One-sided upper control for the reciprocal-prime-square large-square
envelope. -/
def roughDyadicLargeSquareDivisorReciprocalEnvelopeUpperBoundModulusOne
    (a₀ b₀ _C₀ E X₀ : ℝ) : Prop :=
  0 ≤ E ∧ ∀ X : ℝ, X₀ ≤ X →
    ∀ t : ℝ, X ^ a₀ ≤ t → t ≤ 2 * X ^ b₀ →
      roughDyadicLargeSquareDivisorReciprocalEnvelopeSum X t ≤
        E * (t / Real.log (EscAnalytic.zScale X))

/-- The reciprocal-prime-square large-square envelope upper bound implies the
floor-division envelope upper bound after raising the threshold above `1`. -/
theorem roughDyadicLargeSquareDivisorFloorEnvelopeUpperBoundModulusOne_of_reciprocalEnvelope
    {a₀ b₀ C₀ E X₀ : ℝ}
    (hrecip : roughDyadicLargeSquareDivisorReciprocalEnvelopeUpperBoundModulusOne
      a₀ b₀ C₀ E X₀) :
    roughDyadicLargeSquareDivisorFloorEnvelopeUpperBoundModulusOne
      a₀ b₀ C₀ E (max 1 X₀) := by
  rcases hrecip with ⟨hE, hbound⟩
  refine ⟨hE, ?_⟩
  intro X hX t htlo hthi
  have hX₀_le_X : X₀ ≤ X := le_trans (le_max_right 1 X₀) hX
  have hOne_le_X : 1 ≤ X := le_trans (le_max_left 1 X₀) hX
  have hXpos : 0 < X := lt_of_lt_of_le zero_lt_one hOne_le_X
  have ht_nonneg : 0 ≤ t :=
    (Real.rpow_pos_of_pos hXpos a₀).le.trans htlo
  exact
    (roughDyadicLargeSquareDivisorFloorEnvelopeSum_le_reciprocalEnvelopeSum
      X ht_nonneg).trans
      (hbound X hX₀_le_X t htlo hthi)

/-- The floor-division large-square envelope upper bound implies the finite
count-envelope upper bound. -/
theorem roughDyadicLargeSquareDivisorEnvelopeUpperBoundModulusOne_of_floorEnvelope
    {a₀ b₀ C₀ E X₀ : ℝ}
    (hfloor : roughDyadicLargeSquareDivisorFloorEnvelopeUpperBoundModulusOne
      a₀ b₀ C₀ E X₀) :
    roughDyadicLargeSquareDivisorEnvelopeUpperBoundModulusOne
      a₀ b₀ C₀ E X₀ := by
  rcases hfloor with ⟨hE, hbound⟩
  refine ⟨hE, ?_⟩
  intro X hX t htlo hthi
  exact
    (roughDyadicLargeSquareDivisorEnvelopeSum_le_floorEnvelopeSum X t).trans
      (hbound X hX t htlo hthi)

/-- The finite large-square envelope upper bound implies the concrete
large-square count upper bound. -/
theorem roughDyadicLargeSquareDivisorUpperBoundModulusOne_of_envelope
    {a₀ b₀ C₀ E X₀ : ℝ}
    (henv : roughDyadicLargeSquareDivisorEnvelopeUpperBoundModulusOne
      a₀ b₀ C₀ E X₀) :
    roughDyadicLargeSquareDivisorUpperBoundModulusOne
      a₀ b₀ C₀ E X₀ := by
  rcases henv with ⟨hE, hbound⟩
  refine ⟨hE, ?_⟩
  intro X hX t htlo hthi
  exact
    (roughDyadicLargeSquareDivisorCount_le_envelopeSum X t).trans
      (hbound X hX t htlo hthi)

/-- A large-square tail upper bound implies the signed squarefree-loss upper
bound used by the product-error route. -/
theorem roughDyadicBadPrimeProductSquarefreeSignedLossUpperBoundModulusOne_of_largeSquareDivisor
    {a₀ b₀ C₀ E X₀ : ℝ}
    (hlarge : roughDyadicLargeSquareDivisorUpperBoundModulusOne
      a₀ b₀ C₀ E X₀) :
    roughDyadicBadPrimeProductSquarefreeSignedLossUpperBoundModulusOne
      a₀ b₀ C₀ E X₀ := by
  rcases hlarge with ⟨hE, hbound⟩
  refine ⟨hE, ?_⟩
  intro X hX t htlo hthi
  exact
    (roughDyadicBadPrimeProductSquarefreeSignedLossSum_le_largeSquareDivisorCount
      X t).trans (hbound X hX t htlo hthi)

/-- The lower signed squarefree-loss estimate is theorem-level: the signed
carrier is a nonnegative loss, so any nonnegative error budget gives the lower
one-sided bound once `X` is large enough for the normalizing factor to be
nonnegative. -/
theorem roughDyadicBadPrimeProductSquarefreeSignedLossLowerBoundModulusOne_of_nonneg
    (a₀ b₀ C₀ E : ℝ) (hE : 0 ≤ E) :
    ∃ X₀ : ℝ,
      roughDyadicBadPrimeProductSquarefreeSignedLossLowerBoundModulusOne
        a₀ b₀ C₀ E X₀ := by
  refine ⟨max 1 (Real.exp 2), hE, ?_⟩
  intro X hX t htlo _hthi
  have hXone : (1 : ℝ) ≤ X := le_trans (le_max_left _ _) hX
  have hXexp2 : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le zero_lt_one hXone
  have ht_nonneg : 0 ≤ t := by
    exact (Real.rpow_pos_of_pos hXpos a₀).le.trans htlo
  have hlog_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp2
  have hT_nonneg : 0 ≤ t / Real.log (EscAnalytic.zScale X) :=
    div_nonneg ht_nonneg hlog_pos.le
  have hleft :
      - (E * (t / Real.log (EscAnalytic.zScale X))) ≤ 0 := by
    exact neg_nonpos.mpr (mul_nonneg hE hT_nonneg)
  have hright :
      0 ≤ roughDyadicBadPrimeProductSquarefreeSignedLossSum X t :=
    roughDyadicBadPrimeProductSquarefreeSignedLossSum_nonneg X t
  exact hleft.trans hright

/-- An absolute multiples-discrepancy envelope implies the signed lower
multiples-discrepancy bound in the modulus-one lane. -/
theorem roughDyadicBadPrimeProductMultiplesSignedErrorLowerBoundModulusOne_of_localEnvelope
    {a₀ b₀ C₀ E Xenv : ℝ} (hC₀ : 0 ≤ C₀)
    (h :
      roughDyadicBadPrimeProductMultiplesLocalErrorEnvelopeBound
        a₀ b₀ C₀ E Xenv) :
    roughDyadicBadPrimeProductMultiplesSignedErrorLowerBoundModulusOne
      a₀ b₀ C₀ E (max Xenv 1) := by
  rcases h with ⟨hE_nonneg, h⟩
  refine ⟨hE_nonneg, ?_⟩
  intro X hX t htlo hthi
  have hXenv : Xenv ≤ X := le_trans (le_max_left _ _) hX
  have hXone : (1 : ℝ) ≤ X := le_trans (le_max_right _ _) hX
  have hMone : (((1 : ℕ) : ℝ) ≤ X ^ C₀) := by
    simpa using Real.one_le_rpow hXone hC₀
  have henv := h X hXenv 1 hMone t htlo hthi
  have habs :
      |roughDyadicBadPrimeProductMultiplesSignedErrorSum X t| ≤
        E * (t / Real.log (EscAnalytic.zScale X)) :=
    (abs_roughDyadicBadPrimeProductMultiplesSignedErrorSum_le_envelope X t).trans
      henv
  exact (neg_le_neg habs).trans (neg_abs_le _)

/-- An absolute multiples-discrepancy envelope implies the signed upper
multiples-discrepancy bound in the modulus-one lane. -/
theorem roughDyadicBadPrimeProductMultiplesSignedErrorUpperBoundModulusOne_of_localEnvelope
    {a₀ b₀ C₀ E Xenv : ℝ} (hC₀ : 0 ≤ C₀)
    (h :
      roughDyadicBadPrimeProductMultiplesLocalErrorEnvelopeBound
        a₀ b₀ C₀ E Xenv) :
    roughDyadicBadPrimeProductMultiplesSignedErrorUpperBoundModulusOne
      a₀ b₀ C₀ E (max Xenv 1) := by

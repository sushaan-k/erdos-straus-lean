    roughDyadicBadPrimeParityBound_iff_productCount_bound]

/-- The rough count primitive is equivalent to the lower and upper halves of
the explicit product-modulus inclusion-exclusion carrier. -/
theorem linear_sieve_rough_dyadic_count_bound_iff_badPrimeProductCount_lower_upper
    (a₀ b₀ C₀ : ℝ) :

/-- If finite certificates make every reduced base count needed by the rough
fibers vanish, then the whole rough-large range vanishes.

The hypothesis `hred_le_base` is the explicit bridge from the rough-counting
notion used by `LiftCount` to the reduced base-counting notion certified by
`EscLeanChecks`. -/
theorem roughLargeCount_eq_zero_of_reducedBase_certificates
    (z N : ℕ)
    (P R : ℕ → ℕ)
    (cert : ∀ M : ℕ,
      EscLeanChecks.SatEventRankBudgetCertificate M (P M) (R M))
    (hPfac : ∀ M : ℕ, M ≤ N →
      ∀ p : ℕ, Nat.Prime p → p ∣ P M → p ≤ z) :
    roughLargeCount z N = 0 := by
  classical
  have hrough := roughLargeCount_le_sum_reducedGeTwo z N
  have hsum_zero :
      (∑ s ∈ Finset.Icc 1 N, reducedExceptionalCountGeTwo z (N / s)) = 0 := by
    apply Finset.sum_eq_zero
    intro s _hs
    have hdiv : N / s ≤ N := Nat.div_le_self N s
    have hbase_zero :
        EscLeanChecks.reducedBaseExceptionalCountGeTwo (N / s) (P (N / s)) = 0 :=
      EscLeanChecks.reducedBaseExceptionalCountGeTwo_eq_zero_of_SatEventRankBudgetCertificate
        (N / s) (P (N / s)) (R (N / s)) (cert (N / s))
    exact Nat.eq_zero_of_le_zero
      (le_trans
        (reducedExceptionalCountGeTwo_le_reducedBaseExceptionalCountGeTwo
          z (N / s) (P (N / s)) (hPfac (N / s) hdiv))
        (by simp [hbase_zero]))
  exact Nat.eq_zero_of_le_zero (by simpa [hsum_zero] using hrough)


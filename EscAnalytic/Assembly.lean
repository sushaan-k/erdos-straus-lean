/-- Quartic large-range package for canonical reduced classes with the exact
canonical class-count budget and the concrete lifting layer.

Compared with
`QuarticLargeRangeInputs.of_canonical_sigma_classes_mu_lower_eps_half_local_card_transfer`,
this removes the arbitrary local `cardBound`, smooth carrier, Euler carrier,
and lifting inequality from the call surface.  The class-count budget is stated
directly for the canonical images, and the smooth/Euler/lift layer is supplied
by the existing Rankin smooth bound, the elementary fourth-log Euler bound, and
`rough_range_bound_of_reduced_sum`. -/
noncomputable def QuarticLargeRangeInputs.of_canonical_sigma_classes_mu_lower_eps_half_exact_card_budget_concrete_lift
    {κ : Type*} [DecidableEq κ]
    (classOfRed : ℕ → ℕ → ℕ → κ)
    (Pz μ ε : ℕ → ℝ)
    (cμ : ℝ) (T : ℕ)
    (hcμ : 0 < cμ)
    (hPz : ∀ N : ℕ, 3 ≤ N → T ≤ N → 1 ≤ Pz N)
    (hcard_budget : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      (∑ s ∈ Finset.Icc 1 N,
        ((reducedCanonicalClasses (zNatScale N) (N / s)
          (classOfRed N s)).card : ℝ)) ≤ Pz N)
    (htransfer_local : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      ∀ s ∈ Finset.Icc 1 N,
        ∀ b ∈ reducedCanonicalClasses (zNatScale N) (N / s) (classOfRed N s),
          (reducedExceptionalCount (zNatScale N) (N / s) : ℝ) ≤
            ((N : ℝ) / Pz N) * Real.exp (-(1 - ε N) * μ N))
    (hμ_lower : ∀ N : ℕ, 3 ≤ N → T ≤ N →
      cμ * (Real.log N) ^ ((4 : ℝ) / 5) ≤ μ N)
    (hε : ∀ N : ℕ, 3 ≤ N → T ≤ N → ε N ≤ (1 : ℝ) / 2) :
    QuarticLargeRangeInputs := by
  let hsmoothPkg := smoothRangeCount_zNatScale_polynomial_bound_with_carrier_bounds
  let smoothExp : ℝ := Classical.choose hsmoothPkg
  have hsmoothPkg₁ := Classical.choose_spec hsmoothPkg
  let smoothC : ℝ := Classical.choose hsmoothPkg₁
  have hsmoothSpec := Classical.choose_spec hsmoothPkg₁
  let eulerC : ℝ := Classical.choose eulerProductFactorAtNat_log_fourth_bound
  have heulerSpec := Classical.choose_spec eulerProductFactorAtNat_log_fourth_bound
  exact
    QuarticLargeRangeInputs.of_canonical_sigma_classes_mu_lower_eps_half_local_card_transfer
      classOfRed
      (fun N s =>
        ((reducedCanonicalClasses (zNatScale N) (N / s)
          (classOfRed N s)).card : ℝ))
      Pz μ ε
      (fun N => (smoothRangeCount (zNatScale N) N : ℝ))
      eulerProductFactorAtNat
      cμ smoothExp smoothC eulerC T
      hcμ hsmoothSpec.1 hsmoothSpec.2.1 hsmoothSpec.2.2.1 heulerSpec.1 hPz
      (by
        intro N hN hTN s hs
        exact le_rfl)
      hcard_budget htransfer_local hμ_lower hε
      (by
        intro N hN
        exact (hsmoothSpec.2.2.2 N hN).2.1)
      heulerSpec.2
      (by
        intro N hN
        have hrough_sum :
            (roughLargeCount (zNatScale N) N : ℝ) ≤
              (reducedSumCountFor zNatScale N : ℝ) := by
          exact_mod_cast roughLargeCount_le_sum_reduced (zNatScale N) N
        have hrough :
            (roughLargeCount (zNatScale N) N : ℝ) ≤
              eulerProductFactorAtNat N * (reducedSumCountFor zNatScale N : ℝ) := by
          have hsum_le :
              (reducedSumCountFor zNatScale N : ℝ) ≤
                eulerProductFactorAtNat N *
                  (reducedSumCountFor zNatScale N : ℝ) := by
            calc
              (reducedSumCountFor zNatScale N : ℝ) =
                  1 * (reducedSumCountFor zNatScale N : ℝ) := by ring
              _ ≤ eulerProductFactorAtNat N *
                    (reducedSumCountFor zNatScale N : ℝ) :=
                  mul_le_mul_of_nonneg_right
                    (eulerProductFactorAtNat_one_le N) (Nat.cast_nonneg _)
          exact le_trans hrough_sum hsum_le
        exact
          lift_of_range_bounds
            (le_rfl :
              (smoothRangeCount (zNatScale N) N : ℝ) ≤
                (smoothRangeCount (zNatScale N) N : ℝ))
            hrough)

/-- Canonical quartic class-count normalizer.

Choosing `Pz` to be the maximum of `1` and the exact canonical class count
discharges both the positivity and class-budget side conditions. -/
noncomputable def canonicalQuarticPz
    {κ : Type*} [DecidableEq κ]
    (classOfRed : ℕ → ℕ → ℕ → κ) (N : ℕ) : ℝ :=
  max 1
    (∑ s ∈ Finset.Icc 1 N,
      ((reducedCanonicalClasses (zNatScale N) (N / s)
        (classOfRed N s)).card : ℝ))

/-- The canonical quartic normalizer is at least one. -/
theorem canonicalQuarticPz_one_le
    {κ : Type*} [DecidableEq κ]
    (classOfRed : ℕ → ℕ → ℕ → κ) :
    ∀ N : ℕ, 3 ≤ N → ∀ T : ℕ, T ≤ N →
      1 ≤ canonicalQuarticPz classOfRed N := by
  intro N _hN _T _hTN
  exact le_max_left _ _

/-- The exact canonical class-count budget is automatic for
`canonicalQuarticPz`. -/
theorem canonicalQuarticPz_card_budget
    {κ : Type*} [DecidableEq κ]
    (classOfRed : ℕ → ℕ → ℕ → κ) :
    ∀ N : ℕ, 3 ≤ N → ∀ T : ℕ, T ≤ N →
      (∑ s ∈ Finset.Icc 1 N,
        ((reducedCanonicalClasses (zNatScale N) (N / s)
          (classOfRed N s)).card : ℝ)) ≤
        canonicalQuarticPz classOfRed N := by
  intro N _hN _T _hTN
  exact le_max_right _ _


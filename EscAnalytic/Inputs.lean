/-- Conditional reduction of the public modulus-one lower primitive to the
older explicit Mertens/product-error component package.

This theorem is not part of the exported axiom frontier.  It records that if
one proves the standard sharp prime-reciprocal Mertens bound and the two
non-auxiliary quarter-budget component estimates, then the current count-level
modulus-one lower primitive follows. -/
theorem linear_sieve_rough_dyadic_modulus_one_lower_bound_of_primeRecipSharpMertens_and_productErrorComponents
    (hmult : LinearSieveRoughDyadicMultiplesErrorQuarterBound)
    (hsqf : LinearSieveRoughDyadicSquarefreeLossQuarterBound)
    (hmertens : PrimeRecipSharpMertensUpperBound)
    (a₀ b₀ C₀ : ℝ) :
    roughDyadicCountModulusOneLowerBound a₀ b₀ C₀ := by
  rcases
    roughDyadicBadPrimeMainEulerProductLowerBound_of_primeRecipSharpMertens
      (rough_modulus_prime_recip_sharp_mertens_upper_bound hmertens) with
    ⟨c, Xprod, hc, hprod⟩
  let C : ℝ := max C₀ 0
  let Xprod' : ℝ := max Xprod (Real.exp 2)
  have hC_nonneg : 0 ≤ C := by
    dsimp [C]
    exact le_max_right C₀ 0
  have hc_quarter : 0 < c / 4 := by positivity
  have hprod_quarter :
      ∀ X : ℝ, Xprod' ≤ X →
        (c / 4) / Real.log (EscAnalytic.zScale X) ≤
          roughDyadicBadPrimeMainEulerProduct X := by
    intro X hX
    have hXprod : Xprod ≤ X := le_trans (le_max_left _ _) hX
    have hXexp2 : Real.exp 2 ≤ X := le_trans (le_max_right _ _) hX
    have hlogZ_pos : 0 < Real.log (EscAnalytic.zScale X) :=
      log_zScale_pos_of_exp_two_le hXexp2
    calc
      (c / 4) / Real.log (EscAnalytic.zScale X)
          ≤ c / Real.log (EscAnalytic.zScale X) :=
            div_le_div_of_nonneg_right (by linarith) hlogZ_pos.le
      _ ≤ roughDyadicBadPrimeMainEulerProduct X := hprod X hXprod
  rcases hmult a₀ b₀ C (c / 4) Xprod' hc_quarter hprod_quarter with
    ⟨Xm, hm⟩
  rcases hsqf a₀ b₀ C (c / 4) Xprod' hc_quarter hprod_quarter with
    ⟨Xs, hs⟩
  have hE_lt : (c / 4) / 4 + (c / 4) / 4 < c := by
    linarith
  have honeC : roughDyadicCountModulusOneLowerBound a₀ b₀ C :=
    roughDyadicCountModulusOneLowerBound_of_productLower_and_multiples_squarefree
      hC_nonneg hc hE_lt hprod hm hs
  simpa [roughDyadicCountModulusOneLowerBound] using honeC


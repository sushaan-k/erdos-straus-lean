/-- A chosen squarefree kernel in the decomposition `n = b² a`. -/
noncomputable def sfPart (n : ℕ) : ℕ :=
  Classical.choose (Nat.sq_mul_squarefree n)

/-- A chosen square part in the decomposition `n = b² a`. -/
noncomputable def sqPart (n : ℕ) : ℕ :=
  Classical.choose (Classical.choose_spec (Nat.sq_mul_squarefree n))

/-- Specification of the chosen squarefree decomposition. -/
theorem sfPart_spec (n : ℕ) :
    sqPart n ^ 2 * sfPart n = n ∧ Squarefree (sfPart n) := by
  unfold sfPart sqPart
  exact Classical.choose_spec (Classical.choose_spec (Nat.sq_mul_squarefree n))

/-- The squarefree kernel of a positive integer is positive. -/
theorem sfPart_pos {n : ℕ} (hn : 0 < n) : 0 < sfPart n := by
  have hprod := (sfPart_spec n).1
  by_contra h
  have ha0 : sfPart n = 0 := Nat.eq_zero_of_not_pos h
  rw [ha0, Nat.mul_zero] at hprod
  omega

/-- The square part of a positive integer is positive. -/
theorem sqPart_pos {n : ℕ} (hn : 0 < n) : 0 < sqPart n := by
  have hprod := (sfPart_spec n).1
  by_contra h
  have hb0 : sqPart n = 0 := Nat.eq_zero_of_not_pos h
  rw [hb0] at hprod
  norm_num at hprod
  omega

/-- The squarefree kernel is at most the original positive integer. -/
theorem sfPart_le_self {n : ℕ} (hn : 0 < n) : sfPart n ≤ n := by
  have hprod := (sfPart_spec n).1
  have hbpos : 0 < sqPart n := sqPart_pos hn
  have hsqpos : 0 < sqPart n ^ 2 := pow_pos hbpos 2
  calc
    sfPart n ≤ sqPart n ^ 2 * sfPart n := Nat.le_mul_of_pos_left (sfPart n) hsqpos
    _ = n := hprod

/-- The square part is at most the original positive integer. -/
theorem sqPart_le_self {n : ℕ} (hn : 0 < n) : sqPart n ≤ n := by
  have hprod := (sfPart_spec n).1
  have hsfpos : 0 < sfPart n := sfPart_pos hn
  calc
    sqPart n ≤ sqPart n ^ 2 := Nat.le_self_pow (by norm_num : 2 ≠ 0) (sqPart n)
    _ ≤ sqPart n ^ 2 * sfPart n := Nat.le_mul_of_pos_right (sqPart n ^ 2) hsfpos
    _ = n := hprod

/-- The elementary finite bound `∑_{b≤Y} 1/b² ≤ 2`. -/
theorem square_recip_sum_le_two (Y : ℕ) :
    (∑ b ∈ Finset.Icc (1 : ℕ) Y, ((b : ℝ) ^ 2)⁻¹) ≤ 2 := by
  by_cases hY : 1 ≤ Y
  · rw [Finset.Icc_eq_cons_Ioc hY, Finset.sum_cons]
    have htail : (∑ b ∈ Finset.Ioc (1 : ℕ) Y, ((b : ℝ) ^ 2)⁻¹) ≤ (1 : ℝ) := by
      have h := (sum_Ioc_inv_sq_le_sub (α := ℝ) (k := 1) (n := Y) (by norm_num) hY)
      have h' :
          (∑ b ∈ Finset.Ioc (1 : ℕ) Y, ((b : ℝ) ^ 2)⁻¹)
            ≤ (1 : ℝ) - ((Y : ℝ))⁻¹ := by
        simpa using h
      have hnonneg : (0 : ℝ) ≤ ((Y : ℝ))⁻¹ :=
        inv_nonneg.mpr (Nat.cast_nonneg Y)
      linarith
    norm_num
    linarith
  · have hempty : Finset.Icc (1 : ℕ) Y = ∅ := by
      rw [Finset.eq_empty_iff_forall_not_mem]
      intro b hb
      exact hY (le_trans (Finset.mem_Icc.mp hb).1 (Finset.mem_Icc.mp hb).2)
    rw [hempty, Finset.sum_empty]
    norm_num

/-- Decomposing every `n ≤ Y` as `b²a` with `a` squarefree compares the full
harmonic sum to squarefree reciprocal mass times the elementary square tail. -/
theorem harmonic_le_squarefree_recip_mul_square_recip (Y : ℕ) :
    ((harmonic Y : ℚ) : ℝ)
      ≤ (∑ a ∈ (Finset.Icc (1 : ℕ) Y).filter (fun a => Squarefree a),
            (1 : ℝ) / (a : ℝ)) *
          (∑ b ∈ Finset.Icc (1 : ℕ) Y, ((b : ℝ) ^ 2)⁻¹) := by
  classical
  let base : Finset ℕ := Finset.Icc (1 : ℕ) Y
  let sfSet : Finset ℕ := base.filter (fun a => Squarefree a)
  let F : ℕ → ℕ × ℕ := fun n => (sfPart n, sqPart n)
  let G : ℕ × ℕ → ℝ := fun p => ((1 : ℝ) / (p.1 : ℝ)) * (((p.2 : ℝ) ^ 2)⁻¹)
  have hF_mem : ∀ n ∈ base, F n ∈ sfSet.product base := by
    intro n hn
    have hnpos : 0 < n := lt_of_lt_of_le Nat.zero_lt_one (Finset.mem_Icc.mp hn).1
    have hnle : n ≤ Y := (Finset.mem_Icc.mp hn).2
    change F n ∈ sfSet ×ˢ base
    rw [Finset.mem_product]
    constructor
    · rw [Finset.mem_filter]
      exact ⟨Finset.mem_Icc.mpr ⟨sfPart_pos hnpos, le_trans (sfPart_le_self hnpos) hnle⟩,
        (sfPart_spec n).2⟩
    · exact Finset.mem_Icc.mpr ⟨sqPart_pos hnpos, le_trans (sqPart_le_self hnpos) hnle⟩
  have hF_inj : ∀ n ∈ base, ∀ m ∈ base, F n = F m → n = m := by
    intro n _hn m _hm hnm
    have hnprod := (sfPart_spec n).1
    have hmprod := (sfPart_spec m).1
    have ha : sfPart n = sfPart m := congrArg Prod.fst hnm
    have hb : sqPart n = sqPart m := congrArg Prod.snd hnm
    rw [← hnprod, ← hmprod, ha, hb]
  have hsource_to_image :
      (∑ n ∈ base, (1 : ℝ) / (n : ℝ)) = ∑ p ∈ base.image F, G p := by
    rw [Finset.sum_image]
    · apply Finset.sum_congr rfl
      intro n hn
      have hnpos_nat : 0 < n := lt_of_lt_of_le Nat.zero_lt_one (Finset.mem_Icc.mp hn).1
      have hapos_nat : 0 < sfPart n := sfPart_pos hnpos_nat
      have hbpos_nat : 0 < sqPart n := sqPart_pos hnpos_nat
      have hapos : (sfPart n : ℝ) ≠ 0 := by exact_mod_cast (ne_of_gt hapos_nat)
      have hbpos : (sqPart n : ℝ) ≠ 0 := by exact_mod_cast (ne_of_gt hbpos_nat)
      have hprod := (sfPart_spec n).1
      have hcast :
          ((sqPart n ^ 2 * sfPart n : ℕ) : ℝ)
            = (sqPart n : ℝ) ^ 2 * (sfPart n : ℝ) := by
        norm_num [Nat.cast_mul, Nat.cast_pow]
      calc
        (1 : ℝ) / (n : ℝ)
            = (1 : ℝ) / ((sqPart n ^ 2 * sfPart n : ℕ) : ℝ) := by rw [hprod]
        _ = (1 : ℝ) / ((sqPart n : ℝ) ^ 2 * (sfPart n : ℝ)) := by rw [hcast]
        _ = ((1 : ℝ) / (sfPart n : ℝ)) * (((sqPart n : ℝ) ^ 2)⁻¹) := by
              field_simp [hapos, hbpos]
              ring
        _ = G (F n) := by simp [G, F]
    · intro n hn m hm hnm
      exact hF_inj n hn m hm hnm
  have himage_subset : base.image F ⊆ sfSet.product base := by
    intro p hp
    rw [Finset.mem_image] at hp
    rcases hp with ⟨n, hn, rfl⟩
    exact hF_mem n hn
  have hnonneg_extra : ∀ p ∈ sfSet.product base, p ∉ base.image F → 0 ≤ G p := by
    intro p _hp _
    unfold G
    exact mul_nonneg (div_nonneg zero_le_one (Nat.cast_nonneg _))
      (inv_nonneg.mpr (sq_nonneg _))
  have himage_le_product :
      (∑ p ∈ base.image F, G p) ≤ ∑ p ∈ sfSet.product base, G p :=
    Finset.sum_le_sum_of_subset_of_nonneg himage_subset hnonneg_extra
  have hproduct_eq :
      (∑ p ∈ sfSet.product base, G p)
        = (∑ a ∈ sfSet, (1 : ℝ) / (a : ℝ)) *
            (∑ b ∈ base, ((b : ℝ) ^ 2)⁻¹) := by
    change (∑ p ∈ sfSet ×ˢ base, G p) = _
    rw [Finset.sum_product]
    unfold G
    rw [Finset.sum_mul]
    apply Finset.sum_congr rfl
    intro a _ha
    rw [Finset.mul_sum]
  have hharm_eq : ((harmonic Y : ℚ) : ℝ) = ∑ n ∈ base, (1 : ℝ) / (n : ℝ) := by
    rw [harmonic_eq_sum_Icc]
    unfold base
    simp only [Rat.cast_sum, Rat.cast_inv, Rat.cast_natCast]
    simp_rw [one_div]
  calc
    ((harmonic Y : ℚ) : ℝ) = ∑ n ∈ base, (1 : ℝ) / (n : ℝ) := hharm_eq
    _ = ∑ p ∈ base.image F, G p := hsource_to_image
    _ ≤ ∑ p ∈ sfSet.product base, G p := himage_le_product
    _ = (∑ a ∈ sfSet, (1 : ℝ) / (a : ℝ)) *
            (∑ b ∈ base, ((b : ℝ) ^ 2)⁻¹) := hproduct_eq

/-- The squarefree reciprocal conductor sum has logarithmic lower growth. -/
theorem s_average_recip_lower (P : EscAnalytic.Params) :
    ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.SScale P X) ≤ sAvgRecip P X :=
  s_average_recip_lower_for_coprime P

/-- `lem:s-average`, second sum (tex 942): `∑_{s ≤ X^η, μ²(s)} 1/s ≍ log S`.
Both bounds are now elementary: the lower bound uses squarefree decomposition
`n = b²a`, and the upper bound follows from the harmonic-series estimate. -/
theorem s_average_recip (P : EscAnalytic.Params) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.SScale P X) ≤ sAvgRecip P X
        ∧ sAvgRecip P X ≤ C * Real.log (EscAnalytic.SScale P X) := by
  obtain ⟨c, Xlo, hc, hlo⟩ := s_average_recip_lower P
  obtain ⟨C, Xhi, hC, hhi⟩ := sAvgRecip_upper_unconditional P
  refine ⟨c, C, max Xlo Xhi, hc, hC, ?_⟩
  intro X hX
  have hXlo : Xlo ≤ X := le_trans (le_max_left _ _) hX
  have hXhi : Xhi ≤ X := le_trans (le_max_right _ _) hX
  exact ⟨hlo X hXlo, hhi X hXhi⟩

/-- A bare two-sided squarefree reciprocal estimate gives the carrier-bundled
version with logarithm nonnegativity, carrier nonnegativity, and absolute-value
side conditions. -/
theorem s_average_recip_with_carrier_bounds_of_bounds
    (P : EscAnalytic.Params)
    (h :
      ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        c * Real.log (EscAnalytic.SScale P X) ≤ sAvgRecip P X ∧
          sAvgRecip P X ≤ C * Real.log (EscAnalytic.SScale P X)) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      0 ≤ Real.log (EscAnalytic.SScale P X) ∧
        0 ≤ sAvgRecip P X ∧
        c * Real.log (EscAnalytic.SScale P X) ≤ sAvgRecip P X ∧
        sAvgRecip P X ≤ C * Real.log (EscAnalytic.SScale P X) ∧
        |sAvgRecip P X| ≤ C * Real.log (EscAnalytic.SScale P X) := by
  rcases h with ⟨c, C, Xbase, hc, hC, hbounds⟩
  refine ⟨c, C, max Xbase 1, hc, hC, ?_⟩
  intro X hX
  have hXbase : Xbase ≤ X := le_trans (le_max_left _ _) hX
  have hXone : (1 : ℝ) ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le zero_lt_one hXone
  have hlogS_nonneg : 0 ≤ Real.log (EscAnalytic.SScale P X) := by
    unfold EscAnalytic.SScale
    rw [Real.log_rpow hXpos]
    exact mul_nonneg P.η_pos.le (Real.log_nonneg hXone)
  have hcarrier_nonneg : 0 ≤ sAvgRecip P X := sAvgRecip_nonneg P X
  rcases hbounds X hXbase with ⟨hlower, hupper⟩
  exact ⟨hlogS_nonneg, hcarrier_nonneg, hlower, hupper, by
    rw [abs_of_nonneg hcarrier_nonneg]
    exact hupper⟩

/-- Forget the checked side conditions from a bundled squarefree reciprocal
estimate. -/
theorem s_average_recip_bounds_of_carrier_bounds
    (P : EscAnalytic.Params)
    (h :
      ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        0 ≤ Real.log (EscAnalytic.SScale P X) ∧
          0 ≤ sAvgRecip P X ∧
          c * Real.log (EscAnalytic.SScale P X) ≤ sAvgRecip P X ∧
          sAvgRecip P X ≤ C * Real.log (EscAnalytic.SScale P X) ∧
          |sAvgRecip P X| ≤ C * Real.log (EscAnalytic.SScale P X)) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.SScale P X) ≤ sAvgRecip P X ∧
        sAvgRecip P X ≤ C * Real.log (EscAnalytic.SScale P X) := by
  rcases h with ⟨c, C, X₀, hc, hC, hcarrier⟩
  refine ⟨c, C, X₀, hc, hC, ?_⟩
  intro X hX
  have hpack := hcarrier X hX
  exact ⟨hpack.2.2.1, hpack.2.2.2.1⟩

/-- Bare and carrier-bundled squarefree reciprocal estimates have the same
analytic content. -/
theorem s_average_recip_bounds_iff_carrier_bounds
    (P : EscAnalytic.Params) :
    (∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.SScale P X) ≤ sAvgRecip P X ∧
        sAvgRecip P X ≤ C * Real.log (EscAnalytic.SScale P X)) ↔
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      0 ≤ Real.log (EscAnalytic.SScale P X) ∧
        0 ≤ sAvgRecip P X ∧
        c * Real.log (EscAnalytic.SScale P X) ≤ sAvgRecip P X ∧
        sAvgRecip P X ≤ C * Real.log (EscAnalytic.SScale P X) ∧
        |sAvgRecip P X| ≤ C * Real.log (EscAnalytic.SScale P X) := by
  constructor
  · exact s_average_recip_with_carrier_bounds_of_bounds P
  · exact s_average_recip_bounds_of_carrier_bounds P

/-- Carrier-bundled form of the unconditional squarefree reciprocal estimate. -/
theorem s_average_recip_with_carrier_bounds (P : EscAnalytic.Params) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      0 ≤ Real.log (EscAnalytic.SScale P X) ∧
        0 ≤ sAvgRecip P X ∧
        c * Real.log (EscAnalytic.SScale P X) ≤ sAvgRecip P X ∧
        sAvgRecip P X ≤ C * Real.log (EscAnalytic.SScale P X) ∧
        |sAvgRecip P X| ≤ C * Real.log (EscAnalytic.SScale P X) :=
  s_average_recip_with_carrier_bounds_of_bounds P (s_average_recip P)

/-- With coprimality modulus `1`, the coprime squarefree reciprocal carrier is
exactly the ordinary squarefree reciprocal carrier. -/
theorem sAvgRecipCoprime_one_eq_sAvgRecip (P : EscAnalytic.Params) (X : ℝ) :
    sAvgRecipCoprime P X 1 = sAvgRecip P X := by
  classical
  unfold sAvgRecipCoprime sAvgRecip
  congr 1
  apply Finset.ext
  intro s
  simp

/-- The `d = 1` case of the coprime squarefree reciprocal lower estimate is a
theorem, not an external input.  The hard input is the uniform loss for general
coprimality modulus `d`. -/
theorem sAvgRecipCoprime_one_lower (P : EscAnalytic.Params) :
    ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.SScale P X) ≤ sAvgRecipCoprime P X 1 := by
  rcases s_average_recip_lower P with ⟨c, X₀, hc, hlow⟩
  refine ⟨c, X₀, hc, ?_⟩
  intro X hX
  simpa [sAvgRecipCoprime_one_eq_sAvgRecip P X] using hlow X hX

/-- The `d = 1` case in the exact local-density form used by the uniform coprime
reciprocal input. -/
theorem sAvgRecipCoprime_one_lower_with_totient (P : EscAnalytic.Params) :
    ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.SScale P X) *
          ((Nat.totient (1 : ℕ) : ℝ) / ((1 : ℕ) : ℝ))
        ≤ sAvgRecipCoprime P X 1 := by
  rcases sAvgRecipCoprime_one_lower P with ⟨c, X₀, hc, hlow⟩
  refine ⟨c, X₀, hc, ?_⟩
  intro X hX
  simpa [Nat.totient_one] using hlow X hX

/-- The `d = 1` term alone lower-bounds the full small-divisor average by the
ordinary squarefree reciprocal carrier.  This is a foundation-only nontriviality
fallback; the intended extra `log z` factor still comes from the Euler-sum lower
input. -/
theorem sAvgRecip_le_smallDivisorAverage_of_one_le_UScale
    (P : EscAnalytic.Params) (X : ℝ)
    (hU : 1 ≤ EscAnalytic.UScale X) :
    sAvgRecip P X ≤ smallDivisorAverage P X := by
  classical
  let Dset : Finset ℕ :=
    (Finset.Icc (1 : ℕ) ⌊EscAnalytic.UScale X⌋₊).filter
      (fun d => d ∣ roughModulus X ∧ Odd d)
  have hone_mem : (1 : ℕ) ∈ Dset := by
    dsimp [Dset]
    rw [Finset.mem_filter, Finset.mem_Icc]
    have hU' : ((1 : ℕ) : ℝ) ≤ EscAnalytic.UScale X := by simpa using hU
    exact ⟨⟨le_rfl, Nat.le_floor hU'⟩, ⟨one_dvd _, by norm_num⟩⟩
  have hnonneg :
      ∀ d ∈ Dset, 0 ≤ (1 : ℝ) / (d : ℝ) * sAvgRecipCoprime P X d := by
    intro d hd
    have hdIcc : d ∈ Finset.Icc (1 : ℕ) ⌊EscAnalytic.UScale X⌋₊ :=
      (Finset.mem_filter.mp hd).1
    have hdpos_nat : 0 < d :=
      lt_of_lt_of_le Nat.zero_lt_one (Finset.mem_Icc.mp hdIcc).1
    have hdpos : (0 : ℝ) < d := by exact_mod_cast hdpos_nat
    exact mul_nonneg (div_nonneg zero_le_one hdpos.le)
      (sAvgRecipCoprime_nonneg P X d)
  have hsingle :
      (1 : ℝ) / ((1 : ℕ) : ℝ) * sAvgRecipCoprime P X 1
        ≤ ∑ d ∈ Dset, (1 : ℝ) / (d : ℝ) * sAvgRecipCoprime P X d :=
    Finset.single_le_sum hnonneg hone_mem
  have hsum :
      smallDivisorAverage P X =
        ∑ d ∈ Dset, (1 : ℝ) / (d : ℝ) * sAvgRecipCoprime P X d := by
    simpa [Dset] using smallDivisorAverage_eq_sum_coprime P X
  calc
    sAvgRecip P X = (1 : ℝ) / ((1 : ℕ) : ℝ) * sAvgRecipCoprime P X 1 := by
      simp [sAvgRecipCoprime_one_eq_sAvgRecip P X]
    _ ≤ ∑ d ∈ Dset, (1 : ℝ) / (d : ℝ) * sAvgRecipCoprime P X d := hsingle
    _ = smallDivisorAverage P X := hsum.symm

/-- Foundation-only logarithmic lower fallback for the small-divisor average.
This uses only the `d = 1` term and therefore does not claim the intended
additional `log z` gain. -/
theorem smallDivisorAverage_lower_logS_unconditional (P : EscAnalytic.Params) :
    ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.SScale P X) ≤ smallDivisorAverage P X := by
  rcases s_average_recip_lower P with ⟨c, Xlo, hc, hlow⟩
  refine ⟨c, max Xlo (Real.exp 1), hc, ?_⟩
  intro X hX
  have hXlo : Xlo ≤ X := le_trans (le_max_left _ _) hX
  have hXexp : Real.exp 1 ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 1) hXexp
  have hlogX_ge_one : (1 : ℝ) ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hXexp
  have hU : 1 ≤ EscAnalytic.UScale X := by
    unfold EscAnalytic.UScale
    calc
      (1 : ℝ) = (1 : ℝ) ^ (8 : ℕ) := by norm_num
      _ ≤ (Real.log X) ^ (8 : ℕ) :=
        pow_le_pow_left₀ zero_le_one hlogX_ge_one 8
  exact (hlow X hXlo).trans (sAvgRecip_le_smallDivisorAverage_of_one_le_UScale P X hU)

/-- A bare `log S` lower bound for the small-divisor average gives the
carrier-bundled version with logarithm and finite-carrier nonnegativity. -/
theorem smallDivisorAverage_lower_logS_with_carrier_bounds_of_lower_bound
    (P : EscAnalytic.Params)
    (h :
      ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
        c * Real.log (EscAnalytic.SScale P X) ≤ smallDivisorAverage P X) :
    ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      0 ≤ Real.log (EscAnalytic.SScale P X) ∧
        0 ≤ smallDivisorAverage P X ∧
        c * Real.log (EscAnalytic.SScale P X) ≤ smallDivisorAverage P X := by
  rcases h with ⟨c, Xlo, hc, hlow⟩
  refine ⟨c, max Xlo 1, hc, ?_⟩
  intro X hX
  have hXlo : Xlo ≤ X := le_trans (le_max_left _ _) hX
  have hXone : (1 : ℝ) ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le zero_lt_one hXone
  have hlogS_nonneg : 0 ≤ Real.log (EscAnalytic.SScale P X) := by
    unfold EscAnalytic.SScale
    rw [Real.log_rpow hXpos]
    exact mul_nonneg P.η_pos.le (Real.log_nonneg hXone)
  exact ⟨hlogS_nonneg, smallDivisorAverage_nonneg P X, hlow X hXlo⟩

/-- Forget the checked side conditions from a bundled `log S` lower bound for
the small-divisor average. -/
theorem smallDivisorAverage_lower_logS_bound_of_carrier_bounds
    (P : EscAnalytic.Params)
    (h :
      ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
        0 ≤ Real.log (EscAnalytic.SScale P X) ∧
          0 ≤ smallDivisorAverage P X ∧
          c * Real.log (EscAnalytic.SScale P X) ≤ smallDivisorAverage P X) :
    ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.SScale P X) ≤ smallDivisorAverage P X := by
  rcases h with ⟨c, X₀, hc, hcarrier⟩
  refine ⟨c, X₀, hc, ?_⟩
  intro X hX
  exact (hcarrier X hX).2.2

/-- Bare and carrier-bundled `log S` lower bounds for the small-divisor average
have the same analytic content. -/
theorem smallDivisorAverage_lower_logS_bound_iff_carrier_bounds
    (P : EscAnalytic.Params) :
    (∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.SScale P X) ≤ smallDivisorAverage P X) ↔
    ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      0 ≤ Real.log (EscAnalytic.SScale P X) ∧
        0 ≤ smallDivisorAverage P X ∧
        c * Real.log (EscAnalytic.SScale P X) ≤ smallDivisorAverage P X := by
  constructor
  · exact smallDivisorAverage_lower_logS_with_carrier_bounds_of_lower_bound P
  · exact smallDivisorAverage_lower_logS_bound_of_carrier_bounds P

/-- Carrier-bounded version of the foundation-only small-divisor lower fallback.

The lower bound here uses only the `d = 1` slice, so it proves the `log S`
piece without the finite-witness Euler/Mertens input. -/
theorem smallDivisorAverage_lower_logS_unconditional_with_carrier_bounds
    (P : EscAnalytic.Params) :
    ∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      0 ≤ Real.log (EscAnalytic.SScale P X) ∧
        0 ≤ smallDivisorAverage P X ∧
        c * Real.log (EscAnalytic.SScale P X) ≤ smallDivisorAverage P X :=
  smallDivisorAverage_lower_logS_with_carrier_bounds_of_lower_bound P
    (smallDivisorAverage_lower_logS_unconditional P)

/-- Mertens-free fallback package for the small-divisor average.

This is the axiom-free version of the small-divisor estimate currently available
from the finite carriers alone: the `d = 1` slice supplies the `log S` lower
bound, while the checked harmonic estimate gives the usual `log S log z` upper
bound.  The missing arithmetic content in the full two-sided theorem is exactly
the extra lower `log z` factor. -/
theorem smallDivisorAverage_mertensFree_with_carrier_bounds
    (P : EscAnalytic.Params) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      0 ≤ Real.log (EscAnalytic.SScale P X) ∧
        0 ≤ Real.log (EscAnalytic.zScale X) ∧
        0 ≤ smallDivisorAverage P X ∧
        c * Real.log (EscAnalytic.SScale P X) ≤ smallDivisorAverage P X ∧
        smallDivisorAverage P X
          ≤ C * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X) ∧
        |smallDivisorAverage P X|
          ≤ C * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X) := by
  rcases smallDivisorAverage_lower_logS_unconditional P with ⟨c, Xlow, hc, hlow⟩
  rcases smallDivisorAverage_upper_unconditional P with ⟨C, Xup, hC, hup⟩
  refine ⟨c, C, max (max Xlow Xup) (Real.exp (Real.exp 1)), hc, hC, ?_⟩
  intro X hX
  have hXlow : Xlow ≤ X := le_trans (le_trans (le_max_left _ _) (le_max_left _ _)) hX
  have hXup : Xup ≤ X := le_trans (le_trans (le_max_right _ _) (le_max_left _ _)) hX
  have hXexp2 : Real.exp (Real.exp 1) ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos _) hXexp2
  have hXone : (1 : ℝ) ≤ X :=
    le_trans (by
      calc
        (1 : ℝ) = Real.exp 0 := by rw [Real.exp_zero]
        _ ≤ Real.exp (Real.exp 1) := Real.exp_le_exp.mpr (Real.exp_pos 1).le) hXexp2
  have hlogS_nonneg : 0 ≤ Real.log (EscAnalytic.SScale P X) := by
    unfold EscAnalytic.SScale
    rw [Real.log_rpow hXpos]
    exact mul_nonneg P.η_pos.le (Real.log_nonneg hXone)
  have hlogX_ge_exp : Real.exp 1 ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hXexp2
  have hlogX_ge_one : (1 : ℝ) ≤ Real.log X :=
    le_trans (by norm_num : (1 : ℝ) ≤ Real.exp 1) hlogX_ge_exp
  have hlogZ_nonneg : 0 ≤ Real.log (EscAnalytic.zScale X) := by
    have hloglog_nonneg : 0 ≤ Real.log (Real.log X) :=
      Real.log_nonneg hlogX_ge_one
    unfold EscAnalytic.zScale
    rw [Real.log_pow]
    nlinarith
  have hlower := hlow X hXlow
  have hupper := hup X hXup
  have habs : |smallDivisorAverage P X| ≤
      C * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X) := by
    rw [abs_of_nonneg (smallDivisorAverage_nonneg P X)]
    exact hupper
  exact ⟨hlogS_nonneg, hlogZ_nonneg, smallDivisorAverage_nonneg P X,
    hlower, hupper, habs⟩

/-- Bare Mertens-free lower and upper bounds imply the checked carrier package
for the small-divisor average. -/
theorem smallDivisorAverage_mertensFree_with_carrier_bounds_of_bounds
    (P : EscAnalytic.Params)
    (h :
      (∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
        c * Real.log (EscAnalytic.SScale P X) ≤ smallDivisorAverage P X) ∧
      (∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        smallDivisorAverage P X
          ≤ C * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X))) :
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      0 ≤ Real.log (EscAnalytic.SScale P X) ∧
        0 ≤ Real.log (EscAnalytic.zScale X) ∧
        0 ≤ smallDivisorAverage P X ∧
        c * Real.log (EscAnalytic.SScale P X) ≤ smallDivisorAverage P X ∧
        smallDivisorAverage P X
          ≤ C * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X) ∧
        |smallDivisorAverage P X|
          ≤ C * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X) := by
  rcases h with ⟨⟨c, Xlow, hc, hlow⟩, ⟨C, Xup, hC, hup⟩⟩
  refine ⟨c, C, max (max Xlow Xup) (Real.exp (Real.exp 1)), hc, hC, ?_⟩
  intro X hX
  have hXlow : Xlow ≤ X := le_trans (le_trans (le_max_left _ _) (le_max_left _ _)) hX
  have hXup : Xup ≤ X := le_trans (le_trans (le_max_right _ _) (le_max_left _ _)) hX
  have hXexp2 : Real.exp (Real.exp 1) ≤ X := le_trans (le_max_right _ _) hX
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos _) hXexp2
  have hXone : (1 : ℝ) ≤ X :=
    le_trans (by
      calc
        (1 : ℝ) = Real.exp 0 := by rw [Real.exp_zero]
        _ ≤ Real.exp (Real.exp 1) := Real.exp_le_exp.mpr (Real.exp_pos 1).le) hXexp2
  have hlogS_nonneg : 0 ≤ Real.log (EscAnalytic.SScale P X) := by
    unfold EscAnalytic.SScale
    rw [Real.log_rpow hXpos]
    exact mul_nonneg P.η_pos.le (Real.log_nonneg hXone)
  have hlogX_ge_exp : Real.exp 1 ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hXexp2
  have hlogX_ge_one : (1 : ℝ) ≤ Real.log X :=
    le_trans (by norm_num : (1 : ℝ) ≤ Real.exp 1) hlogX_ge_exp
  have hlogZ_nonneg : 0 ≤ Real.log (EscAnalytic.zScale X) := by
    have hloglog_nonneg : 0 ≤ Real.log (Real.log X) :=
      Real.log_nonneg hlogX_ge_one
    unfold EscAnalytic.zScale
    rw [Real.log_pow]
    nlinarith
  have hcarrier_nonneg : 0 ≤ smallDivisorAverage P X := smallDivisorAverage_nonneg P X
  have hlower := hlow X hXlow
  have hupper := hup X hXup
  have habs : |smallDivisorAverage P X| ≤
      C * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X) := by
    rw [abs_of_nonneg hcarrier_nonneg]
    exact hupper
  exact ⟨hlogS_nonneg, hlogZ_nonneg, hcarrier_nonneg, hlower, hupper, habs⟩

/-- Forget the checked side conditions from the Mertens-free small-divisor
average package. -/
theorem smallDivisorAverage_mertensFree_bounds_of_carrier_bounds
    (P : EscAnalytic.Params)
    (h :
      ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        0 ≤ Real.log (EscAnalytic.SScale P X) ∧
          0 ≤ Real.log (EscAnalytic.zScale X) ∧
          0 ≤ smallDivisorAverage P X ∧
          c * Real.log (EscAnalytic.SScale P X) ≤ smallDivisorAverage P X ∧
          smallDivisorAverage P X
            ≤ C * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X) ∧
          |smallDivisorAverage P X|
            ≤ C * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X)) :
    (∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.SScale P X) ≤ smallDivisorAverage P X) ∧
    (∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      smallDivisorAverage P X
        ≤ C * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X)) := by
  rcases h with ⟨c, C, X₀, hc, hC, hcarrier⟩
  constructor
  · refine ⟨c, X₀, hc, ?_⟩
    intro X hX
    exact (hcarrier X hX).2.2.2.1
  · refine ⟨C, X₀, hC, ?_⟩
    intro X hX
    exact (hcarrier X hX).2.2.2.2.1

/-- The Mertens-free small-divisor average carrier package is equivalent to its
bare lower and upper estimates. -/
theorem smallDivisorAverage_mertensFree_bounds_iff_carrier_bounds
    (P : EscAnalytic.Params) :
    ((∃ c X₀ : ℝ, 0 < c ∧ ∀ X : ℝ, X₀ ≤ X →
      c * Real.log (EscAnalytic.SScale P X) ≤ smallDivisorAverage P X) ∧
      (∃ C X₀ : ℝ, 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
        smallDivisorAverage P X
          ≤ C * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X))) ↔
    ∃ c C X₀ : ℝ, 0 < c ∧ 0 < C ∧ ∀ X : ℝ, X₀ ≤ X →
      0 ≤ Real.log (EscAnalytic.SScale P X) ∧
        0 ≤ Real.log (EscAnalytic.zScale X) ∧
        0 ≤ smallDivisorAverage P X ∧
        c * Real.log (EscAnalytic.SScale P X) ≤ smallDivisorAverage P X ∧
        smallDivisorAverage P X
          ≤ C * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X) ∧
        |smallDivisorAverage P X|
          ≤ C * Real.log (EscAnalytic.SScale P X) * Real.log (EscAnalytic.zScale X) := by
  constructor
  · exact smallDivisorAverage_mertensFree_with_carrier_bounds_of_bounds P
  · exact smallDivisorAverage_mertensFree_bounds_of_carrier_bounds P

/-!
The lower half of the `φ(s)/s²` conductor average is still analytic debt
(it needs average totient/Mertens input).  It is not exported as an axiom because
no downstream theorem currently consumes it.  The foundation-only upper/absolute
forms remain available as `sAvgPhi_upper_unconditional` and
`abs_sAvgPhi_upper_unconditional`.
-/

/-! ### Rough (sieved-by-`P(z)`) squarefree estimates. -/

/-- The set of prime factors of `P` that also divide `n`; this is the finite
bad-prime set used in the rough-sieve inclusion-exclusion kernel. -/
noncomputable def badPrimeFactors (P n : ℕ) : Finset ℕ :=
  P.primeFactors.filter (fun p => p ∣ n)

/-- The alternating sum over all subsets of a finite set is `1` for the empty
set and `0` otherwise.  This is the finite algebraic cancellation behind
inclusion-exclusion. -/
theorem alternating_powerset_sum {α : Type} [DecidableEq α] (s : Finset α) :
    (∑ t ∈ s.powerset, (-1 : ℤ) ^ t.card) = if s = ∅ then 1 else 0 := by
  classical
  refine Finset.induction_on s ?h0 ?hins
  · simp
  · intro a s has ih
    rw [Finset.powerset_insert]
    have hdisj : Disjoint s.powerset (s.powerset.image (insert a)) := by
      rw [Finset.disjoint_left]
      intro u hu himg
      rcases Finset.mem_image.mp himg with ⟨v, _hv, hvu⟩
      have hau : a ∉ u := by
        intro hau
        exact has ((Finset.mem_powerset.mp hu) hau)
      have ha_mem : a ∈ u := by
        rw [← hvu]
        exact Finset.mem_insert_self a v
      exact hau ha_mem
    rw [Finset.sum_union hdisj]
    have himage :
        (∑ t ∈ s.powerset.image (insert a), (-1 : ℤ) ^ t.card)
          = ∑ t ∈ s.powerset, (-1 : ℤ) ^ (insert a t).card := by
      rw [Finset.sum_image]
      intro x hx y hy hxy
      apply Finset.ext
      intro z
      by_cases hza : z = a
      · subst z
        have hax : a ∉ x := by
          intro h
          exact has ((Finset.mem_powerset.mp hx) h)
        have hay : a ∉ y := by
          intro h
          exact has ((Finset.mem_powerset.mp hy) h)
        simp [hax, hay]
      · have hz : z ∈ insert a x ↔ z ∈ insert a y := by
          rw [hxy]
        simpa [hza] using hz
    rw [himage]
    have hneg :
        (∑ t ∈ s.powerset, (-1 : ℤ) ^ (insert a t).card)
          = -∑ t ∈ s.powerset, (-1 : ℤ) ^ t.card := by
      rw [← Finset.sum_neg_distrib]
      apply Finset.sum_congr rfl
      intro t ht
      have hat : a ∉ t := by
        intro h
        exact has ((Finset.mem_powerset.mp ht) h)
      rw [Finset.card_insert_of_not_mem hat]
      cases t.card <;> simp [pow_succ]
    rw [hneg]
    by_cases hs_empty : s = ∅
    · subst s
      simp
    · rw [ih, if_neg hs_empty]
      have hne : insert a s ≠ ∅ := by simp
      simp [hne]

/-- The bad-prime set is empty exactly when `n` is coprime to the nonzero
modulus `P`. -/
theorem badPrimeFactors_empty_iff_coprime {P n : ℕ} (hP : P ≠ 0) :
    badPrimeFactors P n = ∅ ↔ Nat.Coprime n P := by
  classical
  constructor
  · intro hempty
    rw [Nat.coprime_iff_gcd_eq_one]
    by_contra hg
    rcases Nat.exists_prime_and_dvd hg with ⟨p, hp, hpg⟩
    have hpn : p ∣ n := Nat.dvd_trans hpg (Nat.gcd_dvd_left n P)
    have hpP : p ∣ P := Nat.dvd_trans hpg (Nat.gcd_dvd_right n P)
    have hmem : p ∈ badPrimeFactors P n := by
      unfold badPrimeFactors
      rw [Finset.mem_filter]
      exact ⟨(Nat.mem_primeFactors).mpr ⟨hp, hpP, hP⟩, hpn⟩
    rw [hempty] at hmem
    simp at hmem
  · intro hcop
    apply Finset.eq_empty_iff_forall_not_mem.mpr
    intro p hpbad
    unfold badPrimeFactors at hpbad
    rw [Finset.mem_filter] at hpbad
    have hp : Nat.Prime p := Nat.prime_of_mem_primeFactors hpbad.1
    have hpP : p ∣ P := Nat.dvd_of_mem_primeFactors hpbad.1
    have hpn : p ∣ n := hpbad.2
    have hpg : p ∣ Nat.gcd n P := Nat.dvd_gcd hpn hpP
    rw [hcop.gcd_eq_one] at hpg
    exact hp.not_dvd_one hpg

/-- Inclusion-exclusion kernel for the roughness condition: the alternating
sum over subsets of bad small prime factors is the indicator of
`Nat.Coprime n P`. -/
theorem badPrimeFactors_parity_sum {P n : ℕ} (hP : P ≠ 0) :
    (∑ t ∈ (badPrimeFactors P n).powerset, (-1 : ℤ) ^ t.card)
      = if Nat.Coprime n P then 1 else 0 := by
  rw [alternating_powerset_sum]
  by_cases hcop : Nat.Coprime n P
  · rw [if_pos hcop, if_pos ((badPrimeFactors_empty_iff_coprime hP).mpr hcop)]
  · rw [if_neg hcop, if_neg]
    exact fun hempty => hcop ((badPrimeFactors_empty_iff_coprime hP).mp hempty)

/-- Specialization of the finite inclusion-exclusion kernel to the actual rough
modulus `P((log X)^4)`. -/
theorem roughModulus_badPrimeFactors_parity_sum (X : ℝ) (n : ℕ) :
    (∑ t ∈ (badPrimeFactors (roughModulus X) n).powerset, (-1 : ℤ) ^ t.card)
      = if Nat.Coprime n (roughModulus X) then 1 else 0 :=
  badPrimeFactors_parity_sum (Nat.ne_of_gt (roughModulus_pos X))

/-- Normalize the optional auxiliary rough-sieve modulus.

The analytic estimates are uniform in an auxiliary modulus.  In the finite
carriers below, `M = 0` is interpreted as the absent auxiliary condition, hence
as modulus `1`, rather than Lean's literal `Nat.Coprime n 0 ↔ n = 1`. -/
def auxiliaryModulus (M : ℕ) : ℕ := max 1 M

theorem auxiliaryModulus_zero : auxiliaryModulus 0 = 1 := by
  simp [auxiliaryModulus]

theorem auxiliaryModulus_one : auxiliaryModulus 1 = 1 := by
  simp [auxiliaryModulus]

theorem auxiliaryModulus_pos (M : ℕ) : 0 < auxiliaryModulus M := by
  simp [auxiliaryModulus]

theorem auxiliaryModulus_eq_self_of_pos {M : ℕ} (hM : 0 < M) :
    auxiliaryModulus M = M := by
  simp [auxiliaryModulus, Nat.succ_le_iff.mpr hM]

theorem auxiliaryModulus_dvd_of_dvd {M₁ M₂ : ℕ}
    (hM₂ : 0 < M₂) (hdiv : M₁ ∣ M₂) :
    auxiliaryModulus M₁ ∣ auxiliaryModulus M₂ := by
  rw [auxiliaryModulus_eq_self_of_pos hM₂]
  by_cases hM₁ : 0 < M₁
  · rw [auxiliaryModulus_eq_self_of_pos hM₁]
    exact hdiv
  · have hM₁zero : M₁ = 0 := Nat.eq_zero_of_not_pos hM₁
    rw [hM₁zero, auxiliaryModulus_zero]
    exact one_dvd M₂

/-- Coprimality descends from a modulus to any nonzero integer whose prime
factors are all present in that modulus. -/
theorem coprime_of_primeFactors_subset_right
    {n m P : ℕ} (hm : m ≠ 0) (hsub : m.primeFactors ⊆ P.primeFactors)
    (hcop : Nat.Coprime n P) :
    Nat.Coprime n m := by
  rw [Nat.coprime_iff_gcd_eq_one]
  by_contra hg
  rcases Nat.exists_prime_and_dvd hg with ⟨p, hp, hpg⟩
  have hpn : p ∣ n := Nat.dvd_trans hpg (Nat.gcd_dvd_left n m)
  have hpm : p ∣ m := Nat.dvd_trans hpg (Nat.gcd_dvd_right n m)
  have hpmem : p ∈ m.primeFactors := (Nat.mem_primeFactors).mpr ⟨hp, hpm, hm⟩
  have hpP : p ∣ P := Nat.dvd_of_mem_primeFactors (hsub hpmem)
  have hp_gcd : p ∣ Nat.gcd n P := Nat.dvd_gcd hpn hpP
  rw [hcop.gcd_eq_one] at hp_gcd
  exact hp.not_dvd_one hp_gcd

/-- If the normalized auxiliary modulus is below `z=(log X)^4`, all of its
prime factors are already present in the rough modulus `P(z)`. -/
theorem auxiliaryModulus_primeFactors_subset_roughModulus_of_le_floor_zScale
    (X : ℝ) (M : ℕ)
    (hM : auxiliaryModulus M ≤ ⌊EscAnalytic.zScale X⌋₊) :
    (auxiliaryModulus M).primeFactors ⊆ (roughModulus X).primeFactors := by
  intro p hp
  have hpPrime : Nat.Prime p := Nat.prime_of_mem_primeFactors hp
  have hp_dvd_aux : p ∣ auxiliaryModulus M := Nat.dvd_of_mem_primeFactors hp
  have hp_le_aux : p ≤ auxiliaryModulus M :=
    Nat.le_of_dvd (auxiliaryModulus_pos M) hp_dvd_aux
  have hp_le_floor : p ≤ ⌊EscAnalytic.zScale X⌋₊ := le_trans hp_le_aux hM
  have hp_dvd_rough : p ∣ roughModulus X := by
    unfold roughModulus
    exact prime_dvd_primeProductBelow_of_le_floor
      (EscAnalytic.zScale X) p hpPrime hp_le_floor
  exact (Nat.mem_primeFactors).mpr
    ⟨hpPrime, hp_dvd_rough, Nat.ne_of_gt (roughModulus_pos X)⟩

/-- Once `z=(log X)^4` contains the normalized auxiliary modulus, rough
coprimality already implies auxiliary coprimality. -/
theorem coprime_auxiliaryModulus_of_coprime_roughModulus_of_le_floor_zScale
    {X : ℝ} {M n : ℕ}
    (hM : auxiliaryModulus M ≤ ⌊EscAnalytic.zScale X⌋₊)
    (hcop : Nat.Coprime n (roughModulus X)) :
    Nat.Coprime n (auxiliaryModulus M) :=
  coprime_of_primeFactors_subset_right
    (Nat.ne_of_gt (auxiliaryModulus_pos M))
    (auxiliaryModulus_primeFactors_subset_roughModulus_of_le_floor_zScale X M hM)
    hcop

/-- If all prime factors of the normalized auxiliary modulus already occur in
the rough modulus, then rough coprimality implies auxiliary coprimality. -/
theorem coprime_auxiliaryModulus_of_primeFactors_subset_roughModulus
    {X : ℝ} {M n : ℕ}
    (hsub : (auxiliaryModulus M).primeFactors ⊆ (roughModulus X).primeFactors)
    (hcop : Nat.Coprime n (roughModulus X)) :
    Nat.Coprime n (auxiliaryModulus M) :=
  coprime_of_primeFactors_subset_right
    (Nat.ne_of_gt (auxiliaryModulus_pos M)) hsub hcop

/-- The part of the auxiliary modulus supported on primes not already present
in the rough modulus.  Prime powers are irrelevant for coprimality, so this is
the squarefree product over the remaining prime support. -/
noncomputable def auxiliaryTailModulus (X : ℝ) (M : ℕ) : ℕ :=
  ∏ p ∈ (auxiliaryModulus M).primeFactors.filter
    (fun p => p ∉ (roughModulus X).primeFactors), p

/-- The auxiliary tail modulus is positive. -/
theorem auxiliaryTailModulus_pos (X : ℝ) (M : ℕ) :
    0 < auxiliaryTailModulus X M := by
  classical
  unfold auxiliaryTailModulus
  exact Finset.prod_pos (fun p hp => by
    exact (Nat.prime_of_mem_primeFactors (Finset.mem_filter.mp hp).1).pos)

/-- Prime factors of the auxiliary tail are exactly the auxiliary prime factors
not already present in the rough modulus. -/
theorem auxiliaryTailModulus_primeFactors
    (X : ℝ) (M : ℕ) :
    (auxiliaryTailModulus X M).primeFactors =
      (auxiliaryModulus M).primeFactors.filter
        (fun p => p ∉ (roughModulus X).primeFactors) := by
  classical
  unfold auxiliaryTailModulus
  rw [Nat.primeFactors_prod]
  intro p hp
  exact Nat.prime_of_mem_primeFactors (Finset.mem_filter.mp hp).1

/-- The auxiliary tail has no prime factor already present in the rough
modulus. -/
theorem auxiliaryTailModulus_primeFactors_disjoint_rough
    (X : ℝ) (M : ℕ) :
    Disjoint (auxiliaryTailModulus X M).primeFactors
      (roughModulus X).primeFactors := by
  classical
  rw [auxiliaryTailModulus_primeFactors]
  exact Finset.disjoint_left.mpr (by
    intro p hp_tail hp_rough
    exact (Finset.mem_filter.mp hp_tail).2 hp_rough)

/-- Every prime factor of the auxiliary tail is a prime factor of the original
normalized auxiliary modulus. -/
theorem auxiliaryTailModulus_primeFactors_subset_auxiliary
    (X : ℝ) (M : ℕ) :
    (auxiliaryTailModulus X M).primeFactors ⊆
      (auxiliaryModulus M).primeFactors := by
  classical
  rw [auxiliaryTailModulus_primeFactors]
  exact Finset.filter_subset _ _

/-- The squarefree auxiliary tail divides the normalized auxiliary modulus
from which it was extracted. -/
theorem auxiliaryTailModulus_dvd_auxiliaryModulus
    (X : ℝ) (M : ℕ) :
    auxiliaryTailModulus X M ∣ auxiliaryModulus M := by
  classical
  unfold auxiliaryTailModulus
  exact dvd_trans
    (Finset.prod_dvd_prod_of_subset
      ((auxiliaryModulus M).primeFactors.filter
        (fun p => p ∉ (roughModulus X).primeFactors))
      (auxiliaryModulus M).primeFactors (fun p : ℕ => p)
      (Finset.filter_subset _ _))
    (Nat.prod_primeFactors_dvd (auxiliaryModulus M))

/-- The number of auxiliary-tail primes is bounded by the normalized auxiliary
modulus. -/
theorem auxiliaryTailModulus_primeFactors_card_le_auxiliaryModulus
    (X : ℝ) (M : ℕ) :
    (auxiliaryTailModulus X M).primeFactors.card ≤ auxiliaryModulus M := by
  exact
    (Finset.card_le_card
      (auxiliaryTailModulus_primeFactors_subset_auxiliary X M)).trans
      (primeFactors_card_le_self_of_pos (auxiliaryModulus_pos M))

/-- The normalized auxiliary modulus is at most `M+1`, a convenient real-size
form for using hypotheses such as `M ≤ X^C`. -/
theorem auxiliaryModulus_cast_le_natCast_add_one (M : ℕ) :
    ((auxiliaryModulus M : ℕ) : ℝ) ≤ (M : ℝ) + 1 := by
  have hnat : auxiliaryModulus M ≤ M + 1 := by
    unfold auxiliaryModulus
    exact max_le (Nat.succ_le_succ (Nat.zero_le M)) (Nat.le_succ M)
  exact_mod_cast hnat

/-- Every prime in the auxiliary tail lies strictly past the rough cutoff. -/
theorem auxiliaryTailModulus_prime_gt_floor_zScale
    {X : ℝ} {M p : ℕ}
    (hp : p ∈ (auxiliaryTailModulus X M).primeFactors) :
    ⌊EscAnalytic.zScale X⌋₊ < p := by
  classical
  rw [auxiliaryTailModulus_primeFactors] at hp
  have hp_aux : p ∈ (auxiliaryModulus M).primeFactors :=
    (Finset.mem_filter.mp hp).1
  have hp_not_rough : p ∉ (roughModulus X).primeFactors :=
    (Finset.mem_filter.mp hp).2
  have hpPrime : Nat.Prime p := Nat.prime_of_mem_primeFactors hp_aux
  by_contra hnot
  have hp_le : p ≤ ⌊EscAnalytic.zScale X⌋₊ := Nat.le_of_not_gt hnot
  have hp_dvd_rough : p ∣ roughModulus X := by
    unfold roughModulus
    exact prime_dvd_primeProductBelow_of_le_floor
      (EscAnalytic.zScale X) p hpPrime hp_le
  have hp_rough : p ∈ (roughModulus X).primeFactors :=
    (Nat.mem_primeFactors).mpr
      ⟨hpPrime, hp_dvd_rough, Nat.ne_of_gt (roughModulus_pos X)⟩
  exact hp_not_rough hp_rough

/-- Tail primes are at least one integer past the rough cutoff. -/
theorem auxiliaryTailModulus_succ_floor_zScale_le_prime
    {X : ℝ} {M p : ℕ}
    (hp : p ∈ (auxiliaryTailModulus X M).primeFactors) :
    ⌊EscAnalytic.zScale X⌋₊ + 1 ≤ p :=
  Nat.succ_le_of_lt (auxiliaryTailModulus_prime_gt_floor_zScale hp)

/-- Since every auxiliary-tail prime lies beyond the rough cutoff, the product
of the common lower bound `⌊z(X)⌋+1` over the tail support is at most the tail
modulus itself. -/
theorem succ_floor_zScale_pow_auxiliaryTail_card_le_auxiliaryTailModulus
    (X : ℝ) (M : ℕ) :
    (⌊EscAnalytic.zScale X⌋₊ + 1) ^
        (auxiliaryTailModulus X M).primeFactors.card
      ≤ auxiliaryTailModulus X M := by
  classical
  let q : ℕ := ⌊EscAnalytic.zScale X⌋₊ + 1
  let s : Finset ℕ :=
    (auxiliaryModulus M).primeFactors.filter
      (fun p => p ∉ (roughModulus X).primeFactors)
  have hterm : ∀ p ∈ s, q ≤ p := by
    intro p hp
    have hp_tail : p ∈ (auxiliaryTailModulus X M).primeFactors := by
      simpa [auxiliaryTailModulus_primeFactors, s] using hp
    simpa [q] using auxiliaryTailModulus_succ_floor_zScale_le_prime hp_tail
  have hprod : ∏ p ∈ s, q ≤ ∏ p ∈ s, p :=
    Finset.prod_le_prod (fun p _hp => Nat.zero_le q) hterm
  have hpf : (auxiliaryTailModulus X M).primeFactors = s := by
    simpa [s] using auxiliaryTailModulus_primeFactors X M
  calc
    (⌊EscAnalytic.zScale X⌋₊ + 1) ^
        (auxiliaryTailModulus X M).primeFactors.card
        = q ^ s.card := by simp [q, hpf]
    _ = ∏ _p ∈ s, q := by simp [Finset.prod_const, nsmul_eq_mul]
    _ ≤ ∏ p ∈ s, p := hprod
    _ = auxiliaryTailModulus X M := by simp [auxiliaryTailModulus, s]

/-- Logarithmic tail-support bound: the number of large auxiliary-tail primes,
weighted by `log(⌊z(X)⌋+1)`, is at most `log(M+1)`. -/
theorem auxiliaryTailModulus_primeFactors_card_mul_log_succ_floor_zScale_le_log_natCast_add_one
    (X : ℝ) (M : ℕ) :
    (((auxiliaryTailModulus X M).primeFactors.card : ℕ) : ℝ) *
        Real.log (((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ))
      ≤ Real.log ((M : ℝ) + 1) := by
  let q : ℕ := ⌊EscAnalytic.zScale X⌋₊ + 1
  let T : ℕ := auxiliaryTailModulus X M
  have hpow_nat : q ^ T.primeFactors.card ≤ T := by
    simpa [q, T] using
      succ_floor_zScale_pow_auxiliaryTail_card_le_auxiliaryTailModulus X M
  have hqpos_nat : 0 < q := by simp [q]
  have hpow_pos : 0 < ((q ^ T.primeFactors.card : ℕ) : ℝ) := by
    exact_mod_cast Nat.pos_pow_of_pos T.primeFactors.card hqpos_nat
  have hlog_pow_le_log_T :
      Real.log (((q ^ T.primeFactors.card : ℕ) : ℝ)) ≤
        Real.log (T : ℝ) := by
    exact Real.log_le_log hpow_pos (by exact_mod_cast hpow_nat)
  have hT_le_aux : T ≤ auxiliaryModulus M := by
    exact Nat.le_of_dvd (auxiliaryModulus_pos M)
      (by simpa [T] using auxiliaryTailModulus_dvd_auxiliaryModulus X M)
  have hT_le_M : (T : ℝ) ≤ (M : ℝ) + 1 := by
    exact le_trans (by exact_mod_cast hT_le_aux)
      (auxiliaryModulus_cast_le_natCast_add_one M)
  have hTpos : 0 < (T : ℝ) := by
    exact_mod_cast (by simpa [T] using auxiliaryTailModulus_pos X M)
  have hlog_T_le_log_M :
      Real.log (T : ℝ) ≤ Real.log ((M : ℝ) + 1) :=
    Real.log_le_log hTpos hT_le_M
  have hlog_pow_eq :
      Real.log (((q ^ T.primeFactors.card : ℕ) : ℝ)) =
        (T.primeFactors.card : ℝ) * Real.log (q : ℝ) := by
    rw [Nat.cast_pow, Real.log_pow]
  calc
    (((auxiliaryTailModulus X M).primeFactors.card : ℕ) : ℝ) *
        Real.log (((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ))
        = (T.primeFactors.card : ℝ) * Real.log (q : ℝ) := by
          simp [q, T]
    _ = Real.log (((q ^ T.primeFactors.card : ℕ) : ℝ)) := hlog_pow_eq.symm
    _ ≤ Real.log (T : ℝ) := hlog_pow_le_log_T
    _ ≤ Real.log ((M : ℝ) + 1) := hlog_T_le_log_M

/-- Division form of the logarithmic tail-support bound.  For `X ≥ exp 1`,
the rough cutoff has `⌊z(X)⌋+1 ≥ 2`, so its logarithm is positive. -/
theorem auxiliaryTailModulus_primeFactors_card_le_log_natCast_add_one_div_log_succ_floor_zScale
    (X : ℝ) (M : ℕ) (hX : Real.exp 1 ≤ X) :
    (((auxiliaryTailModulus X M).primeFactors.card : ℕ) : ℝ)
      ≤ Real.log ((M : ℝ) + 1) /
          Real.log (((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ)) := by
  have hz_ge_one : 1 ≤ EscAnalytic.zScale X := zScale_ge_one_of_exp_one_le hX
  have hfloor_one : 1 ≤ ⌊EscAnalytic.zScale X⌋₊ :=
    Nat.le_floor (by simpa using hz_ge_one)
  have hq_ge_two : 2 ≤ ⌊EscAnalytic.zScale X⌋₊ + 1 := by omega
  have hlog_pos :
      0 < Real.log (((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ)) :=
    Real.log_pos (by exact_mod_cast hq_ge_two)
  have hmul :=
    auxiliaryTailModulus_primeFactors_card_mul_log_succ_floor_zScale_le_log_natCast_add_one
      X M
  exact (le_div_iff₀ hlog_pos).mpr hmul

/-- Multiples of a single auxiliary-tail prime in the dyadic window. -/
noncomputable def auxiliaryTailPrimeMultiplesCount
    (_X : ℝ) (t : ℝ) (p : ℕ) : ℝ :=
  (((natWindow t (2 * t)).filter (fun n : ℕ => p ∣ n)).card : ℝ)

/-- A tail-prime multiples count is bounded by the explicit quotient
`⌊2t⌋ / p`. -/
theorem auxiliaryTailPrimeMultiplesCount_le_floor_div
    (X : ℝ) (M : ℕ) (t : ℝ) {p : ℕ}
    (hp : p ∈ (auxiliaryTailModulus X M).primeFactors) :
    auxiliaryTailPrimeMultiplesCount X t p
      ≤ ((⌊2 * t⌋₊ / p : ℕ) : ℝ) := by
  have hpPrime : Nat.Prime p := Nat.prime_of_mem_primeFactors hp
  simpa [auxiliaryTailPrimeMultiplesCount] using
    natWindow_multiples_card_le_floor_div t (2 * t) hpPrime.pos

/-- Union-bound carrier for loss from imposing the auxiliary tail. -/
noncomputable def auxiliaryTailMultiplesLoss
    (X : ℝ) (M : ℕ) (t : ℝ) : ℝ :=
  ∑ p ∈ (auxiliaryTailModulus X M).primeFactors,
    auxiliaryTailPrimeMultiplesCount X t p

/-- Union-bound carrier for multiples of any prime factor of the normalized
auxiliary modulus.  Unlike `auxiliaryTailMultiplesLoss`, this does not discard
small auxiliary primes already present in the rough modulus. -/
noncomputable def auxiliaryModulusPrimeMultiplesLoss
    (X : ℝ) (M : ℕ) (t : ℝ) : ℝ :=
  ∑ p ∈ (auxiliaryModulus M).primeFactors,
    auxiliaryTailPrimeMultiplesCount X t p

/-- The full auxiliary-prime multiples loss is nonnegative. -/
theorem auxiliaryModulusPrimeMultiplesLoss_nonneg
    (X : ℝ) (M : ℕ) (t : ℝ) :
    0 ≤ auxiliaryModulusPrimeMultiplesLoss X M t := by
  classical
  unfold auxiliaryModulusPrimeMultiplesLoss auxiliaryTailPrimeMultiplesCount
  exact Finset.sum_nonneg (fun p _hp => Nat.cast_nonneg _)

/-- Explicit floor-division envelope for multiples of all prime factors of the
normalized auxiliary modulus. -/
noncomputable def auxiliaryModulusPrimeMultiplesFloorEnvelope
    (M : ℕ) (t : ℝ) : ℝ :=
  ∑ p ∈ (auxiliaryModulus M).primeFactors,
    ((⌊2 * t⌋₊ / p : ℕ) : ℝ)

/-- The full auxiliary-prime multiples loss is bounded termwise by its explicit
floor-division envelope. -/
theorem auxiliaryModulusPrimeMultiplesLoss_le_floorEnvelope
    (X : ℝ) (M : ℕ) (t : ℝ) :
    auxiliaryModulusPrimeMultiplesLoss X M t ≤
      auxiliaryModulusPrimeMultiplesFloorEnvelope M t := by
  classical
  unfold auxiliaryModulusPrimeMultiplesLoss
    auxiliaryModulusPrimeMultiplesFloorEnvelope
  apply Finset.sum_le_sum
  intro p hp
  have hpPrime : Nat.Prime p := Nat.prime_of_mem_primeFactors hp
  simpa [auxiliaryTailPrimeMultiplesCount] using
    natWindow_multiples_card_le_floor_div t (2 * t) hpPrime.pos

/-- Crude cardinality envelope for the full auxiliary-prime floor envelope. -/
theorem auxiliaryModulusPrimeMultiplesFloorEnvelope_le_card_mul_floor_two_mul
    (M : ℕ) (t : ℝ) :
    auxiliaryModulusPrimeMultiplesFloorEnvelope M t ≤
      (((auxiliaryModulus M).primeFactors.card : ℕ) : ℝ) *
        ((⌊2 * t⌋₊ : ℕ) : ℝ) := by
  classical
  unfold auxiliaryModulusPrimeMultiplesFloorEnvelope
  have hterm :
      ∀ p ∈ (auxiliaryModulus M).primeFactors,
        ((⌊2 * t⌋₊ / p : ℕ) : ℝ) ≤ ((⌊2 * t⌋₊ : ℕ) : ℝ) := by
    intro p _hp
    exact_mod_cast Nat.div_le_self ⌊2 * t⌋₊ p
  have hsum :=
    Finset.sum_le_card_nsmul
      ((auxiliaryModulus M).primeFactors)
      (fun p : ℕ => ((⌊2 * t⌋₊ / p : ℕ) : ℝ))
      ((⌊2 * t⌋₊ : ℕ) : ℝ) hterm
  simpa [nsmul_eq_mul] using hsum

/-- Crude envelope controlled by the normalized auxiliary modulus itself. -/
theorem auxiliaryModulusPrimeMultiplesFloorEnvelope_le_auxiliaryModulus_mul_floor_two_mul
    (M : ℕ) (t : ℝ) :
    auxiliaryModulusPrimeMultiplesFloorEnvelope M t ≤
      ((auxiliaryModulus M : ℕ) : ℝ) * ((⌊2 * t⌋₊ : ℕ) : ℝ) := by
  have hcard :
      (((auxiliaryModulus M).primeFactors.card : ℕ) : ℝ)
        ≤ ((auxiliaryModulus M : ℕ) : ℝ) := by
    exact_mod_cast primeFactors_card_le_self_of_pos (auxiliaryModulus_pos M)
  exact
    (auxiliaryModulusPrimeMultiplesFloorEnvelope_le_card_mul_floor_two_mul
      M t).trans
      (mul_le_mul_of_nonneg_right hcard (Nat.cast_nonneg _))

/-- Explicit floor-division envelope for the auxiliary-tail multiples loss. -/
noncomputable def auxiliaryTailMultiplesFloorEnvelope
    (X : ℝ) (M : ℕ) (t : ℝ) : ℝ :=
  ∑ p ∈ (auxiliaryTailModulus X M).primeFactors,
    ((⌊2 * t⌋₊ / p : ℕ) : ℝ)

/-- The tail multiples loss is bounded termwise by the floor-division
envelope. -/
theorem auxiliaryTailMultiplesLoss_le_floorEnvelope
    (X : ℝ) (M : ℕ) (t : ℝ) :
    auxiliaryTailMultiplesLoss X M t
      ≤ auxiliaryTailMultiplesFloorEnvelope X M t := by
  classical
  unfold auxiliaryTailMultiplesLoss auxiliaryTailMultiplesFloorEnvelope
  exact Finset.sum_le_sum (fun p hp =>
    auxiliaryTailPrimeMultiplesCount_le_floor_div X M t hp)

/-- Crude common-denominator bound for the tail floor-division envelope: each
tail prime is at least `⌊z(X)⌋+1`. -/
theorem auxiliaryTailMultiplesFloorEnvelope_le_card_mul_floor_div_succ_floor_zScale
    (X : ℝ) (M : ℕ) (t : ℝ) :
    auxiliaryTailMultiplesFloorEnvelope X M t
      ≤ (((auxiliaryTailModulus X M).primeFactors.card : ℕ) : ℝ) *
          ((⌊2 * t⌋₊ / (⌊EscAnalytic.zScale X⌋₊ + 1) : ℕ) : ℝ) := by
  classical
  let q : ℕ := ⌊EscAnalytic.zScale X⌋₊ + 1
  have hqpos : 0 < q := by
    simp [q]
  have hterm :
      ∀ p ∈ (auxiliaryTailModulus X M).primeFactors,
        ((⌊2 * t⌋₊ / p : ℕ) : ℝ) ≤ ((⌊2 * t⌋₊ / q : ℕ) : ℝ) := by
    intro p hp
    have hqle : q ≤ p := by
      simpa [q] using auxiliaryTailModulus_succ_floor_zScale_le_prime hp
    exact_mod_cast Nat.div_le_div_left hqle hqpos
  have hsum :=
    Finset.sum_le_card_nsmul
      ((auxiliaryTailModulus X M).primeFactors)
      (fun p : ℕ => ((⌊2 * t⌋₊ / p : ℕ) : ℝ))
      ((⌊2 * t⌋₊ / q : ℕ) : ℝ) hterm
  simpa [auxiliaryTailMultiplesFloorEnvelope, q, nsmul_eq_mul] using hsum

/-- Tail floor envelope controlled by the normalized auxiliary modulus. -/
theorem auxiliaryTailMultiplesFloorEnvelope_le_auxiliaryModulus_mul_floor_div_succ_floor_zScale
    (X : ℝ) (M : ℕ) (t : ℝ) :
    auxiliaryTailMultiplesFloorEnvelope X M t
      ≤ ((auxiliaryModulus M : ℕ) : ℝ) *
          ((⌊2 * t⌋₊ / (⌊EscAnalytic.zScale X⌋₊ + 1) : ℕ) : ℝ) := by
  have hcard :
      (((auxiliaryTailModulus X M).primeFactors.card : ℕ) : ℝ)
        ≤ ((auxiliaryModulus M : ℕ) : ℝ) := by
    exact_mod_cast auxiliaryTailModulus_primeFactors_card_le_auxiliaryModulus X M
  exact
    (auxiliaryTailMultiplesFloorEnvelope_le_card_mul_floor_div_succ_floor_zScale
      X M t).trans
      (mul_le_mul_of_nonneg_right hcard (Nat.cast_nonneg _))

/-- Tail floor envelope controlled by the original auxiliary parameter via
`auxiliaryModulus M ≤ M+1`. -/
theorem auxiliaryTailMultiplesFloorEnvelope_le_natCast_add_one_mul_floor_div_succ_floor_zScale
    (X : ℝ) (M : ℕ) (t : ℝ) :
    auxiliaryTailMultiplesFloorEnvelope X M t
      ≤ ((M : ℝ) + 1) *
          ((⌊2 * t⌋₊ / (⌊EscAnalytic.zScale X⌋₊ + 1) : ℕ) : ℝ) := by
  exact
    (auxiliaryTailMultiplesFloorEnvelope_le_auxiliaryModulus_mul_floor_div_succ_floor_zScale
      X M t).trans
      (mul_le_mul_of_nonneg_right
        (auxiliaryModulus_cast_le_natCast_add_one M) (Nat.cast_nonneg _))

/-- Convert the common floor-division quotient in the tail envelope to a real
quotient. -/
theorem auxiliaryTail_common_floor_div_le_real
    {X t : ℝ} (ht : 0 ≤ t) :
    ((⌊2 * t⌋₊ / (⌊EscAnalytic.zScale X⌋₊ + 1) : ℕ) : ℝ)
      ≤ (2 * t) / ((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ) := by
  have htwo_nonneg : 0 ≤ 2 * t := mul_nonneg (by norm_num) ht
  have hfloor_le : (⌊2 * t⌋₊ : ℝ) ≤ 2 * t := Nat.floor_le htwo_nonneg
  have hqnonneg :
      0 ≤ ((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ) := Nat.cast_nonneg _
  have hcast :
      ((⌊2 * t⌋₊ / (⌊EscAnalytic.zScale X⌋₊ + 1) : ℕ) : ℝ)
        ≤ (⌊2 * t⌋₊ : ℝ) /
            ((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ) :=
    Nat.cast_div_le
  exact hcast.trans (div_le_div_of_nonneg_right hfloor_le hqnonneg)

/-- Tail floor envelope with the common floor quotient replaced by a real
quotient. -/
theorem auxiliaryTailMultiplesFloorEnvelope_le_natCast_add_one_mul_real_quotient
    (X : ℝ) (M : ℕ) {t : ℝ} (ht : 0 ≤ t) :
    auxiliaryTailMultiplesFloorEnvelope X M t
      ≤ ((M : ℝ) + 1) *
          ((2 * t) / ((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ)) := by
  have hfactor : 0 ≤ (M : ℝ) + 1 := by positivity
  exact
    (auxiliaryTailMultiplesFloorEnvelope_le_natCast_add_one_mul_floor_div_succ_floor_zScale
      X M t).trans
      (mul_le_mul_of_nonneg_left
        (auxiliaryTail_common_floor_div_le_real (X := X) ht) hfactor)

/-- Since `z < ⌊z⌋+1`, the real tail quotient with denominator
`⌊z(X)⌋+1` is bounded by the same quotient with denominator `z(X)`. -/
theorem two_mul_div_succ_floor_zScale_le_two_mul_div_zScale
    {X t : ℝ} (hz : 0 < EscAnalytic.zScale X) (ht : 0 ≤ t) :
    (2 * t) / ((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ)
      ≤ (2 * t) / EscAnalytic.zScale X := by
  have hnum : 0 ≤ 2 * t := mul_nonneg (by norm_num) ht
  have hden_pos : 0 < ((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ) := by
    exact_mod_cast Nat.succ_pos ⌊EscAnalytic.zScale X⌋₊
  have hz_le_den :
      EscAnalytic.zScale X
        ≤ ((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ) :=
    by simpa [Nat.cast_add, Nat.cast_one] using
      (Nat.lt_floor_add_one (EscAnalytic.zScale X)).le
  exact div_le_div_of_nonneg_left hnum hz hz_le_den

/-- Tail floor envelope controlled directly by the real `zScale` denominator. -/
theorem auxiliaryTailMultiplesFloorEnvelope_le_natCast_add_one_mul_two_mul_div_zScale
    (X : ℝ) (M : ℕ) {t : ℝ}
    (hz : 0 < EscAnalytic.zScale X) (ht : 0 ≤ t) :
    auxiliaryTailMultiplesFloorEnvelope X M t
      ≤ ((M : ℝ) + 1) * ((2 * t) / EscAnalytic.zScale X) := by
  have hfactor : 0 ≤ (M : ℝ) + 1 := by positivity
  exact
    (auxiliaryTailMultiplesFloorEnvelope_le_natCast_add_one_mul_real_quotient
      X M ht).trans
      (mul_le_mul_of_nonneg_left
        (two_mul_div_succ_floor_zScale_le_two_mul_div_zScale hz ht) hfactor)

/-- Tail floor envelope controlled directly by the real `zScale` denominator
under the standard large-`X` hypothesis. -/
theorem auxiliaryTailMultiplesFloorEnvelope_le_natCast_add_one_mul_two_mul_div_zScale_of_exp_one_le
    (X : ℝ) (M : ℕ) {t : ℝ}
    (hX : Real.exp 1 ≤ X) (ht : 0 ≤ t) :
    auxiliaryTailMultiplesFloorEnvelope X M t
      ≤ ((M : ℝ) + 1) * ((2 * t) / EscAnalytic.zScale X) := by
  have hz : 0 < EscAnalytic.zScale X :=
    lt_of_lt_of_le zero_lt_one (zScale_ge_one_of_exp_one_le hX)
  exact
    auxiliaryTailMultiplesFloorEnvelope_le_natCast_add_one_mul_two_mul_div_zScale
      X M hz ht

/-- Sharper tail floor-envelope bound using the logarithmic number of large
auxiliary-tail primes, rather than the crude `M+1` cardinality envelope. -/
theorem auxiliaryTailMultiplesFloorEnvelope_le_log_tail_support_mul_two_mul_div_zScale
    (X : ℝ) (M : ℕ) {t : ℝ}
    (hX : Real.exp 1 ≤ X) (ht : 0 ≤ t) :
    auxiliaryTailMultiplesFloorEnvelope X M t
      ≤ (Real.log ((M : ℝ) + 1) /
          Real.log (((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ))) *
            ((2 * t) / EscAnalytic.zScale X) := by
  have hz : 0 < EscAnalytic.zScale X :=
    lt_of_lt_of_le zero_lt_one (zScale_ge_one_of_exp_one_le hX)
  have hcard :
      (((auxiliaryTailModulus X M).primeFactors.card : ℕ) : ℝ)
        ≤ Real.log ((M : ℝ) + 1) /
            Real.log (((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ)) :=
    auxiliaryTailModulus_primeFactors_card_le_log_natCast_add_one_div_log_succ_floor_zScale
      X M hX
  have hquot :
      ((⌊2 * t⌋₊ / (⌊EscAnalytic.zScale X⌋₊ + 1) : ℕ) : ℝ)
        ≤ (2 * t) / EscAnalytic.zScale X :=
    (auxiliaryTail_common_floor_div_le_real (X := X) ht).trans
      (two_mul_div_succ_floor_zScale_le_two_mul_div_zScale hz ht)
  have hcard_nonneg :
      0 ≤ (((auxiliaryTailModulus X M).primeFactors.card : ℕ) : ℝ) :=
    Nat.cast_nonneg _
  have hquot_nonneg : 0 ≤ (2 * t) / EscAnalytic.zScale X :=
    div_nonneg (mul_nonneg (by norm_num) ht) hz.le
  calc
    auxiliaryTailMultiplesFloorEnvelope X M t
        ≤ (((auxiliaryTailModulus X M).primeFactors.card : ℕ) : ℝ) *
            ((⌊2 * t⌋₊ / (⌊EscAnalytic.zScale X⌋₊ + 1) : ℕ) : ℝ) :=
          auxiliaryTailMultiplesFloorEnvelope_le_card_mul_floor_div_succ_floor_zScale
            X M t
    _ ≤ (((auxiliaryTailModulus X M).primeFactors.card : ℕ) : ℝ) *
            ((2 * t) / EscAnalytic.zScale X) :=
          mul_le_mul_of_nonneg_left hquot hcard_nonneg
    _ ≤ (Real.log ((M : ℝ) + 1) /
          Real.log (((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ))) *
            ((2 * t) / EscAnalytic.zScale X) :=
          mul_le_mul_of_nonneg_right hcard hquot_nonneg

/-- If the auxiliary parameter satisfies `M ≤ X^C`, its logarithmic size is
bounded by `(C+1) log X`, after increasing the large-`X` threshold. -/
theorem log_natCast_add_one_le_add_one_mul_log_of_natCast_le_rpow
    {X C : ℝ} (M : ℕ)
    (hX : Real.exp 2 ≤ X) (hC : 0 ≤ C) (hM : (M : ℝ) ≤ X ^ C) :
    Real.log ((M : ℝ) + 1) ≤ (C + 1) * Real.log X := by
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 2) hX
  have hlogX_ge_two : (2 : ℝ) ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hX
  have hlogX_nonneg : 0 ≤ Real.log X := le_trans (by norm_num) hlogX_ge_two
  have hXone : 1 ≤ X := le_trans (by norm_num : (1 : ℝ) ≤ Real.exp 2) hX
  have hXpow_one : 1 ≤ X ^ C := by
    simpa using Real.one_le_rpow hXone hC
  have hXpow_pos : 0 < X ^ C := Real.rpow_pos_of_pos hXpos C
  have hM_add : (M : ℝ) + 1 ≤ 2 * X ^ C := by
    nlinarith
  have hM_add_pos : 0 < (M : ℝ) + 1 := by positivity
  have hlog_mono :
      Real.log ((M : ℝ) + 1) ≤ Real.log (2 * X ^ C) :=
    Real.log_le_log hM_add_pos hM_add
  have hlog_prod :
      Real.log (2 * X ^ C) = Real.log 2 + C * Real.log X := by
    rw [Real.log_mul (by norm_num : (2 : ℝ) ≠ 0) (ne_of_gt hXpow_pos),
      Real.log_rpow hXpos]
  have hlog_two_le_logX : Real.log 2 ≤ Real.log X := by
    have hlog_two_le_one :
        Real.log 2 ≤ (1 : ℝ) := by
      calc
        Real.log 2 ≤ (2 : ℝ) - 1 :=
          Real.log_le_sub_one_of_pos (by norm_num : (0 : ℝ) < 2)
        _ = 1 := by norm_num
    exact hlog_two_le_one.trans (by linarith)
  calc
    Real.log ((M : ℝ) + 1)
        ≤ Real.log (2 * X ^ C) := hlog_mono
    _ = Real.log 2 + C * Real.log X := hlog_prod
    _ ≤ Real.log X + C * Real.log X :=
          add_le_add_right hlog_two_le_logX _
    _ = (C + 1) * Real.log X := by ring

/-- The successor-floor denominator has logarithm at least `log z(X)`. -/
theorem log_zScale_le_log_succ_floor_zScale
    {X : ℝ} (hX : Real.exp 1 ≤ X) :
    Real.log (EscAnalytic.zScale X)
      ≤ Real.log (((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ)) := by
  have hz_pos : 0 < EscAnalytic.zScale X :=
    lt_of_lt_of_le zero_lt_one (zScale_ge_one_of_exp_one_le hX)
  have hz_le_den :
      EscAnalytic.zScale X
        ≤ ((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ) := by
    simpa [Nat.cast_add, Nat.cast_one] using
      (Nat.lt_floor_add_one (EscAnalytic.zScale X)).le
  exact Real.log_le_log hz_pos hz_le_den

/-- For large `X`, the logarithmic scale is below `z(X)=(log X)^4`. -/
theorem log_le_zScale_of_exp_one_le {X : ℝ} (hX : Real.exp 1 ≤ X) :
    Real.log X ≤ EscAnalytic.zScale X := by
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 1) hX
  have hlogX_ge_one : (1 : ℝ) ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hX
  unfold EscAnalytic.zScale
  simpa using
    (pow_le_pow_right₀ hlogX_ge_one (by norm_num : (1 : ℕ) ≤ 4))

/-- Parameter-shaped tail-loss estimate at the rough-count scale.  Under
`M ≤ X^C` with `C ≥ 0`, imposing the large-prime auxiliary tail costs at most a
constant multiple of `t/log z(X)`. -/
theorem auxiliaryTailMultiplesFloorEnvelope_le_two_mul_C_add_one_mul_t_div_log_zScale
    (X : ℝ) (M : ℕ) {C t : ℝ}
    (hX : Real.exp 2 ≤ X) (hC : 0 ≤ C) (hM : (M : ℝ) ≤ X ^ C)
    (ht : 0 ≤ t) :
    auxiliaryTailMultiplesFloorEnvelope X M t
      ≤ (2 * (C + 1)) * (t / Real.log (EscAnalytic.zScale X)) := by
  have hXexp1 : Real.exp 1 ≤ X :=
    le_trans (Real.exp_le_exp.mpr (by norm_num : (1 : ℝ) ≤ 2)) hX
  have hz_pos : 0 < EscAnalytic.zScale X :=
    lt_of_lt_of_le zero_lt_one (zScale_ge_one_of_exp_one_le hXexp1)
  have hlogZ_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hX
  have hfloor_one : 1 ≤ ⌊EscAnalytic.zScale X⌋₊ :=
    Nat.le_floor (by simpa using zScale_ge_one_of_exp_one_le hXexp1)
  have hq_ge_two : 2 ≤ ⌊EscAnalytic.zScale X⌋₊ + 1 := by omega
  have hlog_succ_pos :
      0 < Real.log (((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ)) :=
    Real.log_pos (by exact_mod_cast hq_ge_two)
  have hlogM :
      Real.log ((M : ℝ) + 1) ≤ (C + 1) * Real.log X :=
    log_natCast_add_one_le_add_one_mul_log_of_natCast_le_rpow M hX hC hM
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 2) hX
  have hlogX_ge_two : (2 : ℝ) ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hX
  have hlogX_nonneg : 0 ≤ Real.log X :=
    le_trans (by norm_num : (0 : ℝ) ≤ 2) hlogX_ge_two
  have hnum_nonneg : 0 ≤ (C + 1) * Real.log X :=
    mul_nonneg (add_nonneg hC zero_le_one) hlogX_nonneg
  have hfactor₁ :
      Real.log ((M : ℝ) + 1) /
          Real.log (((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ))
        ≤ ((C + 1) * Real.log X) /
          Real.log (((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ)) :=
    div_le_div_of_nonneg_right hlogM hlog_succ_pos.le
  have hlog_den :
      Real.log (EscAnalytic.zScale X)
        ≤ Real.log (((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ)) :=
    log_zScale_le_log_succ_floor_zScale hXexp1
  have hfactor₂ :
      ((C + 1) * Real.log X) /
          Real.log (((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ))
        ≤ ((C + 1) * Real.log X) / Real.log (EscAnalytic.zScale X) :=
    div_le_div_of_nonneg_left hnum_nonneg hlogZ_pos hlog_den
  have hfactor :
      Real.log ((M : ℝ) + 1) /
          Real.log (((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ))
        ≤ ((C + 1) * Real.log X) / Real.log (EscAnalytic.zScale X) :=
    hfactor₁.trans hfactor₂
  have htail :=
    auxiliaryTailMultiplesFloorEnvelope_le_log_tail_support_mul_two_mul_div_zScale
      X M hXexp1 ht
  have hquot_nonneg : 0 ≤ (2 * t) / EscAnalytic.zScale X :=
    div_nonneg (mul_nonneg (by norm_num) ht) hz_pos.le
  have hlogX_le_z : Real.log X ≤ EscAnalytic.zScale X :=
    log_le_zScale_of_exp_one_le hXexp1
  have hratio_le : Real.log X / EscAnalytic.zScale X ≤ 1 :=
    (div_le_iff₀ hz_pos).mpr (by simpa using hlogX_le_z)
  have hbase_nonneg :
      0 ≤ 2 * (C + 1) * (t / Real.log (EscAnalytic.zScale X)) :=
    mul_nonneg (mul_nonneg (by norm_num) (add_nonneg hC zero_le_one))
      (div_nonneg ht hlogZ_pos.le)
  calc
    auxiliaryTailMultiplesFloorEnvelope X M t
        ≤ (Real.log ((M : ℝ) + 1) /
          Real.log (((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ))) *
            ((2 * t) / EscAnalytic.zScale X) := htail
    _ ≤ (((C + 1) * Real.log X) / Real.log (EscAnalytic.zScale X)) *
            ((2 * t) / EscAnalytic.zScale X) :=
          mul_le_mul_of_nonneg_right hfactor hquot_nonneg
    _ = (2 * (C + 1) * (t / Real.log (EscAnalytic.zScale X))) *
          (Real.log X / EscAnalytic.zScale X) := by
          field_simp [ne_of_gt hz_pos, ne_of_gt hlogZ_pos]
          ring
    _ ≤ (2 * (C + 1) * (t / Real.log (EscAnalytic.zScale X))) * 1 :=
          mul_le_mul_of_nonneg_left hratio_le hbase_nonneg
    _ = (2 * (C + 1)) * (t / Real.log (EscAnalytic.zScale X)) := by ring

/-- The logarithmic tail coefficient `2(C+1) log X / z(X)` is eventually
smaller than any prescribed positive `eps`. -/
theorem two_mul_C_add_one_mul_log_div_zScale_le_eps
    {X C eps : ℝ}
    (hX : Real.exp (max 2 (2 * (C + 1) / eps)) ≤ X)
    (hC : 0 ≤ C) (heps : 0 < eps) :
    (2 * (C + 1) * Real.log X) / EscAnalytic.zScale X ≤ eps := by
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos _) hX
  have hlog_ge :
      max 2 (2 * (C + 1) / eps) ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hX
  have hlog_ge_two : (2 : ℝ) ≤ Real.log X :=
    le_trans (le_max_left _ _) hlog_ge
  have hlog_pos : 0 < Real.log X :=
    lt_of_lt_of_le (by norm_num : (0 : ℝ) < 2) hlog_ge_two
  have hlog_ge_one : (1 : ℝ) ≤ Real.log X :=
    le_trans (by norm_num : (1 : ℝ) ≤ 2) hlog_ge_two
  have hC1_nonneg : 0 ≤ C + 1 := by linarith
  have hA_nonneg : 0 ≤ 2 * (C + 1) := by nlinarith
  have hlog_ge_A :
      2 * (C + 1) / eps ≤ Real.log X :=
    le_trans (le_max_right _ _) hlog_ge
  have hA_le_log_mul_eps :
      2 * (C + 1) ≤ Real.log X * eps :=
    (div_le_iff₀ heps).mp hlog_ge_A
  have hA_le_eps_log : 2 * (C + 1) ≤ eps * Real.log X := by
    nlinarith
  have hlog_le_log_cube :
      Real.log X ≤ (Real.log X) ^ (3 : ℕ) := by
    have hsq : (1 : ℝ) ≤ (Real.log X) ^ (2 : ℕ) := by
      nlinarith [sq_nonneg (Real.log X - 1)]
    calc
      Real.log X = Real.log X * 1 := by ring
      _ ≤ Real.log X * (Real.log X) ^ (2 : ℕ) :=
          mul_le_mul_of_nonneg_left hsq hlog_pos.le
      _ = (Real.log X) ^ (3 : ℕ) := by ring
  have hA_le_eps_log_cube :
      2 * (C + 1) ≤ eps * (Real.log X) ^ (3 : ℕ) :=
    hA_le_eps_log.trans
      (mul_le_mul_of_nonneg_left hlog_le_log_cube heps.le)
  have hlog_cube_pos : 0 < (Real.log X) ^ (3 : ℕ) :=
    pow_pos hlog_pos 3
  calc
    (2 * (C + 1) * Real.log X) / EscAnalytic.zScale X
        = (2 * (C + 1)) / (Real.log X) ^ (3 : ℕ) := by
          unfold EscAnalytic.zScale
          field_simp [ne_of_gt hlog_pos]
          ring
    _ ≤ eps := by
          rw [div_le_iff₀ hlog_cube_pos]
          exact hA_le_eps_log_cube

/-- A sharp eventual form of the auxiliary-tail floor estimate: the large-prime
tail can be made smaller than any positive multiple of `t/log z(X)`. -/
theorem auxiliaryTailMultiplesFloorEnvelope_le_eps_mul_t_div_log_zScale
    (X : ℝ) (M : ℕ) {C eps t : ℝ}
    (hX : Real.exp (max 2 (2 * (C + 1) / eps)) ≤ X)
    (hC : 0 ≤ C) (heps : 0 < eps) (hM : (M : ℝ) ≤ X ^ C)
    (ht : 0 ≤ t) :
    auxiliaryTailMultiplesFloorEnvelope X M t
      ≤ eps * (t / Real.log (EscAnalytic.zScale X)) := by
  have hXexp2 : Real.exp 2 ≤ X := by
    exact le_trans (Real.exp_le_exp.mpr (le_max_left _ _)) hX
  have hXexp1 : Real.exp 1 ≤ X :=
    le_trans (Real.exp_le_exp.mpr (by norm_num : (1 : ℝ) ≤ 2)) hXexp2
  have hz_pos : 0 < EscAnalytic.zScale X :=
    lt_of_lt_of_le zero_lt_one (zScale_ge_one_of_exp_one_le hXexp1)
  have hlogZ_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp2
  have hfloor_one : 1 ≤ ⌊EscAnalytic.zScale X⌋₊ :=
    Nat.le_floor (by simpa using zScale_ge_one_of_exp_one_le hXexp1)
  have hq_ge_two : 2 ≤ ⌊EscAnalytic.zScale X⌋₊ + 1 := by omega
  have hlog_succ_pos :
      0 < Real.log (((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ)) :=
    Real.log_pos (by exact_mod_cast hq_ge_two)
  have hlogM :
      Real.log ((M : ℝ) + 1) ≤ (C + 1) * Real.log X :=
    log_natCast_add_one_le_add_one_mul_log_of_natCast_le_rpow M hXexp2 hC hM
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 2) hXexp2
  have hlogX_ge_two : (2 : ℝ) ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hXexp2
  have hlogX_nonneg : 0 ≤ Real.log X :=
    le_trans (by norm_num : (0 : ℝ) ≤ 2) hlogX_ge_two
  have hnum_nonneg : 0 ≤ (C + 1) * Real.log X :=
    mul_nonneg (add_nonneg hC zero_le_one) hlogX_nonneg
  have hfactor₁ :
      Real.log ((M : ℝ) + 1) /
          Real.log (((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ))
        ≤ ((C + 1) * Real.log X) /
          Real.log (((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ)) :=
    div_le_div_of_nonneg_right hlogM hlog_succ_pos.le
  have hlog_den :
      Real.log (EscAnalytic.zScale X)
        ≤ Real.log (((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ)) :=
    log_zScale_le_log_succ_floor_zScale hXexp1
  have hfactor₂ :
      ((C + 1) * Real.log X) /
          Real.log (((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ))
        ≤ ((C + 1) * Real.log X) / Real.log (EscAnalytic.zScale X) :=
    div_le_div_of_nonneg_left hnum_nonneg hlogZ_pos hlog_den
  have hfactor :
      Real.log ((M : ℝ) + 1) /
          Real.log (((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ))
        ≤ ((C + 1) * Real.log X) / Real.log (EscAnalytic.zScale X) :=
    hfactor₁.trans hfactor₂
  have htail :=
    auxiliaryTailMultiplesFloorEnvelope_le_log_tail_support_mul_two_mul_div_zScale
      X M hXexp1 ht
  have hquot_nonneg : 0 ≤ (2 * t) / EscAnalytic.zScale X :=
    div_nonneg (mul_nonneg (by norm_num) ht) hz_pos.le
  have hcoeff :
      (2 * (C + 1) * Real.log X) / EscAnalytic.zScale X ≤ eps :=
    two_mul_C_add_one_mul_log_div_zScale_le_eps hX hC heps
  have hT_nonneg : 0 ≤ t / Real.log (EscAnalytic.zScale X) :=
    div_nonneg ht hlogZ_pos.le
  calc
    auxiliaryTailMultiplesFloorEnvelope X M t
        ≤ (Real.log ((M : ℝ) + 1) /
          Real.log (((⌊EscAnalytic.zScale X⌋₊ + 1 : ℕ) : ℝ))) *
            ((2 * t) / EscAnalytic.zScale X) := htail
    _ ≤ (((C + 1) * Real.log X) / Real.log (EscAnalytic.zScale X)) *
            ((2 * t) / EscAnalytic.zScale X) :=
          mul_le_mul_of_nonneg_right hfactor hquot_nonneg
    _ = ((2 * (C + 1) * Real.log X) / EscAnalytic.zScale X) *
          (t / Real.log (EscAnalytic.zScale X)) := by
          field_simp [ne_of_gt hz_pos, ne_of_gt hlogZ_pos]
          ring
    _ ≤ eps * (t / Real.log (EscAnalytic.zScale X)) :=
          mul_le_mul_of_nonneg_right hcoeff hT_nonneg

/-- Under rough coprimality, coprimality to the full auxiliary modulus is
equivalent to coprimality to its large-prime tail. -/
theorem coprime_auxiliaryModulus_iff_coprime_tail_of_coprime_rough
    {X : ℝ} {M n : ℕ} (hrough : Nat.Coprime n (roughModulus X)) :
    Nat.Coprime n (auxiliaryModulus M) ↔
      Nat.Coprime n (auxiliaryTailModulus X M) := by
  constructor
  · intro haux
    exact coprime_of_primeFactors_subset_right
      (Nat.ne_of_gt (auxiliaryTailModulus_pos X M))
      (auxiliaryTailModulus_primeFactors_subset_auxiliary X M) haux
  · intro htail
    rw [Nat.coprime_iff_gcd_eq_one]
    by_contra hg
    rcases Nat.exists_prime_and_dvd hg with ⟨p, hp, hpg⟩
    have hpn : p ∣ n := Nat.dvd_trans hpg (Nat.gcd_dvd_left n (auxiliaryModulus M))
    have hpaux : p ∣ auxiliaryModulus M :=
      Nat.dvd_trans hpg (Nat.gcd_dvd_right n (auxiliaryModulus M))
    have hpaux_mem : p ∈ (auxiliaryModulus M).primeFactors :=
      (Nat.mem_primeFactors).mpr
        ⟨hp, hpaux, Nat.ne_of_gt (auxiliaryModulus_pos M)⟩
    by_cases hp_rough : p ∈ (roughModulus X).primeFactors
    · have hp_dvd_rough : p ∣ roughModulus X :=
        Nat.dvd_of_mem_primeFactors hp_rough
      have hp_gcd : p ∣ Nat.gcd n (roughModulus X) :=
        Nat.dvd_gcd hpn hp_dvd_rough
      rw [hrough.gcd_eq_one] at hp_gcd
      exact hp.not_dvd_one hp_gcd
    · have hp_tail_mem : p ∈ (auxiliaryTailModulus X M).primeFactors := by
        rw [auxiliaryTailModulus_primeFactors]
        exact Finset.mem_filter.mpr ⟨hpaux_mem, hp_rough⟩
      have hp_dvd_tail : p ∣ auxiliaryTailModulus X M :=
        Nat.dvd_of_mem_primeFactors hp_tail_mem
      have hp_gcd_tail : p ∣ Nat.gcd n (auxiliaryTailModulus X M) :=
        Nat.dvd_gcd hpn hp_dvd_tail
      rw [htail.gcd_eq_one] at hp_gcd_tail
      exact hp.not_dvd_one hp_gcd_tail

/-- A convenient explicit threshold: if `X ≥ exp(auxiliaryModulus M)`, then
`z(X)` contains the normalized auxiliary modulus. -/
theorem auxiliaryModulus_le_floor_zScale_of_exp_auxiliary_le
    {X : ℝ} (M : ℕ)
    (hX : Real.exp ((auxiliaryModulus M : ℕ) : ℝ) ≤ X) :
    auxiliaryModulus M ≤ ⌊EscAnalytic.zScale X⌋₊ := by
  have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos _) hX
  have hlog_ge_aux :
      ((auxiliaryModulus M : ℕ) : ℝ) ≤ Real.log X := by
    rw [Real.le_log_iff_exp_le hXpos]
    exact hX
  have haux_ge_one : (1 : ℝ) ≤ ((auxiliaryModulus M : ℕ) : ℝ) := by
    exact_mod_cast (auxiliaryModulus_pos M)
  have hlog_ge_one : (1 : ℝ) ≤ Real.log X := le_trans haux_ge_one hlog_ge_aux
  have hlog_le_pow : Real.log X ≤ (Real.log X) ^ (4 : ℕ) := by
    simpa using
      (pow_le_pow_right₀ hlog_ge_one (by norm_num : (1 : ℕ) ≤ 4))
  have haux_le_z :
      ((auxiliaryModulus M : ℕ) : ℝ) ≤ EscAnalytic.zScale X := by
    unfold EscAnalytic.zScale
    exact le_trans hlog_ge_aux hlog_le_pow
  exact Nat.le_floor haux_le_z

/-- The (abstract) count `#{t < n ≤ 2t : n squarefree, (n,P(z))=1, (n,M)=1}`
appearing in `lem:rough-sqf`, `(eq:dyadic-rough-sqf-count)`. -/
noncomputable def roughDyadicCount (X : ℝ) (M : ℕ) (t : ℝ) : ℝ := by
  classical
  exact
    (((natWindow t (2 * t)).filter
        (fun n : ℕ => Squarefree n ∧
          Nat.Coprime n (roughModulus X) ∧
            Nat.Coprime n (auxiliaryModulus M))).card : ℝ)

/-- The rough dyadic count is exactly a finite coprimality-indicator sum over
the squarefree, `M`-coprime dyadic window. -/
theorem roughDyadicCount_eq_coprime_indicator_sum (X : ℝ) (M : ℕ) (t : ℝ) :
    roughDyadicCount X M t =
      ∑ n ∈ (natWindow t (2 * t)).filter
          (fun n : ℕ => Squarefree n ∧ Nat.Coprime n (auxiliaryModulus M)),
        (if Nat.Coprime n (roughModulus X) then (1 : ℝ) else 0) := by
  classical
  unfold roughDyadicCount
  rw [Finset.card_eq_sum_ones]
  norm_num
  simp [Finset.filter_filter, and_assoc, and_left_comm, and_comm]

/-- Exact finite inclusion-exclusion form of the rough dyadic count: after the
squarefree and `(n,M)=1` filters, roughness is the alternating sum over subsets
of the bad small prime factors. -/
theorem roughDyadicCount_eq_badPrimeFactors_parity_sum (X : ℝ) (M : ℕ) (t : ℝ) :
    roughDyadicCount X M t =
      ∑ n ∈ (natWindow t (2 * t)).filter
          (fun n : ℕ => Squarefree n ∧ Nat.Coprime n (auxiliaryModulus M)),
        ((∑ u ∈ (badPrimeFactors (roughModulus X) n).powerset,
            (-1 : ℤ) ^ u.card : ℤ) : ℝ) := by
  classical
  rw [roughDyadicCount_eq_coprime_indicator_sum]
  apply Finset.sum_congr rfl
  intro n _hn
  have h :=
    congrArg (fun m : ℤ => (m : ℝ))
      (roughModulus_badPrimeFactors_parity_sum X n)
  simpa using h.symm

/-- Named finite inclusion-exclusion carrier for the rough dyadic count. -/
noncomputable def roughDyadicBadPrimeParitySum (X : ℝ) (M : ℕ) (t : ℝ) : ℝ :=
  ∑ n ∈ (natWindow t (2 * t)).filter
      (fun n : ℕ => Squarefree n ∧ Nat.Coprime n (auxiliaryModulus M)),
    ((∑ u ∈ (badPrimeFactors (roughModulus X) n).powerset,
        (-1 : ℤ) ^ u.card : ℤ) : ℝ)

/-- The zero auxiliary modulus is the no-extra-modulus case for the rough
dyadic count, not Lean's literal `Nat.Coprime n 0` carrier. -/
theorem roughDyadicCount_zero_auxiliary_eq_one (X t : ℝ) :
    roughDyadicCount X 0 t = roughDyadicCount X 1 t := by
  unfold roughDyadicCount
  simp [auxiliaryModulus_zero, auxiliaryModulus_one]

/-- If `z(X)` contains the fixed auxiliary modulus, then the auxiliary
coprimality condition is redundant in the rough dyadic count. -/
theorem roughDyadicCount_eq_modulus_one_of_auxiliary_le_floor_zScale
    (X : ℝ) (M : ℕ) (t : ℝ)
    (hM : auxiliaryModulus M ≤ ⌊EscAnalytic.zScale X⌋₊) :
    roughDyadicCount X M t = roughDyadicCount X 1 t := by
  classical
  unfold roughDyadicCount
  apply congrArg (fun s : Finset ℕ => ((s.card : ℕ) : ℝ))
  ext n
  rw [Finset.mem_filter, Finset.mem_filter]
  constructor
  · intro h
    exact ⟨h.1, h.2.1, h.2.2.1, by
      simp [auxiliaryModulus_one]⟩
  · intro h
    exact ⟨h.1, h.2.1, h.2.2.1,
      coprime_auxiliaryModulus_of_coprime_roughModulus_of_le_floor_zScale
        hM h.2.2.1⟩

/-- Prime-factor support form of auxiliary-modulus absorption: if every prime
factor of the normalized auxiliary modulus is already in `P(z)`, the auxiliary
coprimality condition is redundant in the rough dyadic count. -/
theorem roughDyadicCount_eq_modulus_one_of_auxiliary_primeFactors_subset
    (X : ℝ) (M : ℕ) (t : ℝ)
    (hsub : (auxiliaryModulus M).primeFactors ⊆ (roughModulus X).primeFactors) :
    roughDyadicCount X M t = roughDyadicCount X 1 t := by
  classical
  unfold roughDyadicCount
  apply congrArg (fun s : Finset ℕ => ((s.card : ℕ) : ℝ))
  ext n
  rw [Finset.mem_filter, Finset.mem_filter]
  constructor
  · intro h
    exact ⟨h.1, h.2.1, h.2.2.1, by
      simp [auxiliaryModulus_one]⟩
  · intro h
    exact ⟨h.1, h.2.1, h.2.2.1,
      coprime_auxiliaryModulus_of_primeFactors_subset_roughModulus
        hsub h.2.2.1⟩

/-- The rough dyadic count only sees the large-prime tail of the auxiliary
modulus; all auxiliary prime factors already contained in `P(z)` are absorbed
by the rough coprimality condition. -/
theorem roughDyadicCount_eq_auxiliaryTailModulus
    (X : ℝ) (M : ℕ) (t : ℝ) :
    roughDyadicCount X M t =
      roughDyadicCount X (auxiliaryTailModulus X M) t := by
  classical
  unfold roughDyadicCount
  apply congrArg (fun s : Finset ℕ => ((s.card : ℕ) : ℝ))
  ext n
  rw [Finset.mem_filter, Finset.mem_filter]
  constructor
  · intro h
    have htail :
        Nat.Coprime n (auxiliaryTailModulus X M) :=
      (coprime_auxiliaryModulus_iff_coprime_tail_of_coprime_rough
        (M := M) h.2.2.1).mp h.2.2.2
    have htail_aux :
        Nat.Coprime n (auxiliaryModulus (auxiliaryTailModulus X M)) := by
      rw [auxiliaryModulus_eq_self_of_pos (auxiliaryTailModulus_pos X M)]
      exact htail
    exact ⟨h.1, h.2.1, h.2.2.1, htail_aux⟩
  · intro h
    have htail :
        Nat.Coprime n (auxiliaryTailModulus X M) := by
      simpa [auxiliaryModulus_eq_self_of_pos (auxiliaryTailModulus_pos X M)]
        using h.2.2.2
    have haux :
        Nat.Coprime n (auxiliaryModulus M) :=
      (coprime_auxiliaryModulus_iff_coprime_tail_of_coprime_rough
        (M := M) h.2.2.1).mpr htail
    exact ⟨h.1, h.2.1, h.2.2.1, haux⟩

/-- Finite union bound for the loss caused by imposing the auxiliary tail:
every integer counted without the tail is either still counted with the tail,
or is divisible by some tail prime. -/
theorem roughDyadicCount_one_le_auxiliaryTail_count_add_multiplesLoss
    (X : ℝ) (M : ℕ) (t : ℝ) :
    roughDyadicCount X 1 t
      ≤ roughDyadicCount X (auxiliaryTailModulus X M) t
          + auxiliaryTailMultiplesLoss X M t := by
  classical
  let W : Finset ℕ := natWindow t (2 * t)
  let T : ℕ := auxiliaryTailModulus X M
  let tail : Finset ℕ := T.primeFactors
  let A : Finset ℕ :=
    W.filter (fun n : ℕ => Squarefree n ∧
      Nat.Coprime n (roughModulus X) ∧ Nat.Coprime n (auxiliaryModulus 1))
  let B : Finset ℕ :=
    W.filter (fun n : ℕ => Squarefree n ∧
      Nat.Coprime n (roughModulus X) ∧ Nat.Coprime n (auxiliaryModulus T))
  let U : Finset ℕ := tail.biUnion (fun p : ℕ =>
    W.filter (fun n : ℕ => p ∣ n))
  have hsub : A ⊆ B ∪ U := by
    intro n hn
    have hn' : n ∈ W ∧ Squarefree n ∧
        Nat.Coprime n (roughModulus X) ∧
          Nat.Coprime n (auxiliaryModulus 1) := by
      simpa [A] using (Finset.mem_filter.mp hn)
    by_cases htail : Nat.Coprime n T
    · rw [Finset.mem_union]
      left
      change n ∈ W.filter (fun n : ℕ => Squarefree n ∧
        Nat.Coprime n (roughModulus X) ∧ Nat.Coprime n (auxiliaryModulus T))
      rw [Finset.mem_filter]
      refine ⟨hn'.1, hn'.2.1, hn'.2.2.1, ?_⟩
      simpa [T, auxiliaryModulus_eq_self_of_pos
        (auxiliaryTailModulus_pos X M)] using htail
    · rw [Finset.mem_union]
      right
      rcases Nat.Prime.not_coprime_iff_dvd.mp htail with
        ⟨p, hpPrime, hpn, hpT⟩
      have hp_tail : p ∈ tail := by
        change p ∈ T.primeFactors
        have hTpos : 0 < T := by
          simpa [T] using auxiliaryTailModulus_pos X M
        exact (Nat.mem_primeFactors).mpr
          ⟨hpPrime, hpT, Nat.ne_of_gt hTpos⟩
      change n ∈ tail.biUnion (fun p : ℕ => W.filter (fun n : ℕ => p ∣ n))
      rw [Finset.mem_biUnion]
      refine ⟨p, hp_tail, ?_⟩
      rw [Finset.mem_filter]
      exact ⟨hn'.1, hpn⟩
  have hcard_U :
      U.card ≤ ∑ p ∈ tail, (W.filter (fun n : ℕ => p ∣ n)).card := by
    simpa [U] using
      (Finset.card_biUnion_le
        (s := tail) (t := fun p : ℕ => W.filter (fun n : ℕ => p ∣ n)))
  have hcard_nat :
      A.card ≤ B.card +
        ∑ p ∈ tail, (W.filter (fun n : ℕ => p ∣ n)).card := by
    calc
      A.card ≤ (B ∪ U).card := Finset.card_le_card hsub
      _ ≤ B.card + U.card := Finset.card_union_le B U
      _ ≤ B.card + ∑ p ∈ tail,
            (W.filter (fun n : ℕ => p ∣ n)).card :=
          Nat.add_le_add_left hcard_U B.card
  have hcard_real :
      (A.card : ℝ) ≤ (B.card : ℝ) +
        ∑ p ∈ tail, ((W.filter (fun n : ℕ => p ∣ n)).card : ℝ) := by
    exact_mod_cast hcard_nat
  simpa [roughDyadicCount, auxiliaryTailMultiplesLoss,
    auxiliaryTailPrimeMultiplesCount, W, T, tail, A, B,
    auxiliaryModulus_eq_self_of_pos (auxiliaryTailModulus_pos X M)]
    using hcard_real

/-- Same tail-loss bound, rewritten back in terms of the original auxiliary
modulus. -/
theorem roughDyadicCount_one_le_count_add_multiplesLoss
    (X : ℝ) (M : ℕ) (t : ℝ) :
    roughDyadicCount X 1 t
      ≤ roughDyadicCount X M t + auxiliaryTailMultiplesLoss X M t := by
  rw [roughDyadicCount_eq_auxiliaryTailModulus X M t]
  exact roughDyadicCount_one_le_auxiliaryTail_count_add_multiplesLoss X M t

/-- Explicit floor-division envelope for the count loss caused by the large
auxiliary-prime tail. -/
theorem roughDyadicCount_one_le_count_add_multiplesFloorEnvelope
    (X : ℝ) (M : ℕ) (t : ℝ) :
    roughDyadicCount X 1 t
      ≤ roughDyadicCount X M t + auxiliaryTailMultiplesFloorEnvelope X M t :=
  (roughDyadicCount_one_le_count_add_multiplesLoss X M t).trans
    (add_le_add_left (auxiliaryTailMultiplesLoss_le_floorEnvelope X M t)
      (roughDyadicCount X M t))

/-- Explicit-threshold form of `roughDyadicCount_eq_modulus_one_of_auxiliary_le_floor_zScale`. -/
theorem roughDyadicCount_eq_modulus_one_of_exp_auxiliary_le
    (X : ℝ) (M : ℕ) (t : ℝ)
    (hX : Real.exp ((auxiliaryModulus M : ℕ) : ℝ) ≤ X) :
    roughDyadicCount X M t = roughDyadicCount X 1 t :=
  roughDyadicCount_eq_modulus_one_of_auxiliary_le_floor_zScale X M t
    (auxiliaryModulus_le_floor_zScale_of_exp_auxiliary_le M hX)

/-- The named inclusion-exclusion carrier is exactly the rough dyadic count. -/
theorem roughDyadicBadPrimeParitySum_eq_roughDyadicCount (X : ℝ) (M : ℕ) (t : ℝ) :
    roughDyadicBadPrimeParitySum X M t = roughDyadicCount X M t := by
  unfold roughDyadicBadPrimeParitySum
  exact (roughDyadicCount_eq_badPrimeFactors_parity_sum X M t).symm

/-- Powersets of the bad-prime set are the same as subsets of the small-prime
set all of whose primes divide `n`. -/
theorem badPrimeFactors_powerset_eq_filter (P n : ℕ) :
    (badPrimeFactors P n).powerset =
      P.primeFactors.powerset.filter (fun u : Finset ℕ => ∀ p ∈ u, p ∣ n) := by
  classical
  ext u
  constructor
  · intro hu
    rw [Finset.mem_powerset] at hu
    rw [Finset.mem_filter, Finset.mem_powerset]
    exact ⟨fun p hp => (Finset.mem_filter.mp (hu hp)).1,
      fun p hp => (Finset.mem_filter.mp (hu hp)).2⟩
  · intro hu
    rw [Finset.mem_filter, Finset.mem_powerset] at hu
    rw [Finset.mem_powerset]
    intro p hp
    exact Finset.mem_filter.mpr ⟨hu.1 hp, hu.2 p hp⟩

/-- Count of squarefree, `M`-coprime dyadic integers divisible by every prime
in a chosen small-prime subset. -/
noncomputable def roughBadPrimeSubsetCount
    (_X : ℝ) (M : ℕ) (t : ℝ) (u : Finset ℕ) : ℝ :=
  (((natWindow t (2 * t)).filter
      (fun n : ℕ =>
        Squarefree n ∧ Nat.Coprime n (auxiliaryModulus M) ∧ ∀ p ∈ u, p ∣ n)).card : ℝ)

/-- Product modulus attached to a selected subset of bad small primes. -/
noncomputable def badPrimeSubsetModulus (u : Finset ℕ) : ℕ :=
  ∏ p ∈ u, p

/-- For a finite set of primes, divisibility by every prime in the set is the
same as divisibility by their product. -/
theorem badPrimeSubsetModulus_dvd_iff
    {u : Finset ℕ} {n : ℕ} (huprime : ∀ p ∈ u, Nat.Prime p) :
    badPrimeSubsetModulus u ∣ n ↔ ∀ p ∈ u, p ∣ n := by
  classical
  unfold badPrimeSubsetModulus
  constructor
  · intro hprod p hp
    exact dvd_trans (Finset.dvd_prod_of_mem (f := fun q : ℕ => q) hp) hprod
  · intro hdiv
    exact Finset.prod_primes_dvd n
      (fun p hp => (huprime p hp).prime) hdiv

/-- The product modulus of a finite set of primes is positive. -/
theorem badPrimeSubsetModulus_pos_of_primes
    {u : Finset ℕ} (huprime : ∀ p ∈ u, Nat.Prime p) :
    0 < badPrimeSubsetModulus u := by
  classical
  unfold badPrimeSubsetModulus
  exact Finset.prod_pos (fun p hp => (huprime p hp).pos)

/-- Subsets of the rough modulus prime-factor set have positive product
modulus. -/
theorem badPrimeSubsetModulus_pos_of_mem_rough_powerset
    (X : ℝ) {u : Finset ℕ}
    (hu : u ∈ (roughModulus X).primeFactors.powerset) :
    0 < badPrimeSubsetModulus u := by
  classical
  have hsubset : u ⊆ (roughModulus X).primeFactors :=
    Finset.mem_powerset.mp hu
  exact badPrimeSubsetModulus_pos_of_primes (fun p hp =>
    Nat.prime_of_mem_primeFactors (hsubset hp))

/-- Same count as `roughBadPrimeSubsetCount`, but written in the product-modulus
form used by standard sieve estimates. -/
noncomputable def roughBadPrimeSubsetProductCount
    (_X : ℝ) (M : ℕ) (t : ℝ) (u : Finset ℕ) : ℝ :=
  (((natWindow t (2 * t)).filter
      (fun n : ℕ => Squarefree n ∧ Nat.Coprime n (auxiliaryModulus M) ∧
        badPrimeSubsetModulus u ∣ n)).card : ℝ)

/-- Multiples-only envelope for a product-modulus term in the rough
inclusion-exclusion expansion. -/
noncomputable def roughBadPrimeSubsetProductMultiplesCount
    (_X : ℝ) (t : ℝ) (u : Finset ℕ) : ℝ :=
  (((natWindow t (2 * t)).filter
      (fun n : ℕ => badPrimeSubsetModulus u ∣ n)).card : ℝ)

/-- Product-modulus count after imposing only squarefreeness, before imposing
auxiliary coprimality. -/
noncomputable def roughBadPrimeSubsetProductSquarefreeCount
    (_X : ℝ) (t : ℝ) (u : Finset ℕ) : ℝ :=
  (((natWindow t (2 * t)).filter
      (fun n : ℕ => Squarefree n ∧ badPrimeSubsetModulus u ∣ n)).card : ℝ)

/-- On subsets of the rough modulus prime factors, the pointwise subset count
and product-modulus count are identical. -/
theorem roughBadPrimeSubsetCount_eq_productCount
    (X : ℝ) (M : ℕ) (t : ℝ)
    {u : Finset ℕ} (hu : u ∈ (roughModulus X).primeFactors.powerset) :
    roughBadPrimeSubsetCount X M t u =
      roughBadPrimeSubsetProductCount X M t u := by
  classical
  have hsubset : u ⊆ (roughModulus X).primeFactors :=
    Finset.mem_powerset.mp hu
  have huprime : ∀ p ∈ u, Nat.Prime p := by
    intro p hp
    exact Nat.prime_of_mem_primeFactors (hsubset hp)
  unfold roughBadPrimeSubsetCount roughBadPrimeSubsetProductCount
  apply congrArg (fun s : Finset ℕ => ((s.card : ℕ) : ℝ))
  ext n
  constructor
  · intro hn
    rw [Finset.mem_filter] at hn
    rw [Finset.mem_filter]
    exact ⟨hn.1, hn.2.1, hn.2.2.1,
      (badPrimeSubsetModulus_dvd_iff huprime).mpr hn.2.2.2⟩
  · intro hn
    rw [Finset.mem_filter] at hn
    rw [Finset.mem_filter]
    exact ⟨hn.1, hn.2.1, hn.2.2.1,
      (badPrimeSubsetModulus_dvd_iff huprime).mp hn.2.2.2⟩

/-- The squarefree and coprimality filters only decrease a product-modulus
dyadic count. -/
theorem roughBadPrimeSubsetProductCount_le_multiplesCount
    (X : ℝ) (M : ℕ) (t : ℝ) (u : Finset ℕ) :
    roughBadPrimeSubsetProductCount X M t u ≤
      roughBadPrimeSubsetProductMultiplesCount X t u := by
  classical
  unfold roughBadPrimeSubsetProductCount
    roughBadPrimeSubsetProductMultiplesCount
  have hcard :
      ((natWindow t (2 * t)).filter
        (fun n : ℕ => Squarefree n ∧ Nat.Coprime n (auxiliaryModulus M) ∧
          badPrimeSubsetModulus u ∣ n)).card
        ≤ ((natWindow t (2 * t)).filter
          (fun n : ℕ => badPrimeSubsetModulus u ∣ n)).card := by
    apply Finset.card_le_card
    intro n hn
    rw [Finset.mem_filter] at hn ⊢
    exact ⟨hn.1, hn.2.2.2⟩
  exact_mod_cast hcard

/-- The squarefree-only product-modulus count is contained in the
multiples-only product-modulus count. -/
theorem roughBadPrimeSubsetProductSquarefreeCount_le_multiplesCount
    (X : ℝ) (t : ℝ) (u : Finset ℕ) :
    roughBadPrimeSubsetProductSquarefreeCount X t u ≤
      roughBadPrimeSubsetProductMultiplesCount X t u := by
  classical
  unfold roughBadPrimeSubsetProductSquarefreeCount
    roughBadPrimeSubsetProductMultiplesCount
  have hcard :
      ((natWindow t (2 * t)).filter
        (fun n : ℕ => Squarefree n ∧ badPrimeSubsetModulus u ∣ n)).card
        ≤ ((natWindow t (2 * t)).filter
          (fun n : ℕ => badPrimeSubsetModulus u ∣ n)).card := by
    apply Finset.card_le_card
    intro n hn
    rw [Finset.mem_filter] at hn ⊢
    exact ⟨hn.1, hn.2.2⟩
  exact_mod_cast hcard

/-- The fully filtered product-modulus count is contained in the squarefree-only
product-modulus count. -/
theorem roughBadPrimeSubsetProductCount_le_squarefreeCount
    (X : ℝ) (M : ℕ) (t : ℝ) (u : Finset ℕ) :
    roughBadPrimeSubsetProductCount X M t u ≤
      roughBadPrimeSubsetProductSquarefreeCount X t u := by
  classical
  unfold roughBadPrimeSubsetProductCount
    roughBadPrimeSubsetProductSquarefreeCount
  have hcard :
      ((natWindow t (2 * t)).filter
        (fun n : ℕ => Squarefree n ∧ Nat.Coprime n (auxiliaryModulus M) ∧
          badPrimeSubsetModulus u ∣ n)).card
        ≤ ((natWindow t (2 * t)).filter
          (fun n : ℕ => Squarefree n ∧ badPrimeSubsetModulus u ∣ n)).card := by
    apply Finset.card_le_card
    intro n hn
    rw [Finset.mem_filter] at hn ⊢
    exact ⟨hn.1, hn.2.1, hn.2.2.2⟩
  exact_mod_cast hcard

/-- A product-modulus dyadic count is bounded by the explicit quotient
`⌊2t⌋ / q`, where `q` is the subset product. -/
theorem roughBadPrimeSubsetProductMultiplesCount_le_floor_div
    (X : ℝ) (t : ℝ) {u : Finset ℕ}
    (hupos : 0 < badPrimeSubsetModulus u) :
    roughBadPrimeSubsetProductMultiplesCount X t u
      ≤ ((⌊2 * t⌋₊ / badPrimeSubsetModulus u : ℕ) : ℝ) := by
  simpa [roughBadPrimeSubsetProductMultiplesCount] using
    natWindow_multiples_card_le_floor_div t (2 * t) hupos

/-- Exact floor formula for the multiples-only product-modulus count.  For
`t ≥ 0`, the carrier `t < n ≤ 2t` is the natural interval
`Ioc floor(t) floor(2t)`, so Mathlib's interval-mod counting theorem gives a
fully explicit floor expression. -/
noncomputable def roughBadPrimeSubsetProductMultiplesFloorCount
    (t : ℝ) (u : Finset ℕ) : ℝ :=
  (((⌊((⌊2 * t⌋₊ : ℕ) : ℚ) / (badPrimeSubsetModulus u : ℚ)⌋ -
      ⌊((⌊t⌋₊ : ℕ) : ℚ) / (badPrimeSubsetModulus u : ℚ)⌋) ⊔ 0 : ℤ) : ℝ)

/-- The multiples-only subset count is exactly the explicit floor-count carrier.
This removes the last local counting ambiguity from the signed-multiples
discrepancy: the remaining analytic content is cancellation in the alternating
floor sum, not the definition of the finite count. -/
theorem roughBadPrimeSubsetProductMultiplesCount_eq_floorCount
    (X : ℝ) {t : ℝ} (ht : 0 ≤ t) {u : Finset ℕ}
    (hupos : 0 < badPrimeSubsetModulus u) :
    roughBadPrimeSubsetProductMultiplesCount X t u =
      roughBadPrimeSubsetProductMultiplesFloorCount t u := by
  classical
  let q : ℕ := badPrimeSubsetModulus u
  let L : ℕ := ⌊t⌋₊
  let U : ℕ := ⌊2 * t⌋₊
  have htwo_t : 0 ≤ 2 * t := mul_nonneg (by norm_num) ht
  have hset :
      (natWindow t (2 * t)).filter (fun n : ℕ => q ∣ n) =
        (Finset.Ioc L U).filter (fun n : ℕ => n ≡ 0 [MOD q]) := by
    ext n
    constructor
    · intro hn
      rcases Finset.mem_filter.mp hn with ⟨hnw, hdvd⟩
      unfold natWindow at hnw
      rcases Finset.mem_filter.mp hnw with ⟨hnIcc, htlt⟩
      have hnU : n ≤ U := by
        simpa [U] using (Finset.mem_Icc.mp hnIcc).2
      have hLn : L < n := by
        simpa [L] using (Nat.floor_lt ht).mpr htlt
      exact Finset.mem_filter.mpr
        ⟨Finset.mem_Ioc.mpr ⟨hLn, hnU⟩, (Nat.modEq_zero_iff_dvd).mpr hdvd⟩
    · intro hn
      rcases Finset.mem_filter.mp hn with ⟨hnIoc, hmod⟩
      rcases Finset.mem_Ioc.mp hnIoc with ⟨hLn, hnU⟩
      have htlt : t < (n : ℝ) := by
        simpa [L] using (Nat.floor_lt ht).mp hLn
      have hnUreal : (n : ℝ) ≤ 2 * t := by
        exact (Nat.le_floor_iff htwo_t).mp (by simpa [U] using hnU)
      have hnOne : 1 ≤ n := by
        by_contra hnot
        have hn0 : n = 0 := Nat.eq_zero_of_not_pos (by simpa using hnot)
        have : t < (0 : ℝ) := by simpa [hn0] using htlt
        linarith
      exact Finset.mem_filter.mpr
        ⟨by
          unfold natWindow
          exact Finset.mem_filter.mpr
            ⟨Finset.mem_Icc.mpr ⟨hnOne, (by simpa [U] using hnU)⟩, htlt⟩,
          (Nat.modEq_zero_iff_dvd).mp hmod⟩
  unfold roughBadPrimeSubsetProductMultiplesCount
    roughBadPrimeSubsetProductMultiplesFloorCount
  change (((natWindow t (2 * t)).filter (fun n : ℕ => q ∣ n)).card : ℝ) =
    (((⌊((U : ℕ) : ℚ) / (q : ℚ)⌋ - ⌊((L : ℕ) : ℚ) / (q : ℚ)⌋) ⊔ 0 : ℤ) : ℝ)
  rw [hset]
  have hcard := Nat.Ioc_filter_modEq_card L U hupos 0
  have hcard_real := congrArg (fun z : ℤ => (z : ℝ)) hcard
  simpa using hcard_real

/-- Signed alternating floor-error carrier for the multiples-only
product-modulus discrepancy. -/
noncomputable def roughDyadicBadPrimeProductMultiplesFloorErrorSum
    (X : ℝ) (t : ℝ) : ℝ :=
  ∑ u ∈ (roughModulus X).primeFactors.powerset,
    (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
      (roughBadPrimeSubsetProductMultiplesFloorCount t u -
        t / (badPrimeSubsetModulus u : ℝ))

/-- Pointwise sawtooth form of a product-modulus floor error.  This writes
`⌊U/q⌋ - ⌊L/q⌋ - t/q`, with `L = ⌊t⌋₊` and `U = ⌊2t⌋₊`, as a difference of
fractional parts plus the harmless endpoint discrepancy `(U - L - t)/q`. -/
noncomputable def roughBadPrimeSubsetProductMultiplesFractionalError
    (t : ℝ) (u : Finset ℕ) : ℝ :=
  let q : ℕ := badPrimeSubsetModulus u
  let L : ℕ := ⌊t⌋₊
  let U : ℕ := ⌊2 * t⌋₊
  Int.fract (((((L : ℕ) : ℚ) / (q : ℚ) : ℚ) : ℝ)) -
    Int.fract (((((U : ℕ) : ℚ) / (q : ℚ) : ℚ) : ℝ)) +
      (((U : ℝ) - (L : ℝ) - t) / (q : ℝ))

/-- Endpoint defect in replacing the dyadic length by the natural-floor
endpoints `⌊2t⌋₊` and `⌊t⌋₊`. -/
noncomputable def roughBadPrimeProductMultiplesEndpointDelta (t : ℝ) : ℝ :=
  ((⌊2 * t⌋₊ : ℕ) : ℝ) - ((⌊t⌋₊ : ℕ) : ℝ) - t

/-- Pure sawtooth part of a product-modulus floor error, with the endpoint
defect removed. -/
noncomputable def roughBadPrimeSubsetProductMultiplesFractionalPartError
    (t : ℝ) (u : Finset ℕ) : ℝ :=
  let q : ℕ := badPrimeSubsetModulus u
  let L : ℕ := ⌊t⌋₊
  let U : ℕ := ⌊2 * t⌋₊
  Int.fract (((((L : ℕ) : ℚ) / (q : ℚ) : ℚ) : ℝ)) -
    Int.fract (((((U : ℕ) : ℚ) / (q : ℚ) : ℚ) : ℝ))

/-- Single-endpoint fractional-part potential for a product modulus. -/
noncomputable def roughBadPrimeSubsetProductMultiplesFractionalPartPotential
    (n : ℕ) (u : Finset ℕ) : ℝ :=
  let q : ℕ := badPrimeSubsetModulus u
  Int.fract (((((n : ℕ) : ℚ) / (q : ℚ) : ℚ) : ℝ))

/-- The same endpoint potential, written as a normalized residue. -/
noncomputable def roughBadPrimeSubsetProductMultiplesResiduePotential
    (n : ℕ) (u : Finset ℕ) : ℝ :=
  ((n % badPrimeSubsetModulus u : ℕ) : ℝ) /
    (badPrimeSubsetModulus u : ℝ)

/-- The fractional-part endpoint potential is exactly the normalized residue
`n mod q` divided by the subset product modulus `q`. -/
theorem roughBadPrimeSubsetProductMultiplesFractionalPartPotential_eq_residue
    (n : ℕ) (u : Finset ℕ) :
    roughBadPrimeSubsetProductMultiplesFractionalPartPotential n u =
      roughBadPrimeSubsetProductMultiplesResiduePotential n u := by
  unfold roughBadPrimeSubsetProductMultiplesFractionalPartPotential
    roughBadPrimeSubsetProductMultiplesResiduePotential
  simpa using
    (Int.fract_div_natCast_eq_div_natCast_mod
      (k := ℝ) (m := n) (n := badPrimeSubsetModulus u))

/-- The pure fractional-part interval term is the difference of the endpoint
potentials at `⌊t⌋₊` and `⌊2t⌋₊`. -/
theorem roughBadPrimeSubsetProductMultiplesFractionalPartError_eq_potential_sub
    (t : ℝ) (u : Finset ℕ) :
    roughBadPrimeSubsetProductMultiplesFractionalPartError t u =
      roughBadPrimeSubsetProductMultiplesFractionalPartPotential ⌊t⌋₊ u -
        roughBadPrimeSubsetProductMultiplesFractionalPartPotential ⌊2 * t⌋₊ u := by
  rfl

/-- The empty-subset pure fractional-part term vanishes: it is the difference
of fractional parts of integers. -/
theorem roughBadPrimeSubsetProductMultiplesFractionalPartError_empty
    (t : ℝ) :
    roughBadPrimeSubsetProductMultiplesFractionalPartError t ∅ = 0 := by
  unfold roughBadPrimeSubsetProductMultiplesFractionalPartError
    badPrimeSubsetModulus
  simp

/-- Pointwise split of the sawtooth form into pure fractional-part oscillation
and an endpoint defect divided by the subset modulus. -/
theorem roughBadPrimeSubsetProductMultiplesFractionalError_eq_fractionalPart_add_endpoint
    (t : ℝ) (u : Finset ℕ) :
    roughBadPrimeSubsetProductMultiplesFractionalError t u =
      roughBadPrimeSubsetProductMultiplesFractionalPartError t u +
        roughBadPrimeProductMultiplesEndpointDelta t /
          (badPrimeSubsetModulus u : ℝ) := by
  unfold roughBadPrimeSubsetProductMultiplesFractionalError
    roughBadPrimeSubsetProductMultiplesFractionalPartError
    roughBadPrimeProductMultiplesEndpointDelta
  ring

/-- The explicit floor-error carrier is exactly its sawtooth/fractional-part
form.  The proof is finite endpoint bookkeeping; it does not use any analytic
estimate. -/
theorem roughBadPrimeSubsetProductMultiplesFloorCount_sub_main_eq_fractionalError
    {t : ℝ} (ht : 0 ≤ t) {u : Finset ℕ}
    (hupos : 0 < badPrimeSubsetModulus u) :
    roughBadPrimeSubsetProductMultiplesFloorCount t u -
        t / (badPrimeSubsetModulus u : ℝ) =
      roughBadPrimeSubsetProductMultiplesFractionalError t u := by
  classical
  let q : ℕ := badPrimeSubsetModulus u
  let L : ℕ := ⌊t⌋₊
  let U : ℕ := ⌊2 * t⌋₊
  let xq : ℚ := (U : ℚ) / (q : ℚ)
  let yq : ℚ := (L : ℚ) / (q : ℚ)
  have hqpos_nat : 0 < q := by simpa [q] using hupos
  have hqpos_real : 0 < (q : ℝ) := by exact_mod_cast hqpos_nat
  have hqpos_rat : 0 < (q : ℚ) := by exact_mod_cast hqpos_nat
  have hL_le_U : L ≤ U := by
    dsimp [L, U]
    exact Nat.floor_mono (by linarith : t ≤ 2 * t)
  have hxy : yq ≤ xq := by
    dsimp [xq, yq]
    exact div_le_div_of_nonneg_right
      (by exact_mod_cast hL_le_U : (L : ℚ) ≤ U) hqpos_rat.le
  have hfloor_nonneg : 0 ≤ ⌊xq⌋ - ⌊yq⌋ := by
    exact sub_nonneg.mpr (Int.floor_mono hxy)
  have hfloorCount :
      roughBadPrimeSubsetProductMultiplesFloorCount t u =
        (((⌊xq⌋ - ⌊yq⌋ : ℤ) : ℝ)) := by
    unfold roughBadPrimeSubsetProductMultiplesFloorCount
    change (((⌊xq⌋ - ⌊yq⌋) ⊔ 0 : ℤ) : ℝ) =
      (((⌊xq⌋ - ⌊yq⌋ : ℤ) : ℝ))
    rw [max_eq_left hfloor_nonneg]
  have hfloorCount' :
      roughBadPrimeSubsetProductMultiplesFloorCount t u =
        (((⌊xq⌋ : ℤ) : ℝ) - ((⌊yq⌋ : ℤ) : ℝ)) := by
    rw [hfloorCount]
    norm_num
  have hx_floor :
      (((⌊xq⌋ : ℤ) : ℝ)) =
        ((xq : ℚ) : ℝ) - Int.fract (((xq : ℚ) : ℝ)) := by
    have hxq : ((⌊xq⌋ : ℤ) : ℚ) = xq - Int.fract xq :=
      eq_sub_of_add_eq (Int.floor_add_fract xq)
    exact_mod_cast hxq
  have hy_floor :
      (((⌊yq⌋ : ℤ) : ℝ)) =
        ((yq : ℚ) : ℝ) - Int.fract (((yq : ℚ) : ℝ)) := by
    have hyq : ((⌊yq⌋ : ℤ) : ℚ) = yq - Int.fract yq :=
      eq_sub_of_add_eq (Int.floor_add_fract yq)
    exact_mod_cast hyq
  have hxy_real :
      ((xq : ℚ) : ℝ) - ((yq : ℚ) : ℝ) =
        ((U : ℝ) - (L : ℝ)) / (q : ℝ) := by
    dsimp [xq, yq]
    field_simp [ne_of_gt hqpos_real]
  rw [hfloorCount']
  unfold roughBadPrimeSubsetProductMultiplesFractionalError
  change
      (((⌊xq⌋ : ℤ) : ℝ) - ((⌊yq⌋ : ℤ) : ℝ)) -
        t / (q : ℝ) =
      Int.fract (((yq : ℚ) : ℝ)) -
        Int.fract (((xq : ℚ) : ℝ)) +
          (((U : ℝ) - (L : ℝ) - t) / (q : ℝ))
  rw [hx_floor, hy_floor]
  change
    (((xq : ℚ) : ℝ) - Int.fract (((xq : ℚ) : ℝ)) -
        (((yq : ℚ) : ℝ) - Int.fract (((yq : ℚ) : ℝ)))) -
        t / (q : ℝ) =
      Int.fract (((yq : ℚ) : ℝ)) - Int.fract (((xq : ℚ) : ℝ)) +
        (((U : ℝ) - (L : ℝ) - t) / (q : ℝ))
  calc
    (((xq : ℚ) : ℝ) - Int.fract (((xq : ℚ) : ℝ)) -
        (((yq : ℚ) : ℝ) - Int.fract (((yq : ℚ) : ℝ)))) -
        t / (q : ℝ)
        =
      Int.fract (((yq : ℚ) : ℝ)) - Int.fract (((xq : ℚ) : ℝ)) +
        (((xq : ℚ) : ℝ) - ((yq : ℚ) : ℝ) - t / (q : ℝ)) := by
          ring
    _ =
      Int.fract (((yq : ℚ) : ℝ)) - Int.fract (((xq : ℚ) : ℝ)) +
        (((U : ℝ) - (L : ℝ) - t) / (q : ℝ)) := by
          rw [hxy_real]
          field_simp [ne_of_gt hqpos_real]

/-- Signed alternating sawtooth/fractional-part form of the multiples-only
product-modulus discrepancy. -/
noncomputable def roughDyadicBadPrimeProductMultiplesFractionalErrorSum
    (X : ℝ) (t : ℝ) : ℝ :=
  ∑ u ∈ (roughModulus X).primeFactors.powerset,
    (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
      roughBadPrimeSubsetProductMultiplesFractionalError t u

/-- Signed alternating pure fractional-part sum after removing the endpoint
defect from the sawtooth floor-error carrier. -/
noncomputable def roughDyadicBadPrimeProductMultiplesFractionalPartErrorSum
    (X : ℝ) (t : ℝ) : ℝ :=
  ∑ u ∈ (roughModulus X).primeFactors.powerset,
    (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
      roughBadPrimeSubsetProductMultiplesFractionalPartError t u

/-- The same pure fractional-part sum with the empty-subset contribution
removed.  The removed term is theorem-level zero. -/
noncomputable def roughDyadicBadPrimeProductMultiplesNonemptyFractionalPartErrorSum
    (X : ℝ) (t : ℝ) : ℝ :=
  ∑ u ∈ ((roughModulus X).primeFactors.powerset.filter (fun u => u.Nonempty)),
    (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
      roughBadPrimeSubsetProductMultiplesFractionalPartError t u

/-- Nonempty alternating fractional-part potential at a single endpoint. -/
noncomputable def roughDyadicBadPrimeProductMultiplesNonemptyFractionalPartPotential
    (X : ℝ) (n : ℕ) : ℝ :=
  ∑ u ∈ ((roughModulus X).primeFactors.powerset.filter (fun u => u.Nonempty)),
    (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
      roughBadPrimeSubsetProductMultiplesFractionalPartPotential n u

/-- Nonempty alternating endpoint potential written in normalized residues. -/
noncomputable def roughDyadicBadPrimeProductMultiplesNonemptyResiduePotential
    (X : ℝ) (n : ℕ) : ℝ :=
  ∑ u ∈ ((roughModulus X).primeFactors.powerset.filter (fun u => u.Nonempty)),
    (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
      roughBadPrimeSubsetProductMultiplesResiduePotential n u

/-- Full alternating endpoint residue potential, before deleting the
theorem-level zero empty-subset contribution. -/
noncomputable def roughDyadicBadPrimeProductMultiplesResiduePotential
    (X : ℝ) (n : ℕ) : ℝ :=
  ∑ u ∈ (roughModulus X).primeFactors.powerset,
    (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
      roughBadPrimeSubsetProductMultiplesResiduePotential n u

/-- The empty-subset endpoint residue term is zero. -/
theorem roughBadPrimeSubsetProductMultiplesResiduePotential_empty
    (n : ℕ) :
    roughBadPrimeSubsetProductMultiplesResiduePotential n ∅ = 0 := by
  unfold roughBadPrimeSubsetProductMultiplesResiduePotential
    badPrimeSubsetModulus
  simp [Nat.mod_one]

/-- Removing the empty subset does not change the endpoint residue potential. -/
theorem roughDyadicBadPrimeProductMultiplesNonemptyResiduePotential_eq_full
    (X : ℝ) (n : ℕ) :
    roughDyadicBadPrimeProductMultiplesNonemptyResiduePotential X n =
      roughDyadicBadPrimeProductMultiplesResiduePotential X n := by
  classical
  unfold roughDyadicBadPrimeProductMultiplesNonemptyResiduePotential
    roughDyadicBadPrimeProductMultiplesResiduePotential
  rw [Finset.sum_filter]
  refine (Finset.sum_congr rfl ?_).symm
  intro u _hu
  by_cases hune : u.Nonempty
  · simp [hune]
  · have huempty : u = ∅ := Finset.not_nonempty_iff_eq_empty.mp hune
    subst u
    simp [roughBadPrimeSubsetProductMultiplesResiduePotential_empty]

/-- The nonempty endpoint potential is the corresponding alternating
normalized-residue sum. -/
theorem roughDyadicBadPrimeProductMultiplesNonemptyFractionalPartPotential_eq_residue
    (X : ℝ) (n : ℕ) :
    roughDyadicBadPrimeProductMultiplesNonemptyFractionalPartPotential X n =
      roughDyadicBadPrimeProductMultiplesNonemptyResiduePotential X n := by
  classical
  unfold roughDyadicBadPrimeProductMultiplesNonemptyFractionalPartPotential
    roughDyadicBadPrimeProductMultiplesNonemptyResiduePotential
  refine Finset.sum_congr rfl ?_
  intro u _hu
  rw [roughBadPrimeSubsetProductMultiplesFractionalPartPotential_eq_residue]

/-- The nonempty pure fractional-part interval carrier is the difference of a
single endpoint potential at `⌊t⌋₊` and `⌊2t⌋₊`. -/
theorem roughDyadicBadPrimeProductMultiplesNonemptyFractionalPartErrorSum_eq_potential_sub
    (X : ℝ) (t : ℝ) :
    roughDyadicBadPrimeProductMultiplesNonemptyFractionalPartErrorSum X t =
      roughDyadicBadPrimeProductMultiplesNonemptyFractionalPartPotential X ⌊t⌋₊ -
        roughDyadicBadPrimeProductMultiplesNonemptyFractionalPartPotential X ⌊2 * t⌋₊ := by
  classical
  unfold roughDyadicBadPrimeProductMultiplesNonemptyFractionalPartErrorSum
    roughDyadicBadPrimeProductMultiplesNonemptyFractionalPartPotential
  rw [← Finset.sum_sub_distrib]
  refine Finset.sum_congr rfl ?_
  intro u _hu
  rw [roughBadPrimeSubsetProductMultiplesFractionalPartError_eq_potential_sub]
  ring

/-- Removing the empty subset does not change the pure fractional-part sum. -/
theorem roughDyadicBadPrimeProductMultiplesFractionalPartErrorSum_eq_nonempty
    (X : ℝ) (t : ℝ) :
    roughDyadicBadPrimeProductMultiplesFractionalPartErrorSum X t =
      roughDyadicBadPrimeProductMultiplesNonemptyFractionalPartErrorSum X t := by
  classical
  unfold roughDyadicBadPrimeProductMultiplesFractionalPartErrorSum
    roughDyadicBadPrimeProductMultiplesNonemptyFractionalPartErrorSum
  rw [Finset.sum_filter]
  refine Finset.sum_congr rfl ?_
  intro u _hu
  by_cases hune : u.Nonempty
  · simp [hune]
  · have huempty : u = ∅ := Finset.not_nonempty_iff_eq_empty.mp hune
    subst u
    simp [roughBadPrimeSubsetProductMultiplesFractionalPartError_empty]

/-- The finite alternating floor-error sum is exactly the finite alternating
sawtooth/fractional-part sum. -/
theorem roughDyadicBadPrimeProductMultiplesFloorErrorSum_eq_fractionalErrorSum
    (X : ℝ) {t : ℝ} (ht : 0 ≤ t) :
    roughDyadicBadPrimeProductMultiplesFloorErrorSum X t =
      roughDyadicBadPrimeProductMultiplesFractionalErrorSum X t := by
  classical
  unfold roughDyadicBadPrimeProductMultiplesFloorErrorSum
    roughDyadicBadPrimeProductMultiplesFractionalErrorSum
  apply Finset.sum_congr rfl
  intro u hu
  rw [roughBadPrimeSubsetProductMultiplesFloorCount_sub_main_eq_fractionalError
    ht (badPrimeSubsetModulus_pos_of_mem_rough_powerset X hu)]

/-- The dyadic endpoint defect `⌊2t⌋ - ⌊t⌋ - t` has absolute value at most one
for nonnegative `t`. -/
theorem abs_roughBadPrimeProductMultiplesEndpointDelta_le_one
    {t : ℝ} (ht : 0 ≤ t) :
    |roughBadPrimeProductMultiplesEndpointDelta t| ≤ 1 := by
  let L : ℕ := ⌊t⌋₊
  let U : ℕ := ⌊2 * t⌋₊
  have htwo_t : 0 ≤ 2 * t := mul_nonneg (by norm_num) ht
  have hU_le : (U : ℝ) ≤ 2 * t := by
    dsimp [U]
    exact Nat.floor_le htwo_t
  have hU_gt : 2 * t < (U : ℝ) + 1 := by
    dsimp [U]
    exact Nat.lt_floor_add_one (2 * t)
  have hL_le : (L : ℝ) ≤ t := by
    dsimp [L]
    exact Nat.floor_le ht
  have hL_gt : t < (L : ℝ) + 1 := by
    dsimp [L]
    exact Nat.lt_floor_add_one t
  have hdelta : |(((U : ℝ) - (L : ℝ)) - t)| ≤ 1 := by
    rw [abs_sub_le_iff]
    constructor <;> linarith
  simpa [roughBadPrimeProductMultiplesEndpointDelta, L, U] using hdelta

/-- One product-modulus floor carrier differs from its real main term by at
most an absolute endpoint constant.  This is unconditional lattice
bookkeeping: it uses only floor inequalities, not cancellation across subsets
or any analytic sieve input. -/
theorem abs_roughBadPrimeSubsetProductMultiplesFloorCount_sub_main_le_three
    {t : ℝ} (ht : 0 ≤ t) {u : Finset ℕ}
    (hupos : 0 < badPrimeSubsetModulus u) :
    |roughBadPrimeSubsetProductMultiplesFloorCount t u -
        t / (badPrimeSubsetModulus u : ℝ)| ≤ 3 := by
  classical
  let q : ℕ := badPrimeSubsetModulus u
  let L : ℕ := ⌊t⌋₊
  let U : ℕ := ⌊2 * t⌋₊
  let xq : ℚ := (U : ℚ) / (q : ℚ)
  let yq : ℚ := (L : ℚ) / (q : ℚ)
  have htwo_t : 0 ≤ 2 * t := mul_nonneg (by norm_num) ht
  have hqpos_nat : 0 < q := by simpa [q] using hupos
  have hqpos_real : 0 < (q : ℝ) := by exact_mod_cast hqpos_nat
  have hqpos_rat : 0 < (q : ℚ) := by exact_mod_cast hqpos_nat
  have hL_le_U : L ≤ U := by
    dsimp [L, U]
    exact Nat.floor_mono (by linarith : t ≤ 2 * t)
  have hxy : yq ≤ xq := by
    dsimp [xq, yq]
    exact div_le_div_of_nonneg_right
      (by exact_mod_cast hL_le_U : (L : ℚ) ≤ U) hqpos_rat.le
  have hfloor_nonneg : 0 ≤ ⌊xq⌋ - ⌊yq⌋ := by
    exact sub_nonneg.mpr (Int.floor_mono hxy)
  have hfloorCount :
      roughBadPrimeSubsetProductMultiplesFloorCount t u =
        (((⌊xq⌋ - ⌊yq⌋ : ℤ) : ℝ)) := by
    unfold roughBadPrimeSubsetProductMultiplesFloorCount
    change (((⌊xq⌋ - ⌊yq⌋) ⊔ 0 : ℤ) : ℝ) =
      (((⌊xq⌋ - ⌊yq⌋ : ℤ) : ℝ))
    rw [max_eq_left hfloor_nonneg]
  have hfloorRat :
      |(((⌊xq⌋ - ⌊yq⌋ : ℤ) : ℝ) -
          (((xq - yq : ℚ) : ℝ)))| ≤ 2 := by
    have hq :
        |(((⌊xq⌋ - ⌊yq⌋ : ℤ) : ℚ) - (xq - yq))| ≤ (2 : ℚ) := by
      rw [abs_sub_le_iff]
      constructor
      · have hx : ((⌊xq⌋ : ℤ) : ℚ) ≤ xq := Int.floor_le xq
        have hy : yq < ((⌊yq⌋ : ℤ) : ℚ) + 1 := Int.lt_floor_add_one yq
        norm_num
        linarith
      · have hx : xq < ((⌊xq⌋ : ℤ) : ℚ) + 1 := Int.lt_floor_add_one xq
        have hy : ((⌊yq⌋ : ℤ) : ℚ) ≤ yq := Int.floor_le yq
        norm_num
        linarith
    exact_mod_cast hq
  have hU_le : (U : ℝ) ≤ 2 * t := by
    dsimp [U]
    exact Nat.floor_le htwo_t
  have hU_gt : 2 * t < (U : ℝ) + 1 := by
    dsimp [U]
    exact Nat.lt_floor_add_one (2 * t)
  have hL_le : (L : ℝ) ≤ t := by
    dsimp [L]
    exact Nat.floor_le ht
  have hL_gt : t < (L : ℝ) + 1 := by
    dsimp [L]
    exact Nat.lt_floor_add_one t
  have hdelta : |(((U : ℝ) - (L : ℝ)) - t)| ≤ 1 := by
    rw [abs_sub_le_iff]
    constructor <;> linarith
  have hxy_real :
      (((xq - yq : ℚ) : ℝ)) = ((U : ℝ) - (L : ℝ)) / (q : ℝ) := by
    dsimp [xq, yq]
    field_simp [ne_of_gt hqpos_real]
  have hdelta_div :
      |(((xq - yq : ℚ) : ℝ) - t / (q : ℝ))| ≤ 1 := by
    rw [hxy_real]
    have hrewrite :
        ((U : ℝ) - (L : ℝ)) / (q : ℝ) - t / (q : ℝ) =
          (((U : ℝ) - (L : ℝ)) - t) / (q : ℝ) := by
      ring
    rw [hrewrite, abs_div]
    have hq_abs : |(q : ℝ)| = (q : ℝ) := abs_of_pos hqpos_real
    rw [hq_abs, div_le_iff₀ hqpos_real]
    have hq_ge_one : (1 : ℝ) ≤ q := by exact_mod_cast hqpos_nat
    calc
      |((U : ℝ) - (L : ℝ) - t)| ≤ 1 := hdelta
      _ ≤ 1 * (q : ℝ) := by simpa using hq_ge_one
  rw [hfloorCount]
  calc
    |(((⌊xq⌋ - ⌊yq⌋ : ℤ) : ℝ) - t / (q : ℝ))|
        ≤ |(((⌊xq⌋ - ⌊yq⌋ : ℤ) : ℝ) -
              (((xq - yq : ℚ) : ℝ)))| +
            |(((xq - yq : ℚ) : ℝ) - t / (q : ℝ))| :=
          abs_sub_le _ _ _
    _ ≤ 2 + 1 := add_le_add hfloorRat hdelta_div
    _ ≤ 3 := by norm_num

/-- Crude unconditional global envelope for the explicit alternating floor
error.  It intentionally discards all inclusion-exclusion cancellation; the
remaining quarter-budget primitive is precisely the assertion that this finite
floor-error sum is much smaller than this trivial subset-count bound. -/
theorem abs_roughDyadicBadPrimeProductMultiplesFloorErrorSum_le_three_mul_powerset_card
    (X : ℝ) {t : ℝ} (ht : 0 ≤ t) :
    |roughDyadicBadPrimeProductMultiplesFloorErrorSum X t| ≤
      3 * (((roughModulus X).primeFactors.powerset.card : ℕ) : ℝ) := by
  classical
  unfold roughDyadicBadPrimeProductMultiplesFloorErrorSum
  calc
    |∑ u ∈ (roughModulus X).primeFactors.powerset,
        (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
          (roughBadPrimeSubsetProductMultiplesFloorCount t u -
            t / (badPrimeSubsetModulus u : ℝ))|
        ≤ ∑ u ∈ (roughModulus X).primeFactors.powerset,
          |(((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
            (roughBadPrimeSubsetProductMultiplesFloorCount t u -
              t / (badPrimeSubsetModulus u : ℝ))| :=
          Finset.abs_sum_le_sum_abs _ _
    _ = ∑ u ∈ (roughModulus X).primeFactors.powerset,
          |roughBadPrimeSubsetProductMultiplesFloorCount t u -
            t / (badPrimeSubsetModulus u : ℝ)| := by
          apply Finset.sum_congr rfl
          intro u _hu
          rw [abs_mul]
          have hsign :
              |(((-1 : ℤ) ^ u.card : ℤ) : ℝ)| = (1 : ℝ) := by
            simp
          rw [hsign, one_mul]
    _ ≤ ∑ u ∈ (roughModulus X).primeFactors.powerset, (3 : ℝ) := by
          apply Finset.sum_le_sum
          intro u hu
          exact abs_roughBadPrimeSubsetProductMultiplesFloorCount_sub_main_le_three
            ht (badPrimeSubsetModulus_pos_of_mem_rough_powerset X hu)
    _ = 3 * (((roughModulus X).primeFactors.powerset.card : ℕ) : ℝ) := by
          simp [mul_comm]

/-- Explicit quotient envelope for each product-modulus term appearing in the
rough-sieve inclusion-exclusion expansion. -/
theorem roughBadPrimeSubsetProductCount_le_floor_div
    (X : ℝ) (M : ℕ) (t : ℝ) {u : Finset ℕ}
    (hu : u ∈ (roughModulus X).primeFactors.powerset) :
    roughBadPrimeSubsetProductCount X M t u
      ≤ ((⌊2 * t⌋₊ / badPrimeSubsetModulus u : ℕ) : ℝ) := by
  exact (roughBadPrimeSubsetProductCount_le_multiplesCount X M t u).trans
    (roughBadPrimeSubsetProductMultiplesCount_le_floor_div X t
      (badPrimeSubsetModulus_pos_of_mem_rough_powerset X hu))

/-- Fully expanded finite inclusion-exclusion carrier: an alternating sum over
subsets of the small primes, where each term is the exact divisibility count
for that subset. -/
noncomputable def roughDyadicBadPrimeSubsetCountSum (X : ℝ) (M : ℕ) (t : ℝ) : ℝ :=
  ∑ u ∈ (roughModulus X).primeFactors.powerset,
    (((-1 : ℤ) ^ u.card : ℤ) : ℝ) * roughBadPrimeSubsetCount X M t u

/-- Product-modulus version of the fully expanded finite inclusion-exclusion
carrier. -/
noncomputable def roughDyadicBadPrimeSubsetProductCountSum
    (X : ℝ) (M : ℕ) (t : ℝ) : ℝ :=
  ∑ u ∈ (roughModulus X).primeFactors.powerset,
    (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
      roughBadPrimeSubsetProductCount X M t u

/-- Signed product-modulus main term for the rough inclusion-exclusion carrier.
The associated error below absorbs the squarefree/coprimality restrictions and
the finite endpoint/floor effects. -/
noncomputable def roughDyadicBadPrimeProductMainTermSum
    (X : ℝ) (t : ℝ) : ℝ :=
  ∑ u ∈ (roughModulus X).primeFactors.powerset,
    (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
      (t / (badPrimeSubsetModulus u : ℝ))

/-- Finite Euler product attached to the rough-sieve main term. -/
noncomputable def roughDyadicBadPrimeMainEulerProduct (X : ℝ) : ℝ :=
  ∏ p ∈ (roughModulus X).primeFactors, (1 - (p : ℝ)⁻¹)

/-- Generic finite Euler product attached to `P(z)`, before specializing
`z = (log X)^4`. -/
noncomputable def primeProductBelowEulerProduct (z : ℝ) : ℝ :=
  ∏ p ∈ (primeProductBelow z).primeFactors, (1 - (p : ℝ)⁻¹)

/-- The finite bad-prime Euler product is nonnegative. -/
theorem roughDyadicBadPrimeMainEulerProduct_nonneg (X : ℝ) :
    0 ≤ roughDyadicBadPrimeMainEulerProduct X := by
  classical
  unfold roughDyadicBadPrimeMainEulerProduct
  apply Finset.prod_nonneg
  intro p hp
  have hpPrime : Nat.Prime p := Nat.prime_of_mem_primeFactors hp
  have hpOne : (1 : ℝ) ≤ (p : ℝ) := by exact_mod_cast hpPrime.one_lt.le
  exact sub_nonneg.mpr (inv_le_one_of_one_le₀ hpOne)

/-- The finite bad-prime Euler product is at most one. -/
theorem roughDyadicBadPrimeMainEulerProduct_le_one (X : ℝ) :
    roughDyadicBadPrimeMainEulerProduct X ≤ 1 := by
  classical
  unfold roughDyadicBadPrimeMainEulerProduct
  calc
    ∏ p ∈ (roughModulus X).primeFactors, (1 - (p : ℝ)⁻¹)
        ≤ ∏ _p ∈ (roughModulus X).primeFactors, (1 : ℝ) := by
          apply Finset.prod_le_prod
          · intro p hp
            have hpPrime : Nat.Prime p := Nat.prime_of_mem_primeFactors hp
            have hpOne : (1 : ℝ) ≤ (p : ℝ) := by exact_mod_cast hpPrime.one_lt.le
            exact sub_nonneg.mpr (inv_le_one_of_one_le₀ hpOne)
          · intro p _hp
            have hinv_nonneg : 0 ≤ (p : ℝ)⁻¹ :=
              inv_nonneg.mpr (Nat.cast_nonneg p)
            linarith
    _ = 1 := by simp

/-- The finite bad-prime Euler product is the coprime residue density modulo
the rough modulus. -/
theorem roughDyadicBadPrimeMainEulerProduct_eq_totient_ratio (X : ℝ) :
    roughDyadicBadPrimeMainEulerProduct X =
      (Nat.totient (roughModulus X) : ℝ) / (roughModulus X : ℝ) := by
  rw [totient_div_eq_totientPrimeFactorProduct (roughModulus_pos X)]
  rfl

/-- The signed product-modulus main term is exactly the usual finite
Euler-product main term.  This is pure finite inclusion-exclusion algebra; the
analytic work in the rough primitive is the size of this product and domination
of the exact error term. -/
theorem roughDyadicBadPrimeProductMainTermSum_eq_mul_eulerProduct
    (X : ℝ) (t : ℝ) :
    roughDyadicBadPrimeProductMainTermSum X t =
      t * roughDyadicBadPrimeMainEulerProduct X := by
  classical
  let s : Finset ℕ := (roughModulus X).primeFactors
  have hprod_sub :
      ∏ p ∈ s, (1 - (p : ℝ)⁻¹) =
        ∑ u ∈ s.powerset,
          (-1 : ℝ) ^ u.card * ∏ p ∈ u, (p : ℝ)⁻¹ := by
    have h := Finset.prod_sub (fun _p : ℕ => (1 : ℝ))
      (fun p : ℕ => (p : ℝ)⁻¹) s
    simpa using h
  have hsum :
      roughDyadicBadPrimeProductMainTermSum X t =
        t * ∑ u ∈ s.powerset,
          (-1 : ℝ) ^ u.card * ∏ p ∈ u, (p : ℝ)⁻¹ := by
    unfold roughDyadicBadPrimeProductMainTermSum
    dsimp [s]
    rw [Finset.mul_sum]
    apply Finset.sum_congr rfl
    intro u hu
    have hsubset : u ⊆ s := Finset.mem_powerset.mp hu
    have hne : (∏ p ∈ u, (p : ℝ)) ≠ 0 := by
      exact Finset.prod_ne_zero_iff.mpr (fun p hp => by
        have hpprime : Nat.Prime p :=
          Nat.prime_of_mem_primeFactors (hsubset hp)
        exact_mod_cast hpprime.ne_zero)
    have hmod_cast :
        (badPrimeSubsetModulus u : ℝ) = ∏ p ∈ u, (p : ℝ) := by
      unfold badPrimeSubsetModulus
      exact Finset.prod_natCast u (fun p : ℕ => p)
    calc
      ((((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
          (t / (badPrimeSubsetModulus u : ℝ)))
          = ((-1 : ℝ) ^ u.card) *
              (t * (∏ p ∈ u, (p : ℝ))⁻¹) := by
            rw [hmod_cast]
            simp [div_eq_mul_inv]
      _ = t * ((-1 : ℝ) ^ u.card * ∏ p ∈ u, (p : ℝ)⁻¹) := by
            rw [Finset.prod_inv_distrib]
            ring
  calc
    roughDyadicBadPrimeProductMainTermSum X t
        = t * ∑ u ∈ s.powerset,
            (-1 : ℝ) ^ u.card * ∏ p ∈ u, (p : ℝ)⁻¹ := hsum
    _ = t * roughDyadicBadPrimeMainEulerProduct X := by
          rw [← hprod_sub]
          rfl

/-- The signed sawtooth/fractional-error sum splits into a pure fractional-part
sum plus the endpoint defect times the finite Euler product. -/
theorem roughDyadicBadPrimeProductMultiplesFractionalErrorSum_eq_fractionalPart_add_endpoint
    (X : ℝ) (t : ℝ) :
    roughDyadicBadPrimeProductMultiplesFractionalErrorSum X t =
      roughDyadicBadPrimeProductMultiplesFractionalPartErrorSum X t +
        roughDyadicBadPrimeProductMainTermSum X
          (roughBadPrimeProductMultiplesEndpointDelta t) := by
  classical
  unfold roughDyadicBadPrimeProductMultiplesFractionalErrorSum
    roughDyadicBadPrimeProductMultiplesFractionalPartErrorSum
    roughDyadicBadPrimeProductMainTermSum
  rw [← Finset.sum_add_distrib]
  apply Finset.sum_congr rfl
  intro u _hu
  rw [roughBadPrimeSubsetProductMultiplesFractionalError_eq_fractionalPart_add_endpoint]
  ring

/-- Equivalent Euler-product form of the endpoint split. -/
theorem roughDyadicBadPrimeProductMultiplesFractionalErrorSum_eq_fractionalPart_add_endpointEuler
    (X : ℝ) (t : ℝ) :
    roughDyadicBadPrimeProductMultiplesFractionalErrorSum X t =
      roughDyadicBadPrimeProductMultiplesFractionalPartErrorSum X t +
        roughBadPrimeProductMultiplesEndpointDelta t *
          roughDyadicBadPrimeMainEulerProduct X := by
  rw [roughDyadicBadPrimeProductMultiplesFractionalErrorSum_eq_fractionalPart_add_endpoint,
    roughDyadicBadPrimeProductMainTermSum_eq_mul_eulerProduct]

/-- The endpoint contribution in the rough multiples split is absolutely
bounded by one. -/
theorem abs_roughDyadicBadPrimeProductMultiplesEndpointErrorSum_le_one
    (X : ℝ) {t : ℝ} (ht : 0 ≤ t) :
    |roughDyadicBadPrimeProductMainTermSum X
      (roughBadPrimeProductMultiplesEndpointDelta t)| ≤ 1 := by
  rw [roughDyadicBadPrimeProductMainTermSum_eq_mul_eulerProduct]
  have hdelta := abs_roughBadPrimeProductMultiplesEndpointDelta_le_one ht
  have hprod_nonneg := roughDyadicBadPrimeMainEulerProduct_nonneg X
  have hprod_le_one := roughDyadicBadPrimeMainEulerProduct_le_one X
  have hprod_abs : |roughDyadicBadPrimeMainEulerProduct X| ≤ 1 := by
    rw [abs_of_nonneg hprod_nonneg]
    exact hprod_le_one
  calc
    |roughBadPrimeProductMultiplesEndpointDelta t *
        roughDyadicBadPrimeMainEulerProduct X|
        = |roughBadPrimeProductMultiplesEndpointDelta t| *
            |roughDyadicBadPrimeMainEulerProduct X| := abs_mul _ _
    _ ≤ 1 * 1 := mul_le_mul hdelta hprod_abs (abs_nonneg _) (by norm_num)
    _ = 1 := by norm_num

/-- Exact finite error after subtracting the signed product-modulus main term
from the product-count inclusion-exclusion carrier. -/
noncomputable def roughDyadicBadPrimeProductErrorSum
    (X : ℝ) (M : ℕ) (t : ℝ) : ℝ :=
  roughDyadicBadPrimeSubsetProductCountSum X M t -
    roughDyadicBadPrimeProductMainTermSum X t

/-- Local error for one subset in the product-modulus inclusion-exclusion
expansion.  This is the exact gap between the finite filtered count and its
naive quotient main term. -/
noncomputable def roughBadPrimeSubsetProductLocalError
    (X : ℝ) (M : ℕ) (t : ℝ) (u : Finset ℕ) : ℝ :=
  roughBadPrimeSubsetProductCount X M t u -
    t / (badPrimeSubsetModulus u : ℝ)

/-- Local lattice discrepancy before squarefree and auxiliary-coprimality
filters are imposed. -/
noncomputable def roughBadPrimeSubsetProductMultiplesLocalError
    (X : ℝ) (t : ℝ) (u : Finset ℕ) : ℝ :=
  roughBadPrimeSubsetProductMultiplesCount X t u -
    t / (badPrimeSubsetModulus u : ℝ)

/-- Loss from imposing squarefreeness and auxiliary coprimality on one
product-modulus subset term. -/
noncomputable def roughBadPrimeSubsetProductFilterLoss
    (X : ℝ) (M : ℕ) (t : ℝ) (u : Finset ℕ) : ℝ :=
  roughBadPrimeSubsetProductMultiplesCount X t u -
    roughBadPrimeSubsetProductCount X M t u

/-- Loss from imposing squarefreeness on one product-modulus subset term,
before imposing auxiliary coprimality. -/
noncomputable def roughBadPrimeSubsetProductSquarefreeLoss
    (X : ℝ) (t : ℝ) (u : Finset ℕ) : ℝ :=
  roughBadPrimeSubsetProductMultiplesCount X t u -
    roughBadPrimeSubsetProductSquarefreeCount X t u

/-- Loss from imposing auxiliary coprimality after squarefreeness has already
been imposed. -/
noncomputable def roughBadPrimeSubsetProductAuxiliaryLoss
    (X : ℝ) (M : ℕ) (t : ℝ) (u : Finset ℕ) : ℝ :=
  roughBadPrimeSubsetProductSquarefreeCount X t u -
    roughBadPrimeSubsetProductCount X M t u

/-- The filter-loss term is nonnegative because the filtered count is contained
in the multiples-only count. -/
theorem roughBadPrimeSubsetProductFilterLoss_nonneg
    (X : ℝ) (M : ℕ) (t : ℝ) (u : Finset ℕ) :
    0 ≤ roughBadPrimeSubsetProductFilterLoss X M t u := by
  unfold roughBadPrimeSubsetProductFilterLoss
  exact sub_nonneg.mpr
    (roughBadPrimeSubsetProductCount_le_multiplesCount X M t u)

/-- The squarefree-loss term is nonnegative because the squarefree-only count
is contained in the multiples-only count. -/
theorem roughBadPrimeSubsetProductSquarefreeLoss_nonneg
    (X : ℝ) (t : ℝ) (u : Finset ℕ) :
    0 ≤ roughBadPrimeSubsetProductSquarefreeLoss X t u := by
  unfold roughBadPrimeSubsetProductSquarefreeLoss
  exact sub_nonneg.mpr
    (roughBadPrimeSubsetProductSquarefreeCount_le_multiplesCount X t u)

/-- A squarefree natural number is not divisible by `4`. -/
theorem not_four_dvd_of_squarefree {n : ℕ} (hn : Squarefree n) :
    ¬ 4 ∣ n := by
  have hnot : ¬ 2 * 2 ∣ n :=
    (Nat.squarefree_iff_prime_squarefree.mp hn) 2 Nat.prime_two
  simpa using hnot

/-- The empty-subset squarefree loss already contains every multiple of `4`
in the dyadic window.  This is a diagnostic obstruction to treating the
squarefree-loss envelope itself as an arbitrary-small error term. -/
theorem natWindow_four_multiples_card_le_empty_squarefreeLoss
    (X : ℝ) (t : ℝ) :
    (((natWindow t (2 * t)).filter (fun n : ℕ => 4 ∣ n)).card : ℝ) ≤
      roughBadPrimeSubsetProductSquarefreeLoss X t ∅ := by
  classical
  let W : Finset ℕ := natWindow t (2 * t)
  let S : Finset ℕ := W.filter (fun n : ℕ => Squarefree n)
  let F : Finset ℕ := W.filter (fun n : ℕ => 4 ∣ n)
  have hdisj : Disjoint S F := by
    rw [Finset.disjoint_left]
    intro n hnS hnF
    have hn_sqf : Squarefree n := (Finset.mem_filter.mp hnS).2
    have hn_four : 4 ∣ n := (Finset.mem_filter.mp hnF).2
    exact (not_four_dvd_of_squarefree hn_sqf) hn_four
  have hsub : S ∪ F ⊆ W := by
    intro n hn
    rw [Finset.mem_union] at hn
    rcases hn with hnS | hnF
    · exact (Finset.mem_filter.mp hnS).1
    · exact (Finset.mem_filter.mp hnF).1
  have hcard_union : (S ∪ F).card = S.card + F.card :=
    Finset.card_union_of_disjoint hdisj
  have hcard_le : S.card + F.card ≤ W.card := by
    rw [← hcard_union]
    exact Finset.card_le_card hsub
  have hreal : (F.card : ℝ) ≤ (W.card : ℝ) - (S.card : ℝ) := by
    have hcard_le' : F.card + S.card ≤ W.card := by
      simpa [Nat.add_comm] using hcard_le
    have hsub : F.card ≤ W.card - S.card :=
      Nat.le_sub_of_add_le hcard_le'
    have hS_le_W : S.card ≤ W.card :=
      le_trans (Nat.le_add_right S.card F.card) hcard_le
    have hsub_real : (F.card : ℝ) ≤ ((W.card - S.card : ℕ) : ℝ) := by
      exact_mod_cast hsub
    rwa [Nat.cast_sub hS_le_W] at hsub_real
  have hmul_empty :
      roughBadPrimeSubsetProductMultiplesCount X t ∅ = (W.card : ℝ) := by
    unfold roughBadPrimeSubsetProductMultiplesCount W
    simp [badPrimeSubsetModulus]
  have hsqf_empty :
      roughBadPrimeSubsetProductSquarefreeCount X t ∅ = (S.card : ℝ) := by
    unfold roughBadPrimeSubsetProductSquarefreeCount S W
    simp [badPrimeSubsetModulus]
  simpa [roughBadPrimeSubsetProductSquarefreeLoss, hmul_empty, hsqf_empty, F, W]
    using hreal

/-- The auxiliary-loss term is nonnegative because the fully filtered count is
contained in the squarefree-only count. -/
theorem roughBadPrimeSubsetProductAuxiliaryLoss_nonneg
    (X : ℝ) (M : ℕ) (t : ℝ) (u : Finset ℕ) :
    0 ≤ roughBadPrimeSubsetProductAuxiliaryLoss X M t u := by
  unfold roughBadPrimeSubsetProductAuxiliaryLoss
  exact sub_nonneg.mpr
    (roughBadPrimeSubsetProductCount_le_squarefreeCount X M t u)

/-- With no auxiliary modulus, the auxiliary-loss term vanishes pointwise. -/
theorem roughBadPrimeSubsetProductAuxiliaryLoss_one
    (X : ℝ) (t : ℝ) (u : Finset ℕ) :
    roughBadPrimeSubsetProductAuxiliaryLoss X 1 t u = 0 := by
  unfold roughBadPrimeSubsetProductAuxiliaryLoss
    roughBadPrimeSubsetProductSquarefreeCount
    roughBadPrimeSubsetProductCount
  simp [auxiliaryModulus_one]

/-- Finite union bound for the loss caused by imposing auxiliary coprimality
on one product-modulus subset term.  Any integer lost from the squarefree-only
term is divisible by some prime factor of the normalized auxiliary modulus. -/
theorem roughBadPrimeSubsetProductAuxiliaryLoss_le_auxiliaryModulusPrimeMultiplesLoss
    (X : ℝ) (M : ℕ) (t : ℝ) (u : Finset ℕ) :
    roughBadPrimeSubsetProductAuxiliaryLoss X M t u ≤
      auxiliaryModulusPrimeMultiplesLoss X M t := by
  classical
  let W : Finset ℕ := natWindow t (2 * t)
  let aux : Finset ℕ := (auxiliaryModulus M).primeFactors
  let A : Finset ℕ :=
    W.filter (fun n : ℕ => Squarefree n ∧ badPrimeSubsetModulus u ∣ n)
  let B : Finset ℕ :=
    W.filter (fun n : ℕ => Squarefree n ∧
      Nat.Coprime n (auxiliaryModulus M) ∧ badPrimeSubsetModulus u ∣ n)
  let U : Finset ℕ := aux.biUnion (fun p : ℕ =>
    W.filter (fun n : ℕ => p ∣ n))
  have hsub : A ⊆ B ∪ U := by
    intro n hn
    have hn' :
        n ∈ W ∧ Squarefree n ∧ badPrimeSubsetModulus u ∣ n := by
      simpa [A] using (Finset.mem_filter.mp hn)
    by_cases haux : Nat.Coprime n (auxiliaryModulus M)
    · rw [Finset.mem_union]
      left
      change n ∈ W.filter (fun n : ℕ => Squarefree n ∧
        Nat.Coprime n (auxiliaryModulus M) ∧ badPrimeSubsetModulus u ∣ n)
      rw [Finset.mem_filter]
      exact ⟨hn'.1, hn'.2.1, haux, hn'.2.2⟩
    · rw [Finset.mem_union]
      right
      rcases Nat.Prime.not_coprime_iff_dvd.mp haux with
        ⟨p, hpPrime, hpn, hpAux⟩
      have hp_aux : p ∈ aux := by
        change p ∈ (auxiliaryModulus M).primeFactors
        exact (Nat.mem_primeFactors).mpr
          ⟨hpPrime, hpAux, Nat.ne_of_gt (auxiliaryModulus_pos M)⟩
      change n ∈ aux.biUnion (fun p : ℕ => W.filter (fun n : ℕ => p ∣ n))
      rw [Finset.mem_biUnion]
      refine ⟨p, hp_aux, ?_⟩
      rw [Finset.mem_filter]
      exact ⟨hn'.1, hpn⟩
  have hcard_U :
      U.card ≤ ∑ p ∈ aux, (W.filter (fun n : ℕ => p ∣ n)).card := by
    simpa [U] using
      (Finset.card_biUnion_le
        (s := aux) (t := fun p : ℕ => W.filter (fun n : ℕ => p ∣ n)))
  have hcard_nat :
      A.card ≤ B.card +
        ∑ p ∈ aux, (W.filter (fun n : ℕ => p ∣ n)).card := by
    calc
      A.card ≤ (B ∪ U).card := Finset.card_le_card hsub
      _ ≤ B.card + U.card := Finset.card_union_le B U
      _ ≤ B.card + ∑ p ∈ aux,
            (W.filter (fun n : ℕ => p ∣ n)).card :=
          Nat.add_le_add_left hcard_U B.card
  have hcard_real :
      (A.card : ℝ) ≤ (B.card : ℝ) +
        ∑ p ∈ aux, ((W.filter (fun n : ℕ => p ∣ n)).card : ℝ) := by
    exact_mod_cast hcard_nat
  have hloss :
      (A.card : ℝ) - (B.card : ℝ) ≤
        ∑ p ∈ aux, ((W.filter (fun n : ℕ => p ∣ n)).card : ℝ) := by
    linarith
  simpa [roughBadPrimeSubsetProductAuxiliaryLoss,
    roughBadPrimeSubsetProductSquarefreeCount,
    roughBadPrimeSubsetProductCount, auxiliaryModulusPrimeMultiplesLoss,
    auxiliaryTailPrimeMultiplesCount, W, aux, A, B] using hloss

/-- The product-modulus filter loss splits exactly into the loss from
squarefreeness plus the subsequent loss from auxiliary coprimality. -/
theorem roughBadPrimeSubsetProductFilterLoss_eq_squarefreeLoss_add_auxiliaryLoss
    (X : ℝ) (M : ℕ) (t : ℝ) (u : Finset ℕ) :
    roughBadPrimeSubsetProductFilterLoss X M t u =
      roughBadPrimeSubsetProductSquarefreeLoss X t u +
        roughBadPrimeSubsetProductAuxiliaryLoss X M t u := by
  unfold roughBadPrimeSubsetProductFilterLoss
    roughBadPrimeSubsetProductSquarefreeLoss
    roughBadPrimeSubsetProductAuxiliaryLoss
  ring

/-- With no auxiliary modulus, one subset's filter loss is exactly its
squarefree loss. -/
theorem roughBadPrimeSubsetProductFilterLoss_one_eq_squarefreeLoss
    (X : ℝ) (t : ℝ) (u : Finset ℕ) :
    roughBadPrimeSubsetProductFilterLoss X 1 t u =
      roughBadPrimeSubsetProductSquarefreeLoss X t u := by
  rw [roughBadPrimeSubsetProductFilterLoss_eq_squarefreeLoss_add_auxiliaryLoss,
    roughBadPrimeSubsetProductAuxiliaryLoss_one]
  ring

/-- One subset-local error splits exactly into a multiples-only lattice
discrepancy minus the loss from squarefree and auxiliary-coprimality filters. -/
theorem roughBadPrimeSubsetProductLocalError_eq_multiplesLocalError_sub_filterLoss
    (X : ℝ) (M : ℕ) (t : ℝ) (u : Finset ℕ) :
    roughBadPrimeSubsetProductLocalError X M t u =
      roughBadPrimeSubsetProductMultiplesLocalError X t u -
        roughBadPrimeSubsetProductFilterLoss X M t u := by
  unfold roughBadPrimeSubsetProductLocalError
    roughBadPrimeSubsetProductMultiplesLocalError
    roughBadPrimeSubsetProductFilterLoss
  ring

/-- Pointwise absolute local-error bound after separating lattice discrepancy
from arithmetic filter loss. -/
theorem abs_roughBadPrimeSubsetProductLocalError_le_multiplesLocalError_add_filterLoss
    (X : ℝ) (M : ℕ) (t : ℝ) (u : Finset ℕ) :
    |roughBadPrimeSubsetProductLocalError X M t u| ≤
      |roughBadPrimeSubsetProductMultiplesLocalError X t u| +
        roughBadPrimeSubsetProductFilterLoss X M t u := by
  have hfilter_nonneg :
      0 ≤ roughBadPrimeSubsetProductFilterLoss X M t u :=
    roughBadPrimeSubsetProductFilterLoss_nonneg X M t u
  rw [roughBadPrimeSubsetProductLocalError_eq_multiplesLocalError_sub_filterLoss]
  calc
    |roughBadPrimeSubsetProductMultiplesLocalError X t u -
        roughBadPrimeSubsetProductFilterLoss X M t u|
        = |roughBadPrimeSubsetProductMultiplesLocalError X t u +
            -(roughBadPrimeSubsetProductFilterLoss X M t u)| := by
          rw [sub_eq_add_neg]
    _ ≤ |roughBadPrimeSubsetProductMultiplesLocalError X t u| +
          |-(roughBadPrimeSubsetProductFilterLoss X M t u)| :=
          abs_add _ _
    _ = |roughBadPrimeSubsetProductMultiplesLocalError X t u| +
          roughBadPrimeSubsetProductFilterLoss X M t u := by
          rw [abs_neg, abs_of_nonneg hfilter_nonneg]

/-- Absolute local-error envelope for the full product-modulus expansion. -/
noncomputable def roughDyadicBadPrimeProductLocalErrorEnvelopeSum
    (X : ℝ) (M : ℕ) (t : ℝ) : ℝ :=
  ∑ u ∈ (roughModulus X).primeFactors.powerset,
    |roughBadPrimeSubsetProductLocalError X M t u|

/-- Sum of the multiples-only lattice discrepancies over all subset terms. -/
noncomputable def roughDyadicBadPrimeProductMultiplesLocalErrorEnvelopeSum
    (X : ℝ) (t : ℝ) : ℝ :=
  ∑ u ∈ (roughModulus X).primeFactors.powerset,
    |roughBadPrimeSubsetProductMultiplesLocalError X t u|

/-- Sum of squarefree/auxiliary-coprimality filter losses over all subset
terms. -/
noncomputable def roughDyadicBadPrimeProductFilterLossEnvelopeSum
    (X : ℝ) (M : ℕ) (t : ℝ) : ℝ :=
  ∑ u ∈ (roughModulus X).primeFactors.powerset,
    roughBadPrimeSubsetProductFilterLoss X M t u

/-- Sum of squarefree losses over all subset terms. -/
noncomputable def roughDyadicBadPrimeProductSquarefreeLossEnvelopeSum
    (X : ℝ) (t : ℝ) : ℝ :=
  ∑ u ∈ (roughModulus X).primeFactors.powerset,
    roughBadPrimeSubsetProductSquarefreeLoss X t u

/-- Signed multiples-discrepancy component of the product-modulus error.  This
keeps the inclusion-exclusion signs instead of taking the absolute envelope. -/
noncomputable def roughDyadicBadPrimeProductMultiplesSignedErrorSum
    (X : ℝ) (t : ℝ) : ℝ :=
  ∑ u ∈ (roughModulus X).primeFactors.powerset,
    (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
      roughBadPrimeSubsetProductMultiplesLocalError X t u

/-- The signed multiples discrepancy is exactly the explicit alternating
floor-error sum.  Thus the remaining analytic content in the signed-multiples
route is cancellation in a finite floor-error expression. -/
theorem roughDyadicBadPrimeProductMultiplesSignedErrorSum_eq_floorErrorSum
    (X : ℝ) {t : ℝ} (ht : 0 ≤ t) :
    roughDyadicBadPrimeProductMultiplesSignedErrorSum X t =
      roughDyadicBadPrimeProductMultiplesFloorErrorSum X t := by
  classical
  unfold roughDyadicBadPrimeProductMultiplesSignedErrorSum
    roughDyadicBadPrimeProductMultiplesFloorErrorSum
    roughBadPrimeSubsetProductMultiplesLocalError
  apply Finset.sum_congr rfl
  intro u hu
  rw [roughBadPrimeSubsetProductMultiplesCount_eq_floorCount X ht
    (badPrimeSubsetModulus_pos_of_mem_rough_powerset X hu)]

/-- Signed squarefree-loss component of the product-modulus error.  This is the
piece where cancellation is needed; the absolute squarefree envelope has an
empty-subset obstruction. -/
noncomputable def roughDyadicBadPrimeProductSquarefreeSignedLossSum
    (X : ℝ) (t : ℝ) : ℝ :=
  ∑ u ∈ (roughModulus X).primeFactors.powerset,
    (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
      roughBadPrimeSubsetProductSquarefreeLoss X t u

/-- Alternating multiples-only product-modulus count. -/
noncomputable def roughDyadicBadPrimeProductMultiplesCountSum
    (X : ℝ) (t : ℝ) : ℝ :=
  ∑ u ∈ (roughModulus X).primeFactors.powerset,
    (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
      roughBadPrimeSubsetProductMultiplesCount X t u

/-- Alternating squarefree-only product-modulus count. -/
noncomputable def roughDyadicBadPrimeProductSquarefreeCountSum
    (X : ℝ) (t : ℝ) : ℝ :=
  ∑ u ∈ (roughModulus X).primeFactors.powerset,
    (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
      roughBadPrimeSubsetProductSquarefreeCount X t u

/-- Dyadic-window count after imposing only rough-modulus coprimality. -/
noncomputable def roughDyadicRoughWindowCount (X : ℝ) (t : ℝ) : ℝ :=
  (((natWindow t (2 * t)).filter
    (fun n : ℕ => Nat.Coprime n (roughModulus X))).card : ℝ)

/-- Generic dyadic-window count after imposing coprimality to `P(z)`, before
specializing `z = (log X)^4`. -/
noncomputable def primeProductBelowRoughWindowCount (z : ℝ) (t : ℝ) : ℝ :=
  (((natWindow t (2 * t)).filter
    (fun n : ℕ => Nat.Coprime n (primeProductBelow z))).card : ℝ)

/-- Initial-segment count after imposing only rough-modulus coprimality. -/
noncomputable def roughInitialCoprimeCount (X : ℝ) (N : ℕ) : ℝ :=
  (((Finset.Icc (1 : ℕ) N).filter
    (fun n : ℕ => Nat.Coprime n (roughModulus X))).card : ℝ)

/-- Every complete residue block modulo the rough modulus contains exactly
`φ(P(z))` integers coprime to that modulus. -/
theorem roughCompleteResidueBlockCoprimeCount_eq_totient
    (X : ℝ) (n : ℕ) :
    (((Finset.Ico n (n + roughModulus X)).filter
      (fun m : ℕ => Nat.Coprime m (roughModulus X))).card : ℝ) =
      (Nat.totient (roughModulus X) : ℝ) := by
  have h := Nat.filter_coprime_Ico_eq_totient (roughModulus X) n
  have hset :
      (Finset.Ico n (n + roughModulus X)).filter
        (fun m : ℕ => Nat.Coprime m (roughModulus X)) =
      (Finset.Ico n (n + roughModulus X)).filter
        (fun m : ℕ => Nat.Coprime (roughModulus X) m) := by
    ext m
    simp [Nat.coprime_comm]
  rw [hset]
  exact_mod_cast h

/-- A complete rough-modulus block has exactly its Euler-product main mass. -/
theorem roughCompleteResidueBlockCoprimeCount_eq_eulerMain
    (X : ℝ) (n : ℕ) :
    (((Finset.Ico n (n + roughModulus X)).filter
      (fun m : ℕ => Nat.Coprime m (roughModulus X))).card : ℝ) =
      (roughModulus X : ℝ) * roughDyadicBadPrimeMainEulerProduct X := by
  rw [roughCompleteResidueBlockCoprimeCount_eq_totient,
    roughDyadicBadPrimeMainEulerProduct_eq_totient_ratio]
  field_simp [show (roughModulus X : ℝ) ≠ 0 by
    exact_mod_cast (roughModulus_pos X).ne']

/-- Any integral number of complete rough-modulus blocks contains exactly that
many copies of the coprime residue system. -/
theorem roughCompleteResidueBlocksCoprimeCount_eq_mul_totient
    (X : ℝ) (k q : ℕ) :
    (((Finset.Ico k (k + q * roughModulus X)).filter
      (fun m : ℕ => Nat.Coprime m (roughModulus X))).card : ℝ) =
      (q : ℝ) * (Nat.totient (roughModulus X) : ℝ) := by
  induction q with
  | zero =>
      simp
  | succ q ih =>
      let P : ℕ := roughModulus X
      have hsplit :
          Finset.Ico k (k + (q + 1) * P) =
            Finset.Ico k (k + q * P) ∪
              Finset.Ico (k + q * P) (k + q * P + P) := by
        rw [Finset.Ico_union_Ico_eq_Ico]
        · ring_nf
        · exact Nat.le_add_right _ _
        · exact Nat.le_add_right _ _
      have hdisj :
          Disjoint (Finset.Ico k (k + q * P))
            (Finset.Ico (k + q * P) (k + q * P + P)) :=
        Finset.Ico_disjoint_Ico_consecutive k (k + q * P) (k + q * P + P)
      have hfilter_disj : Disjoint
          ((Finset.Ico k (k + q * P)).filter
            (fun m : ℕ => Nat.Coprime m P))
          ((Finset.Ico (k + q * P) (k + q * P + P)).filter
            (fun m : ℕ => Nat.Coprime m P)) :=
        hdisj.mono (Finset.filter_subset _ _) (Finset.filter_subset _ _)
      have hcard_union :
          (((Finset.Ico k (k + (q + 1) * P)).filter
              (fun m : ℕ => Nat.Coprime m P)).card : ℝ) =
            (((Finset.Ico k (k + q * P)).filter
              (fun m : ℕ => Nat.Coprime m P)).card : ℝ) +
            (((Finset.Ico (k + q * P) (k + q * P + P)).filter
              (fun m : ℕ => Nat.Coprime m P)).card : ℝ) := by
        rw [hsplit, Finset.filter_union,
          Finset.card_union_of_disjoint hfilter_disj]
        norm_num
      have hlast :
          (((Finset.Ico (k + q * P) (k + q * P + P)).filter
              (fun m : ℕ => Nat.Coprime m P)).card : ℝ) =
            (Nat.totient P : ℝ) := by
        dsimp [P]
        exact roughCompleteResidueBlockCoprimeCount_eq_totient X
          (k + q * roughModulus X)
      dsimp [P] at hcard_union ih hlast ⊢
      rw [hcard_union, ih, hlast]
      rw [Nat.cast_add, Nat.cast_one]
      ring

/-- Any natural interval contains at most one incomplete rough-modulus block
more than its complete-block average. -/
theorem roughResidueIntervalCoprimeCount_le_totient_mul_div_add_one
    (X : ℝ) (k n : ℕ) :
    (((Finset.Ico k (k + n)).filter
      (fun m : ℕ => Nat.Coprime m (roughModulus X))).card : ℝ) ≤
      (Nat.totient (roughModulus X) : ℝ) *
        (((n / roughModulus X) + 1 : ℕ) : ℝ) := by
  have hset :
      (Finset.Ico k (k + n)).filter
        (fun m : ℕ => Nat.Coprime m (roughModulus X)) =
      (Finset.Ico k (k + n)).filter
        (fun m : ℕ => Nat.Coprime (roughModulus X) m) := by
    ext m
    simp [Nat.coprime_comm]
  rw [hset]
  exact_mod_cast Nat.Ico_filter_coprime_le k n (roughModulus_pos X)

/-- Any natural interval contains at least its complete rough-modulus blocks. -/
theorem roughResidueIntervalCoprimeCount_ge_totient_mul_div
    (X : ℝ) (k n : ℕ) :
    (Nat.totient (roughModulus X) : ℝ) *
        ((n / roughModulus X : ℕ) : ℝ) ≤
      (((Finset.Ico k (k + n)).filter
        (fun m : ℕ => Nat.Coprime m (roughModulus X))).card : ℝ) := by
  let P : ℕ := roughModulus X
  let q : ℕ := n / P
  have hqP_le : q * P ≤ n := by
    dsimp [q, P]
    exact Nat.div_mul_le_self n (roughModulus X)
  have hsubset :
      (Finset.Ico k (k + q * P)).filter
          (fun m : ℕ => Nat.Coprime m P) ⊆
        (Finset.Ico k (k + n)).filter
          (fun m : ℕ => Nat.Coprime m P) := by
    intro m hm
    rcases Finset.mem_filter.mp hm with ⟨hmIco, hcop⟩
    rcases Finset.mem_Ico.mp hmIco with ⟨hmlo, hmhi⟩
    exact Finset.mem_filter.mpr
      ⟨Finset.mem_Ico.mpr ⟨hmlo, lt_of_lt_of_le hmhi (add_le_add_left hqP_le k)⟩,
        hcop⟩
  have hcard :=
    Finset.card_le_card hsubset
  have hblocks :
      (((Finset.Ico k (k + q * P)).filter
        (fun m : ℕ => Nat.Coprime m P)).card : ℝ) =
        (q : ℝ) * (Nat.totient P : ℝ) := by
    dsimp [P, q]
    exact roughCompleteResidueBlocksCoprimeCount_eq_mul_totient X k
      (n / roughModulus X)
  dsimp [P, q] at hcard hblocks ⊢
  calc
    (Nat.totient (roughModulus X) : ℝ) *
        ((n / roughModulus X : ℕ) : ℝ)
        = ((n / roughModulus X : ℕ) : ℝ) *
            (Nat.totient (roughModulus X) : ℝ) := by ring
    _ = (((Finset.Ico k (k + (n / roughModulus X) * roughModulus X)).filter
          (fun m : ℕ => Nat.Coprime m (roughModulus X))).card : ℝ) :=
          hblocks.symm
    _ ≤ (((Finset.Ico k (k + n)).filter
          (fun m : ℕ => Nat.Coprime m (roughModulus X))).card : ℝ) := by
          exact_mod_cast hcard

/-- Real form of `n/P ≤ ⌊n/P⌋ + 1` for natural division by a positive modulus. -/
theorem natCast_div_le_natDiv_add_one_real {n P : ℕ} (hP : 0 < P) :
    (n : ℝ) / (P : ℝ) ≤ ((n / P : ℕ) : ℝ) + 1 := by
  have hnat_lt : n < P * (n / P + 1) := Nat.lt_mul_div_succ n hP
  have hnat : n ≤ P * (n / P + 1) := le_of_lt hnat_lt
  have hreal : (n : ℝ) ≤ (P : ℝ) * (((n / P : ℕ) : ℝ) + 1) := by
    exact_mod_cast hnat
  have hPpos : (0 : ℝ) < (P : ℝ) := by exact_mod_cast hP
  calc
    (n : ℝ) / (P : ℝ)
        ≤ ((P : ℝ) * (((n / P : ℕ) : ℝ) + 1)) / (P : ℝ) := by
          exact div_le_div_of_nonneg_right hreal hPpos.le
    _ = ((n / P : ℕ) : ℝ) + 1 := by
          field_simp [ne_of_gt hPpos]

/-- One-sided finite-remainder form of the periodic rough-coprime count:
on any natural interval, the count exceeds its Euler-product main term by at
most one complete block. -/
theorem roughResidueIntervalCoprimeCount_sub_eulerMain_le_totient
    (X : ℝ) (k n : ℕ) :
    (((Finset.Ico k (k + n)).filter
      (fun m : ℕ => Nat.Coprime m (roughModulus X))).card : ℝ) -
        (n : ℝ) * roughDyadicBadPrimeMainEulerProduct X ≤
      (Nat.totient (roughModulus X) : ℝ) := by
  let P : ℕ := roughModulus X
  let phiR : ℝ := Nat.totient P
  have hcount :
      (((Finset.Ico k (k + n)).filter
        (fun m : ℕ => Nat.Coprime m P)).card : ℝ) ≤
        phiR * (((n / P) + 1 : ℕ) : ℝ) := by
    dsimp [phiR, P]
    exact roughResidueIntervalCoprimeCount_le_totient_mul_div_add_one X k n
  have hdiv : (((n / P : ℕ) : ℝ)) ≤ (n : ℝ) / (P : ℝ) :=
    Nat.cast_div_le
  have hdiv_add :
      (((n / P) + 1 : ℕ) : ℝ) ≤ (n : ℝ) / (P : ℝ) + 1 := by
    rw [Nat.cast_add, Nat.cast_one]
    exact add_le_add_right hdiv 1
  have hcount' :
      (((Finset.Ico k (k + n)).filter
        (fun m : ℕ => Nat.Coprime m P)).card : ℝ) ≤
        phiR * ((n : ℝ) / (P : ℝ) + 1) := by
    refine hcount.trans ?_
    exact mul_le_mul_of_nonneg_left hdiv_add (by
      dsimp [phiR]
      exact Nat.cast_nonneg _)
  have hPne : (P : ℝ) ≠ 0 := by
    dsimp [P]
    exact_mod_cast (roughModulus_pos X).ne'
  have heuler : roughDyadicBadPrimeMainEulerProduct X = phiR / (P : ℝ) := by
    dsimp [phiR, P]
    exact roughDyadicBadPrimeMainEulerProduct_eq_totient_ratio X
  calc
    (((Finset.Ico k (k + n)).filter
      (fun m : ℕ => Nat.Coprime m P)).card : ℝ) -
        (n : ℝ) * roughDyadicBadPrimeMainEulerProduct X
        ≤ phiR * ((n : ℝ) / (P : ℝ) + 1) -
            (n : ℝ) * roughDyadicBadPrimeMainEulerProduct X := by
          exact sub_le_sub_right hcount' _
    _ = phiR := by
          rw [heuler]
          field_simp [hPne]
          ring

/-- Lower-side finite-remainder form of the periodic rough-coprime count. -/
theorem neg_totient_le_roughResidueIntervalCoprimeCount_sub_eulerMain
    (X : ℝ) (k n : ℕ) :
    - (Nat.totient (roughModulus X) : ℝ) ≤
      (((Finset.Ico k (k + n)).filter
        (fun m : ℕ => Nat.Coprime m (roughModulus X))).card : ℝ) -
          (n : ℝ) * roughDyadicBadPrimeMainEulerProduct X := by
  let P : ℕ := roughModulus X
  let phiR : ℝ := Nat.totient P
  have hcount_lower :
      phiR * ((n / P : ℕ) : ℝ) ≤
        (((Finset.Ico k (k + n)).filter
          (fun m : ℕ => Nat.Coprime m P)).card : ℝ) := by
    dsimp [phiR, P]
    exact roughResidueIntervalCoprimeCount_ge_totient_mul_div X k n
  have hdiv :
      (n : ℝ) / (P : ℝ) ≤ ((n / P : ℕ) : ℝ) + 1 :=
    natCast_div_le_natDiv_add_one_real (by
      dsimp [P]
      exact roughModulus_pos X)
  have hphi_nonneg : 0 ≤ phiR := by
    dsimp [phiR]
    exact Nat.cast_nonneg _
  have hPne : (P : ℝ) ≠ 0 := by
    dsimp [P]
    exact_mod_cast (roughModulus_pos X).ne'
  have heuler : roughDyadicBadPrimeMainEulerProduct X = phiR / (P : ℝ) := by
    dsimp [phiR, P]
    exact roughDyadicBadPrimeMainEulerProduct_eq_totient_ratio X
  have hmain_le :
      (n : ℝ) * roughDyadicBadPrimeMainEulerProduct X - phiR ≤
        phiR * ((n / P : ℕ) : ℝ) := by
    have hmain :
        (n : ℝ) * roughDyadicBadPrimeMainEulerProduct X ≤
          phiR * (((n / P : ℕ) : ℝ) + 1) := by
      calc
        (n : ℝ) * roughDyadicBadPrimeMainEulerProduct X
            = phiR * ((n : ℝ) / (P : ℝ)) := by
              rw [heuler]
              field_simp [hPne]
              ring
        _ ≤ phiR * (((n / P : ℕ) : ℝ) + 1) :=
              mul_le_mul_of_nonneg_left hdiv hphi_nonneg
    calc
      (n : ℝ) * roughDyadicBadPrimeMainEulerProduct X - phiR
          ≤ phiR * (((n / P : ℕ) : ℝ) + 1) - phiR :=
            sub_le_sub_right hmain phiR
      _ = phiR * ((n / P : ℕ) : ℝ) := by ring
  dsimp [P, phiR] at hcount_lower hmain_le ⊢
  linarith

/-- Two-sided finite-periodic discrepancy bound for rough-coprime counts on
natural intervals. -/
theorem abs_roughResidueIntervalCoprimeCount_sub_eulerMain_le_totient
    (X : ℝ) (k n : ℕ) :
    |(((Finset.Ico k (k + n)).filter
      (fun m : ℕ => Nat.Coprime m (roughModulus X))).card : ℝ) -
        (n : ℝ) * roughDyadicBadPrimeMainEulerProduct X| ≤
      (Nat.totient (roughModulus X) : ℝ) := by
  exact abs_le.mpr
    ⟨neg_totient_le_roughResidueIntervalCoprimeCount_sub_eulerMain X k n,
      roughResidueIntervalCoprimeCount_sub_eulerMain_le_totient X k n⟩

/-- The dyadic natural window `t < n ≤ 2t` is the half-open interval
`⌊t⌋₊ + 1 ≤ n < ⌊2t⌋₊ + 1` when `t` is nonnegative. -/
theorem roughDyadicRoughWindowCount_eq_Ico_floor
    (X : ℝ) {t : ℝ} (ht : 0 ≤ t) :
    roughDyadicRoughWindowCount X t =
      (((Finset.Ico (⌊t⌋₊ + 1) (⌊2 * t⌋₊ + 1)).filter
        (fun n : ℕ => Nat.Coprime n (roughModulus X))).card : ℝ) := by
  let L : ℕ := ⌊t⌋₊
  let U : ℕ := ⌊2 * t⌋₊
  have hset :
      (natWindow t (2 * t)).filter
        (fun n : ℕ => Nat.Coprime n (roughModulus X)) =
      (Finset.Ico (L + 1) (U + 1)).filter
        (fun n : ℕ => Nat.Coprime n (roughModulus X)) := by
    ext n
    constructor
    · intro hn
      rcases Finset.mem_filter.mp hn with ⟨hnw, hcop⟩
      unfold natWindow at hnw
      rcases Finset.mem_filter.mp hnw with ⟨hnIcc, htlt⟩
      rcases Finset.mem_Icc.mp hnIcc with ⟨_hn1, hnU⟩
      have hLn : L < n := by
        dsimp [L]
        exact (Nat.floor_lt ht).mpr htlt
      exact Finset.mem_filter.mpr
        ⟨Finset.mem_Ico.mpr
          ⟨Nat.succ_le_iff.mpr hLn,
            Nat.lt_succ_iff.mpr (by simpa [U] using hnU)⟩,
          hcop⟩
    · intro hn
      rcases Finset.mem_filter.mp hn with ⟨hnIco, hcop⟩
      rcases Finset.mem_Ico.mp hnIco with ⟨hL1, hnUsucc⟩
      have hLn : L < n := Nat.lt_of_succ_le hL1
      have htlt : t < (n : ℝ) := by
        dsimp [L] at hLn
        exact (Nat.floor_lt ht).mp hLn
      have hnU : n ≤ U := Nat.lt_succ_iff.mp hnUsucc
      have hn1 : 1 ≤ n := by omega
      exact Finset.mem_filter.mpr
        ⟨by
          unfold natWindow
          exact Finset.mem_filter.mpr
            ⟨Finset.mem_Icc.mpr ⟨hn1, by simpa [U] using hnU⟩, htlt⟩,
          hcop⟩
  unfold roughDyadicRoughWindowCount
  rw [hset]

/-- One-sided periodic-remainder bound for the actual dyadic rough-window
carrier, normalized to the integer window length. -/
theorem roughDyadicRoughWindowCount_sub_floorLength_eulerMain_le_totient
    (X : ℝ) {t : ℝ} (ht : 0 ≤ t) :
    roughDyadicRoughWindowCount X t -
        ((⌊2 * t⌋₊ - ⌊t⌋₊ : ℕ) : ℝ) *
          roughDyadicBadPrimeMainEulerProduct X ≤
      (Nat.totient (roughModulus X) : ℝ) := by
  let L : ℕ := ⌊t⌋₊
  let U : ℕ := ⌊2 * t⌋₊
  have hLU : L ≤ U := by
    dsimp [L, U]
    exact Nat.floor_mono (by linarith : t ≤ 2 * t)
  have hright : U + 1 = (L + 1) + (U - L) := by
    omega
  have hIco :
      Finset.Ico (L + 1) (U + 1) =
        Finset.Ico (L + 1) ((L + 1) + (U - L)) := by
    rw [hright]
  rw [roughDyadicRoughWindowCount_eq_Ico_floor X ht]
  change
    (((Finset.Ico (L + 1) (U + 1)).filter
      (fun n : ℕ => Nat.Coprime n (roughModulus X))).card : ℝ) -
        ((U - L : ℕ) : ℝ) *
          roughDyadicBadPrimeMainEulerProduct X ≤
      (Nat.totient (roughModulus X) : ℝ)
  rw [hIco]
  exact roughResidueIntervalCoprimeCount_sub_eulerMain_le_totient X (L + 1) (U - L)

/-- Two-sided finite-periodic discrepancy bound for the actual dyadic
rough-window carrier, normalized to the integer window length. -/
theorem abs_roughDyadicRoughWindowCount_sub_floorLength_eulerMain_le_totient
    (X : ℝ) {t : ℝ} (ht : 0 ≤ t) :
    |roughDyadicRoughWindowCount X t -
        ((⌊2 * t⌋₊ - ⌊t⌋₊ : ℕ) : ℝ) *
          roughDyadicBadPrimeMainEulerProduct X| ≤
      (Nat.totient (roughModulus X) : ℝ) := by
  let L : ℕ := ⌊t⌋₊
  let U : ℕ := ⌊2 * t⌋₊
  have hLU : L ≤ U := by
    dsimp [L, U]
    exact Nat.floor_mono (by linarith : t ≤ 2 * t)
  have hright : U + 1 = (L + 1) + (U - L) := by
    omega
  have hIco :
      Finset.Ico (L + 1) (U + 1) =
        Finset.Ico (L + 1) ((L + 1) + (U - L)) := by
    rw [hright]
  rw [roughDyadicRoughWindowCount_eq_Ico_floor X ht]
  change
    |(((Finset.Ico (L + 1) (U + 1)).filter
      (fun n : ℕ => Nat.Coprime n (roughModulus X))).card : ℝ) -
        ((U - L : ℕ) : ℝ) *
          roughDyadicBadPrimeMainEulerProduct X| ≤
      (Nat.totient (roughModulus X) : ℝ)
  rw [hIco]
  exact abs_roughResidueIntervalCoprimeCount_sub_eulerMain_le_totient
    X (L + 1) (U - L)

/-- The integer length of the dyadic natural window differs from its real
length `t` by at most one. -/
theorem abs_floor_two_mul_sub_floor_sub_self_le_one {t : ℝ} (ht : 0 ≤ t) :
    |(((⌊2 * t⌋₊ - ⌊t⌋₊) : ℕ) : ℝ) - t| ≤ 1 := by
  let L : ℕ := ⌊t⌋₊
  let U : ℕ := ⌊2 * t⌋₊
  have htwo : 0 ≤ 2 * t := mul_nonneg (by norm_num) ht
  have hLU : L ≤ U := by
    dsimp [L, U]
    exact Nat.floor_mono (by linarith : t ≤ 2 * t)
  have hLle : (L : ℝ) ≤ t := by
    dsimp [L]
    exact Nat.floor_le ht
  have hUle : (U : ℝ) ≤ 2 * t := by
    dsimp [U]
    exact Nat.floor_le htwo
  have ht_lt_L1 : t < (L : ℝ) + 1 := by
    dsimp [L]
    simpa [Nat.cast_add, Nat.cast_one] using
      (Nat.floor_lt ht).mp (Nat.lt_succ_self ⌊t⌋₊)
  have h2t_lt_U1 : 2 * t < (U : ℝ) + 1 := by
    dsimp [U]
    simpa [Nat.cast_add, Nat.cast_one] using
      (Nat.floor_lt htwo).mp (Nat.lt_succ_self ⌊2 * t⌋₊)
  have hupper : (((U - L : ℕ) : ℝ) - t) ≤ 1 := by
    rw [Nat.cast_sub hLU]
    linarith
  have hlower : -1 ≤ (((U - L : ℕ) : ℝ) - t) := by
    rw [Nat.cast_sub hLU]
    linarith
  dsimp [L, U] at hupper hlower ⊢
  exact abs_le.mpr ⟨hlower, hupper⟩

/-- Unconditional finite-periodic discrepancy bound for the live real-valued
dyadic rough-window main term.  This improves the crude `3t` bound when the
window is much longer than one rough-modulus period, but it is still not the
positive-range linear-sieve saving. -/
theorem abs_roughDyadicRoughWindowCount_sub_real_eulerMain_le_totient_add_one
    (X : ℝ) {t : ℝ} (ht : 0 ≤ t) :
    |roughDyadicRoughWindowCount X t -
        t * roughDyadicBadPrimeMainEulerProduct X| ≤
      (Nat.totient (roughModulus X) : ℝ) + 1 := by
  let d : ℝ := ((⌊2 * t⌋₊ - ⌊t⌋₊ : ℕ) : ℝ)
  have hperiodic :
      |roughDyadicRoughWindowCount X t -
          d * roughDyadicBadPrimeMainEulerProduct X| ≤
        (Nat.totient (roughModulus X) : ℝ) := by
    dsimp [d]
    exact abs_roughDyadicRoughWindowCount_sub_floorLength_eulerMain_le_totient
      X ht
  have hfloor : |d - t| ≤ 1 := by
    dsimp [d]
    exact abs_floor_two_mul_sub_floor_sub_self_le_one ht
  have hprod_abs : |roughDyadicBadPrimeMainEulerProduct X| ≤ 1 := by
    rw [abs_of_nonneg (roughDyadicBadPrimeMainEulerProduct_nonneg X)]
    exact roughDyadicBadPrimeMainEulerProduct_le_one X
  have hendpoint :
      |d * roughDyadicBadPrimeMainEulerProduct X -
          t * roughDyadicBadPrimeMainEulerProduct X| ≤ 1 := by
    calc
      |d * roughDyadicBadPrimeMainEulerProduct X -
          t * roughDyadicBadPrimeMainEulerProduct X|
          = |(d - t) * roughDyadicBadPrimeMainEulerProduct X| := by ring_nf
      _ = |d - t| * |roughDyadicBadPrimeMainEulerProduct X| := abs_mul _ _
      _ ≤ 1 * 1 := mul_le_mul hfloor hprod_abs (abs_nonneg _) (by norm_num)
      _ = 1 := by norm_num
  calc
    |roughDyadicRoughWindowCount X t -
        t * roughDyadicBadPrimeMainEulerProduct X|
        = |(roughDyadicRoughWindowCount X t -
              d * roughDyadicBadPrimeMainEulerProduct X) +
            (d * roughDyadicBadPrimeMainEulerProduct X -
              t * roughDyadicBadPrimeMainEulerProduct X)| := by ring_nf
    _ ≤ |roughDyadicRoughWindowCount X t -
            d * roughDyadicBadPrimeMainEulerProduct X| +
          |d * roughDyadicBadPrimeMainEulerProduct X -
              t * roughDyadicBadPrimeMainEulerProduct X| := abs_add _ _
    _ ≤ (Nat.totient (roughModulus X) : ℝ) + 1 :=
          add_le_add hperiodic hendpoint

/-- Initial-segment multiples count for one product-modulus term. -/
noncomputable def roughBadPrimeSubsetInitialMultiplesCount
    (N : ℕ) (u : Finset ℕ) : ℝ :=
  (((Finset.Icc (1 : ℕ) N).filter
    (fun n : ℕ => badPrimeSubsetModulus u ∣ n)).card : ℝ)

/-- The initial-segment multiples count for one product modulus is the natural
quotient `N / q`. -/
theorem roughBadPrimeSubsetInitialMultiplesCount_eq_nat_div
    (N : ℕ) {u : Finset ℕ}
    (hupos : 0 < badPrimeSubsetModulus u) :
    roughBadPrimeSubsetInitialMultiplesCount N u =
      ((N / badPrimeSubsetModulus u : ℕ) : ℝ) := by
  classical
  let q : ℕ := badPrimeSubsetModulus u
  have hqpos : 0 < q := by simpa [q] using hupos
  have hset :
      (Finset.Icc (1 : ℕ) N).filter (fun n : ℕ => q ∣ n) =
        (Finset.Ioc (0 : ℕ) N).filter (fun n : ℕ => n ≡ 0 [MOD q]) := by
    ext n
    constructor
    · intro hn
      rcases Finset.mem_filter.mp hn with ⟨hnIcc, hdvd⟩
      rcases Finset.mem_Icc.mp hnIcc with ⟨hn1, hnN⟩
      exact Finset.mem_filter.mpr
        ⟨Finset.mem_Ioc.mpr ⟨by omega, hnN⟩,
          (Nat.modEq_zero_iff_dvd).mpr hdvd⟩
    · intro hn
      rcases Finset.mem_filter.mp hn with ⟨hnIoc, hmod⟩
      rcases Finset.mem_Ioc.mp hnIoc with ⟨hn0, hnN⟩
      exact Finset.mem_filter.mpr
        ⟨Finset.mem_Icc.mpr ⟨by omega, hnN⟩,
          (Nat.modEq_zero_iff_dvd).mp hmod⟩
  unfold roughBadPrimeSubsetInitialMultiplesCount
  change (((Finset.Icc (1 : ℕ) N).filter (fun n : ℕ => q ∣ n)).card : ℝ) =
    ((N / q : ℕ) : ℝ)
  rw [hset]
  have hcard := Nat.Ioc_filter_modEq_card (0 : ℕ) N hqpos 0
  have hdiv_nonneg : (0 : ℤ) ≤ (N : ℤ) / (q : ℤ) :=
    Int.ediv_nonneg (Int.natCast_nonneg N) (Int.natCast_nonneg q)
  have hcard_int :
      (((Finset.Ioc (0 : ℕ) N).filter
          (fun n : ℕ => n ≡ 0 [MOD q])).card : ℤ) =
        ((N / q : ℕ) : ℤ) := by
    calc
      (((Finset.Ioc (0 : ℕ) N).filter
          (fun n : ℕ => n ≡ 0 [MOD q])).card : ℤ)
          = ((N : ℤ) / (q : ℤ)) ⊔ 0 := by
              simpa [Rat.floor_natCast_div_natCast] using hcard
      _ = (N : ℤ) / (q : ℤ) := max_eq_left hdiv_nonneg
      _ = ((N / q : ℕ) : ℤ) := by
            rw [Int.natCast_div]
  exact_mod_cast hcard_int

/-- Alternating initial-segment product-modulus count. -/
noncomputable def roughDyadicBadPrimeInitialMultiplesCountSum
    (X : ℝ) (N : ℕ) : ℝ :=
  ∑ u ∈ (roughModulus X).primeFactors.powerset,
    (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
      roughBadPrimeSubsetInitialMultiplesCount N u

/-- Initial-segment inclusion-exclusion counts exactly the integers coprime to
the rough modulus. -/
theorem roughDyadicBadPrimeInitialMultiplesCountSum_eq_initialCoprimeCount
    (X : ℝ) (N : ℕ) :
    roughDyadicBadPrimeInitialMultiplesCountSum X N =
      roughInitialCoprimeCount X N := by
  classical
  let W : Finset ℕ := Finset.Icc (1 : ℕ) N
  have hcount :
      ∀ u : Finset ℕ,
        roughBadPrimeSubsetInitialMultiplesCount N u =
          ∑ n ∈ W, if badPrimeSubsetModulus u ∣ n then (1 : ℝ) else 0 := by
    intro u
    unfold roughBadPrimeSubsetInitialMultiplesCount
    dsimp [W]
    rw [Finset.card_eq_sum_ones, ← Finset.sum_filter]
    simp
  unfold roughDyadicBadPrimeInitialMultiplesCountSum roughInitialCoprimeCount
  calc
    ∑ u ∈ (roughModulus X).primeFactors.powerset,
        (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
          roughBadPrimeSubsetInitialMultiplesCount N u
        = ∑ u ∈ (roughModulus X).primeFactors.powerset,
            ∑ n ∈ W,
              if badPrimeSubsetModulus u ∣ n then
                (((-1 : ℤ) ^ u.card : ℤ) : ℝ) else 0 := by
          apply Finset.sum_congr rfl
          intro u _hu
          rw [hcount u, Finset.mul_sum]
          apply Finset.sum_congr rfl
          intro n _hn
          by_cases hdiv : badPrimeSubsetModulus u ∣ n
          · simp [hdiv]
          · simp [hdiv]
    _ = ∑ n ∈ W,
          ∑ u ∈ (roughModulus X).primeFactors.powerset,
            if badPrimeSubsetModulus u ∣ n then
              (((-1 : ℤ) ^ u.card : ℤ) : ℝ) else 0 := by
          rw [Finset.sum_comm]
    _ = ∑ n ∈ W,
          if Nat.Coprime n (roughModulus X) then (1 : ℝ) else 0 := by
          apply Finset.sum_congr rfl
          intro n _hn
          have hfilter :
              (roughModulus X).primeFactors.powerset.filter
                  (fun u : Finset ℕ => badPrimeSubsetModulus u ∣ n) =
                (roughModulus X).primeFactors.powerset.filter
                  (fun u : Finset ℕ => ∀ p ∈ u, p ∣ n) := by
            ext u
            by_cases hu : u ∈ (roughModulus X).primeFactors.powerset
            · have hsubset : u ⊆ (roughModulus X).primeFactors :=
                Finset.mem_powerset.mp hu
              have huprime : ∀ p ∈ u, Nat.Prime p := by
                intro p hp
                exact Nat.prime_of_mem_primeFactors (hsubset hp)
              simp [hu, (badPrimeSubsetModulus_dvd_iff huprime)]
            · simp [hu]
          calc
            ∑ u ∈ (roughModulus X).primeFactors.powerset,
              (if badPrimeSubsetModulus u ∣ n then
                (((-1 : ℤ) ^ u.card : ℤ) : ℝ) else 0)
                = ∑ u ∈
                    (roughModulus X).primeFactors.powerset.filter
                      (fun u : Finset ℕ => badPrimeSubsetModulus u ∣ n),
                    (((-1 : ℤ) ^ u.card : ℤ) : ℝ) := by
                  rw [Finset.sum_filter]
            _ = ∑ u ∈ (badPrimeFactors (roughModulus X) n).powerset,
                    (((-1 : ℤ) ^ u.card : ℤ) : ℝ) := by
                  rw [hfilter, ← badPrimeFactors_powerset_eq_filter]
            _ = if Nat.Coprime n (roughModulus X) then (1 : ℝ) else 0 := by
                  have h :=
                    congrArg (fun z : ℤ => (z : ℝ))
                      (roughModulus_badPrimeFactors_parity_sum X n)
                  simpa using h
    _ = (((W.filter
          (fun n : ℕ => Nat.Coprime n (roughModulus X))).card : ℕ) : ℝ) := by
          rw [Finset.card_eq_sum_ones, ← Finset.sum_filter]
          simp

/-- The dyadic rough-window count is the difference of the two corresponding
initial coprime counts.  This is only finite endpoint bookkeeping: the window
`t < n ≤ 2t` is `Ioc ⌊t⌋₊ ⌊2t⌋₊` for nonnegative `t`. -/
theorem roughDyadicRoughWindowCount_eq_initialCoprimeCount_sub
    (X : ℝ) {t : ℝ} (ht : 0 ≤ t) :
    roughDyadicRoughWindowCount X t =
      roughInitialCoprimeCount X ⌊2 * t⌋₊ -
        roughInitialCoprimeCount X ⌊t⌋₊ := by
  classical
  let L : ℕ := ⌊t⌋₊
  let U : ℕ := ⌊2 * t⌋₊
  let P : ℕ → Prop := fun n : ℕ => Nat.Coprime n (roughModulus X)
  let A : Finset ℕ := (Finset.Icc (1 : ℕ) U).filter P
  let B : Finset ℕ := (Finset.Icc (1 : ℕ) L).filter P
  let W : Finset ℕ := (natWindow t (2 * t)).filter P
  have htwo_t : 0 ≤ 2 * t := mul_nonneg (by norm_num) ht
  have hLU : L ≤ U := by
    dsimp [L, U]
    exact Nat.floor_mono (by linarith : t ≤ 2 * t)
  have hBsubA : B ⊆ A := by
    intro n hn
    rcases Finset.mem_filter.mp hn with ⟨hnIcc, hnP⟩
    rcases Finset.mem_Icc.mp hnIcc with ⟨hn1, hnL⟩
    exact Finset.mem_filter.mpr
      ⟨Finset.mem_Icc.mpr ⟨hn1, le_trans hnL hLU⟩, hnP⟩
  have hW : W = A \ B := by
    ext n
    constructor
    · intro hn
      rcases Finset.mem_filter.mp hn with ⟨hnw, hnP⟩
      unfold natWindow at hnw
      rcases Finset.mem_filter.mp hnw with ⟨hnIcc, htlt⟩
      rcases Finset.mem_Icc.mp hnIcc with ⟨hn1, hnU⟩
      refine Finset.mem_sdiff.mpr ?_
      constructor
      · exact Finset.mem_filter.mpr
          ⟨Finset.mem_Icc.mpr ⟨hn1, by simpa [U] using hnU⟩, hnP⟩
      · intro hnB
        rcases Finset.mem_filter.mp hnB with ⟨hnBIcc, _hnPB⟩
        have hnL : n ≤ L := (Finset.mem_Icc.mp hnBIcc).2
        have hn_le_t : (n : ℝ) ≤ t := by
          calc
            (n : ℝ) ≤ (L : ℝ) := by exact_mod_cast hnL
            _ ≤ t := by
              dsimp [L]
              exact Nat.floor_le ht
        linarith
    · intro hn
      rcases Finset.mem_sdiff.mp hn with ⟨hnA, hnnotB⟩
      rcases Finset.mem_filter.mp hnA with ⟨hnAIcc, hnP⟩
      rcases Finset.mem_Icc.mp hnAIcc with ⟨hn1, hnU⟩
      have hLn : L < n := by
        by_contra hnot
        have hnL : n ≤ L := le_of_not_gt hnot
        exact hnnotB (Finset.mem_filter.mpr
          ⟨Finset.mem_Icc.mpr ⟨hn1, hnL⟩, hnP⟩)
      have htlt : t < (n : ℝ) := by
        simpa [L] using (Nat.floor_lt ht).mp hLn
      exact Finset.mem_filter.mpr
        ⟨by
          unfold natWindow
          exact Finset.mem_filter.mpr
            ⟨Finset.mem_Icc.mpr ⟨hn1, by simpa [U] using hnU⟩, htlt⟩,
          hnP⟩
  have hcard_nat : W.card = A.card - B.card := by
    rw [hW, Finset.card_sdiff hBsubA]
  have hBcard_le_Acard : B.card ≤ A.card :=
    Finset.card_le_card hBsubA
  have hcard_real :
      (W.card : ℝ) = (A.card : ℝ) - (B.card : ℝ) := by
    rw [hcard_nat, Nat.cast_sub hBcard_le_Acard]
  simpa [roughDyadicRoughWindowCount, roughInitialCoprimeCount, W, A, B, P, U, L]
    using hcard_real

/-- At one endpoint, the normalized residue potential is exactly the
continuous product-modulus main term minus the exact initial-segment multiples
count. -/
theorem roughBadPrimeSubsetProductMultiplesResiduePotential_eq_main_sub_initialMultiplesCount
    (N : ℕ) {u : Finset ℕ}
    (hupos : 0 < badPrimeSubsetModulus u) :
    roughBadPrimeSubsetProductMultiplesResiduePotential N u =
      (N : ℝ) / (badPrimeSubsetModulus u : ℝ) -
        roughBadPrimeSubsetInitialMultiplesCount N u := by
  let q : ℕ := badPrimeSubsetModulus u
  have hqpos : 0 < q := by simpa [q] using hupos
  have hq_ne : (q : ℝ) ≠ 0 := by exact_mod_cast hqpos.ne'
  rw [roughBadPrimeSubsetInitialMultiplesCount_eq_nat_div N hupos]
  unfold roughBadPrimeSubsetProductMultiplesResiduePotential
  change ((N % q : ℕ) : ℝ) / (q : ℝ) =
    (N : ℝ) / (q : ℝ) - ((N / q : ℕ) : ℝ)
  have hmod_add :
      ((N % q : ℕ) : ℝ) + (q : ℝ) * ((N / q : ℕ) : ℝ) = (N : ℝ) := by
    exact_mod_cast (Nat.mod_add_div N q)
  have hmod_eq :
      ((N % q : ℕ) : ℝ) =
        (N : ℝ) - (q : ℝ) * ((N / q : ℕ) : ℝ) := by
    linarith
  rw [hmod_eq]
  field_simp [hq_ne]

/-- The full alternating endpoint residue potential is the negative of the
initial-segment coprime-count discrepancy from its Euler-product main term. -/
theorem roughDyadicBadPrimeProductMultiplesResiduePotential_eq_main_sub_initialCoprimeCount
    (X : ℝ) (N : ℕ) :
    roughDyadicBadPrimeProductMultiplesResiduePotential X N =
      (N : ℝ) * roughDyadicBadPrimeMainEulerProduct X -
        roughInitialCoprimeCount X N := by
  classical
  calc
    roughDyadicBadPrimeProductMultiplesResiduePotential X N
        = roughDyadicBadPrimeProductMainTermSum X (N : ℝ) -
            roughDyadicBadPrimeInitialMultiplesCountSum X N := by
          unfold roughDyadicBadPrimeProductMultiplesResiduePotential
            roughDyadicBadPrimeProductMainTermSum
            roughDyadicBadPrimeInitialMultiplesCountSum
          rw [← Finset.sum_sub_distrib]
          refine Finset.sum_congr rfl ?_
          intro u hu
          rw [roughBadPrimeSubsetProductMultiplesResiduePotential_eq_main_sub_initialMultiplesCount
            N (badPrimeSubsetModulus_pos_of_mem_rough_powerset X hu)]
          ring
    _ = (N : ℝ) * roughDyadicBadPrimeMainEulerProduct X -
          roughInitialCoprimeCount X N := by
          rw [roughDyadicBadPrimeProductMainTermSum_eq_mul_eulerProduct,
            roughDyadicBadPrimeInitialMultiplesCountSum_eq_initialCoprimeCount]

/-- The nonempty alternating endpoint residue potential has the same
main-minus-count form, since the empty subset contributes zero. -/
theorem roughDyadicBadPrimeProductMultiplesNonemptyResiduePotential_eq_main_sub_initialCoprimeCount
    (X : ℝ) (N : ℕ) :
    roughDyadicBadPrimeProductMultiplesNonemptyResiduePotential X N =
      (N : ℝ) * roughDyadicBadPrimeMainEulerProduct X -
        roughInitialCoprimeCount X N := by
  rw [roughDyadicBadPrimeProductMultiplesNonemptyResiduePotential_eq_full,
    roughDyadicBadPrimeProductMultiplesResiduePotential_eq_main_sub_initialCoprimeCount]

/-- The rough-window count is nonnegative. -/
theorem roughDyadicRoughWindowCount_nonneg (X : ℝ) (t : ℝ) :
    0 ≤ roughDyadicRoughWindowCount X t := by
  unfold roughDyadicRoughWindowCount
  exact Nat.cast_nonneg _

/-- The rough-window count is bounded by the ambient dyadic window. -/
theorem roughDyadicRoughWindowCount_le_natWindow_card (X : ℝ) (t : ℝ) :
    roughDyadicRoughWindowCount X t ≤ ((natWindow t (2 * t)).card : ℝ) := by
  classical
  unfold roughDyadicRoughWindowCount
  exact_mod_cast Finset.card_le_card (Finset.filter_subset _ _)

/-- The rough-window count is bounded by the natural floor of the upper
endpoint `2t`. -/
theorem roughDyadicRoughWindowCount_le_floor_two_mul (X : ℝ) (t : ℝ) :
    roughDyadicRoughWindowCount X t ≤ (⌊2 * t⌋₊ : ℝ) :=
  le_trans (roughDyadicRoughWindowCount_le_natWindow_card X t)
    (natWindow_card_le_floor_upper t (2 * t))

/-- Foundation-only linear envelope for the rough-window count.  This proves
only the ambient-window estimate; the linear-sieve saving is the separate
analytic content. -/
theorem roughDyadicRoughWindowCount_le_two_mul
    (X : ℝ) {t : ℝ} (ht : 0 ≤ t) :
    roughDyadicRoughWindowCount X t ≤ 2 * t :=
  le_trans (roughDyadicRoughWindowCount_le_floor_two_mul X t)
    (Nat.floor_le (mul_nonneg (by norm_num) ht))

/-- Absolute-value form of the foundation-only rough-window count envelope. -/
theorem abs_roughDyadicRoughWindowCount_le_two_mul
    (X : ℝ) {t : ℝ} (ht : 0 ≤ t) :
    |roughDyadicRoughWindowCount X t| ≤ 2 * t := by
  rw [abs_of_nonneg (roughDyadicRoughWindowCount_nonneg X t)]
  exact roughDyadicRoughWindowCount_le_two_mul X ht

/-- Foundation-only linear envelope for the rough-window Euler-product
discrepancy.  The sharp rough-sieve input improves this crude `O(t)` bound to
an arbitrarily small multiple of `t/log z`; all finite carriers in this lemma
are axiom-free. -/
theorem roughDyadicRoughWindowEulerProductDiscrepancy_le_three_mul
    (X : ℝ) {t : ℝ} (ht : 0 ≤ t) :
    |roughDyadicRoughWindowCount X t -
        t * roughDyadicBadPrimeMainEulerProduct X| ≤ 3 * t := by
  have hcount :
      |roughDyadicRoughWindowCount X t| ≤ 2 * t :=
    abs_roughDyadicRoughWindowCount_le_two_mul X ht
  have hprod_nonneg : 0 ≤ roughDyadicBadPrimeMainEulerProduct X :=
    roughDyadicBadPrimeMainEulerProduct_nonneg X
  have hprod_le_one : roughDyadicBadPrimeMainEulerProduct X ≤ 1 :=
    roughDyadicBadPrimeMainEulerProduct_le_one X
  have hmain :
      |t * roughDyadicBadPrimeMainEulerProduct X| ≤ t := by
    rw [abs_of_nonneg (mul_nonneg ht hprod_nonneg)]
    exact mul_le_of_le_one_right ht hprod_le_one
  calc
    |roughDyadicRoughWindowCount X t -
        t * roughDyadicBadPrimeMainEulerProduct X|
        ≤ |roughDyadicRoughWindowCount X t| +
          |t * roughDyadicBadPrimeMainEulerProduct X| := by
          simpa [sub_eq_add_neg, abs_neg] using
            abs_add (roughDyadicRoughWindowCount X t)
              (-(t * roughDyadicBadPrimeMainEulerProduct X))
    _ ≤ 2 * t + t := add_le_add hcount hmain
    _ = 3 * t := by ring

/-- Dyadic-window count after imposing squarefreeness and rough-modulus
coprimality. -/
noncomputable def roughDyadicRoughSquarefreeWindowCount
    (X : ℝ) (t : ℝ) : ℝ :=
  (((natWindow t (2 * t)).filter
    (fun n : ℕ => Squarefree n ∧ Nat.Coprime n (roughModulus X))).card : ℝ)

/-- Dyadic-window count of rough integers that fail squarefreeness. -/
noncomputable def roughDyadicRoughNonSquarefreeWindowCount
    (X : ℝ) (t : ℝ) : ℝ :=
  (((natWindow t (2 * t)).filter
    (fun n : ℕ => Nat.Coprime n (roughModulus X) ∧ ¬ Squarefree n)).card : ℝ)

/-- Dyadic-window count of integers having a square prime divisor outside the
rough-modulus prime-factor set.  This is the concrete large-square tail that
controls the remaining signed squarefree upper input. -/
noncomputable def roughDyadicLargeSquareDivisorCount
    (X : ℝ) (t : ℝ) : ℝ :=
  by
    classical
    exact (((natWindow t (2 * t)).filter
      (fun n : ℕ =>
        ∃ p : ℕ, Nat.Prime p ∧ p ∉ (roughModulus X).primeFactors ∧ p ^ 2 ∣ n)).card : ℝ)

/-- Finite prime range supporting the concrete large-square tail.  A prime
outside the rough modulus and with `p² ∣ n ≤ 2t` must lie in this range. -/
noncomputable def roughDyadicLargeSquarePrimeTail
    (X : ℝ) (t : ℝ) : Finset ℕ :=
  (Finset.Icc (⌊EscAnalytic.zScale X⌋₊ + 1) ⌊2 * t⌋₊).filter
    (fun p : ℕ => Nat.Prime p)

/-- Union-bound envelope for the concrete large-square divisor tail. -/
noncomputable def roughDyadicLargeSquareDivisorEnvelopeSum
    (X : ℝ) (t : ℝ) : ℝ :=
  ∑ p ∈ roughDyadicLargeSquarePrimeTail X t,
    (((natWindow t (2 * t)).filter (fun n : ℕ => p ^ 2 ∣ n)).card : ℝ)

/-- Explicit floor-division envelope for the finite large-square divisor tail. -/
noncomputable def roughDyadicLargeSquareDivisorFloorEnvelopeSum
    (X : ℝ) (t : ℝ) : ℝ :=
  ∑ p ∈ roughDyadicLargeSquarePrimeTail X t,
    ((⌊2 * t⌋₊ / p ^ 2 : ℕ) : ℝ)

/-- Real reciprocal-prime-square envelope for the finite large-square divisor
tail.  This removes the floor divisions from the remaining analytic interface. -/
noncomputable def roughDyadicLargeSquareDivisorReciprocalEnvelopeSum
    (X : ℝ) (t : ℝ) : ℝ :=
  ∑ p ∈ roughDyadicLargeSquarePrimeTail X t,
    (2 * t) / ((p : ℝ) ^ 2)

/-- A prime not in the rough modulus lies above the natural rough cutoff. -/
theorem floor_zScale_lt_of_prime_not_mem_roughModulus_primeFactors
    {X : ℝ} {p : ℕ} (hp : Nat.Prime p)
    (hp_not_rough : p ∉ (roughModulus X).primeFactors) :
    ⌊EscAnalytic.zScale X⌋₊ < p := by
  classical
  by_contra hnot
  have hp_le : p ≤ ⌊EscAnalytic.zScale X⌋₊ := le_of_not_gt hnot
  have hp_mem : p ∈ (roughModulus X).primeFactors := by
    unfold roughModulus
    rw [primeProductBelow_primeFactors_eq]
    rw [Finset.mem_filter, Finset.mem_Icc]
    exact ⟨⟨hp.two_le, hp_le⟩, hp⟩
  exact hp_not_rough hp_mem

/-- The concrete large-square divisor count is bounded by the finite prime-tail
union-bound envelope. -/
theorem roughDyadicLargeSquareDivisorCount_le_envelopeSum
    (X : ℝ) (t : ℝ) :
    roughDyadicLargeSquareDivisorCount X t ≤
      roughDyadicLargeSquareDivisorEnvelopeSum X t := by
  classical
  let W : Finset ℕ := natWindow t (2 * t)
  let tail : Finset ℕ := roughDyadicLargeSquarePrimeTail X t
  let A : Finset ℕ := W.filter
    (fun n : ℕ =>
      ∃ p : ℕ, Nat.Prime p ∧ p ∉ (roughModulus X).primeFactors ∧ p ^ 2 ∣ n)
  let U : Finset ℕ := tail.biUnion (fun p : ℕ =>
    W.filter (fun n : ℕ => p ^ 2 ∣ n))
  have hsub : A ⊆ U := by
    intro n hn
    have hn' :
        n ∈ W ∧
          ∃ p : ℕ, Nat.Prime p ∧
            p ∉ (roughModulus X).primeFactors ∧ p ^ 2 ∣ n := by
      simpa [A] using (Finset.mem_filter.mp hn)
    rcases hn'.2 with ⟨p, hp, hp_not_rough, hp2dvd⟩
    have hp_lower : ⌊EscAnalytic.zScale X⌋₊ + 1 ≤ p :=
      Nat.succ_le_of_lt
        (floor_zScale_lt_of_prime_not_mem_roughModulus_primeFactors
          hp hp_not_rough)
    have hn_le : n ≤ ⌊2 * t⌋₊ := by
      unfold W natWindow at hn'
      exact (Finset.mem_Icc.mp (Finset.mem_filter.mp hn'.1).1).2
    have hp_dvd_n : p ∣ n :=
      dvd_trans (dvd_mul_right p p) (by simpa [pow_two] using hp2dvd)
    have hp_upper : p ≤ ⌊2 * t⌋₊ := by
      have hn_pos : 0 < n := by
        unfold W natWindow at hn'
        exact lt_of_lt_of_le Nat.zero_lt_one
          (Finset.mem_Icc.mp (Finset.mem_filter.mp hn'.1).1).1
      exact le_trans (Nat.le_of_dvd hn_pos hp_dvd_n) hn_le
    have hp_tail : p ∈ tail := by
      change p ∈ roughDyadicLargeSquarePrimeTail X t
      rw [roughDyadicLargeSquarePrimeTail, Finset.mem_filter, Finset.mem_Icc]
      exact ⟨⟨hp_lower, hp_upper⟩, hp⟩
    change n ∈ tail.biUnion (fun p : ℕ => W.filter (fun n : ℕ => p ^ 2 ∣ n))
    rw [Finset.mem_biUnion]
    refine ⟨p, hp_tail, ?_⟩
    rw [Finset.mem_filter]
    exact ⟨hn'.1, hp2dvd⟩
  have hcard_U :
      U.card ≤ ∑ p ∈ tail, (W.filter (fun n : ℕ => p ^ 2 ∣ n)).card := by
    simpa [U] using
      (Finset.card_biUnion_le
        (s := tail) (t := fun p : ℕ => W.filter (fun n : ℕ => p ^ 2 ∣ n)))
  have hcard_nat :
      A.card ≤ ∑ p ∈ tail, (W.filter (fun n : ℕ => p ^ 2 ∣ n)).card := by
    exact (Finset.card_le_card hsub).trans hcard_U
  have hcard_real :
      (A.card : ℝ) ≤
        ∑ p ∈ tail, ((W.filter (fun n : ℕ => p ^ 2 ∣ n)).card : ℝ) := by
    exact_mod_cast hcard_nat
  simpa [roughDyadicLargeSquareDivisorCount,
    roughDyadicLargeSquareDivisorEnvelopeSum, W, tail, A]
    using hcard_real

/-- The finite large-square divisor envelope is bounded termwise by its explicit
floor-division envelope. -/
theorem roughDyadicLargeSquareDivisorEnvelopeSum_le_floorEnvelopeSum
    (X : ℝ) (t : ℝ) :
    roughDyadicLargeSquareDivisorEnvelopeSum X t ≤
      roughDyadicLargeSquareDivisorFloorEnvelopeSum X t := by
  classical
  unfold roughDyadicLargeSquareDivisorEnvelopeSum
    roughDyadicLargeSquareDivisorFloorEnvelopeSum
  apply Finset.sum_le_sum
  intro p hp
  have hpPrime : Nat.Prime p := (Finset.mem_filter.mp hp).2
  have hp2_pos : 0 < p ^ 2 := pow_pos hpPrime.pos 2
  simpa using
    natWindow_multiples_card_le_floor_div t (2 * t) hp2_pos

/-- The floor-division large-square envelope is bounded termwise by the real
reciprocal-prime-square envelope. -/
theorem roughDyadicLargeSquareDivisorFloorEnvelopeSum_le_reciprocalEnvelopeSum
    (X : ℝ) {t : ℝ} (ht : 0 ≤ t) :
    roughDyadicLargeSquareDivisorFloorEnvelopeSum X t ≤
      roughDyadicLargeSquareDivisorReciprocalEnvelopeSum X t := by
  classical
  unfold roughDyadicLargeSquareDivisorFloorEnvelopeSum
    roughDyadicLargeSquareDivisorReciprocalEnvelopeSum
  apply Finset.sum_le_sum
  intro p hp
  have htwo_nonneg : 0 ≤ 2 * t := mul_nonneg (by norm_num) ht
  have hfloor_le : (⌊2 * t⌋₊ : ℝ) ≤ 2 * t :=
    Nat.floor_le htwo_nonneg
  have hcast :
      ((⌊2 * t⌋₊ / p ^ 2 : ℕ) : ℝ)
        ≤ (⌊2 * t⌋₊ : ℝ) / ((p ^ 2 : ℕ) : ℝ) :=
    Nat.cast_div_le
  have hdiv :
      (⌊2 * t⌋₊ : ℝ) / ((p ^ 2 : ℕ) : ℝ)
        ≤ (2 * t) / ((p ^ 2 : ℕ) : ℝ) :=
    div_le_div_of_nonneg_right hfloor_le (Nat.cast_nonneg _)
  exact hcast.trans (by simpa [Nat.cast_pow] using hdiv)

/-- The prime-square tail support is contained in the full integer square tail
above the rough cutoff. -/
theorem roughDyadicLargeSquarePrimeTail_inv_sq_sum_le_Ioc
    (X : ℝ) (t : ℝ) :
    (∑ p ∈ roughDyadicLargeSquarePrimeTail X t,
        ((p : ℝ) ^ 2)⁻¹)
      ≤ ∑ n ∈ Finset.Ioc ⌊EscAnalytic.zScale X⌋₊ ⌊2 * t⌋₊,
          ((n : ℝ) ^ 2)⁻¹ := by
  classical
  apply Finset.sum_le_sum_of_subset_of_nonneg
  · intro p hp
    rw [roughDyadicLargeSquarePrimeTail, Finset.mem_filter, Finset.mem_Icc] at hp
    rw [Finset.mem_Ioc]
    exact ⟨Nat.lt_of_succ_le hp.1.1, hp.1.2⟩
  · intro n _hn_big _hn_tail
    exact inv_nonneg.mpr (sq_nonneg (n : ℝ))

/-- The reciprocal-prime-square tail is bounded by the reciprocal of the natural
rough cutoff. -/
theorem roughDyadicLargeSquarePrimeTail_inv_sq_sum_le_floor_zScale_inv
    (X : ℝ) (t : ℝ) (hX : Real.exp 1 ≤ X) :
    (∑ p ∈ roughDyadicLargeSquarePrimeTail X t,
        ((p : ℝ) ^ 2)⁻¹)
      ≤ ((⌊EscAnalytic.zScale X⌋₊ : ℕ) : ℝ)⁻¹ := by
  classical
  let k : ℕ := ⌊EscAnalytic.zScale X⌋₊
  let n : ℕ := ⌊2 * t⌋₊
  have hk_one : 1 ≤ k := by
    exact Nat.le_floor (by simpa [k] using zScale_ge_one_of_exp_one_le hX)
  have hk_ne : k ≠ 0 := by omega
  have hsub :
      (∑ p ∈ roughDyadicLargeSquarePrimeTail X t,
          ((p : ℝ) ^ 2)⁻¹)
        ≤ ∑ m ∈ Finset.Ioc k n, ((m : ℝ) ^ 2)⁻¹ := by
    simpa [k, n] using roughDyadicLargeSquarePrimeTail_inv_sq_sum_le_Ioc X t
  by_cases hkn : k ≤ n
  · have htail :=
      (sum_Ioc_inv_sq_le_sub (α := ℝ) (k := k) (n := n) hk_ne hkn)
    have hn_inv_nonneg : 0 ≤ ((n : ℝ)⁻¹) :=
      inv_nonneg.mpr (Nat.cast_nonneg n)
    have hIoc_le : (∑ m ∈ Finset.Ioc k n, ((m : ℝ) ^ 2)⁻¹) ≤ (k : ℝ)⁻¹ := by
      linarith
    exact hsub.trans hIoc_le
  · have hn_le_k : n ≤ k := le_of_lt (lt_of_not_ge hkn)
    have hIoc_empty : Finset.Ioc k n = ∅ :=
      Finset.Ioc_eq_empty_of_le hn_le_k
    have hsum_nonpos :
        (∑ p ∈ roughDyadicLargeSquarePrimeTail X t,
            ((p : ℝ) ^ 2)⁻¹) ≤ 0 := by
      simpa [hIoc_empty] using hsub
    exact hsum_nonpos.trans (inv_nonneg.mpr (Nat.cast_nonneg k))

/-- The reciprocal-prime-square envelope is bounded by `4t/z(X)` for large
`X`.  The constant absorbs the natural floor in the rough cutoff. -/
theorem roughDyadicLargeSquareDivisorReciprocalEnvelopeSum_le_four_mul_t_div_zScale
    (X : ℝ) {t : ℝ} (hX : Real.exp 2 ≤ X) (ht : 0 ≤ t) :
    roughDyadicLargeSquareDivisorReciprocalEnvelopeSum X t
      ≤ (4 * t) / EscAnalytic.zScale X := by
  classical
  have hXexp1 : Real.exp 1 ≤ X :=
    le_trans (Real.exp_le_exp.mpr (by norm_num : (1 : ℝ) ≤ 2)) hX
  have hz_ge_two : (2 : ℝ) ≤ EscAnalytic.zScale X := by
    have hXpos : 0 < X := lt_of_lt_of_le (Real.exp_pos 2) hX
    have hlogX_ge_two : (2 : ℝ) ≤ Real.log X := by
      rw [Real.le_log_iff_exp_le hXpos]
      exact hX
    unfold EscAnalytic.zScale
    nlinarith [sq_nonneg ((Real.log X) ^ 2 - 2)]
  have hz_pos : 0 < EscAnalytic.zScale X :=
    lt_of_lt_of_le (by norm_num : (0 : ℝ) < 2) hz_ge_two
  have hfloor_gt :
      EscAnalytic.zScale X - 1 <
        ((⌊EscAnalytic.zScale X⌋₊ : ℕ) : ℝ) :=
    Nat.sub_one_lt_floor (EscAnalytic.zScale X)
  have hz_half_le_floor :
      EscAnalytic.zScale X / 2 ≤
        ((⌊EscAnalytic.zScale X⌋₊ : ℕ) : ℝ) := by
    linarith
  have hfloor_pos :
      0 < ((⌊EscAnalytic.zScale X⌋₊ : ℕ) : ℝ) := by
    linarith
  have hinv_floor_le :
      (((⌊EscAnalytic.zScale X⌋₊ : ℕ) : ℝ)⁻¹)
        ≤ 2 / EscAnalytic.zScale X := by
    rw [inv_le_comm₀ hfloor_pos (by positivity : (0 : ℝ) < 2 / EscAnalytic.zScale X)]
    field_simp [ne_of_gt hz_pos]
    linarith
  have hsum :=
    roughDyadicLargeSquarePrimeTail_inv_sq_sum_le_floor_zScale_inv
      X t hXexp1
  have hcoef_nonneg : 0 ≤ 2 * t := mul_nonneg (by norm_num) ht
  calc
    roughDyadicLargeSquareDivisorReciprocalEnvelopeSum X t
        = (2 * t) *
            ∑ p ∈ roughDyadicLargeSquarePrimeTail X t,
              ((p : ℝ) ^ 2)⁻¹ := by
          unfold roughDyadicLargeSquareDivisorReciprocalEnvelopeSum
          rw [Finset.mul_sum]
          simp [div_eq_mul_inv]
    _ ≤ (2 * t) * (((⌊EscAnalytic.zScale X⌋₊ : ℕ) : ℝ)⁻¹) :=
          mul_le_mul_of_nonneg_left hsum hcoef_nonneg
    _ ≤ (2 * t) * (2 / EscAnalytic.zScale X) :=
          mul_le_mul_of_nonneg_left hinv_floor_le hcoef_nonneg
    _ = (4 * t) / EscAnalytic.zScale X := by ring

/-- The reciprocal-prime-square large-square envelope is eventually smaller
than any prescribed positive multiple of `t/log z(X)`. -/
theorem roughDyadicLargeSquareDivisorReciprocalEnvelopeSum_le_eps_mul_t_div_log_zScale
    (X : ℝ) {eps t : ℝ}
    (hX : Real.exp (max 2 (2 * (7 + 1) / eps)) ≤ X) (heps : 0 < eps)
    (ht : 0 ≤ t) :
    roughDyadicLargeSquareDivisorReciprocalEnvelopeSum X t
      ≤ eps * (t / Real.log (EscAnalytic.zScale X)) := by
  have hXexp2 : Real.exp 2 ≤ X :=
    le_trans (Real.exp_le_exp.mpr (le_max_left _ _)) hX
  have hXexp1 : Real.exp 1 ≤ X :=
    le_trans (Real.exp_le_exp.mpr (by norm_num : (1 : ℝ) ≤ 2)) hXexp2
  have hz_pos : 0 < EscAnalytic.zScale X :=
    lt_of_lt_of_le zero_lt_one (zScale_ge_one_of_exp_one_le hXexp1)
  have hlogZ_pos : 0 < Real.log (EscAnalytic.zScale X) :=
    log_zScale_pos_of_exp_two_le hXexp2
  have htail :
      roughDyadicLargeSquareDivisorReciprocalEnvelopeSum X t
        ≤ (4 * t) / EscAnalytic.zScale X :=
    roughDyadicLargeSquareDivisorReciprocalEnvelopeSum_le_four_mul_t_div_zScale
      X hXexp2 ht
  have hcoeff :
      (2 * (7 + 1) * Real.log X) / EscAnalytic.zScale X ≤ eps := by
    simpa using
      (two_mul_C_add_one_mul_log_div_zScale_le_eps
        (X := X) (C := 7) (eps := eps) hX (by norm_num) heps)
  have hlogZ_le : Real.log (EscAnalytic.zScale X) ≤ 4 * Real.log X :=
    EscAnalytic.log_zScale_le_four_log hXexp1
  have hcoeff' :
      (4 * Real.log (EscAnalytic.zScale X)) / EscAnalytic.zScale X ≤ eps := by
    have hnum :
        4 * Real.log (EscAnalytic.zScale X) ≤ 2 * (7 + 1) * Real.log X := by
      nlinarith
    have hdiv :
        (4 * Real.log (EscAnalytic.zScale X)) / EscAnalytic.zScale X
          ≤ (2 * (7 + 1) * Real.log X) / EscAnalytic.zScale X :=
      div_le_div_of_nonneg_right hnum hz_pos.le
    exact hdiv.trans hcoeff
  have hT_nonneg : 0 ≤ t / Real.log (EscAnalytic.zScale X) :=
    div_nonneg ht hlogZ_pos.le
  have hfour :
      (4 * t) / EscAnalytic.zScale X
        = ((4 * Real.log (EscAnalytic.zScale X)) / EscAnalytic.zScale X) *
            (t / Real.log (EscAnalytic.zScale X)) := by
    field_simp [ne_of_gt hz_pos, ne_of_gt hlogZ_pos]
    ring
  calc
    roughDyadicLargeSquareDivisorReciprocalEnvelopeSum X t
        ≤ (4 * t) / EscAnalytic.zScale X := htail
    _ = ((4 * Real.log (EscAnalytic.zScale X)) / EscAnalytic.zScale X) *
          (t / Real.log (EscAnalytic.zScale X)) := hfour
    _ ≤ eps * (t / Real.log (EscAnalytic.zScale X)) :=
          mul_le_mul_of_nonneg_right hcoeff' hT_nonneg

/-- Multiples-only inclusion-exclusion counts exactly the integers coprime to
the rough modulus. -/
theorem roughDyadicBadPrimeProductMultiplesCountSum_eq_roughWindowCount
    (X : ℝ) (t : ℝ) :
    roughDyadicBadPrimeProductMultiplesCountSum X t =
      roughDyadicRoughWindowCount X t := by
  classical
  let W : Finset ℕ := natWindow t (2 * t)
  let primes : Finset (Finset ℕ) := (roughModulus X).primeFactors.powerset
  have hcount :
      ∀ u : Finset ℕ,
        (roughBadPrimeSubsetProductMultiplesCount X t u) =
          ∑ n ∈ W, if badPrimeSubsetModulus u ∣ n then (1 : ℝ) else 0 := by
    intro u
    unfold roughBadPrimeSubsetProductMultiplesCount
    dsimp [W]
    rw [Finset.card_eq_sum_ones, ← Finset.sum_filter]
    simp
  unfold roughDyadicBadPrimeProductMultiplesCountSum roughDyadicRoughWindowCount
  calc
    ∑ u ∈ (roughModulus X).primeFactors.powerset,
        (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
          roughBadPrimeSubsetProductMultiplesCount X t u
        = ∑ u ∈ (roughModulus X).primeFactors.powerset,
            ∑ n ∈ W,
              if badPrimeSubsetModulus u ∣ n then
                (((-1 : ℤ) ^ u.card : ℤ) : ℝ) else 0 := by
          apply Finset.sum_congr rfl
          intro u _hu
          rw [hcount u, Finset.mul_sum]
          apply Finset.sum_congr rfl
          intro n _hn
          by_cases hdiv : badPrimeSubsetModulus u ∣ n
          · simp [hdiv]
          · simp [hdiv]
    _ = ∑ n ∈ W,
          ∑ u ∈ (roughModulus X).primeFactors.powerset,
            if badPrimeSubsetModulus u ∣ n then
              (((-1 : ℤ) ^ u.card : ℤ) : ℝ) else 0 := by
          rw [Finset.sum_comm]
    _ = ∑ n ∈ W,
          if Nat.Coprime n (roughModulus X) then (1 : ℝ) else 0 := by
          apply Finset.sum_congr rfl
          intro n _hn
          have hfilter :
              (roughModulus X).primeFactors.powerset.filter
                  (fun u : Finset ℕ => badPrimeSubsetModulus u ∣ n) =
                (roughModulus X).primeFactors.powerset.filter
                  (fun u : Finset ℕ => ∀ p ∈ u, p ∣ n) := by
            ext u
            by_cases hu : u ∈ (roughModulus X).primeFactors.powerset
            · have hsubset : u ⊆ (roughModulus X).primeFactors :=
                Finset.mem_powerset.mp hu
              have huprime : ∀ p ∈ u, Nat.Prime p := by
                intro p hp
                exact Nat.prime_of_mem_primeFactors (hsubset hp)
              simp [hu, (badPrimeSubsetModulus_dvd_iff huprime)]
            · simp [hu]
          calc
            ∑ u ∈ (roughModulus X).primeFactors.powerset,
              (if badPrimeSubsetModulus u ∣ n then
                (((-1 : ℤ) ^ u.card : ℤ) : ℝ) else 0)
                = ∑ u ∈
                    (roughModulus X).primeFactors.powerset.filter
                      (fun u : Finset ℕ => badPrimeSubsetModulus u ∣ n),
                    (((-1 : ℤ) ^ u.card : ℤ) : ℝ) := by
                  rw [Finset.sum_filter]
            _ = ∑ u ∈ (badPrimeFactors (roughModulus X) n).powerset,
                    (((-1 : ℤ) ^ u.card : ℤ) : ℝ) := by
                  rw [hfilter, ← badPrimeFactors_powerset_eq_filter]
            _ = if Nat.Coprime n (roughModulus X) then (1 : ℝ) else 0 := by
                  have h :=
                    congrArg (fun z : ℤ => (z : ℝ))
                      (roughModulus_badPrimeFactors_parity_sum X n)
                  simpa using h
    _ = (((W.filter
          (fun n : ℕ => Nat.Coprime n (roughModulus X))).card : ℕ) : ℝ) := by
          rw [Finset.card_eq_sum_ones, ← Finset.sum_filter]
          simp

/-- The signed multiples-discrepancy carrier is exactly the difference between
the rough dyadic count and the finite Euler-product main term.

This identifies the remaining signed-multiples input with the genuine
modulus-one linear-sieve discrepancy, rather than a byproduct of the
inclusion-exclusion expansion. -/
theorem roughDyadicBadPrimeProductMultiplesSignedErrorSum_eq_roughWindowCount_sub_main
    (X : ℝ) (t : ℝ) :
    roughDyadicBadPrimeProductMultiplesSignedErrorSum X t =
      roughDyadicRoughWindowCount X t -
        t * roughDyadicBadPrimeMainEulerProduct X := by
  unfold roughDyadicBadPrimeProductMultiplesSignedErrorSum
    roughBadPrimeSubsetProductMultiplesLocalError
  calc
    ∑ u ∈ (roughModulus X).primeFactors.powerset,
        (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
          (roughBadPrimeSubsetProductMultiplesCount X t u -
            t / (badPrimeSubsetModulus u : ℝ))
        = (∑ u ∈ (roughModulus X).primeFactors.powerset,
            (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
              roughBadPrimeSubsetProductMultiplesCount X t u) -
          ∑ u ∈ (roughModulus X).primeFactors.powerset,
            (((-1 : ℤ) ^ u.card : ℤ) : ℝ) *
              (t / (badPrimeSubsetModulus u : ℝ)) := by
          rw [← Finset.sum_sub_distrib]
          apply Finset.sum_congr rfl
          intro u _hu
          ring
    _ = roughDyadicRoughWindowCount X t -
        t * roughDyadicBadPrimeMainEulerProduct X := by
          change roughDyadicBadPrimeProductMultiplesCountSum X t -
              roughDyadicBadPrimeProductMainTermSum X t =
            roughDyadicRoughWindowCount X t -
              t * roughDyadicBadPrimeMainEulerProduct X
          rw [roughDyadicBadPrimeProductMultiplesCountSum_eq_roughWindowCount,
            roughDyadicBadPrimeProductMainTermSum_eq_mul_eulerProduct]

/-- Squarefree-only inclusion-exclusion counts exactly the squarefree integers
coprime to the rough modulus. -/
theorem roughDyadicBadPrimeProductSquarefreeCountSum_eq_roughSquarefreeWindowCount
    (X : ℝ) (t : ℝ) :

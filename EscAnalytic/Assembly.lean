/-- Large-range concrete reduced-carrier saving from the fixed-`m` analytic core.

Unlike the global version below, this theorem does not enlarge a finite initial
constant.  On the range where the fixed-`m` Suen core is valid, the concrete
carrier is bounded by `N * saving H.c N` with coefficient `1`.  This is the
form needed for later uniformization, since no constant depending on `m` is
introduced. -/
theorem fixedNumeratorReducedSumCount_large_saving_of_paper_suen_analytic_core_exact_reduced_carrier
    {ι : Type*} {m : ℕ}
    (H : FixedNumeratorPaperSuenAnalyticCoreInputs m ι)
    (hEred_sum_exact : ∀ N : ℕ, 3 ≤ N →
      (fixedNumeratorReducedSumCount m (zNatScale N) N : ℝ) ≤
        ∑ b ∈ H.cls N, H.Mb N b) :
    ∀ N : ℕ, 3 ≤ N → H.T ≤ N →
      (fixedNumeratorReducedSumCount m (zNatScale N) N : ℝ) ≤
        (N : ℝ) * saving H.c N := by
  let Hexact :=
    fixedNumeratorPaperSuenAnalyticCoreInputs_with_exact_reduced_carrier
      H hEred_sum_exact
  intro N hN hTN
  have htransfer :
      ∀ b ∈ Hexact.cls N,
        Hexact.Mb N b ≤ ((N : ℝ) / Hexact.Pz N) *
          Real.exp (-(1 - (Hexact.εb N + Real.log 3 / Hexact.μ N)) *
            Hexact.μ N) :=
    per_class_transfer_of_suen_finite_transfer_on_range_standard_tail
      Hexact.cls Hexact.Mb Hexact.Pz Hexact.μ Hexact.εb Hexact.δb
      Hexact.Δb Hexact.Xpow Hexact.errTerm Hexact.F2R Hexact.εK Hexact.T
      Hexact.mu_pos Hexact.Pz_ge_one Hexact.delta_nonneg Hexact.Delta_nonneg
      Hexact.Xpow_nonneg Hexact.suen_tail Hexact.decomp Hexact.err_bound
      Hexact.eps_le_one Hexact.level Hexact.F2R_bound N hN hTN
  have hsum :
      (∑ b ∈ Hexact.cls N, Hexact.Mb N b) ≤
        (N : ℝ) * saving Hexact.c N :=
    Ered_bound_of_finite_transfer_of_one_le (Hexact.cls N)
      (Hexact.Pz_ge_one N hN hTN) (by positivity)
      (Hexact.class_card N hN hTN) htransfer (Hexact.saving_bound N hN hTN)
  calc
    (fixedNumeratorReducedSumCount m (zNatScale N) N : ℝ)
        = (Hexact.Ered N : ℝ) := by rfl
    _ ≤ ∑ b ∈ Hexact.cls N, Hexact.Mb N b := Hexact.Ered_sum N hN
    _ ≤ (N : ℝ) * saving Hexact.c N := hsum
    _ = (N : ℝ) * saving H.c N := by
      simp [Hexact, fixedNumeratorPaperSuenAnalyticCoreInputs_with_exact_reduced_carrier]

/-- Concrete reduced-carrier saving extracted from the fixed-`m` analytic core.

This is the direct `E_red` projection of the exact-carrier wrapper: once the
finite reduced carrier is dominated by the paper's reduced-class majorants, the
Suen finite-transfer data in `H` give an all-`N >= 3` saving bound for
`fixedNumeratorReducedSumCount m (zNatScale N) N` itself.  No lifting or final
exceptional-set assembly is used here. -/
theorem fixedNumeratorReducedSumCount_saving_of_paper_suen_analytic_core_exact_reduced_carrier
    {ι : Type*} {m : ℕ}
    (H : FixedNumeratorPaperSuenAnalyticCoreInputs m ι)
    (hEred_sum_exact : ∀ N : ℕ, 3 ≤ N →
      (fixedNumeratorReducedSumCount m (zNatScale N) N : ℝ) ≤
        ∑ b ∈ H.cls N, H.Mb N b) :
    ∃ c > (0 : ℝ), ∃ C > (0 : ℝ), ∀ N : ℕ, 3 ≤ N →
      (fixedNumeratorReducedSumCount m (zNatScale N) N : ℝ) ≤
        C * ((N : ℝ) * saving c N) := by
  let Hexact :=
    fixedNumeratorPaperSuenAnalyticCoreInputs_with_exact_reduced_carrier
      H hEred_sum_exact
  let hinit := finite_initial_saving_bound Hexact.Ered Hexact.c_pos Hexact.T
  let Cinit : ℝ := Classical.choose hinit
  have hCinit_spec : 0 < Cinit ∧
      ∀ N : ℕ, 3 ≤ N → N < Hexact.T →
        (Hexact.Ered N : ℝ) ≤ Cinit * ((N : ℝ) * saving Hexact.c N) :=
    Classical.choose_spec hinit
  rcases
    Ered_bound_global_of_large_suen_finite_transfer_ingredients_and_initial_standard_tail
      Hexact.cls Hexact.Mb Hexact.Ered Hexact.Pz Hexact.μ Hexact.εb
      Hexact.δb Hexact.Δb Hexact.Xpow Hexact.errTerm Hexact.F2R Hexact.εK
      Hexact.c Cinit Hexact.T Hexact.c_pos hCinit_spec.1 Hexact.Ered_sum
      Hexact.mu_pos Hexact.Pz_ge_one Hexact.delta_nonneg Hexact.Delta_nonneg
      Hexact.Xpow_nonneg Hexact.suen_tail Hexact.decomp Hexact.err_bound
      Hexact.eps_le_one Hexact.level Hexact.F2R_bound Hexact.class_card
      Hexact.saving_bound hCinit_spec.2 with
    ⟨C, hC_pos, hbound⟩
  refine ⟨Hexact.c, Hexact.c_pos, C, hC_pos, ?_⟩
  intro N hN
  simpa [Hexact, fixedNumeratorPaperSuenAnalyticCoreInputs_with_exact_reduced_carrier]
    using hbound N hN

